import 'package:flutter/material.dart';
import 'package:provider/provider.dart';
import '../providers/shipment_provider.dart';
import '../services/api_service.dart';

class ShipmentsScreen extends StatefulWidget {
  const ShipmentsScreen({Key? key}) : super(key: key);

  @override
  State<ShipmentsScreen> createState() => _ShipmentsScreenState();
}

class _ShipmentsScreenState extends State<ShipmentsScreen>
    with SingleTickerProviderStateMixin {
  late TabController _tabController;
  final ApiService _apiService = ApiService();
  String _selectedStatus = 'all';

  @override
  void initState() {
    super.initState();
    _tabController = TabController(length: 5, vsync: this);
    _loadShipments();
  }

  @override
  void dispose() {
    _tabController.dispose();
    super.dispose();
  }

  void _loadShipments() async {
    await Provider.of<ShipmentProvider>(context, listen: false)
        .fetchShipments();
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: const Text('الشحنات'),
        centerTitle: true,
        bottom: TabBar(
          controller: _tabController,
          isScrollable: true,
          tabs: const [
            Tab(text: 'الكل'),
            Tab(text: 'قيد الانتظار'),
            Tab(text: 'قيد النقل'),
            Tab(text: 'مكتملة'),
            Tab(text: 'ملغاة'),
          ],
          onTap: (index) {
            const statuses = [
              'all',
              'pending',
              'in_transit',
              'delivered',
              'cancelled'
            ];
            setState(() {
              _selectedStatus = statuses[index];
            });
            _loadShipments();
          },
        ),
      ),
      body: Consumer<ShipmentProvider>(
        builder: (context, shipmentProvider, child) {
          if (shipmentProvider.isLoading) {
            return const Center(child: CircularProgressIndicator());
          }

          final shipments = _filterShipments(shipmentProvider.shipments);

          if (shipments.isEmpty) {
            return Center(
              child: Column(
                mainAxisAlignment: MainAxisAlignment.center,
                children: [
                  Icon(
                    Icons.inbox,
                    size: 64,
                    color: Colors.grey[600],
                  ),
                  const SizedBox(height: 16),
                  Text(
                    'لا توجد شحنات',
                    style: Theme.of(context).textTheme.headline6?.copyWith(
                          color: Colors.grey[400],
                        ),
                  ),
                ],
              ),
            );
          }

          return RefreshIndicator(
            onRefresh: () async {
              _loadShipments();
            },
            child: ListView.builder(
              itemCount: shipments.length,
              itemBuilder: (context, index) {
                final shipment = shipments[index];
                return ShipmentListItem(
                  shipment: shipment,
                  onTap: () {
                    Navigator.pushNamed(
                      context,
                      '/shipment-detail',
                      arguments: shipment['_id'],
                    );
                  },
                );
              },
            ),
          );
        },
      ),
      floatingActionButton: FloatingActionButton(
        onPressed: () {
          Navigator.pushNamed(context, '/create-shipment');
        },
        tooltip: 'شحنة جديدة',
        child: const Icon(Icons.add),
      ),
    );
  }

  List<dynamic> _filterShipments(List<dynamic> shipments) {
    if (_selectedStatus == 'all') {
      return shipments;
    }
    return shipments
        .where((shipment) => shipment['status'] == _selectedStatus)
        .toList();
  }
}

