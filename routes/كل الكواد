const { Server } = require('socket.io');
const jwt = require('jsonwebtoken');
const User = require('../models/User');
const Notification = require('../models/Notification');
const logger = require('../utils/logger');

class NotificationGateway {
  constructor(io) {
    this.io = io;
    this.userConnections = new Map();
    this.setupMiddleware();
    this.setupEventHandlers();
  }

  setupMiddleware() {
    this.io.use(async (socket, next) => {
      try {
        const token = socket.handshake.auth.token;
        if (!token) return next(new Error('بدون توكن'));

        const decoded = jwt.verify(token, process.env.JWT_SECRET);
        const user = await User.findById(decoded.id);

        if (!user) return next(new Error('المستخدم غير موجود'));

        socket.userId = decoded.id;
        socket.user = user;
        next();
      } catch (error) {
        next(error);
      }
    });
  }

  setupEventHandlers() {
    this.io.on('connection', (socket) => {
      logger.success('✅ مستخدم متصل', { userId: socket.userId });

      // Store connection
      if (!this.userConnections.has(socket.userId)) {
        this.userConnections.set(socket.userId, []);
      }
      this.userConnections.get(socket.userId).push(socket.id);

      // Join user room
      socket.join(`user:${socket.userId}`);

      // Join role room
      socket.join(`role:${socket.user.role}`);

      // Handle disconnect
      socket.on('disconnect', () => {
        const connections = this.userConnections.get(socket.userId);
        if (connections) {
          connections.splice(connections.indexOf(socket.id), 1);
          if (connections.length === 0) {
            this.userConnections.delete(socket.userId);
          }
        }
        logger.info('👋 مستخدم قطع الاتصال', { userId: socket.userId });
      });

      // Handle notifications
      socket.on('notification:read', async (notificationId) => {
        await this.markAsRead(notificationId, socket.userId);
      });

      socket.on('notification:delete', async (notificationId) => {
        await this.deleteNotification(notificationId, socket.userId);
      });
    });
  }

  /**
   * إرسال إشعار إلى مستخدم
   */
  async sendToUser(userId, notification) {
    try {
      const socketsIds = this.userConnections.get(userId) || [];
      socketsIds.forEach(socketId => {
        this.io.to(socketId).emit('notification', notification);
      });

      logger.info('📤 تم إرسال إشعار', { userId, type: notification.type });
    } catch (error) {
      logger.error('❌ خطأ في إرسال الإشعار', error);
    }
  }

  /**
   * إرسال إشعار إلى مجموعة (Role)
   */
  async sendToRole(role, notification) {
    this.io.to(`role:${role}`).emit('notification', notification);
    logger.info('📤 تم إرسال إشعار للدور', { role, type: notification.type });
  }

  /**
   * بث الإشعار
   */
  async broadcast(notification) {
    this.io.emit('notification', notification);
    logger.info('📢 تم بث الإشعار', { type: notification.type });
  }

  /**
   * تحديث الإشعار كمقروء
   */
  async markAsRead(notificationId, userId) {
    try {
      await Notification.findByIdAndUpdate(
        notificationId,
        { read: true, readAt: new Date() }
      );

      // Emit read confirmation
      this.io.to(`user:${userId}`).emit('notification:marked-as-read', notificationId);
    } catch (error) {
      logger.error('❌ خطأ في تحديث الإشعار', error);
    }
  }

  /**
   * حذف الإشعار
   */
  async deleteNotification(notificationId, userId) {
    try {
      await Notification.findByIdAndDelete(notificationId);
      this.io.to(`user:${userId}`).emit('notification:deleted', notificationId);
    } catch (error) {
      logger.error('❌ خطأ في حذف الإشعار', error);
    }
  }

  /**
   * الحصول على إحصائيات الاتصالات
   */
  getStats() {
    return {
      totalConnectedUsers: this.userConnections.size,
      totalSockets: this.io.engine.clientsCount,
      userConnections: Array.from(this.userConnections.entries()).map(([userId, sockets]) => ({
        userId,
        socketCount: sockets.length
      }))
    };
  }
}

