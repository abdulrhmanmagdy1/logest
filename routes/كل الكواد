const crypto = require('crypto');
const bcrypt = require('bcryptjs');
const User = require('../models/User');
const AuditLog = require('../models/AuditLog');
const logger = require('../utils/logger');

class SecurityService {
  /**
   * التشفير المتقدم للبيانات الحساسة
   */
  static async encryptSensitiveData(data, key = process.env.ENCRYPTION_KEY) {
    try {
      const iv = crypto.randomBytes(16);
      const cipher = crypto.createCipheriv(
        'aes-256-cbc',
        Buffer.from(key.padEnd(32)),
        iv
      );

      let encrypted = cipher.update(JSON.stringify(data), 'utf8', 'hex');
      encrypted += cipher.final('hex');

      return {
        encrypted,
        iv: iv.toString('hex'),
        algorithm: 'aes-256-cbc'
      };
    } catch (error) {
      logger.error('❌ خطأ في التشفير', error);
      throw error;
    }
  }

  /**
   * فك التشفير
   */
  static async decryptSensitiveData(encryptedData, key = process.env.ENCRYPTION_KEY) {
    try {
      const decipher = crypto.createDecipheriv(
        'aes-256-cbc',
        Buffer.from(key.padEnd(32)),
        Buffer.from(encryptedData.iv, 'hex')
      );

      let decrypted = decipher.update(encryptedData.encrypted, 'hex', 'utf8');
      decrypted += decipher.final('utf8');

      return JSON.parse(decrypted);
    } catch (error) {
      logger.error('❌ خطأ في فك التشفير', error);
      throw error;
    }
  }

  /**
   * كشف محاولات الاختراق
   */
  static async detectIntrusionAttempt(req, suspiciousActivity) {
    try {
      const user = req.user;
      const ip = req.ip;

      // Check for multiple failed attempts
      const recentAttempts = await AuditLog.countDocuments({
        user: user?._id,
        ipAddress: ip,
        status: 'failed',
        createdAt: { $gte: new Date(Date.now() - 15 * 60 * 1000) }
      });

      if (recentAttempts > 5) {
        logger.warn('🚨 كشف محاولات اختراق متعددة', {
          userId: user?._id,
          ip,
          attempts: recentAttempts
        });

        // Lock account if user exists
        if (user) {
          await User.findByIdAndUpdate(user._id, {
            lockUntil: new Date(Date.now() + 2 * 60 * 60 * 1000)
          });
        }

        return {
          threat: true,
          severity: 'high',
          action: 'account_locked'
        };
      }

      // Check for suspicious IP
      const sameDayAttempts = await AuditLog.countDocuments({
        ipAddress: ip,
        createdAt: { $gte: new Date(Date.now() - 24 * 60 * 60 * 1000) }
      });

      if (sameDayAttempts > 100) {
        logger.warn('🚨 IP مريب مع عدد كبير من المحاولات', { ip, attempts: sameDayAttempts });

        return {
          threat: true,
          severity: 'critical',
          action: 'ip_blocked'
        };
      }

      return { threat: false };
    } catch (error) {
      logger.error('❌ خطأ في كشف الاختراقات', error);
      return { threat: false };
    }
  }

  /**
   * إنشاء نسخة احتياطية آمنة من البيانات
   */
  static async secureBackup(data) {
    try {
      const hash = crypto.createHash('sha256').update(JSON.stringify(data)).digest('hex');
      const timestamp = new Date().toISOString();
      const signature = this.signData(data);

      return {
        data,
        hash,
        timestamp,
        signature,
        verified: false
      };
    } catch (error) {
      logger.error('❌ خطأ في النسخة الاحتياطية الآمنة', error);
      throw error;
    }
  }

  /**
   * التحقق من التوقيع الرقمي
   */
  static signData(data) {
    const privateKey = process.env.PRIVATE_KEY || 'private-key';
    const sign = crypto.createSign('sha256');
    sign.update(JSON.stringify(data));
    return sign.sign(privateKey, 'hex');
  }

  /**
   * التحقق من صحة البيانات الحساسة
   */
  static async validateSensitiveData(data, rules) {
    const errors = [];

    for (const [field, rule] of Object.entries(rules)) {
      const value = data[field];

      if (rule.required && !value) {
        errors.push(`${field} مطلوب`);
      }

      if (rule.pattern && !rule.pattern.test(value)) {
        errors.push(`${field} لا يطابق النمط المطلوب`);
      }

      if (rule.minLength && value.length < rule.minLength) {
        errors.push(`${field} يجب أن يكون على الأقل ${rule.minLength} أحرف`);
      }

      if (rule.maxLength && value.length > rule.maxLength) {
        errors.push(`${field} لا يمكن أن يتجاوز ${rule.maxLength} حرف`);
      }
    }

    return { isValid: errors.length === 0, errors };
  }

  /**
   * تنظيف المدخلات من الأنماط الخطرة
   */
  static sanitizeInput(input) {
    if (typeof input !== 'string') return input;

    // Remove dangerous patterns
    let sanitized = input
      .replace(/<script[^>]*>.*?<\/script>/gi, '') // Remove scripts
      .replace(/<[^>]*>/g, '') // Remove HTML tags
      .replace(/javascript:/gi, '') // Remove javascript: protocol
      .replace(/on\w+\s*=/gi, ''); // Remove event handlers

    return sanitized.trim();
  }

  /**
   * تسجيل الأحداث الأمنية
   */
  static async logSecurityEvent(eventType, details, req) {
    try {
      await AuditLog.create({
        user: req.user?._id,
        action: eventType,
        entity: 'Security',
        details,
        ipAddress: req.ip,
        userAgent: req.get('user-agent'),
        status: 'logged'
      });

      logger.warn(`⚠️ حدث أمني: ${eventType}`, details);
    } catch (error) {
      logger.error('❌ خطأ في تسجيل الحدث الأمني', error);
    }
  }

  /**
   * فرض HTTPS و Security Headers
   */
  static securityHeaders(req, res, next) {
    // Force HTTPS
    if (process.env.NODE_ENV === 'production' && req.protocol !== 'https') {
      return res.redirect(301, `https://${req.get('host')}${req.url}`);
    }

    // Security headers
    res.setHeader('X-Content-Type-Options', 'nosniff');
    res.setHeader('X-Frame-Options', 'DENY');
    res.setHeader('X-XSS-Protection', '1; mode=block');
    res.setHeader('Strict-Transport-Security', 'max-age=31536000; includeSubDomains');
    res.setHeader('Content-Security-Policy', "default-src 'self'");
    res.setHeader('Referrer-Policy', 'strict-origin-when-cross-origin');

    next();
  }
}

