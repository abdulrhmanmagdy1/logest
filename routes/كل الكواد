const Shipment = require('../models/Shipment');
const Trip = require('../models/Trip');
const User = require('../models/User');
const logger = require('../utils/logger');
const moment = require('moment');

class AIAnalytics {
  /**
   * التنبؤ بأوقات التسليم
   */
  static async predictDeliveryTime(shipment) {
    try {
      // Get historical data
      const historicalShipments = await Shipment.find({
        'pickupLocation.city': shipment.pickupLocation.city,
        'deliveryLocation.city': shipment.deliveryLocation.city,
        status: 'delivered',
        actualPickupDate: { $exists: true },
        actualDeliveryDate: { $exists: true }
      }).limit(100).lean();

      if (historicalShipments.length === 0) {
        return null;
      }

      // Calculate average delivery time
      const deliveryTimes = historicalShipments.map(s => {
        const time = (new Date(s.actualDeliveryDate) - new Date(s.actualPickupDate)) / (1000 * 60 * 60);
        return time;
      });

      const avgTime = deliveryTimes.reduce((a, b) => a + b) / deliveryTimes.length;
      const stdDev = this.calculateStandardDeviation(deliveryTimes, avgTime);

      // Add factors
      const timeOfDay = new Date().getHours();
      const isWeekend = [0, 6].includes(new Date().getDay());
      const distance = this.calculateDistance(
        shipment.pickupLocation,
        shipment.deliveryLocation
      );

      let prediction = avgTime;
      if (isWeekend) prediction *= 1.2;
      if (timeOfDay > 18) prediction *= 1.1;
      if (distance > 1000) prediction *= 1.15;

      return {
        estimatedTime: Math.round(prediction),
        confidence: this.calculateConfidence(historicalShipments.length, stdDev),
        factors: {
          historicalAverage: Math.round(avgTime),
          distance,
          isWeekend,
          timeOfDay
        }
      };
    } catch (error) {
      logger.error('❌ خطأ في التنبؤ بالوقت', error);
      return null;
    }
  }

  /**
   * كشف الشحنات المتأخرة
   */
  static async detectDelayedShipments() {
    try {
      const shipments = await Shipment.find({
        status: { $in: ['assigned', 'in_transit'] },
        scheduledDeliveryDate: { $lt: new Date() }
      }).populate('driver', 'name phone').lean();

      const alerts = shipments.map(shipment => {
        const hoursLate = Math.floor(
          (new Date() - new Date(shipment.scheduledDeliveryDate)) / (1000 * 60 * 60)
        );

        return {
          shipmentId: shipment._id,
          shipmentNumber: shipment.shipmentNumber,
          hoursLate,
          severity: hoursLate > 12 ? 'critical' : 'warning',
          driver: shipment.driver,
          estimatedDelivery: new Date(Date.now() + (hoursLate / 2) * 60 * 60 * 1000)
        };
      });

      logger.warn(`⚠️ تم كشف ${alerts.length} شحنة متأخرة`, {
        critical: alerts.filter(a => a.severity === 'critical').length
      });

      return alerts;
    } catch (error) {
      logger.error('❌ خطأ في كشف التأخيرات', error);
      return [];
    }
  }

