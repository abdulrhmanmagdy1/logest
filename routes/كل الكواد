const { PATTERNS, SAUDI_CITIES } = require('../config/constants');

class Validators {
  /**
   * التحقق من البريد الإلكتروني
   */
  static isValidEmail(email) {
    return PATTERNS.EMAIL.test(email);
  }

  /**
   * التحقق من رقم الهاتف السعودي
   */
  static isValidSaudiPhone(phone) {
    return PATTERNS.PHONE_SA.test(phone);
  }

  /**
   * التحقق من قوة كلمة المرور
   */
  static getPasswordStrength(password) {
    let strength = 0;
    let feedback = [];

    // Length check
    if (password.length >= 8) strength += 1;
    else feedback.push('يجب أن تكون كلمة المرور 8 أحرف على الأقل');

    if (password.length >= 12) strength += 1;

    // Uppercase check
    if (/[A-Z]/.test(password)) strength += 1;
    else feedback.push('أضف أحرف كبيرة');

    // Lowercase check
    if (/[a-z]/.test(password)) strength += 1;
    else feedback.push('أضف أحرف صغيرة');

    // Number check
    if (/[0-9]/.test(password)) strength += 1;
    else feedback.push('أضف أرقام');

    // Special characters check
    if (/[!@#$%^&*]/.test(password)) strength += 1;
    else feedback.push('أضف رموز خاصة (!@#$%^&*)');

    const levels = ['ضعيفة جداً', 'ضعيفة', 'متوسطة', 'قوية', 'قوية جداً'];
    
    return {
      score: strength,
      level: levels[Math.min(strength, 4)],
      feedback,
      isStrong: strength >= 4
    };
  }

  /**
   * التحقق من صحة العنوان
   */
  static isValidAddress(address) {
    if (!address || typeof address !== 'string') return false;
    return address.trim().length >= 5;
  }

  /**
   * التحقق من صحة المدينة
   */
  static isValidCity(city) {
    return SAUDI_CITIES.some(c => c.name === city || c.code === city);
  }

  /**
   * التحقق من صحة الإحداثيات
   */
  static isValidCoordinates(latitude, longitude) {
    if (typeof latitude !== 'number' || typeof longitude !== 'number') {
      return false;
    }
    return latitude >= -90 && latitude <= 90 && longitude >= -180 && longitude <= 180;
  }

  /**
   * التحقق من صحة الوزن
   */
  static isValidWeight(weight) {
    return typeof weight === 'number' && weight > 0 && weight <= 100000;
  }

  /**
   * التحقق من صحة السعر
   */
  static isValidPrice(price) {
    return typeof price === 'number' && price >= 0;
  }

  /**
   * التحقق من صحة التاريخ
   */
  static isValidDate(date) {
    if (!date) return false;
    const d = new Date(date);
    return d instanceof Date && !isNaN(d);
  }

  /**
   * التحقق من أن التاريخ في المستقبل
   */
  static isFutureDate(date) {
    return this.isValidDate(date) && new Date(date) > new Date();
  }

  /**
   * التحقق من صحة معرف MongoDB
   */
  static isValidObjectId(id) {
    return /^[0-9a-fA-F]{24}$/.test(id);
  }

  /**
   * التحقق من صحة URL
   */
  static isValidURL(url) {
    return PATTERNS.URL.test(url);
  }

  /**
   * التحقق من صحة رقم لوحة الترخيص السعودية
   */
  static isValidPlateNumber(plateNumber) {
    return PATTERNS.PLATE_NUMBER.test(plateNumber);
  }

  /**
   * التحقق من صحة الرمز البريدي
   */
  static isValidPostalCode(postalCode) {
    return /^\d{5}$/.test(postalCode);
  }

  /**
   * التحقق من صحة حالة الشحنة
   */
  static isValidShipmentStatus(status) {
    const validStatuses = [
      'pending', 'assigned', 'in_transit', 'delivered', 'cancelled', 'failed', 'on_hold', 'returned'
    ];
    return validStatuses.includes(status);
  }

  /**
   * التحقق من صحة حالة الفاتورة
   */
  static isValidInvoiceStatus(status) {
    const validStatuses = ['pending', 'sent', 'viewed', 'paid', 'partial', 'overdue', 'cancelled', 'refunded'];
    return validStatuses.includes(status);
  }

  /**
   * التحقق من البيانات قبل الحفظ في قاعدة البيانات
   */
  static validateShipmentData(data) {
    const errors = [];

    if (!data.description || data.description.trim().length < 5) {
      errors.push('وصف الشحنة يجب أن يكون 5 أحرف على الأقل');
    }

    if (!this.isValidWeight(data.weight)) {
      errors.push('الوزن غير صحيح');
    }

    if (!data.pickupLocation || !this.isValidAddress(data.pickupLocation.address)) {
      errors.push('عنوان الاستلام غير صحيح');
    }

    if (!this.isValidCity(data.pickupLocation.city)) {
      errors.push('مدينة الاستلام غير صحيحة');
    }

    if (!data.deliveryLocation || !this.isValidAddress(data.deliveryLocation.address)) {
      errors.push('عنوان التسليم غير صحيح');
    }

    if (!this.isValidCity(data.deliveryLocation.city)) {
      errors.push('مدينة التسليم غير صحيحة');
    }

    if (!this.isValidCoordinates(
      data.pickupLocation.latitude,
      data.pickupLocation.longitude
    )) {
      errors.push('إحداثيات الاستلام غير صحيحة');
    }

    if (!this.isValidCoordinates(
      data.deliveryLocation.latitude,
      data.deliveryLocation.longitude
    )) {
      errors.push('إحداثيات التسليم غير صحيحة');
    }

    return {
      isValid: errors.length === 0,
      errors
    };
  }

  /**
   * التحقق من بيانات الفاتورة
   */
  static validateInvoiceData(data) {
    const errors = [];

    if (!this.isValidPrice(data.subtotal)) {
      errors.push('المبلغ الفرعي غير صحيح');
    }

    if (!this.isValidPrice(data.tax)) {
      errors.push('الضريبة غير صحيحة');
    }

    if (!Array.isArray(data.items) || data.items.length === 0) {
      errors.push('يجب أن تحتوي الفاتورة على بند واحد على الأقل');
    }

    return {
      isValid: errors.length === 0,
      errors
    };
  }
}

module.exports = Validators;
