const redis = require('redis');
const logger = require('../utils/logger');

class CacheManager {
  constructor() {
    this.client = redis.createClient({
      url: process.env.REDIS_URL || 'redis://localhost:6379'
    });
    this.client.connect().catch(err => logger.error('Cache connection error', err));
  }

  /**
   * Middleware لتخزين الاستجابات
   */
  cacheMiddleware(duration = 300) {
    return async (req, res, next) => {
      if (req.method !== 'GET') {
        return next();
      }

      const cacheKey = `cache:${req.originalUrl}`;

      try {
        const cached = await this.client.get(cacheKey);
        if (cached) {
          logger.info('💾 استجابة من التخزين المؤقت', { url: req.originalUrl });
          return res.json(JSON.parse(cached));
        }
      } catch (error) {
        logger.warn('⚠️ خطأ في استرجاع التخزين المؤقت', error);
      }

      // Store original send
      const originalSend = res.json;

      res.json = function(data) {
        try {
          this.client.setEx(cacheKey, duration, JSON.stringify(data))
            .catch(err => logger.warn('⚠️ خطأ في حفظ التخزين المؤقت', err));
        } catch (error) {
          logger.warn('⚠️ خطأ في تخزين الاستجابة', error);
        }

        return originalSend.call(this, data);
      };

      next();
    };
  }

  /**
   * حفظ في التخزين المؤقت
   */
  async set(key, value, ttl = 300) {
    try {
      await this.client.setEx(key, ttl, JSON.stringify(value));
      logger.info('💾 تم حفظ في التخزين المؤقت', { key, ttl });
    } catch (error) {
      logger.error('❌ خطأ في حفظ التخزين المؤقت', error);
    }
  }

  /**
   * استرجاع من التخزين المؤقت
   */
  async get(key) {
    try {
      const cached = await this.client.get(key);
      return cached ? JSON.parse(cached) : null;
    } catch (error) {
      logger.error('❌ خطأ في استرجاع التخزين المؤقت', error);
      return null;
    }
  }

  /**
   * حذف من التخزين المؤقت
   */
  async delete(key) {
    try {
      await this.client.del(key);
      logger.info('🗑️  تم حذف من التخزين المؤقت', { key });
    } catch (error) {
      logger.error('❌ خطأ في حذف التخزين المؤقت', error);
    }
  }

  /**
   * تطهير كل التخزين المؤقت
   */
  async flush() {
    try {
      await this.client.flushAll();
      logger.success('✅ تم تطهير التخزين المؤقت بالكامل');
    } catch (error) {
      logger.error('❌ خطأ في تطهير التخزين المؤقت', error);
    }
  }
}

