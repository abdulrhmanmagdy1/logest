  Future<void> initialize() async {
    try {
      _prefs = await SharedPreferences.getInstance();
      
      // Load saved preferences
      final savedTheme = _prefs.getString('theme') ?? 'dark';
      _theme = savedTheme == 'light' ? AppTheme.light : AppTheme.dark;

      final savedLanguage = _prefs.getString('language') ?? 'ar';
      _language = savedLanguage == 'en' ? AppLanguage.en : AppLanguage.ar;

      _isInitialized = true;
      notifyListeners();
    } catch (e) {
      print('خطأ في تهيئة التطبيق: $e');
      rethrow;
    }
  }

  /// تبديل المظهر
  Future<void> toggleTheme() async {
    _theme = _theme == AppTheme.dark ? AppTheme.light : AppTheme.dark;
    await _prefs.setString('theme', _theme == AppTheme.light ? 'light' : 'dark');
    notifyListeners();
  }

  /// تغيير اللغة
  Future<void> setLanguage(AppLanguage language) async {
    _language = language;
    await _prefs.setString('language', language == AppLanguage.ar ? 'ar' : 'en');
    notifyListeners();
  }

  /// التحقق من الاتصال بالإنترنت
  Future<void> checkConnectivity() async {
    try {
      final isConnected = await _apiService.isConnected();
      _isOnline = isConnected;
      notifyListeners();
    } catch (e) {
      _isOnline = false;
      notifyListeners();
    }
  }

  /// الحصول على البيانات المخزنة محلياً
  T? getLocalData<T>(String key) {
    try {
      final data = _prefs.get(key);
      return data as T?;
    } catch (e) {
      return null;
    }
  }

  /// حفظ البيانات محلياً
  Future<void> setLocalData<T>(String key, T value) async {
    try {
      if (value is String) {
        await _prefs.setString(key, value);
      } else if (value is int) {
        await _prefs.setInt(key, value);
      } else if (value is double) {
        await _prefs.setDouble(key, value);
      } else if (value is bool) {
        await _prefs.setBool(key, value);
      }
      notifyListeners();
    } catch (e) {
      print('خطأ في حفظ البيانات: $e');
    }
  }

  /// مسح البيانات المخزنة محلياً
  Future<void> clearLocalData() async {
    await _prefs.clear();
    notifyListeners();
  }
}
