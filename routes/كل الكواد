import React from 'react';

export default function Button({
  children,
  variant = 'primary',
  size = 'md',
  disabled = false,
  ...props
}) {
  const baseStyles = 'font-semibold rounded-lg transition-all duration-normal focus:outline-none';
  
  const variants = {
    primary: 'bg-primary-light hover:bg-secondary-blue text-white shadow-md hover:shadow-lg active:bg-primary-dark',
    secondary: 'bg-transparent border-2 border-primary-light text-primary-light hover:bg-blue-50',
    outline: 'bg-transparent border-2 border-primary-dark text-primary-dark hover:bg-gray-100',
    gold: 'bg-primary-gold text-white hover:opacity-90 shadow-md',
  };
  
  const sizes = {
    sm: 'px-3 py-2 text-sm',
    md: 'px-6 py-3 text-base',
    lg: 'px-8 py-4 text-lg',
  };

  return (
    <button
      className={`${baseStyles} ${variants[variant]} ${sizes[size]} ${disabled ? 'opacity-50 cursor-not-allowed' : ''}`}
      disabled={disabled}
      {...props}
    >
      {children}
    </button>
  );
}
