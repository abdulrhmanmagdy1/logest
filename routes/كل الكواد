import 'package:flutter/foundation.dart';
import '../services/api_service.dart';

class ShipmentProvider with ChangeNotifier {
  final ApiService _apiService = ApiService();

  List<dynamic> _shipments = [];
  bool _isLoading = false;
  String? _error;

  List<dynamic> get shipments => _shipments;
  bool get isLoading => _isLoading;
  String? get error => _error;

  int get totalShipments => _shipments.length;
  int get pendingCount => _shipments
      .where((s) => s['status'] == 'pending')
      .toList()
      .length;
  int get inTransitCount => _shipments
      .where((s) => s['status'] == 'in_transit')
      .toList()
      .length;
  int get completedCount => _shipments
      .where((s) => s['status'] == 'delivered')
      .toList()
      .length;

  Future<void> fetchShipments({int page = 1, int limit = 20}) async {
    _isLoading = true;
    _error = null;
    notifyListeners();

    try {
      final response = await _apiService
          .get('/api/v1/shipments?page=$page&limit=$limit');
      
      _shipments = response['data'] ?? [];
      _isLoading = false;
      notifyListeners();
    } catch (e) {
      _error = e.toString();
      _isLoading = false;
      notifyListeners();
      rethrow;
    }
  }

  Future<Map<String, dynamic>> getShipmentDetail(String shipmentId) async {
    try {
      final response = await _apiService.get('/api/v1/shipments/$shipmentId');
      return response['data'];
    } catch (e) {
      _error = e.toString();
      notifyListeners();
      rethrow;
    }
  }

  Future<void> createShipment(Map<String, dynamic> shipmentData) async {
    _isLoading = true;
    notifyListeners();

    try {
      await _apiService.post('/api/v1/shipments', shipmentData);
      await fetchShipments();
      _isLoading = false;
      notifyListeners();
    } catch (e) {
      _error = e.toString();
      _isLoading = false;
      notifyListeners();
      rethrow;
    }
  }

  Future<void> updateShipment(
    String shipmentId,
    Map<String, dynamic> updates,
  ) async {
    try {
      await _apiService.put('/api/v1/shipments/$shipmentId', updates);
      await fetchShipments();
      notifyListeners();
    } catch (e) {
      _error = e.toString();
      notifyListeners();
      rethrow;
    }
  }

  Future<void> updateShipmentStatus(
    String shipmentId,
    String newStatus,
  ) async {
    try {
      await _apiService.patch(
        '/api/v1/shipments/$shipmentId/status',
        {'status': newStatus},
      );
      await fetchShipments();
      notifyListeners();
    } catch (e) {
      _error = e.toString();
      notifyListeners();
      rethrow;
    }
  }

  void clearError() {
    _error = null;
    notifyListeners();
  }
}
