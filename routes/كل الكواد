      const token = this.extractToken(req);

      if (!token) {
        return res.status(HTTP_STATUS.UNAUTHORIZED).json({
          success: false,
          message: 'لا توجد رسالة مصادقة'
        });
      }

      let decoded;
      try {
        decoded = JWTManager.verifyToken(token, 'access');
      } catch (error) {
        if (error.name === 'TokenExpiredError') {
          // Check if refresh token is available
          const refreshToken = req.cookies.refreshToken;
          if (refreshToken) {
            try {
              const newTokens = await this.refreshAccessToken(req.user.id, refreshToken);
              res.cookie('accessToken', newTokens.accessToken, {
                httpOnly: true,
                secure: process.env.NODE_ENV === 'production',
                sameSite: 'strict',
                maxAge: 7 * 24 * 60 * 60 * 1000
              });
              decoded = JWTManager.verifyToken(newTokens.accessToken);
            } catch (refreshError) {
              return res.status(HTTP_STATUS.UNAUTHORIZED).json({
                success: false,
                message: MESSAGES.TOKEN_EXPIRED
              });
            }
          } else {
            return res.status(HTTP_STATUS.UNAUTHORIZED).json({
              success: false,
              message: MESSAGES.TOKEN_EXPIRED
            });
          }
        } else {
          throw error;
        }
      }

      // Get user from database
      const user = await User.findById(decoded.id).select('-password');

      if (!user) {
        return res.status(HTTP_STATUS.UNAUTHORIZED).json({
          success: false,
          message: 'المستخدم غير موجود'
        });
      }

      if (!user.isActive) {
        return res.status(HTTP_STATUS.FORBIDDEN).json({
          success: false,
          message: 'الحساب معطل'
        });
      }

      // Check if account is locked
      if (user.isLocked()) {
        return res.status(HTTP_STATUS.FORBIDDEN).json({
          success: false,
          message: MESSAGES.ACCOUNT_LOCKED,
          lockedUntil: user.lockUntil
        });
      }

      // Attach user and token to request
      req.user = user;
      req.token = token;
      req.permissions = decoded.permissions || [];

      // Log access
      await this.logAccess(user._id, req);

      next();
    } catch (error) {
      logger.error('❌ خطأ في المصادقة', error);
      res.status(HTTP_STATUS.INTERNAL_ERROR).json({
        success: false,
        message: MESSAGES.ERROR
      });
    }
  }

  /**
   * التحقق من الصلاحيات الدقيقة
   */
  static hasPermission(...requiredPermissions) {
    return (req, res, next) => {
      if (!req.user) {
        return res.status(HTTP_STATUS.UNAUTHORIZED).json({
          success: false,
          message: 'لا توجد جلسة مستخدم'
        });
      }

      // Admin has all permissions
      if (req.user.role === 'admin') {
        return next();
      }

      const userPermissions = req.permissions || [];
      const hasPermission = requiredPermissions.some(perm =>
        userPermissions.includes(perm)
      );

      if (!hasPermission) {
        logger.warn('محاولة وصول غير مصرحة', {
          userId: req.user._id,
          requiredPermissions,
          userPermissions
        });

        return res.status(HTTP_STATUS.FORBIDDEN).json({
          success: false,
          message: 'ليس لديك الصلاحية للقيام بهذه العملية'
        });
      }

      next();
    };
  }

  /**
   * تحديث access token
   */
  static async refreshAccessToken(userId, refreshToken) {
    try {
      const decoded = JWTManager.verifyToken(refreshToken, 'refresh');
      const user = await User.findById(userId);

      if (!user || !user.isActive) {
        throw new Error('المستخدم غير صحيح');
      }

      return JWTManager.createTokenPair(user._id, user.role, user.permissions);
    } catch (error) {
      throw new Error('فشل تحديث الـ token');
    }
  }

  /**
   * استخراج التوكن
   */
  static extractToken(req) {
    if (req.headers.authorization) {
      const parts = req.headers.authorization.split(' ');
      if (parts.length === 2 && parts[0] === 'Bearer') {
        return parts[1];
      }
    }

    if (req.cookies && req.cookies.accessToken) {
      return req.cookies.accessToken;
    }

    if (req.query && req.query.token) {
      return req.query.token;
    }

    return null;
  }

  /**
   * تسجيل الوصول
   */
  static async logAccess(userId, req) {
    try {
      await AuditLog.create({
        user: userId,
        action: 'login',
        entity: 'User',
        ipAddress: req.ip,
        userAgent: req.get('user-agent'),
        status: 'success'
      });
    } catch (error) {
      logger.warn('⚠️ فشل تسجيل الوصول', error);
    }
  }
}

