        method,
        date: new Date(),
        reference
      });

      if (invoice.balanceDue === 0) {
        invoice.paidDate = new Date();
      }

      await invoice.save();

      logger.success('Payment recorded', { invoiceNumber: invoice.invoiceNumber, amount });

      res.json({
        success: true,
        message: 'تم تسجيل الدفعة بنجاح',
        data: invoice
      });
    } catch (error) {
      logger.error('Record payment error', error);
      res.status(HTTP_STATUS.INTERNAL_ERROR).json({
        success: false,
        message: MESSAGES.ERROR
      });
    }
  }

  /**
   * توليد PDF للفاتورة
   */
  static async generatePDF(req, res) {
    try {
      const invoice = await Invoice.findById(req.params.id)
        .populate('client')
        .populate('accountant');

      if (!invoice) {
        return res.status(HTTP_STATUS.NOT_FOUND).json({
          success: false,
          message: MESSAGES.NOT_FOUND
        });
      }

      const doc = new PDFDocument();
      res.setHeader('Content-Type', 'application/pdf');
      res.setHeader('Content-Disposition', `attachment; filename=invoice-${invoice.invoiceNumber}.pdf`);

      doc.pipe(res);

      // Header
      doc.fontSize(24).text('إدهام', { align: 'center' });
      doc.fontSize(12).text('فاتورة', { align: 'center' });
      doc.moveDown();

      // Invoice info
      doc.fontSize(10)
        .text(`رقم الفاتورة: ${invoice.invoiceNumber}`)
        .text(`التاريخ: ${Helpers.formatDateArabic(invoice.issueDate)}`)
        .text(`تاريخ الاستحقاق: ${Helpers.formatDateArabic(invoice.dueDate)}`);

      doc.moveDown();

      // Client info
      if (invoice.client) {
        doc.fontSize(12).text('العميل:', { underline: true });
        doc.fontSize(10)
          .text(`الاسم: ${invoice.client.name}`)
          .text(`البريد: ${invoice.client.email}`)
          .text(`الهاتف: ${invoice.client.phone}`);
      }

      doc.moveDown();

      // Items table
      doc.fontSize(12).text('البنود:', { underline: true });
      doc.moveDown();

      doc.fontSize(10);
      invoice.items.forEach(item => {
        doc.text(`${item.description}: ${item.quantity} × ${item.unitPrice} = ${item.total}`);
      });

      doc.moveDown();

      // Totals
      doc.fontSize(10)
        .text(`الإجمالي: ${invoice.subtotal}`)
        .text(`الضريبة: ${invoice.tax}`)
        .text(`الخصم: ${invoice.discount}`)
        .text(`الإجمالي النهائي: ${invoice.total}`, { underline: true });

      doc.moveDown();
      doc.text(`المبلغ المدفوع: ${invoice.amountPaid}`);
      doc.text(`الرصيد المتبقي: ${invoice.balanceDue}`);

      doc.end();
    } catch (error) {
      logger.error('Generate PDF error', error);
      res.status(HTTP_STATUS.INTERNAL_ERROR).json({
        success: false,
        message: MESSAGES.ERROR
      });
    }
  }

  /**
   * التحقق من الفاتورة
   */
  static async verify(req, res) {
    try {
      const { serialNumber, verificationCode } = req.body;

      let invoice;
      if (serialNumber) {
        invoice = await Invoice.findOne({ serialNumber });
      } else if (verificationCode) {
        invoice = await Invoice.findOne({ verificationCode });
      } else {
        return res.status(HTTP_STATUS.BAD_REQUEST).json({
          success: false,
          message: 'رقم سري أو كود التحقق مطلوب'
        });
      }

      if (!invoice) {
        return res.status(HTTP_STATUS.NOT_FOUND).json({
          success: false,
          message: 'الفاتورة غير موجودة'
        });
      }

      invoice.verificationAttempts += 1;
      invoice.lastVerifiedAt = new Date();
      await invoice.save();

      res.json({
        success: true,
        data: {
          invoiceNumber: invoice.invoiceNumber,
          amount: invoice.total,
          status: invoice.status,
          isVerified: true,
          issuedAt: invoice.issueDate
        }
      });
    } catch (error) {
      logger.error('Verify invoice error', error);
      res.status(HTTP_STATUS.INTERNAL_ERROR).json({
        success: false,
        message: MESSAGES.ERROR
      });
    }
  }

  /**
   * الحصول على إحصائيات الفواتير
   */
  static async getStatistics(req, res) {
    try {
      const { dateFrom, dateTo } = req.query;
      let query = {};

      if (dateFrom || dateTo) {
        query.issueDate = {};
        if (dateFrom) query.issueDate.$gte = new Date(dateFrom);
        if (dateTo) query.issueDate.$lte = new Date(dateTo);
      }

      const [totalInvoices, paidInvoices, pendingInvoices, overdue] = await Promise.all([
        Invoice.countDocuments(query),
        Invoice.countDocuments({ ...query, status: INVOICE_STATUS.PAID }),
        Invoice.countDocuments({ ...query, status: INVOICE_STATUS.PENDING }),
        Invoice.countDocuments({
          ...query,
          status: INVOICE_STATUS.OVERDUE,
          dueDate: { $lt: new Date() }
        })
      ]);

      const totalRevenue = await Invoice.aggregate([
        { $match: query },
        { $group: { _id: null, total: { $sum: '$total' } } }
      ]);

      const totalPaid = await Invoice.aggregate([
        { $match: query },
        { $group: { _id: null, total: { $sum: '$amountPaid' } } }
      ]);

      const totalPending = await Invoice.aggregate([
        { $match: query },
        { $group: { _id: null, total: { $sum: '$balanceDue' } } }
      ]);

      res.json({
        success: true,
        data: {
          totalInvoices,
          paidInvoices,
          pendingInvoices,
          overdue,
          totalRevenue: totalRevenue[0]?.total || 0,
          totalPaid: totalPaid[0]?.total || 0,
          totalPending: totalPending[0]?.total || 0
        }
      });
    } catch (error) {
      logger.error('Get invoice statistics error', error);
      res.status(HTTP_STATUS.INTERNAL_ERROR).json({
        success: false,
        message: MESSAGES.ERROR
      });
    }
  }
}

