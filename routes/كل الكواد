const cron = require('node-cron');
const Invoice = require('../models/Invoice');
const Notification = require('../models/Notification');
const EmailService = require('../services/emailService');
const { INVOICE_STATUS } = require('../config/constants');
const logger = require('../utils/logger');

class InvoiceScheduler {
  static init() {
    // Check overdue invoices - every day at 10 AM
    cron.schedule('0 10 * * *', () => {
      this.checkOverdueInvoices();
    });

    // Send payment reminders - every 3 days at 9 AM
    cron.schedule('0 9 */3 * *', () => {
      this.sendPaymentReminders();
    });

    // Generate revenue report - every month at the 1st day, 8 AM
    cron.schedule('0 8 1 * *', () => {
      this.generateRevenueReport();
    });

    logger.success('✅ Invoice Scheduler initialized');
  }

  /**
   * التحقق من الفواتير المتأخرة
   */
  static async checkOverdueInvoices() {
    try {
      logger.info('🔍 جاري البحث عن الفواتير المتأخرة...');

      const overdueInvoices = await Invoice.find({
        status: { $in: [INVOICE_STATUS.PENDING, INVOICE_STATUS.PARTIAL] },
        dueDate: { $lt: new Date() }
      }).populate('client');

      for (const invoice of overdueInvoices) {
        invoice.status = INVOICE_STATUS.OVERDUE;
        await invoice.save();

        // Create notification
        await Notification.create({
          user: invoice.client._id,
          type: 'invoice_overdue',
          title: 'فاتورة متأخرة',
          message: `فاتورة #${invoice.invoiceNumber} متأخرة عن الدفع`,
          data: { invoiceId: invoice._id },
          read: false
        });

        logger.warn('⚠️ فاتورة متأخرة', { invoiceNumber: invoice.invoiceNumber });
      }
    } catch (error) {
      logger.error('❌ خطأ في التحقق من الفواتير', error);
    }
  }

  /**
   * إرسال تذكيرات الدفع
   */
  static async sendPaymentReminders() {
    try {
      logger.info('📧 جاري إرسال تذكيرات الدفع...');

      const pendingInvoices = await Invoice.find({
        status: { $in: [INVOICE_STATUS.PENDING, INVOICE_STATUS.PARTIAL] },
        dueDate: { $gte: new Date(), $lte: new Date(Date.now() + 7 * 24 * 60 * 60 * 1000) }
      }).populate('client');

      for (const invoice of pendingInvoices) {
        try {
          await EmailService.sendPaymentReminderEmail(invoice);
          logger.info('📬 تذكير دفع مرسل', { invoiceNumber: invoice.invoiceNumber });
        } catch (error) {
          logger.warn('⚠️ فشل إرسال التذكير', { invoiceNumber: invoice.invoiceNumber });
        }
      }
    } catch (error) {
      logger.error('❌ خطأ في إرسال التذكيرات', error);
    }
  }

  /**
   * توليد تقرير الإيرادات
   */
  static async generateRevenueReport() {
    try {
      logger.info('📊 جاري توليد تقرير الإيرادات الشهري...');

      const startOfMonth = new Date(new Date().getFullYear(), new Date().getMonth(), 1);
      const endOfMonth = new Date(new Date().getFullYear(), new Date().getMonth() + 1, 0);

      const revenueStats = await Invoice.aggregate([
        {
          $match: {
            issueDate: { $gte: startOfMonth, $lte: endOfMonth }
          }
        },
        {
          $group: {
            _id: null,
            totalRevenue: { $sum: '$total' },
            totalPaid: { $sum: '$amountPaid' },
            totalPending: { $sum: '$balanceDue' },
            invoiceCount: { $sum: 1 }
          }
        }
      ]);

      logger.success('✅ تم توليد تقرير الإيرادات', revenueStats[0]);
    } catch (error) {
      logger.error('❌ خطأ في توليد التقرير', error);
    }
  }
}

