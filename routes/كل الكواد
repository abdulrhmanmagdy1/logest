const os = require('os');
const logger = require('../utils/logger');

class PerformanceMonitor {
  constructor() {
    this.metrics = {
      requestCount: 0,
      totalTime: 0,
      errors: 0,
      startTime: Date.now()
    };
    this.startMonitoring();
  }

  /**
   * بدء المراقبة
   */
  startMonitoring() {
    setInterval(() => {
      this.logSystemMetrics();
    }, 60000); // كل دقيقة
  }

  /**
   * تسجيل مقاييس النظام
   */
  logSystemMetrics() {
    try {
      const cpuUsage = os.loadavg()[0];
      const memUsage = process.memoryUsage();
      const uptime = process.uptime();

      const avgResponseTime = this.metrics.requestCount > 0
        ? (this.metrics.totalTime / this.metrics.requestCount).toFixed(2)
        : 0;

      const errorRate = this.metrics.requestCount > 0
        ? ((this.metrics.errors / this.metrics.requestCount) * 100).toFixed(2)
        : 0;

      logger.info('📊 مقاييس الأداء', {
        cpuUsage: `${(cpuUsage * 100).toFixed(2)}%`,
        memUsage: {
          heapUsed: `${(memUsage.heapUsed / 1024 / 1024).toFixed(2)} MB`,
          heapTotal: `${(memUsage.heapTotal / 1024 / 1024).toFixed(2)} MB`,
          external: `${(memUsage.external / 1024 / 1024).toFixed(2)} MB`
        },
        uptime: `${uptime.toFixed(2)}s`,
        requestMetrics: {
          totalRequests: this.metrics.requestCount,
          avgResponseTime: `${avgResponseTime}ms`,
          errorRate: `${errorRate}%`
        }
      });

      // Reset metrics
      if (this.metrics.requestCount > 10000) {
        this.metrics = {
          requestCount: 0,
          totalTime: 0,
          errors: 0,
          startTime: Date.now()
        };
      }
    } catch (error) {
      logger.error('❌ خطأ في مراقبة الأداء', error);
    }
  }

  /**
   * Middleware لتتبع وقت الطلب
   */
  static trackRequestTime(req, res, next) {
    const startTime = Date.now();

    res.on('finish', () => {
      const duration = Date.now() - startTime;
      PerformanceMonitor.instance.metrics.requestCount++;
      PerformanceMonitor.instance.metrics.totalTime += duration;

      if (res.statusCode >= 400) {
        PerformanceMonitor.instance.metrics.errors++;
      }

      // Log slow requests
      if (duration > 1000) {
        logger.warn('⚠️ طلب بطيء', {
          method: req.method,
          path: req.path,
          duration: `${duration}ms`,
          statusCode: res.statusCode
        });
      }
    });

    next();
  }

  /**
   * الحصول على تقرير الأداء
   */
  getPerformanceReport() {
    const uptime = (Date.now() - this.metrics.startTime) / 1000;
    const avgResponseTime = this.metrics.requestCount > 0
      ? (this.metrics.totalTime / this.metrics.requestCount).toFixed(2)
      : 0;

    const errorRate = this.metrics.requestCount > 0
      ? ((this.metrics.errors / this.metrics.requestCount) * 100).toFixed(2)
      : 0;

    return {
      uptime,
      requests: {
        total: this.metrics.requestCount,
        avgResponseTime: `${avgResponseTime}ms`,
        errors: this.metrics.errors,
        errorRate: `${errorRate}%`
      },
      system: {
        cpuUsage: os.loadavg()[0],
        freeMemory: os.freemem(),
        totalMemory: os.totalmem(),
        nodeVersion: process.version,
        platform: os.platform()
      }
    };
  }

  /**
   * Instance holder
   */
  static get instance() {
    if (!this._instance) {
      this._instance = new PerformanceMonitor();
    }
    return this._instance;
  }
}

