const { HTTP_STATUS, MESSAGES } = require('../config/constants');
const logger = require('../utils/logger');

/**
 * Custom Error Class
 */
class AppError extends Error {
  constructor(message, statusCode) {
    super(message);
    this.statusCode = statusCode;
    this.isOperational = true;
    Error.captureStackTrace(this, this.constructor);
  }
}

/**
 * معالج الأخطاء المركزي
 */
const errorHandler = (err, req, res, next) => {
  err.statusCode = err.statusCode || HTTP_STATUS.INTERNAL_ERROR;
  err.message = err.message || MESSAGES.ERROR;

  // Log error
  logger.error(`Error: ${err.message}`, {
    statusCode: err.statusCode,
    path: req.path,
    method: req.method,
    userId: req.user?._id,
    ip: req.ip,
    stack: err.stack
  });

  // Mongoose duplicate key error
  if (err.code === 11000) {
    const field = Object.keys(err.keyPattern)[0];
    err.statusCode = HTTP_STATUS.CONFLICT;
    err.message = `${field} موجود بالفعل`;
  }

  // Mongoose validation error
  if (err.name === 'ValidationError') {
    const fields = Object.keys(err.errors);
    err.statusCode = HTTP_STATUS.UNPROCESSABLE_ENTITY;
    err.message = `خطأ في التحقق: ${fields.join(', ')}`;
  }

  // JWT errors
  if (err.name === 'JsonWebTokenError') {
    err.statusCode = HTTP_STATUS.UNAUTHORIZED;
    err.message = MESSAGES.INVALID_TOKEN;
  }

  if (err.name === 'TokenExpiredError') {
    err.statusCode = HTTP_STATUS.UNAUTHORIZED;
    err.message = MESSAGES.TOKEN_EXPIRED;
  }

  // Response
  const response = {
    success: false,
    message: err.message,
    ...(process.env.NODE_ENV === 'development' && { error: err.stack })
  };

  if (err.errors) {
    response.errors = err.errors;
  }

  res.status(err.statusCode).json(response);
};

/**
 * معالج الطلبات التي لم يتم العثور عليها
 */
const notFound = (req, res, next) => {
  logger.warn('404 - المسار غير موجود', {
    path: req.originalUrl,
    method: req.method,
    ip: req.ip
  });

  const error = new AppError(`المسار غير موجود: ${req.originalUrl}`, HTTP_STATUS.NOT_FOUND);
  next(error);
};

/**
 * معالج الأخطاء غير المتوقعة
 */
const asyncHandler = (fn) => {
  return (req, res, next) => {
    Promise.resolve(fn(req, res, next)).catch(next);
  };
};

module.exports = {
  AppError,
  errorHandler,
  notFound,
  asyncHandler
};
