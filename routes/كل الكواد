const { PAGINATION } = require('../config/constants');

class Pagination {
  /**
   * حساب skip و limit
   */
  static calculatePagination(page = 1, limit = PAGINATION.DEFAULT_LIMIT) {
    const pageNum = Math.max(1, parseInt(page));
    const limitNum = Math.min(parseInt(limit), PAGINATION.MAX_LIMIT);
    const skip = (pageNum - 1) * limitNum;

    return { pageNum, limitNum, skip };
  }

  /**
   * إنشاء استجابة التقسيم
   */
  static getPaginationResponse(data, total, page, limit) {
    const { pageNum, limitNum } = this.calculatePagination(page, limit);
    const pages = Math.ceil(total / limitNum);

    return {
      data,
      pagination: {
        total,
        page: pageNum,
        limit: limitNum,
        pages,
        hasNextPage: pageNum < pages,
        hasPrevPage: pageNum > 1,
        nextPage: pageNum < pages ? pageNum + 1 : null,
        prevPage: pageNum > 1 ? pageNum - 1 : null
      }
    };
  }

  /**
   * معالجة query parameters
   */
  static parseQueryParams(query) {
    return {
      page: parseInt(query.page) || PAGINATION.DEFAULT_PAGE,
      limit: parseInt(query.limit) || PAGINATION.DEFAULT_LIMIT,
      sortBy: query.sortBy || 'createdAt',
      sortOrder: query.sortOrder === 'asc' ? 1 : -1,
      search: query.search || '',
      filters: this.parseFilters(query)
    };
  }

  /**
   * معالجة الفلاتر
   */
  static parseFilters(query) {
    const filters = {};

    // Date range filters
    if (query.dateFrom || query.dateTo) {
      filters.dateRange = {};
      if (query.dateFrom) {
        filters.dateRange.$gte = new Date(query.dateFrom);
      }
      if (query.dateTo) {
        filters.dateRange.$lte = new Date(query.dateTo);
      }
    }

    // Price range filters
    if (query.minPrice || query.maxPrice) {
      filters.priceRange = {};
      if (query.minPrice) {
        filters.priceRange.$gte = parseFloat(query.minPrice);
      }
      if (query.maxPrice) {
        filters.priceRange.$lte = parseFloat(query.maxPrice);
      }
    }

    // Status filter
    if (query.status) {
      filters.status = Array.isArray(query.status) ? query.status : [query.status];
    }

    return filters;
  }
}

module.exports = Pagination;
