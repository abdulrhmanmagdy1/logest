    if (notes) shipment.notes = notes;
    if (status === SHIPMENT_STATUS.ASSIGNED) {
      shipment.driver = driverId;
      shipment.truck = truckId;
    }
    if (status === SHIPMENT_STATUS.IN_TRANSIT) {
      shipment.actualPickupDate = new Date();
    }
    if (status === SHIPMENT_STATUS.DELIVERED) {
      shipment.actualDeliveryDate = new Date();
