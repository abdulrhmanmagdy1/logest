const Truck = require('../models/Truck');
const OilSchedule = require('../models/OilSchedule');
const Maintenance = require('../models/Maintenance');
const Shipment = require('../models/Shipment');
const { MESSAGES, HTTP_STATUS, TRUCK_STATUS, PAGINATION } = require('../config/constants');
const logger = require('../utils/logger');
const Helpers = require('../utils/helpers');

class TruckController {
  /**
   * الحصول على جميع الشاحنات مع الفلاتر المتقدمة
   */
  static async getAll(req, res) {
    try {
      const { 
        page = PAGINATION.DEFAULT_PAGE, 
        limit = PAGINATION.DEFAULT_LIMIT,
        status,
        maintenanceStatus,
        search 
      } = req.query;

      const skip = (page - 1) * limit;
      let query = { deletedAt: null };

      // Apply filters
      if (status) query.status = status;
      if (maintenanceStatus) query.maintenanceStatus = maintenanceStatus;
      
      if (search) {
        query.$or = [
          { truckNumber: new RegExp(search, 'i') },
          { plateNumber: new RegExp(search, 'i') },
          { model: new RegExp(search, 'i') }
        ];
      }

      const trucks = await Truck.find(query)
        .populate('driver', 'name phone email')
        .skip(skip)
        .limit(Math.min(parseInt(limit), PAGINATION.MAX_LIMIT))
        .sort({ createdAt: -1 });

      // Get statistics for each truck
      const trucksWithStats = await Promise.all(trucks.map(async (truck) => {
        const totalTrips = await Shipment.countDocuments({ truck: truck._id });
        const totalKm = truck.currentKilometers || 0;
        const maintenanceDue = truck.nextMaintenanceDate 
          ? truck.nextMaintenanceDate <= new Date() 
          : false;

        return {
          ...truck.toObject(),
          stats: {
            totalTrips,
            totalKilometers: totalKm,
            maintenanceDue,
            daysUntilMaintenance: truck.nextMaintenanceDate 
            ? Math.ceil((truck.nextMaintenanceDate - new Date()) / (1000 * 60 * 60 * 24))
            : null
          }
        };
      }));

      const total = await Truck.countDocuments(query);

      logger.info('Trucks retrieved', { count: trucks.length, page });

      res.json({
        success: true,
        data: trucksWithStats,
        pagination: {
          total,
          page: parseInt(page),
          limit: parseInt(limit),
          pages: Math.ceil(total / limit)
        }
      });
    } catch (error) {
      logger.error('Get trucks error', error);
      res.status(HTTP_STATUS.INTERNAL_ERROR).json({
        success: false,
        message: MESSAGES.ERROR
      });
    }
  }

  /**
   * الحصول على شاحنة واحدة مع تفاصيل شاملة
   */
  static async getById(req, res) {
    try {
      const truck = await Truck.findById(req.params.id)
        .populate('driver', 'name phone email');

      if (!truck || truck.deletedAt) {
        return res.status(HTTP_STATUS.NOT_FOUND).json({
          success: false,
          message: MESSAGES.NOT_FOUND
        });
      }

      // Get related data
      const [maintenance, oilSchedule, currentShipment, tripHistory] = await Promise.all([
        Maintenance.find({ truck: truck._id }).limit(10).sort({ createdAt: -1 }),
        OilSchedule.findOne({ truck: truck._id }).sort({ createdAt: -1 }),
        Shipment.findOne({ truck: truck._id, status: { $in: ['assigned', 'in_transit'] } }),
        Shipment.find({ truck: truck._id }).limit(20).sort({ createdAt: -1 })
      ]);

      res.json({
        success: true,
        data: {
          ...truck.toObject(),
          relatedData: {
            maintenance,
            oilSchedule,
            currentShipment,
            tripHistory
          }
        }
      });
    } catch (error) {
      logger.error('Get truck error', error);
      res.status(HTTP_STATUS.INTERNAL_ERROR).json({
        success: false,
        message: MESSAGES.ERROR
      });
    }
  }

  /**
   * إنشاء شاحنة جديدة
   */
  static async create(req, res) {
    try {
      const { truckNumber, plateNumber, model, brand, year, capacity, driver } = req.body;

      // Check duplicate
      const existingTruck = await Truck.findOne({ 
        $or: [{ truckNumber }, { plateNumber }] 
      });

      if (existingTruck) {
        return res.status(HTTP_STATUS.CONFLICT).json({
          success: false,
          message: 'الشاحنة موجودة بالفعل'
        });
      }

      const truck = new Truck({
        truckNumber,
        plateNumber,
        model,
        brand,
        year,
        capacity,
        driver: driver || null,
        status: TRUCK_STATUS.ACTIVE,
        maintenanceStatus: 'good',
        lastMaintenanceDate: new Date()
      });

      await truck.save();

      // Create initial oil schedule
      const oilSchedule = new OilSchedule({
        truck: truck._id,
        lastChangeDate: new Date(),
        nextChangeDate: new Date(Date.now() + 90 * 24 * 60 * 60 * 1000), // 3 months
        lastChangeKilometers: 0,
        nextChangeKilometers: 5000
      });

      await oilSchedule.save();

      logger.success('Truck created', { truckNumber, plateNumber });

      res.status(HTTP_STATUS.CREATED).json({
        success: true,
        message: MESSAGES.CREATED,
        data: truck
      });
    } catch (error) {
      logger.error('Create truck error', error);
      res.status(HTTP_STATUS.INTERNAL_ERROR).json({
        success: false,
        message: MESSAGES.ERROR
      });
    }
  }

  /**
   * تحديث بيانات الشاحنة
   */
  static async update(req, res) {
    try {
      const allowedFields = ['driver', 'status', 'maintenanceStatus', 'model', 'year'];
      const updates = {};

      allowedFields.forEach(field => {
        if (req.body[field] !== undefined) {
          updates[field] = req.body[field];
        }
      });

      updates.updatedAt = new Date();

      const truck = await Truck.findByIdAndUpdate(
        req.params.id,
        updates,
        { new: true, runValidators: true }
      ).populate('driver', 'name phone');

      if (!truck) {
        return res.status(HTTP_STATUS.NOT_FOUND).json({
          success: false,
          message: MESSAGES.NOT_FOUND
        });
      }

      logger.success('Truck updated', { truckId: req.params.id });

      res.json({
        success: true,
        message: MESSAGES.UPDATED,
        data: truck
      });
    } catch (error) {
      logger.error('Update truck error', error);
      res.status(HTTP_STATUS.INTERNAL_ERROR).json({
        success: false,
        message: MESSAGES.ERROR
      });
    }
  }

  /**
   * تحديث الموقع الحالي للشاحنة
   */
  static async updateLocation(req, res) {
    try {
      const { latitude, longitude, address, speed } = req.body;

      if (!latitude || !longitude) {
        return res.status(HTTP_STATUS.BAD_REQUEST).json({
          success: false,
          message: 'الإحداثيات مطلوبة'
        });
      }

      const truck = await Truck.findByIdAndUpdate(
        req.params.id,
        {
          currentLocation: {
            latitude,
            longitude,
            address: address || 'Unknown',
            updatedAt: new Date()
          },
          updatedAt: new Date()
        },
        { new: true }
      );

      if (!truck) {
        return res.status(HTTP_STATUS.NOT_FOUND).json({
          success: false,
          message: MESSAGES.NOT_FOUND
        });
      }

      logger.info('Truck location updated', { truckId: req.params.id, latitude, longitude });

      res.json({
        success: true,
        message: 'تم تحديث الموقع بنجاح',
        data: truck
      });
    } catch (error) {
      logger.error('Update location error', error);
      res.status(HTTP_STATUS.INTERNAL_ERROR).json({
        success: false,
        message: MESSAGES.ERROR
      });
    }
  }

  /**
   * تحديث عداد الكيلومترات
   */
  static async updateKilometers(req, res) {
    try {
      const { currentKilometers } = req.body;

      if (currentKilometers < 0) {
        return res.status(HTTP_STATUS.BAD_REQUEST).json({
          success: false,
          message: 'عداد الكيلومترات لا يمكن أن يكون سالباً'
        });
      }

      const truck = await Truck.findById(req.params.id);
      if (!truck) {
        return res.status(HTTP_STATUS.NOT_FOUND).json({
          success: false,
          message: MESSAGES.NOT_FOUND
        });
      }

      const previousKilometers = truck.currentKilometers || 0;
      const distance = currentKilometers - previousKilometers;

      truck.currentKilometers = currentKilometers;
      truck.totalKilometers = (truck.totalKilometers || 0) + Math.max(0, distance);
      truck.updatedAt = new Date();

      // Check if oil change is needed
      const oilSchedule = await OilSchedule.findOne({ truck: truck._id });
      if (oilSchedule && currentKilometers >= oilSchedule.nextChangeKilometers) {
        truck.maintenanceStatus = 'due';
      }

      await truck.save();

      logger.info('Kilometers updated', { truckId: req.params.id, distance });

      res.json({
        success: true,
        message: 'تم تحديث عداد الكيلومترات',
        data: truck
      });
    } catch (error) {
      logger.error('Update kilometers error', error);
      res.status(HTTP_STATUS.INTERNAL_ERROR).json({
        success: false,
        message: MESSAGES.ERROR
      });
    }
  }

  /**
   * حذف شاحنة (Soft Delete)
   */
  static async delete(req, res) {
    try {
      const truck = await Truck.findByIdAndUpdate(
        req.params.id,
        { deletedAt: new Date() },
        { new: true }
      );

      if (!truck) {
        return res.status(HTTP_STATUS.NOT_FOUND).json({
          success: false,
          message: MESSAGES.NOT_FOUND
        });
      }

      logger.success('Truck deleted', { truckId: req.params.id });

      res.json({
        success: true,
        message: MESSAGES.DELETED
      });
    } catch (error) {
      logger.error('Delete truck error', error);
      res.status(HTTP_STATUS.INTERNAL_ERROR).json({
        success: false,
        message: MESSAGES.ERROR
      });
    }
  }

  /**
   * الحصول على إحصائيات الأسطول
   */
  static async getFleetStatistics(req, res) {
    try {
      const [total, active, maintenance, outOfService] = await Promise.all([
        Truck.countDocuments({ deletedAt: null }),
        Truck.countDocuments({ status: TRUCK_STATUS.ACTIVE, deletedAt: null }),
        Truck.countDocuments({ status: TRUCK_STATUS.MAINTENANCE, deletedAt: null }),
        Truck.countDocuments({ status: TRUCK_STATUS.OUT_OF_SERVICE, deletedAt: null })
      ]);

      const totalCapacity = await Truck.aggregate([
        { $match: { deletedAt: null } },
        { $group: { _id: null, total: { $sum: '$capacity' } } }
      ]);

      const totalKilometers = await Truck.aggregate([
        { $match: { deletedAt: null } },
        { $group: { _id: null, total: { $sum: '$totalKilometers' } } }
      ]);

      res.json({
        success: true,
        data: {
          total,
          active,
          maintenance,
          outOfService,
          utilization: Math.round((active / total) * 100) || 0,
          totalCapacity: totalCapacity[0]?.total || 0,
          totalKilometers: totalKilometers[0]?.total || 0
        }
      });
    } catch (error) {
      logger.error('Get fleet statistics error', error);
      res.status(HTTP_STATUS.INTERNAL_ERROR).json({
        success: false,
        message: MESSAGES.ERROR
      });
    }
  }
}

