      print('🔔 Firebase Token: $token');

      // Local notifications setup
      await _initializeLocalNotifications();

      // Handle foreground messages
      FirebaseMessaging.onMessage.listen(_handleForegroundMessage);

      // Handle background messages
      FirebaseMessaging.onMessageOpenedApp.listen(_handleMessageOpenedApp);

      print('✅ تم تهيئة الإشعارات بنجاح');
    } catch (e) {
      print('❌ خطأ في تهيئة الإشعارات: $e');
    }
  }

  /// تهيئة الإشعارات المحلية
  Future<void> _initializeLocalNotifications() async {
    const AndroidInitializationSettings androidSettings =
        AndroidInitializationSettings('@mipmap/ic_launcher');
    const IOSInitializationSettings iosSettings = IOSInitializationSettings();

    const InitializationSettings initSettings = InitializationSettings(
      android: androidSettings,
      iOS: iosSettings,
    );

    await _localNotifications.initialize(
      initSettings,
      onSelectNotification: _handleNotificationClick,
    );
  }

  /// معالجة الإشعارات في المقدمة
  void _handleForegroundMessage(RemoteMessage message) {
    print('📨 رسالة: ${message.notification?.title}');

    _showLocalNotification(
      title: message.notification?.title ?? 'إشعار',
      body: message.notification?.body ?? '',
      data: message.data,
    );
  }

  /// معالجة الإشعار عند فتح التطبيق
  void _handleMessageOpenedApp(RemoteMessage message) {
    print('📲 فتح الرسالة: ${message.notification?.title}');
    _navigateToPage(message.data);
  }

  /// عرض إشعار محلي
  Future<void> _showLocalNotification({
    required String title,
    required String body,
    Map<String, dynamic>? data,
  }) async {
    const AndroidNotificationDetails androidDetails =
        AndroidNotificationDetails(
      'edham_notifications',
      'إدهام',
      channelDescription: 'إشعارات إدهام',
      importance: Importance.max,
      priority: Priority.high,
      ticker: 'ticker',
    );

    const NotificationDetails details = NotificationDetails(
      android: androidDetails,
    );

    await _localNotifications.show(
      0,
      title,
      body,
      details,
      payload: data != null ? data.toString() : null,
    );
  }

  /// معالجة نقر الإشعار
  Future<void> _handleNotificationClick(String? payload) async {
    if (payload != null) {
      final data = _parsePayload(payload);
      _navigateToPage(data);
    }
  }

  /// الملاحة إلى الصفحة
  void _navigateToPage(Map<String, dynamic> data) {
    if (data['type'] == 'shipment') {
      Get.toNamed('/shipment-detail', arguments: data['id']);
    } else if (data['type'] == 'invoice') {
      Get.toNamed('/invoice-detail', arguments: data['id']);
    }
  }

  /// تحليل البيانات
  Map<String, dynamic> _parsePayload(String payload) {
    try {
      return Map<String, dynamic>.from(
        payload.split(',').fold<Map<String, dynamic>>({}, (acc, item) {
          final parts = item.split(':');
          if (parts.length == 2) {
            acc[parts[0].trim()] = parts[1].trim();
          }
          return acc;
        }),
      );
    } catch (e) {
      return {};
    }
  }

  /// الحصول على التوكن
  Future<String?> getToken() async {
    return await _firebaseMessaging.getToken();
  }

  /// الاشتراك في الموضوع
  Future<void> subscribeToTopic(String topic) async {
    await _firebaseMessaging.subscribeToTopic(topic);
    print('✅ تم الاشتراك في: $topic');
  }

  /// إلغاء الاشتراك عن الموضوع
  Future<void> unsubscribeFromTopic(String topic) async {
    await _firebaseMessaging.unsubscribeFromTopic(topic);
    print('✅ تم إلغاء الاشتراك عن: $topic');
  }
