  static async recommendBestDriver(shipment) {
    try {
      const drivers = await User.find({
        role: 'driver',
        isActive: true
      }).lean();

      const driverScores = await Promise.all(
        drivers.map(async (driver) => {
          const trips = await Trip.find({
            employee: driver._id,
            status: 'completed'
          }).limit(50).lean();

          const shipments = await Shipment.find({
            driver: driver._id,
            status: 'delivered'
          }).limit(50).lean();

          // Calculate metrics
          const avgDeliveryTime = trips.length > 0
            ? trips.reduce((sum, t) => sum + (t.duration || 0), 0) / trips.length
            : 0;

          const onTimeRate = shipments.length > 0
            ? (shipments.filter(s => new Date(s.actualDeliveryDate) <= new Date(s.scheduledDeliveryDate)).length / shipments.length) * 100
            : 0;

          const totalDistance = trips.reduce((sum, t) => sum + (t.distance || 0), 0);

          // Calculate score
          let score = 100;
          score -= (avgDeliveryTime / 100) * 10; // Penalize slow deliveries
          score += (onTimeRate / 100) * 20; // Reward on-time rate
          score -= (Math.abs(totalDistance - shipment.estimatedCost * 50) / 1000); // Prefer drivers near route

          return {
            driverId: driver._id,
            driverName: driver.name,
            score: Math.max(0, score),
            metrics: {
              avgDeliveryTime,
              onTimeRate,
              totalTrips: trips.length,
              totalShipments: shipments.length
            }
          };
        })
      );

      return driverScores.sort((a, b) => b.score - a.score).slice(0, 5);
    } catch (error) {
      logger.error('❌ خطأ في التوصية بالسائق', error);
      return [];
    }
  }

  /**
   * تحليل الأنماط والاتجاهات
   */
  static async analyzePatterns() {
    try {
      const past30Days = new Date(Date.now() - 30 * 24 * 60 * 60 * 1000);

      // Daily shipment volume
      const dailyVolume = await Shipment.aggregate([
        {
          $match: { createdAt: { $gte: past30Days } }
        },
        {
          $group: {
            _id: { $dateToString: { format: '%Y-%m-%d', date: '$createdAt' } },
            count: { $sum: 1 },
            totalWeight: { $sum: '$weight' }
          }
        },
        { $sort: { _id: 1 } }
      ]);

      // Peak hours
      const peakHours = await Shipment.aggregate([
        {
          $match: { createdAt: { $gte: past30Days } }
        },
        {
          $group: {
            _id: { $hour: '$createdAt' },
            count: { $sum: 1 }
          }
        },
        { $sort: { count: -1 } },
        { $limit: 5 }
      ]);

      // Popular routes
      const popularRoutes = await Shipment.aggregate([
        {
          $match: { createdAt: { $gte: past30Days } }
        },
        {
          $group: {
            _id: {
              from: '$pickupLocation.city',
              to: '$deliveryLocation.city'
            },
            count: { $sum: 1 },
            avgWeight: { $avg: '$weight' }
          }
        },
        { $sort: { count: -1 } },
        { $limit: 10 }
      ]);

      return {
        dailyVolume,
        peakHours,
        popularRoutes,
        recommendations: this.generateRecommendations(dailyVolume, peakHours, popularRoutes)
      };
    } catch (error) {
      logger.error('❌ خطأ في تحليل الأنماط', error);
      return null;
    }
  }

  /**
   * توليد التوصيات
   */
  static generateRecommendations(dailyVolume, peakHours, popularRoutes) {
    const recommendations = [];

    // Check volume trends
    if (dailyVolume.length > 7) {
      const recentDays = dailyVolume.slice(-7);
      const avgRecent = recentDays.reduce((sum, d) => sum + d.count, 0) / 7;
      const avgPrevious = dailyVolume.slice(0, -7).reduce((sum, d) => sum + d.count, 0) / (dailyVolume.length - 7);

      if (avgRecent > avgPrevious * 1.2) {
        recommendations.push({
          type: 'increase_capacity',
          priority: 'high',
          message: 'الطلب يزداد بسرعة - يجب زيادة السعة'
        });
      }
    }

    // Peak hours recommendation
    if (peakHours.length > 0) {
      recommendations.push({
        type: 'staffing',
        priority: 'medium',
        message: `ذروة الطلب في الساعة ${peakHours[0]._id}:00 - زيادة الموظفين`
      });
    }

    // Route optimization
    const largestRoute = popularRoutes[0];
    if (largestRoute && largestRoute.count > 50) {
      recommendations.push({
        type: 'route_optimization',
        priority: 'medium',
        message: `الطريق ${largestRoute._id.from} → ${largestRoute._id.to} مزدحمة - تحسين المسار`,
        route: largestRoute._id
      });
    }

    return recommendations;
  }

  /**
   * حساب الانحراف المعياري
   */
  static calculateStandardDeviation(values, mean) {
    const squareDiffs = values.map(value => Math.pow(value - mean, 2));
    const avgSquareDiff = squareDiffs.reduce((a, b) => a + b) / values.length;
    return Math.sqrt(avgSquareDiff);
  }

  /**
   * حساب درجة الثقة
   */
  static calculateConfidence(sampleSize, stdDev) {
    let confidence = Math.min(sampleSize / 100, 1);
    confidence *= (1 - Math.min(stdDev / 100, 1));
    return Math.round(confidence * 100);
  }

  /**
   * حساب المسافة
   */
  static calculateDistance(from, to) {
    const R = 6371; // Earth's radius in km
    const dLat = (to.latitude - from.latitude) * Math.PI / 180;
    const dLon = (to.longitude - from.longitude) * Math.PI / 180;
    const a = Math.sin(dLat / 2) * Math.sin(dLat / 2) +
      Math.cos(from.latitude * Math.PI / 180) * Math.cos(to.latitude * Math.PI / 180) *
      Math.sin(dLon / 2) * Math.sin(dLon / 2);
    const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
    return R * c;
  }
}

