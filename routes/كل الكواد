const Invoice = require('../models/Invoice');
const Truck = require('../models/Truck');
const Trip = require('../models/Trip');
const Maintenance = require('../models/Maintenance');
const moment = require('moment-hijri');
const logger = require('../utils/logger');
const ReportGenerator = require('./reportGenerator');

class ReportService {
  /**
   * تقرير الأداء الشامل
   */
  static async generateComprehensiveReport(dateRange) {
    try {
      const { startDate, endDate } = this.parseDateRange(dateRange);

      logger.info('📊 جاري إنشاء التقرير الشامل...', { startDate, endDate });

      const report = {
        period: `${moment(startDate).format('DD/MM/YYYY')} - ${moment(endDate).format('DD/MM/YYYY')}`,
        generatedAt: moment().format('YYYY-MM-DD HH:mm:ss'),
        sections: {}
      };

      // Shipment Summary
      report.sections.shipments = await this.generateShipmentReport(startDate, endDate);

      // Financial Summary
      report.sections.financial = await this.generateFinancialReport(startDate, endDate);

      // Fleet Performance
      report.sections.fleet = await this.generateFleetReport(startDate, endDate);

      // Driver Performance
      report.sections.drivers = await this.generateDriverReport(startDate, endDate);

      // Maintenance Summary
      report.sections.maintenance = await this.generateMaintenanceReport(startDate, endDate);

      // KPIs
      report.kpis = this.calculateKPIs(report.sections);

      // Recommendations
      report.recommendations = this.generateRecommendations(report.sections);

      logger.success('✅ تم إنشاء التقرير الشامل');

      return report;
    } catch (error) {
      logger.error('❌ خطأ في إنشاء التقرير', error);
      throw error;
    }
  }

  /**
   * تقرير الشحنات
   */
  static async generateShipmentReport(startDate, endDate) {
    const query = { createdAt: { $gte: startDate, $lte: endDate } };

    const [total, byStatus, avgDeliveryTime] = await Promise.all([
      Shipment.countDocuments(query),
      Shipment.aggregate([
        { $match: query },
        { $group: { _id: '$status', count: { $sum: 1 } } }
      ]),
      Shipment.aggregate([
        {
          $match: {
            ...query,
            status: 'delivered',
            actualPickupDate: { $exists: true },
            actualDeliveryDate: { $exists: true }
          }
        },
        {
          $group: {
            _id: null,
            avgTime: {
              $avg: {
                $subtract: ['$actualDeliveryDate', '$actualPickupDate']
              }
            }
          }
        }
      ])
    ]);

    const statusMap = {};
    byStatus.forEach(s => {
      statusMap[s._id] = s.count;
    });

    return {
      total,
      byStatus: statusMap,
      avgDeliveryTime: avgDeliveryTime[0]
        ? Math.round(avgDeliveryTime[0].avgTime / (1000 * 60 * 60))
        : 0,
      completionRate: total > 0
        ? Math.round(((statusMap.delivered || 0) / total) * 100)
        : 0
    };
  }

  /**
   * التقرير المالي
   */
  static async generateFinancialReport(startDate, endDate) {
    const query = { issueDate: { $gte: startDate, $lte: endDate } };

    const revenueStats = await Invoice.aggregate([
      { $match: query },
      {
        $group: {
          _id: '$status',
          count: { $sum: 1 },
          totalRevenue: { $sum: '$total' },
          totalPaid: { $sum: '$amountPaid' },
          totalPending: { $sum: '$balanceDue' }
        }
      }
    ]);

    let totalRevenue = 0;
    let totalPaid = 0;
    let totalPending = 0;
    const statusStats = {};

    revenueStats.forEach(stat => {
      statusStats[stat._id] = {
        count: stat.count,
        revenue: stat.totalRevenue,
        paid: stat.totalPaid,
        pending: stat.totalPending
      };
      totalRevenue += stat.totalRevenue;
      totalPaid += stat.totalPaid;
      totalPending += stat.totalPending;
    });

    return {
      totalRevenue: Math.round(totalRevenue),
      totalPaid: Math.round(totalPaid),
      totalPending: Math.round(totalPending),
      collectionRate: totalRevenue > 0
        ? Math.round((totalPaid / totalRevenue) * 100)
        : 0,
      invoiceStats: statusStats
    };
  }

  /**
   * تقرير الأسطول
   */
  static async generateFleetReport(startDate, endDate) {
    const tripsQuery = { createdAt: { $gte: startDate, $lte: endDate } };

    const [totalTrips, completedTrips, totalDistance, totalFuelUsed] = await Promise.all([
      Trip.countDocuments(tripsQuery),
      Trip.countDocuments({ ...tripsQuery, status: 'completed' }),
      Trip.aggregate([
        { $match: tripsQuery },
        { $group: { _id: null, total: { $sum: '$distance' } } }
      ]),
      Trip.aggregate([
        { $match: tripsQuery },
        { $group: { _id: null, total: { $sum: '$fuelConsumption' } } }
      ])
    ]);

    const trucks = await Truck.find().select('_id truckNumber');
    const truckStats = await Promise.all(
      trucks.map(async (truck) => {
        const trips = await Trip.countDocuments({
          vehicle: truck._id,
          ...tripsQuery
        });
        return { truck: truck.truckNumber, trips };
      })
    );

    return {
      totalTrips,
      completedTrips,
      completionRate: totalTrips > 0
        ? Math.round((completedTrips / totalTrips) * 100)
        : 0,
      totalDistance: totalDistance[0]?.total || 0,
      totalFuelUsed: totalFuelUsed[0]?.total || 0,
      fuelEfficiency: totalDistance[0]?.total > 0
        ? ((totalDistance[0].total / (totalFuelUsed[0]?.total || 1)).toFixed(2))
        : 0,
      truckStats
    };
  }

  /**
   * تقرير السائقين
   */
  static async generateDriverReport(startDate, endDate) {
    const shippentsQuery = { createdAt: { $gte: startDate, $lte: endDate } };

    const driverStats = await Shipment.aggregate([
      { $match: shippentsQuery },
      { $match: { driver: { $exists: true } } },
      {
        $group: {
          _id: '$driver',
          totalShipments: { $sum: 1 },
          deliveredShipments: {
            $sum: { $cond: [{ $eq: ['$status', 'delivered'] }, 1, 0] }
          },
          totalWeight: { $sum: '$weight' }
        }
      },
      {
        $lookup: {
          from: 'users',
          localField: '_id',
          foreignField: '_id',
          as: 'driverInfo'
        }
      },
      { $unwind: '$driverInfo' },
      {
        $project: {
          driverName: '$driverInfo.name',
          totalShipments: 1,
          deliveredShipments: 1,
          totalWeight: 1,
          deliveryRate: {
            $multiply: [
              { $divide: ['$deliveredShipments', '$totalShipments'] },
              100
            ]
          }
        }
      },
      { $sort: { totalShipments: -1 } }
    ]);

    return {
      topPerformers: driverStats.slice(0, 10),
      totalStats: {
        totalDrivers: driverStats.length,
        totalShipmentsByDrivers: driverStats.reduce((sum, d) => sum + d.totalShipments, 0)
      }
    };
  }

  /**
   * تقرير الصيانة
   */
  static async generateMaintenanceReport(startDate, endDate) {
    const query = { createdAt: { $gte: startDate, $lte: endDate } };

    const [completed, pending, byType] = await Promise.all([
      Maintenance.countDocuments({ ...query, status: 'completed' }),
      Maintenance.countDocuments({ ...query, status: 'pending' }),
      Maintenance.aggregate([
        { $match: query },
        { $group: { _id: '$type', count: { $sum: 1 }, totalCost: { $sum: '$cost' } } }
      ])
    ]);

    const costStats = await Maintenance.aggregate([
      { $match: query },
      {
        $group: {
          _id: null,
          totalCost: { $sum: '$cost' },
          avgCost: { $avg: '$cost' }
        }
      }
    ]);

    return {
      completed,
      pending,
      byType: byType.reduce((acc, t) => {
        acc[t._id] = { count: t.count, cost: t.totalCost };
        return acc;
      }, {}),
      totalCost: costStats[0]?.totalCost || 0,
      avgCostPerMaintenance: costStats[0]?.avgCost || 0
    };
  }

  /**
   * حساب مؤشرات الأداء الرئيسية
   */
  static calculateKPIs(sections) {
    return {
      operationalEfficiency: {
        name: 'كفاءة التشغيل',
        value: sections.shipments.completionRate,
        unit: '%',
        target: 95
      },
      financialHealth: {
        name: 'الصحة المالية',
        value: sections.financial.collectionRate,
        unit: '%',
        target: 90
      },
      fleetUtilization: {
        name: 'استخدام الأسطول',
        value: sections.fleet.completionRate,
        unit: '%',
        target: 85
      },
      fuelEfficiency: {
        name: 'كفاءة الوقود',
        value: parseFloat(sections.fleet.fuelEfficiency),
        unit: 'km/l',
        target: 6
      },
      customerSatisfaction: {
        name: 'رضا العملاء',
        value: sections.drivers.totalStats.totalDrivers > 0 ? 85 : 0,
        unit: '%',
        target: 90
      }
    };
  }

  /**
   * توليد التوصيات
   */
  static generateRecommendations(sections) {
    const recommendations = [];

    if (sections.shipments.completionRate < 85) {
      recommendations.push({
        priority: 'high',
        category: 'Operations',
        message: 'معدل الإكمال منخفض - يجب تحسين الكفاءة التشغيلية'
      });
    }

    if (sections.financial.collectionRate < 80) {
      recommendations.push({
        priority: 'high',
        category: 'Finance',
        message: 'معدل التحصيل منخفض - يجب متابعة الديون المعلقة'
      });
    }

    if (sections.fleet.fuelEfficiency < 5) {
      recommendations.push({
        priority: 'medium',
        category: 'Fleet',
        message: 'كفاءة الوقود منخفضة - يجب صيانة المركبات'
      });
    }

    if (sections.maintenance.pending > sections.maintenance.completed) {
      recommendations.push({
        priority: 'high',
        category: 'Maintenance',
        message: 'هناك عمليات صيانة معلقة - يجب الإسراع في إنجازها'
      });
    }

    return recommendations;
  }

  /**
   * معالجة نطاق التاريخ
   */
  static parseDateRange(dateRange) {
    const endDate = new Date();
    let startDate;

    switch (dateRange) {
      case 'week':
        startDate = new Date(endDate.setDate(endDate.getDate() - 7));
        break;
      case 'month':
        startDate = new Date(endDate.setMonth(endDate.getMonth() - 1));
        break;
      case 'quarter':
        startDate = new Date(endDate.setMonth(endDate.getMonth() - 3));
        break;
      case 'year':
        startDate = new Date(endDate.setFullYear(endDate.getFullYear() - 1));
        break;
      default:
        startDate = new Date(endDate.setMonth(endDate.getMonth() - 1));
    }

    return { startDate, endDate };
  }
}

module.exports = ReportService;
