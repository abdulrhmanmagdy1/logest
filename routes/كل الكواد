class NotificationService {
  /**
   * إرسال إشعار شامل
   */
  static async send(userId, options = {}) {
    try {
      const {
        type,
        title,
        message,
        data = {},
        channels = ['in_app'],
        email = null,
        phone = null
      } = options;

      // Create notification record
      const notification = new Notification({
        user: userId,
        type,
        title,
        message,
        data
      });

      // Send via channels
      const results = {};

      if (channels.includes('in_app')) {
        results.in_app = await this.sendInApp(notification);
      }

      if (channels.includes('email') && email) {
        results.email = await this.sendEmail(notification, email, title, message);
      }

      if (channels.includes('sms') && phone) {
        results.sms = await this.sendSMS(notification, phone, message);
      }

      if (channels.includes('push')) {
        results.push = await this.sendPush(notification);
      }

      // Update notification status
      notification.channels = {
        email: { sent: results.email ? true : false },
        sms: { sent: results.sms ? true : false },
        push: { sent: results.push ? true : false },
        in_app: { sent: results.in_app ? true : false }
      };

      notification.deliveryStatus = Object.values(results).some(r => r)
        ? 'delivered'
        : 'failed';

      await notification.save();

      logger.success('✅ تم إرسال الإشعار', {
        userId,
        type,
        results
      });

      return notification;
    } catch (error) {
      logger.error('❌ خطأ في إرسال الإشعار', error);
      throw error;
    }
  }

  /**
   * إرسال إشعار في التطبيق
   */
  static async sendInApp(notification) {
    try {
      // يمكن إرسالها عبر WebSocket أو إشعار الخادم
      return true;
    } catch (error) {
      logger.error('❌ خطأ في إرسال الإشعار في التطبيق', error);
      return false;
    }
  }

  /**
   * إرسال عبر البريد الإلكتروني
   */
  static async sendEmail(notification, email, title, message) {
    try {
      const mailOptions = {
        from: process.env.SMTP_FROM,
        to: email,
        subject: title,
        html: `
          <div style="font-family: Arial, sans-serif; direction: rtl; text-align: right;">
            <h1>${title}</h1>
            <p>${message}</p>
          </div>
        `
      };

      await EmailService.transporter.sendMail(mailOptions);
      notification.channels.email.sent = true;
      notification.channels.email.sentAt = new Date();
      return true;
    } catch (error) {
      logger.error('❌ خطأ في إرسال البريد', error);
      return false;
    }
  }

  /**
   * إرسال عبر SMS
   */
  static async sendSMS(notification, phone, message) {
    try {
      if (!process.env.TWILIO_ACCOUNT_SID) {
        logger.warn('⚠️ Twilio غير مكون');
        return false;
      }

      // Twilio logic here
      notification.channels.sms.sent = true;
      notification.channels.sms.sentAt = new Date();
      return true;
    } catch (error) {
      logger.error('❌ خطأ في إرسال SMS', error);
      return false;
    }
  }

  /**
   * إرسال Push Notification
   */
  static async sendPush(notification) {
    try {
      // Firebase Cloud Messaging logic here
      notification.channels.push.sent = true;
      notification.channels.push.sentAt = new Date();
      return true;
    } catch (error) {
      logger.error('❌ خطأ في إرسال Push', error);
      return false;
    }
  }

  /**
   * الحصول على إشعارات المستخدم
   */
  static async getUserNotifications(userId, { read = null, limit = 20 }) {
    try {
      const query = { user: userId };
      if (read !== null) {
        query.read = read;
      }

      return await Notification.find(query)
        .sort({ sentAt: -1 })
        .limit(limit);
    } catch (error) {
      logger.error('❌ خطأ في جلب الإشعارات', error);
      throw error;
    }
  }

  /**
   * حذف إشعار قديم
   */
  static async deleteOldNotifications(daysOld = 30) {
    try {
      const date = new Date(Date.now() - daysOld * 24 * 60 * 60 * 1000);
      const result = await Notification.deleteMany({ sentAt: { $lt: date } });
      logger.info('🗑️  تم حذف الإشعارات القديمة', { deletedCount: result.deletedCount });
      return result;
    } catch (error) {
      logger.error('❌ خطأ في حذف الإشعارات', error);
      throw error;
    }
  }
