const rateLimit = require('express-rate-limit');
const RedisStore = require('rate-limit-redis');
const redis = require('redis');
const logger = require('../utils/logger');

// Create Redis client
const redisClient = redis.createClient({
  url: process.env.REDIS_URL || 'redis://localhost:6379'
});

redisClient.on('error', (err) => logger.error('Redis error', err));
redisClient.on('connect', () => logger.success('Connected to Redis'));

/**
 * General API limiter
 */
const generalLimiter = rateLimit({
  store: new RedisStore({
    client: redisClient,
    prefix: 'rl:general:'
  }),
  windowMs: 15 * 60 * 1000, // 15 minutes
  max: 100,
  message: 'عدد كبير جداً من الطلبات، يرجى المحاولة لاحقاً',
  standardHeaders: true,
  legacyHeaders: false,
  handler: (req, res) => {
    logger.warn('Rate limit exceeded', {
      ip: req.ip,
      path: req.path
    });
    res.status(429).json({
      success: false,
      message: 'عدد الطلبات كبير جداً'
    });
  }
});

/**
 * Authentication limiter (stricter)
 */
const authLimiter = rateLimit({
  store: new RedisStore({
    client: redisClient,
    prefix: 'rl:auth:'
  }),
  windowMs: 15 * 60 * 1000,
  max: 5,
  message: 'عدد محاولات دخول كبير، يرجى المحاولة لاحقاً',
  skipSuccessfulRequests: true,
  handler: (req, res) => {
    logger.warn('Auth rate limit exceeded', {
      ip: req.ip,
      email: req.body.email
    });
    res.status(429).json({
      success: false,
      message: 'عدد محاولات الدخول كبير جداً'
    });
  }
});

/**
 * Payment limiter
 */
const paymentLimiter = rateLimit({
  store: new RedisStore({
    client: redisClient,
    prefix: 'rl:payment:'
  }),
  windowMs: 60 * 60 * 1000, // 1 hour
  max: 10,
  message: 'عدد محاولات الدفع كبير جداً',
  handler: (req, res) => {
    logger.warn('Payment rate limit exceeded', {
      ip: req.ip,
      userId: req.user?._id
    });
    res.status(429).json({
      success: false,
      message: 'عدد محاولات الدفع كبير جداً'
    });
  }
});

/**
 * File upload limiter
 */
const uploadLimiter = rateLimit({
  store: new RedisStore({
    client: redisClient,
    prefix: 'rl:upload:'
  }),
  windowMs: 60 * 60 * 1000,
  max: 50,
  message: 'عدد عمليات الرفع كبير جداً'
});

/**
 * API key limiter
 */
const apiKeyLimiter = rateLimit({
  store: new RedisStore({
    client: redisClient,
    prefix: 'rl:apikey:'
  }),
  windowMs: 60 * 1000,
  max: 1000,
  keyGenerator: (req) => req.headers['x-api-key'] || req.ip
});

module.exports = {
  generalLimiter,
  authLimiter,
  paymentLimiter,
  uploadLimiter,
  apiKeyLimiter,
  redisClient
};
