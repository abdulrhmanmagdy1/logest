// ============ PRIMARY COLORS ============
$primary-dark: #003D5C;        // Main brand color
$primary-light: #0099D8;       // CTA & Interactive elements
$primary-gold: #D4AF37;        // Accents & Details

// ============ SECONDARY COLORS ============
$secondary-blue: #005A7F;      // Hover states
$navy-dark: #001F3F;           // Text & Dark elements
$dark-bg: #1A1A1A;             // Dark backgrounds
$light-gray: #F5F5F5;          // Secondary backgrounds

// ============ NEUTRAL COLORS ============
$white: #FFFFFF;
$black: #000000;
$gray-50: #F9FAFB;
$gray-100: #F3F4F6;
$gray-200: #E5E7EB;
$gray-300: #D1D5DB;
$gray-400: #9CA3AF;
$gray-500: #6B7280;
$gray-600: #4B5563;
$gray-700: #374151;
$gray-800: #1F2937;

// ============ STATUS COLORS ============
$success: #10B981;             // Green
$warning: #F59E0B;             // Orange
$error: #EF4444;               // Red
$info: #3B82F6;                // Blue

// ============ GRADIENTS ============
$gradient-primary: linear-gradient(135deg, $primary-dark 0%, $primary-light 100%);
$gradient-dark: linear-gradient(135deg, $primary-dark 0%, $secondary-blue 100%);
$gradient-light: linear-gradient(135deg, $primary-light 0%, #00C9FF 100%);

// ============ SHADOWS ============
$shadow-sm: 0 2px 4px rgba(0, 61, 92, 0.1);
$shadow-md: 0 4px 8px rgba(0, 61, 92, 0.15);
$shadow-lg: 0 8px 16px rgba(0, 61, 92, 0.2);
$shadow-xl: 0 12px 24px rgba(0, 61, 92, 0.25);

// ============ TRANSITIONS ============
$transition-fast: 0.15s ease-in-out;
$transition-normal: 0.3s ease-in-out;
$transition-slow: 0.5s ease-in-out;

// ============ BREAKPOINTS ============
$mobile: 320px;
$tablet: 768px;
$desktop: 1024px;
$wide: 1440px;
