const PDFDocument = require('pdfkit');

class InvoiceController {
  /**
   * الحصول على جميع الفواتير
   */
  static async getAll(req, res) {
    try {
      const { 
        page = 1, 
        limit = 20, 
        status, 
        client, 
        dateFrom, 
        dateTo 
      } = req.query;

      const skip = (page - 1) * limit;
      let query = {};

      if (status) query.status = status;
      if (client) query.client = client;
      if (dateFrom || dateTo) {
        query.issueDate = {};
        if (dateFrom) query.issueDate.$gte = new Date(dateFrom);
        if (dateTo) query.issueDate.$lte = new Date(dateTo);
      }

      const invoices = await Invoice.find(query)
        .populate('client', 'name email phone')
        .populate('shipment', 'shipmentNumber weight')
        .populate('accountant', 'name')
        .skip(skip)
        .limit(Math.min(parseInt(limit), 100))
        .sort({ issueDate: -1 });

      const total = await Invoice.countDocuments(query);

      res.json({
        success: true,
        data: invoices,
        pagination: {
          total,
          page: parseInt(page),
          limit: parseInt(limit),
          pages: Math.ceil(total / limit)
        }
      });
    } catch (error) {
      logger.error('Get invoices error', error);
      res.status(HTTP_STATUS.INTERNAL_ERROR).json({
        success: false,
        message: MESSAGES.ERROR
      });
    }
  }

  /**
   * إنشاء فاتورة جديدة
   */
  static async create(req, res) {
    try {
      const { 
        shipment, 
        client, 
        items, 
        subtotal, 
        tax, 
        discount = 0,
        notes 
      } = req.body;

      const invoiceNumber = Helpers.generateInvoiceNumber();
      const serialNumber = `SN-${Date.now()}-${Math.random().toString(36).substr(2, 9)}`;
      const verificationCode = Math.random().toString(36).substr(2, 8).toUpperCase();

      const total = subtotal - discount + tax;

      const invoice = new Invoice({
        invoiceNumber,
        serialNumber,
        verificationCode,
        shipment,
        client: client || null,
        items,
        subtotal,
        tax,
        discount,
        total,
        balanceDue: total,
        accountant: req.user._id,
        issueDate: new Date(),
        dueDate: new Date(Date.now() + 30 * 24 * 60 * 60 * 1000), // 30 days
        notes
      });

      await invoice.save();
      await invoice.populate(['client', 'shipment', 'accountant']);

      logger.success('Invoice created', { invoiceNumber, total });

      res.status(HTTP_STATUS.CREATED).json({
        success: true,
        message: MESSAGES.CREATED,
        data: invoice
      });
    } catch (error) {
      logger.error('Create invoice error', error);
      res.status(HTTP_STATUS.INTERNAL_ERROR).json({
        success: false,
        message: MESSAGES.ERROR
      });
    }
  }

  /**
   * تسجيل دفعة
   */
  static async recordPayment(req, res) {
    try {
      const { amount, method, reference, notes } = req.body;

      const invoice = await Invoice.findById(req.params.id);
      if (!invoice) {
        return res.status(HTTP_STATUS.NOT_FOUND).json({
          success: false,
          message: MESSAGES.NOT_FOUND
        });
      }

      if (amount > invoice.balanceDue) {
        return res.status(HTTP_STATUS.BAD_REQUEST).json({
          success: false,
          message: 'المبلغ يتجاوز الرصيد المتبقي'
        });
      }

      const payment = new Payment({
        invoice: invoice._id,
        amount,
        method,
        reference,
        transactionId: `TXN-${Date.now()}`,
        processedBy: req.user._id,
        notes
      });

      await payment.save();

      // Update invoice
      invoice.amountPaid += amount;
      invoice.balanceDue -= amount;
      invoice.status = invoice.balanceDue === 0 ? INVOICE_STATUS.PAID : INVOICE_STATUS.PARTIAL;
      invoice.paymentHistory.push({
