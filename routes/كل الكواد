const Redis = require('redis');
const logger = require('../utils/logger');
const { HTTP_STATUS } = require('../config/constants');

class AdvancedRateLimiter {
  constructor() {
    this.client = Redis.createClient({
      url: process.env.REDIS_URL || 'redis://localhost:6379'
    });
    this.client.connect();
  }

  /**
   * تحديد المعدل بناءً على المستخدم والـ IP
   */
  async limit(req, res, next) {
    try {
      const key = this.generateKey(req);
      const limit = this.getLimit(req);
      const windowMs = this.getWindow(req);

      const current = await this.client.incr(key);

      if (current === 1) {
        await this.client.expire(key, Math.ceil(windowMs / 1000));
      }

      res.set('X-RateLimit-Limit', limit);
      res.set('X-RateLimit-Remaining', Math.max(0, limit - current));
      res.set('X-RateLimit-Reset', new Date(Date.now() + windowMs).toISOString());

      if (current > limit) {
        logger.warn('⚠️ تجاوز حد المعدل', {
          ip: req.ip,
          userId: req.user?._id,
          current,
          limit
        });

        return res.status(HTTP_STATUS.TOO_MANY_REQUESTS).json({
          success: false,
          message: 'عدد كبير جداً من الطلبات، يرجى المحاولة لاحقاً',
          retryAfter: Math.ceil(windowMs / 1000)
        });
      }

      next();
    } catch (error) {
      logger.error('❌ خطأ في تحديد المعدل', error);
      next(); // لا تحجب الطلب إذا حدث خطأ
    }
  }

  /**
   * توليد مفتاح فريد
   */
  generateKey(req) {
    const userId = req.user?._id || 'anonymous';
    const ip = req.ip;
    const endpoint = req.path;
    return `ratelimit:${userId}:${ip}:${endpoint}`;
  }

  /**
   * الحصول على حد المعدل
   */
  getLimit(req) {
    if (req.user?.role === 'admin') {
      return 1000; // الأدمن لديه حد أعلى
    }

    const endpoint = req.path;
    if (endpoint.includes('/auth')) {
      return 5; // حد منخفض للمصادقة
    }
    if (endpoint.includes('/payments')) {
      return 10; // حد منخفض للدفع
    }

    return 100; // الحد الافتراضي
  }

  /**
   * الحصول على نافذة المراقبة
   */
  getWindow(req) {
    const endpoint = req.path;
    if (endpoint.includes('/auth')) {
      return 15 * 60 * 1000; // 15 دقيقة
    }
    if (endpoint.includes('/payments')) {
      return 60 * 60 * 1000; // ساعة واحدة
    }

    return 15 * 60 * 1000; // 15 دقيقة
  }

  /**
   * تنظيف المفاتيح القديمة
   */
  async cleanup() {
    const keys = await this.client.keys('ratelimit:*');
    if (keys.length > 0) {
      await this.client.del(keys);
      logger.info('🧹 تم تنظيف مفاتيح حد المعدل', { count: keys.length });
    }
  }
}

module.exports = new AdvancedRateLimiter();
