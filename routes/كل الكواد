const Truck = require('../models/Truck');
const Maintenance = require('../models/Maintenance');
const OilSchedule = require('../models/OilSchedule');
const Trip = require('../models/Trip');
const Shipment = require('../models/Shipment');
const { MESSAGES, HTTP_STATUS, TRUCK_STATUS, MAINTENANCE_STATUS } = require('../config/constants');
const logger = require('../utils/logger');
const { asyncHandler } = require('../middleware/errorHandler');

class TruckController {
  /**
   * الحصول على جميع الشاحنات مع الإحصائيات
   */
  static getAll = asyncHandler(async (req, res) => {
    const { page = 1, limit = 20, status, maintenanceStatus, search } = req.query;

    const pageNum = Math.max(1, parseInt(page));
    const limitNum = Math.min(parseInt(limit), 100);
    const skip = (pageNum - 1) * limitNum;

    let query = { deletedAt: null };

    if (status) query.status = status;
    if (maintenanceStatus) query.maintenanceStatus = maintenanceStatus;
    if (search) {
      query.$or = [
        { truckNumber: new RegExp(search, 'i') },
        { plateNumber: new RegExp(search, 'i') }
      ];
    }

    const trucks = await Truck.find(query)
      .populate('driver', 'name phone email')
      .skip(skip)
      .limit(limitNum)
      .sort({ createdAt: -1 });

    // Add statistics for each truck
    const trucksWithStats = await Promise.all(
      trucks.map(async (truck) => {
        const [totalTrips, activeTripCount, nextMaintenance] = await Promise.all([
          Trip.countDocuments({ vehicle: truck._id }),
          Trip.countDocuments({ vehicle: truck._id, status: { $in: ['started', 'in_progress'] } }),
          Maintenance.findOne({ truck: truck._id, status: { $in: [MAINTENANCE_STATUS.PENDING, MAINTENANCE_STATUS.SCHEDULED] } }).sort({ scheduledDate: 1 })
        ]);

        return {
          ...truck.toObject(),
          stats: {
            totalTrips,
            activeTrips: activeTripCount,
            nextMaintenance: nextMaintenance ? {
              date: nextMaintenance.scheduledDate,
              type: nextMaintenance.type
            } : null
          }
        };
      })
    );

    const total = await Truck.countDocuments(query);

    res.json({
      success: true,
      data: trucksWithStats,
      pagination: {
        total,
        page: pageNum,
        limit: limitNum,
        pages: Math.ceil(total / limitNum)
      }
    });
  });

  /**
   * إنشاء شاحنة جديدة
   */
  static create = asyncHandler(async (req, res) => {
    const { truckNumber, plateNumber, model, brand, year, capacity, driver } = req.body;

    // Check for duplicates
    const existingTruck = await Truck.findOne({
      $or: [{ truckNumber }, { plateNumber }]
    });

    if (existingTruck) {
      return res.status(HTTP_STATUS.CONFLICT).json({
        success: false,
        message: 'الشاحنة موجودة بالفعل'
      });
    }

    const truck = new Truck({
      truckNumber,
      plateNumber,
      model,
      brand,
      year: parseInt(year),
      capacity: parseFloat(capacity),
      driver: driver || null,
      status: TRUCK_STATUS.ACTIVE,
      maintenanceStatus: 'good',
      lastMaintenanceDate: new Date(),
      nextMaintenanceDate: new Date(Date.now() + 3 * 30 * 24 * 60 * 60 * 1000) // 3 months
    });

    await truck.save();

    // Create oil schedule
    const oilSchedule = new OilSchedule({
      truck: truck._id,
      lastChangeDate: new Date(),
      nextChangeDate: new Date(Date.now() + 90 * 24 * 60 * 60 * 1000),
      lastChangeKilometers: 0,
      nextChangeKilometers: 5000
    });

    await oilSchedule.save();

    logger.success('تم إنشاء شاحنة جديدة', {
      truckNumber,
      plateNumber,
      capacity
    });

    res.status(HTTP_STATUS.CREATED).json({
      success: true,
      message: MESSAGES.CREATED,
      data: truck
    });
  });

  /**
   * الحصول على شاحنة واحدة مع التفاصيل الكاملة
   */
  static getById = asyncHandler(async (req, res) => {
    const truck = await Truck.findById(req.params.id)
      .populate('driver', 'name phone email');

    if (!truck || truck.deletedAt) {
      return res.status(HTTP_STATUS.NOT_FOUND).json({
        success: false,
        message: MESSAGES.NOT_FOUND
      });
    }

    const [maintenance, oilSchedule, trips, activeShipment] = await Promise.all([
      Maintenance.find({ truck: truck._id }).limit(10).sort({ createdAt: -1 }),
      OilSchedule.findOne({ truck: truck._id }).sort({ createdAt: -1 }),
      Trip.find({ vehicle: truck._id }).limit(5).sort({ createdAt: -1 }),
      Shipment.findOne({ truck: truck._id, status: { $in: ['assigned', 'in_transit'] } })
    ]);

    res.json({
      success: true,
      data: {
        ...truck.toObject(),
        maintenance,
        oilSchedule,
        recentTrips: trips,
        activeShipment
      }
    });
  });

  /**
   * تحديث الموقع الحالي للشاحنة
   */
  static updateLocation = asyncHandler(async (req, res) => {
    const { latitude, longitude, address, speed } = req.body;

    if (!latitude || !longitude) {
      return res.status(HTTP_STATUS.BAD_REQUEST).json({
        success: false,
        message: 'الإحداثيات مطلوبة'
      });
    }

    const truck = await Truck.findByIdAndUpdate(
      req.params.id,
      {
        currentLocation: {
          latitude: parseFloat(latitude),
          longitude: parseFloat(longitude),
          address: address || 'Unknown',
          updatedAt: new Date()
        },
        updatedAt: new Date()
      },
      { new: true }
    );

    if (!truck) {
      return res.status(HTTP_STATUS.NOT_FOUND).json({
        success: false,
        message: MESSAGES.NOT_FOUND
      });
    }

    logger.info('تم تحديث موقع الشاحنة', {
      truckNumber: truck.truckNumber,
      latitude,
      longitude
    });

    res.json({
      success: true,
      message: 'تم تحديث الموقع بنجاح',
      data: truck
    });
  });

  /**
   * تحديث عداد الكيلومترات
   */
  static updateKilometers = asyncHandler(async (req, res) => {
    const { currentKilometers } = req.body;

    if (currentKilometers < 0) {
      return res.status(HTTP_STATUS.BAD_REQUEST).json({
        success: false,
        message: 'عداد الكيلومترات لا يمكن أن يكون سالباً'
      });
    }

    const truck = await Truck.findById(req.params.id);
    if (!truck) {
      return res.status(HTTP_STATUS.NOT_FOUND).json({
        success: false,
        message: MESSAGES.NOT_FOUND
      });
    }

    const previousKilometers = truck.currentKilometers || 0;
    const distance = Math.max(0, currentKilometers - previousKilometers);

    truck.currentKilometers = currentKilometers;
    truck.totalKilometers = (truck.totalKilometers || 0) + distance;

    // Check oil schedule
    const oilSchedule = await OilSchedule.findOne({ truck: truck._id });
    if (oilSchedule && currentKilometers >= oilSchedule.nextChangeKilometers) {
      truck.maintenanceStatus = 'due';
    }

    await truck.save();

    logger.info('تم تحديث الكيلومترات', {
      truckNumber: truck.truckNumber,
      distance,
      totalKilometers: truck.totalKilometers
    });

    res.json({
      success: true,
      message: 'تم تحديث عداد الكيلومترات',
      data: truck
    });
  });

  /**
   * الحصول على إحصائيات الأسطول
   */
  static getFleetStatistics = asyncHandler(async (req, res) => {
    const [total, active, maintenance, outOfService, activeTrips, totalTrips] = await Promise.all([
      Truck.countDocuments({ deletedAt: null }),
      Truck.countDocuments({ status: TRUCK_STATUS.ACTIVE, deletedAt: null }),
      Truck.countDocuments({ status: TRUCK_STATUS.MAINTENANCE, deletedAt: null }),
      Truck.countDocuments({ status: TRUCK_STATUS.OUT_OF_SERVICE, deletedAt: null }),
      Trip.countDocuments({ status: { $in: ['started', 'in_progress'] } }),
      Trip.countDocuments({ status: 'completed' })
    ]);

    const capacityData = await Truck.aggregate([
      { $match: { deletedAt: null } },
      {
        $group: {
          _id: null,
          totalCapacity: { $sum: '$capacity' },
          avgCapacity: { $avg: '$capacity' }
        }
      }
    ]);

    const kmData = await Truck.aggregate([
      { $match: { deletedAt: null } },
      {
        $group: {
          _id: null,
          totalKilometers: { $sum: '$totalKilometers' },
          avgKilometers: { $avg: '$totalKilometers' }
        }
      }
    ]);

    res.json({
      success: true,
      data: {
        total,
        active,
        maintenance,
        outOfService,
        utilization: total > 0 ? Math.round((active / total) * 100) : 0,
        activeTrips,
        completedTrips: totalTrips,
        totalCapacity: capacityData[0]?.totalCapacity || 0,
        avgCapacity: capacityData[0]?.avgCapacity || 0,
        totalKilometers: kmData[0]?.totalKilometers || 0,
        avgKilometers: kmData[0]?.avgKilometers || 0
      }
    });
  });
}

