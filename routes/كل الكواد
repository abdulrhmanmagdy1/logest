const cron = require('node-cron');
const Truck = require('../models/Truck');
const Maintenance = require('../models/Maintenance');
const OilSchedule = require('../models/OilSchedule');
const Notification = require('../models/Notification');
const Helpers = require('../utils/helpers');
const logger = require('../utils/logger');

class MaintenanceScheduler {
  static init() {
    // Check maintenance due - every day at 8 AM
    cron.schedule('0 8 * * *', () => {
      this.checkMaintenanceDue();
    });

    // Check oil schedule - every day at 9 AM
    cron.schedule('0 9 * * *', () => {
      this.checkOilSchedule();
    });

    // Generate maintenance reports - every Sunday at 10 AM
    cron.schedule('0 10 ? * SUN', () => {
      this.generateMaintenanceReport();
    });

    logger.success('✅ Maintenance Scheduler initialized');
  }

  /**
   * التحقق من الصيانة المستحقة
   */
  static async checkMaintenanceDue() {
    try {
      logger.info('🔍 جاري التحقق من الصيانة المستحقة...');

      const trucks = await Truck.find({
        status: 'active',
        deletedAt: null,
        nextMaintenanceDate: { $lte: new Date(Date.now() + 7 * 24 * 60 * 60 * 1000) }
      });

      for (const truck of trucks) {
        const daysUntilMaintenance = Math.ceil(
          (truck.nextMaintenanceDate - new Date()) / (1000 * 60 * 60 * 24)
        );

        if (daysUntilMaintenance <= 0) {
          truck.maintenanceStatus = 'urgent';
        } else if (daysUntilMaintenance <= 3) {
          truck.maintenanceStatus = 'due';
        } else {
          truck.maintenanceStatus = 'warning';
        }

        await truck.save();

        // Create notification
        const supervisors = await require('../models/User').find({
          role: 'supervisor',
          isActive: true
        });

        for (const supervisor of supervisors) {
          await Notification.create({
            user: supervisor._id,
            type: 'maintenance_due',
            title: 'صيانة مستحقة',
            message: `الشاحنة ${truck.truckNumber} بحاجة لصيانة`,
            data: { truckId: truck._id },
            read: false
          });
        }

        logger.info('⚠️ صيانة مستحقة', {
          truckNumber: truck.truckNumber,
          daysUntilMaintenance
        });
      }
    } catch (error) {
      logger.error('❌ خطأ في التحقق من الصيانة', error);
    }
  }

  /**
   * التحقق من جدولة الزيت
   */
  static async checkOilSchedule() {
    try {
      logger.info('🔍 جاري التحقق من جدول الزيت...');

      const oilSchedules = await OilSchedule.find({
        nextChangeDate: { $lte: new Date(Date.now() + 7 * 24 * 60 * 60 * 1000) }
      }).populate('truck');

      for (const schedule of oilSchedules) {
        const truck = schedule.truck;
        const daysUntil = Math.ceil(
          (schedule.nextChangeDate - new Date()) / (1000 * 60 * 60 * 24)
        );

        if (daysUntil <= 0) {
          truck.maintenanceStatus = 'urgent';
        }

        await truck.save();

        logger.info('🛢️ تغيير زيت مستحق', {
          truckNumber: truck.truckNumber,
          daysUntil
        });
      }
    } catch (error) {
      logger.error('❌ خطأ في التحقق من الزيت', error);
    }
  }

  /**
   * توليد تقرير الصيانة
   */
  static async generateMaintenanceReport() {
    try {
      logger.info('📊 جاري توليد تقرير الصيانة الأسبوعي...');

      const weekAgo = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000);

      const maintenanceStats = await Maintenance.aggregate([
        {
          $match: {
            createdAt: { $gte: weekAgo }
          }
        },
        {
          $group: {
            _id: '$type',
            count: { $sum: 1 },
            totalCost: { $sum: '$cost' }
          }
        }
      ]);

      const completedMaintenance = await Maintenance.countDocuments({
        status: 'completed',
        completedDate: { $gte: weekAgo }
      });

      const pendingMaintenance = await Maintenance.countDocuments({
        status: 'pending'
      });

      logger.success('✅ تم توليد تقرير الصيانة', {
        maintenanceStats,
        completedCount: completedMaintenance,
        pendingCount: pendingMaintenance
      });
    } catch (error) {
      logger.error('❌ خطأ في توليد التقرير', error);
    }
  }
}

module.exports = MaintenanceScheduler;
