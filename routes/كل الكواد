class EnvValidator {
  constructor() {
    this.required = [
      'MONGODB_URI',
      'JWT_SECRET',
      'NODE_ENV',
      'PORT'
    ];

    this.optional = [
      'STRIPE_SECRET_KEY',
      'GOOGLE_MAPS_API_KEY',
      'SMTP_HOST',
      'REDIS_URL'
    ];

    this.validate();
  }

  validate() {
    const missing = this.required.filter(key => !process.env[key]);

    if (missing.length > 0) {
      console.error('❌ متغيرات البيئة المفقودة:');
      missing.forEach(key => console.error(`   - ${key}`));
      process.exit(1);
    }

    console.log('✅ تم التحقق من جميع متغيرات البيئة');
  }

  get config() {
    return {
      // Server
