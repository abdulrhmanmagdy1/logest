require('dotenv').config();
const mongoose = require('mongoose');
const fs = require('fs');
const path = require('path');
const archiver = require('archiver');
const logger = require('../utils/logger');

class BackupManager {
  constructor() {
    this.backupDir = path.join(__dirname, '../backups');
    this.ensureBackupDir();
  }

  ensureBackupDir() {
    if (!fs.existsSync(this.backupDir)) {
      fs.mkdirSync(this.backupDir, { recursive: true });
    }
  }

  async connectDB() {
    try {
      await mongoose.connect(process.env.MONGODB_URI);
      logger.success('✅ تم الاتصال بقاعدة البيانات');
    } catch (error) {
      logger.error('❌ خطأ في الاتصال', error);
      throw error;
    }
  }

  async disconnectDB() {
    await mongoose.disconnect();
    logger.success('✅ تم قطع الاتصال');
  }

  async exportCollections() {
    try {
      logger.info('📤 جاري تصدير المجموعات...');

      const models = [
        'User',
        'Shipment',
        'Truck',
        'Invoice',
        'Maintenance',
        'Trip',
        'OilSchedule',
        'SparePart',
        'Survey',
        'AuditLog'
      ];

      const exportDir = path.join(this.backupDir, `export-${Date.now()}`);
      fs.mkdirSync(exportDir);

      for (const modelName of models) {
        try {
          const model = require(`../models/${modelName}`);
          const data = await model.find({}).lean();
          
          const filePath = path.join(exportDir, `${modelName}.json`);
          fs.writeFileSync(filePath, JSON.stringify(data, null, 2));
          
          logger.success(`✅ تم تصدير ${modelName} (${data.length} سجل)`);
        } catch (error) {
          logger.warn(`⚠️ لم يتمكن من تصدير ${modelName}`, error.message);
        }
      }

      return exportDir;
    } catch (error) {
      logger.error('❌ خطأ في التصدير', error);
      throw error;
    }
  }

  async compressBackup(exportDir) {
    return new Promise((resolve, reject) => {
      try {
        logger.info('📦 جاري ضغط النسخة الاحتياطية...');

        const zipPath = path.join(
          this.backupDir,
          `backup-${new Date().toISOString().split('T')[0]}.zip`
        );

        const output = fs.createWriteStream(zipPath);
        const archive = archiver('zip', { zlib: { level: 9 } });

        output.on('close', () => {
          logger.success(`✅ تم إنشاء النسخة الاحتياطية: ${zipPath}`);
          resolve(zipPath);
        });

        archive.on('error', (err) => {
          logger.error('❌ خطأ في الضغط', err);
          reject(err);
        });

        archive.pipe(output);
        archive.directory(exportDir, false);
        archive.finalize();
      } catch (error) {
        reject(error);
      }
    });
  }

  async cleanOldBackups(daysToKeep = 30) {
    try {
      logger.info('🧹 جاري تنظيف النسخ القديمة...');

      const files = fs.readdirSync(this.backupDir);
      const now = Date.now();
      const maxAge = daysToKeep * 24 * 60 * 60 * 1000;

      let deletedCount = 0;
      for (const file of files) {
        const filePath = path.join(this.backupDir, file);
        const stats = fs.statSync(filePath);

        if (now - stats.mtime.getTime() > maxAge) {
          fs.unlinkSync(filePath);
          deletedCount++;
          logger.info(`🗑️  تم حذف: ${file}`);
        }
      }

      logger.success(`✅ تم حذف ${deletedCount} نسخة قديمة`);
    } catch (error) {
      logger.error('❌ خطأ في التنظيف', error);
    }
  }

  async run() {
    try {
      logger.info('🔄 بدء عملية النسخ الاحتياطي...');

      await this.connectDB();
      const exportDir = await this.exportCollections();
      const zipPath = await this.compressBackup(exportDir);
      await this.disconnectDB();
      await this.cleanOldBackups();

      logger.success('✅ اكتملت عملية النسخ الاحتياطي!');
      process.exit(0);
    } catch (error) {
      logger.error('❌ فشلت عملية النسخ', error);
      process.exit(1);
    }
  }
}

const backup = new BackupManager();
backup.run();
