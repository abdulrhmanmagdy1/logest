const jwt = require('jsonwebtoken');
const User = require('../models/User');
const config = require('../config/env').config;
const { MESSAGES, HTTP_STATUS } = require('../config/constants');
const logger = require('../utils/logger');

/**
 * التحقق من التوكن والمستخدم
 */
const auth = async (req, res, next) => {
  try {
    const token = extractToken(req);

    if (!token) {
      logger.warn('محاولة وصول بدون توكن', { ip: req.ip, path: req.path });
      return res.status(HTTP_STATUS.UNAUTHORIZED).json({
        success: false,
        message: 'لا توجد رسالة مصادقة'
      });
    }

    // Verify token
    let decoded;
    try {
      decoded = jwt.verify(token, config.JWT_SECRET);
    } catch (error) {
      if (error.name === 'TokenExpiredError') {
        return res.status(HTTP_STATUS.UNAUTHORIZED).json({
          success: false,
          message: MESSAGES.TOKEN_EXPIRED,
          expiredAt: error.expiredAt
        });
      }
      throw error;
    }

    // Get user from database
    const user = await User.findById(decoded.id).select('-password');

    if (!user) {
      logger.warn('محاولة وصول لمستخدم غير موجود', { userId: decoded.id });
      return res.status(HTTP_STATUS.UNAUTHORIZED).json({
        success: false,
        message: 'المستخدم غير موجود'
      });
    }

    if (!user.isActive) {
      logger.warn('محاولة وصول من حساب معطل', { userId: user._id });
      return res.status(HTTP_STATUS.FORBIDDEN).json({
        success: false,
        message: 'الحساب معطل'
      });
    }

    // Attach user to request
    req.user = user;
    req.token = token;

    next();
  } catch (error) {
    logger.error('خطأ في التحقق من المصادقة', error);
    res.status(HTTP_STATUS.INTERNAL_ERROR).json({
      success: false,
      message: MESSAGES.ERROR
    });
  }
};

/**
 * استخراج التوكن من رؤوس الطلب
 */
function extractToken(req) {
  // Check Authorization header
  if (req.headers.authorization) {
    const parts = req.headers.authorization.split(' ');
    if (parts.length === 2 && parts[0] === 'Bearer') {
      return parts[1];
    }
  }

  // Check cookie
  if (req.cookies && req.cookies.token) {
    return req.cookies.token;
  }

  // Check query parameter (for WebSocket)
  if (req.query && req.query.token) {
    return req.query.token;
  }

  return null;
}

/**
 * التحقق من الصلاحيات
 */
const authorize = (...allowedRoles) => {
  return (req, res, next) => {
    try {
      if (!req.user) {
        return res.status(HTTP_STATUS.UNAUTHORIZED).json({
          success: false,
          message: 'لا توجد جلسة مستخدم'
        });
      }

      if (!allowedRoles.includes(req.user.role)) {
        logger.warn('محاولة وصول غير مصرحة', {
          userId: req.user._id,
          userRole: req.user.role,
          requiredRoles: allowedRoles,
          path: req.path
        });

        return res.status(HTTP_STATUS.FORBIDDEN).json({
          success: false,
          message: `ممنوع. الأدوار المسموحة: ${allowedRoles.join(', ')}`,
          userRole: req.user.role,
          requiredRoles: allowedRoles
        });
      }

      next();
    } catch (error) {
      logger.error('خطأ في التحقق من الصلاحيات', error);
      res.status(HTTP_STATUS.INTERNAL_ERROR).json({
        success: false,
        message: MESSAGES.ERROR
      });
    }
  };
};

/**
 * التحقق من الصلاحيات المتقدمة
 */
const checkPermission = (permission) => {
  return (req, res, next) => {
    if (!req.user) {
      return res.status(HTTP_STATUS.UNAUTHORIZED).json({
        success: false,
        message: 'لا توجد جلسة مستخدم'
      });
    }

    // Admin has all permissions
    if (req.user.role === 'admin') {
      return next();
    }

    // Check user permissions
    const userPermissions = getUserPermissions(req.user.role);
    if (!userPermissions.includes(permission)) {
      logger.warn('محاولة وصول لعملية ممنوعة', {
        userId: req.user._id,
        permission,
        userRole: req.user.role
      });

      return res.status(HTTP_STATUS.FORBIDDEN).json({
        success: false,
        message: `ليس لديك الصلاحية للقيام بهذه العملية: ${permission}`
      });
    }

    next();
  };
};

/**
 * الحصول على صلاحيات المستخدم بناءً على دوره
 */
function getUserPermissions(role) {
  const permissions = {
    admin: [
      'create_shipment', 'view_shipment', 'update_shipment', 'delete_shipment',
      'create_invoice', 'view_invoice', 'record_payment',
      'manage_users', 'view_analytics', 'manage_trucks',
      'manage_maintenance', 'manage_payments'
    ],
    supervisor: [
      'create_shipment', 'view_shipment', 'update_shipment',
      'view_invoice', 'manage_trucks', 'manage_maintenance',
      'view_analytics'
    ],
    accountant: [
      'view_shipment', 'view_invoice', 'create_invoice',
      'record_payment', 'view_analytics'
    ],
    driver: [
      'view_shipment', 'update_shipment'
    ],
    client: [
      'create_shipment', 'view_shipment'
    ],
    employee: [
      'view_shipment', 'update_shipment'
    ],
    maintenance: [
      'view_trucks', 'manage_maintenance'
    ]
  };

  return permissions[role] || [];
}

/**
 * التحقق من ملكية المورد
 */
const checkResourceOwnership = async (req, res, next) => {
  try {
    const { id } = req.params;
    const resource = req.params.resourceType || 'shipment';

    let Model;
    let ownerField = 'client';

    if (resource === 'shipment') {
      Model = require('../models/Shipment');
      ownerField = 'client';
    } else if (resource === 'invoice') {
      Model = require('../models/Invoice');
      ownerField = 'client';
    } else if (resource === 'trip') {
      Model = require('../models/Trip');
      ownerField = 'employee';
    }

    if (!Model) {
      return res.status(HTTP_STATUS.NOT_FOUND).json({
        success: false,
        message: 'نوع المورد غير معروف'
      });
    }

    const document = await Model.findById(id);

    if (!document) {
      return res.status(HTTP_STATUS.NOT_FOUND).json({
        success: false,
        message: MESSAGES.NOT_FOUND
      });
    }

    // Admin can access any resource
    if (req.user.role === 'admin') {
      return next();
    }

    // Check ownership
    if (document[ownerField].toString() !== req.user._id.toString()) {
      logger.warn('محاولة وصول غير مصرحة للمورد', {
        userId: req.user._id,
        resourceId: id,
        ownerId: document[ownerField]
      });

      return res.status(HTTP_STATUS.FORBIDDEN).json({
        success: false,
        message: 'ليس لديك صلاحية الوصول إلى هذا المورد'
      });
    }

    req.resource = document;
    next();
  } catch (error) {
    logger.error('خطأ في التحقق من ملكية المورد', error);
    res.status(HTTP_STATUS.INTERNAL_ERROR).json({
      success: false,
      message: MESSAGES.ERROR
    });
  }
};

module.exports = {
  auth,
  authorize,
  checkPermission,
  checkResourceOwnership,
  extractToken
};
