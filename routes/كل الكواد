// ============ BUTTONS ============
.btn {
  &.primary {
    background-color: $primary-light;
    color: $white;
    border: none;
    border-radius: 8px;
    padding: 12px 24px;
    font-weight: 600;
    transition: all $transition-normal;
    
    &:hover {
      background-color: $secondary-blue;
      box-shadow: $shadow-md;
    }
    
    &:active {
      background-color: $primary-dark;
    }
  }

  &.secondary {
    background-color: transparent;
    color: $primary-light;
    border: 2px solid $primary-light;
    border-radius: 8px;
    padding: 10px 22px;
    font-weight: 600;
    
    &:hover {
      background-color: rgba(0, 153, 216, 0.1);
    }
  }

  &.outline {
    background-color: transparent;
    color: $primary-dark;
    border: 2px solid $primary-dark;
    border-radius: 8px;
    padding: 10px 22px;
    
    &:hover {
      background-color: rgba(0, 61, 92, 0.05);
    }
  }
}

// ============ HEADERS ============
header {
  background: linear-gradient(135deg, $primary-dark 0%, $secondary-blue 100%);
  color: $white;
  padding: 20px 0;
  box-shadow: $shadow-md;

  .logo {
    color: $white;
    font-weight: 700;
    font-size: 24px;

    .accent {
      color: $primary-gold;
    }
  }

  .nav-link {
    color: $gray-300;
    transition: color $transition-fast;

    &:hover,
    &.active {
      color: $primary-gold;
    }
  }
}

// ============ SIDEBAR ============
.sidebar {
  background-color: $primary-dark;
  color: $white;
  padding: 20px;

  .menu-item {
    color: $gray-300;
    padding: 12px 16px;
    border-radius: 8px;
    transition: all $transition-fast;

    &:hover {
      background-color: rgba($primary-light, 0.1);
      color: $primary-gold;
    }

    &.active {
      background-color: $primary-light;
      color: $white;
    }
  }
}

// ============ CARDS ============
.card {
  background-color: $white;
  border-radius: 12px;
  border-left: 4px solid $primary-light;
  box-shadow: $shadow-sm;
  padding: 20px;
  transition: all $transition-normal;

  &:hover {
    box-shadow: $shadow-md;
    transform: translateY(-2px);
  }

  &.accent-gold {
    border-left-color: $primary-gold;
  }

  &.accent-success {
    border-left-color: $success;
  }

  .card-title {
    color: $primary-dark;
    font-weight: 700;
    margin-bottom: 10px;
  }

  .card-value {
    color: $primary-light;
    font-size: 32px;
    font-weight: 700;
  }
}

// ============ INPUTS ============
input,
textarea,
select {
  background-color: $white;
  border: 2px solid $gray-200;
  border-radius: 8px;
  padding: 12px 16px;
  color: $navy-dark;
  font-size: 14px;
  transition: all $transition-fast;

  &:focus {
    outline: none;
    border-color: $primary-light;
    box-shadow: 0 0 0 3px rgba(0, 153, 216, 0.1);
  }

  &:hover {
    border-color: $primary-dark;
  }

  &::placeholder {
    color: $gray-400;
  }
}

// ============ BADGES & STATUS ============
.badge {
  display: inline-block;
  padding: 6px 12px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 600;

  &.success {
    background-color: rgba($success, 0.1);
    color: $success;
  }

  &.warning {
    background-color: rgba($warning, 0.1);
    color: $warning;
  }

  &.error {
    background-color: rgba($error, 0.1);
    color: $error;
  }

  &.primary {
    background-color: rgba($primary-light, 0.1);
    color: $primary-light;
  }
}

// ============ TABLES ============
table {
  background-color: $white;
  border-collapse: collapse;

  thead {
    background-color: $light-gray;
    border-bottom: 2px solid $primary-light;

    th {
      color: $primary-dark;
      font-weight: 700;
      padding: 16px;
      text-align: right;
    }
  }

  tbody {
    tr {
      border-bottom: 1px solid $gray-200;
      transition: background-color $transition-fast;

      &:hover {
        background-color: rgba($primary-light, 0.05);
      }

      td {
        color: $navy-dark;
        padding: 12px 16px;
      }
    }
  }
}

// ============ MODALS & OVERLAYS ============
.modal {
  .modal-header {
    background: linear-gradient(135deg, $primary-dark 0%, $secondary-blue 100%);
    color: $white;
    padding: 20px;
    border-radius: 12px 12px 0 0;
  }

  .modal-body {
    background-color: $white;
    padding: 20px;
  }

  .modal-footer {
    background-color: $light-gray;
    padding: 16px 20px;
    border-radius: 0 0 12px 12px;
    display: flex;
    justify-content: flex-end;
    gap: 10px;
  }
}

// ============ NOTIFICATIONS ============
.notification {
  border-radius: 8px;
  padding: 16px;
  margin-bottom: 10px;

  &.success {
    background-color: rgba($success, 0.1);
    border-left: 4px solid $success;
    color: $success;
  }

  &.error {
    background-color: rgba($error, 0.1);
    border-left: 4px solid $error;
    color: $error;
  }

  &.warning {
    background-color: rgba($warning, 0.1);
    border-left: 4px solid $warning;
    color: $warning;
  }

  &.info {
    background-color: rgba($primary-light, 0.1);
    border-left: 4px solid $primary-light;
    color: $primary-light;
  }
}

// ============ CHARTS & GRAPHS ============
.chart {
  background-color: $white;
  border-radius: 12px;
  padding: 20px;
  box-shadow: $shadow-sm;

  line {
    stroke: $primary-light;
  }

  .chart-bar {
    fill: $primary-light;

    &:hover {
      fill: $secondary-blue;
    }
  }
}

// ============ DARK MODE ============
.dark-mode {
  background-color: $dark-bg;
  color: $white;

  .card {
    background-color: $gray-800;
    border-color: $gray-700;
  }

  input,
  textarea,
  select {
    background-color: $gray-800;
    border-color: $gray-700;
    color: $white;
  }

  table {
    background-color: $gray-800;

    thead {
      background-color: $gray-700;
    }

    tbody tr {
      border-color: $gray-700;
    }
  }
}
