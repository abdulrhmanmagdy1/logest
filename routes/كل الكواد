          actualDeliveryDate: status === 'delivered' ? new Date() : null
        };
      });

      const createdShipments = await Shipment.create(shipments);
      logger.success(`✅ تم إنشاء ${createdShipments.length} شحنة`);
      return createdShipments;
    } catch (error) {
      logger.error('❌ خطأ في إنشاء الشحنات', error);
      throw error;
    }
  }

  async seedInvoices(users, shipments) {
    try {
      logger.info('📄 جاري إنشاء الفواتير...');

      const accountants = users.filter(u => u.role === 'accountant');
      const invoiceStatuses = ['pending', 'paid', 'partial', 'overdue'];

      const invoices = shipments.slice(0, 20).map((shipment, i) => {
        const subtotal = Helpers.randomBetween(500, 5000);
        const tax = Math.round(subtotal * 0.15);
        const total = subtotal + tax;

        return {
          invoiceNumber: Helpers.generateInvoiceNumber(),
          serialNumber: `SN-${Date.now()}-${i}`,
          verificationCode: Math.random().toString(36).substr(2, 8).toUpperCase(),
          shipment: shipment._id,
          client: shipment.client,
          accountant: accountants[0]._id,
          items: [
            {
              description: shipment.description,
              quantity: shipment.quantity,
              unitPrice: Math.round(subtotal / shipment.quantity),
              total: subtotal
            }
          ],
          subtotal,
          tax,
          total,
          amountPaid: Helpers.randomBetween(0, total),
          balanceDue: total,
          status: invoiceStatuses[Math.floor(Math.random() * invoiceStatuses.length)],
          issueDate: new Date(),
          dueDate: new Date(Date.now() + 30 * 24 * 60 * 60 * 1000)
        };
      });

      const createdInvoices = await Invoice.create(invoices);
      logger.success(`✅ تم إنشاء ${createdInvoices.length} فاتورة`);
      return createdInvoices;
    } catch (error) {
      logger.error('❌ خطأ في إنشاء الفواتير', error);
      throw error;
    }
  }

  async seedMaintenance(trucks, users) {
    try {
      logger.info('🔧 جاري إنشاء سجلات الصيانة...');

      const maintenanceTypes = [
        'oil_change',
        'tire_replacement',
        'brake_service',
        'engine_inspection'
      ];

      const maintenance = trucks.slice(0, 5).map((truck, i) => ({
        maintenanceNumber: Helpers.generateMaintenanceNumber(),
        truck: truck._id,
        type: maintenanceTypes[i % maintenanceTypes.length],
        description: 'صيانة دورية',
        scheduledDate: new Date(),
        cost: Helpers.randomBetween(500, 2000),
        status: 'completed',
        completedDate: new Date(),
        technician: users.find(u => u.role === 'maintenance')?._id
      }));

      const createdMaintenance = await Maintenance.create(maintenance);
      logger.success(`✅ تم إنشاء ${createdMaintenance.length} سجل صيانة`);
      return createdMaintenance;
    } catch (error) {
      logger.error('❌ خطأ في إنشاء سجلات الصيانة', error);
      throw error;
    }
  }

  async run() {
    try {
      logger.info('🌱 بدء عملية الـ Seed...');

      await this.connect();
      await this.clearData();

      const users = await this.seedUsers();
      const trucks = await this.seedTrucks(users);
      const shipments = await this.seedShipments(users, trucks);
      await this.seedInvoices(users, shipments);
      await this.seedMaintenance(trucks, users);

      logger.success('✅ تمت عملية الـ Seed بنجاح!');
      await this.disconnect();
      process.exit(0);
    } catch (error) {
      logger.error('❌ فشلت عملية الـ Seed', error);
      await this.disconnect();
      process.exit(1);
    }
  }
}

