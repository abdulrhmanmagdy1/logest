const mongoose = require('mongoose');
const logger = require('../utils/logger');

class Database {
  constructor() {
    this.connection = null;
    this.retries = 0;
    this.maxRetries = 5;
  }

  /**
   * الاتصال بقاعدة البيانات مع إعادة المحاولة
   */
  async connect() {
    try {
      logger.info('🔄 جاري الاتصال بقاعدة البيانات...', {
        uri: process.env.MONGODB_URI.replace(/:[^:]*@/, ':****@')
      });

      const conn = await mongoose.connect(process.env.MONGODB_URI, {
        useNewUrlParser: true,
        useUnifiedTopology: true,
        serverSelectionTimeoutMS: 10000,
        socketTimeoutMS: 45000,
        retryWrites: true,
        w: 'majority',
        maxPoolSize: 10,
        minPoolSize: 5
      });

      this.connection = conn;
      this.retries = 0;

      // Set up event listeners
      this.setupEventListeners();

      logger.success('✅ تم الاتصال بقاعدة البيانات بنجاح', {
        host: conn.connection.host,
        db: conn.connection.name,
        timestamp: new Date().toISOString()
      });

      // Create indexes
      await this.createIndexes();

      return conn;
    } catch (error) {
      logger.error('❌ خطأ في الاتصال بقاعدة البيانات', error);

      if (this.retries < this.maxRetries) {
        this.retries++;
        const delay = Math.pow(2, this.retries) * 1000; // Exponential backoff
        logger.warn(`⏳ إعادة محاولة ${this.retries}/${this.maxRetries} بعد ${delay}ms...`);
        
        await new Promise(resolve => setTimeout(resolve, delay));
        return this.connect();
      }

      process.exit(1);
    }
  }

  /**
   * إعداد مستمعي الأحداث
   */
  setupEventListeners() {
    mongoose.connection.on('connected', () => {
      logger.success('🔗 MongoDB متصل');
    });

    mongoose.connection.on('error', (error) => {
      logger.error('❌ خطأ MongoDB:', error);
    });

    mongoose.connection.on('disconnected', () => {
      logger.warn('⚠️ MongoDB غير متصل');
    });

    mongoose.connection.on('reconnected', () => {
      logger.success('🔄 MongoDB متصل من جديد');
    });
  }

  /**
   * إنشاء الفهارس
   */
  async createIndexes() {
    try {
      const User = require('../models/User');
      const Shipment = require('../models/Shipment');
      const Invoice = require('../models/Invoice');
      const Trip = require('../models/Trip');

      await User.collection.createIndex({ email: 1 });
      await User.collection.createIndex({ role: 1 });
      await User.collection.createIndex({ createdAt: -1 });

      await Shipment.collection.createIndex({ client: 1, createdAt: -1 });
      await Shipment.collection.createIndex({ status: 1 });
      await Shipment.collection.createIndex({ driver: 1 });

      await Invoice.collection.createIndex({ client: 1 });
      await Invoice.collection.createIndex({ status: 1 });
      await Invoice.collection.createIndex({ issueDate: -1 });

      await Trip.collection.createIndex({ employee: 1 });
      await Trip.collection.createIndex({ status: 1 });
      await Trip.collection.createIndex({ createdAt: -1 });

      logger.success('✅ تم إنشاء جميع الفهارس');
    } catch (error) {
      logger.error('❌ خطأ في إنشاء الفهارس', error);
    }
  }

  /**
   * قطع الاتصال
   */
  async disconnect() {
    try {
      await mongoose.disconnect();
      logger.success('✅ تم قطع الاتصال بقاعدة البيانات');
    } catch (error) {
      logger.error('❌ خطأ في قطع الاتصال', error);
    }
  }

  /**
   * الحصول على حالة الاتصال
   */
  getStatus() {
    return {
      connected: mongoose.connection.readyState === 1,
      readyState: mongoose.connection.readyState,
      host: mongoose.connection.host,
      db: mongoose.connection.name,
      collections: mongoose.connection.collections.length
    };
  }
}

module.exports = new Database();
