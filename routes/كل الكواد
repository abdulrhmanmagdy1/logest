    const startDate = this.getStartDate(timeRange);

    let query = {
      createdAt: { $gte: startDate },
      deletedAt: null
    };

    if (clientId) query.client = clientId;

    const [total, pending, assigned, inTransit, delivered, cancelled, failed] = await Promise.all([
      Shipment.countDocuments(query),
      Shipment.countDocuments({ ...query, status: SHIPMENT_STATUS.PENDING }),
      Shipment.countDocuments({ ...query, status: SHIPMENT_STATUS.ASSIGNED }),
      Shipment.countDocuments({ ...query, status: SHIPMENT_STATUS.IN_TRANSIT }),
      Shipment.countDocuments({ ...query, status: SHIPMENT_STATUS.DELIVERED }),
      Shipment.countDocuments({ ...query, status: SHIPMENT_STATUS.CANCELLED }),
      Shipment.countDocuments({ ...query, status: SHIPMENT_STATUS.FAILED })
    ]);

    // Calculate average delivery time
    const deliveryStats = await Shipment.aggregate([
      {
        $match: {
          status: SHIPMENT_STATUS.DELIVERED,
          actualPickupDate: { $exists: true },
          actualDeliveryDate: { $exists: true },
          createdAt: { $gte: startDate },
          deletedAt: null,
          ...(clientId && { client: ObjectId(clientId) })
        }
      },
      {
        $group: {
          _id: null,
          avgDeliveryTime: {
            $avg: {
              $subtract: ['$actualDeliveryDate', '$actualPickupDate']
            }
          },
          minDeliveryTime: {
            $min: {
              $subtract: ['$actualDeliveryDate', '$actualPickupDate']
            }
          },
          maxDeliveryTime: {
            $max: {
              $subtract: ['$actualDeliveryDate', '$actualPickupDate']
            }
          }
        }
      }
    ]);

    const avgDeliveryTime = deliveryStats[0]?.avgDeliveryTime
      ? Math.round(deliveryStats[0].avgDeliveryTime / (1000 * 60 * 60))
      : 0;

    res.json({
      success: true,
      data: {
        total,
        byStatus: {
          pending,
          assigned,
          inTransit,
          delivered,
          cancelled,
          failed
        },
        completionRate: total > 0 ? Math.round((delivered / total) * 100) : 0,
        avgDeliveryTime: `${avgDeliveryTime} ساعة`,
        timeRange
      }
    });
  });

  /**
   * دوال مساعدة
   */
  static getStartDate(timeRange) {
    const now = new Date();
    switch (timeRange) {
      case 'week':
        return new Date(now.setDate(now.getDate() - 7));
      case 'month':
        return new Date(now.setMonth(now.getMonth() - 1));
      case 'year':
        return new Date(now.setFullYear(now.getFullYear() - 1));
      default:
        return new Date(now.setMonth(now.getMonth() - 1));
    }
  }

  static getStatusNotificationMessage(status) {
    const messages = {
      [SHIPMENT_STATUS.PENDING]: 'تم إنشاء شحنتك وجاري معالجتها',
      [SHIPMENT_STATUS.ASSIGNED]: 'تم تعيين سائق لشحنتك',
      [SHIPMENT_STATUS.IN_TRANSIT]: 'شحنتك في الطريق الآن',
      [SHIPMENT_STATUS.DELIVERED]: 'تم تسليم شحنتك بنجاح',
      [SHIPMENT_STATUS.CANCELLED]: 'تم إلغاء شحنتك',
      [SHIPMENT_STATUS.FAILED]: 'فشلت عملية توصيل شحنتك'
    };
    return messages[status] || 'تم تحديث حالة الشحنة';
  }

  static async notifySupervisors(notification) {
    const User = require('../models/User');
    const Notification = require('../models/Notification');

    const supervisors = await User.find({
      role: 'supervisor',
      isActive: true,
      deletedAt: null
    });

    for (const supervisor of supervisors) {
      await Notification.create({
        user: supervisor._id,
        ...notification,
        read: false
      });
    }
  }

  static async notifyRelatedUsers({ shipmentId, clientId, driverId, message, status }) {
    const Notification = require('../models/Notification');

    const notificationData = {
      type: `shipment_${status}`,
      title: 'تحديث الشحنة',
      message,
      data: { shipmentId },
      read: false
    };

    if (clientId) {
      await Notification.create({
        user: clientId,
        ...notificationData
      });
    }

    if (driverId) {
      await Notification.create({
        user: driverId,
        ...notificationData
      });
    }
  }
}

