        {
          status,
          notes: notes || null,
          updatedAt: new Date(),
          ...(status === 'in_transit' && { actualPickupDate: new Date() }),
          ...(status === 'delivered' && { actualDeliveryDate: new Date() })
        },
        { new: true }
      ).populate(['client', 'driver', 'truck']);

      if (!shipment) {
