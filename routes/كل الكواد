const jwt = require('jsonwebtoken');
const config = require('../config/env').config;
const logger = require('../utils/logger');

class JWTManager {
  /**
   * إنشاء access token
   */
  static createAccessToken(userId, role, permissions = []) {
    return jwt.sign(
      {
        id: userId,
        role,
        permissions,
        type: 'access',
        iat: Math.floor(Date.now() / 1000)
      },
      config.JWT_SECRET,
      { expiresIn: config.JWT_EXPIRE }
    );
  }

  /**
   * إنشاء refresh token
   */
  static createRefreshToken(userId) {
    return jwt.sign(
      {
        id: userId,
        type: 'refresh',
        iat: Math.floor(Date.now() / 1000)
      },
      config.JWT_SECRET,
      { expiresIn: config.JWT_REFRESH_EXPIRE }
    );
  }

  /**
   * إنشاء reset token (قصير المدى)
   */
  static createResetToken(userId) {
    return jwt.sign(
      {
        id: userId,
        type: 'reset',
        iat: Math.floor(Date.now() / 1000)
      },
      config.JWT_SECRET,
      { expiresIn: '15m' }
    );
  }

  /**
   * التحقق من token
   */
  static verifyToken(token, type = 'access') {
    try {
      const decoded = jwt.verify(token, config.JWT_SECRET);
      
      if (type && decoded.type !== type) {
        throw new Error(`نوع token غير صحيح: ${decoded.type}`);
      }

      return decoded;
    } catch (error) {
      logger.error('❌ خطأ في التحقق من token', error);
      throw error;
    }
  }

  /**
   * الحصول على وقت انتهاء الصلاحية
   */
  static getExpirationTime(token) {
    try {
      const decoded = jwt.decode(token);
      return new Date(decoded.exp * 1000);
    } catch (error) {
      return null;
    }
  }

  /**
   * التحقق من قرب انتهاء الصلاحية
   */
  static isExpiringSoon(token, minutesBefore = 5) {
    const expirationTime = this.getExpirationTime(token);
    if (!expirationTime) return true;

    const now = new Date();
    const timeDifference = expirationTime - now;
    const minutesDifference = timeDifference / (1000 * 60);

    return minutesDifference <= minutesBefore;
  }

  /**
   * إنشاء token pair (access + refresh)
   */
  static createTokenPair(userId, role, permissions = []) {
    return {
      accessToken: this.createAccessToken(userId, role, permissions),
      refreshToken: this.createRefreshToken(userId),
      expiresIn: config.JWT_EXPIRE
    };
  }
}

module.exports = JWTManager;
