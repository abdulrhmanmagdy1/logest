const LocationHandler = require('./handlers/locationHandler');
const logger = require('../utils/logger');

module.exports = (io) => {
  // Middleware للتحقق من المصادقة
  io.use(async (socket, next) => {
    try {
      const token = socket.handshake.auth.token;
      if (!token) {
        return next(new Error('بدون توكن مصادقة'));
      }

      const jwt = require('jsonwebtoken');
      const decoded = jwt.verify(token, process.env.JWT_SECRET);
      socket.userId = decoded.id;
      socket.userRole = decoded.role;

      next();
    } catch (error) {
      next(new Error('خطأ في المصادقة'));
    }
  });

  io.on('connection', (socket) => {
    logger.success('✅ مستخدم متصل', {
      socketId: socket.id,
      userId: socket.userId,
      userRole: socket.userRole
    });

    // Join user room
    socket.join(`user-${socket.userId}`);

    // Join role-based rooms
    if (socket.userRole === 'supervisor' || socket.userRole === 'admin') {
      socket.join('supervisors');
    }
    if (socket.userRole === 'driver') {
      socket.join('drivers');
    }
    if (socket.userRole === 'accountant') {
      socket.join('accounting');
    }

    // ============ LOCATION EVENTS ============
    socket.on('updateLocation', (data) => {
      LocationHandler.handleLocationUpdate(socket, io, data);
    });

    socket.on('updateTripStatus', (data) => {
      LocationHandler.handleTripStatusUpdate(socket, io, data);
    });

    socket.on('updateShipmentStatus', (data) => {
      LocationHandler.handleShipmentStatusUpdate(socket, io, data);
    });

    socket.on('updateTruckLocation', (data) => {
      LocationHandler.handleTruckLocationUpdate(socket, io, data);
    });

    // ============ ROOM MANAGEMENT ============
    socket.on('joinShipment', (shipmentId) => {
      socket.join(`shipment-${shipmentId}`);
      logger.info('انضم إلى غرفة شحنة', { shipmentId });
    });

    socket.on('leaveShipment', (shipmentId) => {
      socket.leave(`shipment-${shipmentId}`);
      logger.info('غادر غرفة شحنة', { shipmentId });
    });

    socket.on('joinTrip', (tripId) => {
      socket.join(`trip-${tripId}`);
      logger.info('انضم إلى غرفة رحلة', { tripId });
    });

    socket.on('leaveTrip', (tripId) => {
      socket.leave(`trip-${tripId}`);
      logger.info('غادر غرفة رحلة', { tripId });
    });

    // ============ NOTIFICATIONS ============
    socket.on('sendNotification', (data) => {
      io.emit('notification', {
        ...data,
        timestamp: new Date(),
        from: socket.userId
      });
      logger.info('تم إرسال إشعار', { from: socket.userId });
    });

    socket.on('markNotificationAsRead', async (notificationId) => {
      try {
        const Notification = require('../models/Notification');
        await Notification.findByIdAndUpdate(notificationId, {
          read: true,
          readAt: new Date()
        });
      } catch (error) {
        logger.error('خطأ في تحديث الإشعار', error);
      }
    });

    // ============ CHAT ============
    socket.on('sendMessage', (data) => {
      io.to(`chat-${data.roomId}`).emit('messageReceived', {
        ...data,
        timestamp: new Date(),
        userId: socket.userId
      });
    });

    // ============ HEARTBEAT ============
    socket.on('ping', () => {
      socket.emit('pong');
    });

    // ============ ERROR HANDLING ============
    socket.on('error', (error) => {
      logger.error('خطأ Socket.io', error);
    });

    // ============ DISCONNECT ============
    socket.on('disconnect', () => {
      logger.warn('⚠️ مستخدم قطع الاتصال', { socketId: socket.id });
    });
  });

  // Broadcast active connections count
  setInterval(() => {
    io.emit('activeConnections', {
      count: io.engine.clientsCount,
      timestamp: new Date()
    });
  }, 30000); // كل 30 ثانية
};
