import 'package:socket_io_client/socket_io_client.dart' as IO;
import 'package:flutter_polyline_points/flutter_polyline_points.dart';
import 'package:get/get.dart';

class RealtimeTrackingScreen extends StatefulWidget {
  final String shipmentId;

  const RealtimeTrackingScreen({required this.shipmentId});

  @override
  State<RealtimeTrackingScreen> createState() => _RealtimeTrackingScreenState();
}

class _RealtimeTrackingScreenState extends State<RealtimeTrackingScreen> {
  late GoogleMapController mapController;
  late IO.Socket socket;
  
  final Set<Marker> markers = {};
  final Set<Polyline> polylines = {};
  
  LatLng currentLocation = LatLng(24.7136, 46.6753);
  LatLng? destinationLocation;
  
  final PolylinePoints polylinePoints = PolylinePoints();
  List<LatLng> routeCoordinates = [];

  @override
  void initState() {
    super.initState();
    _initializeTracking();
  }

  Future<void> _initializeTracking() async {
    try {
      // Initialize socket connection
      _initializeSocket();

      // Get current location
      await _getCurrentLocation();

      // Request location updates
      _startLocationUpdates();

      // Initialize map
      _initializeMap();
    } catch (e) {
      print('خطأ في التهيئة: $e');
      Get.snackbar('خطأ', 'فشل تهيئة التتبع');
    }
  }

  void _initializeSocket() {
    socket = IO.io(
      'https://api.edham.com',
      IO.OptionBuilder()
          .setTransports(['websocket'])
          .disableAutoConnect()
          .build(),
    );

    socket.onConnect((_) {
      print('✅ متصل بخادم التتبع');
      socket.emit('join', {'shipmentId': widget.shipmentId});
    });

    socket.on('location_update', (data) {
      _onLocationUpdate(data);
    });

    socket.on('shipment_status_changed', (data) {
      _onStatusChange(data);
    });

    socket.connect();
  }

  Future<void> _getCurrentLocation() async {
    try {
      final permission = await Geolocator.checkPermission();
      if (permission == LocationPermission.denied) {
        await Geolocator.requestPermission();
      }

      final position = await Geolocator.getCurrentPosition(
        desiredAccuracy: LocationAccuracy.best,
      );

      setState(() {
        currentLocation = LatLng(position.latitude, position.longitude);
      });
    } catch (e) {
      print('خطأ في الحصول على الموقع: $e');
    }
  }

  void _startLocationUpdates() {
    Geolocator.getPositionStream(
      locationSettings: const LocationSettings(
        accuracy: LocationAccuracy.best,
        distanceFilter: 10,
      ),
    ).listen((position) {
      setState(() {
        currentLocation = LatLng(position.latitude, position.longitude);
      });

      // Send to server
      socket.emit('driver_location', {
        'latitude': position.latitude,
        'longitude': position.longitude,
        'speed': position.speed,
        'accuracy': position.accuracy,
      });
    });
  }

  void _onLocationUpdate(dynamic data) {
    setState(() {
      currentLocation = LatLng(
        data['latitude'],
        data['longitude'],
      );

      // Add marker
      _addMarker(
        LatLng(data['latitude'], data['longitude']),
        'السائق: ${data['driverName']}',
        BitmapDescriptor.defaultMarkerWithHue(BitmapDescriptor.hueBlue),
      );

      // Update route
      _updateRoute();
    });
  }

  void _onStatusChange(dynamic data) {
    Get.snackbar(
      'تحديث الحالة',
      'الحالة الجديدة: ${data['status']}',
      backgroundColor: Colors.green,
      colorText: Colors.white,
    );
  }

  void _initializeMap() {
    _addMarker(currentLocation, 'موقعك', BitmapDescriptor.defaultMarker);

    if (destinationLocation != null) {
      _addMarker(
        destinationLocation!,
        'الوجهة',
        BitmapDescriptor.defaultMarkerWithHue(BitmapDescriptor.hueRed),
      );
    }
  }

  void _addMarker(
    LatLng location,
    String title,
    BitmapDescriptor descriptor,
  ) {
    markers.add(
      Marker(
        markerId: MarkerId(title),
        position: location,
        infoWindow: InfoWindow(title: title),
        icon: descriptor,
      ),
    );
  }

  Future<void> _updateRoute() async {
    if (destinationLocation == null) return;

    try {
      PolylineResult result = await polylinePoints.getRouteBetweenCoordinates(
        googleApiKey: 'YOUR_GOOGLE_API_KEY',
        request: PolylineRequest(
          origin: PointLatLng(currentLocation.latitude, currentLocation.longitude),
          destination: PointLatLng(
            destinationLocation!.latitude,
            destinationLocation!.longitude,
          ),
          mode: TravelMode.driving,
        ),
      );

      if (result.points.isNotEmpty) {
        routeCoordinates = result.points
            .map((point) => LatLng(point.latitude, point.longitude))
            .toList();

        setState(() {
          polylines.clear();
          polylines.add(
            Polyline(
              polylineId: PolylineId('route'),
              color: Colors.blue,
              points: routeCoordinates,
              width: 5,
            ),
          );
        });

        // Animate camera
        _animateCamera();
      }
    } catch (e) {
      print('خطأ في تحديث المسار: $e');
    }
  }

  void _animateCamera() {
    if (routeCoordinates.isNotEmpty) {
      LatLngBounds bounds = _calculateBounds(routeCoordinates);
      mapController.animateCamera(
        CameraUpdateOptions(
          bounds: bounds,
          padding: EdgeInsets.all(100),
        ),
      );
    }
  }

  LatLngBounds _calculateBounds(List<LatLng> points) {
    double minLat = points.first.latitude;
    double maxLat = points.first.latitude;
    double minLng = points.first.longitude;
    double maxLng = points.first.longitude;

    for (LatLng point in points) {
      minLat = point.latitude < minLat ? point.latitude : minLat;
      maxLat = point.latitude > maxLat ? point.latitude : maxLat;
      minLng = point.longitude < minLng ? point.longitude : minLng;
      maxLng = point.longitude > maxLng ? point.longitude : maxLng;
    }

    return LatLngBounds(
      southwest: LatLng(minLat, minLng),
      northeast: LatLng(maxLat, maxLng),
    );
  }

