        return res.status(HTTP_STATUS.NOT_FOUND).json({
          success: false,
          message: 'الشحنة غير موجودة'
        });
      }
    }

    const invoiceNumber = Helpers.generateInvoiceNumber();
    const serialNumber = `SN-${Date.now()}-${Math.random().toString(36).substr(2, 9)}`;
    const verificationCode = Math.random().toString(36).substr(2, 8).toUpperCase();

    const total = parseFloat(subtotal) - parseFloat(discount) + parseFloat(tax);

    const invoice = new Invoice({
      invoiceNumber,
      serialNumber,
      verificationCode,
      shipment: shipmentId || null,
      client: clientId,
      items,
      subtotal: parseFloat(subtotal),
      tax: parseFloat(tax),
      discount: parseFloat(discount),
      total,
      balanceDue: total,
      accountant: req.user._id,
      issueDate: new Date(),
      dueDate: new Date(Date.now() + 30 * 24 * 60 * 60 * 1000),
      status: INVOICE_STATUS.PENDING,
      notes
    });

    await invoice.save();
    await invoice.populate(['client', 'shipment', 'accountant']);

    // Send invoice email
    try {
      await EmailService.sendInvoiceEmail(invoice);
    } catch (error) {
      logger.warn('فشل إرسال الفاتورة بالبريد', { invoiceNumber });
    }

    logger.success('تم إنشاء فاتورة جديدة', {
      invoiceNumber,
      clientId,
      total
    });

    res.status(HTTP_STATUS.CREATED).json({
      success: true,
      message: MESSAGES.CREATED,
      data: invoice
    });
  });

  /**
   * تسجيل دفعة
   */
  static recordPayment = asyncHandler(async (req, res) => {
    const { amount, method, reference, notes } = req.body;

    const invoice = await Invoice.findById(req.params.id);
    if (!invoice) {
      return res.status(HTTP_STATUS.NOT_FOUND).json({
        success: false,
        message: MESSAGES.NOT_FOUND
      });
    }

    const paymentAmount = parseFloat(amount);

    if (paymentAmount > invoice.balanceDue) {
      return res.status(HTTP_STATUS.BAD_REQUEST).json({
        success: false,
        message: 'المبلغ يتجاوز الرصيد المتبقي',
        balanceDue: invoice.balanceDue
      });
    }

    // Create payment record
    const payment = new Payment({
      invoice: invoice._id,
      amount: paymentAmount,
      method,
      reference: reference || `PAY-${Date.now()}`,
      transactionId: `TXN-${Date.now()}`,
      processedBy: req.user._id,
      status: 'completed',
      notes
    });

    await payment.save();

    // Update invoice
    invoice.amountPaid += paymentAmount;
    invoice.balanceDue -= paymentAmount;
    invoice.status = invoice.balanceDue === 0
      ? INVOICE_STATUS.PAID
      : INVOICE_STATUS.PARTIAL;

    invoice.paymentHistory.push({
      amount: paymentAmount,
      method,
      date: new Date(),
      reference: payment.reference
    });

    if (invoice.balanceDue === 0) {
      invoice.paidDate = new Date();
    }

    await invoice.save();

    logger.success('تم تسجيل دفعة', {
      invoiceNumber: invoice.invoiceNumber,
      amount: paymentAmount,
      method
    });

    res.json({
      success: true,
      message: 'تم تسجيل الدفعة بنجاح',
      data: {
        invoice,
        payment
      }
    });
  });

  /**
   * توليد PDF للفاتورة
   */
  static generatePDF = asyncHandler(async (req, res) => {
    const invoice = await Invoice.findById(req.params.id)
      .populate('client')
      .populate('accountant');

    if (!invoice) {
      return res.status(HTTP_STATUS.NOT_FOUND).json({
        success: false,
        message: MESSAGES.NOT_FOUND
      });
    }

    try {
      const pdfBuffer = await PDFService.generateInvoicePDF(invoice);

      res.setHeader('Content-Type', 'application/pdf');
      res.setHeader(
        'Content-Disposition',
        `attachment; filename=invoice-${invoice.invoiceNumber}.pdf`
      );
      res.send(pdfBuffer);

      logger.success('تم توليد PDF الفاتورة', { invoiceNumber: invoice.invoiceNumber });
    } catch (error) {
      logger.error('خطأ في توليد PDF', error);
      res.status(HTTP_STATUS.INTERNAL_ERROR).json({
        success: false,
        message: 'خطأ في توليد الفاتورة'
      });
    }
  });

  /**
   * تصدير فواتير لـ Excel
   */
  static exportToExcel = asyncHandler(async (req, res) => {
    const { status, dateFrom, dateTo, clientId } = req.query;

    let query = {};
    if (status) query.status = status;
    if (clientId) query.client = clientId;
    if (dateFrom || dateTo) {
      query.issueDate = {};
      if (dateFrom) query.issueDate.$gte = new Date(dateFrom);
      if (dateTo) query.issueDate.$lte = new Date(dateTo);
    }

    const invoices = await Invoice.find(query)
      .populate('client', 'name email')
      .sort({ issueDate: -1 });

    try {
      const excelBuffer = await ExcelService.generateInvoicesExcel(invoices);

      res.setHeader('Content-Type', 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet');
      res.setHeader('Content-Disposition', 'attachment; filename=invoices.xlsx');
      res.send(excelBuffer);

      logger.success('تم تصدير الفواتير إلى Excel', { count: invoices.length });
    } catch (error) {
      logger.error('خطأ في تصدير Excel', error);
      res.status(HTTP_STATUS.INTERNAL_ERROR).json({
        success: false,
        message: 'خطأ في التصدير'
      });
    }
  });

  /**
   * التحقق من الفاتورة
   */
  static verify = asyncHandler(async (req, res) => {
    const { serialNumber, verificationCode } = req.body;

    let invoice;
    if (serialNumber) {
      invoice = await Invoice.findOne({ serialNumber });
    } else if (verificationCode) {
      invoice = await Invoice.findOne({ verificationCode });
    } else {
      return res.status(HTTP_STATUS.BAD_REQUEST).json({
        success: false,
        message: 'رقم سري أو كود التحقق مطلوب'
      });
    }

    if (!invoice) {
      return res.status(HTTP_STATUS.NOT_FOUND).json({
        success: false,
        message: 'الفاتورة غير موجودة'
      });
    }

    // Update verification stats
    invoice.verificationAttempts += 1;
    invoice.lastVerifiedAt = new Date();
    await invoice.save();

    logger.info('تم التحقق من الفاتورة', { invoiceNumber: invoice.invoiceNumber });

    res.json({
      success: true,
      data: {
        invoiceNumber: invoice.invoiceNumber,
        serialNumber: invoice.serialNumber,
        amount: invoice.total,
        status: invoice.status,
        clientName: invoice.client?.name,
        issuedAt: invoice.issueDate,
        isVerified: true
      }
    });
  });

  /**
   * الحصول على إحصائيات الفواتير
   */
  static getStatistics = asyncHandler(async (req, res) => {
    const { dateFrom, dateTo } = req.query;

    let query = {};
    if (dateFrom || dateTo) {
      query.issueDate = {};
      if (dateFrom) query.issueDate.$gte = new Date(dateFrom);
      if (dateTo) query.issueDate.$lte = new Date(dateTo);
    }

    const [totalInvoices, paidInvoices, partialInvoices, pendingInvoices, overdueInvoices] = await Promise.all([
      Invoice.countDocuments(query),
      Invoice.countDocuments({ ...query, status: INVOICE_STATUS.PAID }),
      Invoice.countDocuments({ ...query, status: INVOICE_STATUS.PARTIAL }),
      Invoice.countDocuments({ ...query, status: INVOICE_STATUS.PENDING }),
      Invoice.countDocuments({
        ...query,
        status: INVOICE_STATUS.OVERDUE,
        dueDate: { $lt: new Date() }
      })
    ]);

    const revenueData = await Invoice.aggregate([
      { $match: query },
      {
        $group: {
          _id: null,
          totalRevenue: { $sum: '$total' },
          totalPaid: { $sum: '$amountPaid' },
          totalPending: { $sum: '$balanceDue' }
        }
      }
    ]);

    const revenue = revenueData[0] || {
      totalRevenue: 0,
      totalPaid: 0,
      totalPending: 0
    };

    res.json({
      success: true,
      data: {
        invoices: {
          total: totalInvoices,
          paid: paidInvoices,
          partial: partialInvoices,
          pending: pendingInvoices,
          overdue: overdueInvoices
        },
        revenue,
        collectionRate: totalInvoices > 0
          ? Math.round((revenue.totalPaid / revenue.totalRevenue) * 100)
          : 0
      }
    });
  });

  /**
   * إرسال تذكير للدفع
