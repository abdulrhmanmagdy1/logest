const PDFDocument = require('pdfkit');
const Helpers = require('../utils/helpers');

class PDFService {
  /**
   * توليد PDF الفاتورة
   */
  static async generateInvoicePDF(invoice) {
    return new Promise((resolve, reject) => {
      try {
        const doc = new PDFDocument({ size: 'A4', margin: 50 });
        let buffer = [];

        doc.on('data', (data) => buffer.push(data));
        doc.on('end', () => resolve(Buffer.concat(buffer)));
        doc.on('error', reject);

        // Header
        doc.fontSize(24).text('إدهام', { align: 'center' });
        doc.fontSize(12).text('للخدمات اللوجستية', { align: 'center' });
        doc.moveDown();

        // Invoice title
        doc.fontSize(16).text('فاتورة', { align: 'center' });
        doc.moveTo(50, doc.y).lineTo(550, doc.y).stroke();
        doc.moveDown();

        // Invoice info
        doc.fontSize(10);
        doc.text(`رقم الفاتورة: ${invoice.invoiceNumber}`, 50, doc.y);
        doc.text(`التاريخ: ${Helpers.formatDateArabic(invoice.issueDate)}`, 50, doc.y);
        doc.text(`تاريخ الاستحقاق: ${Helpers.formatDateArabic(invoice.dueDate)}`, 50, doc.y);
        doc.moveDown();

        // Client info
        doc.fontSize(12).text('بيانات العميل:');
        doc.fontSize(10);
        if (invoice.client) {
          doc.text(`الاسم: ${invoice.client.name}`);
          doc.text(`البريد: ${invoice.client.email}`);
          doc.text(`الهاتف: ${invoice.client.phone}`);
        }
        doc.moveDown();

        // Items table
        doc.fontSize(12).text('البنود:');
        doc.moveDown(0.5);

        // Table header
        doc.fontSize(10).font('Helvetica-Bold');
        doc.text('الوصف', 50, doc.y, { width: 200 });
        doc.text('الكمية', 260, doc.y - doc.heightOfString('الوصف'), { width: 80 });
        doc.text('السعر', 350, doc.y - doc.heightOfString('الوصف'), { width: 80 });
        doc.text('الإجمالي', 450, doc.y - doc.heightOfString('الوصف'), { width: 80 });

        doc.moveTo(50, doc.y).lineTo(550, doc.y).stroke();
        doc.moveDown();

        // Table items
        doc.font('Helvetica');
        invoice.items.forEach((item) => {
          doc.text(item.description, 50, doc.y, { width: 200 });
          doc.text(item.quantity.toString(), 260, doc.y - doc.heightOfString(item.description), { width: 80 });
          doc.text(`${item.unitPrice}`, 350, doc.y - doc.heightOfString(item.description), { width: 80 });
          doc.text(`${item.total}`, 450, doc.y - doc.heightOfString(item.description), { width: 80 });
          doc.moveDown();
        });

        doc.moveTo(50, doc.y).lineTo(550, doc.y).stroke();
        doc.moveDown();

        // Totals
        doc.fontSize(11).font('Helvetica-Bold');
        doc.text(`الإجمالي: ${invoice.subtotal}`, 350);
        doc.text(`الضريبة: ${invoice.tax}`, 350);
        doc.text(`الخصم: ${invoice.discount}`, 350);
        doc.fontSize(12).text(`الإجمالي النهائي: ${invoice.total}`, 350);
        doc.moveDown();

        // Status
        doc.fontSize(10);
        const statusText = {
          pending: 'معلقة',
          paid: 'مدفوعة',
          partial: 'جزئية',
          overdue: 'متأخرة'
        };
        doc.text(`الحالة: ${statusText[invoice.status] || invoice.status}`);

        // Footer
        doc.fontSize(8);
        doc.text('شكراً لتعاملك مع إدهام', { align: 'center' });
        doc.text(`التاريخ: ${new Date().toLocaleDateString('ar-SA')}`, { align: 'center' });

        doc.end();
      } catch (error) {
        reject(error);
      }
    });
  }

  /**
   * توليد PDF التقرير
   */
  static async generateReportPDF(reportData) {
    return new Promise((resolve, reject) => {
      try {
        const doc = new PDFDocument({ size: 'A4', margin: 50 });
        let buffer = [];

        doc.on('data', (data) => buffer.push(data));
        doc.on('end', () => resolve(Buffer.concat(buffer)));
        doc.on('error', reject);

        // Header
        doc.fontSize(20).text('تقرير إدهام', { align: 'center' });
        doc.fontSize(12).text(reportData.title, { align: 'center' });
        doc.moveDown();

        // Report details
        doc.fontSize(11);
        doc.text(`الفترة: من ${reportData.fromDate} إلى ${reportData.toDate}`);
        doc.text(`تاريخ التقرير: ${Helpers.formatDateArabic(new Date())}`);
        doc.moveDown();

        // Content
        if (reportData.content) {
          doc.text(reportData.content);
        }

        doc.end();
      } catch (error) {
        reject(error);
      }
    });
  }
