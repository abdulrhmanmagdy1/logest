const mongoose = require('mongoose');
const archiver = require('archiver');
const fs = require('fs');
const path = require('path');
const moment = require('moment');
const logger = require('../utils/logger');

class BackupService {
  constructor() {
    this.backupDir = path.join(__dirname, '../backups');
    this.ensureDirectory();
  }

  ensureDirectory() {
    if (!fs.existsSync(this.backupDir)) {
      fs.mkdirSync(this.backupDir, { recursive: true });
    }
  }

  /**
   * النسخ الاحتياطي الكامل
   */
  async fullBackup() {
    try {
      logger.info('🔄 جاري إجراء النسخة الاحتياطية الكاملة...');

      const backupName = `backup-${moment().format('YYYY-MM-DD-HH-mm-ss')}`;
      const backupPath = path.join(this.backupDir, backupName);

      fs.mkdirSync(backupPath);

      // Get all models
      const models = Object.keys(mongoose.models);
      const backupData = {};

      for (const modelName of models) {
        const model = mongoose.model(modelName);
        const data = await model.find({}).lean();
        backupData[modelName] = data;

        logger.info(`✅ تم نسخ ${modelName} (${data.length} مستند)`);
      }

      // Save backup data
      const jsonPath = path.join(backupPath, 'backup.json');
      fs.writeFileSync(jsonPath, JSON.stringify(backupData, null, 2));

      // Create archive
      const zipPath = path.join(this.backupDir, `${backupName}.zip`);
      await this.createArchive(backupPath, zipPath);

      // Clean up temp directory
      fs.rmSync(backupPath, { recursive: true });

      logger.success(`✅ تم إنشاء النسخة الاحتياطية: ${zipPath}`);

      return zipPath;
    } catch (error) {
      logger.error('❌ خطأ في النسخ الاحتياطي', error);
      throw error;
    }
  }

  /**
   * النسخ الاحتياطي الزيادي
   */
  async incrementalBackup(lastBackupDate) {
    try {
      logger.info('🔄 جاري إجراء نسخة احتياطية زيادية...');

      const backupName = `incremental-${moment().format('YYYY-MM-DD-HH-mm-ss')}`;
      const backupPath = path.join(this.backupDir, backupName);

      fs.mkdirSync(backupPath);

      const models = Object.keys(mongoose.models);
      const backupData = {};

      for (const modelName of models) {
        const model = mongoose.model(modelName);
        const data = await model.find({
          updatedAt: { $gte: new Date(lastBackupDate) }
        }).lean();

        if (data.length > 0) {
          backupData[modelName] = data;
          logger.info(`✅ تم نسخ ${modelName} (${data.length} مستند محدث)`);
        }
      }

      const jsonPath = path.join(backupPath, 'incremental.json');
      fs.writeFileSync(jsonPath, JSON.stringify(backupData, null, 2));

      const zipPath = path.join(this.backupDir, `${backupName}.zip`);
      await this.createArchive(backupPath, zipPath);

      fs.rmSync(backupPath, { recursive: true });

      logger.success(`✅ تم إنشاء النسخة الزيادية: ${zipPath}`);

      return zipPath;
    } catch (error) {
      logger.error('❌ خطأ في النسخ الزيادية', error);
      throw error;
    }
  }

  /**
   * استعادة من نسخة احتياطية
   */
  async restore(zipPath) {
    try {
      logger.info('🔄 جاري استعادة البيانات...');

      // Extract backup
      const extractPath = path.join(this.backupDir, 'restore-temp');
      await this.extractArchive(zipPath, extractPath);

      // Read backup data
      const backupFile = path.join(extractPath, 'backup.json');
      const backupData = JSON.parse(fs.readFileSync(backupFile, 'utf8'));

      // Restore data
      for (const [modelName, documents] of Object.entries(backupData)) {
        if (!mongoose.models[modelName]) {
          logger.warn(`⚠️ نموذج ${modelName} غير موجود`);
          continue;
        }

        const model = mongoose.model(modelName);
        await model.deleteMany({}); // Clear collection
        await model.insertMany(documents);

        logger.success(`✅ تم استعادة ${modelName}`);
      }

      // Clean up
      fs.rmSync(extractPath, { recursive: true });

      logger.success('✅ تمت الاستعادة بنجاح');
    } catch (error) {
      logger.error('❌ خطأ في الاستعادة', error);
      throw error;
    }
  }

  /**
   * حذف النسخ القديمة
   */
  async cleanOldBackups(daysToKeep = 30) {
    try {
      const files = fs.readdirSync(this.backupDir);
      const now = Date.now();
      const maxAge = daysToKeep * 24 * 60 * 60 * 1000;

      let deletedCount = 0;
      for (const file of files) {
        const filePath = path.join(this.backupDir, file);
        const stats = fs.statSync(filePath);

        if (now - stats.mtime.getTime() > maxAge) {
          fs.unlinkSync(filePath);
          deletedCount++;
        }
      }

      logger.success(`✅ تم حذف ${deletedCount} نسخة احتياطية قديمة`);
    } catch (error) {
      logger.error('❌ خطأ في تنظيف النسخ', error);
    }
  }

  /**
   * إنشاء ملف مضغوط
   */
  async createArchive(sourcePath, zipPath) {
    return new Promise((resolve, reject) => {
      const output = fs.createWriteStream(zipPath);
      const archive = archiver('zip', { zlib: { level: 9 } });

      output.on('close', resolve);
      archive.on('error', reject);

      archive.pipe(output);
      archive.directory(sourcePath, false);
      archive.finalize();
    });
  }

  /**
   * استخراج ملف مضغوط
   */
  async extractArchive(zipPath, extractPath) {
    return new Promise((resolve, reject) => {
      const extract = require('extract-zip');
      extract(zipPath, { dir: extractPath }).then(resolve).catch(reject);
    });
  }

  /**
   * الحصول على قائمة النسخ الاحتياطية
   */
  getBackupsList() {
    try {
      const files = fs.readdirSync(this.backupDir)
        .filter(f => f.endsWith('.zip'))
        .map(f => {
          const filePath = path.join(this.backupDir, f);
          const stats = fs.statSync(filePath);
          return {
            name: f,
            size: `${(stats.size / 1024 / 1024).toFixed(2)} MB`,
            date: moment(stats.mtime).format('YYYY-MM-DD HH:mm:ss'),
            path: filePath
          };
        })
        .sort((a, b) => new Date(b.date) - new Date(a.date));

      return files;
    } catch (error) {
      logger.error('❌ خطأ في جلب قائمة النسخ', error);
      return [];
    }
  }
}

