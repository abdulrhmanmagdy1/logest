          value={stats?.data?.total || 0}
          icon={<Truck />}
          color="blue"
        />
        <StatCard
          title="قيد التوصيل"
          value={stats?.data?.byStatus?.inTransit || 0}
          icon={<TrendingUp />}
          color="yellow"
        />
        <StatCard
          title="مكتملة"
          value={stats?.data?.byStatus?.delivered || 0}
          icon={<TrendingUp />}
          color="green"
        />
        <StatCard
          title="معدل الإكمال"
          value={`${stats?.data?.completionRate || 0}%`}
          color="red"
        />
      </div>

      {/* Recent Shipments */}
