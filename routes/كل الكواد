const User = require('../models/User');
const jwt = require('jsonwebtoken');
const crypto = require('crypto');
const config = require('../config/env').config;
const { MESSAGES, HTTP_STATUS } = require('../config/constants');
const logger = require('../utils/logger');
const { asyncHandler, AppError } = require('../middleware/errorHandler');

class AuthController {
  /**
   * تسجيل مستخدم جديد
   */
  static register = asyncHandler(async (req, res) => {
    const { name, email, password, phone, role, department } = req.body;

    // Check if user exists
    const existingUser = await User.findOne({ email });
    if (existingUser) {
      logger.warn('محاولة تسجيل ببريد موجود', { email });
      return res.status(HTTP_STATUS.CONFLICT).json({
        success: false,
        message: MESSAGES.ALREADY_EXISTS
      });
    }

    // Create new user
    const user = new User({
      name,
      email,
      password,
      phone,
      role: role || 'client',
      department: department || 'logistics'
    });

    await user.save();

    // Generate tokens
    const tokens = this.generateTokens(user);

    // Send verification email
    try {
      await sendVerificationEmail(user);
    } catch (error) {
      logger.warn('فشل إرسال بريد التحقق', { email });
    }

    logger.success('مستخدم جديد مسجل', {
      userId: user._id,
      email: user.email,
      role: user.role
    });

    res.status(HTTP_STATUS.CREATED).json({
      success: true,
      message: MESSAGES.CREATED,
      data: {
        user: user.getPublicData(),
        tokens
      }
    });
  });

  /**
   * تسجيل الدخول
   */
  static login = asyncHandler(async (req, res) => {
    const { email, password } = req.body;

    // Get user with password
    const user = await User.findOne({ email }).select('+password');
    if (!user) {
      logger.warn('محاولة دخول بريد غير موجود', { email });
      return res.status(HTTP_STATUS.UNAUTHORIZED).json({
        success: false,
        message: MESSAGES.INVALID_CREDENTIALS
      });
    }

    // Check if account is active
    if (!user.isActive) {
      logger.warn('محاولة دخول حساب معطل', { userId: user._id });
      return res.status(HTTP_STATUS.FORBIDDEN).json({
        success: false,
        message: 'الحساب معطل'
      });
    }

    // Check if account is locked
    if (user.isLocked()) {
      logger.warn('محاولة دخول حساب مقفل', { userId: user._id });
      return res.status(HTTP_STATUS.UNAUTHORIZED).json({
        success: false,
        message: MESSAGES.ACCOUNT_LOCKED,
        lockedUntil: user.lockUntil
      });
    }

    // Verify password
    const isPasswordValid = await user.comparePassword(password);
    if (!isPasswordValid) {
      await user.incLoginAttempts();
      logger.warn('محاولة دخول بكلمة مرور خاطئة', { email });
      return res.status(HTTP_STATUS.UNAUTHORIZED).json({
        success: false,
        message: MESSAGES.INVALID_CREDENTIALS
      });
    }

    // Reset login attempts and update last login
    await user.resetLoginAttempts();
    user.lastLoginIP = req.ip;
    await user.save();

    // Generate tokens
    const tokens = this.generateTokens(user);

    logger.success('تسجيل دخول ناجح', {
      userId: user._id,
      email: user.email,
      ip: req.ip
    });

    res.json({
      success: true,
      message: MESSAGES.LOGGED_IN,
      data: {
        user: user.getPublicData(),
        tokens
      }
    });
  });

  /**
   * تحديث التوكن
   */
  static refreshToken = asyncHandler(async (req, res) => {
    const { refreshToken } = req.body;

    if (!refreshToken) {
      return res.status(HTTP_STATUS.UNAUTHORIZED).json({
        success: false,
        message: 'Refresh token مطلوب'
      });
    }

    try {
      const decoded = jwt.verify(refreshToken, config.JWT_SECRET);
      const user = await User.findById(decoded.id);

      if (!user || !user.isActive) {
        return res.status(HTTP_STATUS.UNAUTHORIZED).json({
          success: false,
          message: MESSAGES.INVALID_TOKEN
        });
      }

      const tokens = this.generateTokens(user);

      res.json({
        success: true,
        message: 'تم تحديث التوكن بنجاح',
        data: { tokens }
      });
    } catch (error) {
      logger.error('خطأ في تحديث التوكن', error);
      res.status(HTTP_STATUS.UNAUTHORIZED).json({
        success: false,
        message: MESSAGES.INVALID_TOKEN
      });
    }
  });

  /**
   * الحصول على بيانات المستخدم الحالي
   */
  static getCurrentUser = asyncHandler(async (req, res) => {
    const user = await User.findById(req.user._id)
      .populate('manager', 'name email');

    res.json({
      success: true,
      data: user
    });
  });

  /**
   * تحديث الملف الشخصي
   */
  static updateProfile = asyncHandler(async (req, res) => {
    const allowedFields = [
      'name',
      'phone',
      'address',
      'city',
      'region',
      'postalCode',
      'avatar',
      'bio',
      'language',
      'theme'
    ];

    const updates = {};
    allowedFields.forEach(field => {
      if (req.body[field] !== undefined) {
        updates[field] = req.body[field];
      }
    });

    const user = await User.findByIdAndUpdate(
      req.user._id,
      updates,
      { new: true, runValidators: true }
    );

    logger.success('تم تحديث الملف الشخصي', { userId: user._id });

    res.json({
      success: true,
      message: MESSAGES.UPDATED,
      data: user
    });
  });

  /**
   * تغيير كلمة المرور
   */
  static changePassword = asyncHandler(async (req, res) => {
    const { currentPassword, newPassword } = req.body;

    const user = await User.findById(req.user._id).select('+password');

    // Verify current password
    const isValid = await user.comparePassword(currentPassword);
    if (!isValid) {
      logger.warn('محاولة تغيير كلمة مرور بكلمة حالية خاطئة', {
        userId: user._id
      });
      return res.status(HTTP_STATUS.UNAUTHORIZED).json({
        success: false,
        message: 'كلمة المرور الحالية غير صحيحة'
      });
    }

    // Update password
    user.password = newPassword;
    await user.save();

    logger.success('تم تغيير كلمة المرور', { userId: user._id });

    res.json({
      success: true,
      message: MESSAGES.PASSWORD_CHANGED
    });
  });

  /**
   * تسجيل الخروج
   */
  static logout = asyncHandler(async (req, res) => {
    logger.success('تسجيل خروج', { userId: req.user._id });

    res.json({
      success: true,
      message: MESSAGES.LOGGED_OUT
    });
  });

  /**
   * طلب إعادة تعيين كلمة المرور
   */
  static forgotPassword = asyncHandler(async (req, res) => {
    const { email } = req.body;

    const user = await User.findOne({ email });
    if (!user) {
      return res.status(HTTP_STATUS.NOT_FOUND).json({
        success: false,
        message: 'لا يوجد حساب بهذا البريد الإلكتروني'
      });
    }

    // Generate reset token
    const resetToken = user.createPasswordResetToken();
    await user.save();

    // Send reset email
    try {
      await sendPasswordResetEmail(user, resetToken);
      logger.success('تم إرسال بريد إعادة تعيين كلمة المرور', { email });
    } catch (error) {
      user.passwordResetToken = undefined;
      user.passwordResetExpires = undefined;
      await user.save();
      logger.error('خطأ في إرسال بريد إعادة التعيين', error);
      return res.status(HTTP_STATUS.INTERNAL_ERROR).json({
        success: false,
        message: 'خطأ في إرسال البريد'
      });
    }

    res.json({
      success: true,
      message: 'تم إرسال رابط إعادة تعيين كلمة المرور إلى بريدك الإلكتروني'
    });
  });

  /**
   * إعادة تعيين كلمة المرور
   */
  static resetPassword = asyncHandler(async (req, res) => {
    const { token, newPassword } = req.body;

    // Hash token
    const hashedToken = crypto
      .createHash('sha256')
      .update(token)
      .digest('hex');

    // Find user
    const user = await User.findOne({
      passwordResetToken: hashedToken,
      passwordResetExpires: { $gt: Date.now() }
    });

    if (!user) {
