# ================================================================
# Edham Logistics — Production Environment Variables Template
#
# USAGE ON SERVER:
#   1. scp .env.prod.example root@YOUR_SERVER_IP:/opt/edham/.env.prod
#   2. nano /opt/edham/.env.prod      ← fill in every CHANGE_ME value
#   3. chmod 600 /opt/edham/.env.prod  ← owner-readable only
#
# NEVER commit .env.prod to version control.
# Generate secrets with:  openssl rand -hex 64
# ================================================================

# ── Server ────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ── MongoDB ───────────────────────────────────────────────────
# Used by the mongodb container AND to build MONGODB_URI for backend
MONGO_ROOT_USER=edham_admin
MONGO_ROOT_PASSWORD=CHANGE_ME_use_openssl_rand_hex_32

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_use_openssl_rand_hex_32

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_use_openssl_rand_hex_64_at_minimum
JWT_EXPIRE=7d

# ── Public URLs (replace yourdomain.com with your real domain) ─
CLIENT_URL=https://yourdomain.com
CORS_ORIGIN=https://yourdomain.com

# ── Frontend Build-Time Variables ─────────────────────────────
# These are baked into the Next.js JS bundle at docker build time.
# After changing them you MUST rebuild:  docker compose ... build frontend
NEXT_PUBLIC_API_BASE_URL=https://yourdomain.com/api/v1
NEXT_PUBLIC_SOCKET_URL=https://yourdomain.com
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_api_key_here

# ── Email / SMTP ──────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_google_app_password
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=Edham Logistics

# ── File Uploads ──────────────────────────────────────────────
MAX_FILE_SIZE=10485760

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info

# ── Maintenance Thresholds ────────────────────────────────────
MAINTENANCE_ALERT_DAYS=7
OIL_CHANGE_KM=5000
TIRE_MIN_TREAD=3.0

# ── Optional: ZATCA (Saudi Arabia e-invoicing) ────────────────
# ZATCA_API_KEY=
# ZATCA_CERT_PATH=./certs/zatca.crt
