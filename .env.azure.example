# ============================================
# Edham Logistics — Azure Production Env Template
# Copy this file to .env and fill in real values.
# NEVER commit a .env with real secrets to Git.
# In Azure: set these as App Service App Settings
# or reference from Azure Key Vault.
# ============================================

# ─── Server ───────────────────────────────────
NODE_ENV=production
PORT=5000

# ─── MongoDB (Azure Cosmos DB for MongoDB) ────
# Get from: Azure Portal → Cosmos DB → Connection strings
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongocluster.cosmos.azure.com/edham_logistics?tls=true&authMechanism=SCRAM-SHA-256&retrywrites=false&maxIdleTimeMS=120000

# ─── Redis (Azure Cache for Redis) ────────────
# Format: rediss://:<primary-key>@<name>.redis.cache.windows.net:6380
REDIS_URL=rediss://:<primary-key>@<your-cache-name>.redis.cache.windows.net:6380

# ─── JWT ──────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<64-character-random-hex-string>
JWT_EXPIRE=7d

# ─── CORS / Frontend URL ──────────────────────
# Set to your Azure Static Web Apps URL
CORS_ORIGIN=https://<your-app>.azurestaticapps.net
CLIENT_URL=https://<your-app>.azurestaticapps.net

# ─── Azure Blob Storage (file uploads) ────────
# Get from: Azure Portal → Storage Account → Access keys
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<name>;AccountKey=<key>;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_NAME=uploads

# ─── Stripe ───────────────────────────────────
STRIPE_SECRET_KEY=sk_live_<your-live-key>
STRIPE_WEBHOOK_SECRET=whsec_<your-webhook-secret>

# ─── Email (SMTP) ─────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=<app-specific-password>
SMTP_FROM=noreply@yourdomain.com

# ─── Google Maps ──────────────────────────────
GOOGLE_MAPS_API_KEY=<your-google-maps-key>

# ─── Firebase / FCM (Push Notifications) ──────
FCM_SERVER_KEY=<your-fcm-server-key>

# ─── ZATCA (Saudi Tax Authority) ──────────────
ZATCA_API_KEY=<your-zatca-key>
# Certificate: load from Azure Key Vault secret, not filesystem
# ZATCA_CERT_CONTENT=<base64-encoded-cert>

# ─── Logging ──────────────────────────────────
LOG_LEVEL=info
# Logs stream to stdout → captured by Azure Application Insights

# ─── Misc ─────────────────────────────────────
MAX_FILE_SIZE=10485760
MAINTENANCE_ALERT_DAYS=7
