# ===================================
# نظام إدهام - متغيرات البيئة
# Edham Logistics - Environment Variables
# ===================================

# ========== SERVER ==========
NODE_ENV=development
PORT=5000

# ========== DATABASE ==========
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/edham?retryWrites=true&w=majority

# ========== JWT ==========
JWT_SECRET=your_very_secure_jwt_secret_key_min_32_characters_here_edham_2024_production
JWT_EXPIRE=7d

# ========== STRIPE ==========
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ========== GOOGLE ==========
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ========== CORS ==========
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ========== EMAIL ==========
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@edham.com

# ========== LOGGING ==========
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ========== UPLOAD ==========
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads

# ========== REDIS ==========
REDIS_URL=redis://localhost:6379

# ========== APP ==========
APP_NAME=Edham
APP_VERSION=1.0.0
APP_URL=http://localhost:5000

# ========== MAINTENANCE ==========
MAINTENANCE_ALERT_DAYS=7
OIL_CHANGE_KM=5000
TIRE_MIN_TREAD=3.0

# ========== ZATCA (Saudi Arabia - Optional) ==========
ZATCA_API_KEY=your_zatca_api_key
ZATCA_CERT_PATH=./certs/zatca.crt
