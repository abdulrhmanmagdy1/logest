/**
 * Fuel Analytics Fragment - Comprehensive fuel consumption and cost analytics
 * 
 * Features:
 * - Fuel consumption overview
 * - Cost analysis and trends
 * - Fuel efficiency metrics
 * - Vehicle fuel performance
 * - Fuel station analytics
 * - Price trends analysis
 * - Optimization recommendations
 * - Interactive charts
 */
@AndroidEntryPoint
class FuelAnalyticsFragment : Fragment() {
    
    @Inject
    lateinit var analyticsEngineService: AnalyticsEngineService
    
    private val viewModel: FuelAnalyticsViewModel by viewModels()
    
    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View {
        return ComposeView(requireContext()).apply {
            setContent {
                EdhamLogisticsTheme {
                    FuelAnalyticsScreen(
                        viewModel = viewModel,
                        analyticsEngineService = analyticsEngineService
                    )
                }
            }
        }
    }
    
    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        
        // Initialize analytics engine
        lifecycleScope.launch {
            analyticsEngineService.initialize()
        }
        
        // Load fuel analytics
        viewModel.loadFuelAnalytics()
    }
}

@Composable
fun FuelAnalyticsScreen(
    viewModel: FuelAnalyticsViewModel,
    analyticsEngineService: AnalyticsEngineService
) {
    val fuelAnalytics by viewModel.fuelAnalytics.collectAsStateWithLifecycle()
    val isLoading by viewModel.isLoading.collectAsStateWithLifecycle()
    val errorMessage by viewModel.errorMessage.collectAsStateWithLifecycle()
    val selectedTimeRange by viewModel.selectedTimeRange.collectAsStateWithLifecycle()
    
    LaunchedEffect(selectedTimeRange) {
        viewModel.loadFuelAnalytics()
    }
    
    Column(
        modifier = Modifier
            .fillMaxSize()
            .padding(16.dp),
        verticalArrangement = Arrangement.spacedBy(16.dp)
    ) {
        // Header with time range selector
        FuelAnalyticsHeader(
            selectedTimeRange = selectedTimeRange,
            onTimeRangeChanged = viewModel::setTimeRange,
            onRefresh = viewModel::refreshAnalytics,
            isLoading = isLoading
        )
        
        // Error message
        errorMessage?.let { error ->
            Card(
                modifier = Modifier.fillMaxWidth(),
                colors = CardDefaults.cardColors(
                    containerColor = ErrorRed.copy(alpha = 0.1f)
                ),
                elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
            ) {
                Text(
                    text = error,
                    modifier = Modifier.padding(16.dp),
                    color = ErrorRed,
                    style = MaterialTheme.typography.bodyMedium
                )
            }
        }
        
        // Fuel Analytics Content
        fuelAnalytics?.let { analytics ->
            // Fuel Overview
            FuelOverviewSection(analytics = analytics)
            
            // Cost Analysis
            FuelCostSection(analytics = analytics)
            
            // Efficiency Metrics
            FuelEfficiencySection(analytics = analytics)
            
            // Vehicle Performance
            VehicleFuelPerformanceSection(analytics = analytics)
            
            // Fuel Station Analytics
            FuelStationAnalyticsSection(analytics = analytics)
            
            // Price Trends
            FuelPriceTrendsSection(analytics = analytics)
            
            // Optimization Recommendations
            OptimizationRecommendationsSection(analytics = analytics)
        }
        
        // Loading indicator
        if (isLoading) {
            Box(
                modifier = Modifier.fillMaxWidth(),
                contentAlignment = Alignment.Center
            ) {
                CircularProgressIndicator(
                    color = EdhamOrange,
                    strokeWidth = 3.dp
                )
            }
        }
    }
}

@Composable
fun FuelAnalyticsHeader(
    selectedTimeRange: TimeRange,
    onTimeRangeChanged: (TimeRange) -> Unit,
    onRefresh: () -> Unit,
    isLoading: Boolean
) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.surface
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Row(
                modifier = Modifier.fillMaxWidth(),
                horizontalArrangement = Arrangement.SpaceBetween,
                verticalAlignment = Alignment.CenterVertically
            ) {
                Text(
                    text = "Fuel Analytics",
                    style = MaterialTheme.typography.headlineMedium,
                    color = EdhamOrange,
                    fontWeight = FontWeight.Bold
                )
                
                Row {
                    // Time range selector
                    TimeRangeSelector(
                        selectedTimeRange = selectedTimeRange,
                        onTimeRangeChanged = onTimeRangeChanged
                    )
                    
                    Spacer(modifier = Modifier.width(8.dp))
                    
                    // Refresh button
                    IconButton(
                        onClick = onRefresh,
                        enabled = !isLoading
                    ) {
                        Icon(
                            painter = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_rotate),
                            contentDescription = "Refresh",
                            tint = EdhamOrange
                        )
                    }
                }
            }
        }
    }
}

@Composable
fun FuelOverviewSection(analytics: FuelAnalytics) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.surface
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Text(
                text = "Fuel Overview",
                style = MaterialTheme.typography.titleMedium,
                color = EdhamOrange,
                fontWeight = FontWeight.Bold
            )
            
            Spacer(modifier = Modifier.height(16.dp))
            
            LazyColumn(
                verticalArrangement = Arrangement.spacedBy(12.dp)
            ) {
                item {
                    OverviewMetric(
                        title = "Total Fuel Consumed",
                        value = "${String.format("%,.0f", analytics.totalFuelConsumed)} L",
                        subtitle = "All vehicles combined",
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_save),
                        color = EdhamOrange,
                        change = analytics.fuelConsumptionChange
                    )
                }
                
                item {
                    OverviewMetric(
                        title = "Total Fuel Cost",
                        value = "SAR ${String.format("%,.2f", analytics.totalFuelCost)}",
                        subtitle = "Total expenditure",
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_more),
                        color = ErrorRed,
                        change = analytics.fuelCostChange
                    )
                }
                
                item {
                    OverviewMetric(
                        title = "Average Fuel Price",
                        value = "SAR ${String.format("%.3f", analytics.averageFuelPrice)}/L",
                        subtitle = "Per liter average",
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_info_details),
                        color = IceBlue,
                        change = analytics.fuelPriceChange
                    )
                }
                
                item {
                    OverviewMetric(
                        title = "Fleet Efficiency",
                        value = "${String.format("%.1f", analytics.fleetAverageEfficiency)} km/L",
                        subtitle = "Fleet average",
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_directions),
                        color = if (analytics.fleetAverageEfficiency >= 8) SuccessGreen else WarningYellow,
                        change = analytics.efficiencyChange
                    )
                }
            }
        }
    }
}

