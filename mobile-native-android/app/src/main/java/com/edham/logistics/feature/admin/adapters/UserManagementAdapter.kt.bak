package com.edham.logistics.feature.admin.adapters

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.ImageView
import android.widget.TextView
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.data.local.entity.User
import java.text.SimpleDateFormat
import java.util.*

class UserManagementAdapter(
    private val onUserAction: (User, UserAction) -> Unit
) : RecyclerView.Adapter<UserManagementAdapter.ViewHolder>() {
    
    private var users = mutableListOf<User>()
    private val dateFormat = SimpleDateFormat("MMM dd, yyyy", Locale.getDefault())
    
    fun updateUsers(newUsers: List<User>) {
        users.clear()
        users.addAll(newUsers)
        notifyDataSetChanged()
    }
    
    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): ViewHolder {
        val view = LayoutInflater.from(parent.context).inflate(R.layout.item_user_management, parent, false)
        return ViewHolder(view)
    }
    
    override fun onBindViewHolder(holder: ViewHolder, position: Int) {
        holder.bind(users[position])
    }
    
    override fun getItemCount(): Int = users.size
    
    inner class ViewHolder(itemView: View) : RecyclerView.ViewHolder(itemView) {
        private val userName: TextView = itemView.findViewById(R.id.userName)
        private val userEmail: TextView = itemView.findViewById(R.id.userEmail)
        private val userRole: TextView = itemView.findViewById(R.id.userRole)
        private val userStatus: TextView = itemView.findViewById(R.id.userStatus)
        private val statusIndicator: View = itemView.findViewById(R.id.statusIndicator)
        private val createdDate: TextView = itemView.findViewById(R.id.createdDate)
        private val lastActive: TextView = itemView.findViewById(R.id.lastActive)
        private val actionView: ImageView = itemView.findViewById(R.id.actionView)
        private val actionEdit: ImageView = itemView.findViewById(R.id.actionEdit)
        private val actionDelete: ImageView = itemView.findViewById(R.id.actionDelete)
        private val actionToggle: ImageView = itemView.findViewById(R.id.actionToggle)
        
        fun bind(user: User) {
            // Set user information
            userName.text = "${user.firstName} ${user.lastName}"
            userEmail.text = user.email
            userRole.text = "Role: ${user.roleId}"
            createdDate.text = "Created: ${dateFormat.format(Date(user.createdAt))}"
            
            // Set last active date
            val lastActiveText = if (user.lastLogin > 0) {
                "Last active: ${dateFormat.format(Date(user.lastLogin))}"
            } else {
                "Never active"
            }
            lastActive.text = lastActiveText
            
            // Set status and indicator
            val (statusText, statusColor, indicatorColor, iconRes) = if (user.isActive) {
                Triple("ACTIVE", itemView.context.getColor(R.color.status_active), 
                      itemView.context.getColor(R.color.status_active), R.drawable.ic_active_user)
            } else {
                Triple("INACTIVE", itemView.context.getColor(R.color.status_inactive),
                      itemView.context.getColor(R.color.status_inactive), R.drawable.ic_inactive_user)
            }
            
            userStatus.text = statusText
            userStatus.setTextColor(statusColor)
            statusIndicator.setBackgroundColor(indicatorColor)
            
            // Set background color based on status
            when {
                user.isActive -> {
                    itemView.setBackgroundColor(itemView.context.getColor(R.color.active_user_bg))
                }
                else -> {
                    itemView.setBackgroundColor(itemView.context.getColor(R.color.inactive_user_bg))
                }
            }
            
            // Set action buttons
            actionView.setOnClickListener {
                onUserAction(user, UserAction.VIEW)
            }
            
            actionEdit.setOnClickListener {
                onUserAction(user, UserAction.EDIT)
            }
            
            actionDelete.setOnClickListener {
                onUserAction(user, UserAction.DELETE)
            }
            
            // Set toggle button based on status
            val toggleAction = if (user.isActive) UserAction.DEACTIVATE else UserAction.ACTIVATE
            val toggleIcon = if (user.isActive) R.drawable.ic_deactivate else R.drawable.ic_activate
            actionToggle.setImageResource(toggleIcon)
            actionToggle.setOnClickListener {
                onUserAction(user, toggleAction)
            }
            
            // Set click listener for item
            itemView.setOnClickListener {
                onUserAction(user, UserAction.VIEW)
            }
            
            // Long click for quick actions
            itemView.setOnLongClickListener {
                showQuickActions(user)
                true
            }
        }
        
        private fun showQuickActions(user: User) {
            // Show quick actions dialog
            val actions = if (user.isActive) {
                listOf("View Details", "Edit User", "Deactivate", "Delete")
            } else {
                listOf("View Details", "Edit User", "Activate")
            }
            
            // Implementation would show actions in a bottom sheet or dialog
        }
    }
}
