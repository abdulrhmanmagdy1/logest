/**
 * Delay Analytics Fragment - Comprehensive delay analysis and insights
 * 
 * Features:
 * - Delay overview and statistics
 * - Delay causes analysis
 * - Route delay metrics
 * - Driver delay performance
 * - Delay trends and patterns
 * - Impact analysis
 * - Predictive delay insights
 * - Interactive charts
 */
@AndroidEntryPoint
class DelayAnalyticsFragment : Fragment() {
    
    @Inject
    lateinit var analyticsEngineService: AnalyticsEngineService
    
    private val viewModel: DelayAnalyticsViewModel by viewModels()
    
    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View {
        return ComposeView(requireContext()).apply {
            setContent {
                EdhamLogisticsTheme {
                    DelayAnalyticsScreen(
                        viewModel = viewModel,
                        analyticsEngineService = analyticsEngineService
                    )
                }
            }
        }
    }
    
    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        
        // Initialize analytics engine
        lifecycleScope.launch {
            analyticsEngineService.initialize()
        }
        
        // Load delay analytics
        viewModel.loadDelayAnalytics()
    }
}

@Composable
fun DelayAnalyticsScreen(
    viewModel: DelayAnalyticsViewModel,
    analyticsEngineService: AnalyticsEngineService
) {
    val delayAnalytics by viewModel.delayAnalytics.collectAsStateWithLifecycle()
    val isLoading by viewModel.isLoading.collectAsStateWithLifecycle()
    val errorMessage by viewModel.errorMessage.collectAsStateWithLifecycle()
    val selectedTimeRange by viewModel.selectedTimeRange.collectAsStateWithLifecycle()
    
    LaunchedEffect(selectedTimeRange) {
        viewModel.loadDelayAnalytics()
    }
    
    Column(
        modifier = Modifier
            .fillMaxSize()
            .padding(16.dp),
        verticalArrangement = Arrangement.spacedBy(16.dp)
    ) {
        // Header with time range selector
        DelayAnalyticsHeader(
            selectedTimeRange = selectedTimeRange,
            onTimeRangeChanged = viewModel::setTimeRange,
            onRefresh = viewModel::refreshAnalytics,
            isLoading = isLoading
        )
        
        // Error message
        errorMessage?.let { error ->
            Card(
                modifier = Modifier.fillMaxWidth(),
                colors = CardDefaults.cardColors(
                    containerColor = ErrorRed.copy(alpha = 0.1f)
                ),
                elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
            ) {
                Text(
                    text = error,
                    modifier = Modifier.padding(16.dp),
                    color = ErrorRed,
                    style = MaterialTheme.typography.bodyMedium
                )
            }
        }
        
        // Delay Analytics Content
        delayAnalytics?.let { analytics ->
            // Delay Overview
            DelayOverviewSection(analytics = analytics)
            
            // Delay Causes Analysis
            DelayCausesSection(analytics = analytics)
            
            // Route Delay Metrics
            RouteDelaySection(analytics = analytics)
            
            // Driver Delay Performance
            DriverDelaySection(analytics = analytics)
            
            // Delay Trends
            DelayTrendsSection(analytics = analytics)
            
            // Impact Analysis
            DelayImpactSection(analytics = analytics)
            
            // Predictive Insights
            PredictiveInsightsSection(analytics = analytics)
        }
        
        // Loading indicator
        if (isLoading) {
            Box(
                modifier = Modifier.fillMaxWidth(),
                contentAlignment = Alignment.Center
            ) {
                CircularProgressIndicator(
                    color = EdhamOrange,
                    strokeWidth = 3.dp
                )
            }
        }
    }
}

@Composable
fun DelayAnalyticsHeader(
    selectedTimeRange: TimeRange,
    onTimeRangeChanged: (TimeRange) -> Unit,
    onRefresh: () -> Unit,
    isLoading: Boolean
) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.surface
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Row(
                modifier = Modifier.fillMaxWidth(),
                horizontalArrangement = Arrangement.SpaceBetween,
                verticalAlignment = Alignment.CenterVertically
            ) {
                Text(
                    text = "Delay Analytics",
                    style = MaterialTheme.typography.headlineMedium,
                    color = EdhamOrange,
                    fontWeight = FontWeight.Bold
                )
                
                Row {
                    // Time range selector
                    TimeRangeSelector(
                        selectedTimeRange = selectedTimeRange,
                        onTimeRangeChanged = onTimeRangeChanged
                    )
                    
                    Spacer(modifier = Modifier.width(8.dp))
                    
                    // Refresh button
                    IconButton(
                        onClick = onRefresh,
                        enabled = !isLoading
                    ) {
                        Icon(
                            painter = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_rotate),
                            contentDescription = "Refresh",
                            tint = EdhamOrange
                        )
                    }
                }
            }
        }
    }
}

@Composable
fun DelayOverviewSection(analytics: DelayAnalytics) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.surface
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Text(
                text = "Delay Overview",
                style = MaterialTheme.typography.titleMedium,
                color = EdhamOrange,
                fontWeight = FontWeight.Bold
            )
            
            Spacer(modifier = Modifier.height(16.dp))
            
            LazyColumn(
                verticalArrangement = Arrangement.spacedBy(12.dp)
            ) {
                item {
                    OverviewMetric(
                        title = "Total Delayed Shipments",
                        value = analytics.totalDelayedShipments.toString(),
                        subtitle = "In selected period",
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_warning),
                        color = WarningYellow,
                        change = analytics.delayedShipmentsChange
                    )
                }
                
                item {
                    OverviewMetric(
                        title = "Average Delay Time",
                        value = "${String.format("%.1f", analytics.averageDelayTime)} hours",
                        subtitle = "Per delayed shipment",
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_recent_history),
                        color = if (analytics.averageDelayTime <= 2) SuccessGreen else WarningYellow,
                        change = analytics.averageDelayChange
                    )
                }
                
                item {
                    OverviewMetric(
                        title = "On-Time Delivery Rate",
                        value = "${String.format("%.1f", analytics.onTimeDeliveryRate)}%",
                        subtitle = "Delivered on schedule",
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_star),
                        color = if (analytics.onTimeDeliveryRate >= 90) SuccessGreen else WarningYellow,
                        change = analytics.onTimeRateChange
                    )
                }
                
                item {
                    OverviewMetric(
                        title = "Delay Cost Impact",
                        value = "SAR ${String.format("%,.2f", analytics.delayCostImpact)}",
                        subtitle = "Financial impact of delays",
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_info_details),
                        color = ErrorRed,
                        change = analytics.costImpactChange
                    )
                }
            }
        }
    }
}

