package com.edham.logistics.domain.usecase

import com.edham.logistics.core.utils.Result
import com.edham.logistics.domain.model.Driver
import com.edham.logistics.domain.repository.DriverRepository
import kotlinx.coroutines.flow.Flow
import javax.inject.Inject
import javax.inject.Singleton

@Singleton
class GetDriversUseCase @Inject constructor(
    private val driverRepository: DriverRepository
) {
    suspend operator fun invoke(
        page: Int = 1,
        pageSize: Int = 20
    ): Result<List<Driver>> {
        return driverRepository.getDrivers(page, pageSize)
    }
    
    suspend fun getAvailableDrivers(): Result<List<Driver>> {
        return driverRepository.getAvailableDrivers()
    }
    
    suspend fun getDriversByStatus(status: String): Result<List<Driver>> {
        return driverRepository.getDriversByStatus(status)
    }
    
    suspend fun searchDrivers(query: String): Result<List<Driver>> {
        return driverRepository.searchDrivers(query)
    }
    
    fun observeDrivers(): Flow<List<Driver>> {
        return driverRepository.observeDrivers()
    }
    
    fun observeDriverById(id: String): Flow<Driver?> {
        return driverRepository.observeDriverById(id)
    }
}
