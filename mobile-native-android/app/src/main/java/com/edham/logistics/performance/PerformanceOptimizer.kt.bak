/**
 * Performance Optimizer
 * Optimizes full application performance including API calls, caching, image loading, and startup time
 */
class PerformanceOptimizer(private val context: Context) {

    companion object {
        private const val CACHE_SIZE = 50 * 1024 * 1024L // 50MB
        private const val HTTP_CACHE_SIZE = 10 * 1024 * 1024L // 10MB
        private const val CACHE_EXPIRY_MINUTES = 30
        private const val PREFETCH_LIMIT = 10
    }

    private val sharedPreferences = SharedPreferencesHelper(context)
    private val performanceScope = CoroutineScope(Dispatchers.IO + SupervisorJob())
    
    // Cache managers
    private val memoryCache = MemoryCache<String, Any>(100)
    private val diskCache = DiskCache(context, "performance_cache", CACHE_SIZE)
    private val imageCache = ImageCache(context)
    private val apiCache = APICache(context)
    
    // Performance metrics
    private var apiCallCount = 0
    private var cacheHitCount = 0
    private var totalResponseTime = 0L
    
    init {
        initializeOptimizations()
    }

    /**
     * Initialize all performance optimizations
     */
    private fun initializeOptimizations() {
        // Initialize HTTP cache
        initializeHTTPCache()
        
        // Initialize image loading optimizations
        initializeImageOptimizations()
        
        // Initialize API optimizations
        initializeAPIOptimizations()
        
        // Prefetch critical data
        prefetchCriticalData()
        
        // Start performance monitoring
        startPerformanceMonitoring()
    }

    /**
     * Reduce API calls through intelligent caching and batching
     */
    suspend fun <T> optimizeAPICall(
        key: String,
        cacheExpiryMinutes: Int = CACHE_EXPIRY_MINUTES,
        forceRefresh: Boolean = false,
        apiCall: suspend () -> T
    ): Result<T> {
        val startTime = System.currentTimeMillis()
        apiCallCount++

        return try {
            // Check cache first
            if (!forceRefresh) {
                val cachedResult = apiCache.get<T>(key)
                if (cachedResult != null) {
                    cacheHitCount++
                    val responseTime = System.currentTimeMillis() - startTime
                    totalResponseTime += responseTime
                    return Result.success(cachedResult)
                }
            }

            // Make API call
            val result = apiCall()
            val responseTime = System.currentTimeMillis() - startTime
            totalResponseTime += responseTime

            // Cache the result
            apiCache.put(key, result, cacheExpiryMinutes)

            Result.success(result)

        } catch (e: Exception) {
            val responseTime = System.currentTimeMillis() - startTime
            totalResponseTime += responseTime
            Result.failure(e)
        }
    }

    /**
     * Batch multiple API calls
     */
    suspend fun <T> batchAPICalls(
        calls: List<suspend () -> T>
    ): Result<List<T>> {
        return try {
            val results = calls.map { call ->
                async { call() }
            }.awaitAll()
            Result.success(results)
        } catch (e: Exception) {
            Result.failure(e)
        }
    }

    /**
     * Implement intelligent caching
     */
    fun <T> cacheData(key: String, data: T, expiryMinutes: Int = CACHE_EXPIRY_MINUTES) {
        memoryCache.put(key, data)
        diskCache.put(key, data, expiryMinutes)
    }

    fun <T> getCachedData(key: String): T? {
        // Try memory cache first
        memoryCache.get<T>(key)?.let { return it }

        // Try disk cache
        return diskCache.get<T>(key)
    }

    fun clearCache() {
        memoryCache.clear()
        diskCache.clear()
        imageCache.clear()
        apiCache.clear()
    }

    /**
     * Optimize image loading
     */
    fun loadImageWithOptimization(
        url: String,
        options: RequestOptions = defaultImageOptions()
    ) = Glide.with(context)
        .load(url)
        .apply(options)
        .into(android.widget.ImageView(context))

    fun preloadImages(urls: List<String>) {
        performanceScope.launch {
            urls.take(PREFETCH_LIMIT).forEach { url ->
                try {
                    Glide.with(context)
                        .load(url)
                        .preload()
                } catch (e: Exception) {
                    // Log error but continue
                }
            }
        }
    }

    fun optimizeImageBitmap(bitmap: Bitmap): Bitmap {
        val maxSize = 1024
        val width = bitmap.width
        val height = bitmap.height

        if (width <= maxSize && height <= maxSize) {
            return bitmap
        }

        val ratio = minOf(maxSize.toFloat() / width, maxSize.toFloat() / height)
        val newWidth = (width * ratio).toInt()
        val newHeight = (height * ratio).toInt()

        return Bitmap.createScaledBitmap(bitmap, newWidth, newHeight, true)
    }

    /**
     * Improve map performance
     */
    fun optimizeMapPerformance(): MapOptimizations {
        return MapOptimizations(
            enableClustering = true,
            markerBatchSize = 100,
            updateInterval = 5000L, // 5 seconds
            enableLazyLoading = true,
            cacheMapData = true,
            reduceMarkerComplexity = true
        )
    }

    fun cacheMapData(key: String, data: Any) {
        cacheData("map_$key", data, 60) // Cache map data for 1 hour
    }

    fun getCachedMapData(key: String): Any? {
        return getCachedData("map_$key")
    }

    /**
     * Reduce app startup time
     */
    fun optimizeStartupTime(): StartupOptimizations {
        return StartupOptimizations(
            enableLazyInitialization = true,
            prefetchCriticalData = true,
            optimizeSplashScreen = true,
            reduceInitialLoad = true,
            enableBackgroundInit = true
        )
    }

    fun initializeInBackground() {
        performanceScope.launch {
            // Initialize non-critical components in background
            initializeNonCriticalComponents()
            
            // Prefetch data
            prefetchNonCriticalData()
            
            // Warm up caches
            warmUpCaches()
        }
    }

    /**
     * Performance monitoring and metrics
     */
    fun getPerformanceMetrics(): PerformanceMetrics {
        val avgResponseTime = if (apiCallCount > 0) totalResponseTime / apiCallCount else 0
        val cacheHitRate = if (apiCallCount > 0) (cacheHitCount.toFloat() / apiCallCount * 100) else 0f

        return PerformanceMetrics(
            apiCallCount = apiCallCount,
            cacheHitCount = cacheHitCount,
            cacheHitRate = cacheHitRate,
            averageResponseTime = avgResponseTime,
            memoryUsage = getMemoryUsage(),
            diskCacheSize = diskCache.getSize(),
            imageCacheSize = imageCache.getSize()
        )
    }

    fun resetMetrics() {
        apiCallCount = 0
        cacheHitCount = 0
        totalResponseTime = 0L
    }

    // Private helper methods
    private fun initializeHTTPCache() {
        val httpCacheDir = File(context.cacheDir, "http_cache")
        val cache = Cache(httpCacheDir, HTTP_CACHE_SIZE)

        val okHttpClient = OkHttpClient.Builder()
            .cache(cache)
            .connectTimeout(30, TimeUnit.SECONDS)
            .readTimeout(30, TimeUnit.SECONDS)
            .writeTimeout(30, TimeUnit.SECONDS)
            .addInterceptor(createCacheInterceptor())
            .build()

        // Update Retrofit client with optimized OkHttpClient
        RetrofitClient.updateOkHttpClient(okHttpClient)
    }

    private fun createCacheInterceptor(): Interceptor {
        return Interceptor { chain ->
            val request = chain.request()
            val response = chain.proceed(request)

            // Cache successful responses
            if (response.isSuccessful) {
                val cacheControl = response.request.header("Cache-Control")
                if (cacheControl == null || cacheControl.contains("no-cache")) {
                    val newCacheControl = "public, max-age=$CACHE_EXPIRY_MINUTES"
                    response.newBuilder()
                        .header("Cache-Control", newCacheControl)
                        .build()
                } else {
                    response
                }
            } else {
                response
            }
        }
    }

    private fun initializeImageOptimizations() {
        // Configure Glide with optimizations
        Glide.get(context).clearMemory()
    }

    private fun defaultImageOptions(): RequestOptions {
        return RequestOptions()
            .diskCacheStrategy(DiskCacheStrategy.ALL)
            .skipMemoryCache(false)
            .override(800, 600)
            .centerCrop()
    }

    private fun initializeAPIOptimizations() {
        // Set up request batching
        // Configure retry policies
        // Set up connection pooling
    }

    private fun prefetchCriticalData() {
        performanceScope.launch {
            try {
                // Prefetch user data
                // Prefetch dashboard data
                // Prefetch recent shipments
                // Prefetch driver data if applicable
            } catch (e: Exception) {
