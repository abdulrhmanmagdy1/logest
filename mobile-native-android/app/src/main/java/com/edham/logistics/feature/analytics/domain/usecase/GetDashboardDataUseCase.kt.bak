package com.edham.logistics.feature.analytics.domain.usecase

import com.edham.logistics.core.utils.Result
import com.edham.logistics.feature.analytics.domain.model.*
import com.edham.logistics.feature.analytics.domain.repository.AnalyticsRepository
import javax.inject.Inject

class GetDashboardDataUseCase @Inject constructor(
    private val analyticsRepository: AnalyticsRepository
) {
    
    suspend operator fun invoke(request: GetDashboardDataRequest): Result<DashboardData> {
        return when (request.userRole) {
            "admin" -> getAdminDashboardData(request)
            "customer" -> getCustomerDashboardData(request)
            "driver" -> getDriverDashboardData(request)
            "accountant" -> getAccountantDashboardData(request)
            else -> Result.Error(Exception("Invalid user role"))
        }
    }
    
    private suspend fun getAdminDashboardData(request: GetDashboardDataRequest): Result<AdminDashboardData> {
        return analyticsRepository.getAdminDashboardData(request.userId, request.filters)
    }
    
    private suspend fun getCustomerDashboardData(request: GetDashboardDataRequest): Result<CustomerDashboardData> {
        return analyticsRepository.getCustomerDashboardData(request.userId, request.filters)
    }
    
    private suspend fun getDriverDashboardData(request: GetDashboardDataRequest): Result<DriverDashboardData> {
        return analyticsRepository.getDriverDashboardData(request.userId, request.filters)
    }
    
    private suspend fun getAccountantDashboardData(request: GetDashboardDataRequest): Result<AccountantDashboardData> {
        return analyticsRepository.getAccountantDashboardData(request.userId, request.filters)
    }
}

// Union type for different dashboard data types
sealed class DashboardData {
    data class AdminData(val data: AdminDashboardData) : DashboardData()
    data class CustomerData(val data: CustomerDashboardData) : DashboardData()
    data class DriverData(val data: DriverDashboardData) : DashboardData()
    data class AccountantData(val data: AccountantDashboardData) : DashboardData()
}
