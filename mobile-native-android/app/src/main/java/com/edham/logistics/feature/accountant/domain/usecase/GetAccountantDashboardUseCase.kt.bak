package com.edham.logistics.feature.accountant.domain.usecase

import com.edham.logistics.core.utils.Result
import com.edham.logistics.feature.accountant.domain.model.AccountantDashboardData
import com.edham.logistics.feature.accountant.domain.repository.AccountantRepository
import kotlinx.coroutines.flow.Flow
import javax.inject.Inject

class GetAccountantDashboardUseCase @Inject constructor(
    private val accountantRepository: AccountantRepository
) {
    
    suspend operator fun invoke(): Flow<Result<AccountantDashboardData>> {
        return accountantRepository.getDashboardData()
    }
}
