package com.edham.logistics.feature.admin

import com.edham.logistics.data.local.entity.Role
import com.edham.logistics.data.local.entity.Permission
import timber.log.Timber
import java.util.concurrent.ConcurrentHashMap

/**
 * Permissions Engine
 * Advanced permissions management with role-based access control
 */
class PermissionsEngine {
    
    private val rolePermissions = ConcurrentHashMap<String, List<String>>()
    private val permissionMap = ConcurrentHashMap<String, Permission>()
    private val roleMap = ConcurrentHashMap<String, Role>()
    
    private val defaultPermissions = listOf(
        "VIEW_DASHBOARD",
        "VIEW_PROFILE",
        "EDIT_PROFILE"
    )
    
    /**
     * Initialize permissions engine with roles and permissions
     */
    fun initialize(permissions: List<Permission>) {
        try {
            // Clear existing data
            permissionMap.clear()
            rolePermissions.clear()
            
            // Load permissions
            permissions.forEach { permission ->
                permissionMap[permission.id] = permission
            }
            
            Timber.d("Permissions engine initialized with ${permissions.size} permissions")
            
        } catch (e: Exception) {
            Timber.e(e, "Error initializing permissions engine")
        }
    }
    
    /**
     * Add role to permissions engine
     */
    fun addRole(role: Role) {
        try {
            roleMap[role.id] = role
            rolePermissions[role.id] = role.permissions
            
            Timber.d("Added role: ${role.name}")
            
        } catch (e: Exception) {
            Timber.e(e, "Error adding role")
        }
    }
    
    /**
     * Update role in permissions engine
     */
    fun updateRole(role: Role) {
        try {
            roleMap[role.id] = role
            rolePermissions[role.id] = role.permissions
            
            Timber.d("Updated role: ${role.name}")
            
        } catch (e: Exception) {
            Timber.e(e, "Error updating role")
        }
    }
    
    /**
     * Remove role from permissions engine
     */
    fun removeRole(roleId: String) {
        try {
            roleMap.remove(roleId)
            rolePermissions.remove(roleId)
            
            Timber.d("Removed role: $roleId")
            
        } catch (e: Exception) {
            Timber.e(e, "Error removing role")
        }
    }
    
    /**
     * Add permission to permissions engine
     */
    fun addPermission(permission: Permission) {
        try {
            permissionMap[permission.id] = permission
            
            Timber.d("Added permission: ${permission.name}")
            
        } catch (e: Exception) {
            Timber.e(e, "Error adding permission")
        }
    }
    
    /**
     * Check if user has specific permission
     */
    fun hasPermission(roleId: String, permissionKey: String): Boolean {
        return try {
            val permissions = rolePermissions[roleId] ?: defaultPermissions
            permissions.contains(permissionKey)
        } catch (e: Exception) {
            Timber.e(e, "Error checking permission")
            false
        }
    }
    
    /**
     * Check if user has any of the specified permissions
     */
    fun hasAnyPermission(roleId: String, permissionKeys: List<String>): Boolean {
        return try {
            val permissions = rolePermissions[roleId] ?: defaultPermissions
            permissionKeys.any { permissions.contains(it) }
        } catch (e: Exception) {
            Timber.e(e, "Error checking any permission")
            false
        }
    }
    
    /**
     * Check if user has all specified permissions
     */
    fun hasAllPermissions(roleId: String, permissionKeys: List<String>): Boolean {
        return try {
            val permissions = rolePermissions[roleId] ?: defaultPermissions
            permissionKeys.all { permissions.contains(it) }
        } catch (e: Exception) {
            Timber.e(e, "Error checking all permissions")
            false
        }
    }
    
    /**
     * Get all permissions for a role
     */
    fun getRolePermissions(roleId: String): List<String> {
        return try {
            rolePermissions[roleId] ?: defaultPermissions
        } catch (e: Exception) {
            Timber.e(e, "Error getting role permissions")
            defaultPermissions
        }
    }
    
    /**
     * Get all permission details for a role
     */
    fun getRolePermissionDetails(roleId: String): List<Permission> {
        return try {
            val permissionIds = rolePermissions[roleId] ?: defaultPermissions
            permissionIds.mapNotNull { permissionMap.values.find { it.key == it } }
        } catch (e: Exception) {
            Timber.e(e, "Error getting role permission details")
            emptyList()
        }
    }
    
    /**
     * Get all roles
     */
    fun getAllRoles(): List<Role> {
        return try {
            roleMap.values.toList()
        } catch (e: Exception) {
            Timber.e(e, "Error getting all roles")
            emptyList()
        }
    }
    
    /**
     * Get all permissions
     */
    fun getAllPermissions(): List<Permission> {
        return try {
            permissionMap.values.toList()
        } catch (e: Exception) {
            Timber.e(e, "Error getting all permissions")
            emptyList()
        }
    }
    
    /**
     * Get permission by key
     */
    fun getPermissionByKey(permissionKey: String): Permission? {
        return try {
            permissionMap.values.find { it.key == permissionKey }
        } catch (e: Exception) {
            Timber.e(e, "Error getting permission by key")
            null
        }
    }
    
    /**
     * Get role by ID
     */
    fun getRoleById(roleId: String): Role? {
        return try {
            roleMap[roleId]
        } catch (e: Exception) {
            Timber.e(e, "Error getting role by ID")
            null
        }
    }
    
    /**
     * Create permissions matrix
     */
    fun createPermissionsMatrix(): PermissionsMatrix {
        return try {
            val roles = getAllRoles()
            val permissions = getAllPermissions()
            
            val matrix = mutableMapOf<String, MutableMap<String, Boolean>>()
            
            roles.forEach { role ->
                val rolePerms = mutableMapOf<String, Boolean>()
                permissions.forEach { permission ->
                    rolePerms[permission.key] = hasPermission(role.id, permission.key)
                }
                matrix[role.id] = rolePerms
            }
            
            PermissionsMatrix(
                roles = roles,
                permissions = permissions,
                matrix = matrix
            )
            
        } catch (e: Exception) {
            Timber.e(e, "Error creating permissions matrix")
            PermissionsMatrix()
        }
    }
    
    /**
     * Validate role permissions
     */
    fun validateRolePermissions(roleId: String, permissionKeys: List<String>): ValidationResult {
        return try {
            val invalidPermissions = permissionKeys.filter { permissionKey ->
                permissionMap.values.none { it.key == permissionKey }
            }
            
            if (invalidPermissions.isNotEmpty()) {
                ValidationResult.INVALID_PERMISSIONS(invalidPermissions)
            } else {
                ValidationResult.VALID
            }
            
        } catch (e: Exception) {
            Timber.e(e, "Error validating role permissions")
            ValidationResult.ERROR
        }
    }
    
    /**
     * Get permission hierarchy
     */
    fun getPermissionHierarchy(): PermissionHierarchy {
        return try {
            val categories = permissionMap.values
                .groupBy { it.category }
                .mapValues { (_, permissions) ->
                    permissions.map { PermissionItem(it.key, it.name, it.description) }
                }
            
            PermissionHierarchy(categories)
            
        } catch (e: Exception) {
            Timber.e(e, "Error getting permission hierarchy")
            PermissionHierarchy()
        }
    }
    
    /**
     * Check permission dependencies
     */
    fun checkPermissionDependencies(roleId: String, permissionKey: String): DependencyCheck {
        return try {
            val permission = getPermissionByKey(permissionKey)
                ?: return DependencyCheck.PERMISSION_NOT_FOUND
            
            val dependencies = permission.dependencies ?: emptyList()
            val missingDependencies = dependencies.filter { !hasPermission(roleId, it) }
            
            if (missingDependencies.isNotEmpty()) {
                DependencyCheck.MISSING_DEPENDENCIES(missingDependencies)
            } else {
                DependencyCheck.SATISFIED
            }
            
        } catch (e: Exception) {
            Timber.e(e, "Error checking permission dependencies")
            DependencyCheck.ERROR
        }
    }
    
    /**
     * Get effective permissions for a role (including inherited permissions)
     */
    fun getEffectivePermissions(roleId: String): List<String> {
        return try {
            val role = getRoleById(roleId) ?: return defaultPermissions
            val effectivePermissions = mutableListOf<String>()
            
            // Add role's direct permissions
            effectivePermissions.addAll(role.permissions)
            
            // Add inherited permissions from parent roles
            role.parentRoleIds?.forEach { parentRoleId ->
                effectivePermissions.addAll(getEffectivePermissions(parentRoleId))
            }
            
            // Add default permissions
            effectivePermissions.addAll(defaultPermissions)
            
            // Remove duplicates and return
            effectivePermissions.distinct()
            
        } catch (e: Exception) {
            Timber.e(e, "Error getting effective permissions")
            defaultPermissions
        }
    }
    
    /**
     * Export permissions configuration
     */
    fun exportConfiguration(): PermissionsConfiguration {
        return try {
            val roles = getAllRoles().map { role ->
                RoleConfiguration(
                    id = role.id,
                    name = role.name,
                    description = role.description,
                    permissions = role.permissions,
                    parentRoleIds = role.parentRoleIds
                )
            }
            
            val permissions = getAllPermissions().map { permission ->
                PermissionConfiguration(
                    key = permission.key,
                    name = permission.name,
                    description = permission.description,
                    category = permission.category,
                    dependencies = permission.dependencies
                )
            }
            
            PermissionsConfiguration(
                roles = roles,
                permissions = permissions,
                exportedAt = System.currentTimeMillis()
            )
            
        } catch (e: Exception) {
            Timber.e(e, "Error exporting permissions configuration")
            PermissionsConfiguration()
        }
    }
    
    /**
     * Import permissions configuration
     */
    fun importConfiguration(configuration: PermissionsConfiguration): ImportResult {
        return try {
            var importedRoles = 0
            var importedPermissions = 0
            val errors = mutableListOf<String>()
            
            // Import permissions first
            configuration.permissions.forEach { permConfig ->
                try {
                    val permission = Permission(
                        id = java.util.UUID.randomUUID().toString(),
                        key = permConfig.key,
                        name = permConfig.name,
                        description = permConfig.description,
                        category = permConfig.category,
                        dependencies = permConfig.dependencies,
                        createdAt = System.currentTimeMillis()
                    )
                    
                    addPermission(permission)
                    importedPermissions++
                    
                } catch (e: Exception) {
                    errors.add("Error importing permission ${permConfig.key}: ${e.message}")
                }
            }
            
            // Import roles
            configuration.roles.forEach { roleConfig ->
                try {
                    val role = Role(
                        id = roleConfig.id,
                        name = roleConfig.name,
                        description = roleConfig.description,
                        permissions = roleConfig.permissions,
                        parentRoleIds = roleConfig.parentRoleIds,
                        createdAt = System.currentTimeMillis(),
                        lastUpdated = System.currentTimeMillis()
                    )
                    
                    addRole(role)
                    importedRoles++
                    
                } catch (e: Exception) {
                    errors.add("Error importing role ${roleConfig.name}: ${e.message}")
                }
            }
            
            if (errors.isNotEmpty()) {
                ImportResult.PARTIAL_SUCCESS(importedRoles, importedPermissions, errors)
            } else {
                ImportResult.SUCCESS(importedRoles, importedPermissions)
            }
            
        } catch (e: Exception) {
            Timber.e(e, "Error importing permissions configuration")
            ImportResult.ERROR
        }
    }
    
    /**
     * Cleanup resources
     */
    fun cleanup() {
        rolePermissions.clear()
        permissionMap.clear()
        roleMap.clear()
        
        Timber.d("Permissions engine cleaned up")
    }
}

// Data classes
data class PermissionsMatrix(
    val roles: List<Role> = emptyList(),
    val permissions: List<Permission> = emptyList(),
    val matrix: Map<String, Map<String, Boolean>> = emptyMap()
)

data class PermissionHierarchy(
    val categories: Map<String, List<PermissionItem>> = emptyMap()
)

data class PermissionItem(
    val key: String,
    val name: String,
    val description: String
)

data class PermissionsConfiguration(
    val roles: List<RoleConfiguration> = emptyList(),
    val permissions: List<PermissionConfiguration> = emptyList(),
    val exportedAt: Long = System.currentTimeMillis()
)

data class RoleConfiguration(
    val id: String,
    val name: String,
    val description: String,
    val permissions: List<String>,
    val parentRoleIds: List<String>? = null
)

data class PermissionConfiguration(
    val key: String,
    val name: String,
    val description: String,
    val category: String,
    val dependencies: List<String>? = null
)

// Enums
sealed class ValidationResult {
    object VALID : ValidationResult()
    data class INVALID_PERMISSIONS(val permissions: List<String>) : ValidationResult()
    object ERROR : ValidationResult()
}

sealed class DependencyCheck {
    object SATISFIED : DependencyCheck()
    object PERMISSION_NOT_FOUND : DependencyCheck()
    data class MISSING_DEPENDENCIES(val dependencies: List<String>) : DependencyCheck()
    object ERROR : DependencyCheck()
}

sealed class ImportResult {
    data class SUCCESS(val rolesImported: Int, val permissionsImported: Int) : ImportResult()
    data class PARTIAL_SUCCESS(
        val rolesImported: Int,
        val permissionsImported: Int,
        val errors: List<String>
    ) : ImportResult()
    object ERROR : ImportResult()
}
