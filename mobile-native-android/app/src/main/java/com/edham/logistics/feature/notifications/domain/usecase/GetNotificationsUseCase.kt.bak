package com.edham.logistics.feature.notifications.domain.usecase

import com.edham.logistics.core.utils.Result
import com.edham.logistics.feature.notifications.domain.model.GetNotificationsRequest
import com.edham.logistics.feature.notifications.domain.model.Notification
import com.edham.logistics.feature.notifications.domain.repository.NotificationRepository
import kotlinx.coroutines.flow.Flow
import javax.inject.Inject

class GetNotificationsUseCase @Inject constructor(
    private val notificationRepository: NotificationRepository
) {
    
    suspend operator fun invoke(request: GetNotificationsRequest): Result<List<Notification>> {
        return notificationRepository.getNotifications(request)
    }
    
    suspend fun observeNotifications(userId: String, userRole: com.edham.logistics.feature.notifications.domain.model.UserRole): Flow<Result<List<Notification>>> {
        return notificationRepository.observeNotifications(userId, userRole)
    }
    
    suspend fun getUnreadCount(userId: String, userRole: com.edham.logistics.feature.notifications.domain.model.UserRole): Result<Int> {
        return notificationRepository.getUnreadCount(userId, userRole)
    }
    
    suspend fun markAsRead(notificationId: String, userId: String): Result<Unit> {
        return notificationRepository.markNotificationAsRead(notificationId, userId)
    }
    
    suspend fun markAllAsRead(userId: String, userRole: com.edham.logistics.feature.notifications.domain.model.UserRole): Result<Unit> {
        return notificationRepository.markAllNotificationsAsRead(userId, userRole)
    }
    
    suspend fun deleteNotification(notificationId: String, userId: String): Result<Unit> {
        return notificationRepository.deleteNotification(notificationId, userId)
    }
}
