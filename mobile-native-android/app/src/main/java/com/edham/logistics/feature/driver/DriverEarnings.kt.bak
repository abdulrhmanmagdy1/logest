package com.edham.logistics.feature.driver

import android.os.Bundle
import androidx.fragment.app.Fragment
import androidx.recyclerview.widget.LinearLayoutManager
import com.edham.logistics.R
import com.edham.logistics.databinding.FragmentDriverEarningsBinding
import com.edham.logistics.feature.driver.adapters.EarningsAdapter
import com.edham.logistics.utils.VoiceAlertManager
import timber.log.Timber
import java.text.SimpleDateFormat
import java.util.*

class DriverEarningsFragment : Fragment() {
    
    private var _binding: FragmentDriverEarningsBinding? = null
    private val binding get() = _binding!!
    
    private lateinit var voiceAlertManager: VoiceAlertManager
    private lateinit var earningsAdapter: EarningsAdapter
    private var earningsList = mutableListOf<EarningRecord>()
    private val dateFormat = SimpleDateFormat("MMM dd, yyyy", Locale.getDefault())
    private val currencyFormat = java.text.NumberFormat.getCurrencyInstance(Locale.US)
    
    override fun onCreateView(
        inflater: android.view.LayoutInflater,
        container: android.view.ViewGroup?,
        savedInstanceState: Bundle?
    ): android.view.View {
        _binding = FragmentDriverEarningsBinding.inflate(inflater, container, false)
        return binding.root
    }
    
    override fun onViewCreated(view: android.view.View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        
        voiceAlertManager = VoiceAlertManager(requireContext())
        setupUI()
        setupRecyclerView()
        setupClickListeners()
        loadEarningsData()
        
        voiceAlertManager.speak("Driver earnings dashboard opened")
    }
    
    private fun setupUI() {
        // Large touch targets for one-hand usage
        binding.btnViewDetails.minimumHeight = 72.dp
        binding.btnViewDetails.minimumWidth = 120.dp
        
        binding.btnExportEarnings.minimumHeight = 72.dp
        binding.btnExportEarnings.minimumWidth = 120.dp
        
        binding.btnFilterDate.minimumHeight = 64.dp
        binding.btnFilterDate.minimumWidth = 64.dp
        
        // Dark mode optimized colors
        binding.cardEarningsSummary.setCardBackgroundColor(
            requireContext().getColor(R.color.dark_surface)
        )
        
        binding.cardPerformanceMetrics.setCardBackgroundColor(
            requireContext().getColor(R.color.dark_surface)
        )
        
        // High visibility status colors
        binding.viewEarningsStatus.setBackgroundColor(
            requireContext().getColor(R.color.status_active)
        )
    }
    
    private fun setupRecyclerView() {
        earningsAdapter = EarningsAdapter(earningsList)
        
        binding.recyclerViewEarnings.apply {
            layoutManager = LinearLayoutManager(requireContext())
            adapter = earningsAdapter
        }
    }
    
    private fun setupClickListeners() {
        binding.btnViewDetails.setOnClickListener {
            viewEarningsDetails()
        }
        
        binding.btnExportEarnings.setOnClickListener {
            exportEarningsReport()
        }
        
        binding.btnFilterDate.setOnClickListener {
            showDateFilterDialog()
        }
        
        binding.tabDaily.setOnClickListener {
            switchToDailyView()
        }
        
        binding.tabWeekly.setOnClickListener {
            switchToWeeklyView()
        }
        
        binding.tabMonthly.setOnClickListener {
            switchToMonthlyView()
        }
    }
    
    private fun loadEarningsData() {
        // Load earnings data from API or local database
        // For now, simulate with sample data
        loadSampleEarningsData()
        updateEarningsSummary()
        updatePerformanceMetrics()
    }
    
    private fun loadSampleEarningsData() {
        val sampleEarnings = listOf(
            EarningRecord(
                id = UUID.randomUUID().toString(),
                date = System.currentTimeMillis() - 86400000, // Yesterday
                amount = 125.50,
                type = "DELIVERY",
                description = "Delivery to Downtown",
                trips = 8,
                distance = 45.2,
                bonus = 15.0
            ),
            EarningRecord(
                id = UUID.randomUUID().toString(),
                date = System.currentTimeMillis() - 172800000, // 2 days ago
                amount = 98.75,
                type = "DELIVERY",
                description = "Regular deliveries",
                trips = 6,
                distance = 32.8,
                bonus = 0.0
            ),
            EarningRecord(
                id = UUID.randomUUID().toString(),
                date = System.currentTimeMillis() - 259200000, // 3 days ago
                amount = 156.25,
                type = "DELIVERY",
                description = "Express deliveries + bonus",
                trips = 10,
                distance = 58.5,
                bonus = 25.0
            ),
            EarningRecord(
                id = UUID.randomUUID().toString(),
                date = System.currentTimeMillis() - 345600000, // 4 days ago
                amount = 87.00,
                type = "DELIVERY",
                description = "Morning shift",
                trips = 5,
                distance = 28.3,
                bonus = 0.0
            ),
            EarningRecord(
                id = UUID.randomUUID().toString(),
                date = System.currentTimeMillis() - 432000000, // 5 days ago
                amount = 134.80,
                type = "DELIVERY",
                description = "Evening shift + tips",
                trips = 7,
                distance = 41.7,
                bonus = 12.0
            )
        )
        
        earningsList.addAll(sampleEarnings)
        earningsAdapter.notifyDataSetChanged()
    }
    
    private fun updateEarningsSummary() {
        val totalEarnings = earningsList.sumOf { it.amount }
        val totalTrips = earningsList.sumOf { it.trips }
        val totalDistance = earningsList.sumOf { it.distance }
        val totalBonus = earningsList.sumOf { it.bonus }
        
        // Update summary cards
        binding.tvTotalEarnings.text = currencyFormat.format(totalEarnings)
        binding.tvTotalTrips.text = totalTrips.toString()
        binding.tvTotalDistance.text = String.format("%.1f km", totalDistance)
        binding.tvTotalBonus.text = currencyFormat.format(totalBonus)
        
        // Calculate average per day
        val avgPerDay = if (earningsList.isNotEmpty()) {
            totalEarnings / earningsList.size
        } else 0.0
        binding.tvAveragePerDay.text = currencyFormat.format(avgPerDay)
        
        // Update current period
        binding.tvCurrentPeriod.text = "Last ${earningsList.size} days"
    }
    
    private fun updatePerformanceMetrics() {
        if (earningsList.isEmpty()) return
        
        val totalEarnings = earningsList.sumOf { it.amount }
        val totalTrips = earningsList.sumOf { it.trips }
        val totalDistance = earningsList.sumOf { it.distance }
        
        // Calculate metrics
        val avgEarningsPerTrip = if (totalTrips > 0) totalEarnings / totalTrips else 0.0
        val avgDistancePerTrip = if (totalTrips > 0) totalDistance / totalTrips else 0.0
        val earningsPerKm = if (totalDistance > 0) totalEarnings / totalDistance else 0.0
        
        // Update performance metrics
        binding.tvAvgEarningsPerTrip.text = currencyFormat.format(avgEarningsPerTrip)
        binding.tvAvgDistancePerTrip.text = String.format("%.1f km", avgDistancePerTrip)
        binding.tvEarningsPerKm.text = currencyFormat.format(earningsPerKm)
        
        // Calculate performance score (0-100)
        val performanceScore = calculatePerformanceScore(avgEarningsPerTrip, totalTrips)
        binding.tvPerformanceScore.text = "${performanceScore.toInt()}/100"
        
        // Update progress bar
        binding.progressBarPerformance.progress = performanceScore.toInt()
        
        // Performance status
        val performanceStatus = when {
            performanceScore >= 80 -> "Excellent"
            performanceScore >= 60 -> "Good"
            performanceScore >= 40 -> "Average"
            else -> "Needs Improvement"
        }
        
        binding.tvPerformanceStatus.text = performanceStatus
    }
    
    private fun calculatePerformanceScore(avgEarningsPerTrip: Double, totalTrips: Int): Double {
        // Simple performance calculation based on earnings per trip and total trips
        val earningsScore = (avgEarningsPerTrip / 20.0) * 50 // 50% weight
        val tripsScore = (totalTrips / 10.0) * 50 // 50% weight
        
        return (earningsScore + tripsScore).coerceIn(0.0, 100.0)
    }
    
    private fun switchToDailyView() {
        // Update tab selection
        updateTabSelection(binding.tabDaily)
        
        // Load daily earnings data
        loadDailyEarnings()
        
        voiceAlertManager.speak("Switched to daily view")
    }
    
    private fun switchToWeeklyView() {
        // Update tab selection
        updateTabSelection(binding.tabWeekly)
        
        // Load weekly earnings data
        loadWeeklyEarnings()
        
        voiceAlertManager.speak("Switched to weekly view")
    }
    
    private fun switchToMonthlyView() {
        // Update tab selection
        updateTabSelection(binding.tabMonthly)
        
        // Load monthly earnings data
        loadMonthlyEarnings()
        
        voiceAlertManager.speak("Switched to monthly view")
    }
    
    private fun updateTabSelection(selectedTab: android.widget.TextView) {
        // Reset all tabs
        binding.tabDaily.setBackgroundColor(requireContext().getColor(R.color.tab_inactive))
        binding.tabWeekly.setBackgroundColor(requireContext().getColor(R.color.tab_inactive))
        binding.tabMonthly.setBackgroundColor(requireContext().getColor(R.color.tab_inactive))
        
        // Highlight selected tab
        selectedTab.setBackgroundColor(requireContext().getColor(R.color.tab_active))
    }
    
    private fun loadDailyEarnings() {
        // Filter earnings for daily view (last 7 days)
        val sevenDaysAgo = System.currentTimeMillis() - (7 * 24 * 60 * 60 * 1000)
        val dailyEarnings = earningsList.filter { it.date >= sevenDaysAgo }
        
        earningsList.clear()
        earningsList.addAll(dailyEarnings)
        earningsAdapter.notifyDataSetChanged()
        
        updateEarningsSummary()
        updatePerformanceMetrics()
    }
    
    private fun loadWeeklyEarnings() {
        // Group earnings by week
        // For now, show all data
        earningsAdapter.notifyDataSetChanged()
        
        voiceAlertManager.speak("Weekly earnings loaded")
    }
    
    private fun loadMonthlyEarnings() {
        // Group earnings by month
        // For now, show all data
        earningsAdapter.notifyDataSetChanged()
        
        voiceAlertManager.speak("Monthly earnings loaded")
    }
    
    private fun viewEarningsDetails() {
        // Navigate to detailed earnings view
        voiceAlertManager.speak("Viewing earnings details")
        
        // Implementation would navigate to detailed earnings screen
    }
    
    private fun exportEarningsReport() {
        // Export earnings data to PDF or Excel
        voiceAlertManager.speak("Exporting earnings report")
        
        // Implementation would generate and share earnings report
        Toast.makeText(requireContext(), "Earnings report exported", Toast.LENGTH_SHORT).show()
    }
    
    private fun showDateFilterDialog() {
        // Show date range picker dialog
        voiceAlertManager.speak("Select date range")
        
        // Implementation would show date picker dialog
    }
    
    private fun refreshEarningsData() {
        // Refresh earnings data from server
        voiceAlertManager.speak("Refreshing earnings data")
        
        // Implementation would reload data from API
        loadEarningsData()
    }
    
    override fun onResume() {
        super.onResume()
        
        // Refresh data when fragment resumes
        refreshEarningsData()
    }
    
    override fun onDestroyView() {
        super.onDestroyView()
        
        voiceAlertManager.cleanup()
        _binding = null
    }
    
    // Extension for dp to pixels
    private val Int.dp: Int
        get() = (this * resources.displayMetrics.density).toInt()
}

data class EarningRecord(
    val id: String,
    val date: Long,
    val amount: Double,
    val type: String, // DELIVERY, BONUS, TIP, PENALTY
    val description: String,
    val trips: Int,
    val distance: Double,
    val bonus: Double
)
