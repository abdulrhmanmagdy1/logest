package com.edham.logistics.offline.database

import android.content.Context
import androidx.room.Room
import dagger.Module
import dagger.Provides
import dagger.hilt.InstallIn
import dagger.hilt.android.qualifiers.ApplicationContext
import dagger.hilt.components.SingletonComponent
import javax.inject.Singleton

@Module
@InstallIn(SingletonComponent::class)
object DatabaseModule {

    @Provides
    @Singleton
    fun provideOfflineDatabase(
        @ApplicationContext context: Context
    ): OfflineDatabase {
        return Room.databaseBuilder(
            context,
            OfflineDatabase::class.java,
            "edham_offline_database"
        )
        .fallbackToDestructiveMigration()
        .build()
    }

    @Provides
    fun provideShipmentDao(database: OfflineDatabase): ShipmentDao {
        return database.shipmentDao()
    }

    @Provides
    fun provideDriverDao(database: OfflineDatabase): DriverDao {
        return database.driverDao()
    }

    @Provides
    fun provideVehicleDao(database: OfflineDatabase): VehicleDao {
        return database.vehicleDao()
    }

    @Provides
    fun provideLocationDao(database: OfflineDatabase): LocationDao {
        return database.locationDao()
    }

    @Provides
    fun provideSyncOperationDao(database: OfflineDatabase): SyncOperationDao {
        return database.syncOperationDao()
    }

    @Provides
    fun provideCachedMapsDataDao(database: OfflineDatabase): CachedMapsDataDao {
        return database.cachedMapsDataDao()
    }

    @Provides
    fun provideOfflineSettingsDao(database: OfflineDatabase): OfflineSettingsDao {
        return database.offlineSettingsDao()
    }
}
