package com.edham.logistics.feature.analytics.domain.model

import com.edham.logistics.domain.model.DriverStatus

// Admin Dashboard Data
data class AdminDashboardData(
    val totalShipments: Long,
    val activeShipments: Long,
    val completedShipments: Long,
    val activeDrivers: Long,
    val totalRevenue: Double,
    val monthlyRevenue: Double,
    val delayedShipments: Long,
    val delayedPercentage: Double,
    val averageDeliveryTime: Double,
    val customerSatisfaction: Double,
    val fleetUtilization: Double,
    val systemHealth: Double,
    val shipmentsByStatus: Map<String, Long>,
    val revenueByMonth: List<MonthlyRevenue>,
    val driverPerformance: List<DriverPerformance>,
    val topCustomers: List<CustomerAnalytics>,
    val recentActivities: List<ActivityLog>
)

data class MonthlyRevenue(
    val month: String,
    val revenue: Double,
    val shipments: Long,
    val growth: Double
)

data class DriverPerformance(
    val driverId: String,
    val driverName: String,
    val completedTrips: Long,
    val averageRating: Double,
    val onTimeDeliveryRate: Double,
    val totalDistance: Double,
    val fuelEfficiency: Double,
    val earnings: Double
)

data class CustomerAnalytics(
    val customerId: String,
    val customerName: String,
    val totalShipments: Long,
    val totalRevenue: Double,
    val averageRating: Double,
    val loyaltyScore: Double
)

data class ActivityLog(
    val id: String,
    val type: ActivityType,
    val description: String,
    val userId: String,
    val userName: String,
    val timestamp: Long,
    val metadata: Map<String, Any>
)

enum class ActivityType {
    SHIPMENT_CREATED,
    SHIPMENT_DELIVERED,
    DRIVER_ASSIGNED,
    PAYMENT_RECEIVED,
    SYSTEM_ALERT,
    USER_LOGIN,
    REPORT_GENERATED
}

// Customer Dashboard Data
data class CustomerDashboardData(
    val activeShipments: Long,
    val totalShipments: Long,
    val completedShipments: Long,
    val totalSpent: Double,
    val averageDeliveryTime: Double,
    val onTimeDeliveryRate: Double,
    val customerRating: Double,
    val loyaltyPoints: Long,
    val recentShipments: List<ShipmentAnalytics>,
    val shippingHistory: List<ShipmentHistory>,
    val monthlySpending: List<MonthlySpending>,
    val serviceUsage: Map<String, Long>
)

data class ShipmentAnalytics(
    val shipmentId: String,
    val shipmentNumber: String,
    val status: String,
    val pickupLocation: String,
    val deliveryLocation: String,
    val estimatedDelivery: Long,
    val actualDelivery: Long?,
    val cost: Double,
    val distance: Double,
    val driverName: String?,
    val driverRating: Double?,
    val currentLocation: String?
)

data class ShipmentHistory(
    val shipmentId: String,
    val shipmentNumber: String,
    val status: String,
    val createdDate: Long,
    val deliveredDate: Long?,
    val cost: Double,
    val rating: Double?,
    val pickupLocation: String,
    val deliveryLocation: String
)

data class MonthlySpending(
    val month: String,
    val amount: Double,
    val shipments: Long
)

// Driver Dashboard Data
data class DriverDashboardData(
    val completedTrips: Long,
    val totalTrips: Long,
    val performanceScore: Double,
    val averageRating: Double,
    val onTimeDeliveryRate: Double,
    val totalEarnings: Double,
    val monthlyEarnings: Double,
    val totalDistance: Double,
    val fuelEfficiency: Double,
    val activeHours: Double,
    val currentStatus: DriverStatus,
    val nextTrip: NextTripInfo?,
    val recentTrips: List<TripAnalytics>,
    val weeklyPerformance: List<WeeklyPerformance>,
    val earningsByMonth: List<MonthlyEarnings>
)

data class TripAnalytics(
    val tripId: String,
    val shipmentNumber: String,
    val pickupLocation: String,
    val deliveryLocation: String,
    val startTime: Long,
    val endTime: Long,
    val duration: Long,
    val distance: Double,
    val earnings: Double,
    val fuelCost: Double,
    val customerRating: Double?,
    val onTime: Boolean
)

data class WeeklyPerformance(
    val week: String,
    val trips: Long,
    val earnings: Double,
    val rating: Double,
    val onTimeRate: Double
)

data class MonthlyEarnings(
    val month: String,
    val earnings: Double,
    val trips: Long,
    val bonus: Double
)

data class NextTripInfo(
    val shipmentId: String,
    val shipmentNumber: String,
    val pickupLocation: String,
    val deliveryLocation: String,
    val estimatedStartTime: Long,
    val estimatedDuration: Long,
    val distance: Double,
    val earnings: Double
)

// DriverStatus is now imported from domain.model

// Accountant Dashboard Data
data class AccountantDashboardData(
    val totalRevenue: Double,
    val monthlyRevenue: Double,
    val totalExpenses: Double,
    val monthlyExpenses: Double,
    val netProfit: Double,
    val unpaidInvoices: Long,
    val overdueInvoices: Long,
    val totalUnpaidAmount: Double,
    val totalOverdueAmount: Double,
    val revenueByCategory: Map<String, Double>,
    val expensesByCategory: Map<String, Double>,
    val revenueByMonth: List<MonthlyRevenue>,
    val expensesByMonth: List<MonthlyExpenses>,
    val topRevenueSources: List<RevenueSource>,
    val recentTransactions: List<TransactionAnalytics>,
    val cashFlow: List<CashFlowData>
)

data class MonthlyExpenses(
    val month: String,
    val amount: Double,
    val category: String
)

data class RevenueSource(
    val source: String,
    val amount: Double,
    val percentage: Double,
    val growth: Double
)

data class TransactionAnalytics(
    val transactionId: String,
    val type: TransactionType,
    val amount: Double,
    val description: String,
    val customerId: String?,
    val customerName: String?,
    val date: Long,
    val status: String,
    val category: String
)

data class CashFlowData(
    val date: String,
    val inflow: Double,
    val outflow: Double,
    val netFlow: Double
)

enum class TransactionType {
    INCOME,
    EXPENSE,
    REFUND,
    PENALTY
}

// Common Analytics Models
data class ChartData(
    val labels: List<String>,
    val datasets: List<DataSet>
)

data class DataSet(
    val label: String,
    val data: List<Double>,
    val backgroundColor: String?,
    val borderColor: String?,
    val borderWidth: Int = 1
)

data class MetricCard(
    val title: String,
    val value: String,
    val subtitle: String?,
    val trend: Trend?,
    val icon: String,
    val color: String
)

data class Trend(
    val value: Double,
    val direction: TrendDirection,
    val period: String
)

enum class TrendDirection {
    UP,
    DOWN,
    STABLE
}

data class FilterOptions(
    val dateRange: DateRange?,
    val categories: List<String>?,
    val statuses: List<String>?,
    val users: List<String>?
)

data class DateRange(
    val startDate: Long,
    val endDate: Long
)

// Request/Response Models
data class GetDashboardDataRequest(
    val userId: String,
    val userRole: String,
    val filters: FilterOptions?
)

data class GetAnalyticsRequest(
    val userId: String,
    val userRole: String,
    val analyticsType: AnalyticsType,
    val filters: FilterOptions?,
    val limit: Int = 100
)

enum class AnalyticsType {
    ADMIN_DASHBOARD,
    CUSTOMER_DASHBOARD,
    DRIVER_DASHBOARD,
    ACCOUNTANT_DASHBOARD,
    REVENUE_ANALYTICS,
    PERFORMANCE_ANALYTICS,
    USAGE_ANALYTICS
}

// WebSocket Models for Real-time Updates
data class AnalyticsWebSocketMessage(
    val type: AnalyticsWebSocketType,
    val data: Any,
    val timestamp: Long,
    val userId: String?,
    val userRole: String?
)

enum class AnalyticsWebSocketType {
    DASHBOARD_UPDATED,
    METRIC_CHANGED,
    NEW_ACTIVITY,
    PERFORMANCE_UPDATED,
    REVENUE_UPDATED
}
