package com.edham.logistics.feature.customer.adapters

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.ImageView
import android.widget.TextView
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.feature.customer.CustomerNotification
import com.edham.logistics.feature.customer.NotificationType
import java.text.SimpleDateFormat
import java.util.*

class NotificationAdapter(
    private val onNotificationClick: (CustomerNotification) -> Unit
) : RecyclerView.Adapter<NotificationAdapter.ViewHolder>() {
    
    private var notifications = mutableListOf<CustomerNotification>()
    private val timeFormat = SimpleDateFormat("HH:mm", Locale.getDefault())
    private val dateFormat = SimpleDateFormat("MMM dd", Locale.getDefault())
    
    fun updateNotifications(newNotifications: List<CustomerNotification>) {
        notifications.clear()
        notifications.addAll(newNotifications)
        notifyDataSetChanged()
    }
    
    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): ViewHolder {
        val view = LayoutInflater.from(parent.context).inflate(R.layout.item_notification, parent, false)
        return ViewHolder(view)
    }
    
    override fun onBindViewHolder(holder: ViewHolder, position: Int) {
        holder.bind(notifications[position])
    }
    
    override fun getItemCount(): Int = notifications.size
    
    inner class ViewHolder(itemView: View) : RecyclerView.ViewHolder(itemView) {
        private val notificationIcon: ImageView = itemView.findViewById(R.id.notificationIcon)
        private val notificationTitle: TextView = itemView.findViewById(R.id.notificationTitle)
        private val notificationMessage: TextView = itemView.findViewById(R.id.notificationMessage)
        private val notificationTime: TextView = itemView.findViewById(R.id.notificationTime)
        private val unreadIndicator: View = itemView.findViewById(R.id.unreadIndicator)
        private val typeIndicator: View = itemView.findViewById(R.id.typeIndicator)
        
        fun bind(notification: CustomerNotification) {
            // Set notification icon and type indicator
            val (iconRes, colorRes) = when (notification.type) {
                NotificationType.SHIPMENT_CREATED -> Pair(R.drawable.ic_notification_shipment, R.color.notification_shipment)
                NotificationType.SHIPMENT_PICKED_UP -> Pair(R.drawable.ic_notification_pickup, R.color.notification_pickup)
                NotificationType.SHIPMENT_IN_TRANSIT -> Pair(R.drawable.ic_notification_transit, R.color.notification_transit)
                NotificationType.SHIPMENT_OUT_FOR_DELIVERY -> Pair(R.drawable.ic_notification_delivery, R.color.notification_delivery)
                NotificationType.SHIPMENT_DELIVERED -> Pair(R.drawable.ic_notification_delivered, R.color.notification_delivered)
                NotificationType.DELAY_ALERT -> Pair(R.drawable.ic_notification_delay, R.color.notification_delay)
                NotificationType.ETA_UPDATE -> Pair(R.drawable.ic_notification_eta, R.color.notification_eta)
                NotificationType.PAYMENT_DUE -> Pair(R.drawable.ic_notification_payment, R.color.notification_payment)
                NotificationType.PAYMENT_RECEIVED -> Pair(R.drawable.ic_notification_payment_received, R.color.notification_payment_received)
                NotificationType.REVIEW_REQUEST -> Pair(R.drawable.ic_notification_review, R.color.notification_review)
                NotificationType.PROMOTION -> Pair(R.drawable.ic_notification_promotion, R.color.notification_promotion)
            }
            
            notificationIcon.setImageResource(iconRes)
            notificationIcon.setColorFilter(itemView.context.getColor(colorRes))
            typeIndicator.setBackgroundColor(itemView.context.getColor(colorRes))
            
            // Set notification text
            notificationTitle.text = notification.title
            notificationMessage.text = notification.message
            
            // Set time
            val now = System.currentTimeMillis()
            val diff = now - notification.timestamp
            
            notificationTime.text = when {
                diff < 3600000 -> { // Less than 1 hour
                    val minutes = diff / 60000
                    "${minutes}m ago"
                }
                diff < 86400000 -> { // Less than 1 day
                    val hours = diff / 3600000
                    "${hours}h ago"
                }
                diff < 604800000 -> { // Less than 1 week
                    dateFormat.format(Date(notification.timestamp))
                }
                else -> {
                    dateFormat.format(Date(notification.timestamp))
                }
            }
            
            // Set unread indicator
            unreadIndicator.visibility = if (notification.isRead) View.GONE else View.VISIBLE
            
            // Set background based on read status
            val backgroundColor = if (notification.isRead) {
                itemView.context.getColor(R.color.notification_read_bg)
            } else {
                itemView.context.getColor(R.color.notification_unread_bg)
            }
            
            itemView.setBackgroundColor(backgroundColor)
            
            // Set click listener
            itemView.setOnClickListener {
                onNotificationClick(notification)
            }
        }
    }
}
