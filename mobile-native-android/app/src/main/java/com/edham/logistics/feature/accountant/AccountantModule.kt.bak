package com.edham.logistics.feature.accountant

import com.edham.logistics.feature.accountant.data.repository.AccountantRepositoryImpl
import com.edham.logistics.feature.accountant.domain.repository.AccountantRepository
import com.edham.logistics.feature.accountant.domain.usecase.GetInvoicesUseCase
import com.edham.logistics.feature.accountant.domain.usecase.CreateInvoiceUseCase
import com.edham.logistics.feature.accountant.domain.usecase.UpdateInvoiceUseCase
import com.edham.logistics.feature.accountant.domain.usecase.GetFinancialReportsUseCase
import com.edham.logistics.feature.accountant.domain.usecase.GetPaymentsUseCase
import com.edham.logistics.feature.accountant.domain.usecase.ProcessPaymentUseCase
import dagger.Binds
import dagger.Module
import dagger.hilt.InstallIn
import dagger.hilt.components.SingletonComponent
import javax.inject.Singleton

@Module
@InstallIn(SingletonComponent::class)
abstract class AccountantModule {

    @Binds
    @Singleton
    abstract fun bindAccountantRepository(
        accountantRepositoryImpl: AccountantRepositoryImpl
    ): AccountantRepository

    @Binds
    @Singleton
    abstract fun bindGetInvoicesUseCase(
        getInvoicesUseCase: GetInvoicesUseCase
    ): com.edham.logistics.feature.accountant.domain.usecase.GetInvoicesUseCase

    @Binds
    @Singleton
    abstract fun bindCreateInvoiceUseCase(
        createInvoiceUseCase: CreateInvoiceUseCase
    ): com.edham.logistics.feature.accountant.domain.usecase.CreateInvoiceUseCase

    @Binds
    @Singleton
    abstract fun bindUpdateInvoiceUseCase(
        updateInvoiceUseCase: UpdateInvoiceUseCase
    ): com.edham.logistics.feature.accountant.domain.usecase.UpdateInvoiceUseCase

    @Binds
    @Singleton
    abstract fun bindGetFinancialReportsUseCase(
        getFinancialReportsUseCase: GetFinancialReportsUseCase
    ): com.edham.logistics.feature.accountant.domain.usecase.GetFinancialReportsUseCase

    @Binds
    @Singleton
    abstract fun bindGetPaymentsUseCase(
        getPaymentsUseCase: GetPaymentsUseCase
    ): com.edham.logistics.feature.accountant.domain.usecase.GetPaymentsUseCase

    @Binds
    @Singleton
    abstract fun bindProcessPaymentUseCase(
        processPaymentUseCase: ProcessPaymentUseCase
    ): com.edham.logistics.feature.accountant.domain.usecase.ProcessPaymentUseCase
}
