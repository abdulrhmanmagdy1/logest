package com.edham.logistics.feature.driver.data.remote.mapper

import com.edham.logistics.feature.driver.domain.model.*
import com.edham.logistics.feature.driver.data.remote.dto.*
import javax.inject.Inject
import javax.inject.Singleton

@Singleton
class DriverMapper @Inject constructor() {

    fun mapToDomainDashboard(dashboardDto: DriverDashboardDto): DriverDashboardData {
        return DriverDashboardData(
            driverInfo = mapToDomainDriverInfo(dashboardDto.driverInfo),
            todayStats = mapToDomainTodayStats(dashboardDto.todayStats),
            assignedTrips = dashboardDto.assignedTrips.map { mapToDomainDriverTrip(it) },
            activeTrip = dashboardDto.activeTrip?.let { mapToDomainDriverTrip(it) },
            recentDeliveries = dashboardDto.recentDeliveries.map { mapToDomainDriverTrip(it) }
        )
    }

    fun mapToDomainDriverInfo(driverInfoDto: DriverInfoDto): DriverInfo {
        return DriverInfo(
            id = driverInfoDto.id,
            name = driverInfoDto.name,
            phone = driverInfoDto.phone,
            email = driverInfoDto.email,
            licenseNumber = driverInfoDto.licenseNumber,
            vehicleInfo = mapToDomainVehicleInfo(driverInfoDto.vehicleInfo),
            isOnline = driverInfoDto.isOnline,
            currentLocation = driverInfoDto.currentLocation?.let { mapToDomainLocationPoint(it) }
        )
    }

    fun mapToDomainVehicleInfo(vehicleInfoDto: VehicleInfoDto): VehicleInfo {
        return VehicleInfo(
            id = vehicleInfoDto.id,
            type = vehicleInfoDto.type,
            licensePlate = vehicleInfoDto.licensePlate,
            capacity = vehicleInfoDto.capacity,
            temperatureControlled = vehicleInfoDto.temperatureControlled
        )
    }

    fun mapToDomainTodayStats(todayStatsDto: TodayStatsDto): TodayStats {
        return TodayStats(
            completedTrips = todayStatsDto.completedTrips,
            totalDistance = todayStatsDto.totalDistance,
            totalEarnings = todayStatsDto.totalEarnings,
            averageRating = todayStatsDto.averageRating
        )
    }

    fun mapToDomainDriverTrip(tripDto: DriverTripDto): DriverTrip {
        return DriverTrip(
            id = tripDto.id,
            trackingNumber = tripDto.trackingNumber,
            customerName = tripDto.customerName,
            customerPhone = tripDto.customerPhone,
            pickupLocation = mapToDomainLocationPoint(tripDto.pickupLocation),
            deliveryLocation = mapToDomainLocationPoint(tripDto.deliveryLocation),
            cargoType = tripDto.cargoType,
            weight = tripDto.weight,
            priority = tripDto.priority,
            specialInstructions = tripDto.specialInstructions,
            estimatedDuration = tripDto.estimatedDuration,
            estimatedDistance = tripDto.estimatedDistance,
            price = tripDto.price,
            status = mapToDomainTripStatus(tripDto.status),
            assignedAt = tripDto.assignedAt,
            acceptedAt = tripDto.acceptedAt,
            startedAt = tripDto.startedAt,
            completedAt = tripDto.completedAt,
            deliveryProof = tripDto.deliveryProof?.let { mapToDomainDeliveryProof(it) },
            currentLocation = tripDto.currentLocation?.let { mapToDomainLocationPoint(it) },
            route = tripDto.route?.let { mapToDomainRouteInfo(it) }
        )
    }

    fun mapToDomainLocationPoint(locationDto: LocationDto): LocationPoint {
        return LocationPoint(
            latitude = locationDto.latitude,
            longitude = locationDto.longitude,
            address = locationDto.address,
            city = locationDto.city,
            timestamp = locationDto.timestamp
        )
    }

    fun mapToDomainRouteInfo(routeDto: RouteDto): RouteInfo {
        return RouteInfo(
            distance = routeDto.distance,
            duration = routeDto.duration,
            steps = routeDto.steps.map { mapToDomainRouteStep(it) }
        )
    }

    fun mapToDomainRouteStep(stepDto: RouteStepDto): RouteStep {
        return RouteStep(
            instruction = stepDto.instruction,
            distance = stepDto.distance,
            duration = stepDto.duration,
            startLocation = mapToDomainLocationPoint(stepDto.startLocation),
            endLocation = mapToDomainLocationPoint(stepDto.endLocation)
        )
    }

    fun mapToDomainDeliveryProof(proofDto: DeliveryProofDto): DeliveryProof {
        return DeliveryProof(
            id = proofDto.id,
            photoUrl = proofDto.photoUrl,
            signatureUrl = proofDto.signatureUrl,
            recipientName = proofDto.recipientName,
            recipientPhone = proofDto.recipientPhone,
            notes = proofDto.notes,
            timestamp = proofDto.timestamp,
            location = mapToDomainLocationPoint(proofDto.location)
        )
    }

    fun mapToDomainTripStatus(status: String): TripStatus {
        return when (status) {
            "ASSIGNED" -> TripStatus.ASSIGNED
            "ACCEPTED" -> TripStatus.ACCEPTED
            "REJECTED" -> TripStatus.REJECTED
            "STARTED" -> TripStatus.STARTED
            "IN_TRANSIT" -> TripStatus.IN_TRANSIT
            "ARRIVED" -> TripStatus.ARRIVED
            "DELIVERED" -> TripStatus.DELIVERED
            "CANCELLED" -> TripStatus.CANCELLED
            else -> TripStatus.ASSIGNED
        }
    }

    // Reverse mappings for requests
    fun mapToDtoTripAction(request: TripActionRequest): TripActionDto {
        return TripActionDto(
            tripId = request.tripId,
            action = request.action.name,
            notes = request.notes
        )
    }

    fun mapToDtoTripUpdate(request: TripUpdateRequest): TripUpdateDto {
        return TripUpdateDto(
            tripId = request.tripId,
            status = request.status.name,
            location = request.location?.let { mapToDtoLocation(it) },
            notes = request.notes,
            deliveryProof = request.deliveryProof?.let { mapToDtoDeliveryProof(it) }
        )
    }

    fun mapToDtoDeliveryProof(request: DeliveryProofRequest): DeliveryProofDto {
        return DeliveryProofDto(
            id = "", // Will be generated by server
            photoUrl = request.photoBase64, // In real app, this would be uploaded first
            signatureUrl = request.signatureBase64, // In real app, this would be uploaded first
            recipientName = request.recipientName,
            recipientPhone = request.recipientPhone,
            notes = request.notes,
            timestamp = "", // Will be set by server
            location = mapToDtoLocation(request.location)
        )
    }

    fun mapToDtoLocation(location: LocationPoint): LocationDto {
        return LocationDto(
            latitude = location.latitude,
            longitude = location.longitude,
            address = location.address,
            city = location.city,
            timestamp = location.timestamp
        )
    }

    fun mapToDtoLocation(location: com.edham.logistics.feature.driver.domain.model.DriverLocation): DriverLocationDto {
        return DriverLocationDto(
            driverId = location.driverId,
            latitude = location.latitude,
            longitude = location.longitude,
            timestamp = location.timestamp
        )
    }

    fun mapToDomainProfile(profileDto: DriverProfileDto): com.edham.logistics.feature.driver.domain.model.DriverProfile {
        return com.edham.logistics.feature.driver.domain.model.DriverProfile(
            id = profileDto.id,
            name = profileDto.name,
            phone = profileDto.phone,
            email = profileDto.email,
            licenseNumber = profileDto.licenseNumber,
            vehicleInfo = mapToDomainVehicleInfo(profileDto.vehicleInfo),
            isOnline = profileDto.isOnline
        )
    }

    fun mapToDtoProfile(profile: com.edham.logistics.feature.driver.domain.model.DriverProfile): DriverProfileDto {
        return DriverProfileDto(
            id = profile.id,
            name = profile.name,
            phone = profile.phone,
            email = profile.email,
            licenseNumber = profile.licenseNumber,
            vehicleInfo = VehicleInfoDto(
                id = profile.vehicleInfo.id,
                type = profile.vehicleInfo.type,
                licensePlate = profile.vehicleInfo.licensePlate,
                capacity = profile.vehicleInfo.capacity,
                temperatureControlled = profile.vehicleInfo.temperatureControlled
            ),
            isOnline = profile.isOnline
        )
    }

    fun mapToDomainShipmentSummary(shipmentDto: ShipmentSummaryDto): com.edham.logistics.feature.driver.domain.model.ShipmentSummary {
        return com.edham.logistics.feature.driver.domain.model.ShipmentSummary(
            id = shipmentDto.id,
            trackingNumber = shipmentDto.trackingNumber,
            customerName = shipmentDto.customerName,
            pickupLocation = shipmentDto.pickupLocation,
            deliveryLocation = shipmentDto.deliveryLocation,
            status = shipmentDto.status,
            assignedAt = shipmentDto.assignedAt,
            price = shipmentDto.price
        )
    }
}
