package com.edham.logistics.feature.ai.adapters

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.ImageView
import android.widget.TextView
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.feature.ai.ETAPrediction
import com.edham.logistics.feature.ai.DelayPrediction
import com.edham.logistics.feature.ai.RouteOptimization
import com.edham.logistics.feature.ai.MaintenancePrediction
import com.edham.logistics.feature.ai.DemandForecast
import java.text.SimpleDateFormat
import java.util.*

class PredictionAdapter(
    private val onPredictionClick: (Any) -> Unit
) : RecyclerView.Adapter<PredictionAdapter.ViewHolder>() {
    
    private var predictions = mutableListOf<Any>()
    private val timeFormat = SimpleDateFormat("HH:mm", Locale.getDefault())
    
    fun updatePredictions(newPredictions: List<Any>) {
        predictions.clear()
        predictions.addAll(newPredictions)
        notifyDataSetChanged()
    }
    
    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): ViewHolder {
        val view = LayoutInflater.from(parent.context).inflate(R.layout.item_prediction, parent, false)
        return ViewHolder(view)
    }
    
    override fun onBindViewHolder(holder: ViewHolder, position: Int) {
        holder.bind(predictions[position])
    }
    
    override fun getItemCount(): Int = predictions.size
    
    inner class ViewHolder(itemView: View) : RecyclerView.ViewHolder(itemView) {
        private val predictionIcon: ImageView = itemView.findViewById(R.id.predictionIcon)
        private val predictionType: TextView = itemView.findViewById(R.id.predictionType)
        private val predictionTitle: TextView = itemView.findViewById(R.id.predictionTitle)
        private val predictionValue: TextView = itemView.findViewById(R.id.predictionValue)
        private val predictionConfidence: TextView = itemView.findViewById(R.id.predictionConfidence)
        private val predictionTime: TextView = itemView.findViewById(R.id.predictionTime)
        private val predictionStatus: TextView = itemView.findViewById(R.id.predictionStatus)
        private val typeIndicator: View = itemView.findViewById(R.id.typeIndicator)
        
        fun bind(prediction: Any) {
            when (prediction) {
                is ETAPrediction -> bindETAPrediction(prediction)
                is DelayPrediction -> bindDelayPrediction(prediction)
                is RouteOptimization -> bindRouteOptimization(prediction)
                is MaintenancePrediction -> bindMaintenancePrediction(prediction)
                is DemandForecast -> bindDemandForecast(prediction)
            }
            
            // Set click listener
            itemView.setOnClickListener {
                onPredictionClick(prediction)
            }
        }
        
        private fun bindETAPrediction(prediction: ETAPrediction) {
            val (iconRes, typeText, colorRes) = when {
                prediction.confidence > 0.8 -> Triple(R.drawable.ic_eta_high, "ETA", R.color.prediction_high)
                prediction.confidence > 0.6 -> Triple(R.drawable.ic_eta_medium, "ETA", R.color.prediction_medium)
                else -> Triple(R.drawable.ic_eta_low, "ETA", R.color.prediction_low)
            }
            
            predictionIcon.setImageResource(iconRes)
            predictionIcon.setColorFilter(itemView.context.getColor(colorRes))
            predictionType.text = typeText
            predictionTitle.text = "Shipment ${prediction.shipmentId}"
            predictionValue.text = timeFormat.format(Date(prediction.predictedETA))
            predictionConfidence.text = "${(prediction.confidence * 100).toInt()}%"
            predictionTime.text = timeFormat.format(Date(prediction.timestamp))
            predictionStatus.text = "Active"
            typeIndicator.setBackgroundColor(itemView.context.getColor(colorRes))
            
            // Set background color
            itemView.setBackgroundColor(itemView.context.getColor(R.color.prediction_eta_bg))
        }
        
        private fun bindDelayPrediction(prediction: DelayPrediction) {
            val (iconRes, typeText, colorRes) = when {
                prediction.delayRisk > 0.8 -> Triple(R.drawable.ic_delay_high, "DELAY", R.color.prediction_high)
                prediction.delayRisk > 0.5 -> Triple(R.drawable.ic_delay_medium, "DELAY", R.color.prediction_medium)
                else -> Triple(R.drawable.ic_delay_low, "DELAY", R.color.prediction_low)
            }
            
            predictionIcon.setImageResource(iconRes)
            predictionIcon.setColorFilter(itemView.context.getColor(colorRes))
            predictionType.text = typeText
            predictionTitle.text = "Shipment ${prediction.shipmentId}"
            predictionValue.text = "${prediction.predictedDelayMinutes} min"
            predictionConfidence.text = "${(prediction.delayRisk * 100).toInt()}% risk"
            predictionTime.text = timeFormat.format(Date(prediction.timestamp))
            predictionStatus.text = if (prediction.delayPrevented) "Prevented" else "Risk"
            typeIndicator.setBackgroundColor(itemView.context.getColor(colorRes))
            
            // Set background color
            itemView.setBackgroundColor(itemView.context.getColor(R.color.prediction_delay_bg))
        }
        
        private fun bindRouteOptimization(optimization: RouteOptimization) {
            val (iconRes, typeText, colorRes) = when {
                optimization.potentialSavings > 20.0 -> Triple(R.drawable.ic_route_high, "ROUTE", R.color.prediction_high)
                optimization.potentialSavings > 10.0 -> Triple(R.drawable.ic_route_medium, "ROUTE", R.color.prediction_medium)
                else -> Triple(R.drawable.ic_route_low, "ROUTE", R.color.prediction_low)
            }
            
            predictionIcon.setImageResource(iconRes)
            predictionIcon.setColorFilter(itemView.context.getColor(colorRes))
            predictionType.text = typeText
            predictionTitle.text = "Shipment ${optimization.shipmentId}"
            predictionValue.text = "${optimization.potentialSavings.toInt()}% save"
            predictionConfidence.text = "${optimization.timeReduction} min"
            predictionTime.text = timeFormat.format(Date(optimization.timestamp))
            predictionStatus.text = "Optimized"
            typeIndicator.setBackgroundColor(itemView.context.getColor(colorRes))
            
            // Set background color
            itemView.setBackgroundColor(itemView.context.getColor(R.color.prediction_route_bg))
        }
        
        private fun bindMaintenancePrediction(prediction: MaintenancePrediction) {
            val (iconRes, typeText, colorRes) = when {
                prediction.maintenanceUrgency > 0.8 -> Triple(R.drawable.ic_maintenance_high, "MAINT", R.color.prediction_high)
                prediction.maintenanceUrgency > 0.5 -> Triple(R.drawable.ic_maintenance_medium, "MAINT", R.color.prediction_medium)
                else -> Triple(R.drawable.ic_maintenance_low, "MAINT", R.color.prediction_low)
            }
            
            predictionIcon.setImageResource(iconRes)
            predictionIcon.setColorFilter(itemView.context.getColor(colorRes))
            predictionType.text = typeText
            predictionTitle.text = "Vehicle ${prediction.vehicleId}"
            predictionValue.text = "${prediction.daysUntilMaintenance} days"
            predictionConfidence.text = "$${prediction.estimatedCost.toInt()}"
            predictionTime.text = timeFormat.format(Date(prediction.timestamp))
            predictionStatus.text = prediction.maintenanceType
            typeIndicator.setBackgroundColor(itemView.context.getColor(colorRes))
            
            // Set background color
            itemView.setBackgroundColor(itemView.context.getColor(R.color.prediction_maintenance_bg))
        }
        
        private fun bindDemandForecast(forecast: DemandForecast) {
            val (iconRes, typeText, colorRes) = when {
                forecast.demandSpike > 1.5 -> Triple(R.drawable.ic_demand_high, "DEMAND", R.color.prediction_high)
                forecast.demandSpike > 1.2 -> Triple(R.drawable.ic_demand_medium, "DEMAND", R.color.prediction_medium)
                else -> Triple(R.drawable.ic_demand_low, "DEMAND", R.color.prediction_low)
            }
            
            predictionIcon.setImageResource(iconRes)
            predictionIcon.setColorFilter(itemView.context.getColor(colorRes))
            predictionType.text = typeText
            predictionTitle.text = forecast.period
            predictionValue.text = "${forecast.predictedDemand} units"
            predictionConfidence.text = "${forecast.demandSpike}x spike"
            predictionTime.text = timeFormat.format(Date(forecast.timestamp))
            predictionStatus.text = "${(forecast.accuracy * 100).toInt()}% acc"
            typeIndicator.setBackgroundColor(itemView.context.getColor(colorRes))
            
            // Set background color
            itemView.setBackgroundColor(itemView.context.getColor(R.color.prediction_demand_bg))
        }
    }
}
