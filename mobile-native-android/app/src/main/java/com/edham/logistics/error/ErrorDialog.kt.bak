package com.edham.logistics.error

import androidx.compose.foundation.layout.*
import androidx.compose.foundation.rememberScrollState
import androidx.compose.foundation.verticalScroll
import androidx.compose.material.icons.Icons
import androidx.compose.material.icons.filled.*
import androidx.compose.material3.*
import androidx.compose.runtime.*
import androidx.compose.ui.Alignment
import androidx.compose.ui.Modifier
import androidx.compose.ui.graphics.Color
import androidx.compose.ui.graphics.vector.ImageVector
import androidx.compose.ui.res.stringResource
import androidx.compose.ui.text.font.FontWeight
import androidx.compose.ui.text.style.TextAlign
import androidx.compose.ui.unit.dp
import androidx.compose.ui.window.Dialog
import androidx.compose.ui.window.DialogProperties

/**
 * Error Dialog Component
 * User-friendly error dialog with helpful actions and suggestions
 */
@OptIn(ExperimentalMaterial3Api::class)
@Composable
fun ErrorDialog(
    errorResult: ErrorResult,
    onDismiss: () -> Unit,
    onRetry: (() -> Unit)? = null,
    onRefresh: (() -> Unit)? = null,
    onLogin: (() -> Unit)? = null,
    onContactSupport: (() -> Unit)? = null
) {
    Dialog(
        onDismissRequest = onDismiss,
        properties = DialogProperties(
            dismissOnBackPress = true,
            dismissOnClickOutside = true
        )
    ) {
        Card(
            modifier = Modifier
                .fillMaxWidth()
                .padding(16.dp),
            elevation = CardDefaults.cardElevation(defaultElevation = 8.dp)
        ) {
            Column(
                modifier = Modifier
                    .fillMaxWidth()
                    .padding(24.dp)
                    .verticalScroll(rememberScrollState()),
                horizontalAlignment = Alignment.CenterHorizontally
            ) {
                // Error Icon
                Icon(
                    imageVector = getErrorIcon(errorResult.type),
                    contentDescription = null,
                    modifier = Modifier.size(64.dp),
                    tint = getErrorColor(errorResult.type)
                )
                
                Spacer(modifier = Modifier.height(16.dp))
                
                // Error Title
                Text(
                    text = errorResult.title,
                    style = MaterialTheme.typography.headlineSmall,
                    fontWeight = FontWeight.Bold,
                    textAlign = TextAlign.Center,
                    color = MaterialTheme.colorScheme.onSurface
                )
                
                Spacer(modifier = Modifier.height(8.dp))
                
                // Error Message
                Text(
                    text = errorResult.message,
                    style = MaterialTheme.typography.bodyMedium,
                    textAlign = TextAlign.Center,
                    color = MaterialTheme.colorScheme.onSurfaceVariant
                )
                
                // Helpful Suggestion
                getSuggestion(errorResult.type)?.let { suggestion ->
                    Spacer(modifier = Modifier.height(16.dp))
                    
                    Card(
                        colors = CardDefaults.cardColors(
                            containerColor = MaterialTheme.colorScheme.surfaceVariant
                        )
                    ) {
                        Row(
                            modifier = Modifier
                                .fillMaxWidth()
                                .padding(12.dp),
                            verticalAlignment = Alignment.CenterVertically
                        ) {
                            Icon(
                                imageVector = Icons.Default.Lightbulb,
                                contentDescription = null,
                                modifier = Modifier.size(20.dp),
                                tint = MaterialTheme.colorScheme.primary
                            )
                            
                            Spacer(modifier = Modifier.width(8.dp))
                            
                            Text(
                                text = suggestion,
                                style = MaterialTheme.typography.bodySmall,
                                color = MaterialTheme.colorScheme.onSurfaceVariant
                            )
                        }
                    }
                }
                
                Spacer(modifier = Modifier.height(24.dp))
                
                // Action Buttons
                Column(
                    modifier = Modifier.fillMaxWidth(),
                    verticalArrangement = Arrangement.spacedBy(8.dp)
                ) {
                    // Primary Action
                    when (errorResult.userAction) {
                        UserAction.RETRY, UserAction.REFRESH -> {
                            Button(
                                onClick = {
                                    onRetry?.invoke() ?: onRefresh?.invoke()
                                    onDismiss()
                                },
                                modifier = Modifier.fillMaxWidth()
                            ) {
                                Icon(
                                    imageVector = Icons.Default.Refresh,
                                    contentDescription = null,
                                    modifier = Modifier.size(18.dp)
                                )
                                Spacer(modifier = Modifier.width(8.dp))
                                Text(stringResource(getActionText(errorResult.userAction)))
                            }
                        }
                        
                        UserAction.LOGIN_AGAIN -> {
                            Button(
                                onClick = {
                                    onLogin?.invoke()
                                    onDismiss()
                                },
                                modifier = Modifier.fillMaxWidth()
                            ) {
                                Icon(
                                    imageVector = Icons.Default.Login,
                                    contentDescription = null,
                                    modifier = Modifier.size(18.dp)
                                )
                                Spacer(modifier = Modifier.width(8.dp))
                                Text(stringResource(getActionText(errorResult.userAction)))
                            }
                        }
                        
                        UserAction.CONTACT_SUPPORT -> {
                            Button(
                                onClick = {
                                    onContactSupport?.invoke()
                                    onDismiss()
                                },
                                modifier = Modifier.fillMaxWidth()
                            ) {
                                Icon(
                                    imageVector = Icons.Default.Support,
                                    contentDescription = null,
                                    modifier = Modifier.size(18.dp)
                                )
                                Spacer(modifier = Modifier.width(8.dp))
                                Text(stringResource(getActionText(errorResult.userAction)))
                            }
                        }
                        
                        UserAction.CHECK_CONNECTION -> {
                            Button(
                                onClick = {
                                    onDismiss()
                                },
                                modifier = Modifier.fillMaxWidth()
                            ) {
                                Icon(
                                    imageVector = Icons.Default.Wifi,
                                    contentDescription = null,
                                    modifier = Modifier.size(18.dp)
                                )
                                Spacer(modifier = Modifier.width(8.dp))
                                Text(stringResource(getActionText(errorResult.userAction)))
                            }
                        }
                        
                        UserAction.CHECK_INPUT -> {
                            Button(
                                onClick = {
                                    onDismiss()
                                },
                                modifier = Modifier.fillMaxWidth()
                            ) {
                                Icon(
                                    imageVector = Icons.Default.Edit,
                                    contentDescription = null,
                                    modifier = Modifier.size(18.dp)
                                )
                                Spacer(modifier = Modifier.width(8.dp))
                                Text(stringResource(getActionText(errorResult.userAction)))
                            }
                        }
                        
                        UserAction.WAIT_AND_RETRY -> {
                            Button(
                                onClick = {
                                    onRetry?.invoke()
                                    onDismiss()
                                },
                                modifier = Modifier.fillMaxWidth()
                            ) {
                                Icon(
                                    imageVector = Icons.Default.Schedule,
                                    contentDescription = null,
                                    modifier = Modifier.size(18.dp)
                                )
                                Spacer(modifier = Modifier.width(8.dp))
                                Text(stringResource(getActionText(errorResult.userAction)))
                            }
                        }
                    }
                    
                    // Secondary Action - Dismiss
                    OutlinedButton(
                        onClick = onDismiss,
                        modifier = Modifier.fillMaxWidth()
                    ) {
                        Text(stringResource(R.string.action_dismiss))
                    }
                }
            }
        }
    }
}

/**
 * Get error icon based on error type
 */
private fun getErrorIcon(errorType: ErrorType): ImageVector {
    return when (errorType) {
        ErrorType.NETWORK_ERROR -> Icons.Default.WifiOff
        ErrorType.TIMEOUT_ERROR -> Icons.Default.Schedule
        ErrorType.SERVER_ERROR -> Icons.Default.CloudOff
        ErrorType.AUTHENTICATION_ERROR -> Icons.Default.Lock
        ErrorType.AUTHORIZATION_ERROR -> Icons.Default.NoAccounts
        ErrorType.VALIDATION_ERROR -> Icons.Default.Error
        ErrorType.NOT_FOUND_ERROR -> Icons.Default.SearchOff
        ErrorType.RATE_LIMIT_ERROR -> Icons.Default.Speed
        ErrorType.SSL_ERROR -> Icons.Default.Security
        ErrorType.HOST_ERROR -> Icons.Default.Dns
        ErrorType.UNKNOWN_ERROR -> Icons.Default.ErrorOutline
    }
}

/**
 * Get error color based on error type
 */
private fun getErrorColor(errorType: ErrorType): Color {
    return when (errorType) {
        ErrorType.NETWORK_ERROR, ErrorType.TIMEOUT_ERROR, ErrorType.HOST_ERROR -> Color(0xFFFF9800)
        ErrorType.SERVER_ERROR, ErrorType.UNKNOWN_ERROR -> Color(0xFFF44336)
        ErrorType.AUTHENTICATION_ERROR, ErrorType.AUTHORIZATION_ERROR -> Color(0xFFE91E63)
        ErrorType.VALIDATION_ERROR -> Color(0xFF9C27B0)
        ErrorType.NOT_FOUND_ERROR -> Color(0xFF607D8B)
        ErrorType.RATE_LIMIT_ERROR -> Color(0xFFFF5722)
        ErrorType.SSL_ERROR -> Color(0xFF795548)
    }
}

/**
 * Get helpful suggestion based on error type
 */
private fun getSuggestion(errorType: ErrorType): String? {
    return when (errorType) {
        ErrorType.NETWORK_ERROR -> "تأكد من أن الواي فاي أو بيانات الهاتف تعمل بشكل جيد"
        ErrorType.TIMEOUT_ERROR -> "الاستجابة بطيئة حالياً. حاول مرة أخرى بعد ثوانٍ"
        ErrorType.SERVER_ERROR -> "الخادم مشغول حالياً. حاول مرة أخرى بعد دقائق"
        ErrorType.AUTHENTICATION_ERROR -> "سجل الدخول مرة أخرى لتحديث جلساتك"
        ErrorType.AUTHORIZATION_ERROR -> "هذه الميزة غير متاحة لحسابك الحالي"
        ErrorType.VALIDATION_ERROR -> "تأكد من إدخال جميع الحقول المطلوبة بشكل صحيح"
        ErrorType.NOT_FOUND_ERROR -> "هذه البيانات غير موجودة أو تم حذفها"
        ErrorType.RATE_LIMIT_ERROR -> "أنت تسرع كثيراً! خذ استراحة قصيرة ثم حاول مرة أخرى"
        ErrorType.SSL_ERROR -> "مشكلة أمنية مؤقتة. جرب فتح التطبيق مرة أخرى"
        ErrorType.HOST_ERROR -> "لا يمكن الوصول للخادم. تأكد من أن الإنترنت يعمل"
        ErrorType.UNKNOWN_ERROR -> "أعد تشغيل التطبيق إذا استمرت المشكلة"
    }
}

/**
 * Get action text resource ID
 */
private fun getActionText(userAction: UserAction): Int {
    return when (userAction) {
        UserAction.RETRY -> R.string.action_retry
        UserAction.REFRESH -> R.string.action_refresh
        UserAction.LOGIN_AGAIN -> R.string.action_login_again
        UserAction.CONTACT_SUPPORT -> R.string.action_contact_support
        UserAction.CHECK_CONNECTION -> R.string.action_check_connection
        UserAction.CHECK_INPUT -> R.string.action_check_input
        UserAction.WAIT_AND_RETRY -> R.string.action_wait_and_retry
    }
}

/**
 * Simple Error Dialog for non-critical errors
 */
@Composable
fun SimpleErrorDialog(
    title: String,
    message: String,
    onDismiss: () -> Unit,
    onRetry: (() -> Unit)? = null
) {
    AlertDialog(
        onDismissRequest = onDismiss,
        title = {
            Text(
                text = title,
                style = MaterialTheme.typography.titleLarge
            )
        },
        text = {
            Text(
                text = message,
                style = MaterialTheme.typography.bodyMedium
            )
        },
        confirmButton = {
            TextButton(onClick = onDismiss) {
                Text(stringResource(R.string.action_dismiss))
            }
        },
        dismissButton = onRetry?.let {
            {
                TextButton(onClick = {
                    it()
                    onDismiss()
                }) {
                    Text(stringResource(R.string.action_retry))
                }
            }
        },
        icon = {
            Icon(
                imageVector = Icons.Default.Error,
                contentDescription = null,
                tint = MaterialTheme.colorScheme.error
            )
        }
    )
}
