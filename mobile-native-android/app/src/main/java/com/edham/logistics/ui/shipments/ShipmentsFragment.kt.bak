package com.edham.logistics.ui.shipments

import android.os.Bundle
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.TextView
import androidx.fragment.app.Fragment
import androidx.recyclerview.widget.LinearLayoutManager
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.adapters.ShipmentManagementAdapter
import com.edham.logistics.domain.model.Shipment

class ShipmentsFragment : Fragment() {

    private lateinit var rvShipments: RecyclerView
    private var tvTotalShipments: TextView? = null
    private var tvActiveShipments: TextView? = null
    private var tvDeliveredShipments: TextView? = null
    private lateinit var shipmentAdapter: ShipmentManagementAdapter

    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View? {
        return inflater.inflate(R.layout.fragment_shipments, container, false)
    }

    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        
        initViews(view)
        setupRecyclerView()
        loadShipmentData()
    }

    private fun initViews(view: View) {
        rvShipments = view.findViewById(R.id.rv_shipments)
        tvTotalShipments = null // TextView not present in layout
        tvActiveShipments = null // TextView not present in layout
        tvDeliveredShipments = null // TextView not present in layout
    }

    private fun setupRecyclerView() {
        shipmentAdapter = ShipmentManagementAdapter(getSampleShipments()) { shipment ->
            // Handle shipment click
            // TODO: Navigate to shipment details
        }
        
        rvShipments.apply {
            layoutManager = LinearLayoutManager(requireContext())
            adapter = shipmentAdapter
        }
    }

    private fun loadShipmentData() {
        val shipments = getSampleShipments()
        shipmentAdapter.updateShipments(shipments)
    }

