package com.edham.logistics.presentation.ui.base

import android.os.Bundle
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import androidx.fragment.app.Fragment
import androidx.lifecycle.Lifecycle
import androidx.lifecycle.lifecycleScope
import androidx.lifecycle.repeatOnLifecycle
import com.edham.logistics.core.extensions.gone
import com.edham.logistics.core.extensions.visible
import kotlinx.coroutines.flow.Flow
import kotlinx.coroutines.launch

abstract class BaseFragment : Fragment() {

    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        setupView()
        observeData()
        setupListeners()
    }

    protected open fun setupView() {
        // Override in child fragments
    }

    protected open fun observeData() {
        // Override in child fragments
    }

    protected open fun setupListeners() {
        // Override in child fragments
    }

    protected fun <T> Flow<T>.collectWithLifecycle(
        onCollect: (T) -> Unit
    ) {
        viewLifecycleOwner.lifecycleScope.launch {
            repeatOnLifecycle(Lifecycle.State.STARTED) {
                collect { onCollect(it) }
            }
        }
    }

    protected fun showLoading(progressBar: View, content: View) {
        progressBar.visible()
        content.gone()
    }

    protected fun hideLoading(progressBar: View, content: View) {
        progressBar.gone()
        content.visible()
    }

    protected fun showError(
        errorView: View,
        contentView: View,
        message: String? = null
    ) {
        errorView.visible()
        contentView.gone()
        // Set error message if available
    }

    protected fun hideError(errorView: View, contentView: View) {
        errorView.gone()
        contentView.visible()
    }

    protected fun showEmpty(emptyView: View, contentView: View) {
        emptyView.visible()
        contentView.gone()
    }

    protected fun hideEmpty(emptyView: View, contentView: View) {
        emptyView.gone()
        contentView.visible()
    }

    protected fun showContent(contentView: View) {
        contentView.visible()
    }

    override fun onDestroyView() {
        super.onDestroyView()
        onDetachView()
    }

    protected open fun onDetachView() {
        // Override in child fragments for cleanup
    }
}
