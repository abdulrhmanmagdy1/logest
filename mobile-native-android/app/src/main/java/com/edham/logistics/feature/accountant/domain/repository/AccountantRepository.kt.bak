package com.edham.logistics.feature.accountant.domain.repository

import com.edham.logistics.core.utils.Result
import com.edham.logistics.feature.accountant.domain.model.*
import kotlinx.coroutines.flow.Flow

interface AccountantRepository {
    // Dashboard
    suspend fun getDashboardData(): Flow<Result<AccountantDashboardData>>
    
    // Invoices
    suspend fun getInvoices(
        page: Int = 1,
        pageSize: Int = 20,
        status: String? = null,
        customerId: String? = null,
        search: String? = null
    ): Flow<Result<List<Invoice>>>
    
    suspend fun getInvoiceDetails(invoiceId: String): Result<Invoice>
    
    suspend fun createInvoice(request: CreateInvoiceRequest): Result<Invoice>
    
    suspend fun updateInvoice(request: UpdateInvoiceRequest): Result<Invoice>
    
    suspend fun deleteInvoice(invoiceId: String): Result<Unit>
    
    // Payments
    suspend fun getPayments(
        page: Int = 1,
        pageSize: Int = 20,
        status: String? = null,
        paymentMethod: String? = null,
        customerId: String? = null,
        search: String? = null
    ): Flow<Result<List<Payment>>>
    
    suspend fun getPaymentDetails(paymentId: String): Result<Payment>
    
    suspend fun recordPayment(request: CreatePaymentRequest): Result<Payment>
    
    suspend fun updatePayment(paymentId: String, status: PaymentStatus): Result<Payment>
    
    suspend fun refundPayment(paymentId: String, reason: String): Result<Payment>
    
    // Debts
    suspend fun getDebts(
        page: Int = 1,
        pageSize: Int = 20,
        status: String? = null,
        customerId: String? = null,
        isOverdue: Boolean? = null
    ): Flow<Result<List<Debt>>>
    
    suspend fun getDebtDetails(debtId: String): Result<Debt>
    
    suspend fun createPaymentPlan(request: CreatePaymentPlanRequest): Result<PaymentPlan>
    
    suspend fun updatePaymentPlan(planId: String, status: PaymentPlanStatus): Result<PaymentPlan>
    
    suspend fun recordInstallmentPayment(planId: String, installmentId: String, amount: Double): Result<Installment>
    
    // Reports
    suspend fun generateReport(request: GenerateReportRequest): Result<FinancialReport>
    
    suspend fun getRevenueReport(startDate: String, endDate: String): Result<RevenueReport>
    
    suspend fun getDebtReport(startDate: String, endDate: String): Result<DebtReport>
    
    suspend fun getPaymentReport(startDate: String, endDate: String): Result<PaymentReport>
    
    suspend fun downloadReport(reportId: String, format: ReportFormat): Result<String> // Returns file path
    
    // Analytics
    suspend fun getRevenueOverview(period: String): Result<RevenueOverview>
    
    suspend fun getPaymentStats(period: String): Result<PaymentStats>
    
    suspend fun getMonthlyRevenue(year: Int): Flow<Result<List<MonthlyRevenue>>>
    
    suspend fun getTopCustomers(period: String, limit: Int = 10): Result<List<CustomerRevenue>>
    
    suspend fun getRevenueByService(period: String): Result<List<ServiceRevenue>>
}
