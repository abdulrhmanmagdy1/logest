package com.edham.logistics.core.production

import android.content.Context
import android.util.Log
import com.edham.logistics.BuildConfig
import dagger.hilt.android.qualifiers.ApplicationContext
import javax.inject.Inject
import javax.inject.Singleton

/**
 * Build Optimizer
 * Handles build performance optimizations and app size reduction
 */
@Singleton
class BuildOptimizer @Inject constructor(
    @ApplicationContext private val context: Context,
    private val productionConfig: ProductionConfig
) {
    
    companion object {
        private const val TAG = "BuildOptimizer"
        
        // Build optimization settings
        const val ENABLE_PROGUARD = true
        const val ENABLE_SHRINK_RESOURCES = true
        const val ENABLE_CODE_SHRINKING = true
        const val ENABLE_RESOURCE_SHRINKING = true
        const val ENABLE_R8_FULL_MODE = true
        
        // App size optimization
        const val ENABLE_VECTOR_DRAWABLES = true
        const val ENABLE_WEBP_FORMAT = true
        const val ENABLE_DYNAMIC_FEATURE_MODULES = false
        const val ENABLE_APP_BUNDLE = true
        
        // Build performance
        const val ENABLE_INCREMENTAL_BUILD = true
        const val ENABLE_BUILD_CACHE = true
        const val ENABLE_PARALLEL_EXECUTION = true
        const val ENABLE_DAEMON_BUILD = true
        
        // Native libraries optimization
        const val ENABLE_ABI_SPLITTING = true
        const val ENABLE_NATIVE_DEBUG_SYMBOLS = false
        const val ENABLE_NATIVE_LIBS_COMPRESSION = true
        
        // APK optimization
        const val ENABLE_APK_COMPRESSION = true
        const val ENABLE_APK_OPTIMIZATION = true
        const val ENABLE_APK_SIGNING_V2 = true
        const val ENABLE_APK_SIGNING_V3 = true
    }
    
    /**
     * Initialize build optimizations
     */
    fun initializeBuildOptimizations() {
        if (productionConfig.isProductionMode()) {
            setupProGuard()
            setupResourceOptimization()
            setupNativeLibrariesOptimization()
            setupAPKOptimization()
            Log.i(TAG, "Build optimizations initialized")
        }
    }
    
    /**
     * Setup ProGuard configuration
     */
    private fun setupProGuard() {
        if (ENABLE_PROGUARD) {
            Log.i(TAG, "ProGuard enabled with full mode optimization")
            
            // ProGuard rules are applied in proguard-rules.pro
            // - Keep all model classes with @Keep annotation
            // - Keep all API interfaces and DTOs
            // - Keep all Firebase classes
            // - Keep all Hilt injection points
            // - Optimize and obfuscate all other code
        }
    }
    
    /**
     * Setup resource optimization
     */
    private fun setupResourceOptimization() {
        if (ENABLE_SHRINK_RESOURCES) {
            Log.i(TAG, "Resource shrinking enabled")
            
            // Unused resources will be removed
            // Vector drawables will be used where possible
            // WebP format will be used for images
            // Duplicate resources will be merged
        }
        
        if (ENABLE_RESOURCE_SHRINKING) {
            Log.i(TAG, "Resource shrinking with analysis enabled")
        }
    }
    
    /**
     * Setup native libraries optimization
     */
    private fun setupNativeLibrariesOptimization() {
        if (ENABLE_ABI_SPLITTING) {
            Log.i(TAG, "ABI splitting enabled for native libraries")
            
            // Separate APKs for different architectures
            // arm64-v8a, armeabi-v7a, x86, x86_64
        }
        
        if (ENABLE_NATIVE_LIBS_COMPRESSION) {
            Log.i(TAG, "Native libraries compression enabled")
        }
        
        if (!ENABLE_NATIVE_DEBUG_SYMBOLS) {
            Log.i(TAG, "Native debug symbols removed for production")
        }
    }
    
    /**
     * Setup APK optimization
     */
    private fun setupAPKOptimization() {
        if (ENABLE_APK_COMPRESSION) {
            Log.i(TAG, "APK compression enabled")
        }
        
        if (ENABLE_APK_OPTIMIZATION) {
            Log.i(TAG, "APK optimization enabled")
        }
        
        if (ENABLE_APK_SIGNING_V2 && ENABLE_APK_SIGNING_V3) {
            Log.i(TAG, "APK signing v2 and v3 enabled")
        }
    }
    
    /**
     * Get build configuration recommendations
     */
    fun getBuildRecommendations(): List<String> {
        val recommendations = mutableListOf<String>()
        
        if (!ENABLE_PROGUARD) {
            recommendations.add("Enable ProGuard for code obfuscation and optimization")
        }
        
        if (!ENABLE_SHRINK_RESOURCES) {
            recommendations.add("Enable resource shrinking to reduce APK size")
        }
        
        if (!ENABLE_ABI_SPLITTING) {
            recommendations.add("Enable ABI splitting for optimized APK delivery")
        }
        
        if (!ENABLE_APP_BUNDLE) {
            recommendations.add("Use Android App Bundle for optimized delivery")
        }
        
        return recommendations
    }
    
    /**
     * Analyze APK size
     */
    fun analyzeAPKSize(): Map<String, Any> {
        return try {
            val packageInfo = context.packageManager.getPackageInfo(context.packageName, 0)
            val apkPath = packageInfo.applicationInfo.sourceDir
            val apkFile = java.io.File(apkPath)
            val apkSizeBytes = apkFile.length()
            val apkSizeMB = apkSizeBytes / (1024.0 * 1024.0)
            
            mapOf(
                "apkSizeBytes" to apkSizeBytes,
                "apkSizeMB" to String.format("%.2f", apkSizeMB),
                "apkPath" to apkPath,
                "isOptimized" to apkSizeMB < 50.0, // Target under 50MB
                "recommendations" to if (apkSizeMB > 50.0) {
                    listOf("Consider enabling additional optimizations")
                } else {
                    emptyList<String>()
                }
            )
        } catch (e: Exception) {
            Log.e(TAG, "Failed to analyze APK size", e)
            mapOf("error" to "Failed to analyze APK size")
        }
    }
    
    /**
     * Get build performance metrics
     */
    fun getBuildPerformanceMetrics(): Map<String, Any> {
        return mapOf(
            "incrementalBuild" to ENABLE_INCREMENTAL_BUILD,
            "buildCache" to ENABLE_BUILD_CACHE,
            "parallelExecution" to ENABLE_PARALLEL_EXECUTION,
            "daemonBuild" to ENABLE_DAEMON_BUILD,
            "proGuardEnabled" to ENABLE_PROGUARD,
            "codeShrinking" to ENABLE_CODE_SHRINKING,
            "resourceShrinking" to ENABLE_RESOURCE_SHRINKING,
            "r8FullMode" to ENABLE_R8_FULL_MODE
        )
    }
    
    /**
     * Get app bundle configuration
     */
    fun getAppBundleConfig(): Map<String, Any> {
        return mapOf(
            "enabled" to ENABLE_APP_BUNDLE,
            "dynamicFeatures" to ENABLE_DYNAMIC_FEATURE_MODULES,
            "splitApks" to ENABLE_ABI_SPLITTING,
            "compression" to ENABLE_APK_COMPRESSION,
            "optimization" to ENABLE_APK_OPTIMIZATION
        )
    }
    
    /**
     * Validate build configuration
     */
    fun validateBuildConfiguration(): List<String> {
        val issues = mutableListOf<String>()
        
        if (productionConfig.isProductionMode()) {
            if (!ENABLE_PROGUARD) {
                issues.add("ProGuard should be enabled in production")
            }
            
            if (!ENABLE_SHRINK_RESOURCES) {
                issues.add("Resource shrinking should be enabled in production")
            }
            
            if (!ENABLE_CODE_SHRINKING) {
                issues.add("Code shrinking should be enabled in production")
            }
            
            if (!ENABLE_APK_SIGNING_V2) {
                issues.add("APK signing v2 should be enabled in production")
            }
            
            if (!ENABLE_APK_SIGNING_V3) {
                issues.add("APK signing v3 should be enabled in production")
            }
            
            if (ENABLE_NATIVE_DEBUG_SYMBOLS) {
                issues.add("Native debug symbols should be disabled in production")
            }
        }
        
        return issues
    }
    
    /**
     * Get optimization summary
     */
    fun getOptimizationSummary(): Map<String, Any> {
        return mapOf(
            "proGuard" to mapOf(
                "enabled" to ENABLE_PROGUARD,
                "codeShrinking" to ENABLE_CODE_SHRINKING,
                "r8FullMode" to ENABLE_R8_FULL_MODE
            ),
            "resources" to mapOf(
                "shrinking" to ENABLE_SHRINK_RESOURCES,
                "resourceShrinking" to ENABLE_RESOURCE_SHRINKING,
                "vectorDrawables" to ENABLE_VECTOR_DRAWABLES,
                "webpFormat" to ENABLE_WEBP_FORMAT
            ),
            "nativeLibs" to mapOf(
                "abiSplitting" to ENABLE_ABI_SPLITTING,
                "compression" to ENABLE_NATIVE_LIBS_COMPRESSION,
                "debugSymbols" to ENABLE_NATIVE_DEBUG_SYMBOLS
            ),
            "apk" to mapOf(
                "compression" to ENABLE_APK_COMPRESSION,
                "optimization" to ENABLE_APK_OPTIMIZATION,
                "signingV2" to ENABLE_APK_SIGNING_V2,
                "signingV3" to ENABLE_APK_SIGNING_V3
            ),
            "buildPerformance" to mapOf(
                "incremental" to ENABLE_INCREMENTAL_BUILD,
                "cache" to ENABLE_BUILD_CACHE,
                "parallel" to ENABLE_PARALLEL_EXECUTION,
                "daemon" to ENABLE_DAEMON_BUILD
            )
        )
    }
    
    /**
     * Check if build is optimized
     */
    fun isBuildOptimized(): Boolean {
        return productionConfig.isProductionMode() && 
               ENABLE_PROGUARD && 
               ENABLE_SHRINK_RESOURCES && 
               ENABLE_CODE_SHRINKING &&
               ENABLE_APK_SIGNING_V2 &&
               ENABLE_APK_SIGNING_V3 &&
               !ENABLE_NATIVE_DEBUG_SYMBOLS
    }
    
    /**
     * Get optimization recommendations
     */
    fun getOptimizationRecommendations(): List<String> {
        val recommendations = mutableListOf<String>()
        
        if (!ENABLE_PROGUARD) {
            recommendations.add("Enable ProGuard for code obfuscation and size reduction")
        }
        
        if (!ENABLE_SHRINK_RESOURCES) {
            recommendations.add("Enable resource shrinking to remove unused resources")
        }
        
        if (!ENABLE_ABI_SPLITTING) {
            recommendations.add("Enable ABI splitting for optimized native library delivery")
        }
        
        if (!ENABLE_APP_BUNDLE) {
            recommendations.add("Use Android App Bundle for optimized Play Store delivery")
        }
        
        if (!ENABLE_APK_COMPRESSION) {
            recommendations.add("Enable APK compression to reduce download size")
        }
        
        return recommendations
    }
}
