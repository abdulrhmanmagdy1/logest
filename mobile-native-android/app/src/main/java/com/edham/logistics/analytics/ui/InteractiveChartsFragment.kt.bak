package com.edham.logistics.analytics.ui

import android.os.Bundle
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import androidx.compose.foundation.layout.*
import androidx.compose.foundation.lazy.LazyColumn
import androidx.compose.foundation.lazy.LazyRow
import androidx.compose.foundation.lazy.items
import androidx.compose.foundation.shape.RoundedCornerShape
import androidx.compose.material3.*
import androidx.compose.runtime.*
import androidx.compose.ui.Alignment
import androidx.compose.ui.Modifier
import androidx.compose.ui.draw.clip
import androidx.compose.ui.graphics.Color
import androidx.compose.ui.text.font.FontWeight
import androidx.compose.ui.text.style.TextAlign
import androidx.compose.ui.unit.dp
import androidx.compose.ui.unit.sp
import androidx.fragment.app.Fragment
import androidx.fragment.app.viewModels
import androidx.lifecycle.compose.collectAsStateWithLifecycle
import com.edham.logistics.analytics.AnalyticsEngineService
import com.edham.logistics.ui.theme.*
import dagger.hilt.android.AndroidEntryPoint
import kotlinx.coroutines.launch
import javax.inject.Inject

/**
 * Interactive Charts Fragment - Comprehensive interactive charts and visualizations
 * 
 * Features:
 * - Multiple chart types (Line, Bar, Pie, Area, Scatter)
 * - Real-time data updates
 * - Interactive tooltips and legends
 * - Chart customization options
 * - Export functionality
 * - Responsive design
 * - Touch gestures support
 * - Animation effects
 */
@AndroidEntryPoint
class InteractiveChartsFragment : Fragment() {
    
    @Inject
    lateinit var analyticsEngineService: AnalyticsEngineService
    
    private val viewModel: InteractiveChartsViewModel by viewModels()
    
    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View {
        return ComposeView(requireContext()).apply {
            setContent {
                EdhamLogisticsTheme {
                    InteractiveChartsScreen(
                        viewModel = viewModel,
                        analyticsEngineService = analyticsEngineService
                    )
                }
            }
        }
    }
    
    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        
        // Initialize analytics engine
        lifecycleScope.launch {
            analyticsEngineService.initialize()
        }
        
        // Load chart data
        viewModel.loadChartData()
    }
}

@Composable
fun InteractiveChartsScreen(
    viewModel: InteractiveChartsViewModel,
    analyticsEngineService: AnalyticsEngineService
) {
    val chartData by viewModel.chartData.collectAsStateWithLifecycle()
    val selectedChartType by viewModel.selectedChartType.collectAsStateWithLifecycle()
    val isLoading by viewModel.isLoading.collectAsStateWithLifecycle()
    val errorMessage by viewModel.errorMessage.collectAsStateWithLifecycle()
    val selectedTimeRange by viewModel.selectedTimeRange.collectAsStateWithLifecycle()
    
    LaunchedEffect(selectedTimeRange, selectedChartType) {
        viewModel.loadChartData()
    }
    
    Column(
        modifier = Modifier
            .fillMaxSize()
            .padding(16.dp),
        verticalArrangement = Arrangement.spacedBy(16.dp)
    ) {
        // Header with chart type selector
        ChartsHeader(
            selectedChartType = selectedChartType,
            onChartTypeChanged = viewModel::setChartType,
            selectedTimeRange = selectedTimeRange,
            onTimeRangeChanged = viewModel::setTimeRange,
            onRefresh = viewModel::refreshCharts,
            isLoading = isLoading
        )
        
        // Error message
        errorMessage?.let { error ->
            Card(
                modifier = Modifier.fillMaxWidth(),
                colors = CardDefaults.cardColors(
                    containerColor = ErrorRed.copy(alpha = 0.1f)
                ),
                elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
            ) {
                Text(
                    text = error,
                    modifier = Modifier.padding(16.dp),
                    color = ErrorRed,
                    style = MaterialTheme.typography.bodyMedium
                )
            }
        }
        
        // Chart Content
        chartData?.let { data ->
            // Main Chart Display
            MainChartSection(
                chartType = selectedChartType,
                data = data,
                onChartInteraction = viewModel::handleChartInteraction
            )
            
            // Chart Controls
            ChartControlsSection(
                chartType = selectedChartType,
                data = data,
                onControlAction = viewModel::handleControlAction
            )
            
            // Chart Statistics
            ChartStatisticsSection(data = data)
            
            // Related Charts
            RelatedChartsSection(
                currentChartType = selectedChartType,
                data = data,
                onChartSelected = viewModel::setChartType
            )
        }
        
        // Loading indicator
        if (isLoading) {
            Box(
                modifier = Modifier.fillMaxWidth(),
                contentAlignment = Alignment.Center
            ) {
                CircularProgressIndicator(
                    color = EdhamOrange,
                    strokeWidth = 3.dp
                )
            }
        }
    }
}

@Composable
fun ChartsHeader(
    selectedChartType: ChartType,
    onChartTypeChanged: (ChartType) -> Unit,
    selectedTimeRange: TimeRange,
    onTimeRangeChanged: (TimeRange) -> Unit,
    onRefresh: () -> Unit,
    isLoading: Boolean
) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.surface
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Text(
                text = "Interactive Charts",
                style = MaterialTheme.typography.headlineMedium,
                color = EdhamOrange,
                fontWeight = FontWeight.Bold
            )
            
            Spacer(modifier = Modifier.height(16.dp))
            
            // Chart type selector
            LazyRow(
                horizontalArrangement = Arrangement.spacedBy(8.dp)
            ) {
                items(ChartType.values()) { chartType ->
                    FilterChip(
                        selected = selectedChartType == chartType,
                        onClick = { onChartTypeChanged(chartType) },
                        label = {
                            Text(
                                text = chartType.displayName,
                                style = MaterialTheme.typography.bodyMedium
                            )
                        },
                        colors = FilterChipDefaults.filterChipColors(
                            selectedContainerColor = EdhamOrange,
                            selectedLabelColor = Color.White
                        )
                    )
                }
            }
            
            Spacer(modifier = Modifier.height(12.dp))
            
            Row(
                modifier = Modifier.fillMaxWidth(),
                horizontalArrangement = Arrangement.SpaceBetween,
                verticalAlignment = Alignment.CenterVertically
            ) {
                // Time range selector
                TimeRangeSelector(
                    selectedTimeRange = selectedTimeRange,
                    onTimeRangeChanged = onTimeRangeChanged
                )
                
                // Refresh button
                IconButton(
                    onClick = onRefresh,
                    enabled = !isLoading
                ) {
                    Icon(
                        painter = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_rotate),
                        contentDescription = "Refresh",
                        tint = EdhamOrange
                    )
                }
            }
        }
    }
}

@Composable
fun MainChartSection(
    chartType: ChartType,
    data: ChartData,
    onChartInteraction: (ChartInteraction) -> Unit
) {
    Card(
        modifier = Modifier
            .fillMaxWidth()
            .height(400.dp),
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.surface
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier
                .fillMaxSize()
                .padding(16.dp)
        ) {
            // Chart title and actions
            Row(
                modifier = Modifier.fillMaxWidth(),
                horizontalArrangement = Arrangement.SpaceBetween,
                verticalAlignment = Alignment.CenterVertically
            ) {
                Text(
                    text = "${chartType.displayName} Chart",
                    style = MaterialTheme.typography.titleMedium,
                    color = EdhamOrange,
                    fontWeight = FontWeight.Bold
                )
                
                Row {
                    IconButton(
                        onClick = { onChartInteraction(ChartInteraction.Export) }
                    ) {
                        Icon(
                            painter = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_save),
                            contentDescription = "Export",
                            tint = EdhamOrange
                        )
                    }
                    
                    IconButton(
                        onClick = { onChartInteraction(ChartInteraction.Fullscreen) }
                    ) {
                        Icon(
                            painter = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_zoom),
                            contentDescription = "Fullscreen",
                            tint = EdhamOrange
                        )
                    }
                }
            }
            
            Spacer(modifier = Modifier.height(16.dp))
            
            // Chart display area
            Box(
                modifier = Modifier
                    .fillMaxWidth()
                    .weight(1f)
                    .clip(RoundedCornerShape(8.dp))
                    .background(MaterialTheme.colorScheme.surfaceVariant),
                contentAlignment = Alignment.Center
            ) {
                Column(
                    horizontalAlignment = Alignment.CenterHorizontally
                ) {
                    Icon(
                        painter = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_gallery),
                        contentDescription = "Chart",
                        tint = MaterialTheme.colorScheme.onSurfaceVariant,
                        modifier = Modifier.size(64.dp)
                    )
                    
                    Spacer(modifier = Modifier.height(16.dp))
                    
                    Text(
                        text = "${chartType.displayName} Visualization",
                        style = MaterialTheme.typography.titleMedium,
                        color = MaterialTheme.colorScheme.onSurfaceVariant
                    )
                    
                    Text(
                        text = "Interactive ${chartType.displayName.lowercase()} chart",
                        style = MaterialTheme.typography.bodyMedium,
                        color = MaterialTheme.colorScheme.onSurfaceVariant.copy(alpha = 0.8f)
                    )
                    
                    Spacer(modifier = Modifier.height(8.dp))
                    
                    Text(
                        text = "${data.dataPoints.size} data points",
                        style = MaterialTheme.typography.bodySmall,
                        color = MaterialTheme.colorScheme.onSurfaceVariant.copy(alpha = 0.6f)
                    )
                    
                    Spacer(modifier = Modifier.height(16.dp))
                    
                    // Interactive elements placeholder
                    Row(
                        horizontalArrangement = Arrangement.spacedBy(8.dp)
                    ) {
                        Button(
                            onClick = { onChartInteraction(ChartInteraction.ZoomIn) },
                            colors = ButtonDefaults.buttonColors(
                                containerColor = EdhamOrange
                            )
                        ) {
                            Text("Zoom In")
                        }
                        
                        Button(
                            onClick = { onChartInteraction(ChartInteraction.ZoomOut) },
                            colors = ButtonDefaults.buttonColors(
                                containerColor = EdhamOrange
                            )
                        ) {
                            Text("Zoom Out")
                        }
                        
                        Button(
                            onClick = { onChartInteraction(ChartInteraction.Reset) },
                            colors = ButtonDefaults.buttonColors(
                                containerColor = IceBlue
                            )
                        ) {
                            Text("Reset")
                        }
                    }
                }
            }
        }
    }
}

@Composable
fun ChartControlsSection(
    chartType: ChartType,
    data: ChartData,
    onControlAction: (ChartControlAction) -> Unit
) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.surface
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Text(
                text = "Chart Controls",
                style = MaterialTheme.typography.titleMedium,
                color = EdhamOrange,
                fontWeight = FontWeight.Bold
            )
            
            Spacer(modifier = Modifier.height(16.dp))
            
            LazyColumn(
                verticalArrangement = Arrangement.spacedBy(12.dp)
            ) {
                item {
                    ChartControlRow(
                        title = "Animation",
                        value = "Enabled",
                        onAction = { onControlAction(ChartControlAction.ToggleAnimation) }
                    )
                }
                
                item {
                    ChartControlRow(
                        title = "Grid Lines",
                        value = "Show",
                        onAction = { onControlAction(ChartControlAction.ToggleGrid) }
                    )
                }
                
                item {
                    ChartControlRow(
                        title = "Legend",
                        value = "Visible",
                        onAction = { onControlAction(ChartControlAction.ToggleLegend) }
                    )
                }
                
                item {
                    ChartControlRow(
                        title = "Data Labels",
                        value = "Auto",
                        onAction = { onControlAction(ChartControlAction.ToggleLabels) }
                    )
                }
                
                item {
                    ChartControlRow(
                        title = "Smooth Lines",
                        value = "Enabled",
                        onAction = { onControlAction(ChartControlAction.ToggleSmoothing) }
                    )
                }
            }
        }
    }
}

@Composable
fun ChartControlRow(
    title: String,
    value: String,
    onAction: () -> Unit
) {
    Row(
        modifier = Modifier.fillMaxWidth(),
        horizontalArrangement = Arrangement.SpaceBetween,
        verticalAlignment = Alignment.CenterVertically
    ) {
        Text(
            text = title,
            style = MaterialTheme.typography.bodyMedium,
            color = MaterialTheme.colorScheme.onSurface
        )
        
        OutlinedButton(
            onClick = onAction,
            colors = ButtonDefaults.outlinedButtonColors(
                contentColor = EdhamOrange,
                borderColor = EdhamOrange
            )
        ) {
            Text(
                text = value,
                style = MaterialTheme.typography.bodySmall
            )
        }
    }
}

@Composable
fun ChartStatisticsSection(data: ChartData) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.surface
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Text(
                text = "Chart Statistics",
                style = MaterialTheme.typography.titleMedium,
                color = EdhamOrange,
                fontWeight = FontWeight.Bold
            )
            
            Spacer(modifier = Modifier.height(16.dp))
            
            LazyColumn(
                verticalArrangement = Arrangement.spacedBy(8.dp)
            ) {
                item {
                    StatisticRow(
                        title = "Data Points",
                        value = data.dataPoints.size.toString()
                    )
                }
                
                item {
                    StatisticRow(
                        title = "Minimum Value",
                        value = String.format("%.2f", data.minValue)
                    )
                }
                
                item {
                    StatisticRow(
                        title = "Maximum Value",
                        value = String.format("%.2f", data.maxValue)
                    )
                }
                
                item {
                    StatisticRow(
                        title = "Average Value",
                        value = String.format("%.2f", data.averageValue)
                    )
                }
                
                item {
                    StatisticRow(
                        title = "Trend Direction",
                        value = data.trendDirection
                    )
                }
                
                item {
                    StatisticRow(
                        title = "Last Updated",
                        value = data.lastUpdated
                    )
                }
            }
        }
    }
}

@Composable
fun StatisticRow(
    title: String,
    value: String
) {
    Row(
        modifier = Modifier.fillMaxWidth(),
        horizontalArrangement = Arrangement.SpaceBetween,
        verticalAlignment = Alignment.CenterVertically
    ) {
        Text(
            text = title,
            style = MaterialTheme.typography.bodyMedium,
            color = MaterialTheme.colorScheme.onSurface
        )
        
        Text(
            text = value,
            style = MaterialTheme.typography.bodyMedium,
            color = EdhamOrange,
            fontWeight = FontWeight.Medium
        )
    }
}

@Composable
fun RelatedChartsSection(
    currentChartType: ChartType,
    data: ChartData,
    onChartSelected: (ChartType) -> Unit
) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.surface
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Text(
                text = "Related Charts",
                style = MaterialTheme.typography.titleMedium,
                color = EdhamOrange,
                fontWeight = FontWeight.Bold
            )
            
            Spacer(modifier = Modifier.height(16.dp))
            
            LazyColumn(
                verticalArrangement = Arrangement.spacedBy(8.dp)
            ) {
                items(getRelatedCharts(currentChartType)) { chartType ->
                    RelatedChartItem(
                        chartType = chartType,
                        isSelected = chartType == currentChartType,
                        onSelected = onChartSelected
                    )
                }
            }
        }
    }
}

@Composable
fun RelatedChartItem(
    chartType: ChartType,
    isSelected: Boolean,
    onSelected: (ChartType) -> Unit
) {
    Card(
        modifier = Modifier
            .fillMaxWidth()
            .clip(RoundedCornerShape(8.dp)),
        colors = CardDefaults.cardColors(
            containerColor = if (isSelected) EdhamOrange.copy(alpha = 0.1f) 
                            else MaterialTheme.colorScheme.surfaceVariant
        ),
        elevation = CardDefaults.cardElevation(
            defaultElevation = if (isSelected) 2.dp else 1.dp
        )
    ) {
        Row(
            modifier = Modifier
                .fillMaxWidth()
                .padding(12.dp)
                .clickable { onSelected(chartType) },
            horizontalArrangement = Arrangement.SpaceBetween,
            verticalAlignment = Alignment.CenterVertically
        ) {
            Row(
                verticalAlignment = Alignment.CenterVertically
            ) {
                Icon(
                    painter = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_gallery),
                    contentDescription = null,
                    tint = if (isSelected) EdhamOrange else MaterialTheme.colorScheme.onSurfaceVariant,
                    modifier = Modifier.size(24.dp)
                )
                
                Spacer(modifier = Modifier.width(12.dp))
                
                Column {
                    Text(
                        text = chartType.displayName,
                        style = MaterialTheme.typography.bodyMedium,
                        color = if (isSelected) EdhamOrange else MaterialTheme.colorScheme.onSurface,
                        fontWeight = if (isSelected) FontWeight.Bold else FontWeight.Normal
                    )
                    
                    Text(
                        text = chartType.description,
                        style = MaterialTheme.typography.bodySmall,
                        color = MaterialTheme.colorScheme.onSurface.copy(alpha = 0.7f)
                    )
                }
            }
            
            if (isSelected) {
                Icon(
                    painter = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_info_details),
                    contentDescription = "Selected",
                    tint = EdhamOrange,
                    modifier = Modifier.size(20.dp)
                )
            }
        }
    }
}

// Helper functions
private fun getRelatedCharts(currentChartType: ChartType): List<ChartType> {
    return ChartType.values().filter { it != currentChartType }
}

// Data classes and enums
enum class ChartType(val displayName: String, val description: String) {
    LINE("Line Chart", "Shows trends over time"),
    BAR("Bar Chart", "Compares values across categories"),
    PIE("Pie Chart", "Shows proportion of whole"),
    AREA("Area Chart", "Shows volume over time"),
    SCATTER("Scatter Plot", "Shows correlation between variables"),
    DONUT("Donut Chart", "Shows proportion with center focus"),
    RADAR("Radar Chart", "Shows multiple dimensions"),
    HEATMAP("Heat Map", "Shows intensity across grid")
}

enum class ChartInteraction {
    Export,
    Fullscreen,
    ZoomIn,
    ZoomOut,
    Reset,
    Pan,
    Select
}

enum class ChartControlAction {
    ToggleAnimation,
    ToggleGrid,
    ToggleLegend,
    ToggleLabels,
    ToggleSmoothing,
    ChangeColors,
    ExportData,
    ShareChart
}

data class ChartData(
    val dataPoints: List<DataPoint>,
    val minValue: Double,
    val maxValue: Double,
    val averageValue: Double,
    val trendDirection: String,
    val lastUpdated: String
)

data class DataPoint(
    val x: Double,
    val y: Double,
    val label: String,
    val color: Color
)
