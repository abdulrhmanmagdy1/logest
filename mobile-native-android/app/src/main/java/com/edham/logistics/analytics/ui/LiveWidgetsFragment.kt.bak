package com.edham.logistics.analytics.ui

import android.os.Bundle
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import androidx.compose.foundation.layout.*
import androidx.compose.foundation.lazy.LazyColumn
import androidx.compose.foundation.lazy.LazyRow
import androidx.compose.foundation.lazy.items
import androidx.compose.foundation.shape.RoundedCornerShape
import androidx.compose.material3.*
import androidx.compose.runtime.*
import androidx.compose.ui.Alignment
import androidx.compose.ui.Modifier
import androidx.compose.ui.draw.clip
import androidx.compose.ui.graphics.Color
import androidx.compose.ui.text.font.FontWeight
import androidx.compose.ui.text.style.TextAlign
import androidx.compose.ui.unit.dp
import androidx.compose.ui.unit.sp
import androidx.fragment.app.Fragment
import androidx.fragment.app.viewModels
import androidx.lifecycle.compose.collectAsStateWithLifecycle
import com.edham.logistics.analytics.AnalyticsEngineService
import com.edham.logistics.ui.theme.*
import dagger.hilt.android.AndroidEntryPoint
import kotlinx.coroutines.launch
import javax.inject.Inject

/**
 * Live Widgets Fragment - Real-time widgets and dashboard components
 * 
 * Features:
 * - Real-time KPI widgets
 * - Live status indicators
 * - Mini charts and graphs
 * - Alert widgets
 * - Performance meters
 * - Activity feeds
 * - Quick stats
 * - Customizable widget layouts
 */
@AndroidEntryPoint
class LiveWidgetsFragment : Fragment() {
    
    @Inject
    lateinit var analyticsEngineService: AnalyticsEngineService
    
    private val viewModel: LiveWidgetsViewModel by viewModels()
    
    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View {
        return ComposeView(requireContext()).apply {
            setContent {
                EdhamLogisticsTheme {
                    LiveWidgetsScreen(
                        viewModel = viewModel,
                        analyticsEngineService = analyticsEngineService
                    )
                }
            }
        }
    }
    
    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        
        // Initialize analytics engine
        lifecycleScope.launch {
            analyticsEngineService.initialize()
        }
        
        // Start live widget updates
        viewModel.startLiveUpdates()
    }
    
    override fun onDestroyView() {
        super.onDestroyView()
        viewModel.stopLiveUpdates()
    }
}

@Composable
fun LiveWidgetsScreen(
    viewModel: LiveWidgetsViewModel,
    analyticsEngineService: AnalyticsEngineService
) {
    val widgets by viewModel.widgets.collectAsStateWithLifecycle()
    val isLoading by viewModel.isLoading.collectAsStateWithLifecycle()
    val errorMessage by viewModel.errorMessage.collectAsStateWithLifecycle()
    val isLiveMode by viewModel.isLiveMode.collectAsStateWithLifecycle()
    
    LaunchedEffect(Unit) {
        viewModel.loadWidgets()
    }
    
    Column(
        modifier = Modifier
            .fillMaxSize()
            .padding(16.dp),
        verticalArrangement = Arrangement.spacedBy(16.dp)
    ) {
        // Header
        WidgetsHeader(
            isLiveMode = isLiveMode,
            onToggleLiveMode = viewModel::toggleLiveMode,
            onRefresh = viewModel::refreshWidgets,
            isLoading = isLoading
        )
        
        // Error message
        errorMessage?.let { error ->
            Card(
                modifier = Modifier.fillMaxWidth(),
                colors = CardDefaults.cardColors(
                    containerColor = ErrorRed.copy(alpha = 0.1f)
                ),
                elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
            ) {
                Text(
                    text = error,
                    modifier = Modifier.padding(16.dp),
                    color = ErrorRed,
                    style = MaterialTheme.typography.bodyMedium
                )
            }
        }
        
        // Live Widgets Grid
        LazyColumn(
            verticalArrangement = Arrangement.spacedBy(16.dp)
        ) {
            // KPI Widgets Row
            item {
                LazyRow(
                    horizontalArrangement = Arrangement.spacedBy(12.dp)
                ) {
                    items(widgets.kpiWidgets.take(3)) { widget ->
                        KPIWidget(
                            widget = widget,
                            isLiveMode = isLiveMode
                        )
                    }
                }
            }
            
            // Status Widgets Row
            item {
                LazyRow(
                    horizontalArrangement = Arrangement.spacedBy(12.dp)
                ) {
                    items(widgets.statusWidgets.take(2)) { widget ->
                        StatusWidget(
                            widget = widget,
                            isLiveMode = isLiveMode
                        )
                    }
                }
            }
            
            // Chart Widgets Row
            item {
                LazyRow(
                    horizontalArrangement = Arrangement.spacedBy(12.dp)
                ) {
                    items(widgets.chartWidgets.take(2)) { widget ->
                        ChartWidget(
                            widget = widget,
                            isLiveMode = isLiveMode
                        )
                    }
                }
            }
            
            // Alert Widget
            item {
                AlertWidget(
                    widget = widgets.alertWidget,
                    isLiveMode = isLiveMode
                )
            }
            
            // Activity Feed Widget
            item {
                ActivityFeedWidget(
                    widget = widgets.activityFeedWidget,
                    isLiveMode = isLiveMode
                )
            }
            
            // Performance Meters
            item {
                LazyRow(
                    horizontalArrangement = Arrangement.spacedBy(12.dp)
                ) {
                    items(widgets.performanceMeters.take(3)) { widget ->
                        PerformanceMeterWidget(
                            widget = widget,
                            isLiveMode = isLiveMode
                        )
                    }
                }
            }
            
            // Quick Stats
            item {
                LazyRow(
                    horizontalArrangement = Arrangement.spacedBy(12.dp)
                ) {
                    items(widgets.quickStats.take(4)) { widget ->
                        QuickStatWidget(
                            widget = widget,
                            isLiveMode = isLiveMode
                        )
                    }
                }
            }
        }
        
        // Loading indicator
        if (isLoading) {
            Box(
                modifier = Modifier.fillMaxWidth(),
                contentAlignment = Alignment.Center
            ) {
                CircularProgressIndicator(
                    color = EdhamOrange,
                    strokeWidth = 3.dp
                )
            }
        }
    }
}

@Composable
fun WidgetsHeader(
    isLiveMode: Boolean,
    onToggleLiveMode: () -> Unit,
    onRefresh: () -> Unit,
    isLoading: Boolean
) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.surface
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Row(
                modifier = Modifier.fillMaxWidth(),
                horizontalArrangement = Arrangement.SpaceBetween,
                verticalAlignment = Alignment.CenterVertically
            ) {
                Text(
                    text = "Live Widgets",
                    style = MaterialTheme.typography.headlineMedium,
                    color = EdhamOrange,
                    fontWeight = FontWeight.Bold
                )
                
                Row {
                    // Live mode toggle
                    FilterChip(
                        selected = isLiveMode,
                        onClick = onToggleLiveMode,
                        label = {
                            Row(
                                verticalAlignment = Alignment.CenterVertically
                            ) {
                                if (isLiveMode) {
                                    Box(
                                        modifier = Modifier
                                            .size(8.dp)
                                            .background(
                                                color = SuccessGreen,
                                                shape = androidx.compose.foundation.shape.CircleShape
                                            )
                                    )
                                    Spacer(modifier = Modifier.width(8.dp))
                                }
                                Text(
                                    text = if (isLiveMode) "LIVE" else "OFFLINE",
                                    style = MaterialTheme.typography.bodySmall,
                                    fontWeight = FontWeight.Bold
                                )
                            }
                        },
                        colors = FilterChipDefaults.filterChipColors(
                            selectedContainerColor = if (isLiveMode) SuccessGreen else ErrorRed,
                            selectedLabelColor = Color.White
                        )
                    )
                    
                    Spacer(modifier = Modifier.width(8.dp))
                    
                    // Refresh button
                    IconButton(
                        onClick = onRefresh,
                        enabled = !isLoading
                    ) {
                        Icon(
                            painter = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_rotate),
                            contentDescription = "Refresh",
                            tint = EdhamOrange
                        )
                    }
                }
            }
        }
    }
}

@Composable
fun KPIWidget(
    widget: KPIWidgetData,
    isLiveMode: Boolean
) {
    Card(
        modifier = Modifier
            .width(200.dp)
            .height(120.dp),
        colors = CardDefaults.cardColors(
            containerColor = widget.color.copy(alpha = 0.1f)
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier
                .fillMaxSize()
                .padding(12.dp),
            verticalArrangement = Arrangement.SpaceBetween
        ) {
            Row(
                verticalAlignment = Alignment.CenterVertically
            ) {
                Icon(
                    painter = widget.icon,
                    contentDescription = null,
                    tint = widget.color,
                    modifier = Modifier.size(24.dp)
                )
                
                Spacer(modifier = Modifier.width(8.dp))
                
                if (isLiveMode) {
                    Box(
                        modifier = Modifier
                            .size(8.dp)
                            .background(
                                color = SuccessGreen,
                                shape = androidx.compose.foundation.shape.CircleShape
                            )
                    )
                }
            }
            
            Column {
                Text(
                    text = widget.title,
                    style = MaterialTheme.typography.bodySmall,
                    color = MaterialTheme.colorScheme.onSurface.copy(alpha = 0.7f),
                    maxLines = 1
                )
                
                Text(
                    text = widget.value,
                    style = MaterialTheme.typography.titleLarge,
                    color = widget.color,
                    fontWeight = FontWeight.Bold,
                    maxLines = 1
                )
                
                if (widget.change != 0.0) {
                    Row(
                        verticalAlignment = Alignment.CenterVertically
                    ) {
                        Icon(
                            painter = androidx.compose.ui.res.painterResource(
                                id = if (widget.change > 0) android.R.drawable.arrow_up_float 
                                else android.R.drawable.arrow_down_float
                            ),
                            contentDescription = null,
                            tint = if (widget.change > 0) SuccessGreen else ErrorRed,
                            modifier = Modifier.size(16.dp)
                        )
                        
                        Spacer(modifier = Modifier.width(4.dp))
                        
                        Text(
                            text = "${String.format("%.1f", kotlin.math.abs(widget.change))}%",
                            style = MaterialTheme.typography.bodySmall,
                            color = if (widget.change > 0) SuccessGreen else ErrorRed,
                            fontWeight = FontWeight.Medium
                        )
                    }
                }
            }
        }
    }
}

@Composable
fun StatusWidget(
    widget: StatusWidgetData,
    isLiveMode: Boolean
) {
    Card(
        modifier = Modifier
            .width(300.dp)
            .height(100.dp),
        colors = CardDefaults.cardColors(
            containerColor = widget.statusColor.copy(alpha = 0.1f)
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Row(
            modifier = Modifier
                .fillMaxSize()
                .padding(16.dp),
            verticalAlignment = Alignment.CenterVertically
        ) {
            Box(
                modifier = Modifier
                    .size(48.dp)
                    .background(
                        color = widget.statusColor.copy(alpha = 0.2f),
                        shape = androidx.compose.foundation.shape.CircleShape
                    ),
                contentAlignment = Alignment.Center
            ) {
                Icon(
                    painter = widget.icon,
                    contentDescription = null,
                    tint = widget.statusColor,
                    modifier = Modifier.size(24.dp)
                )
            }
            
            Spacer(modifier = Modifier.width(16.dp))
            
            Column(modifier = Modifier.weight(1f)) {
                Text(
                    text = widget.title,
                    style = MaterialTheme.typography.titleMedium,
                    color = widget.statusColor,
                    fontWeight = FontWeight.Bold
                )
                
                Text(
                    text = widget.description,
                    style = MaterialTheme.typography.bodyMedium,
                    color = MaterialTheme.colorScheme.onSurface.copy(alpha = 0.8f)
                )
                
                if (isLiveMode) {
                    Text(
                        text = "Live",
                        style = MaterialTheme.typography.bodySmall,
                        color = SuccessGreen,
                        fontWeight = FontWeight.Medium
                    )
                }
            }
        }
    }
}

@Composable
fun ChartWidget(
    widget: ChartWidgetData,
    isLiveMode: Boolean
) {
    Card(
        modifier = Modifier
            .width(250.dp)
            .height(150.dp),
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.surface
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier
                .fillMaxSize()
                .padding(12.dp)
        ) {
            Row(
                modifier = Modifier.fillMaxWidth(),
                horizontalArrangement = Arrangement.SpaceBetween,
                verticalAlignment = Alignment.CenterVertically
            ) {
                Text(
                    text = widget.title,
                    style = MaterialTheme.typography.bodyMedium,
                    color = MaterialTheme.colorScheme.onSurface,
                    fontWeight = FontWeight.Medium
                )
                
                if (isLiveMode) {
                    Box(
                        modifier = Modifier
                            .size(6.dp)
                            .background(
                                color = SuccessGreen,
                                shape = androidx.compose.foundation.shape.CircleShape
                            )
                    )
                }
            }
            
            Spacer(modifier = Modifier.height(8.dp))
            
            // Mini chart placeholder
            Box(
                modifier = Modifier
                    .fillMaxWidth()
                    .weight(1f)
                    .clip(RoundedCornerShape(4.dp))
                    .background(MaterialTheme.colorScheme.surfaceVariant),
                contentAlignment = Alignment.Center
            ) {
                Column(
                    horizontalAlignment = Alignment.CenterHorizontally
                ) {
                    Icon(
                        painter = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_gallery),
                        contentDescription = "Chart",
                        tint = MaterialTheme.colorScheme.onSurfaceVariant,
                        modifier = Modifier.size(32.dp)
                    )
                    
                    Text(
                        text = "${widget.dataPoints} points",
                        style = MaterialTheme.typography.bodySmall,
                        color = MaterialTheme.colorScheme.onSurfaceVariant
                    )
                }
            }
            
            Spacer(modifier = Modifier.height(8.dp))
            
            Text(
                text = widget.currentValue,
                style = MaterialTheme.typography.titleMedium,
                color = EdhamOrange,
                fontWeight = FontWeight.Bold
            )
        }
    }
}

@Composable
fun AlertWidget(
    widget: AlertWidgetData,
    isLiveMode: Boolean
) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(
            containerColor = if (widget.alertCount > 0) ErrorRed.copy(alpha = 0.1f) 
                                  else SuccessGreen.copy(alpha = 0.1f)
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Row(
                modifier = Modifier.fillMaxWidth(),
                horizontalArrangement = Arrangement.SpaceBetween,
                verticalAlignment = Alignment.CenterVertically
            ) {
                Text(
                    text = "System Alerts",
                    style = MaterialTheme.typography.titleMedium,
                    color = if (widget.alertCount > 0) ErrorRed else SuccessGreen,
                    fontWeight = FontWeight.Bold
                )
                
                Row(
                    verticalAlignment = Alignment.CenterVertically
                ) {
                    if (isLiveMode) {
                        Box(
                            modifier = Modifier
                                .size(8.dp)
                                .background(
                                    color = if (widget.alertCount > 0) ErrorRed else SuccessGreen,
                                    shape = androidx.compose.foundation.shape.CircleShape
                                )
                        )
                        Spacer(modifier = Modifier.width(8.dp))
                    }
                    
                    Text(
                        text = "${widget.alertCount} active",
                        style = MaterialTheme.typography.titleLarge,
                        color = if (widget.alertCount > 0) ErrorRed else SuccessGreen,
                        fontWeight = FontWeight.Bold
                    )
                }
            }
            
            Spacer(modifier = Modifier.height(12.dp))
            
            LazyColumn(
                verticalArrangement = Arrangement.spacedBy(8.dp),
                modifier = Modifier.height(100.dp)
            ) {
                items(widget.recentAlerts.take(3)) { alert ->
                    AlertItem(alert = alert)
                }
            }
        }
    }
}

@Composable
fun AlertItem(alert: AlertItemData) {
    Row(
        modifier = Modifier.fillMaxWidth(),
        verticalAlignment = Alignment.CenterVertically
    ) {
        Box(
            modifier = Modifier
                .size(8.dp)
                .background(
                    color = alert.color,
                    shape = androidx.compose.foundation.shape.CircleShape
                )
        )
        
        Spacer(modifier = Modifier.width(12.dp))
        
        Column(modifier = Modifier.weight(1f)) {
            Text(
                text = alert.message,
                style = MaterialTheme.typography.bodySmall,
                color = MaterialTheme.colorScheme.onSurface,
                maxLines = 1
            )
            
            Text(
                text = alert.time,
                style = MaterialTheme.typography.bodySmall,
                color = MaterialTheme.colorScheme.onSurface.copy(alpha = 0.6f)
            )
        }
    }
}

