@Composable
fun PerformanceMeterWidget(
    widget: PerformanceMeterWidgetData,
    isLiveMode: Boolean
) {
    Card(
        modifier = Modifier
            .width(150.dp)
            .height(120.dp),
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.surface
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier
                .fillMaxSize()
                .padding(12.dp),
            horizontalAlignment = Alignment.CenterHorizontally,
            verticalArrangement = Arrangement.SpaceBetween
        ) {
            Text(
                text = widget.title,
                style = MaterialTheme.typography.bodySmall,
                color = MaterialTheme.colorScheme.onSurface.copy(alpha = 0.7f),
                textAlign = TextAlign.Center
            )
            
            // Performance meter placeholder
            Box(
                modifier = Modifier
                    .size(60.dp)
                    .background(
                        color = widget.color.copy(alpha = 0.2f),
                        shape = androidx.compose.foundation.shape.CircleShape
                    ),
                contentAlignment = Alignment.Center
            ) {
                Column(
                    horizontalAlignment = Alignment.CenterHorizontally
                ) {
                    Text(
                        text = "${String.format("%.0f", widget.percentage)}%",
                        style = MaterialTheme.typography.titleMedium,
                        color = widget.color,
                        fontWeight = FontWeight.Bold
                    )
                    
                    if (isLiveMode) {
                        Box(
                            modifier = Modifier
                                .size(4.dp)
                                .background(
                                    color = SuccessGreen,
                                    shape = androidx.compose.foundation.shape.CircleShape
                                )
                        )
                    }
                }
            }
            
            Text(
                text = widget.status,
                style = MaterialTheme.typography.bodySmall,
                color = widget.color,
                fontWeight = FontWeight.Medium
            )
        }
    }
}

@Composable
fun QuickStatWidget(
    widget: QuickStatWidgetData,
    isLiveMode: Boolean
) {
    Card(
        modifier = Modifier
            .width(120.dp)
            .height(80.dp),
        colors = CardDefaults.cardColors(
            containerColor = widget.color.copy(alpha = 0.1f)
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 1.dp)
    ) {
        Column(
            modifier = Modifier
                .fillMaxSize()
                .padding(8.dp),
            horizontalAlignment = Alignment.CenterHorizontally,
            verticalArrangement = Arrangement.Center
        ) {
            Text(
                text = widget.value,
                style = MaterialTheme.typography.titleMedium,
                color = widget.color,
                fontWeight = FontWeight.Bold
            )
            
            Text(
                text = widget.label,
                style = MaterialTheme.typography.bodySmall,
                color = MaterialTheme.colorScheme.onSurface.copy(alpha = 0.7f),
                textAlign = TextAlign.Center
            )
            
            if (isLiveMode) {
                Spacer(modifier = Modifier.height(4.dp))
                Box(
                    modifier = Modifier
                        .size(4.dp)
                        .background(
                            color = SuccessGreen,
                            shape = androidx.compose.foundation.shape.CircleShape
                        )
                )
            }
        }
    }
}

// Data classes
data class KPIWidgetData(
    val title: String,
    val value: String,
    val change: Double,
    val icon: androidx.compose.ui.graphics.painter.Painter,
    val color: Color
)

data class StatusWidgetData(
    val title: String,
    val description: String,
    val icon: androidx.compose.ui.graphics.painter.Painter,
    val statusColor: Color
)

data class ChartWidgetData(
    val title: String,
    val dataPoints: Int,
    val currentValue: String
)

data class AlertWidgetData(
    val alertCount: Int,
    val recentAlerts: List<AlertItemData>
)

data class AlertItemData(
    val message: String,
    val time: String,
    val color: Color
)

data class ActivityFeedWidgetData(
    val activities: List<ActivityItemData>
)

data class ActivityItemData(
    val description: String,
    val time: String,
    val icon: androidx.compose.ui.graphics.painter.Painter,
    val color: Color
)

data class PerformanceMeterWidgetData(
    val title: String,
    val percentage: Float,
    val status: String,
    val color: Color
)

data class QuickStatWidgetData(
    val value: String,
    val label: String,
    val color: Color
)

data class LiveWidgetsData(
    val kpiWidgets: List<KPIWidgetData>,
    val statusWidgets: List<StatusWidgetData>,
    val chartWidgets: List<ChartWidgetData>,
    val alertWidget: AlertWidgetData,
    val activityFeedWidget: ActivityFeedWidgetData,
    val performanceMeters: List<PerformanceMeterWidgetData>,
    val quickStats: List<QuickStatWidgetData>
)
