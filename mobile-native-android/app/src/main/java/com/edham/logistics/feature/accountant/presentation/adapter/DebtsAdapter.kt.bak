package com.edham.logistics.feature.accountant.presentation.adapter

import android.view.LayoutInflater
import android.view.ViewGroup
import androidx.recyclerview.widget.DiffUtil
import androidx.recyclerview.widget.ListAdapter
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.databinding.ItemDebtBinding
import com.edham.logistics.feature.accountant.domain.model.Debt
import javax.inject.Inject

class DebtsAdapter @Inject constructor(
    private val onDebtAction: (Debt, String) -> Unit
) : ListAdapter<Debt, DebtsAdapter.DebtViewHolder>(DebtDiffCallback()) {

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): DebtViewHolder {
        val binding = ItemDebtBinding.inflate(
            LayoutInflater.from(parent.context),
            parent,
            false
        )
        return DebtViewHolder(binding)
    }

    override fun onBindViewHolder(holder: DebtViewHolder, position: Int) {
        holder.bind(getItem(position))
    }

    inner class DebtViewHolder(
        private val binding: ItemDebtBinding
    ) : RecyclerView.ViewHolder(binding.root) {

        fun bind(debt: Debt) {
            binding.apply {
                textDebtId.text = debt.id
                textCustomerName.text = debt.customerName
                textCustomerPhone.text = debt.customerPhone
                textTotalAmount.text = formatCurrency(debt.totalAmount)
                textPaidAmount.text = formatCurrency(debt.paidAmount)
                textRemainingAmount.text = formatCurrency(debt.remainingAmount)
                textDueDate.text = formatDate(debt.dueDate)
                textStatus.text = formatDebtStatus(debt.status)
                
                // Set status color
                textStatus.setTextColor(getDebtStatusColor(debt.status))
                
                // Show overdue days if applicable
                if (debt.overdueDays > 0) {
                    textOverdueDays.text = "${debt.overdueDays} يوم متأخر"
                    textOverdueDays.setTextColor(android.graphics.Color.parseColor("#F44336"))
                    layoutOverdueDays.visible()
                } else {
                    layoutOverdueDays.gone()
                }
                
                // Show last payment date if available
                if (debt.lastPaymentDate != null) {
                    textLastPaymentDate.text = formatDate(debt.lastPaymentDate)
                    layoutLastPaymentDate.visible()
                } else {
                    layoutLastPaymentDate.gone()
                }
                
                // Show payment plan info if available
                if (debt.paymentPlan != null) {
                    textPaymentPlanStatus.text = formatPaymentPlanStatus(debt.paymentPlan.status)
                    layoutPaymentPlan.visible()
                } else {
                    layoutPaymentPlan.gone()
                }
                
                // Set progress bar
                val progress = (debt.paidAmount / debt.totalAmount) * 100
                progressBar.progress = progress.toInt()
                textProgress.text = "${String.format("%.0f", progress)}%"
                
                // Set click listeners
                buttonDetails.setOnClickListener {
                    onDebtAction(debt, "details")
                }
                
                buttonPayment.setOnClickListener {
                    onDebtAction(debt, "payment")
                }
                
                buttonPlan.setOnClickListener {
                    onDebtAction(debt, "plan")
                }
                
                root.setOnClickListener {
                    onDebtAction(debt, "details")
                }
                
                // Show/hide action buttons based on status
                buttonPayment.visibility = when (debt.status) {
                    com.edham.logistics.feature.accountant.domain.model.DebtStatus.CURRENT,
                    com.edham.logistics.feature.accountant.domain.model.DebtStatus.OVERDUE,
                    com.edham.logistics.feature.accountant.domain.model.DebtStatus.COLLECTION -> android.view.View.VISIBLE
                    else -> android.view.View.GONE
                }
            }
        }
        
        private fun formatDebtStatus(status: com.edham.logistics.feature.accountant.domain.model.DebtStatus): String {
            return when (status) {
                com.edham.logistics.feature.accountant.domain.model.DebtStatus.CURRENT -> "جاري"
                com.edham.logistics.feature.accountant.domain.model.DebtStatus.OVERDUE -> "متأخر"
                com.edham.logistics.feature.accountant.domain.model.DebtStatus.COLLECTION -> "تحصيل"
                com.edham.logistics.feature.accountant.domain.model.DebtStatus.PAID -> "مدفوع"
                com.edham.logistics.feature.accountant.domain.model.DebtStatus.WRITE_OFF -> "إلغاء"
            }
        }
        
        private fun formatPaymentPlanStatus(status: com.edham.logistics.feature.accountant.domain.model.PaymentPlanStatus): String {
            return when (status) {
                com.edham.logistics.feature.accountant.domain.model.PaymentPlanStatus.ACTIVE -> "نشط"
                com.edham.logistics.feature.accountant.domain.model.PaymentPlanStatus.COMPLETED -> "مكتمل"
                com.edham.logistics.feature.accountant.domain.model.PaymentPlanStatus.CANCELLED -> "ملغي"
                com.edham.logistics.feature.accountant.domain.model.PaymentPlanStatus.DEFAULTED -> "تخلف"
            }
        }
        
        private fun formatCurrency(amount: Double): String {
            return String.format("%.2f ريال", amount)
        }
        
        private fun formatDate(date: String): String {
            return date.substring(0, 10).replace("-", "/")
        }
        
        private fun getDebtStatusColor(status: com.edham.logistics.feature.accountant.domain.model.DebtStatus): Int {
            return when (status) {
                com.edham.logistics.feature.accountant.domain.model.DebtStatus.CURRENT -> android.graphics.Color.parseColor("#2196F3")
                com.edham.logistics.feature.accountant.domain.model.DebtStatus.OVERDUE -> android.graphics.Color.parseColor("#F44336")
                com.edham.logistics.feature.accountant.domain.model.DebtStatus.COLLECTION -> android.graphics.Color.parseColor("#FF5722")
                com.edham.logistics.feature.accountant.domain.model.DebtStatus.PAID -> android.graphics.Color.parseColor("#4CAF50")
                com.edham.logistics.feature.accountant.domain.model.DebtStatus.WRITE_OFF -> android.graphics.Color.parseColor("#9E9E9E")
            }
        }
    }

    private class DebtDiffCallback : DiffUtil.ItemCallback<Debt>() {
        override fun areItemsTheSame(oldItem: Debt, newItem: Debt): Boolean {
            return oldItem.id == newItem.id
        }

        override fun areContentsTheSame(oldItem: Debt, newItem: Debt): Boolean {
            return oldItem == newItem
        }
    }
}
