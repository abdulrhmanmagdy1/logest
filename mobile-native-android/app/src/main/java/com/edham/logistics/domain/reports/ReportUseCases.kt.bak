            )
        )
    }

    private fun calculateCustomerLifetimeValue(customerInsights: List<CustomerInsight>): CustomerLifetimeValue {
        val totalRevenue = customerInsights.sumOf { it.totalRevenue }
        val averageLifetime = 24.0 // months
        
        return CustomerLifetimeValue(
            averageLifetimeValue = totalRevenue / customerInsights.size,
            totalLifetimeValue = totalRevenue,
            averageCustomerLifetime = averageLifetime
        )
    }

