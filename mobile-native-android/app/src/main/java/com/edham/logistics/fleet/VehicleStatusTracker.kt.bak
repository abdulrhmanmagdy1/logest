        // Implementation would send notifications based on status
        when (status) {
            VehicleStatus.MAINTENANCE -> {
                // Send maintenance notification
            }
            VehicleStatus.OUT_OF_SERVICE -> {
                // Send out of service notification
            }
            VehicleStatus.RETIRED -> {
                // Send retirement notification
            }
            else -> {
                // No specific notifications
            }
        }
    }
    
    private suspend fun updateStatusHistory() {
        val history = database.vehicleStatusHistoryDao().getAllHistory()
        _statusHistory.value = history.take(MAX_HISTORY_ENTRIES)
    }
    
    private fun calculateHealthMetrics(vehicle: VehicleEntity, latestHistory: VehicleStatusHistoryEntity?): HealthMetrics {
        val issues = mutableListOf<HealthIssue>()
        var healthScore = 100f
        
        // Check mileage
        if (vehicle.mileage > 100000) {
            issues.add(HealthIssue(
                type = HealthIssueType.HIGH_MILEAGE,
                severity = HealthIssueSeverity.MEDIUM,
                description = "High mileage detected",
                recommendation = "Schedule comprehensive maintenance check"
            ))
            healthScore -= 20f
        }
        
        // Check fuel level
        if (vehicle.fuelLevel < 20f) {
            issues.add(HealthIssue(
                type = HealthIssueType.LOW_FUEL,
                severity = HealthIssueSeverity.LOW,
                description = "Low fuel level",
                recommendation = "Refuel vehicle soon"
            ))
            healthScore -= 10f
        }
        
        // Check maintenance due
        if (vehicle.nextMaintenance.before(Date())) {
            issues.add(HealthIssue(
                type = HealthIssueType.MAINTENANCE_DUE,
                severity = HealthIssueSeverity.HIGH,
                description = "Maintenance is overdue",
                recommendation = "Schedule maintenance immediately"
            ))
            healthScore -= 30f
        }
        
        // Check document expiry
        val expiringDocuments = getExpiringDocuments(vehicle)
        if (expiringDocuments.isNotEmpty()) {
            issues.add(HealthIssue(
                type = HealthIssueType.DOCUMENT_EXPIRY,
                severity = HealthIssueSeverity.MEDIUM,
                description = "Documents expiring soon",
                recommendation = "Renew expiring documents"
            ))
            healthScore -= 15f
        }
        
        // Check status duration
        val statusDuration = calculateStatusDuration(latestHistory?.changedAt ?: vehicle.createdAt)
        if (vehicle.status == VehicleStatus.MAINTENANCE && statusDuration > 7 * 24 * 60 * 60 * 1000L) { // 7 days
            issues.add(HealthIssue(
                type = HealthIssueType.LONG_MAINTENANCE,
                severity = HealthIssueSeverity.HIGH,
                description = "Vehicle in maintenance for extended period",
                recommendation = "Complete maintenance or re-evaluate vehicle status"
            ))
            healthScore -= 25f
        }
        
        return HealthMetrics(
            healthScore = maxOf(0f, healthScore),
            issues = issues
        )
    }
    
    private fun calculateStatusDuration(statusChangeTime: Date): Long {
        return System.currentTimeMillis() - statusChangeTime.time
    }
    
    private fun getExpiringDocuments(vehicle: VehicleEntity): List<ExpiringDocument> {
        val expiring = mutableListOf<ExpiringDocument>()
        val now = Date()
        val thirtyDaysFromNow = Date(System.currentTimeMillis() + 30L * 24 * 60 * 60 * 1000)
        
        if (vehicle.insuranceExpiry.before(thirtyDaysFromNow)) {
            expiring.add(ExpiringDocument(
                type = DocumentType.INSURANCE,
                expiryDate = vehicle.insuranceExpiry,
                daysUntilExpiry = ((vehicle.insuranceExpiry.time - now.time) / (24 * 60 * 60 * 1000)).toInt()
            ))
        }
        
        if (vehicle.licenseExpiry.before(thirtyDaysFromNow)) {
            expiring.add(ExpiringDocument(
                type = DocumentType.LICENSE,
                expiryDate = vehicle.licenseExpiry,
                daysUntilExpiry = ((vehicle.licenseExpiry.time - now.time) / (24 * 60 * 60 * 1000)).toInt()
            ))
        }
        
        if (vehicle.registrationExpiry.before(thirtyDaysFromNow)) {
            expiring.add(ExpiringDocument(
                type = DocumentType.REGISTRATION,
                expiryDate = vehicle.registrationExpiry,
                daysUntilExpiry = ((vehicle.registrationExpiry.time - now.time) / (24 * 60 * 60 * 1000)).toInt()
            ))
        }
        
        return expiring
    }
    
    private fun calculateUtilizationRate(vehicleId: Long): Float {
        // Implementation would calculate utilization rate based on assignments and usage
        return 0.75f // Placeholder
    }
    
    private fun determineOverallHealth(healthScore: Float): OverallHealth {
        return when {
            healthScore >= 90 -> OverallHealth.EXCELLENT
            healthScore >= 75 -> OverallHealth.GOOD
            healthScore >= 60 -> OverallHealth.FAIR
            healthScore >= 40 -> OverallHealth.POOR
            else -> OverallHealth.CRITICAL
        }
    }
    
    private fun generateHealthRecommendations(healthMetrics: HealthMetrics): List<String> {
        return healthMetrics.issues.map { it.recommendation }
    }
    
    private fun needsAttention(vehicle: VehicleEntity): Boolean {
        return vehicle.status == VehicleStatus.MAINTENANCE ||
                vehicle.status == VehicleStatus.OUT_OF_SERVICE ||
                vehicle.nextMaintenance.before(Date()) ||
                vehicle.fuelLevel < 20f
    }
    
    private fun serializeMetadata(metadata: Map<String, Any>): String {
        // Implementation would serialize metadata to JSON
        return metadata.toString()
    }
    
    private fun calculateStatusDistribution(history: List<VehicleStatusHistoryEntity>): Map<VehicleStatus, Int> {
        return history.groupBy { it.newStatus }.mapValues { it.value.size }
    }
    
    private fun calculateAverageStatusDuration(history: List<VehicleStatusHistoryEntity>): Double {
        if (history.size < 2) return 0.0
        
        val durations = mutableListOf<Long>()
        for (i in 1 until history.size) {
            val duration = history[i].changedAt.time - history[i-1].changedAt.time
            durations.add(duration)
        }
        
        return if (durations.isNotEmpty()) {
            durations.average()
        } else 0.0
    }
    
    private fun calculateMostCommonTransitions(history: List<VehicleStatusHistoryEntity>): Map<String, Int> {
        val transitions = mutableMapOf<String, Int>()
        
        history.zipWithNext { prev, current ->
            val transition = "${prev.previousStatus} -> ${current.newStatus}"
            transitions[transition] = transitions.getOrDefault(transition, 0) + 1
        }
        
        return transitions
    }
    
    private fun calculateStatusChangeFrequency(history: List<VehicleStatusHistoryEntity>): Map<String, Int> {
        return history.groupBy { it.newStatus.toString() }.mapValues { it.value.size }
    }
    
    private fun calculateHealthScoreDistribution(vehicles: List<VehicleEntity>): Map<String, Int> {
        val distribution = mutableMapOf<String, Int>()
        
        vehicles.forEach { vehicle ->
            val healthScore = 75f // Placeholder - would calculate actual health score
            val category = when {
                healthScore >= 90 -> "Excellent"
                healthScore >= 75 -> "Good"
                healthScore >= 60 -> "Fair"
                healthScore >= 40 -> "Poor"
                else -> "Critical"
            }
            distribution[category] = distribution.getOrDefault(category, 0) + 1
        }
        
        return distribution
    }
    
    private fun calculateMaintenancePredictions(vehicles: List<VehicleEntity>): List<MaintenancePrediction> {
        return vehicles.map { vehicle ->
            MaintenancePrediction(
                vehicleId = vehicle.id,
                vehicleIdString = vehicle.vehicleId,
                predictedMaintenanceDate = vehicle.nextMaintenance,
                confidence = 0.85f,
                factors = listOf("Mileage", "Time since last service", "Vehicle type")
            )
        }
    }
    
    /**
     * Get tracking status
     */
    fun isTracking(): Boolean = isTracking
    
    /**
     * Get tracked vehicles count
     */
    fun getTrackedVehiclesCount(): Int = trackedVehicles.size
}

/**
 * Data classes
 */
data class VehicleStatusInfo(
    val vehicleId: Long,
    val currentStatus: VehicleStatus,
    val previousStatus: VehicleStatus?,
    val lastStatusChange: Date,
    val statusDuration: Long,
    val healthScore: Float,
    val healthIssues: List<HealthIssue>,
    val nextMaintenanceDue: Date?,
    val documentsExpiring: List<ExpiringDocument>,
    val utilizationRate: Float,
    val lastLocation: String,
    val lastUpdate: Date
)

data class VehicleHealthReport(
    val vehicleId: Long,
    val healthScore: Float,
    val overallHealth: OverallHealth,
    val issues: List<HealthIssue>,
    val recommendations: List<String>,
    val nextMaintenanceDue: Date?,
    val criticalAlerts: List<HealthIssue>,
    val lastCheck: Date,
    val checkInterval: Long
)

data class HealthMetrics(
    val healthScore: Float,
    val issues: List<HealthIssue>
)

data class HealthIssue(
    val type: HealthIssueType,
    val severity: HealthIssueSeverity,
    val description: String,
    val recommendation: String
)

data class ExpiringDocument(
    val type: DocumentType,
    val expiryDate: Date,
    val daysUntilExpiry: Int
)

data class StatusAnalytics(
    val totalStatusChanges: Int = 0,
    val statusDistribution: Map<VehicleStatus, Int> = emptyMap(),
    val averageStatusDuration: Double = 0.0,
    val mostCommonTransitions: Map<String, Int> = emptyMap(),
    val statusChangeFrequency: Map<String, Int> = emptyMap(),
    val healthScoreDistribution: Map<String, Int> = emptyMap(),
    val maintenancePredictions: List<MaintenancePrediction> = emptyList(),
    val vehiclesNeedingAttention: Int = 0,
    val automatedStatusChanges: Int = 0,
    val manualStatusChanges: Int = 0
)

data class MaintenancePrediction(
    val vehicleId: Long,
    val vehicleIdString: String,
    val predictedMaintenanceDate: Date,
    val confidence: Float,
    val factors: List<String>
)

data class VehicleStatusAlert(
    val id: Long,
    val vehicleId: Long,
    val type: VehicleStatusAlertType,
    val message: String,
    val severity: AlertSeverity,
    val timestamp: Date,
    val resolved: Boolean,
    val resolvedAt: Date?,
    val resolvedBy: String?
)

/**
 * Interfaces
 */
interface StatusChangeListener {
    fun onStatusChanged(vehicleId: Long, oldStatus: VehicleStatus, newStatus: VehicleStatus, history: VehicleStatusHistoryEntity)
}

/**
 * Enums
 */
enum class TrackingState {
    Idle,
    Starting,
    Tracking,
    Stopped,
    Error
}

enum class HealthIssueType {
    HIGH_MILEAGE,
    LOW_FUEL,
    MAINTENANCE_DUE,
    DOCUMENT_EXPIRY,
    LONG_MAINTENANCE,
    ABNORMAL_TEMPERATURE,
    ENGINE_ISSUES,
    TIRE_ISSUES,
    BATTERY_ISSUES,
    TRANSMISSION_ISSUES
}

enum class HealthIssueSeverity {
    LOW,
    MEDIUM,
    HIGH,
    CRITICAL
}

enum class OverallHealth {
    EXCELLENT,
    GOOD,
    FAIR,
    POOR,
    CRITICAL
}

enum class DocumentType {
    INSURANCE,
    LICENSE,
    REGISTRATION,
    PERMIT,
    INSPECTION
}

enum class VehicleStatusAlertType {
    STATUS_CHANGED,
    HEALTH_DEGRADATION,
    MAINTENANCE_DUE,
    DOCUMENT_EXPIRY,
    ABNORMAL_BEHAVIOR,
    GEOLOCATION_VIOLATION
}
