package com.edham.logistics.fleet

import android.content.Context
import com.edham.logistics.data.local.database.EdhamDatabase
import com.edham.logistics.data.local.entity.VehicleEntity
import com.edham.logistics.data.local.entity.VehicleStatusHistoryEntity
import com.edham.logistics.data.remote.api.FleetApi
import com.edham.logistics.tracking.LiveTrackingManager
import com.edham.logistics.utils.NetworkUtils
import kotlinx.coroutines.Dispatchers
import kotlinx.coroutines.flow.MutableStateFlow
import kotlinx.coroutines.flow.StateFlow
import kotlinx.coroutines.flow.asStateFlow
import kotlinx.coroutines.withContext
import java.util.*
import javax.inject.Inject
import javax.inject.Singleton

/**
 * Vehicle Status Tracker - Comprehensive vehicle status monitoring and tracking system
 * 
 * Features:
 * - Real-time status monitoring
 * - Status history tracking
 * - Automated status transitions
 * - Status-based alerts
 * - Performance analytics
 * - Health monitoring
 */
@Singleton
class VehicleStatusTracker @Inject constructor(
    private val context: Context,
    private val database: EdhamDatabase,
    private val fleetApi: FleetApi,
    private val liveTrackingManager: LiveTrackingManager,
    private val networkUtils: NetworkUtils
) {
    
    private val _trackingState = MutableStateFlow<TrackingState>(TrackingState.Idle)
    val trackingState: StateFlow<TrackingState> = _trackingState.asStateFlow()
    
    private val _vehicleStatuses = MutableStateFlow<Map<Long, VehicleStatusInfo>>(emptyMap())
    val vehicleStatuses: StateFlow<Map<Long, VehicleStatusInfo>> = _vehicleStatuses.asStateFlow()
    
    private val _statusHistory = MutableStateFlow<List<VehicleStatusHistoryEntity>>(emptyList())
    val statusHistory: StateFlow<List<VehicleStatusHistoryEntity>> = _statusHistory.asStateFlow()
    
    private val _statusAnalytics = MutableStateFlow<StatusAnalytics?>(null)
    val statusAnalytics: StateFlow<StatusAnalytics?> = _statusAnalytics.asStateFlow()
    
    private val _statusAlerts = MutableStateFlow<List<VehicleStatusAlert>>(emptyList())
    val statusAlerts: StateFlow<List<VehicleStatusAlert>> = _statusAlerts.asStateFlow()
    
    private var isTracking = false
    private val trackedVehicles = mutableSetOf<Long>()
    private val statusChangeListeners = mutableListOf<StatusChangeListener>()
    
    companion object {
        private const val TAG = "VehicleStatusTracker"
        private const val MONITORING_INTERVAL = 30000L // 30 seconds
        private const val MAX_HISTORY_ENTRIES = 1000
        private const val HEALTH_CHECK_INTERVAL = 60000L // 1 minute
    }
    
    /**
     * Start status tracking for vehicle
     */
    fun startTracking(vehicleId: Long) {
        if (trackedVehicles.contains(vehicleId)) return
        
        try {
            _trackingState.value = TrackingState.Starting
            
            trackedVehicles.add(vehicleId)
            
            // Load current status
            loadVehicleStatus(vehicleId)
            
            // Load status history
            loadStatusHistory(vehicleId)
            
            // Start health monitoring
            startHealthMonitoring(vehicleId)
            
            _trackingState.value = TrackingState.Tracking
            
        } catch (e: Exception) {
            _trackingState.value = TrackingState.Error("Failed to start tracking: ${e.message}")
        }
    }
    
    /**
     * Stop status tracking for vehicle
     */
    fun stopTracking(vehicleId: Long) {
        if (!trackedVehicles.contains(vehicleId)) return
        
        try {
            trackedVehicles.remove(vehicleId)
            
            // Stop health monitoring
            stopHealthMonitoring(vehicleId)
            
            // Remove from status map
            val currentStatuses = _vehicleStatuses.value.toMutableMap()
            currentStatuses.remove(vehicleId)
            _vehicleStatuses.value = currentStatuses
            
            if (trackedVehicles.isEmpty()) {
                _trackingState.value = TrackingState.Stopped
            }
            
        } catch (e: Exception) {
            _trackingState.value = TrackingState.Error("Failed to stop tracking: ${e.message}")
        }
    }
    
    /**
     * Update vehicle status
     */
    suspend fun updateVehicleStatus(
        vehicleId: Long,
        newStatus: VehicleStatus,
        reason: String,
        updatedBy: String,
        metadata: Map<String, Any> = emptyMap()
    ): Result<VehicleStatusHistoryEntity> {
        return withContext(Dispatchers.IO) {
            try {
                // Get current vehicle
                val vehicle = database.vehicleDao().getVehicleById(vehicleId)
                    ?: throw Exception("Vehicle not found")
                
                // Validate status transition
                if (!isValidStatusTransition(vehicle.status, newStatus)) {
                    throw Exception("Invalid status transition from ${vehicle.status} to $newStatus")
                }
                
                // Create status history entry
                val statusHistory = VehicleStatusHistoryEntity(
                    id = 0,
                    vehicleId = vehicleId,
                    previousStatus = vehicle.status,
                    newStatus = newStatus,
                    changeReason = reason,
                    changedAt = Date(),
                    changedBy = updatedBy,
                    metadata = serializeMetadata(metadata),
                    location = vehicle.currentLocation,
                    mileage = vehicle.mileage,
                    fuelLevel = vehicle.fuelLevel,
                    engineHours = metadata["engineHours"] as? Float,
                    temperature = metadata["temperature"] as? Float,
                    createdAt = Date()
                )
                
                // Save status history
                val historyId = database.vehicleStatusHistoryDao().insertHistory(statusHistory)
                val savedHistory = statusHistory.copy(id = historyId)
                
                // Update vehicle status
                val updatedVehicle = vehicle.copy(
                    status = newStatus,
                    updatedAt = Date(),
                    updatedBy = updatedBy
                )
                
                database.vehicleDao().updateVehicle(updatedVehicle)
                
                // Update status info
                updateStatusInfo(vehicleId, newStatus, savedHistory)
                
                // Notify listeners
                notifyStatusChange(vehicleId, vehicle.status, newStatus, savedHistory)
                
                // Send notifications
                sendStatusNotifications(vehicleId, newStatus, reason)
                
                // Update status history list
                updateStatusHistory()
                
                Result.success(savedHistory)
                
            } catch (e: Exception) {
                Result.failure(e)
            }
        }
    }
    
    /**
     * Get vehicle status info
     */
    suspend fun getVehicleStatusInfo(vehicleId: Long): VehicleStatusInfo? {
        return withContext(Dispatchers.IO) {
            try {
                val vehicle = database.vehicleDao().getVehicleById(vehicleId)
                    ?: return@withContext null
                
                val latestHistory = database.vehicleStatusHistoryDao().getLatestHistory(vehicleId)
                val healthMetrics = calculateHealthMetrics(vehicle, latestHistory)
                
                VehicleStatusInfo(
                    vehicleId = vehicleId,
                    currentStatus = vehicle.status,
                    previousStatus = latestHistory?.previousStatus,
                    lastStatusChange = latestHistory?.changedAt ?: vehicle.updatedAt,
                    statusDuration = calculateStatusDuration(latestHistory?.changedAt ?: vehicle.createdAt),
                    healthScore = healthMetrics.healthScore,
                    healthIssues = healthMetrics.issues,
                    nextMaintenanceDue = vehicle.nextMaintenance,
                    documentsExpiring = getExpiringDocuments(vehicle),
                    utilizationRate = calculateUtilizationRate(vehicleId),
                    lastLocation = vehicle.currentLocation,
                    lastUpdate = vehicle.updatedAt
                )
                
            } catch (e: Exception) {
                null
            }
        }
    }
    
    /**
     * Get status history for vehicle
     */
    suspend fun getStatusHistory(vehicleId: Long, limit: Int = 100): List<VehicleStatusHistoryEntity> {
        return withContext(Dispatchers.IO) {
            database.vehicleStatusHistoryDao().getHistoryByVehicle(vehicleId, limit)
        }
    }
    
    /**
     * Get status analytics
     */
    suspend fun getStatusAnalytics(): StatusAnalytics {
        return withContext(Dispatchers.IO) {
            try {
                val allHistory = database.vehicleStatusHistoryDao().getAllHistory()
                val allVehicles = database.vehicleDao().getAllVehicles()
                
                val totalStatusChanges = allHistory.size
                val statusDistribution = calculateStatusDistribution(allHistory)
                val averageStatusDuration = calculateAverageStatusDuration(allHistory)
                val mostCommonTransitions = calculateMostCommonTransitions(allHistory)
                val statusChangeFrequency = calculateStatusChangeFrequency(allHistory)
                val healthScoreDistribution = calculateHealthScoreDistribution(allVehicles)
                val maintenancePredictions = calculateMaintenancePredictions(allVehicles)
                
                StatusAnalytics(
                    totalStatusChanges = totalStatusChanges,
                    statusDistribution = statusDistribution,
                    averageStatusDuration = averageStatusDuration,
                    mostCommonTransitions = mostCommonTransitions,
                    statusChangeFrequency = statusChangeFrequency,
                    healthScoreDistribution = healthScoreDistribution,
                    maintenancePredictions = maintenancePredictions,
                    vehiclesNeedingAttention = allVehicles.count { needsAttention(it) },
                    automatedStatusChanges = allHistory.count { it.metadata.contains("automated") },
                    manualStatusChanges = totalStatusChanges - allHistory.count { it.metadata.contains("automated") }
                )
                
            } catch (e: Exception) {
                StatusAnalytics()
            }
        }
    }
    
    /**
     * Check vehicle health
     */
    suspend fun checkVehicleHealth(vehicleId: Long): VehicleHealthReport {
        return withContext(Dispatchers.IO) {
            try {
                val vehicle = database.vehicleDao().getVehicleById(vehicleId)
                    ?: throw Exception("Vehicle not found")
                
                val history = database.vehicleStatusHistoryDao().getHistoryByVehicle(vehicleId, 10)
                val healthMetrics = calculateHealthMetrics(vehicle, history.lastOrNull())
                
                VehicleHealthReport(
                    vehicleId = vehicleId,
                    healthScore = healthMetrics.healthScore,
                    overallHealth = determineOverallHealth(healthMetrics.healthScore),
                    issues = healthMetrics.issues,
                    recommendations = generateHealthRecommendations(healthMetrics),
                    nextMaintenanceDue = vehicle.nextMaintenance,
                    criticalAlerts = healthMetrics.issues.filter { it.severity == HealthIssueSeverity.CRITICAL },
                    lastCheck = Date(),
                    checkInterval = HEALTH_CHECK_INTERVAL
                )
                
            } catch (e: Exception) {
                throw Exception("Failed to check vehicle health: ${e.message}")
            }
        }
    }
    
    /**
     * Add status change listener
     */
    fun addStatusChangeListener(listener: StatusChangeListener) {
        statusChangeListeners.add(listener)
    }
    
    /**
     * Remove status change listener
     */
    fun removeStatusChangeListener(listener: StatusChangeListener) {
        statusChangeListeners.remove(listener)
    }
    
    /**
     * Get next expected status
     */
    fun getNextExpectedStatus(currentStatus: VehicleStatus): VehicleStatus? {
        return when (currentStatus) {
            VehicleStatus.AVAILABLE -> VehicleStatus.IN_USE
            VehicleStatus.IN_USE -> VehicleStatus.AVAILABLE
            VehicleStatus.MAINTENANCE -> VehicleStatus.AVAILABLE
            VehicleStatus.OUT_OF_SERVICE -> VehicleStatus.MAINTENANCE
            VehicleStatus.RETIRED -> null
        }
    }
    
    /**
     * Check if status change is valid
     */
    fun isValidStatusTransition(from: VehicleStatus, to: VehicleStatus): Boolean {
        val validTransitions = mapOf(
            VehicleStatus.AVAILABLE to setOf(VehicleStatus.IN_USE, VehicleStatus.MAINTENANCE, VehicleStatus.OUT_OF_SERVICE, VehicleStatus.RETIRED),
            VehicleStatus.IN_USE to setOf(VehicleStatus.AVAILABLE, VehicleStatus.MAINTENANCE, VehicleStatus.OUT_OF_SERVICE, VehicleStatus.RETIRED),
            VehicleStatus.MAINTENANCE to setOf(VehicleStatus.AVAILABLE, VehicleStatus.OUT_OF_SERVICE, VehicleStatus.RETIRED),
            VehicleStatus.OUT_OF_SERVICE to setOf(VehicleStatus.AVAILABLE, VehicleStatus.MAINTENANCE, VehicleStatus.RETIRED),
            VehicleStatus.RETIRED to emptySet()
        )
        
        return validTransitions[from]?.contains(to) == true
    }
    
    /**
     * Helper functions
     */
    private suspend fun loadVehicleStatus(vehicleId: Long) {
        val statusInfo = getVehicleStatusInfo(vehicleId)
        statusInfo?.let {
            val currentStatuses = _vehicleStatuses.value.toMutableMap()
            currentStatuses[vehicleId] = it
            _vehicleStatuses.value = currentStatuses
        }
    }
    
    private suspend fun loadStatusHistory(vehicleId: Long) {
        val history = getStatusHistory(vehicleId, 50)
        val currentHistory = _statusHistory.value.toMutableList()
        currentHistory.addAll(history.filter { it.vehicleId == vehicleId })
        _statusHistory.value = currentHistory.take(MAX_HISTORY_ENTRIES)
    }
    
    private fun startHealthMonitoring(vehicleId: Long) {
        // Implementation would start periodic health checks
    }
    
    private fun stopHealthMonitoring(vehicleId: Long) {
        // Implementation would stop health monitoring
    }
    
    private fun updateStatusInfo(vehicleId: Long, newStatus: VehicleStatus, history: VehicleStatusHistoryEntity) {
        val statusInfo = VehicleStatusInfo(
            vehicleId = vehicleId,
            currentStatus = newStatus,
            previousStatus = history.previousStatus,
            lastStatusChange = history.changedAt,
            statusDuration = 0L,
            healthScore = 0f,
            healthIssues = emptyList(),
            nextMaintenanceDue = null,
            documentsExpiring = emptyList(),
            utilizationRate = 0f,
            lastLocation = history.location,
            lastUpdate = history.changedAt
        )
        
        val currentStatuses = _vehicleStatuses.value.toMutableMap()
        currentStatuses[vehicleId] = statusInfo
        _vehicleStatuses.value = currentStatuses
    }
    
    private fun notifyStatusChange(vehicleId: Long, oldStatus: VehicleStatus, newStatus: VehicleStatus, history: VehicleStatusHistoryEntity) {
        statusChangeListeners.forEach { listener ->
            listener.onStatusChanged(vehicleId, oldStatus, newStatus, history)
        }
    }
    
