package com.edham.logistics.adapters

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.ImageView
import android.widget.TextView
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.domain.model.Payment

class PaymentManagementAdapter(
    private var payments: List<Payment>,
    private val onPaymentClick: (Payment) -> Unit
) : RecyclerView.Adapter<PaymentManagementAdapter.PaymentViewHolder>() {

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): PaymentViewHolder {
        val view = LayoutInflater.from(parent.context)
            .inflate(R.layout.item_payment_management, parent, false)
        return PaymentViewHolder(view)
    }

    override fun onBindViewHolder(holder: PaymentViewHolder, position: Int) {
        holder.bind(payments[position])
    }

    override fun getItemCount(): Int = payments.size

    fun updatePayments(newPayments: List<Payment>) {
        payments = newPayments
        notifyDataSetChanged()
    }

    inner class PaymentViewHolder(itemView: View) : RecyclerView.ViewHolder(itemView) {
        private val tvPaymentTitle: TextView = itemView.findViewById(R.id.tvPaymentTitle)
        private val tvAmount: TextView = itemView.findViewById(R.id.tvAmount)
        private val tvStatus: TextView = itemView.findViewById(R.id.tvStatus)
        private val tvTime: TextView = itemView.findViewById(R.id.tvTime)
        private val tvCustomerName: TextView = itemView.findViewById(R.id.tvCustomerName)
        private val tvPaymentMethod: TextView = itemView.findViewById(R.id.tvPaymentMethod)
        private val ivPaymentIcon: ImageView = itemView.findViewById(R.id.ivPaymentIcon)

        fun bind(payment: Payment) {
            tvPaymentTitle.text = payment.title
            tvAmount.text = String.format("%.2f ريال", payment.amount)
            tvStatus.text = payment.status
            tvTime.text = payment.time
            tvCustomerName.text = payment.customerName
            tvPaymentMethod.text = payment.paymentMethod

            // Set payment icon and color based on status
            when (payment.status) {
                "مكتمل", "مدفوع" -> {
                    ivPaymentIcon.setImageResource(R.drawable.ic_check_circle)
                    ivPaymentIcon.setColorFilter(itemView.context.getColor(R.color.supervisor_success))
                    tvStatus.setTextColor(itemView.context.getColor(R.color.supervisor_success))
                }
                "قيد المراجعة" -> {
                    ivPaymentIcon.setImageResource(R.drawable.ic_info)
                    ivPaymentIcon.setColorFilter(itemView.context.getColor(R.color.supervisor_info))
                    tvStatus.setTextColor(itemView.context.getColor(R.color.supervisor_info))
                }
                "معلق" -> {
                    ivPaymentIcon.setImageResource(R.drawable.ic_warning)
                    ivPaymentIcon.setColorFilter(itemView.context.getColor(R.color.supervisor_warning))
                    tvStatus.setTextColor(itemView.context.getColor(R.color.supervisor_warning))
                }
                "فشل" -> {
                    ivPaymentIcon.setImageResource(R.drawable.ic_error)
                    ivPaymentIcon.setColorFilter(itemView.context.getColor(R.color.supervisor_error))
                    tvStatus.setTextColor(itemView.context.getColor(R.color.supervisor_error))
                }
                else -> {
                    ivPaymentIcon.setImageResource(R.drawable.ic_info)
                    ivPaymentIcon.setColorFilter(itemView.context.getColor(R.color.text_secondary))
                    tvStatus.setTextColor(itemView.context.getColor(R.color.text_secondary))
                }
            }

            // Set payment method icon
            when (payment.paymentMethod) {
                "بطاقة ائتمان" -> {
                    // TODO: Set credit card icon
                }
                "تحويل بنكي" -> {
                    // TODO: Set bank transfer icon
                }
                "محفظة إلكترونية" -> {
                    // TODO: Set wallet icon
                }
                "نقدي" -> {
                    // TODO: Set cash icon
                }
            }

            itemView.setOnClickListener {
                onPaymentClick(payment)
            }
        }
    }
}
