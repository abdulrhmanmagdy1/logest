/**
 * Smart Cooling Alert Fragment - Comprehensive Temperature Monitoring UI
 */
class SmartCoolingAlertFragment : Fragment() {
    
    private val viewModel: SmartCoolingAlertViewModel by viewModels()
    
    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View {
        return ComposeView(requireContext()).apply {
            setContent {
                SmartCoolingAlertScreen(viewModel = viewModel)
            }
        }
    }
}

@OptIn(ExperimentalMaterial3Api::class)
@Composable
fun SmartCoolingAlertScreen(viewModel: SmartCoolingAlertViewModel) {
    val activeAlerts by viewModel.activeAlerts.collectAsState()
    val alertStatistics by viewModel.alertStatistics.collectAsState()
    val failurePredictions by viewModel.failurePredictions.collectAsState()
    val isLoading by viewModel.isLoading.collectAsState()
    val error by viewModel.error.collectAsState()
    
    val scope = rememberCoroutineScope()
    
    Column(
        modifier = Modifier
            .fillMaxSize()
            .background(Color.Black)
            .padding(16.dp)
    ) {
        // Header
        Row(
            modifier = Modifier.fillMaxWidth(),
            horizontalArrangement = Arrangement.SpaceBetween,
            verticalAlignment = Alignment.CenterVertically
        ) {
            Text(
                text = "🌡️ تنبيهات التبريد الذكية",
                color = Color.White,
                fontSize = 24.sp,
                fontWeight = FontWeight.Bold
            )
            
            IconButton(
                onClick = { scope.launch { viewModel.refreshData() } }
            ) {
                Icon(
                    Icons.Default.Refresh,
                    contentDescription = "Refresh",
                    tint = Color(0xFFF97316)
                )
            }
        }
        
        Spacer(modifier = Modifier.height(16.dp))
        
        // Alert Statistics Cards
        AlertStatisticsCards(statistics = alertStatistics)
        
        Spacer(modifier = Modifier.height(16.dp))
        
        // Active Alerts Section
        Text(
            text = "التنبيهات النشطة",
            color = Color.White,
            fontSize = 20.sp,
            fontWeight = FontWeight.Bold,
            modifier = Modifier.padding(bottom = 8.dp)
        )
        
        if (activeAlerts.isEmpty()) {
            Card(
                modifier = Modifier.fillMaxWidth(),
                colors = CardDefaults.cardColors(containerColor = Color(0xFF1F2937))
            ) {
                Column(
                    modifier = Modifier.padding(16.dp),
                    horizontalAlignment = Alignment.CenterHorizontally
                ) {
                    Icon(
                        Icons.Default.CheckCircle,
                        contentDescription = "No Alerts",
                        tint = Color(0xFF10B981),
                        modifier = Modifier.size(48.dp)
                    )
                    Spacer(modifier = Modifier.height(8.dp))
                    Text(
                        text = "لا توجد تنبيهات نشطة",
                        color = Color.White,
                        fontSize = 16.sp
                    )
                }
            }
        } else {
            LazyColumn(
                verticalArrangement = Arrangement.spacedBy(8.dp)
            ) {
                items(activeAlerts) { alert ->
                    AlertCard(
                        alert = alert,
                        onAcknowledge = { viewModel.acknowledgeAlert(alert.alertId, "current_user") }
                    )
                }
            }
        }
        
        Spacer(modifier = Modifier.height(16.dp))
        
        // Risk Predictions Section
        Text(
            text = "توقعات مخاطر فشل التبريد",
            color = Color.White,
            fontSize = 20.sp,
            fontWeight = FontWeight.Bold,
            modifier = Modifier.padding(bottom = 8.dp)
        )
        
        if (failurePredictions.isEmpty()) {
            Card(
                modifier = Modifier.fillMaxWidth(),
                colors = CardDefaults.cardColors(containerColor = Color(0xFF1F2937))
            ) {
                Column(
                    modifier = Modifier.padding(16.dp),
                    horizontalAlignment = Alignment.CenterHorizontally
                ) {
                    Icon(
                        Icons.Default.TrendingUp,
                        contentDescription = "No Predictions",
                        tint = Color(0xFF6B7280),
                        modifier = Modifier.size(48.dp)
                    )
                    Spacer(modifier = Modifier.height(8.dp))
                    Text(
                        text = "لا توجد توقيات متاحة",
                        color = Color.White,
                        fontSize = 16.sp
                    )
                }
            }
        } else {
            LazyColumn(
                verticalArrangement = Arrangement.spacedBy(8.dp)
            ) {
                items(failurePredictions.values.toList()) { prediction ->
                    RiskPredictionCard(prediction = prediction)
                }
            }
        }
        
        // Error message
        error?.let {
            Spacer(modifier = Modifier.height(16.dp))
            Card(
                modifier = Modifier.fillMaxWidth(),
                colors = CardDefaults.cardColors(containerColor = Color(0xFFEF4444))
            ) {
                Text(
                    text = it,
                    color = Color.White,
                    modifier = Modifier.padding(16.dp)
                )
            }
        }
        
        // Loading indicator
        if (isLoading) {
            Box(
                modifier = Modifier.fillMaxSize(),
                contentAlignment = Alignment.Center
            ) {
                CircularProgressIndicator(color = Color(0xFFF97316))
            }
        }
    }
}

@Composable
fun AlertStatisticsCards(statistics: SmartCoolingAlertService.AlertStatistics) {
    Row(
        modifier = Modifier.fillMaxWidth(),
        horizontalArrangement = Arrangement.spacedBy(8.dp)
    ) {
        StatCard(
            title = "إجمالي التنبيهات",
            value = statistics.totalActiveAlerts.toString(),
            icon = Icons.Default.Warning,
            color = Color(0xFFF97316),
            modifier = Modifier.weight(1f)
        )
        
        StatCard(
            title = "تنبيهات حرجة",
            value = (statistics.criticalAlerts + statistics.emergencyAlerts).toString(),
            icon = Icons.Default.Error,
            color = Color(0xFFEF4444),
            modifier = Modifier.weight(1f)
        )
        
        StatCard(
            title = "تم الاعتراف بها",
            value = statistics.acknowledgedAlerts.toString(),
            icon = Icons.Default.CheckCircle,
            color = Color(0xFF10B981),
            modifier = Modifier.weight(1f)
        )
    }
}

@Composable
fun StatCard(
    title: String,
    value: String,
    icon: ImageVector,
    color: Color,
    modifier: Modifier = Modifier
) {
    Card(
        modifier = modifier,
        colors = CardDefaults.cardColors(containerColor = Color(0xFF1F2937))
    ) {
        Column(
            modifier = Modifier.padding(12.dp),
            horizontalAlignment = Alignment.CenterHorizontally
        ) {
            Icon(
                icon,
                contentDescription = title,
                tint = color,
                modifier = Modifier.size(24.dp)
            )
            Spacer(modifier = Modifier.height(4.dp))
            Text(
                text = value,
                color = Color.White,
                fontSize = 20.sp,
                fontWeight = FontWeight.Bold
            )
            Text(
                text = title,
                color = Color(0xFF9CA3AF),
                fontSize = 12.sp
            )
        }
    }
}

@Composable
fun AlertCard(
    alert: SmartCoolingAlertService.SmartCoolingAlert,
    onAcknowledge: () -> Unit
) {
    val levelColor = when (alert.level) {
        SmartCoolingAlertService.AlertLevel.WARNING -> Color(0xFFF59E0B)
        SmartCoolingAlertService.AlertLevel.CRITICAL -> Color(0xFFEF4444)
        SmartCoolingAlertService.AlertLevel.EMERGENCY -> Color(0xFFDC2626)
    }
    
    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(containerColor = Color(0xFF1F2937))
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Row(
                modifier = Modifier.fillMaxWidth(),
                horizontalArrangement = Arrangement.SpaceBetween,
                verticalAlignment = Alignment.Top
            ) {
                Column(modifier = Modifier.weight(1f)) {
                    Text(
                        text = alert.level.arabicName,
                        color = levelColor,
                        fontSize = 18.sp,
                        fontWeight = FontWeight.Bold
                    )
                    Text(
                        text = "الشحنة: ${alert.shipmentId}",
                        color = Color.White,
                        fontSize = 14.sp,
                        modifier = Modifier.padding(top = 4.dp)
                    )
                    Text(
                        text = alert.productType,
                        color = Color(0xFF9CA3AF),
                        fontSize = 12.sp
                    )
                }
                
                if (!alert.acknowledged) {
                    Button(
                        onClick = onAcknowledge,
                        colors = ButtonDefaults.buttonColors(containerColor = Color(0xFFF97316)),
                        modifier = Modifier.height(32.dp)
                    ) {
                        Text(
                            text = "اعتراف",
                            color = Color.White,
                            fontSize = 12.sp
                        )
                    }
                }
            }
            
            Spacer(modifier = Modifier.height(8.dp))
            
            Row(
                modifier = Modifier.fillMaxWidth(),
                horizontalArrangement = Arrangement.SpaceBetween
            ) {
                Text(
                    text = "درجة الحرارة: ${alert.currentTemperature}°C",
                    color = Color.White,
                    fontSize = 14.sp
                )
                Text(
                    text = "الانحراف: ${alert.temperatureDeviation}°C",
                    color = Color.White,
                    fontSize = 14.sp
                )
            }
            
            Text(
                text = alert.alertReason,
                color = Color(0xFF9CA3AF),
                fontSize = 12.sp,
                modifier = Modifier.padding(top = 4.dp)
            )
            
            if (alert.durationMinutes > 0) {
                Text(
                    text = "المدة: ${alert.durationMinutes} دقيقة",
                    color = Color(0xFF9CA3AF),
                    fontSize = 12.sp,
                    modifier = Modifier.padding(top = 2.dp)
                )
            }
            
            if (alert.acknowledged) {
                Row(
                    verticalAlignment = Alignment.CenterVertically,
                    modifier = Modifier.padding(top = 4.dp)
                ) {
                    Icon(
                        Icons.Default.CheckCircle,
                        contentDescription = "Acknowledged",
                        tint = Color(0xFF10B981),
                        modifier = Modifier.size(16.dp)
                    )
                    Spacer(modifier = Modifier.width(4.dp))
                    Text(
                        text = "تم الاعتراف بها بواسطة ${alert.acknowledgedBy}",
                        color = Color(0xFF10B981),
                        fontSize = 12.sp
                    )
                }
            }
            
            if (alert.autoResolved) {
                Row(
                    verticalAlignment = Alignment.CenterVertically,
                    modifier = Modifier.padding(top = 4.dp)
                ) {
                    Icon(
                        Icons.Default.AutoFixHigh,
                        contentDescription = "Auto Resolved",
                        tint = Color(0xFF10B981),
                        modifier = Modifier.size(16.dp)
                    )
                    Spacer(modifier = Modifier.width(4.dp))
                    Text(
                        text = "تم الحل تلقائياً",
                        color = Color(0xFF10B981),
                        fontSize = 12.sp
                    )
                }
            }
        }
    }
}

@Composable
fun RiskPredictionCard(prediction: SmartCoolingAlertService.CoolingFailurePrediction) {
    val riskColor = when (prediction.riskLevel) {
        "LOW" -> Color(0xFF10B981)
        "MEDIUM" -> Color(0xFFF59E0B)
        "HIGH" -> Color(0xFFEF4444)
        "CRITICAL" -> Color(0xFFDC2626)
        else -> Color(0xFF6B7280)
    }
    
    val riskLevelText = when (prediction.riskLevel) {
        "LOW" -> "منخفض"
        "MEDIUM" -> "متوسط"
        "HIGH" -> "مرتفع"
        "CRITICAL" -> "حرج"
        else -> "غير معروف"
    }
    
    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(containerColor = Color(0xFF1F2937))
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Row(
                modifier = Modifier.fillMaxWidth(),
                horizontalArrangement = Arrangement.SpaceBetween,
                verticalAlignment = Alignment.Top
            ) {
                Column(modifier = Modifier.weight(1f)) {
                    Text(
                        text = "الشحنة: ${prediction.shipmentId}",
                        color = Color.White,
                        fontSize = 16.sp,
                        fontWeight = FontWeight.Bold
                    )
                    Text(
                        text = "مستوى المخاطر: $riskLevelText",
                        color = riskColor,
                        fontSize = 14.sp,
                        fontWeight = FontWeight.Bold,
                        modifier = Modifier.padding(top = 4.dp)
                    )
                }
                
                // Risk score indicator
                Box(
                    modifier = Modifier
                        .size(40.dp)
                        .background(riskColor, RoundedCornerShape(20.dp)),
                    contentAlignment = Alignment.Center
                ) {
                    Text(
                        text = "${(prediction.riskScore * 100).toInt()}%",
                        color = Color.White,
                        fontSize = 12.sp,
                        fontWeight = FontWeight.Bold
                    )
                }
            }
            
            Spacer(modifier = Modifier.height(8.dp))
            
            // Risk factors
            if (prediction.riskFactors.isNotEmpty()) {
                Text(
                    text = "عوامل الخطر:",
                    color = Color.White,
                    fontSize = 14.sp,
                    fontWeight = FontWeight.Bold
                )
                prediction.riskFactors.forEach { factor ->
                    Row(
                        verticalAlignment = Alignment.CenterVertically,
                        modifier = Modifier.padding(top = 2.dp)
                    ) {
                        Icon(
                            Icons.Default.Warning,
                            contentDescription = "Risk Factor",
                            tint = riskColor,
                            modifier = Modifier.size(16.dp)
                        )
                        Spacer(modifier = Modifier.width(4.dp))
                        Text(
                            text = factor,
                            color = Color(0xFF9CA3AF),
                            fontSize = 12.sp
                        )
                    }
                }
            }
            
            Spacer(modifier = Modifier.height(8.dp))
            
            // Recommendation
            Text(
                text = "التوصية:",
                color = Color.White,
                fontSize = 14.sp,
                fontWeight = FontWeight.Bold
            )
            Text(
                text = prediction.recommendation,
                color = Color(0xFF9CA3AF),
                fontSize = 12.sp,
                modifier = Modifier.padding(top = 2.dp)
            )
            
            // Predicted failure time
            prediction.predictedFailureTime?.let { failureTime ->
                Text(
                    text = "الوقت المتوقع للفشل: ${failureTime.format(DateTimeFormatter.ofPattern("HH:mm, dd MMM"))}",
                    color = Color(0xFF9CA3AF),
                    fontSize = 12.sp,
                    modifier = Modifier.padding(top = 4.dp)
                )
            }
            
            // Confidence level
            Text(
                text = "مستوى الثقة: ${(prediction.confidenceLevel * 100).toInt()}%",
                color = Color(0xFF6B7280),
                fontSize = 12.sp,
                modifier = Modifier.padding(top = 4.dp)
            )
        }
    }
}

@Composable
fun TemperatureChart(
    chartData: LineData,
    thresholdLines: List<LimitLine>,
    modifier: Modifier = Modifier
) {
    // This would be implemented using a custom Composable for the chart
    // For now, we'll show a placeholder
    Card(
        modifier = modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(containerColor = Color(0xFF1F2937))
    ) {
        Column(
            modifier = Modifier.padding(16.dp),
            horizontalAlignment = Alignment.CenterHorizontally
        ) {
            Icon(
                Icons.Default.ShowChart,
                contentDescription = "Temperature Chart",
                tint = Color(0xFFF97316),
                modifier = Modifier.size(48.dp)
            )
            Spacer(modifier = Modifier.height(8.dp))
            Text(
                text = "مخطط درجة الحرارة",
                color = Color.White,
                fontSize = 16.sp,
                fontWeight = FontWeight.Bold
            )
            Text(
                text = "سيتم عرض المخطط التفاعلي هنا",
                color = Color(0xFF9CA3AF),
                fontSize = 12.sp
            )
        }
    }
}
