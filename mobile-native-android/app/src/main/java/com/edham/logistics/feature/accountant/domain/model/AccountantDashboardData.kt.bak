package com.edham.logistics.feature.accountant.domain.model

data class AccountantDashboardData(
    val revenueOverview: RevenueOverview,
    val recentInvoices: List<Invoice>,
    val recentPayments: List<Payment>,
    val outstandingDebts: List<Debt>,
    val paymentStats: PaymentStats,
    val monthlyRevenue: List<MonthlyRevenue>
)

data class RevenueOverview(
    val totalRevenue: Double,
    val monthlyRevenue: Double,
    val weeklyRevenue: Double,
    val dailyRevenue: Double,
    val pendingRevenue: Double,
    val revenueGrowth: Double, // percentage
    val averageInvoiceAmount: Double,
    val totalInvoices: Int
)

data class Invoice(
    val id: String,
    val invoiceNumber: String,
    val customerId: String,
    val customerName: String,
    val customerPhone: String,
    val shipmentId: String,
    val trackingNumber: String,
    val amount: Double,
    val taxAmount: Double,
    val totalAmount: Double,
    val status: InvoiceStatus,
    val issueDate: String,
    val dueDate: String,
    val paidDate: String?,
    val paymentMethod: String?,
    val notes: String?,
    val items: List<InvoiceItem>
)

data class InvoiceItem(
    val id: String,
    val description: String,
    val quantity: Int,
    val unitPrice: Double,
    val total: Double
)

data class Payment(
    val id: String,
    val invoiceId: String,
    val invoiceNumber: String,
    val customerId: String,
    val customerName: String,
    val amount: Double,
    val paymentMethod: PaymentMethod,
    val paymentDate: String,
    val status: PaymentStatus,
    val transactionId: String?,
    val notes: String?,
    val processedBy: String
)

data class Debt(
    val id: String,
    val customerId: String,
    val customerName: String,
    val customerPhone: String,
    val totalAmount: Double,
    val paidAmount: Double,
    val remainingAmount: Double,
    val dueDate: String,
    val overdueDays: Int,
    val status: DebtStatus,
    val invoices: List<String>, // invoice IDs
    val lastPaymentDate: String?,
    val paymentPlan: PaymentPlan?
)

data class PaymentPlan(
    val id: String,
    val totalAmount: Double,
    val installments: List<Installment>,
    val status: PaymentPlanStatus,
    val createdDate: String
)

data class Installment(
    val id: String,
    val amount: Double,
    val dueDate: String,
    val paidDate: String?,
    val status: InstallmentStatus
)

data class PaymentStats(
    val totalPayments: Int,
    val totalAmount: Double,
    val averagePaymentAmount: Double,
    val onTimePayments: Int,
    val latePayments: Int,
    val overdueAmount: Double,
    paymentMethods: Map<String, Int>
)

data class MonthlyRevenue(
    val month: String,
    val year: Int,
    val revenue: Double,
    val invoices: Int,
    val payments: Int
)

data class FinancialReport(
    val id: String,
    val reportType: ReportType,
    val title: String,
    val generatedDate: String,
    val period: String,
    val totalRevenue: Double,
    val totalExpenses: Double,
    val netProfit: Double,
    val totalInvoices: Int,
    val totalPayments: Int,
    val outstandingDebts: Double,
    val data: Map<String, Any>
)

data class RevenueReport(
    val period: String,
    val totalRevenue: Double,
    val revenueByMonth: List<MonthlyRevenue>,
    val revenueByCustomer: List<CustomerRevenue>,
    val revenueByService: List<ServiceRevenue>,
    val growthRate: Double
)

data class CustomerRevenue(
    val customerId: String,
    val customerName: String,
    val totalRevenue: Double,
    val invoiceCount: Int,
    val averageInvoiceAmount: Double
)

data class ServiceRevenue(
    val serviceType: String,
    val totalRevenue: Double,
    val invoiceCount: Int,
    val averageRevenue: Double
)

data class DebtReport(
    val period: String,
    val totalDebt: Double,
    val overdueDebt: Double,
    val debtByCustomer: List<CustomerDebt>,
    val debtByAge: List<DebtByAge>,
    val paymentPlans: Int
)

data class CustomerDebt(
    val customerId: String,
    val customerName: String,
    val totalDebt: Double,
    val overdueAmount: Double,
    val invoiceCount: Int
)

data class DebtByAge(
    val ageRange: String,
    val amount: Double,
    val count: Int
)

data class PaymentReport(
    val period: String,
    val totalPayments: Double,
    val paymentCount: Int,
    val averagePayment: Double,
    val paymentsByMethod: Map<String, Double>,
    val paymentsByDay: List<DailyPayment>,
    val latePayments: Int,
    val onTimePayments: Int
)

data class DailyPayment(
    val date: String,
    val amount: Double,
    val count: Int
)

enum class InvoiceStatus {
    DRAFT,
    ISSUED,
    PAID,
    OVERDUE,
    CANCELLED,
    PARTIALLY_PAID
}

enum class PaymentMethod {
    CASH,
    BANK_TRANSFER,
    CREDIT_CARD,
    CHECK,
    ONLINE_PAYMENT,
    MOBILE_MONEY
}

enum class PaymentStatus {
    PENDING,
    COMPLETED,
    FAILED,
    CANCELLED,
    REFUNDED
}

enum class DebtStatus {
    CURRENT,
    OVERDUE,
    COLLECTION,
    PAID,
    WRITE_OFF
}

enum class PaymentPlanStatus {
    ACTIVE,
    COMPLETED,
    CANCELLED,
    DEFAULTED
}

enum class InstallmentStatus {
    PENDING,
    PAID,
    OVERDUE,
    CANCELLED
}

enum class ReportType {
    REVENUE,
    DEBT,
    PAYMENT,
    EXPENSE,
    PROFIT_LOSS,
    BALANCE_SHEET
}

// Request/Response models
data class CreateInvoiceRequest(
    val customerId: String,
    val shipmentId: String,
    val items: List<InvoiceItem>,
    val issueDate: String,
    val dueDate: String,
    val notes: String?
)

data class UpdateInvoiceRequest(
    val invoiceId: String,
    val status: InvoiceStatus,
    val notes: String?
)

data class CreatePaymentRequest(
    val invoiceId: String,
    val amount: Double,
    val paymentMethod: PaymentMethod,
    val paymentDate: String,
    val notes: String?,
    val transactionId: String?
)

data class CreatePaymentPlanRequest(
    val customerId: String,
    val debtIds: List<String>,
    val totalAmount: Double,
    val installments: List<InstallmentRequest>
)

data class InstallmentRequest(
    val amount: Double,
    val dueDate: String
)

data class GenerateReportRequest(
    val reportType: ReportType,
    val startDate: String,
    val endDate: String,
    val format: ReportFormat,
    val filters: Map<String, Any>?
)

enum class ReportFormat {
    PDF,
    EXCEL,
    CSV
}
