package com.edham.logistics.adapters

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.ImageView
import android.widget.Switch
import android.widget.TextView
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.domain.model.Setting

class SettingsManagementAdapter(
    private var settings: List<Setting>,
    private val onSettingChange: (Setting) -> Unit
) : RecyclerView.Adapter<SettingsManagementAdapter.SettingsViewHolder>() {

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): SettingsViewHolder {
        val view = LayoutInflater.from(parent.context)
            .inflate(R.layout.item_settings_management, parent, false)
        return SettingsViewHolder(view)
    }

    override fun onBindViewHolder(holder: SettingsViewHolder, position: Int) {
        holder.bind(settings[position])
    }

    override fun getItemCount(): Int = settings.size

    fun updateSettings(newSettings: List<Setting>) {
        settings = newSettings
        notifyDataSetChanged()
    }

    inner class SettingsViewHolder(itemView: View) : RecyclerView.ViewHolder(itemView) {
        private val tvSettingTitle: TextView = itemView.findViewById(R.id.tvSettingTitle)
        private val tvSettingDescription: TextView = itemView.findViewById(R.id.tvSettingDescription)
        private val tvSettingValue: TextView = itemView.findViewById(R.id.tvSettingValue)
        private val swSettingToggle: Switch = itemView.findViewById(R.id.swSettingToggle)
        private val ivSettingIcon: ImageView = itemView.findViewById(R.id.ivSettingIcon)

        fun bind(setting: Setting) {
            tvSettingTitle.text = setting.title
            tvSettingDescription.text = setting.description
            tvSettingValue.text = setting.value.toString()

            // Set icon based on setting type
            when (setting.type) {
                "notification" -> {
                    ivSettingIcon.setImageResource(R.drawable.ic_notifications)
                    ivSettingIcon.setColorFilter(itemView.context.getColor(R.color.supervisor_primary))
                }
                "location" -> {
                    ivSettingIcon.setImageResource(R.drawable.ic_location_on)
                    ivSettingIcon.setColorFilter(itemView.context.getColor(R.color.supervisor_info))
                }
                "dark_mode" -> {
                    ivSettingIcon.setImageResource(R.drawable.ic_dark_mode)
                    ivSettingIcon.setColorFilter(itemView.context.getColor(R.color.supervisor_secondary))
                }
                "language" -> {
                    ivSettingIcon.setImageResource(R.drawable.ic_language)
                    ivSettingIcon.setColorFilter(itemView.context.getColor(R.color.supervisor_accent))
                }
                "sync" -> {
                    ivSettingIcon.setImageResource(R.drawable.ic_sync)
                    ivSettingIcon.setColorFilter(itemView.context.getColor(R.color.supervisor_success))
                }
                "battery" -> {
                    ivSettingIcon.setImageResource(R.drawable.ic_battery)
                    ivSettingIcon.setColorFilter(itemView.context.getColor(R.color.supervisor_warning))
                }
                "security" -> {
                    ivSettingIcon.setImageResource(R.drawable.ic_security)
                    ivSettingIcon.setColorFilter(itemView.context.getColor(R.color.supervisor_error))
                }
                "updates" -> {
                    ivSettingIcon.setImageResource(R.drawable.ic_system_update)
                    ivSettingIcon.setColorFilter(itemView.context.getColor(R.color.supervisor_info))
                }
                else -> {
                    ivSettingIcon.setImageResource(R.drawable.ic_settings)
                    ivSettingIcon.setColorFilter(itemView.context.getColor(R.color.text_secondary))
                }
            }

            // Handle different setting types
            when (setting.type) {
                "language" -> {
                    swSettingToggle.visibility = View.GONE
                    tvSettingValue.visibility = View.VISIBLE
                }
                else -> {
                    swSettingToggle.visibility = View.VISIBLE
                    tvSettingValue.visibility = View.GONE
                    swSettingToggle.isChecked = setting.value as Boolean
                    swSettingToggle.setOnCheckedChangeListener { _, isChecked ->
                        setting.value = isChecked
                        onSettingChange(setting)
                    }
                }
            }

            itemView.setOnClickListener {
                // Handle setting click for non-toggle settings
                if (setting.type == "language") {
                    // TODO: Show language selection dialog
                }
            }
        }
    }
}
