package com.edham.logistics.sync

import android.app.*
import android.content.Context
import android.content.Intent
import android.os.Build
import android.os.IBinder
import androidx.core.app.NotificationCompat
import kotlinx.coroutines.*
import kotlinx.coroutines.flow.MutableStateFlow
import kotlinx.coroutines.flow.asStateFlow
import java.util.concurrent.TimeUnit

/**
 * Background Sync Service - Handles synchronization in the background
 */
class BackgroundSyncService : Service() {
    
    companion object {
        private const val NOTIFICATION_ID = 1001
        private const val CHANNEL_ID = "background_sync_channel"
        private const val SYNC_INTERVAL_MINUTES = 15L
        
        @Volatile
        private var INSTANCE: BackgroundSyncService? = null
        
        fun getInstance(context: Context): BackgroundSyncService {
            return INSTANCE ?: synchronized(this) {
                // For service access, we need to start the service
                val intent = Intent(context, BackgroundSyncService::class.java)
                if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
                    context.startForegroundService(intent)
                } else {
                    context.startService(intent)
                }
                // Return a mock instance for now
                MockBackgroundSyncService()
            }
        }
    }
    
    private val serviceScope = CoroutineScope(Dispatchers.IO + SupervisorJob())
    private var syncJob: Job? = null
    private var periodicSyncJob: Job? = null
    
    private val _isRunning = MutableStateFlow(false)
    val isRunning = _isRunning.asStateFlow()
    
    private val _syncStatus = MutableStateFlow<BackgroundSyncStatus>(BackgroundSyncStatus.IDLE)
    val syncStatus = _syncStatus.asStateFlow()
    
    private val _lastSyncTime = MutableStateFlow(0L)
    val lastSyncTime = _lastSyncTime.asStateFlow()
    
    private val _syncStatistics = MutableStateFlow<BackgroundSyncStatistics>(BackgroundSyncStatistics())
    val syncStatistics = _syncStatistics.asStateFlow()
    
    private var notificationManager: NotificationManager? = null
    private var syncEngine: SyncEngine? = null
    
    override fun onCreate() {
        super.onCreate()
        INSTANCE = this
        initializeService()
    }
    
    override fun onStartCommand(intent: Intent?, flags: Int, startId: Int): Int {
        when (intent?.action) {
            "START_SYNC" -> startBackgroundSync()
            "STOP_SYNC" -> stopBackgroundSync()
            "FORCE_SYNC" -> forceSync()
            else -> start()
        }
        
        return START_STICKY
    }
    
    override fun onBind(intent: Intent?): IBinder? {
        return null
    }
    
    override fun onDestroy() {
        super.onDestroy()
        stopService()
        INSTANCE = null
    }
    
    /**
     * Initialize service
     */
    private fun initializeService() {
        notificationManager = getSystemService(Context.NOTIFICATION_SERVICE) as NotificationManager
        createNotificationChannel()
        
        serviceScope.launch {
            syncEngine = SyncEngine.getInstance(this@BackgroundSyncService)
            startPeriodicSync()
        }
    }
    
    /**
     * Create notification channel
     */
    private fun createNotificationChannel() {
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            val channel = NotificationChannel(
                CHANNEL_ID,
                "Background Sync",
                NotificationManager.IMPORTANCE_LOW
            ).apply {
                description = "Background synchronization service"
                setShowBadge(false)
                enableVibration(false)
                setSound(null, null)
            }
            
            notificationManager?.createNotificationChannel(channel)
        }
    }
    
    /**
     * Start service
     */
    private fun start() {
        if (_isRunning.value) return
        
        _isRunning.value = true
        startForeground(NOTIFICATION_ID, createNotification("Background sync active"))
        
        serviceScope.launch {
            _syncStatus.value = BackgroundSyncStatus.RUNNING
            updateStatistics()
        }
    }
    
    /**
     * Start background sync
     */
    private fun startBackgroundSync() {
        if (!_isRunning.value) {
            start()
        }
        
        syncJob?.cancel()
        syncJob = serviceScope.launch {
            try {
                _syncStatus.value = BackgroundSyncStatus.SYNCING
                updateNotification("Syncing data...")
                
                syncEngine?.triggerSync()
                
                // Wait for sync to complete
                while (syncEngine?.syncState?.value == com.edham.logistics.sync.SyncState.SYNCING) {
                    delay(1000)
                }
                
                _syncStatus.value = BackgroundSyncStatus.SUCCESS
                _lastSyncTime.value = System.currentTimeMillis()
                updateNotification("Sync completed successfully")
                
                delay(3000) // Show success for 3 seconds
                updateNotification("Background sync active")
                _syncStatus.value = BackgroundSyncStatus.RUNNING
                
                updateStatistics()
                
            } catch (e: Exception) {
                _syncStatus.value = BackgroundSyncStatus.ERROR
                updateNotification("Sync failed: ${e.message}")
                updateStatistics()
            }
        }
    }
    
    /**
     * Stop background sync
     */
    private fun stopBackgroundSync() {
        syncJob?.cancel()
        _syncStatus.value = BackgroundSyncStatus.IDLE
        updateNotification("Background sync paused")
    }
    
    /**
     * Force sync
     */
    private fun forceSync() {
        if (!_isRunning.value) {
            start()
        }
        
        serviceScope.launch {
            try {
                _syncStatus.value = BackgroundSyncStatus.FORCE_SYNCING
                updateNotification("Force syncing...")
                
                syncEngine?.triggerSync()
                
                // Wait for sync to complete
                while (syncEngine?.syncState?.value == com.edham.logistics.sync.SyncState.SYNCING) {
                    delay(1000)
                }
                
                _syncStatus.value = BackgroundSyncStatus.SUCCESS
                _lastSyncTime.value = System.currentTimeMillis()
                updateNotification("Force sync completed")
                
                delay(3000)
                updateNotification("Background sync active")
                _syncStatus.value = BackgroundSyncStatus.RUNNING
                
                updateStatistics()
                
            } catch (e: Exception) {
                _syncStatus.value = BackgroundSyncStatus.ERROR
                updateNotification("Force sync failed: ${e.message}")
                updateStatistics()
            }
        }
    }
    
    /**
     * Start periodic sync
     */
    private fun startPeriodicSync() {
        periodicSyncJob?.cancel()
        periodicSyncJob = serviceScope.launch {
            while (true) {
                try {
                    delay(TimeUnit.MINUTES.toMillis(SYNC_INTERVAL_MINUTES))
                    
                    if (_isRunning.value && _syncStatus.value == BackgroundSyncStatus.RUNNING) {
                        startBackgroundSync()
                    }
                    
                } catch (e: Exception) {
                    // Handle error and continue
                    delay(60000) // Wait 1 minute on error
                }
            }
        }
    }
    
    /**
     * Stop service
     */
    private fun stopService() {
        syncJob?.cancel()
        periodicSyncJob?.cancel()
        serviceScope.cancel()
        
        _isRunning.value = false
        _syncStatus.value = BackgroundSyncStatus.STOPPED
        
        stopForeground(true)
        stopSelf()
    }
    
    /**
     * Create notification
     */
    private fun createNotification(content: String): Notification {
        return NotificationCompat.Builder(this, CHANNEL_ID)
            .setContentTitle("Edham Logistics")
            .setContentText(content)
            .setSmallIcon(android.R.drawable.ic_dialog_info)
            .setOngoing(true)
            .setSilent(true)
            .setCategory(NotificationCompat.CATEGORY_SERVICE)
            .build()
    }
    
    /**
     * Update notification
     */
    private fun updateNotification(content: String) {
        val notification = createNotification(content)
        notificationManager?.notify(NOTIFICATION_ID, notification)
    }
    
    /**
     * Update statistics
     */
    private suspend fun updateStatistics() {
        try {
            val syncStats = syncEngine?.getSyncStatistics()
            if (syncStats != null) {
                _syncStatistics.value = BackgroundSyncStatistics(
                    totalSyncs = _syncStatistics.value.totalSyncs + 1,
                    successfulSyncs = if (_syncStatus.value == BackgroundSyncStatus.SUCCESS) {
                        _syncStatistics.value.successfulSyncs + 1
                    } else {
                        _syncStatistics.value.successfulSyncs
                    },
                    failedSyncs = if (_syncStatus.value == BackgroundSyncStatus.ERROR) {
                        _syncStatistics.value.failedSyncs + 1
                    } else {
                        _syncStatistics.value.failedSyncs
                    },
                    lastSyncTime = _lastSyncTime.value,
                    averageSyncTime = calculateAverageSyncTime(),
                    pendingActions = syncStats.pendingActionsCount,
                    conflicts = syncStats.conflictsCount
                )
            }
        } catch (e: Exception) {
            // Handle error
        }
    }
    
    /**
     * Calculate average sync time
     */
    private fun calculateAverageSyncTime(): Double {
        // This would be calculated from actual sync times
        return 15.0 // 15 seconds average
    }
    
    /**
     * Get sync status
     */
    fun getCurrentStatus(): BackgroundSyncStatus {
        return _syncStatus.value
    }
    
    /**
     * Check if service is running
     */
    fun isServiceRunning(): Boolean {
        return _isRunning.value
    }
}

/**
 * Mock Background Sync Service for testing
 */
class MockBackgroundSyncService : BackgroundSyncServiceInterface {
    
    private val _isRunning = MutableStateFlow(false)
    override val isRunning = _isRunning.asStateFlow()
    
    private val _syncStatus = MutableStateFlow<BackgroundSyncStatus>(BackgroundSyncStatus.IDLE)
    override val syncStatus = _syncStatus.asStateFlow()
    
    private val _lastSyncTime = MutableStateFlow(0L)
    override val lastSyncTime = _lastSyncTime.asStateFlow()
    
    private val _syncStatistics = MutableStateFlow(BackgroundSyncStatistics())
    override val syncStatistics = _syncStatistics.asStateFlow()
    
    override fun start() {
        _isRunning.value = true
        _syncStatus.value = BackgroundSyncStatus.RUNNING
    }
    
    override fun stop() {
        _isRunning.value = false
        _syncStatus.value = BackgroundSyncStatus.STOPPED
    }
    
    override fun forceSync() {
        _syncStatus.value = BackgroundSyncStatus.FORCE_SYNCING
        
        // Simulate sync process
        kotlinx.coroutines.GlobalScope.launch {
            kotlinx.coroutines.delay(3000)
            _syncStatus.value = BackgroundSyncStatus.SUCCESS
            _lastSyncTime.value = System.currentTimeMillis()
            
            kotlinx.coroutines.delay(2000)
            _syncStatus.value = BackgroundSyncStatus.RUNNING
        }
    }
}

/**
 * Interface for background sync service
 */
interface BackgroundSyncServiceInterface {
    val isRunning: kotlinx.coroutines.flow.StateFlow<Boolean>
    val syncStatus: kotlinx.coroutines.flow.StateFlow<BackgroundSyncStatus>
    val lastSyncTime: kotlinx.coroutines.flow.StateFlow<Long>
    val syncStatistics: kotlinx.coroutines.flow.StateFlow<BackgroundSyncStatistics>
    
    fun start()
    fun stop()
    fun forceSync()
}

/**
 * Data classes
 */
data class BackgroundSyncStatistics(
    val totalSyncs: Int = 0,
    val successfulSyncs: Int = 0,
    val failedSyncs: Int = 0,
    val lastSyncTime: Long = 0L,
    val averageSyncTime: Double = 0.0,
    val pendingActions: Int = 0,
    val conflicts: Int = 0
) {
    val successRate: Double
        get() = if (totalSyncs > 0) (successfulSyncs.toDouble() / totalSyncs) * 100 else 0.0
    
    val failureRate: Double
        get() = if (totalSyncs > 0) (failedSyncs.toDouble() / totalSyncs) * 100 else 0.0
}

enum class BackgroundSyncStatus {
    IDLE,
    RUNNING,
    SYNCING,
    FORCE_SYNCING,
    SUCCESS,
    ERROR,
    STOPPED
}
