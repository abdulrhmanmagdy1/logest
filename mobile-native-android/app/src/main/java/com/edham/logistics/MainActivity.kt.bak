package com.edham.logistics

import android.os.Bundle
import androidx.appcompat.app.AppCompatActivity
import androidx.navigation.findNavController
import androidx.navigation.fragment.NavHostFragment
import androidx.navigation.ui.AppBarConfiguration
import androidx.navigation.ui.setupActionBarWithNavController
import com.edham.logistics.databinding.ActivityMainBinding
import com.edham.logistics.core.navigation.AppNavigationController
import com.edham.logistics.core.navigation.NavigationInterceptor
import com.edham.logistics.core.utils.TokenManager
import com.edham.logistics.core.auth.NavigationController
import com.edham.logistics.core.auth.AuthStateManager
import com.edham.logistics.core.auth.SessionExpiredHandler
import com.edham.logistics.core.auth.NavControllerState as NavControllerState
import com.edham.logistics.core.auth.SessionExpiredState
import com.edham.logistics.core.auth.SessionExpiredDialog
import dagger.hilt.android.AndroidEntryPoint
import javax.inject.Inject

@AndroidEntryPoint
class MainActivity : AppCompatActivity() {

    private lateinit var binding: ActivityMainBinding

    @Inject
    lateinit var tokenManager: TokenManager
    
    @Inject
    lateinit var navigationController: NavigationController
    
    @Inject
    lateinit var authStateManager: AuthStateManager
    
    @Inject
    lateinit var sessionExpiredHandler: SessionExpiredHandler

    @Inject
    lateinit var appNavigationController: AppNavigationController

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        binding = ActivityMainBinding.inflate(layoutInflater)
        setContentView(binding.root)

        setupNavigation()
        setupAuthObservers()
        checkAuthentication()
    }

    private fun setupNavigation() {
        val navHostFragment = supportFragmentManager
            .findFragmentById(R.id.nav_host_fragment) as NavHostFragment
        val navController = navHostFragment.navController

        // Initialize AppNavigationController (relaxed mode)
        appNavigationController.initialize(navController, supportFragmentManager)
        
        // Initialize NavigationInterceptor in relaxed mode (only for sensitive operations)
        NavigationInterceptor.initialize(appNavigationController, strictMode = false)

        // Setup ActionBar with Navigation
        val appBarConfiguration = AppBarConfiguration(
            setOf(
                R.id.customerDashboardFragment,
                R.id.driverDashboardFragment,
                R.id.supervisorDashboardFragment,
                R.id.accountantDashboardFragment,
                R.id.workshopDashboardFragment,
                R.id.adminDashboardFragment
            )
        )
        setupActionBarWithNavController(navController, appBarConfiguration)
        
        // Setup Bottom Navigation with Navigation
        binding.bottomNavView.setupWithNavController(navController)
    }

    private fun checkAuthentication() {
        if (!tokenManager.isLoggedIn()) {
            // Navigate to login screen using AppNavigationController
            appNavigationController.navigateToLogin()
        }
    }
    
    private fun setupAuthObservers() {
        // Observe navigation state from NavigationController
        navigationController.navigationState
            .observe(this) { navState ->
                when (navState) {
                    is NavControllerState.NavigateToLogin -> {
                        // Navigate to login fragment using AppNavigationController
                        appNavigationController.navigateToLogin()
                    }
                    is NavControllerState.NavigateToFragment -> {
                        // Navigate to specific fragment using AppNavigationController
                        try {
                            val destination = com.edham.logistics.core.navigation.NavigationDestination.fromFragmentId(navState.fragmentId)
                            appNavigationController.navigateToDestination(destination)
                        } catch (e: Exception) {
                            // Handle navigation errors
                        }
                    }
                    else -> {
                        // No navigation needed
                    }
                }
            }
        
        // Observe session expired state
        sessionExpiredHandler.sessionExpiredState
            .observe(this) { expiredState ->
                when (expiredState) {
                    is SessionExpiredState.Expired -> {
                        // Show session expired dialog
                        showSessionExpiredDialog(expiredState.message, expiredState.canRetry)
                    }
                    is SessionExpiredState.Refreshing -> {
                        // Show refreshing message
                        showRefreshingMessage(expiredState.message)
                    }
                    is SessionExpiredState.LoggingOut -> {
                        // Show logging out message
                        showLoggingOutMessage(expiredState.message)
                    }
                    else -> {
                        // No action needed
                    }
                }
            }
    }
    
    private fun showSessionExpiredDialog(message: String, canRetry: Boolean) {
        val dialog = SessionExpiredDialog.newInstance(message, canRetry)
        dialog.show(supportFragmentManager, "SessionExpiredDialog")
    }
    
    private fun showRefreshingMessage(message: String) {
        // TODO: Implement refreshing message display
        // This could show a progress bar or toast message
    }
    
    private fun showLoggingOutMessage(message: String) {
        // TODO: Implement logging out message display
        // This could show a progress bar or toast message
    }

    override fun onSupportNavigateUp(): Boolean {
        val navHostFragment = supportFragmentManager
            .findFragmentById(R.id.nav_host_fragment) as NavHostFragment
        return navHostFragment.navController.navigateUp() || super.onSupportNavigateUp()
    }
}
