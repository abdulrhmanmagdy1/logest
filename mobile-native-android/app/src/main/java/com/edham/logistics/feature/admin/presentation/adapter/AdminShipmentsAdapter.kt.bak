package com.edham.logistics.feature.admin.presentation.adapter

import android.view.LayoutInflater
import android.view.ViewGroup
import androidx.recyclerview.widget.DiffUtil
import androidx.recyclerview.widget.ListAdapter
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.databinding.ItemAdminShipmentBinding
import com.edham.logistics.feature.admin.domain.model.AdminShipment
import javax.inject.Inject

class AdminShipmentsAdapter @Inject constructor(
    private val onShipmentAction: (AdminShipment, String) -> Unit
) : ListAdapter<AdminShipment, AdminShipmentsAdapter.AdminShipmentViewHolder>(AdminShipmentDiffCallback()) {

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): AdminShipmentViewHolder {
        val binding = ItemAdminShipmentBinding.inflate(
            LayoutInflater.from(parent.context),
            parent,
            false
        )
        return AdminShipmentViewHolder(binding)
    }

    override fun onBindViewHolder(holder: AdminShipmentViewHolder, position: Int) {
        holder.bind(getItem(position))
    }

    inner class AdminShipmentViewHolder(
        private val binding: ItemAdminShipmentBinding
    ) : RecyclerView.ViewHolder(binding.root) {

        fun bind(shipment: AdminShipment) {
            binding.apply {
                textTrackingNumber.text = shipment.trackingNumber
                textCustomerName.text = shipment.customerName
                textCustomerPhone.text = shipment.customerPhone
                textPickupLocation.text = shipment.pickupLocation.address
                textDeliveryLocation.text = shipment.deliveryLocation.address
                textCargoType.text = formatCargoType(shipment.cargoType)
                textWeight.text = "${shipment.weight} كجم"
                textPrice.text = formatPrice(shipment.price)
                textStatus.text = formatShipmentStatus(shipment.status)
                
                // Set status color
                textStatus.setTextColor(getShipmentStatusColor(shipment.status))
                
                // Show assigned driver if available
                if (shipment.assignedDriver != null) {
                    textDriverName.text = shipment.assignedDriver.name
                    textDriverName.visible()
                } else {
                    textDriverName.gone()
                }
                
                // Show temperature if available
                if (shipment.temperature != null) {
                    textTemperature.text = "${shipment.temperature}°C"
                    layoutTemperature.visible()
                } else {
                    layoutTemperature.gone()
                }
                
                // Show priority badge
                textPriority.text = formatPriority(shipment.priority)
                textPriority.setBackgroundColor(getPriorityColor(shipment.priority))
                
                // Set click listeners
                buttonAssign.setOnClickListener {
                    onShipmentAction(shipment, "assign")
                }
                
                buttonTrack.setOnClickListener {
                    onShipmentAction(shipment, "track")
                }
                
                root.setOnClickListener {
                    onShipmentAction(shipment, "details")
                }
                
                // Show/hide assign button based on status
                buttonAssign.visibility = when (shipment.status) {
                    com.edham.logistics.feature.admin.domain.model.ShipmentStatus.APPROVED,
                    com.edham.logistics.feature.admin.domain.model.ShipmentStatus.ASSIGNED -> android.view.View.VISIBLE
                    else -> android.view.View.GONE
                }
            }
        }
        
        private fun formatCargoType(cargoType: String): String {
            return when (cargoType) {
                "general" -> "بضائع عامة"
                "refrigerated" -> "بضائع مبردة"
                "fragile" -> "بضائع قابلة للكسر"
                "heavy" -> "بضائع ثقيلة"
                "urgent" -> "بضائع عاجلة"
                "documents" -> "مستندات"
                "electronics" -> "إلكترونيات"
                "food" -> "مواد غذائية"
                "medical" -> "معدات طبية"
                "chemicals" -> "مواد كيميائية"
                "livestock" -> "مواشي"
                "vehicles" -> "مركبات"
                else -> cargoType
            }
        }
        
        private fun formatShipmentStatus(status: com.edham.logistics.feature.admin.domain.model.ShipmentStatus): String {
            return when (status) {
                com.edham.logistics.feature.admin.domain.model.ShipmentStatus.PENDING -> "في انتظار"
                com.edham.logistics.feature.admin.domain.model.ShipmentStatus.APPROVED -> "موافق عليه"
                com.edham.logistics.feature.admin.domain.model.ShipmentStatus.ASSIGNED -> "مخصص"
                com.edham.logistics.feature.admin.domain.model.ShipmentStatus.IN_TRANSIT -> "قيد النقل"
                com.edham.logistics.feature.admin.domain.model.ShipmentStatus.DELIVERED -> "تم التسليم"
                com.edham.logistics.feature.admin.domain.model.ShipmentStatus.CANCELLED -> "ملغي"
                com.edham.logistics.feature.admin.domain.model.ShipmentStatus.DELAYED -> "متأخر"
            }
        }
        
        private fun formatPriority(priority: String): String {
            return when (priority) {
                "normal" -> "عادي"
                "express" -> "سريع"
                "urgent" -> "عاجل"
                "economy" -> "اقتصادي"
                else -> priority
            }
        }
        
        private fun formatPrice(price: Double): String {
            return String.format("%.2f ريال", price)
        }
        
        private fun getShipmentStatusColor(status: com.edham.logistics.feature.admin.domain.model.ShipmentStatus): Int {
            return when (status) {
                com.edham.logistics.feature.admin.domain.model.ShipmentStatus.PENDING -> android.graphics.Color.parseColor("#FF9800")
                com.edham.logistics.feature.admin.domain.model.ShipmentStatus.APPROVED -> android.graphics.Color.parseColor("#2196F3")
                com.edham.logistics.feature.admin.domain.model.ShipmentStatus.ASSIGNED -> android.graphics.Color.parseColor("#4CAF50")
                com.edham.logistics.feature.admin.domain.model.ShipmentStatus.IN_TRANSIT -> android.graphics.Color.parseColor("#2196F3")
                com.edham.logistics.feature.admin.domain.model.ShipmentStatus.DELIVERED -> android.graphics.Color.parseColor("#4CAF50")
                com.edham.logistics.feature.admin.domain.model.ShipmentStatus.CANCELLED -> android.graphics.Color.parseColor("#F44336")
                com.edham.logistics.feature.admin.domain.model.ShipmentStatus.DELAYED -> android.graphics.Color.parseColor("#FF5722")
            }
        }
        
        private fun getPriorityColor(priority: String): Int {
            return when (priority) {
                "normal" -> android.graphics.Color.parseColor("#9E9E9E")
                "express" -> android.graphics.Color.parseColor("#2196F3")
                "urgent" -> android.graphics.Color.parseColor("#F44336")
                "economy" -> android.graphics.Color.parseColor("#4CAF50")
                else -> android.graphics.Color.parseColor("#9E9E9E")
            }
        }
    }

    private class AdminShipmentDiffCallback : DiffUtil.ItemCallback<AdminShipment>() {
        override fun areItemsTheSame(oldItem: AdminShipment, newItem: AdminShipment): Boolean {
            return oldItem.id == newItem.id
        }

        override fun areContentsTheSame(oldItem: AdminShipment, newItem: AdminShipment): Boolean {
            return oldItem == newItem
        }
    }
}
