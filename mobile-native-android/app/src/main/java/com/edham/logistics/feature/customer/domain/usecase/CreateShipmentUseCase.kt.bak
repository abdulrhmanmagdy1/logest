package com.edham.logistics.feature.customer.domain.usecase

import com.edham.logistics.core.utils.Result
import com.edham.logistics.feature.customer.domain.model.CustomerShipment
import com.edham.logistics.feature.customer.domain.model.ShipmentCreationRequest
import com.edham.logistics.feature.customer.domain.repository.CustomerRepository
import javax.inject.Inject
import javax.inject.Singleton

@Singleton
class CreateShipmentUseCase @Inject constructor(
    private val customerRepository: CustomerRepository
) {
    suspend operator fun invoke(request: ShipmentCreationRequest): Result<CustomerShipment> {
        if (!isValidShipmentRequest(request)) {
            return Result.Error(IllegalArgumentException("Invalid shipment request"))
        }
        
        return customerRepository.createShipment(request)
    }
    
    private fun isValidShipmentRequest(request: ShipmentCreationRequest): Boolean {
        return request.customerId.isNotBlank() &&
                request.pickupAddress.isNotBlank() &&
                request.deliveryAddress.isNotBlank() &&
                request.cargoType.isNotBlank() &&
                request.weight > 0 &&
                request.pickupLatitude != 0.0 &&
                request.pickupLongitude != 0.0 &&
                request.deliveryLatitude != 0.0 &&
                request.deliveryLongitude != 0.0
    }
}
