package com.edham.logistics.feature.auth

import com.edham.logistics.feature.auth.data.repository.AuthRepositoryImpl
import com.edham.logistics.feature.auth.domain.repository.AuthRepository
import com.edham.logistics.feature.auth.domain.usecase.LoginUseCase
import com.edham.logistics.feature.auth.domain.usecase.LogoutUseCase
import com.edham.logistics.feature.auth.domain.usecase.RegisterUseCase
import com.edham.logistics.feature.auth.domain.usecase.ResetPasswordUseCase
import dagger.Binds
import dagger.Module
import dagger.hilt.InstallIn
import dagger.hilt.components.SingletonComponent
import javax.inject.Singleton

@Module
@InstallIn(SingletonComponent::class)
abstract class AuthModule {

    @Binds
    @Singleton
    abstract fun bindAuthRepository(
        authRepositoryImpl: AuthRepositoryImpl
    ): AuthRepository

    @Binds
    @Singleton
    abstract fun bindLoginUseCase(
        loginUseCase: LoginUseCase
    ): com.edham.logistics.feature.auth.domain.usecase.LoginUseCase

    @Binds
    @Singleton
    abstract fun bindRegisterUseCase(
        registerUseCase: RegisterUseCase
    ): com.edham.logistics.feature.auth.domain.usecase.RegisterUseCase

    @Binds
    @Singleton
    abstract fun bindLogoutUseCase(
        logoutUseCase: LogoutUseCase
    ): com.edham.logistics.feature.auth.domain.usecase.LogoutUseCase

    @Binds
    @Singleton
    abstract fun bindResetPasswordUseCase(
        resetPasswordUseCase: ResetPasswordUseCase
    ): com.edham.logistics.feature.auth.domain.usecase.ResetPasswordUseCase
}
