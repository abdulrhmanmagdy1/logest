package com.edham.logistics.feature.search.domain.repository

import com.edham.logistics.core.utils.Result
import com.edham.logistics.feature.search.domain.model.*
import kotlinx.coroutines.flow.Flow

/**
 * Repository interface for global search operations
 */
interface SearchRepository {
    
    // Basic Search Operations
    suspend fun search(query: SearchQuery): Result<SearchResponse>
    suspend fun advancedSearch(request: AdvancedSearchRequest): Result<AdvancedSearchResult>
    suspend fun realTimeSearch(query: String, filters: SearchFilters): Flow<List<SearchResult>>
    
    // Suggestions and Autocomplete
    suspend fun getSuggestions(query: String, limit: Int, types: List<SuggestionType>): Result<List<SearchSuggestion>>
    suspend fun getAutocomplete(query: String, field: String, limit: Int): Result<List<String>>
    
    // Search History
    suspend fun getSearchHistory(userId: String, limit: Int): Result<List<SearchHistory>>
    suspend fun addToSearchHistory(history: SearchHistory): Result<SearchHistory>
    suspend fun updateSearchHistory(history: SearchHistory): Result<SearchHistory>
    suspend fun deleteSearchHistory(historyId: String): Result<Unit>
    suspend fun clearSearchHistory(userId: String): Result<Unit>
    
    // Search Analytics
    suspend fun getSearchAnalytics(timeRange: TimeRange?): Result<SearchAnalytics>
    suspend fun getQueryAnalytics(query: String, timeRange: TimeRange?): Result<QueryAnalytics>
    suspend fun getUserAnalytics(userId: String, timeRange: TimeRange?): Result<UserSearchAnalytics>
    suspend fun getTopQueries(limit: Int, timeRange: TimeRange?): Result<List<QueryAnalytics>>
    suspend fun getNoResultQueries(limit: Int, timeRange: TimeRange?): Result<List<String>>
    
    // Search Optimization
    suspend fun optimizeQuery(query: SearchQuery): Result<SearchOptimizationResult>
    suspend fun analyzeQueryPerformance(query: String): Result<QueryPerformanceAnalysis>
    suspend fun suggestOptimizations(query: SearchQuery): Result<List<OptimizationSuggestion>>
    
    // Search Export
    suspend fun exportSearchResults(query: SearchQuery, config: SearchExportConfig): Result<SearchExportResult>
    suspend fun exportSearchAnalytics(timeRange: TimeRange?, config: SearchExportConfig): Result<SearchExportResult>
    
    // Search Alerts
    suspend fun createSearchAlert(config: SearchAlertConfig): Result<SearchAlertConfig>
    suspend fun updateSearchAlert(config: SearchAlertConfig): Result<SearchAlertConfig>
    suspend fun deleteSearchAlert(alertId: String): Result<Unit>
    suspend fun getSearchAlerts(userId: String): Result<List<SearchAlertConfig>>
    suspend fun getAlertHistory(alertId: String, limit: Int): Result<List<SearchAlert>>
    suspend fun triggerAlert(alertId: String): Result<SearchAlert>
    
    // Search Templates
    suspend fun createSearchTemplate(template: SearchTemplate): Result<SearchTemplate>
    suspend fun updateSearchTemplate(template: SearchTemplate): Result<SearchTemplate>
    suspend fun deleteSearchTemplate(templateId: String): Result<Unit>
    suspend fun getSearchTemplates(userId: String): Result<List<SearchTemplate>>
    suspend fun getPublicTemplates(): Result<List<SearchTemplate>>
    suspend fun executeSearchTemplate(templateId: String, parameters: Map<String, Any>): Result<SearchResponse>
    suspend fun getTemplateUsage(templateId: String): Result<TemplateUsage>
    
    // Index Management
    suspend fun createSearchIndex(config: SearchIndexConfig): Result<Unit>
    suspend fun updateSearchIndex(config: SearchIndexConfig): Result<Unit>
    suspend fun deleteSearchIndex(indexName: String): Result<Unit>
    suspend fun getIndexInfo(indexName: String): Result<SearchIndexConfig>
    suspend fun getAllIndexes(): Result<List<SearchIndexConfig>>
    suspend fun reindex(indexName: String): Result<Long>
    suspend fun reindexAll(): Result<Long>
    suspend fun optimizeIndex(indexName: String): Result<Unit>
    suspend fun optimizeAllIndexes(): Result<Unit>
    suspend fun getIndexStatistics(indexName: String): Result<IndexStatistics>
    suspend fun getAllIndexStatistics(): Result<Map<String, IndexStatistics>>
    
    // Performance Monitoring
    suspend fun getPerformanceMetrics(): Result<SearchPerformanceMetrics>
    suspend fun getSlowQueries(limit: Int): Result<List<SlowQuery>>
    suspend fun getCacheStatistics(): Result<CacheStatistics>
    suspend fun getQueryStatistics(query: String): Result<QueryStatistics>
    suspend fun getSystemHealth(): Result<SystemHealthMetrics>
    
    // Cache Management
    suspend fun configureCache(config: SearchCacheConfig): Result<Unit>
    suspend fun clearCache(): Result<Unit>
    suspend fun clearCacheEntry(key: String): Result<Unit>
    suspend fun warmupCache(queries: List<String>): Result<Long>
    suspend fun precomputePopularQueries(): Result<Long>
    suspend fun getCacheKeys(): Result<List<String>>
    
    // Entity-specific Search
    suspend fun searchShipments(query: String, filters: ShipmentSearchFilters): Result<List<SearchResult>>
    suspend fun searchUsers(query: String, filters: UserSearchFilters): Result<List<SearchResult>>
    suspend fun searchVehicles(query: String, filters: VehicleSearchFilters): Result<List<SearchResult>>
    suspend fun searchInvoices(query: String, filters: InvoiceSearchFilters): Result<List<SearchResult>>
    suspend fun searchActivityLogs(query: String, filters: ActivityLogSearchFilters): Result<List<SearchResult>>
    suspend fun searchDocuments(query: String, filters: DocumentSearchFilters): Result<List<SearchResult>>
    suspend fun searchNotifications(query: String, filters: NotificationSearchFilters): Result<List<SearchResult>>
    suspend fun searchReports(query: String, filters: ReportSearchFilters): Result<List<SearchResult>>
    suspend fun searchPayments(query: String, filters: PaymentSearchFilters): Result<List<SearchResult>>
    
    // Batch Operations
    suspend fun batchSearch(requests: List<BatchSearchRequest>): Result<List<BatchSearchResult>>
    suspend fun batchIndex(entities: List<SearchableEntity>): Result<BatchIndexResult>
    suspend fun batchUpdate(updates: List<SearchUpdate>): Result<BatchUpdateResult>
    suspend fun batchDelete(deletes: List<SearchDelete>): Result<BatchDeleteResult>
    
    // Real-time Monitoring
    fun observeSearchQueries(): Flow<SearchQuery>
    fun observeSearchResults(): Flow<SearchResult>
    fun observeSearchMetrics(): Flow<SearchMetrics>
    fun observeCacheMetrics(): Flow<CacheMetrics>
    fun observeIndexMetrics(): Flow<IndexMetrics>
    fun observeAlerts(): Flow<SearchAlert>
    
    // Search Configuration
    suspend fun getSearchConfiguration(): Result<SearchConfiguration>
    suspend fun updateSearchConfiguration(config: SearchConfiguration): Result<SearchConfiguration>
    suspend fun resetSearchConfiguration(): Result<SearchConfiguration>
    suspend fun validateSearchConfiguration(config: SearchConfiguration): Result<ValidationResult>
    
    // Search Testing
    suspend fun testQuery(query: SearchQuery): Result<TestResult>
    suspend fun benchmarkQueries(queries: List<SearchQuery>): Result<BenchmarkResult>
    suspend fun loadTestSearch(concurrency: Int, duration: Long): Result<LoadTestResult>
    
    // Search Security
    suspend fun validateSearchAccess(userId: String, query: SearchQuery): Result<AccessValidationResult>
    suspend fun sanitizeQuery(query: String): Result<String>
    suspend fun checkQuerySecurity(query: String): Result<SecurityCheckResult>
    
    // Search Integration
    suspend fun integrateWithExternalSystem(systemId: String, config: ExternalSystemConfig): Result<IntegrationResult>
    suspend fun syncWithExternalSystem(systemId: String): Result<SyncResult>
    suspend fun getIntegrationStatus(systemId: String): Result<IntegrationStatus>
}

/**
 * Advanced search request
 */
data class AdvancedSearchRequest(
    val query: String,
    val filters: SearchFilters,
    val options: SearchOptions,
    val pagination: PaginationOptions,
    val sorting: SortingOptions,
    val aggregations: List<Aggregation>,
    val highlighting: HighlightingConfig,
    val explain: Boolean = false,
    val profile: String? = null
)

/**
 * Advanced search result
 */
data class AdvancedSearchResult(
    val results: List<SearchResult>,
    val totalCount: Long,
    val took: Long,
    val aggregations: Map<String, AggregationResult>,
    val highlights: Map<String, List<String>>,
    val explanations: Map<String, Explanation>,
    val profile: String?,
    val metadata: AdvancedSearchMetadata
)

/**
 * Aggregation
 */
data class Aggregation(
    val name: String,
    val type: AggregationType,
    val field: String,
    val size: Int?,
    val subAggregations: List<Aggregation>
)

/**
 * Aggregation types
 */
enum class AggregationType {
    TERMS,
    DATE_HISTOGRAM,
    HISTOGRAM,
    STATS,
    CARDINALITY,
    FILTER,
    NESTED
}

/**
 * Highlighting configuration
 */
data class HighlightingConfig(
    val fields: List<HighlightField>,
    val preTag: String = "<mark>",
    val postTag: String = "</mark>",
    val maxAnalyzedChars: Int = 100000,
    val fragmentSize: Int = 150,
    val numberOfFragments: Int = 3
)

/**
 * Highlight field
 */
data class HighlightField(
    val name: String,
    val type: HighlightType,
    val fragmentSize: Int = 150,
    val numberOfFragments: Int = 3
)

/**
 * Highlight types
 */
enum class HighlightType {
    PLAIN,
    UNIFIED,
    FVH,
    POSTINGS
}

/**
 * Explanation
 */
data class Explanation(
    val value: Float,
    val description: String,
    val details: List<ExplanationDetail>
)

/**
 * Explanation detail
 */
data class ExplanationDetail(
    val description: String,
    val value: Float,
    val details: List<ExplanationDetail>
)

/**
 * Advanced search metadata
 */
data class AdvancedSearchMetadata(
    val searchTime: Long,
    val totalShards: Int,
    val successfulShards: Int,
    val failedShards: Int,
    val timedOut: Boolean,
    val maxScore: Float,
    val hitCount: Long,
    val profile: String?,
    val indexName: String
)

/**
 * Query performance analysis
 */
data class QueryPerformanceAnalysis(
    val query: String,
    val executionTime: Long,
    val resultCount: Int,
    val scoreDistribution: Map<String, Int>,
    val fieldUsage: Map<String, Int>,
    val filterUsage: Map<String, Int>,
    val cacheHitRate: Float,
    val recommendations: List<PerformanceRecommendation>
)

/**
 * Performance recommendation
 */
data class PerformanceRecommendation(
    val type: RecommendationType,
    val description: String,
    val impact: ImpactLevel,
    val effort: EffortLevel
)

/**
 * Recommendation types
 */
enum class RecommendationType {
    QUERY_OPTIMIZATION,
    INDEX_OPTIMIZATION,
    FILTER_OPTIMIZATION,
    CACHE_OPTIMIZATION,
    SHARD_OPTIMIZATION
}

/**
 * Impact levels
 */
enum class ImpactLevel {
    LOW,
    MEDIUM,
    HIGH,
    CRITICAL
}

/**
 * Effort levels
 */
enum class EffortLevel {
    LOW,
    MEDIUM,
    HIGH,
    VERY_HIGH
}

/**
 * Optimization suggestion
 */
data class OptimizationSuggestion(
    val type: OptimizationType,
    val description: String,
    val expectedImprovement: Float,
    val implementation: String
)

/**
 * Template usage
 */
data class TemplateUsage(
    val templateId: String,
    val usageCount: Long,
    val lastUsed: Long,
    val averageExecutionTime: Double,
    val averageResultCount: Double,
    val popularParameters: Map<String, Any>
)

/**
 * Index statistics
 */
data class IndexStatistics(
    val indexName: String,
    val documentCount: Long,
    val storeSize: Long,
    val totalSize: Long,
    val fieldCount: Int,
    val segmentCount: Int,
    val creationDate: Long,
    val lastModified: Long,
    val health: IndexHealth
)

/**
 * Index health
 */
enum class IndexHealth {
    GREEN,
    YELLOW,
    RED
}

/**
 * System health metrics
 */
data class SystemHealthMetrics(
    val overallHealth: HealthStatus,
    val indexHealth: Map<String, IndexHealth>,
    val clusterHealth: ClusterHealth,
    val nodeHealth: Map<String, NodeHealth>,
    val performanceMetrics: SystemPerformanceMetrics,
    val alerts: List<HealthAlert>
)

/**
 * Cluster health
 */
data class ClusterHealth(
    val status: HealthStatus,
    val numberOfNodes: Int,
    val numberOfDataNodes: Int,
    val activePrimaryShards: Int,
    val activeShards: Int,
    val relocatingShards: Int,
    val initializingShards: Int,
    val unassignedShards: Int
)

/**
 * Node health
 */
data class NodeHealth(
    val nodeId: String,
    val name: String,
    val status: HealthStatus,
    val cpuUsage: Float,
    val memoryUsage: Float,
    val diskUsage: Float,
    val loadAverage: Float,
    var uptime: Long
)

/**
 * Health alert
 */
data class HealthAlert(
    val id: String,
    val type: AlertType,
    val severity: AlertSeverity,
    val message: String,
    val timestamp: Long,
    val resolved: Boolean,
    val resolvedAt: Long?
)

/**
 * Alert types
 */
enum class AlertType {
    INDEX_HEALTH,
    CLUSTER_HEALTH,
    PERFORMANCE,
    CAPACITY,
    ERROR_RATE,
    SECURITY
}

/**
 * Alert severity
 */
enum class AlertSeverity {
    INFO,
    WARNING,
    ERROR,
    CRITICAL
}

/**
 * Search metrics
 */
data class SearchMetrics(
    val timestamp: Long,
    val queryCount: Long,
    val averageResponseTime: Double,
    val errorRate: Float,
    val cacheHitRate: Float,
    val throughput: Float
)

/**
 * Cache metrics
 */
data class CacheMetrics(
    val timestamp: Long,
    val hitRate: Float,
    val missRate: Float,
    val size: Long,
    val evictions: Long,
    val hits: Long,
    val misses: Long
)

/**
 * Index metrics
 */
data class IndexMetrics(
    val timestamp: Long,
    val indexName: String,
    val documentCount: Long,
    val size: Long,
    val indexingRate: Float,
    val searchRate: Float,
    val mergeRate: Float,
    val refreshRate: Float
)

/**
 * Batch search request
 */
data class BatchSearchRequest(
    val id: String,
    val query: SearchQuery,
    val priority: BatchPriority
)

/**
 * Batch priority
 */
enum class BatchPriority {
    LOW,
    MEDIUM,
    HIGH,
    URGENT
}

/**
 * Batch search result
 */
data class BatchSearchResult(
    val requestId: String,
    val results: List<SearchResult>,
    val totalCount: Long,
    val took: Long,
    val success: Boolean,
    val error: String?
)

/**
 * Searchable entity
 */
data class SearchableEntity(
    val id: String,
    val type: SearchResultType,
    val fields: Map<String, Any>,
    val metadata: SearchResultMetadata
)

/**
 * Batch index result
 */
data class BatchIndexResult(
    val totalEntities: Int,
    val indexedEntities: Int,
    val failedEntities: Int,
    val errors: List<BatchError>,
    val took: Long
)

/**
 * Search update
 */
data class SearchUpdate(
    val entityId: String,
    val entityType: SearchResultType,
    val fields: Map<String, Any>,
    val metadata: SearchResultMetadata?
)

/**
 * Batch update result
 */
data class BatchUpdateResult(
    val totalUpdates: Int,
    val successfulUpdates: Int,
    val failedUpdates: Int,
    val errors: List<BatchError>,
    val took: Long
)

/**
 * Search delete
 */
data class SearchDelete(
    val entityId: String,
    val entityType: SearchResultType
)

/**
 * Batch delete result
 */
data class BatchDeleteResult(
    val totalDeletes: Int,
    val successfulDeletes: Int,
    val failedDeletes: Int,
    val errors: List<BatchError>,
    val took: Long
)

/**
 * Batch error
 */
data class BatchError(
    val entityId: String,
    val error: String,
    val details: Map<String, Any>
)

/**
 * Search configuration
 */
data class SearchConfiguration(
    val maxResults: Int,
    val defaultPageSize: Int,
    val maxPageSize: Int,
    val fuzzySearchEnabled: Boolean,
    val fuzzyThreshold: Float,
    val cacheEnabled: Boolean,
    val cacheSize: Long,
    val cacheTtl: Long,
    val indexingEnabled: Boolean,
    val indexingBatchSize: Int,
    val refreshInterval: String,
    val numberOfShards: Int,
    val numberOfReplicas: Int,
    val analysisSettings: AnalysisSettings
)

/**
 * Analysis settings
 */
data class AnalysisSettings(
    val analyzer: String,
    val tokenizer: String,
    val filters: List<String>,
    val charFilters: List<String>
)

/**
 * Validation result
 */
data class ValidationResult(
    val isValid: Boolean,
    val errors: List<ValidationError>,
    val warnings: List<ValidationWarning>
)

/**
 * Validation error
 */
data class ValidationError(
    val field: String,
    val message: String,
    val code: String
)

/**
 * Validation warning
 */
data class ValidationWarning(
    val field: String,
    val message: String,
    val code: String
)

/**
 * Test result
 */
data class TestResult(
    val query: SearchQuery,
    val success: Boolean,
    val results: List<SearchResult>,
    val took: Long,
    val errors: List<String>,
    val warnings: List<String>
)

/**
 * Benchmark result
 */
data class BenchmarkResult(
    val queries: List<QueryBenchmark>,
    val totalTime: Long,
    val averageTime: Double,
    val fastestQuery: QueryBenchmark,
    val slowestQuery: QueryBenchmark,
    val recommendations: List<BenchmarkRecommendation>
)

/**
 * Query benchmark
 */
data class QueryBenchmark(
    val query: SearchQuery,
    val executionTime: Long,
    val resultCount: Int,
    val success: Boolean,
    val error: String?
)

/**
 * Benchmark recommendation
 */
data class BenchmarkRecommendation(
    val type: RecommendationType,
    val description: String,
    val impact: Float
)

/**
 * Load test result
 */
data class LoadTestResult(
    val concurrency: Int,
    val duration: Long,
    val totalRequests: Long,
    val successfulRequests: Long,
    val failedRequests: Long,
    val averageResponseTime: Double,
    val minResponseTime: Long,
    val maxResponseTime: Long,
    val throughput: Float,
    val errorRate: Float,
    val percentiles: Map<String, Double>
)

/**
 * Access validation result
 */
data class AccessValidationResult(
    val hasAccess: Boolean,
    val userId: String,
    val query: SearchQuery,
    val restrictions: List<AccessRestriction>,
    val allowedEntityTypes: List<SearchResultType>,
    val allowedFields: List<String>,
    val maxResults: Int
)

/**
 * Access restriction
 */
data class AccessRestriction(
    val type: RestrictionType,
    val description: String,
    val value: Any
)

/**
 * Restriction types
 */
enum class RestrictionType {
    ENTITY_TYPE,
    FIELD,
    RESULT_LIMIT,
    TIME_RANGE,
    GEOGRAPHIC
}

/**
 * Security check result
 */
data class SecurityCheckResult(
    val isSafe: Boolean,
    val threats: List<SecurityThreat>,
    val sanitizedQuery: String,
    val recommendations: List<SecurityRecommendation>
)

/**
 * Security threat
 */
data class SecurityThreat(
    val type: ThreatType,
    val description: String,
    val severity: ThreatSeverity,
    val position: Int,
    val length: Int
)

/**
 * Threat types
 */
enum class ThreatType {
    SQL_INJECTION,
    XSS,
    PATH_TRAVERSAL,
    COMMAND_INJECTION,
    DOS_ATTACK,
    PRIVILEGE_ESCALATION
}

/**
 * Threat severity
 */
enum class ThreatSeverity {
    LOW,
    MEDIUM,
    HIGH,
    CRITICAL
}

/**
 * Security recommendation
 */
data class SecurityRecommendation(
    val type: RecommendationType,
    val description: String,
    val action: String
)

/**
 * External system configuration
 */
data class ExternalSystemConfig(
    val systemId: String,
    val systemType: ExternalSystemType,
    val endpoint: String,
    val authentication: AuthenticationConfig,
    val mapping: FieldMapping,
    val syncSettings: SyncSettings
)

/**
 * External system types
 */
enum class ExternalSystemType {
    ELASTICSEARCH,
    SOLR,
    ALGOLIA,
    AZURE_SEARCH,
    GOOGLE_SEARCH,
    CUSTOM_API
}

/**
 * Authentication configuration
 */
data class AuthenticationConfig(
    val type: AuthenticationType,
    val credentials: Map<String, String>
)

/**
 * Authentication types
 */
enum class AuthenticationType {
    NONE,
    BASIC,
    API_KEY,
    OAUTH2,
    JWT
}

/**
 * Field mapping
 */
data class FieldMapping(
    val sourceFields: Map<String, String>,
    val targetFields: Map<String, String>,
    val transformations: Map<String, FieldTransformation>
)

/**
 * Field transformation
 */
data class FieldTransformation(
    val type: TransformationType,
    val expression: String,
    val parameters: Map<String, Any>
)

/**
 * Transformation types
 */
enum class TransformationType {
    COPY,
    RENAME,
    FORMAT,
    EXTRACT,
    CALCULATE,
    LOOKUP
}

/**
 * Sync settings
 */
data class SyncSettings(
    val enabled: Boolean,
    val interval: Long,
    val batchSize: Int,
    val retryAttempts: Int,
    val conflictResolution: ConflictResolution
)

/**
 * Conflict resolution
 */
enum class ConflictResolution {
    SOURCE_WINS,
    TARGET_WINS,
    MERGE,
    MANUAL
}

/**
 * Integration result
 */
data class IntegrationResult(
    val systemId: String,
    val success: Boolean,
    val message: String,
    val details: Map<String, Any>
)

/**
 * Sync result
 */
data class SyncResult(
    val systemId: String,
    val totalRecords: Long,
    val syncedRecords: Long,
    val failedRecords: Long,
    val errors: List<SyncError>,
    val took: Long
)

/**
 * Sync error
 */
data class SyncError(
    val recordId: String,
    val error: String,
    val details: Map<String, Any>
)

/**
 * Integration status
 */
data class IntegrationStatus(
    val systemId: String,
    val status: IntegrationStatusType,
    val lastSync: Long,
    val nextSync: Long,
    val errorCount: Int,
    val lastError: String?
)

/**
 * Integration status types
 */
enum class IntegrationStatusType {
    ACTIVE,
    INACTIVE,
    ERROR,
    SYNCING,
    DISABLED
}

// Entity-specific search filters

data class ShipmentSearchFilters(
    val dateRange: DateRangeFilter? = null,
    val statusFilter: StatusFilter? = null,
    val locationFilter: LocationFilter? = null,
    val trackingNumber: String? = null,
    val customerName: String? = null,
    val driverName: String? = null
)

data class UserSearchFilters(
    val roleFilter: RoleFilter? = null,
    val statusFilter: StatusFilter? = null,
    val locationFilter: LocationFilter? = null,
    val username: String? = null,
    val email: String? = null,
    val phoneNumber: String? = null
)

data class VehicleSearchFilters(
    val statusFilter: StatusFilter? = null,
    val locationFilter: LocationFilter? = null,
    val licensePlate: String? = null,
    val make: String? = null,
    val model: String? = null,
    val year: Int? = null
)

data class InvoiceSearchFilters(
    val dateRange: DateRangeFilter? = null,
    val statusFilter: StatusFilter? = null,
    val customerFilter: OwnerFilter? = null,
    val invoiceNumber: String? = null,
    val customerName: String? = null,
    val amount: Double? = null
)

data class ActivityLogSearchFilters(
    val dateRange: DateRangeFilter? = null,
    val categoryFilter: CategoryFilter? = null,
    val severityFilter: PriorityFilter? = null,
    val userFilter: OwnerFilter? = null,
    val actionFilter: TagFilter? = null
)

data class DocumentSearchFilters(
    val dateRange: DateRangeFilter? = null,
    val typeFilter: TagFilter? = null,
    val categoryFilter: CategoryFilter? = null,
    val ownerFilter: OwnerFilter? = null,
    val contentFilter: TagFilter? = null
)

data class NotificationSearchFilters(
    val dateRange: DateRangeFilter? = null,
    val typeFilter: TagFilter? = null,
    val statusFilter: StatusFilter? = null,
    val recipientFilter: OwnerFilter? = null,
    val priorityFilter: PriorityFilter? = null
)

data class ReportSearchFilters(
    val dateRange: DateRangeFilter? = null,
    val typeFilter: TagFilter? = null,
    val categoryFilter: CategoryFilter? = null,
    val ownerFilter: OwnerFilter? = null,
    val statusFilter: StatusFilter? = null
)

data class PaymentSearchFilters(
    val dateRange: DateRangeFilter? = null,
    val statusFilter: StatusFilter? = null,
    val typeFilter: TagFilter? = null,
    val amountFilter: TagFilter? = null,
    val customerFilter: OwnerFilter? = null
)
