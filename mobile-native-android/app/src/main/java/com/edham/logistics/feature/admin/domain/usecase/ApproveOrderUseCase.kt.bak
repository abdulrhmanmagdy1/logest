package com.edham.logistics.feature.admin.domain.usecase

import com.edham.logistics.core.utils.Result
import com.edham.logistics.feature.admin.domain.model.ApproveOrderRequest
import com.edham.logistics.feature.admin.domain.repository.AdminRepository
import javax.inject.Inject

class ApproveOrderUseCase @Inject constructor(
    private val adminRepository: AdminRepository
) {
    
    suspend operator fun invoke(
        orderId: String,
        approvedBy: String,
        notes: String? = null
    ): Result<Unit> {
        val request = ApproveOrderRequest(
            orderId = orderId,
            approvedBy = approvedBy,
            notes = notes
        )
        return adminRepository.approveOrder(request)
    }
}
