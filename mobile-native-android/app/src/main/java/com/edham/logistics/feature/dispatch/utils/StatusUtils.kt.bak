package com.edham.logistics.feature.dispatch.utils

import com.edham.logistics.R
import com.edham.logistics.feature.dispatch.DispatchAssignment

/**
 * Utility class for status handling in dispatch system
 */
object StatusUtils {
    
    /**
     * Get assignment status icon resource
     */
    fun getAssignmentStatusIcon(status: DispatchAssignment.Status): Int {
        return when (status) {
            DispatchAssignment.Status.ASSIGNED -> R.drawable.ic_assignment_assigned
            DispatchAssignment.Status.IN_PROGRESS -> R.drawable.ic_assignment_in_progress
            DispatchAssignment.Status.COMPLETED -> R.drawable.ic_assignment_completed
            DispatchAssignment.Status.DELAYED -> R.drawable.ic_assignment_delayed
            DispatchAssignment.Status.CANCELLED -> R.drawable.ic_assignment_cancelled
        }
    }
    
    /**
     * Get assignment status color resource
     */
    fun getAssignmentStatusColor(status: DispatchAssignment.Status): Int {
        return when (status) {
            DispatchAssignment.Status.ASSIGNED -> R.color.assignment_assigned
            DispatchAssignment.Status.IN_PROGRESS -> R.color.assignment_in_progress
            DispatchAssignment.Status.COMPLETED -> R.color.assignment_completed
            DispatchAssignment.Status.DELAYED -> R.color.assignment_delayed
            DispatchAssignment.Status.CANCELLED -> R.color.assignment_cancelled
        }
    }
    
    /**
     * Get assignment status text in Arabic
     */
    fun getAssignmentStatusText(status: DispatchAssignment.Status): String {
        return when (status) {
            DispatchAssignment.Status.ASSIGNED -> "معين"
            DispatchAssignment.Status.IN_PROGRESS -> "قيد التنفيذ"
            DispatchAssignment.Status.COMPLETED -> "مكتمل"
            DispatchAssignment.Status.DELAYED -> "متأخر"
            DispatchAssignment.Status.CANCELLED -> "ملغي"
        }
    }
}
