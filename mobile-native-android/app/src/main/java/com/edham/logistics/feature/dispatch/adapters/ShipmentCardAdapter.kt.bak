package com.edham.logistics.feature.dispatch.adapters

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.ImageView
import android.widget.TextView
import androidx.recyclerview.widget.DiffUtil
import androidx.recyclerview.widget.ListAdapter
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.data.model.Shipment
import com.edham.logistics.utils.PriorityUtils

/**
 * Shipment Card Adapter for dispatch board
 * Shows pending shipments with drag support
 */
class ShipmentCardAdapter(
    private val onShipmentAction: (Shipment, String) -> Unit
) : ListAdapter<Shipment, ShipmentCardAdapter.ShipmentViewHolder>(ShipmentDiffCallback()) {
    
    private var onDragListener: ((View, Shipment) -> Unit)? = null
    
    fun setOnDragListener(listener: (View, Shipment) -> Unit) {
        onDragListener = listener
    }
    
    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): ShipmentViewHolder {
        val view = LayoutInflater.from(parent.context)
            .inflate(R.layout.item_shipment_card_dispatch, parent, false)
        return ShipmentViewHolder(view)
    }
    
    override fun onBindViewHolder(holder: ShipmentViewHolder, position: Int) {
        val shipment = getItem(position)
        holder.bind(shipment, onDragListener)
    }
    
    override fun getItemCount(): Int = currentList.size
    
    class ShipmentViewHolder(itemView: View) : RecyclerView.ViewHolder(itemView) {
        private val imagePriority: ImageView = itemView.findViewById(R.id.imagePriority)
        private val textShipmentRef: TextView = itemView.findViewById(R.id.textShipmentRef)
        private val textCustomerName: TextView = itemView.findViewById(R.id.textCustomerName)
        private val textPickupAddress: TextView = itemView.findViewById(R.id.textPickupAddress)
        private val textDeliveryAddress: TextView = itemView.findViewById(R.id.textDeliveryAddress)
        private val textPriority: TextView = itemView.findViewById(R.id.textPriority)
        private val textEstimatedTime: TextView = itemView.findViewById(R.id.textEstimatedTime)
        private val textWeight: TextView = itemView.findViewById(R.id.textWeight)
        private val textSpecialRequirements: TextView = itemView.findViewById(R.id.textSpecialRequirements)
        private val layoutActions: ViewGroup = itemView.findViewById(R.id.layoutActions)
        
        fun bind(shipment: Shipment, onDragListener: ((View, Shipment) -> Unit)?) {
            // Set tag for drag identification
            itemView.tag = shipment
            itemView.id = View.generateViewId()
            
            // Set priority indicator
            val priorityIcon = PriorityUtils.getPriorityIcon(shipment.priority)
            val priorityColor = PriorityUtils.getPriorityColor(shipment.priority)
            
            imagePriority.setImageResource(priorityIcon)
            imagePriority.setColorFilter(itemView.context.getColor(priorityColor))
            
            // Set shipment information
            textShipmentRef.text = shipment.referenceNumber
            textCustomerName.text = shipment.customerName
            textPickupAddress.text = shipment.pickupAddress
            textDeliveryAddress.text = shipment.deliveryAddress
            textPriority.text = shipment.priority
            textWeight.text = "${shipment.weight} kg"
            
            // Set special requirements
            val requirements = mutableListOf<String>()
            if (shipment.requiresRefrigeration) requirements.add("🧊 تبريد")
            if (shipment.isHazardous) requirements.add("⚠️ مواد خطرة")
            if (shipment.isExpress) requirements.add("🚀 شحنة سريعة")
            if (shipment.requiresInsurance) requirements.add("🛡️ تأمين إلزامي")
            
            textSpecialRequirements.text = if (requirements.isNotEmpty()) {
                requirements.joinToString("  ")
            } else {
                "لا توجد متطلبات خاصة"
            }
            
            // Set estimated time
            textEstimatedTime.text = "تقديري: ${shipment.estimatedDeliveryTime}"
            
            // Setup drag functionality
            itemView.setOnLongClickListener {
                onDragListener?.invoke(itemView, shipment)
                true
            }
            
            // Setup action buttons
            setupActionButtons(shipment)
        }
        
        private fun setupActionButtons(shipment: Shipment) {
            // Clear existing action buttons
            layoutActions.removeAllViews()
            
            // Add action buttons based on shipment status
            when (shipment.status) {
                Shipment.Status.PENDING -> {
                    addActionButton("تعيين سائق", "ASSIGN_DRIVER")
                    addActionButton("تعديل", "EDIT_SHIPMENT")
                    addActionButton("تعيين أولوية", "SET_PRIORITY")
                }
                
                Shipment.Status.ASSIGNED -> {
                    addActionButton("عرض التفاصيل", "VIEW_DETAILS")
                    addActionButton("إلغاء التعيين", "CANCEL_ASSIGNMENT")
                    addActionButton("تتبع", "TRACK_SHIPMENT")
                }
                
                else -> {
                    addActionButton("عرض التفاصيل", "VIEW_DETAILS")
                }
            }
        }
        
        private fun addActionButton(text: String, action: String) {
            val button = android.widget.Button(itemView.context).apply {
                setText(text)
                setTextColor(itemView.context.getColor(R.color.white))
                setBackgroundColor(itemView.context.getColor(R.color.primary))
                layoutParams = ViewGroup.LayoutParams(
                    ViewGroup.LayoutParams.WRAP_CONTENT,
                    ViewGroup.LayoutParams.WRAP_CONTENT
                ).apply {
                    setMargins(4, 0, 4, 0)
                }
                
                setOnClickListener {
                    // This would be handled by parent Fragment
                    onShipmentAction.invoke(getItem(bindingAdapterPosition), action)
                }
            }
            
            layoutActions.addView(button)
        }
    }
    
    private class ShipmentDiffCallback : DiffUtil.ItemCallback<Shipment>() {
        override fun areItemsTheSame(oldItem: Shipment, newItem: Shipment): Boolean {
            return oldItem.id == newItem.id
        }
        
        override fun areContentsTheSame(oldItem: Shipment, newItem: Shipment): Boolean {
            return oldItem == newItem
        }
    }
}
