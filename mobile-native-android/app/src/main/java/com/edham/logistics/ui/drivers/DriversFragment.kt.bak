package com.edham.logistics.ui.drivers

import android.os.Bundle
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.TextView
import androidx.fragment.app.Fragment
import androidx.recyclerview.widget.LinearLayoutManager
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.adapters.DriverManagementAdapter
import com.edham.logistics.domain.model.Driver
import com.edham.logistics.domain.model.EmergencyContact
import com.edham.logistics.domain.model.DriverDocument
import com.edham.logistics.domain.model.DriverPerformance

class DriversFragment : Fragment() {

    private lateinit var rvDrivers: RecyclerView
    private var tvTotalDrivers: TextView? = null
    private var tvActiveDrivers: TextView? = null
    private var tvOfflineDrivers: TextView? = null
    private lateinit var driverAdapter: DriverManagementAdapter

    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View? {
        return inflater.inflate(R.layout.fragment_drivers, container, false)
    }

    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        
        initViews(view)
        setupRecyclerView()
        loadDriverData()
    }

    private fun initViews(view: View) {
        rvDrivers = view.findViewById(R.id.rv_drivers)
        tvTotalDrivers = null // TextView not present in layout
        tvActiveDrivers = null // TextView not present in layout
        tvOfflineDrivers = null // TextView not present in layout
    }

    private fun setupRecyclerView() {
        driverAdapter = DriverManagementAdapter(getSampleDrivers()) { driver ->
            // Handle driver click
            // TODO: Navigate to driver details
        }
        
        rvDrivers.apply {
            layoutManager = LinearLayoutManager(requireContext())
            adapter = driverAdapter
        }
    }

    private fun loadDriverData() {
        val drivers = getSampleDrivers()
        
        driverAdapter.updateDrivers(drivers)
    }

    private fun getSampleDrivers(): List<Driver> {
        val emergencyContact = EmergencyContact("محمد", "0550000000", "أخ")
        val documents = listOf(DriverDocument("1", "1", "license", "12345", "2020-01-01", "2025-01-01", "url", "valid"))
        val performance = DriverPerformance(4.5f, 95.0f, 30, 5000.0, 8.5, 4.8f, 4.9f, 4.7f)

        return listOf(
            Driver("1", "أحمد محمد", "ahmed@example.com", "0551234567", "1234567890", "DL12345", "2025-12-31", "available", 4.5f, 100, 95, 5, null, null, null, null, null, true, "2024-05-12T10:00:00", null, "2020-01-01", 5000.0, null, emergencyContact, documents, performance),
            Driver("2", "محمد علي", "mohammed@example.com", "0552345678", "1234567891", "DL12346", "2025-12-31", "on_trip", 4.3f, 150, 140, 10, null, null, null, null, null, true, "2024-05-12T09:00:00", null, "2019-01-01", 5500.0, null, emergencyContact, documents, performance),
            Driver("3", "عبدالله سالم", "abdullah@example.com", "0553456789", "1234567892", "DL12347", "2025-12-31", "available", 4.7f, 200, 195, 5, null, null, null, null, null, true, "2024-05-12T08:00:00", null, "2021-01-01", 4800.0, null, emergencyContact, documents, performance),
            Driver("4", "سالم خالد", "salem@example.com", "0554567890", "1234567893", "DL12348", "2025-12-31", "offline", 4.2f, 80, 75, 5, null, null, null, null, null, false, "2024-05-12T07:00:00", null, "2018-01-01", 5200.0, null, emergencyContact, documents, performance),
            Driver("5", "خالد أحمد", "khaled@example.com", "0555678901", "1234567894", "DL12349", "2025-12-31", "on_break", 4.4f, 120, 115, 5, null, null, null, null, null, true, "2024-05-12T06:00:00", null, "2022-01-01", 4900.0, null, emergencyContact, documents, performance)
        )
    }
}
