package com.edham.logistics.presentation.util

import com.edham.logistics.domain.model.ShipmentStatus
import com.edham.logistics.domain.model.CargoType
import com.edham.logistics.domain.model.ShipmentPriority
import com.edham.logistics.R
import javax.inject.Inject
import javax.inject.Singleton

@Singleton
class ShipmentStatusFormatter @Inject constructor() {
    
    fun getStatusDisplayName(status: String): String {
        return when (status) {
            ShipmentStatus.PENDING.value -> ShipmentStatus.PENDING.displayName
            ShipmentStatus.CONFIRMED.value -> ShipmentStatus.CONFIRMED.displayName
            ShipmentStatus.ASSIGNED.value -> ShipmentStatus.ASSIGNED.displayName
            ShipmentStatus.PICKED_UP.value -> ShipmentStatus.PICKED_UP.displayName
            ShipmentStatus.IN_TRANSIT.value -> ShipmentStatus.IN_TRANSIT.displayName
            ShipmentStatus.AT_DELIVERY.value -> ShipmentStatus.AT_DELIVERY.displayName
            ShipmentStatus.DELIVERED.value -> ShipmentStatus.DELIVERED.displayName
            ShipmentStatus.CANCELLED.value -> ShipmentStatus.CANCELLED.displayName
            else -> status
        }
    }
    
    fun getStatusColor(status: String): Int {
        return when (status) {
            ShipmentStatus.PENDING.value -> R.color.status_pending
            ShipmentStatus.CONFIRMED.value -> R.color.status_confirmed
            ShipmentStatus.ASSIGNED.value -> R.color.status_assigned
            ShipmentStatus.PICKED_UP.value -> R.color.status_picked_up
            ShipmentStatus.IN_TRANSIT.value -> R.color.status_in_transit
            ShipmentStatus.AT_DELIVERY.value -> R.color.status_at_delivery
            ShipmentStatus.DELIVERED.value -> R.color.status_delivered
            ShipmentStatus.CANCELLED.value -> R.color.status_cancelled
            else -> R.color.status_default
        }
    }
    
    fun getStatusIcon(status: String): Int {
        return when (status) {
            ShipmentStatus.PENDING.value -> R.drawable.ic_status_pending
            ShipmentStatus.CONFIRMED.value -> R.drawable.ic_status_confirmed
            ShipmentStatus.ASSIGNED.value -> R.drawable.ic_status_assigned
            ShipmentStatus.PICKED_UP.value -> R.drawable.ic_status_picked_up
            ShipmentStatus.IN_TRANSIT.value -> R.drawable.ic_status_in_transit
            ShipmentStatus.AT_DELIVERY.value -> R.drawable.ic_status_at_delivery
            ShipmentStatus.DELIVERED.value -> R.drawable.ic_status_delivered
            ShipmentStatus.CANCELLED.value -> R.drawable.ic_status_cancelled
            else -> R.drawable.ic_status_default
        }
    }
    
    fun getCargoTypeDisplayName(cargoType: String): String {
        return when (cargoType) {
            CargoType.GENERAL.value -> CargoType.GENERAL.displayName
            CargoType.FROZEN.value -> CargoType.FROZEN.displayName
            CargoType.CHILLED.value -> CargoType.CHILLED.displayName
            CargoType.PHARMACEUTICAL.value -> CargoType.PHARMACEUTICAL.displayName
            CargoType.FOOD.value -> CargoType.FOOD.displayName
            CargoType.DRY_ICE.value -> CargoType.DRY_ICE.displayName
            CargoType.FLOWERS.value -> CargoType.FLOWERS.displayName
            else -> cargoType
        }
    }
    
    fun getCargoTypeIcon(cargoType: String): Int {
        return when (cargoType) {
            CargoType.GENERAL.value -> R.drawable.ic_cargo_general
            CargoType.FROZEN.value -> R.drawable.ic_cargo_frozen
            CargoType.CHILLED.value -> R.drawable.ic_cargo_chilled
            CargoType.PHARMACEUTICAL.value -> R.drawable.ic_cargo_pharmaceutical
            CargoType.FOOD.value -> R.drawable.ic_cargo_food
            CargoType.DRY_ICE.value -> R.drawable.ic_cargo_dry_ice
            CargoType.FLOWERS.value -> R.drawable.ic_cargo_flowers
            else -> R.drawable.ic_cargo_default
        }
    }
    
    fun getPriorityDisplayName(priority: String): String {
        return when (priority) {
            ShipmentPriority.LOW.value -> ShipmentPriority.LOW.displayName
            ShipmentPriority.NORMAL.value -> ShipmentPriority.NORMAL.displayName
            ShipmentPriority.HIGH.value -> ShipmentPriority.HIGH.displayName
            ShipmentPriority.URGENT.value -> ShipmentPriority.URGENT.displayName
            else -> priority
        }
    }
    
    fun getPriorityColor(priority: String): Int {
        return when (priority) {
            ShipmentPriority.LOW.value -> R.color.priority_low
            ShipmentPriority.NORMAL.value -> R.color.priority_normal
            ShipmentPriority.HIGH.value -> R.color.priority_high
            ShipmentPriority.URGENT.value -> R.color.priority_urgent
            else -> R.color.priority_normal
        }
    }
    
    fun isStatusActive(status: String): Boolean {
        return status in listOf(
            ShipmentStatus.CONFIRMED.value,
            ShipmentStatus.ASSIGNED.value,
            ShipmentStatus.PICKED_UP.value,
            ShipmentStatus.IN_TRANSIT.value,
            ShipmentStatus.AT_DELIVERY.value
        )
    }
    
    fun isStatusCompleted(status: String): Boolean {
        return status == ShipmentStatus.DELIVERED.value
    }
    
    fun isStatusCancelled(status: String): Boolean {
        return status == ShipmentStatus.CANCELLED.value
    }
}
