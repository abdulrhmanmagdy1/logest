package com.edham.logistics.feature.admin

import android.os.Bundle
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import androidx.fragment.app.Fragment
import androidx.lifecycle.Observer
import androidx.recyclerview.widget.LinearLayoutManager
import com.edham.logistics.R
import com.edham.logistics.databinding.FragmentAdminDashboardBinding
import com.edham.logistics.feature.admin.adapters.UserManagementAdapter
import com.edham.logistics.feature.admin.adapters.ActivityLogAdapter
import com.edham.logistics.utils.VoiceAlertManager
import timber.log.Timber
import java.text.SimpleDateFormat
import java.util.*

class AdminDashboardFragment : Fragment() {
    
    private var _binding: FragmentAdminDashboardBinding? = null
    private val binding get() = _binding!!
    
    private lateinit var adminService: AdminManagementService
    private lateinit var voiceAlertManager: VoiceAlertManager
    private lateinit var userManagementAdapter: UserManagementAdapter
    private lateinit var activityLogAdapter: ActivityLogAdapter
    
    private val dateFormat = SimpleDateFormat("MMM dd, yyyy HH:mm", Locale.getDefault())
    private val timeFormat = SimpleDateFormat("HH:mm:ss", Locale.getDefault())
    
    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View {
        _binding = FragmentAdminDashboardBinding.inflate(inflater, container, false)
        return binding.root
    }
    
    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        
        // Initialize services
        adminService = AdminManagementService(
            requireContext(),
            // api instance,
            // database instance
        )
        
        voiceAlertManager = VoiceAlertManager(requireContext())
        
        setupUI()
        setupRecyclerViews()
        setupClickListeners()
        setupObservers()
        
        // Initialize admin system
        initializeAdminSystem()
    }
    
    private fun setupUI() {
        // Large touch targets for one-hand usage
        binding.btnUsers.minimumHeight = 72.dp
        binding.btnUsers.minimumWidth = 120.dp
        
        binding.btnRoles.minimumHeight = 72.dp
        binding.btnRoles.minimumWidth = 120.dp
        
        binding.btnPermissions.minimumHeight = 72.dp
        binding.btnPermissions.minimumWidth = 120.dp
        
        binding.btnSettings.minimumHeight = 72.dp
        binding.btnSettings.minimumWidth = 120.dp
        
        binding.btnAnalytics.minimumHeight = 72.dp
        binding.btnAnalytics.minimumWidth = 120.dp
        
        // Dark mode optimized colors
        binding.cardSystemOverview.setCardBackgroundColor(
            requireContext().getColor(R.color.dark_surface)
        )
        
        binding.cardKPI.setCardBackgroundColor(
            requireContext().getColor(R.color.dark_surface)
        )
        
        binding.cardUserManagement.setCardBackgroundColor(
            requireContext().getColor(R.color.dark_surface)
        )
        
        binding.cardActivityLogs.setCardBackgroundColor(
            requireContext().getColor(R.color.dark_surface)
        )
        
        // High visibility status colors
        updateSystemStatusUI()
    }
    
    private fun setupRecyclerViews() {
        // Setup users RecyclerView
        userManagementAdapter = UserManagementAdapter { user, action ->
            onUserAction(user, action)
        }
        
        binding.recyclerViewUsers.apply {
            layoutManager = LinearLayoutManager(requireContext())
            adapter = userManagementAdapter
        }
        
        // Setup activity logs RecyclerView
        activityLogAdapter = ActivityLogAdapter()
        
        binding.recyclerViewActivityLogs.apply {
            layoutManager = LinearLayoutManager(requireContext())
            adapter = activityLogAdapter
        }
    }
    
    private fun setupClickListeners() {
        binding.btnUsers.setOnClickListener {
            openUserManagement()
        }
        
        binding.btnRoles.setOnClickListener {
            openRoleManagement()
        }
        
        binding.btnPermissions.setOnClickListener {
            openPermissionManagement()
        }
        
        binding.btnSettings.setOnClickListener {
            openSystemSettings()
        }
        
        binding.btnAnalytics.setOnClickListener {
            openAnalyticsCenter()
        }
        
        binding.btnRefreshData.setOnClickListener {
            refreshData()
        }
        
        binding.btnCreateUser.setOnClickListener {
            openCreateUserDialog()
        }
        
        binding.btnViewAllUsers.setOnClickListener {
            viewAllUsers()
        }
        
        binding.btnViewAllLogs.setOnClickListener {
            viewAllActivityLogs()
        }
        
        binding.etSearchUsers.setOnEditorActionListener { _, actionId, _ ->
            if (actionId == android.view.inputmethod.EditorInfo.IME_ACTION_SEARCH) {
                searchUsers()
                true
            } else {
                false
            }
        }
        
        binding.etSearchLogs.setOnEditorActionListener { _, actionId, _ ->
            if (actionId == android.view.inputmethod.EditorInfo.IME_ACTION_SEARCH) {
                searchActivityLogs()
                true
            } else {
                false
            }
        }
    }
    
    private fun setupObservers() {
        // Observe system overview
        adminService.systemOverview.observe(viewLifecycleOwner, Observer { overview ->
            updateSystemOverviewUI(overview)
        })
        
        // Observe KPI metrics
        adminService.kpiMetrics.observe(viewLifecycleOwner, Observer { metrics ->
            updateKPIMetricsUI(metrics)
        })
        
        // Observe users
        adminService.users.observe(viewLifecycleOwner, Observer { users ->
            updateUsersUI(users)
        })
        
        // Observe activity logs
        adminService.activityLogs.observe(viewLifecycleOwner, Observer { logs ->
            updateActivityLogsUI(logs)
        })
    }
    
    private fun initializeAdminSystem() {
        voiceAlertManager.speak("Initializing admin system")
        
        binding.root.post {
            adminService.initializeAdminSystem()
        }
    }
    
    private fun updateSystemOverviewUI(overview: SystemOverview) {
        // Update system statistics
        binding.tvTotalUsers.text = overview.totalUsers.toString()
        binding.tvActiveUsers.text = overview.activeUsers.toString()
        binding.tvTotalRoles.text = overview.totalRoles.toString()
        binding.tvTotalPermissions.text = overview.totalPermissions.toString()
        binding.tvActiveDrivers.text = overview.activeDrivers.toString()
        binding.tvTotalVehicles.text = overview.totalVehicles.toString()
        binding.tvActiveShipments.text = overview.activeShipments.toString()
        
        // Update system uptime
        val uptimeHours = overview.systemUptime / (1000 * 60 * 60)
        binding.tvSystemUptime.text = "${uptimeHours}h"
        
        // Update last sync time
        binding.tvLastSync.text = timeFormat.format(Date(overview.lastSync))
        
        // Update status indicators
        updateSystemStatusUI()
    }
    
    private fun updateKPIMetricsUI(metrics: KPIMetrics) {
        // Update KPI cards
        binding.tvUserGrowthRate.text = String.format("%.1f%%", metrics.userGrowthRate)
        binding.tvDriverUtilization.text = String.format("%.1f%%", metrics.driverUtilizationRate)
        binding.tvVehicleUtilization.text = String.format("%.1f%%", metrics.vehicleUtilizationRate)
        binding.tvShipmentCompletion.text = String.format("%.1f%%", metrics.shipmentCompletionRate)
        binding.tvAvgResponseTime.text = "${metrics.averageResponseTime}ms"
        binding.tvSystemPerformance.text = String.format("%.1f%%", metrics.systemPerformance)
        binding.tvErrorRate.text = String.format("%.2f%%", metrics.errorRate)
        
        // Update KPI indicators
        updateKPIIndicators(metrics)
    }
    
    private fun updateKPIIndicators(metrics: KPIMetrics) {
        // User growth rate indicator
        val userGrowthColor = when {
            metrics.userGrowthRate > 10.0 -> requireContext().getColor(R.color.status_completed)
            metrics.userGrowthRate > 0.0 -> requireContext().getColor(R.color.status_warning)
            else -> requireContext().getColor(R.color.status_error)
        }
        binding.viewUserGrowthIndicator.setBackgroundColor(userGrowthColor)
        
        // Driver utilization indicator
        val driverUtilColor = when {
            metrics.driverUtilizationRate > 80.0 -> requireContext().getColor(R.color.status_completed)
            metrics.driverUtilizationRate > 60.0 -> requireContext().getColor(R.color.status_warning)
            else -> requireContext().getColor(R.color.status_error)
        }
        binding.viewDriverUtilIndicator.setBackgroundColor(driverUtilColor)
        
        // System performance indicator
        val performanceColor = when {
            metrics.systemPerformance > 90.0 -> requireContext().getColor(R.color.status_completed)
            metrics.systemPerformance > 70.0 -> requireContext().getColor(R.color.status_warning)
            else -> requireContext().getColor(R.color.status_error)
        }
        binding.viewPerformanceIndicator.setBackgroundColor(performanceColor)
        
        // Error rate indicator
        val errorColor = when {
            metrics.errorRate < 1.0 -> requireContext().getColor(R.color.status_completed)
            metrics.errorRate < 5.0 -> requireContext().getColor(R.color.status_warning)
            else -> requireContext().getColor(R.color.status_error)
        }
        binding.viewErrorIndicator.setBackgroundColor(errorColor)
    }
    
    private fun updateUsersUI(users: List<com.edham.logistics.data.local.entity.User>) {
        // Show recent users (limit to 5 for dashboard)
        val recentUsers = users.takeLast(5).reversed()
        userManagementAdapter.updateUsers(recentUsers)
        
        // Update user count
        binding.tvRecentUsersCount.text = "${recentUsers.size} recent users"
        
        // Update search results count
        val searchQuery = binding.etSearchUsers.text.toString()
        if (searchQuery.isNotBlank()) {
            binding.tvUserSearchResults.text = "${users.size} users found"
        }
    }
    
    private fun updateActivityLogsUI(logs: List<com.edham.logistics.data.local.entity.ActivityLog>) {
        // Show recent logs (limit to 10 for dashboard)
        val recentLogs = logs.takeLast(10).reversed()
        activityLogAdapter.updateLogs(recentLogs)
        
        // Update log count
        binding.tvRecentLogsCount.text = "${recentLogs.size} recent activities"
        
        // Update search results count
        val searchQuery = binding.etSearchLogs.text.toString()
        if (searchQuery.isNotBlank()) {
            binding.tvLogSearchResults.text = "${logs.size} logs found"
        }
    }
    
    private fun updateSystemStatusUI() {
        // Update system status indicator
        binding.viewSystemStatus.setBackgroundColor(
            requireContext().getColor(R.color.status_completed)
        )
        binding.tvSystemStatus.text = "System Online"
        
        // Update sync status
        binding.viewSyncStatus.setBackgroundColor(
            requireContext().getColor(R.color.status_completed)
        )
        binding.tvSyncStatus.text = "Synced"
    }
    
    private fun onUserAction(user: com.edham.logistics.data.local.entity.User, action: UserAction) {
        when (action) {
            UserAction.VIEW -> {
                viewUserDetails(user)
            }
            UserAction.EDIT -> {
                openEditUserDialog(user)
            }
            UserAction.DELETE -> {
                confirmDeleteUser(user)
            }
            UserAction.ACTIVATE -> {
                toggleUserStatus(user, true)
            }
            UserAction.DEACTIVATE -> {
                toggleUserStatus(user, false)
            }
        }
    }
    
    private fun openUserManagement() {
        voiceAlertManager.speak("Opening user management")
        
        // Navigate to user management screen
        val userManagementFragment = UserManagementFragment()
        parentFragmentManager.beginTransaction()
            .replace(R.id.fragment_container, userManagementFragment)
            .addToBackStack(null)
            .commit()
    }
    
    private fun openRoleManagement() {
        voiceAlertManager.speak("Opening role management")
        
        // Navigate to role management screen
        val roleManagementFragment = RoleManagementFragment()
        parentFragmentManager.beginTransaction()
            .replace(R.id.fragment_container, roleManagementFragment)
            .addToBackStack(null)
            .commit()
    }
    
    private fun openPermissionManagement() {
        voiceAlertManager.speak("Opening permission management")
        
        // Navigate to permission management screen
        val permissionManagementFragment = PermissionManagementFragment()
        parentFragmentManager.beginTransaction()
            .replace(R.id.fragment_container, permissionManagementFragment)
            .addToBackStack(null)
            .commit()
    }
    
    private fun openSystemSettings() {
        voiceAlertManager.speak("Opening system settings")
        
        // Navigate to system settings screen
        val systemSettingsFragment = SystemSettingsFragment()
        parentFragmentManager.beginTransaction()
            .replace(R.id.fragment_container, systemSettingsFragment)
            .addToBackStack(null)
            .commit()
    }
    
    private fun openAnalyticsCenter() {
        voiceAlertManager.speak("Opening analytics center")
        
        // Navigate to analytics center screen
        val analyticsCenterFragment = AnalyticsCenterFragment()
        parentFragmentManager.beginTransaction()
            .replace(R.id.fragment_container, analyticsCenterFragment)
            .addToBackStack(null)
            .commit()
    }
    
    private fun refreshData() {
        voiceAlertManager.speak("Refreshing data")
        
        // Refresh admin data
        adminService.initializeAdminSystem()
        
        Toast.makeText(requireContext(), "Data refreshed", Toast.LENGTH_SHORT).show()
    }
    
    private fun openCreateUserDialog() {
        voiceAlertManager.speak("Creating new user")
        
        // Show create user dialog
        // Implementation would show user creation dialog
        Toast.makeText(requireContext(), "Create user dialog", Toast.LENGTH_SHORT).show()
    }
    
    private fun viewUserDetails(user: com.edham.logistics.data.local.entity.User) {
        voiceAlertManager.speak("Viewing user details")
        
        // Show user details
        val details = """
            User Details
            ===========
            Email: ${user.email}
            Name: ${user.firstName} ${user.lastName}
            Role: ${user.roleId}
            Status: ${if (user.isActive) "Active" else "Inactive"}
            Created: ${dateFormat.format(Date(user.createdAt))}
            Last Updated: ${dateFormat.format(Date(user.lastUpdated))}
        """.trimIndent()
        
        Toast.makeText(requireContext(), details, Toast.LENGTH_LONG).show()
    }
    
    private fun openEditUserDialog(user: com.edham.logistics.data.local.entity.User) {
        voiceAlertManager.speak("Editing user")
        
        // Show edit user dialog
        Toast.makeText(requireContext(), "Edit user: ${user.email}", Toast.LENGTH_SHORT).show()
    }
    
    private fun confirmDeleteUser(user: com.edham.logistics.data.local.entity.User) {
        voiceAlertManager.speak("Confirming user deletion")
        
        // Show confirmation dialog
        Toast.makeText(requireContext(), "Delete user: ${user.email}", Toast.LENGTH_SHORT).show()
    }
    
    private fun toggleUserStatus(user: com.edham.logistics.data.local.entity.User, activate: Boolean) {
        val action = if (activate) "Activating" else "Deactivating"
        voiceAlertManager.speak("$action user")
        
        // Toggle user status
        Toast.makeText(requireContext(), "$action user: ${user.email}", Toast.LENGTH_SHORT).show()
    }
    
    private fun viewAllUsers() {
        voiceAlertManager.speak("Viewing all users")
        
        // Navigate to full user list
        openUserManagement()
    }
    
    private fun viewAllActivityLogs() {
        voiceAlertManager.speak("Viewing all activity logs")
        
        // Navigate to full activity log list
        val activityLogsFragment = ActivityLogsFragment()
        parentFragmentManager.beginTransaction()
            .replace(R.id.fragment_container, activityLogsFragment)
            .addToBackStack(null)
            .commit()
    }
    
    private fun searchUsers() {
        val query = binding.etSearchUsers.text.toString().trim()
        
        if (query.isBlank()) {
            // Show all users
            adminService.users.value?.let { users ->
                updateUsersUI(users)
            }
            binding.tvUserSearchResults.text = ""
            return
        }
        
        // Search users
        adminService.searchUsers(query) { results ->
            updateUsersUI(results)
        }
    }
    
    private fun searchActivityLogs() {
        val query = binding.etSearchLogs.text.toString().trim()
        
        if (query.isBlank()) {
            // Show all logs
            adminService.activityLogs.value?.let { logs ->
                updateActivityLogsUI(logs)
            }
            binding.tvLogSearchResults.text = ""
            return
        }
        
        // Search activity logs
        adminService.searchActivityLogs(query) { results ->
            updateActivityLogsUI(results)
        }
    }
    
    private fun exportSystemData() {
        voiceAlertManager.speak("Exporting system data")
        
        // Export system data
        Toast.makeText(requireContext(), "System data exported", Toast.LENGTH_SHORT).show()
    }
    
    private fun generateSystemReport() {
        voiceAlertManager.speak("Generating system report")
        
        // Generate comprehensive system report
        Toast.makeText(requireContext(), "System report generated", Toast.LENGTH_SHORT).show()
    }
    
    private fun performSystemMaintenance() {
        voiceAlertManager.speak("Performing system maintenance")
        
        // Perform system maintenance tasks
        Toast.makeText(requireContext(), "System maintenance completed", Toast.LENGTH_SHORT).show()
    }
    
    override fun onResume() {
        super.onResume()
        
        // Refresh data when fragment resumes
        refreshData()
    }
    
    override fun onPause() {
        super.onPause()
        
        // Save current state
        // Implementation would save current filter and search state
    }
    
    override fun onDestroyView() {
        super.onDestroyView()
        
        // Cleanup resources
        adminService.cleanup()
        voiceAlertManager.cleanup()
        _binding = null
    }
    
    // Extension for dp to pixels
    private val Int.dp: Int
        get() = (this * resources.displayMetrics.density).toInt()
}

// Enums
enum class UserAction {
    VIEW, EDIT, DELETE, ACTIVATE, DEACTIVATE
}
