package com.edham.logistics.feature.admin.domain.repository

import com.edham.logistics.core.utils.Result
import com.edham.logistics.feature.admin.domain.model.*
import kotlinx.coroutines.flow.Flow

interface AdminRepository {
    // Dashboard
    suspend fun getDashboardData(): Flow<Result<AdminDashboardData>>
    
    // Shipments
    suspend fun getAllShipments(
        page: Int = 1,
        pageSize: Int = 20,
        status: String? = null,
        search: String? = null
    ): Flow<Result<List<AdminShipment>>>
    
    suspend fun getShipmentDetails(shipmentId: String): Result<AdminShipment>
    
    suspend fun createShipment(request: CreateShipmentRequest): Result<AdminShipment>
    
    suspend fun updateShipmentStatus(shipmentId: String, status: ShipmentStatus): Result<Unit>
    
    // Driver Assignment
    suspend fun assignDriver(request: AssignDriverRequest): Result<Unit>
    
    suspend fun reassignDriver(shipmentId: String, newDriverId: String, reason: String?): Result<Unit>
    
    // Order Management
    suspend fun getPendingOrders(): Flow<Result<List<AdminOrder>>>
    
    suspend fun approveOrder(request: ApproveOrderRequest): Result<Unit>
    
    suspend fun rejectOrder(request: RejectOrderRequest): Result<Unit>
    
    // Fleet Tracking
    suspend fun getFleetTracking(): Flow<Result<List<AdminTrip>>>
    
    suspend fun getDriverLocation(driverId: String): Result<LocationPoint>
    
    // Temperature Alerts
    suspend fun getTemperatureAlerts(
        alertLevel: String? = null,
        isResolved: Boolean? = null
    ): Flow<Result<List<TemperatureAlert>>>
    
    suspend fun resolveTemperatureAlert(alertId: String): Result<Unit>
    
    // User Management
    suspend fun getAllUsers(
        page: Int = 1,
        pageSize: Int = 20,
        role: String? = null,
        search: String? = null
    ): Flow<Result<List<User>>>
    
    suspend fun getUserDetails(userId: String): Result<User>
    
    suspend fun updateUser(request: UpdateUserRequest): Result<User>
    
    suspend fun deactivateUser(userId: String): Result<Unit>
    
    suspend fun activateUser(userId: String): Result<Unit>
    
    suspend fun createUser(user: User): Result<User>
    
    // Legacy methods for compatibility
    suspend fun getDashboardStats(): Result<DashboardStats>
    suspend fun getUsers(page: Int = 1, pageSize: Int = 20): Result<List<UserManagement>>
    suspend fun getUserById(id: String): Result<UserManagement>
    suspend fun createUser(user: UserManagement): Result<UserManagement>
    suspend fun updateUser(user: UserManagement): Result<UserManagement>
    suspend fun deleteUser(id: String): Result<Unit>
    suspend fun searchUsers(query: String): Result<List<UserManagement>>
    suspend fun getUsersByRole(role: String): Result<List<UserManagement>>
    suspend fun getUsersByStatus(status: String): Result<List<UserManagement>>
    
    suspend fun getSystemSettings(): Result<List<SystemSettings>>
    suspend fun updateSystemSetting(setting: SystemSettings): Result<SystemSettings>
    suspend fun resetToDefaults(): Result<Unit>
    
    suspend fun getActivityLogs(page: Int = 1, pageSize: Int = 50): Result<List<ActivityLog>>
    suspend fun getActivityLogsByUser(userId: String): Result<List<ActivityLog>>
    suspend fun getActivityLogsByAction(action: String): Result<List<ActivityLog>>
    
    fun observeDashboardStats(): Flow<DashboardStats>
    fun observeUsers(): Flow<List<UserManagement>>
    fun observeActivityLogs(): Flow<List<ActivityLog>>
}
