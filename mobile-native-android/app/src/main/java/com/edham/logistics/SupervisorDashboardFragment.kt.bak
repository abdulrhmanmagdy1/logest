package com.edham.logistics

import android.os.Bundle
import android.os.Handler
import android.os.Looper
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.TextView
import androidx.fragment.app.Fragment

class SupervisorDashboardFragment : Fragment() {
    private lateinit var tvActiveDrivers: TextView
    private lateinit var tvTodayTrips: TextView
    private lateinit var tvOnTimeDelivery: TextView
    private lateinit var tvCustomerSatisfaction: TextView

    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View? {
        return inflater.inflate(R.layout.fragment_supervisor_dashboard, container, false)
    }

    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)

        // Initialize views
        tvActiveDrivers = view.findViewById(R.id.tv_active_drivers)
        tvTodayTrips = view.findViewById(R.id.tv_today_trips)
        tvOnTimeDelivery = view.findViewById(R.id.tv_on_time_delivery)
        tvCustomerSatisfaction = view.findViewById(R.id.tv_customer_satisfaction)

        // Set Arabic titles
        view.findViewById<TextView>(R.id.tv_dashboard_title).text = "لوحة تحكم المشرف"
        view.findViewById<TextView>(R.id.tv_active_drivers_label).text = "السائقين النشطين"
        view.findViewById<TextView>(R.id.tv_today_trips_label).text = "رحلات اليوم"
        view.findViewById<TextView>(R.id.tv_on_time_delivery_label).text = "التوصيل في الوقت"
        view.findViewById<TextView>(R.id.tv_customer_satisfaction_label).text = "رضا العملاء"

        // Animate counter values
        animateCounter(tvActiveDrivers, 38)
        animateCounter(tvTodayTrips, 47)
        animateCounter(tvOnTimeDelivery, 94, "%")
        animateCounter(tvCustomerSatisfaction, 96, "%")
    }

    private fun animateCounter(textView: TextView, targetValue: Int, suffix: String = "") {
        val handler = Handler(Looper.getMainLooper())
        var currentValue = 0
        val increment = Math.max(1, targetValue / 30)
        val delay = 30L

        val runnable = object : Runnable {
            override fun run() {
                if (currentValue < targetValue) {
                    currentValue = Math.min(currentValue + increment, targetValue)
                    textView.text = "$currentValue$suffix"
                    handler.postDelayed(this, delay)
                } else {
                    textView.text = "$targetValue$suffix"
                }
            }
        }
        handler.post(runnable)
    }
}
