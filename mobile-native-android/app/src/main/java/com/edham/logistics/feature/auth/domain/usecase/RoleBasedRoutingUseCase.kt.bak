package com.edham.logistics.feature.auth.domain.usecase

import com.edham.logistics.feature.auth.domain.model.UserRole
import com.edham.logistics.feature.auth.domain.model.User
import javax.inject.Inject
import javax.inject.Singleton

@Singleton
class RoleBasedRoutingUseCase @Inject constructor() {
    
    suspend operator fun invoke(user: User): RoutingDestination {
        return when (user.role) {
            UserRole.ADMIN.value -> RoutingDestination.ADMIN_DASHBOARD
            UserRole.SUPERVISOR.value -> RoutingDestination.ADMIN_DASHBOARD
            UserRole.DRIVER.value -> RoutingDestination.DRIVER_DASHBOARD
            UserRole.CUSTOMER.value -> RoutingDestination.CUSTOMER_DASHBOARD
            UserRole.ACCOUNTANT.value -> RoutingDestination.ACCOUNTANT_DASHBOARD
            UserRole.WORKSHOP.value -> RoutingDestination.WORKSHOP_DASHBOARD
            else -> RoutingDestination.CUSTOMER_DASHBOARD // Default
        }
    }
    
    fun getDashboardFragmentId(role: String): Int {
        return when (role) {
            UserRole.ADMIN.value -> com.edham.logistics.R.id.action_loginFragment_to_adminDashboardFragment
            UserRole.SUPERVISOR.value -> com.edham.logistics.R.id.action_loginFragment_to_adminDashboardFragment
            UserRole.DRIVER.value -> com.edham.logistics.R.id.action_loginFragment_to_driverDashboardFragment
            UserRole.CUSTOMER.value -> com.edham.logistics.R.id.action_loginFragment_to_customerDashboardFragment
            UserRole.ACCOUNTANT.value -> com.edham.logistics.R.id.action_loginFragment_to_accountantDashboardFragment
            UserRole.WORKSHOP.value -> com.edham.logistics.R.id.action_loginFragment_to_workshopDashboardFragment
            else -> com.edham.logistics.R.id.action_loginFragment_to_customerDashboardFragment
        }
    }
}

data class RoutingDestination(
    val fragmentId: Int,
    val title: String,
    val requiresLocation: Boolean = false,
    val requiresPermissions: List<String> = emptyList()
) {
    companion object {
        val ADMIN_DASHBOARD = RoutingDestination(
            fragmentId = com.edham.logistics.R.id.adminDashboardFragment,
            title = "لوحة تحكم المدير"
        )
        
        val DRIVER_DASHBOARD = RoutingDestination(
            fragmentId = com.edham.logistics.R.id.driverDashboardFragment,
            title = "لوحة تحكم السائق",
            requiresLocation = true,
            requiresPermissions = listOf(
                android.Manifest.permission.ACCESS_FINE_LOCATION,
                android.Manifest.permission.ACCESS_COARSE_LOCATION
            )
        )
        
        val CUSTOMER_DASHBOARD = RoutingDestination(
            fragmentId = com.edham.logistics.R.id.customerDashboardFragment,
            title = "لوحة تحكم العميل"
        )
        
        val ACCOUNTANT_DASHBOARD = RoutingDestination(
            fragmentId = com.edham.logistics.R.id.accountantDashboardFragment,
            title = "لوحة تحكم المحاسب"
        )
        
        val WORKSHOP_DASHBOARD = RoutingDestination(
            fragmentId = com.edham.logistics.R.id.workshopDashboardFragment,
            title = "لوحة تحكم الورشة"
        )
    }
}
