package com.edham.logistics.feature.driver.presentation.adapter

import android.view.LayoutInflater
import android.view.ViewGroup
import androidx.recyclerview.widget.DiffUtil
import androidx.recyclerview.widget.ListAdapter
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.databinding.ItemRecentDeliveryBinding
import com.edham.logistics.feature.driver.domain.model.DriverTrip
import javax.inject.Inject

class RecentDeliveriesAdapter @Inject constructor(
    private val onDeliveryClick: (DriverTrip) -> Unit
) : ListAdapter<DriverTrip, RecentDeliveriesAdapter.RecentDeliveryViewHolder>(RecentDeliveryDiffCallback()) {

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): RecentDeliveryViewHolder {
        val binding = ItemRecentDeliveryBinding.inflate(
            LayoutInflater.from(parent.context),
            parent,
            false
        )
        return RecentDeliveryViewHolder(binding)
    }

    override fun onBindViewHolder(holder: RecentDeliveryViewHolder, position: Int) {
        holder.bind(getItem(position))
    }

    inner class RecentDeliveryViewHolder(
        private val binding: ItemRecentDeliveryBinding
    ) : RecyclerView.ViewHolder(binding.root) {

        fun bind(delivery: DriverTrip) {
            binding.apply {
                textTrackingNumber.text = delivery.trackingNumber
                textCustomerName.text = delivery.customerName
                textPickupLocation.text = delivery.pickupLocation.address
                textDeliveryLocation.text = delivery.deliveryLocation.address
                textCargoType.text = formatCargoType(delivery.cargoType)
                textWeight.text = "${delivery.weight} كجم"
                textPrice.text = formatPrice(delivery.price)
                textCompletedAt.text = formatDateTime(delivery.completedAt)
                
                // Set status to delivered for recent deliveries
                textStatus.text = "تم التسليم"
                textStatus.setTextColor(android.graphics.Color.parseColor("#4CAF50"))
                
                root.setOnClickListener {
                    onDeliveryClick(delivery)
                }
                
                // Show rating if available (in real app, this would come from delivery data)
                textRating.text = "⭐ 4.8"
                textRating.visible()
            }
        }
        
        private fun formatCargoType(cargoType: String): String {
            return when (cargoType) {
                "general" -> "بضائع عامة"
                "refrigerated" -> "بضائع مبردة"
                "fragile" -> "بضائع قابلة للكسر"
                "heavy" -> "بضائع ثقيلة"
                "urgent" -> "بضائع عاجلة"
                "documents" -> "مستندات"
                "electronics" -> "إلكترونيات"
                "food" -> "مواد غذائية"
                "medical" -> "معدات طبية"
                "chemicals" -> "مواد كيميائية"
                "livestock" -> "مواشي"
                "vehicles" -> "مركبات"
                else -> cargoType
            }
        }
        
        private fun formatPrice(price: Double): String {
            return String.format("%.2f ريال", price)
        }
        
        private fun formatDateTime(dateTime: String?): String {
            return dateTime?.let { 
                // In real app, we would format the date time properly
                it.substring(0, 16).replace("T", " ")
            } ?: "غير متوفر"
        }
    }

    private class RecentDeliveryDiffCallback : DiffUtil.ItemCallback<DriverTrip>() {
        override fun areItemsTheSame(oldItem: DriverTrip, newItem: DriverTrip): Boolean {
            return oldItem.id == newItem.id
        }

        override fun areContentsTheSame(oldItem: DriverTrip, newItem: DriverTrip): Boolean {
            return oldItem == newItem
        }
    }
}
