package com.edham.logistics.offline

/**
 * Offline-First Architecture Design
 * 
 * Core Components:
 * 1. Local Room Database - Primary data source
 * 2. Background Sync Service - Automatic data synchronization
 * 3. Sync Queue System - Queue offline operations
 * 4. Retry Mechanism - Handle failed requests
 * 5. Conflict Resolution - Resolve data conflicts
 * 6. Caching Strategy - Optimize data storage
 * 7. Network Monitoring - Detect connectivity changes
 */

sealed class SyncStatus {
    object SYNCED : SyncStatus()
    object PENDING : SyncStatus()
    object FAILED : SyncStatus()
    object CONFLICT : SyncStatus()
}

sealed class NetworkStatus {
    object ONLINE : NetworkStatus()
    object OFFLINE : NetworkStatus()
    object CONNECTING : NetworkStatus()
}

data class SyncOperation(
    val id: String,
    val type: OperationType,
    val data: Any,
    val timestamp: Long,
    val status: SyncStatus = SyncStatus.PENDING,
    val retryCount: Int = 0
)

enum class OperationType {
    CREATE_SHIPMENT,
    UPDATE_SHIPMENT,
    DELETE_SHIPMENT,
    UPDATE_LOCATION,
    UPDATE_STATUS,
    UPLOAD_PROOF,
    SYNC_SHIPMENTS,
    SYNC_MAPS_DATA
}

data class ConflictResolution(
    val localData: Any,
    val serverData: Any,
    val resolution: ConflictStrategy,
    val resolvedData: Any
)

enum class ConflictStrategy {
    CLIENT_WINS,
    SERVER_WINS,
    MERGE,
    MANUAL
}

interface OfflineRepository {
    suspend fun <T> getData(query: String): Result<T>
    suspend fun <T> saveData(data: T): Result<Unit>
    suspend fun syncData(): Result<Unit>
    suspend fun clearCache(): Result<Unit>
}

interface SyncQueue {
    suspend fun enqueue(operation: SyncOperation)
    suspend fun dequeue(): SyncOperation?
    suspend fun getPendingOperations(): List<SyncOperation>
    suspend fun markCompleted(operationId: String)
    suspend fun markFailed(operationId: String)
}

interface ConflictResolver {
    suspend fun resolveConflict(local: Any, server: Any): ConflictResolution
}

interface NetworkMonitor {
    fun observeNetworkStatus(): Flow<NetworkStatus>
    fun isOnline(): Boolean
}

data class SyncMetrics(
    val totalOperations: Int,
    val successfulOperations: Int,
    val failedOperations: Int,
    val pendingOperations: Int,
    val lastSyncTime: Long,
    val averageSyncTime: Long
)
