package com.edham.logistics.feature.admin.domain.usecase

import com.edham.logistics.core.utils.Result
import com.edham.logistics.feature.admin.domain.model.UserManagement
import com.edham.logistics.feature.admin.domain.repository.AdminRepository
import kotlinx.coroutines.flow.Flow
import javax.inject.Inject
import javax.inject.Singleton

@Singleton
class GetUsersUseCase @Inject constructor(
    private val adminRepository: AdminRepository
) {
    suspend operator fun invoke(
        page: Int = 1,
        pageSize: Int = 20
    ): Result<List<UserManagement>> {
        return adminRepository.getUsers(page, pageSize)
    }
    
    suspend fun getUserById(id: String): Result<UserManagement> {
        return adminRepository.getUserById(id)
    }
    
    suspend fun searchUsers(query: String): Result<List<UserManagement>> {
        return adminRepository.searchUsers(query)
    }
    
    suspend fun getUsersByRole(role: String): Result<List<UserManagement>> {
        return adminRepository.getUsersByRole(role)
    }
    
    suspend fun getUsersByStatus(status: String): Result<List<UserManagement>> {
        return adminRepository.getUsersByStatus(status)
    }
    
    fun observeUsers(): Flow<List<UserManagement>> {
        return adminRepository.observeUsers()
    }
}
