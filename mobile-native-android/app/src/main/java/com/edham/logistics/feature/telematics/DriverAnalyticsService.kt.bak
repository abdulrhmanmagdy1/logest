package com.edham.logistics.feature.telematics

import android.util.Log
import kotlinx.coroutines.Dispatchers
import kotlinx.coroutines.flow.Flow
import kotlinx.coroutines.flow.flow
import kotlinx.coroutines.flow.flowOn
import kotlinx.coroutines.withContext
import java.time.LocalDateTime
import java.time.temporal.ChronoUnit

/**
 * Driver Analytics Service - Comprehensive driver performance analytics and insights
 * Provides advanced analytics for driver behavior, performance, and coaching recommendations
 */
class DriverAnalyticsService {
    
    companion object {
        private const val TAG = "DriverAnalyticsService"
        
        // Performance thresholds
        private const val EXCELLENT_PERFORMANCE_THRESHOLD = 90.0
        private const val GOOD_PERFORMANCE_THRESHOLD = 75.0
        private const val AVERAGE_PERFORMANCE_THRESHOLD = 60.0
        
        // Risk assessment thresholds
        private const val HIGH_RISK_THRESHOLD = 30.0
        private const val MEDIUM_RISK_THRESHOLD = 60.0
        
        // Coaching recommendation thresholds
        private const val COACHING_NEEDED_THRESHOLD = 70.0
        private const val IMMEDIATE_COACHING_THRESHOLD = 50.0
    }
    
    private val behaviorAnalytics = BehaviorAnalytics()
    private val safetyScoring = SafetyScoring()
    private val fuelEfficiencyScoring = FuelEfficiencyScoring()
    private val drivingHistory = DrivingHistory()
    
    /**
     * Generate comprehensive driver analytics report
     */
    suspend fun generateDriverAnalytics(
        driverId: String,
        timeWindow: TimeWindow = TimeWindow.LAST_30_DAYS
    ): DriverAnalyticsReport {
        return withContext(Dispatchers.IO) {
            try {
                Log.d(TAG, "Generating analytics for driver: $driverId")
                
                // Get driving sessions for the time window
                val sessions = drivingHistory.getDriverSessions(driverId, timeWindow)
                
                // Generate individual analytics components
                val behaviorAnalysis = behaviorAnalytics.analyzeDriverBehavior(sessions)
                val safetyAnalysis = generateSafetyAnalytics(sessions)
                val efficiencyAnalysis = generateEfficiencyAnalytics(sessions)
                val riskAssessment = generateRiskAssessment(sessions)
                val performanceTrends = generatePerformanceTrends(driverId, timeWindow)
                val coachingInsights = generateCoachingInsights(sessions)
                val comparativeAnalysis = generateComparativeAnalysis(driverId, sessions)
                
                // Calculate overall performance score
                val overallScore = calculateOverallScore(
                    behaviorAnalysis,
                    safetyAnalysis,
                    efficiencyAnalysis,
                    riskAssessment
                )
                
                DriverAnalyticsReport(
                    driverId = driverId,
                    generatedAt = LocalDateTime.now(),
                    timeWindow = timeWindow,
                    overallScore = overallScore,
                    behaviorAnalysis = behaviorAnalysis,
                    safetyAnalysis = safetyAnalysis,
                    efficiencyAnalysis = efficiencyAnalysis,
                    riskAssessment = riskAssessment,
                    performanceTrends = performanceTrends,
                    coachingInsights = coachingInsights,
                    comparativeAnalysis = comparativeAnalysis,
                    summary = generateAnalyticsSummary(overallScore, behaviorAnalysis, safetyAnalysis, efficiencyAnalysis)
                )
                
            } catch (e: Exception) {
                Log.e(TAG, "Error generating driver analytics", e)
                DriverAnalyticsReport.createError(driverId, timeWindow)
            }
        }
    }
    
    /**
     * Generate real-time driver analytics stream
     */
    fun getRealTimeAnalytics(driverId: String): Flow<DriverAnalyticsUpdate> {
        return flow {
            try {
                // Emit current analytics
                val currentAnalytics = generateDriverAnalytics(driverId, TimeWindow.LAST_24_HOURS)
                emit(DriverAnalyticsUpdate(currentAnalytics, UpdateType.INITIAL))
                
                // Simulate real-time updates (in real implementation, this would listen to live data)
                while (true) {
                    kotlinx.coroutines.delay(30000) // Update every 30 seconds
                    
                    val updatedAnalytics = generateDriverAnalytics(driverId, TimeWindow.LAST_24_HOURS)
                    emit(DriverAnalyticsUpdate(updatedAnalytics, UpdateType.REAL_TIME))
                }
                
            } catch (e: Exception) {
                Log.e(TAG, "Error in real-time analytics stream", e)
                emit(DriverAnalyticsUpdate.createError(driverId))
            }
        }.flowOn(Dispatchers.IO)
    }
    
    /**
     * Generate fleet-wide analytics comparison
     */
    suspend fun generateFleetAnalyticsComparison(
        driverIds: List<String>,
        timeWindow: TimeWindow = TimeWindow.LAST_30_DAYS
    ): FleetAnalyticsComparison {
        return withContext(Dispatchers.IO) {
            try {
                Log.d(TAG, "Generating fleet analytics for ${driverIds.size} drivers")
                
                val driverAnalytics = mutableListOf<DriverAnalyticsReport>()
                
                for (driverId in driverIds) {
                    val analytics = generateDriverAnalytics(driverId, timeWindow)
                    driverAnalytics.add(analytics)
                }
                
                // Calculate fleet metrics
                val fleetMetrics = calculateFleetMetrics(driverAnalytics)
                val ranking = generateDriverRanking(driverAnalytics)
                val topPerformers = identifyTopPerformers(driverAnalytics)
                val improvementAreas = identifyFleetImprovementAreas(driverAnalytics)
                
                FleetAnalyticsComparison(
                    generatedAt = LocalDateTime.now(),
                    timeWindow = timeWindow,
                    totalDrivers = driverIds.size,
                    fleetMetrics = fleetMetrics,
                    driverAnalytics = driverAnalytics,
                    ranking = ranking,
                    topPerformers = topPerformers,
                    improvementAreas = improvementAreas
                )
                
            } catch (e: Exception) {
                Log.e(TAG, "Error generating fleet analytics comparison", e)
                FleetAnalyticsComparison.createError(driverIds.size, timeWindow)
            }
        }
    }
    
    /**
     * Generate predictive analytics for driver performance
     */
    suspend fun generatePredictiveAnalytics(
        driverId: String,
        forecastDays: Int = 30
    ): PredictiveAnalytics {
        return withContext(Dispatchers.IO) {
            try {
                Log.d(TAG, "Generating predictive analytics for driver: $driverId")
                
                // Get historical data for prediction
                val historicalData = drivingHistory.getDriverSessions(driverId, TimeWindow.LAST_90_DAYS)
                
                // Generate predictions
                val performanceForecast = generatePerformanceForecast(historicalData, forecastDays)
                val riskPrediction = generateRiskPrediction(historicalData)
                val efficiencyProjection = generateEfficiencyProjection(historicalData)
                val coachingNeeds = predictCoachingNeeds(historicalData)
                
                PredictiveAnalytics(
                    driverId = driverId,
                    generatedAt = LocalDateTime.now(),
                    forecastPeriod = forecastDays,
                    performanceForecast = performanceForecast,
                    riskPrediction = riskPrediction,
                    efficiencyProjection = efficiencyProjection,
                    coachingNeeds = coachingNeeds,
                    confidence = calculatePredictionConfidence(historicalData)
                )
                
            } catch (e: Exception) {
                Log.e(TAG, "Error generating predictive analytics", e)
                PredictiveAnalytics.createError(driverId, forecastDays)
            }
        }
    }
    
    // Private helper methods
    
    private fun generateSafetyAnalytics(sessions: List<DrivingSession>): SafetyAnalytics {
        val totalEvents = sessions.sumOf { 
            it.harshBrakingCount + it.rapidAccelerationCount + it.sharpTurnCount + it.seatbeltViolations 
        }
        val avgSafetyScore = sessions.map { it.safetyScore }.average()
        val safetyTrend = calculateSafetyTrend(sessions)
        val highRiskEvents = sessions.filter { it.safetyScore < 60 }.size
        
        return SafetyAnalytics(
            averageSafetyScore = avgSafetyScore,
            totalSafetyEvents = totalEvents,
            safetyTrend = safetyTrend,
            highRiskSessions = highRiskEvents,
            safetyLevel = determineSafetyLevel(avgSafetyScore),
            eventBreakdown = generateSafetyEventBreakdown(sessions)
        )
    }
    
    private fun generateEfficiencyAnalytics(sessions: List<DrivingSession>): EfficiencyAnalytics {
        val avgEfficiencyScore = sessions.map { it.efficiencyScore }.average()
        val totalDistance = sessions.sumOf { it.distance }
        val totalFuel = sessions.sumOf { it.fuelConsumed }
        val avgFuelConsumption = if (totalDistance > 0) (totalFuel / totalDistance) * 100 else 0.0 // L/100km
        val totalIdleTime = sessions.sumOf { it.idleTime }
        
        return EfficiencyAnalytics(
            averageEfficiencyScore = avgEfficiencyScore,
            totalDistance = totalDistance,
            totalFuelConsumed = totalFuel,
            averageFuelConsumption = avgFuelConsumption,
            totalIdleTime = totalIdleTime,
            efficiencyLevel = determineEfficiencyLevel(avgEfficiencyScore),
            fuelEfficiencyTrend = calculateEfficiencyTrend(sessions)
        )
    }
    
    private fun generateRiskAssessment(sessions: List<DrivingSession>): RiskAssessment {
        val overallRiskScore = calculateOverallRiskScore(sessions)
        val riskFactors = identifyRiskFactors(sessions)
        val highRiskBehaviors = identifyHighRiskBehaviors(sessions)
        val accidentRisk = calculateAccidentRisk(sessions)
        
        return RiskAssessment(
            overallRiskScore = overallRiskScore,
            riskLevel = determineRiskLevel(overallRiskScore),
            riskFactors = riskFactors,
            highRiskBehaviors = highRiskBehaviors,
            accidentRisk = accidentRisk,
            recommendations = generateRiskRecommendations(overallRiskScore, riskFactors)
        )
    }
    
    private fun generatePerformanceTrends(driverId: String, timeWindow: TimeWindow): PerformanceTrends {
        // Get data for different time periods to calculate trends
        val currentPeriod = drivingHistory.getDriverSessions(driverId, timeWindow)
        val previousPeriod = drivingHistory.getDriverSessions(driverId, getPreviousTimeWindow(timeWindow))
        
        val scoreTrend = calculateScoreTrend(currentPeriod, previousPeriod)
        val behaviorTrend = calculateBehaviorTrend(currentPeriod, previousPeriod)
        val efficiencyTrend = calculateEfficiencyTrend(currentPeriod, previousPeriod)
        
        return PerformanceTrends(
            scoreTrend = scoreTrend,
            behaviorTrend = behaviorTrend,
            efficiencyTrend = efficiencyTrend,
            overallTrend = determineOverallTrend(scoreTrend, behaviorTrend, efficiencyTrend),
            trendPeriod = timeWindow
        )
    }
    
    private fun generateCoachingInsights(sessions: List<DrivingSession>): CoachingInsights {
        val coachingAreas = identifyCoachingAreas(sessions)
        val priorityLevel = determineCoachingPriority(sessions)
        val specificRecommendations = generateSpecificRecommendations(sessions)
        val improvementPotential = calculateImprovementPotential(sessions)
        
        return CoachingInsights(
            coachingNeeded = priorityLevel != CoachingPriority.NONE,
            priorityLevel = priorityLevel,
            coachingAreas = coachingAreas,
            specificRecommendations = specificRecommendations,
            improvementPotential = improvementPotential,
            estimatedImprovementTime = estimateImprovementTime(coachingAreas)
        )
    }
    
    private fun generateComparativeAnalysis(driverId: String, sessions: List<DrivingSession>): ComparativeAnalysis {
        // In real implementation, this would compare against fleet averages
        val fleetAverageScore = 75.0 // Placeholder
        val driverScore = sessions.map { it.overallScore }.average()
        val percentileRank = calculatePercentileRank(driverScore, fleetAverageScore)
        
        return ComparativeAnalysis(
            fleetAverageScore = fleetAverageScore,
            driverScore = driverScore,
            percentileRank = percentileRank,
            comparisonToPeers = generatePeerComparison(driverScore),
            strengths = identifyDriverStrengths(sessions),
            weaknesses = identifyDriverWeaknesses(sessions)
        )
    }
    
    private fun calculateOverallScore(
        behavior: BehaviorAnalysis,
        safety: SafetyAnalytics,
        efficiency: EfficiencyAnalytics,
        risk: RiskAssessment
    ): Double {
        val behaviorWeight = 0.3
        val safetyWeight = 0.3
        val efficiencyWeight = 0.25
        val riskWeight = 0.15
        
        return (behavior.overallScore * behaviorWeight +
                safety.averageSafetyScore * safetyWeight +
                efficiency.averageEfficiencyScore * efficiencyWeight +
                (100 - risk.overallRiskScore) * riskWeight)
    }
    
    private fun generateAnalyticsSummary(
        overallScore: Double,
        behavior: BehaviorAnalysis,
        safety: SafetyAnalytics,
        efficiency: EfficiencyAnalytics
    ): AnalyticsSummary {
        return AnalyticsSummary(
            overallPerformance = determinePerformanceLevel(overallScore),
            keyStrengths = identifyKeyStrengths(behavior, safety, efficiency),
            areasForImprovement = identifyAreasForImprovement(behavior, safety, efficiency),
            immediateActions = generateImmediateActions(behavior, safety, efficiency),
            longTermGoals = generateLongTermGoals(overallScore)
        )
    }
    
    // Additional helper methods for calculations
    private fun determineSafetyLevel(score: Double): SafetyLevel {
        return when {
            score >= EXCELLENT_PERFORMANCE_THRESHOLD -> SafetyLevel.EXCELLENT
            score >= GOOD_PERFORMANCE_THRESHOLD -> SafetyLevel.GOOD
            score >= AVERAGE_PERFORMANCE_THRESHOLD -> SafetyLevel.AVERAGE
            else -> SafetyLevel.POOR
        }
    }
    
    private fun determineEfficiencyLevel(score: Double): EfficiencyLevel {
        return when {
            score >= EXCELLENT_PERFORMANCE_THRESHOLD -> EfficiencyLevel.EXCELLENT
            score >= GOOD_PERFORMANCE_THRESHOLD -> EfficiencyLevel.GOOD
            score >= AVERAGE_PERFORMANCE_THRESHOLD -> EfficiencyLevel.AVERAGE
            else -> EfficiencyLevel.POOR
        }
    }
    
    private fun determineRiskLevel(score: Double): RiskLevel {
        return when {
            score <= HIGH_RISK_THRESHOLD -> RiskLevel.HIGH
            score <= MEDIUM_RISK_THRESHOLD -> RiskLevel.MEDIUM
            else -> RiskLevel.LOW
        }
    }
    
    private fun determinePerformanceLevel(score: Double): PerformanceLevel {
        return when {
            score >= EXCELLENT_PERFORMANCE_THRESHOLD -> PerformanceLevel.EXCELLENT
            score >= GOOD_PERFORMANCE_THRESHOLD -> PerformanceLevel.GOOD
            score >= AVERAGE_PERFORMANCE_THRESHOLD -> PerformanceLevel.AVERAGE
            else -> PerformanceLevel.POOR
        }
    }
    
    private fun determineCoachingPriority(sessions: List<DrivingSession>): CoachingPriority {
        val avgScore = sessions.map { it.overallScore }.average()
        return when {
            avgScore < IMMEDIATE_COACHING_THRESHOLD -> CoachingPriority.IMMEDIATE
            avgScore < COACHING_NEEDED_THRESHOLD -> CoachingPriority.RECOMMENDED
            else -> CoachingPriority.NONE
        }
    }
    
    private fun getPreviousTimeWindow(window: TimeWindow): TimeWindow {
        return when (window) {
            TimeWindow.LAST_24_HOURS -> TimeWindow.PREVIOUS_24_HOURS
            TimeWindow.LAST_7_DAYS -> TimeWindow.PREVIOUS_7_DAYS
            TimeWindow.LAST_30_DAYS -> TimeWindow.PREVIOUS_30_DAYS
            TimeWindow.LAST_90_DAYS -> TimeWindow.PREVIOUS_90_DAYS
        }
    }
    
    // Placeholder methods for complex calculations
    private fun calculateSafetyTrend(sessions: List<DrivingSession>): TrendDirection = TrendDirection.STABLE
    private fun generateSafetyEventBreakdown(sessions: List<DrivingSession>): Map<String, Int> = emptyMap()
    private fun calculateEfficiencyTrend(sessions: List<DrivingSession>): TrendDirection = TrendDirection.STABLE
    private fun calculateOverallRiskScore(sessions: List<DrivingSession>): Double = 50.0
    private fun identifyRiskFactors(sessions: List<DrivingSession>): List<String> = emptyList()
    private fun identifyHighRiskBehaviors(sessions: List<DrivingSession>): List<String> = emptyList()
    private fun calculateAccidentRisk(sessions: List<DrivingSession>): Double = 10.0
    private fun generateRiskRecommendations(score: Double, factors: List<String>): List<String> = emptyList()
    private fun calculateScoreTrend(current: List<DrivingSession>, previous: List<DrivingSession>): TrendDirection = TrendDirection.STABLE
    private fun calculateBehaviorTrend(current: List<DrivingSession>, previous: List<DrivingSession>): TrendDirection = TrendDirection.STABLE
    private fun calculateEfficiencyTrend(current: List<DrivingSession>, previous: List<DrivingSession>): TrendDirection = TrendDirection.STABLE
    private fun determineOverallTrend(score: TrendDirection, behavior: TrendDirection, efficiency: TrendDirection): TrendDirection = TrendDirection.STABLE
    private fun identifyCoachingAreas(sessions: List<DrivingSession>): List<String> = emptyList()
    private fun generateSpecificRecommendations(sessions: List<DrivingSession>): List<String> = emptyList()
    private fun calculateImprovementPotential(sessions: List<DrivingSession>): Double = 20.0
    private fun estimateImprovementTime(areas: List<String>): Int = 30
    private fun calculatePercentileRank(driverScore: Double, fleetAverage: Double): Double = 75.0
    private fun generatePeerComparison(score: Double): String = "Above average"
    private fun identifyDriverStrengths(sessions: List<DrivingSession>): List<String> = emptyList()
    private fun identifyDriverWeaknesses(sessions: List<DrivingSession>): List<String> = emptyList()
    private fun identifyKeyStrengths(behavior: BehaviorAnalysis, safety: SafetyAnalytics, efficiency: EfficiencyAnalytics): List<String> = emptyList()
    private fun identifyAreasForImprovement(behavior: BehaviorAnalysis, safety: SafetyAnalytics, efficiency: EfficiencyAnalytics): List<String> = emptyList()
    private fun generateImmediateActions(behavior: BehaviorAnalysis, safety: SafetyAnalytics, efficiency: EfficiencyAnalytics): List<String> = emptyList()
    private fun generateLongTermGoals(score: Double): List<String> = emptyList()
    private fun calculateFleetMetrics(analytics: List<DriverAnalyticsReport>): FleetMetrics = FleetMetrics(0.0, 0.0, 0.0, 0)
    private fun generateDriverRanking(analytics: List<DriverAnalyticsReport>): List<DriverRanking> = emptyList()
    private fun identifyTopPerformers(analytics: List<DriverAnalyticsReport>): List<TopPerformer> = emptyList()
    private fun identifyFleetImprovementAreas(analytics: List<DriverAnalyticsReport>): List<String> = emptyList()
    private fun generatePerformanceForecast(data: List<DrivingSession>, days: Int): PerformanceForecast = PerformanceForecast(emptyList())
    private fun generateRiskPrediction(data: List<DrivingSession>): RiskPrediction = RiskPrediction(0.0, emptyList())
    private fun generateEfficiencyProjection(data: List<DrivingSession>): EfficiencyProjection = EfficiencyProjection(0.0)
    private fun predictCoachingNeeds(data: List<DrivingSession>): List<CoachingNeed> = emptyList()
    private fun calculatePredictionConfidence(data: List<DrivingSession>): Double = 85.0
}

// Data classes and enums
data class DriverAnalyticsReport(
    val driverId: String,
    val generatedAt: LocalDateTime,
    val timeWindow: TimeWindow,
    val overallScore: Double,
    val behaviorAnalysis: BehaviorAnalysis,
    val safetyAnalysis: SafetyAnalytics,
    val efficiencyAnalysis: EfficiencyAnalytics,
    val riskAssessment: RiskAssessment,
    val performanceTrends: PerformanceTrends,
    val coachingInsights: CoachingInsights,
    val comparativeAnalysis: ComparativeAnalysis,
    val summary: AnalyticsSummary,
    val errorMessage: String? = null
) {
    companion object {
        fun createError(driverId: String, timeWindow: TimeWindow): DriverAnalyticsReport {
            return DriverAnalyticsReport(
                driverId = driverId,
                generatedAt = LocalDateTime.now(),
                timeWindow = timeWindow,
                overallScore = 0.0,
                behaviorAnalysis = BehaviorAnalysis(0.0, 0.0, 0.0, 0.0, ""),
                safetyAnalysis = SafetyAnalytics(0.0, 0, TrendDirection.STABLE, 0, SafetyLevel.POOR, emptyMap()),
                efficiencyAnalysis = EfficiencyAnalytics(0.0, 0.0, 0.0, 0.0, 0, EfficiencyLevel.POOR, TrendDirection.STABLE),
                riskAssessment = RiskAssessment(0.0, RiskLevel.HIGH, emptyList(), emptyList(), 0.0, emptyList()),
                performanceTrends = PerformanceTrends(TrendDirection.STABLE, TrendDirection.STABLE, TrendDirection.STABLE, TrendDirection.STABLE, TimeWindow.LAST_30_DAYS),
                coachingInsights = CoachingInsights(false, CoachingPriority.NONE, emptyList(), emptyList(), 0.0, 0),
                comparativeAnalysis = ComparativeAnalysis(0.0, 0.0, 0.0, "", emptyList(), emptyList()),
                summary = AnalyticsSummary(PerformanceLevel.POOR, emptyList(), emptyList(), emptyList(), emptyList()),
                errorMessage = "Error generating analytics report"
            )
        }
    }
}

data class DriverAnalyticsUpdate(
    val analytics: DriverAnalyticsReport,
    val updateType: UpdateType,
    val errorMessage: String? = null
) {
    companion object {
        fun createError(driverId: String): DriverAnalyticsUpdate {
            return DriverAnalyticsUpdate(
                analytics = DriverAnalyticsReport.createError(driverId, TimeWindow.LAST_24_HOURS),
                updateType = UpdateType.ERROR,
                errorMessage = "Error in real-time analytics"
            )
        }
    }
}

data class FleetAnalyticsComparison(
    val generatedAt: LocalDateTime,
    val timeWindow: TimeWindow,
    val totalDrivers: Int,
    val fleetMetrics: FleetMetrics,
    val driverAnalytics: List<DriverAnalyticsReport>,
    val ranking: List<DriverRanking>,
    val topPerformers: List<TopPerformer>,
    val improvementAreas: List<String>,
    val errorMessage: String? = null
) {
    companion object {
        fun createError(driverCount: Int, timeWindow: TimeWindow): FleetAnalyticsComparison {
            return FleetAnalyticsComparison(
                generatedAt = LocalDateTime.now(),
                timeWindow = timeWindow,
                totalDrivers = driverCount,
                fleetMetrics = FleetMetrics(0.0, 0.0, 0.0, 0),
                driverAnalytics = emptyList(),
                ranking = emptyList(),
                topPerformers = emptyList(),
                improvementAreas = emptyList(),
                errorMessage = "Error generating fleet analytics"
            )
        }
    }
}

data class PredictiveAnalytics(
    val driverId: String,
    val generatedAt: LocalDateTime,
    val forecastPeriod: Int,
    val performanceForecast: PerformanceForecast,
    val riskPrediction: RiskPrediction,
    val efficiencyProjection: EfficiencyProjection,
    val coachingNeeds: List<CoachingNeed>,
    val confidence: Double,
    val errorMessage: String? = null
) {
    companion object {
        fun createError(driverId: String, days: Int): PredictiveAnalytics {
            return PredictiveAnalytics(
                driverId = driverId,
                generatedAt = LocalDateTime.now(),
                forecastPeriod = days,
                performanceForecast = PerformanceForecast(emptyList()),
                riskPrediction = RiskPrediction(0.0, emptyList()),
                efficiencyProjection = EfficiencyProjection(0.0),
                coachingNeeds = emptyList(),
                confidence = 0.0,
                errorMessage = "Error generating predictive analytics"
            )
        }
    }
}

// Additional data classes
data class SafetyAnalytics(
    val averageSafetyScore: Double,
    val totalSafetyEvents: Int,
    val safetyTrend: TrendDirection,
    val highRiskSessions: Int,
    val safetyLevel: SafetyLevel,
    val eventBreakdown: Map<String, Int>
)

data class EfficiencyAnalytics(
    val averageEfficiencyScore: Double,
    val totalDistance: Double,
    val totalFuelConsumed: Double,
    val averageFuelConsumption: Double,
    val totalIdleTime: Int,
    val efficiencyLevel: EfficiencyLevel,
    val fuelEfficiencyTrend: TrendDirection
)

data class RiskAssessment(
    val overallRiskScore: Double,
    val riskLevel: RiskLevel,
    val riskFactors: List<String>,
    val highRiskBehaviors: List<String>,
    val accidentRisk: Double,
    val recommendations: List<String>
)

data class PerformanceTrends(
    val scoreTrend: TrendDirection,
    val behaviorTrend: TrendDirection,
    val efficiencyTrend: TrendDirection,
    val overallTrend: TrendDirection,
    val trendPeriod: TimeWindow
)

data class CoachingInsights(
    val coachingNeeded: Boolean,
    val priorityLevel: CoachingPriority,
    val coachingAreas: List<String>,
    val specificRecommendations: List<String>,
    val improvementPotential: Double,
    val estimatedImprovementTime: Int
)

data class ComparativeAnalysis(
    val fleetAverageScore: Double,
    val driverScore: Double,
    val percentileRank: Double,
    val comparisonToPeers: String,
    val strengths: List<String>,
    val weaknesses: List<String>
)

data class AnalyticsSummary(
    val overallPerformance: PerformanceLevel,
    val keyStrengths: List<String>,
    val areasForImprovement: List<String>,
    val immediateActions: List<String>,
    val longTermGoals: List<String>
)

data class FleetMetrics(
    val averageScore: Double,
    val averageSafetyScore: Double,
    val averageEfficiencyScore: Double,
    val totalDistance: Int
)

data class DriverRanking(
    val driverId: String,
    val rank: Int,
    val score: Double,
    val change: Int
)

data class TopPerformer(
    val driverId: String,
    val category: String,
    val score: Double,
    val achievement: String
)

data class PerformanceForecast(
    val predictions: List<DailyPrediction>
)

data class DailyPrediction(
    val date: LocalDateTime,
    val predictedScore: Double,
    val confidence: Double
)

data class RiskPrediction(
    val riskScore: Double,
    val riskFactors: List<String>
)

data class EfficiencyProjection(
    val projectedEfficiency: Double
)

data class CoachingNeed(
    val area: String,
    val priority: CoachingPriority,
    val description: String
)

// Enums
enum class UpdateType {
    INITIAL, REAL_TIME, ERROR
}

enum class TrendDirection {
    IMPROVING, DECLINING, STABLE
}

enum class SafetyLevel {
    EXCELLENT, GOOD, AVERAGE, POOR
}

enum class EfficiencyLevel {
    EXCELLENT, GOOD, AVERAGE, POOR
}

enum class RiskLevel {
    LOW, MEDIUM, HIGH
}

enum class PerformanceLevel {
    EXCELLENT, GOOD, AVERAGE, POOR
}

enum class CoachingPriority {
    NONE, RECOMMENDED, IMMEDIATE
}
