package com.edham.logistics.presentation.ui.base

import androidx.lifecycle.ViewModel
import androidx.lifecycle.viewModelScope
import com.edham.logistics.core.utils.Result
import kotlinx.coroutines.flow.MutableStateFlow
import kotlinx.coroutines.flow.StateFlow
import kotlinx.coroutines.flow.asStateFlow
import kotlinx.coroutines.launch

abstract class BaseViewModel<T : UiState> : ViewModel() {

    private val _uiState = MutableStateFlow(createInitialState())
    val uiState: StateFlow<T> = _uiState.asStateFlow()

    abstract fun createInitialState(): T

    protected fun updateUiState(update: T.() -> T) {
        _uiState.value = _uiState.value.update()
    }

    protected fun setLoading(isLoading: Boolean) {
        updateUiState { copyLoading(isLoading) }
    }

    protected fun setError(error: String?) {
        updateUiState { copyError(error) }
    }

    protected fun setSuccess(message: String? = null) {
        updateUiState { copySuccess(message) }
    }

    protected fun clearError() {
        updateUiState { copyError(null) }
    }

    protected fun clearSuccess() {
        updateUiState { copySuccess(null) }
    }

    protected fun <R> executeOperation(
        operation: suspend () -> Result<R>,
        onSuccess: (R) -> Unit = {},
        onError: (String) -> Unit = {},
        onLoading: () -> Unit = {}
    ) {
        viewModelScope.launch {
            onLoading()
            when (val result = operation()) {
                is Result.Success -> {
                    setLoading(false)
                    onSuccess(result.data)
                }
                is Result.Error -> {
                    setLoading(false)
                    onError(result.exception.message ?: "حدث خطأ غير متوقع")
                }
                is Result.Loading -> {
                    setLoading(true)
                }
            }
        }
    }

    protected fun executeAsyncOperation(
        operation: suspend () -> Unit,
        onLoading: () -> Unit = {},
        onError: (String) -> Unit = {}
    ) {
        viewModelScope.launch {
            onLoading()
            try {
                operation()
                setLoading(false)
            } catch (e: Exception) {
                setLoading(false)
                onError(e.message ?: "حدث خطأ غير متوقع")
            }
        }
    }
}

interface UiState {
    fun copyLoading(isLoading: Boolean): UiState
    fun copyError(error: String?): UiState
    fun copySuccess(message: String?): UiState
}
