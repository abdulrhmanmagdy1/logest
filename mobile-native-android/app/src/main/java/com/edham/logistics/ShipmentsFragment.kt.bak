package com.edham.logistics

import android.os.Bundle
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import androidx.fragment.app.Fragment
import androidx.recyclerview.widget.LinearLayoutManager
import androidx.recyclerview.widget.RecyclerView
import com.google.android.material.tabs.TabLayout

class ShipmentsFragment : Fragment() {
    private lateinit var shipmentsAdapter: ShipmentsAdapter
    
    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View? {
        return inflater.inflate(R.layout.fragment_shipments, container, false)
    }
    
    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        
        // Setup TabLayout
        val tabLayout = view.findViewById<TabLayout>(R.id.tab_layout)
        tabLayout.addTab(tabLayout.newTab().setText("Active"))
        tabLayout.addTab(tabLayout.newTab().setText("Completed"))
        tabLayout.addTab(tabLayout.newTab().setText("Cancelled"))
        
        // Setup RecyclerView
        val rvShipments = view.findViewById<RecyclerView>(R.id.rv_shipments)
        shipmentsAdapter = ShipmentsAdapter(getShipments())
        rvShipments.layoutManager = LinearLayoutManager(requireContext())
        rvShipments.adapter = shipmentsAdapter
        
        // Tab selection listener
        tabLayout.addOnTabSelectedListener(object : TabLayout.OnTabSelectedListener {
            override fun onTabSelected(tab: TabLayout.Tab?) {
                // Update shipments based on selected tab
                shipmentsAdapter.updateData(getShipmentsByStatus(tab?.position ?: 0))
            }
            
            override fun onTabUnselected(tab: TabLayout.Tab?) {}
            override fun onTabReselected(tab: TabLayout.Tab?) {}
        })
    }
    
    private fun getShipments(): List<Shipment> {
        return listOf(
            Shipment("#SHP-001", "May 10, 2026", "In Transit", "Riyadh", "Jeddah", "500 kg", "SAR 350"),
            Shipment("#SHP-002", "May 9, 2026", "Delivered", "Dammam", "Riyadh", "300 kg", "SAR 250"),
            Shipment("#SHP-003", "May 8, 2026", "Pending", "Jeddah", "Medina", "200 kg", "SAR 180"),
            Shipment("#SHP-004", "May 7, 2026", "Cancelled", "Medina", "Mecca", "150 kg", "SAR 120"),
            Shipment("#SHP-005", "May 6, 2026", "Delivered", "Mecca", "Taif", "100 kg", "SAR 80")
        )
    }
    
    private fun getShipmentsByStatus(tabPosition: Int): List<Shipment> {
        val status = when (tabPosition) {
            0 -> listOf("In Transit", "Pending")
            1 -> listOf("Delivered")
            2 -> listOf("Cancelled")
            else -> listOf("In Transit", "Pending")
        }
        
        return getShipments().filter { it.status in status }
    }
}
