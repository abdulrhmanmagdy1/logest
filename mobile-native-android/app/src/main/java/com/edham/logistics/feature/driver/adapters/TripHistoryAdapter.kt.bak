package com.edham.logistics.feature.driver.adapters

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.ImageView
import android.widget.RatingBar
import android.widget.TextView
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.feature.driver.TripHistoryItem
import java.text.SimpleDateFormat
import java.util.*

class TripHistoryAdapter(
    private val trips: List<TripHistoryItem>,
    private val onTripClick: (TripHistoryItem) -> Unit
) : RecyclerView.Adapter<TripHistoryAdapter.ViewHolder>() {
    
    private val dateFormat = SimpleDateFormat("MMM dd, yyyy", Locale.getDefault())
    private val timeFormat = SimpleDateFormat("HH:mm", Locale.getDefault())
    
    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): ViewHolder {
        val view = LayoutInflater.from(parent.context).inflate(R.layout.item_trip_history, parent, false)
        return ViewHolder(view)
    }
    
    override fun onBindViewHolder(holder: ViewHolder, position: Int) {
        holder.bind(trips[position])
    }
    
    override fun getItemCount(): Int = trips.size
    
    inner class ViewHolder(itemView: View) : RecyclerView.ViewHolder(itemView) {
        private val tripDate: TextView = itemView.findViewById(R.id.tripDate)
        private val tripTime: TextView = itemView.findViewById(R.id.tripTime)
        private val tripOrigin: TextView = itemView.findViewById(R.id.tripOrigin)
        private val tripDestination: TextView = itemView.findViewById(R.id.tripDestination)
        private val tripDistance: TextView = itemView.findViewById(R.id.tripDistance)
        private val tripDuration: TextView = itemView.findViewById(R.id.tripDuration)
        private val tripStatus: TextView = itemView.findViewById(R.id.tripStatus)
        private val tripEarnings: TextView = itemView.findViewById(R.id.tripEarnings)
        private val customerName: TextView = itemView.findViewById(R.id.customerName)
        private val customerRating: RatingBar = itemView.findViewById(R.id.customerRating)
        private val statusIndicator: ImageView = itemView.findViewById(R.id.statusIndicator)
        private val tripNotes: TextView = itemView.findViewById(R.id.tripNotes)
        
        init {
            itemView.setOnClickListener {
                val position = adapterPosition
                if (position != RecyclerView.NO_POSITION) {
                    onTripClick(trips[position])
                }
            }
        }
        
        fun bind(trip: TripHistoryItem) {
            // Set date and time
            tripDate.text = dateFormat.format(Date(trip.date))
            tripTime.text = "${timeFormat.format(Date(trip.startTime))} - ${timeFormat.format(Date(trip.endTime))}"
            
            // Set route
            tripOrigin.text = trip.origin
            tripDestination.text = trip.destination
            
            // Set metrics
            tripDistance.text = String.format("%.1f km", trip.distance)
            tripDuration.text = String.format("%d min", trip.duration / 60000)
            
            // Set status
            tripStatus.text = trip.status
            
            // Set earnings
            if (trip.earnings > 0) {
                tripEarnings.text = String.format("$%.2f", trip.earnings)
                tripEarnings.visibility = View.VISIBLE
            } else {
                tripEarnings.visibility = View.GONE
            }
            
            // Set customer info
            customerName.text = trip.customerName
            
            // Set rating
            if (trip.customerRating > 0) {
                customerRating.rating = trip.customerRating.toFloat()
                customerRating.visibility = View.VISIBLE
            } else {
                customerRating.visibility = View.GONE
            }
            
            // Set notes
            if (trip.notes.isNotBlank()) {
                tripNotes.text = trip.notes
                tripNotes.visibility = View.VISIBLE
            } else {
                tripNotes.visibility = View.GONE
            }
            
            // Set status indicator and colors
            when (trip.status) {
                "COMPLETED" -> {
                    statusIndicator.setImageResource(R.drawable.ic_check_circle)
                    statusIndicator.setColorFilter(itemView.context.getColor(R.color.status_completed))
                    tripStatus.setTextColor(itemView.context.getColor(R.color.status_completed))
                }
                "CANCELLED" -> {
                    statusIndicator.setImageResource(R.drawable.ic_cancel)
                    statusIndicator.setColorFilter(itemView.context.getColor(R.color.status_cancelled))
                    tripStatus.setTextColor(itemView.context.getColor(R.color.status_cancelled))
                }
                "IN_PROGRESS" -> {
                    statusIndicator.setImageResource(R.drawable.ic_progress)
                    statusIndicator.setColorFilter(itemView.context.getColor(R.color.status_active))
                    tripStatus.setTextColor(itemView.context.getColor(R.color.status_active))
                }
                else -> {
                    statusIndicator.setImageResource(R.drawable.ic_info)
                    statusIndicator.setColorFilter(itemView.context.getColor(R.color.status_idle))
                    tripStatus.setTextColor(itemView.context.getColor(R.color.status_idle))
                }
            }
            
            // Set background for cancelled trips
            if (trip.status == "CANCELLED") {
                itemView.alpha = 0.6f
            } else {
                itemView.alpha = 1.0f
            }
        }
    }
}
