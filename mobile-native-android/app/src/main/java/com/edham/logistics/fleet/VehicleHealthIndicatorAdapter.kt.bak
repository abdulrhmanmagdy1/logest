package com.edham.logistics.fleet

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import androidx.core.content.ContextCompat
import androidx.recyclerview.widget.DiffUtil
import androidx.recyclerview.widget.ListAdapter
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.databinding.ItemVehicleHealthIndicatorBinding
import com.edham.logistics.fleet.models.VehicleHealthData
import com.edham.logistics.utils.AnimUtils

/**
 * Vehicle Health Indicator Adapter - RecyclerView adapter for vehicle health indicators
 * 
 * Features:
 * - Animated health indicators
 * - Color-coded health status
 * - Real-time updates
 * - Interactive actions
 * - Health metrics display
 */
class VehicleHealthIndicatorAdapter(
    private val onItemClick: (VehicleHealthData) -> Unit,
    private val onViewDetails: (VehicleHealthData) -> Unit,
    private val onMoreActions: (VehicleHealthData, View) -> Unit
) : ListAdapter<VehicleHealthData, VehicleHealthIndicatorAdapter.ViewHolder>(VehicleHealthDiffCallback()) {

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): ViewHolder {
        val binding = ItemVehicleHealthIndicatorBinding.inflate(
            LayoutInflater.from(parent.context),
            parent,
            false
        )
        return ViewHolder(binding)
    }

    override fun onBindViewHolder(holder: ViewHolder, position: Int) {
        holder.bind(getItem(position))
    }

    inner class ViewHolder(
        private val binding: ItemVehicleHealthIndicatorBinding
    ) : RecyclerView.ViewHolder(binding.root) {

        fun bind(vehicleHealth: VehicleHealthData) {
            // Set vehicle information
            binding.tvVehicleId.text = vehicleHealth.vehicleId
            binding.tvVehicleDetails.text = vehicleHealth.vehicleDetails
            binding.tvHealthScore.text = "${vehicleHealth.healthScore}%"

            // Update health indicator color
            updateHealthIndicator(vehicleHealth.healthScore)

            // Update health score badge
            updateHealthScoreBadge(vehicleHealth.healthScore)

            // Update vehicle icon based on type
            updateVehicleIcon(vehicleHealth.vehicleType)

            // Update metrics
            binding.tvFuelLevel.text = "${vehicleHealth.fuelLevel}%"
            binding.tvMileage.text = "${vehicleHealth.mileage.toInt().formatNumber()} كم"

            // Update fuel level color
            updateFuelLevelColor(vehicleHealth.fuelLevel)

            // Show/hide health issues
            if (vehicleHealth.healthIssues.isNotEmpty()) {
                binding.llHealthIssues.visibility = View.VISIBLE
                binding.tvHealthIssues.text = vehicleHealth.healthIssues.joinToString(" - ")
                binding.tvHealthIssues.setTextColor(getHealthIssueColor(vehicleHealth.healthIssues))
            } else {
                binding.llHealthIssues.visibility = View.GONE
            }

            // Set click listeners
            binding.root.setOnClickListener {
                onItemClick(vehicleHealth)
                AnimUtils.scaleAnimation(it, 0.95f, 1.0f, 100)
            }

            binding.btnViewDetails.setOnClickListener {
                onViewDetails(vehicleHealth)
                AnimUtils.scaleAnimation(it, 0.9f, 1.0f, 100)
            }

            binding.btnMoreActions.setOnClickListener { view ->
                onMoreActions(vehicleHealth, view)
                AnimUtils.scaleAnimation(it, 0.9f, 1.0f, 100)
            }

            // Animate appearance
            animateAppearance()
        }

        private fun updateHealthIndicator(healthScore: Int) {
            val color = when {
                healthScore >= 80 -> R.color.green
                healthScore >= 60 -> R.color.yellow
                healthScore >= 40 -> R.color.orange
                else -> R.color.red
            }

            binding.viewHealthIndicator.setBackgroundColor(
                ContextCompat.getColor(binding.root.context, color)
            )
        }

        private fun updateHealthScoreBadge(healthScore: Int) {
            val (backgroundRes, textColor) = when {
                healthScore >= 80 -> {
                    R.drawable.bg_health_good_badge to R.color.white
                }
                healthScore >= 60 -> {
                    R.drawable.bg_health_warning_badge to R.color.black
                }
                healthScore >= 40 -> {
                    R.drawable.bg_health_caution_badge to R.color.white
                }
                else -> {
                    R.drawable.bg_health_critical_badge to R.color.white
                }
            }

            binding.tvHealthScore.setBackgroundResource(backgroundRes)
            binding.tvHealthScore.setTextColor(
                ContextCompat.getColor(binding.root.context, textColor)
            )
        }

        private fun updateVehicleIcon(vehicleType: String) {
            val iconRes = when (vehicleType.lowercase()) {
                "truck", "شاحنة" -> R.drawable.ic_truck
                "van", "فان" -> R.drawable.ic_van
                "car", "سيارة" -> R.drawable.ic_car
                "motorcycle", "دراجة نارية" -> R.drawable.ic_motorcycle
                "bus", "حافلة" -> R.drawable.ic_bus
                else -> R.drawable.ic_truck
            }

            binding.ivVehicleIcon.setImageResource(iconRes)
        }

        private fun updateFuelLevelColor(fuelLevel: Int) {
            val color = when {
                fuelLevel >= 50 -> R.color.green
                fuelLevel >= 25 -> R.color.yellow
                fuelLevel >= 10 -> R.color.orange
                else -> R.color.red
            }

            binding.tvFuelLevel.setTextColor(
                ContextCompat.getColor(binding.root.context, color)
            )
        }

        private fun getHealthIssueColor(issues: List<String>): Int {
            return when {
                issues.any { it.contains("حرجة", ignoreCase = true) } -> R.color.red
                issues.any { it.contains("تحذير", ignoreCase = true) } -> R.color.orange
                else -> R.color.yellow
            }
        }

        private fun animateAppearance() {
            binding.root.alpha = 0f
            binding.root.translationY = 50f

            binding.root.animate()
                .alpha(1f)
                .translationY(0f)
                .setDuration(300)
                .setStartDelay(bindingAdapterPosition * 50L)
                .start()
        }

        private fun Int.formatNumber(): String {
            return this.toString().reversed().chunked(3).joinToString(",").reversed()
        }
    }

    private class VehicleHealthDiffCallback : DiffUtil.ItemCallback<VehicleHealthData>() {
        override fun areItemsTheSame(
            oldItem: VehicleHealthData,
            newItem: VehicleHealthData
        ): Boolean {
            return oldItem.vehicleId == newItem.vehicleId
        }

        override fun areContentsTheSame(
            oldItem: VehicleHealthData,
            newItem: VehicleHealthData
        ): Boolean {
            return oldItem == newItem
        }
    }
}
