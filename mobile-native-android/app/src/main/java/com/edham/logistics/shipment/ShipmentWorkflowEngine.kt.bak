    /**
     * Initialize workflow for shipment
     */
    fun initializeWorkflow(shipment: ShipmentEntity) {
        try {
            _workflowState.value = WorkflowState.Initializing
            
            val workflowType = determineWorkflowType(shipment)
            val workflowDefinition = workflowDefinitions[workflowType]
                ?: workflowDefinitions[STANDARD_WORKFLOW]!!
            
            val workflowInstance = WorkflowInstance(
                shipmentId = shipment.id,
                workflowType = workflowType,
                currentStep = workflowDefinition.steps.first(),
                startTime = Date(),
                lastUpdateTime = Date(),
                completedSteps = mutableListOf(),
                failedConditions = mutableListOf(),
                metadata = mutableMapOf()
            )
            
            activeWorkflowInstances[shipment.id] = workflowInstance
            
            // Execute initial step
            executeWorkflowStep(workflowInstance)
            
            // Update active workflows
            updateActiveWorkflows()
            
            _workflowState.value = WorkflowState.Initialized
            
        } catch (e: Exception) {
            _workflowState.value = WorkflowState.Error("Failed to initialize workflow: ${e.message}")
        }
    }
    
    /**
     * Process state change
     */
    fun processStateChange(shipmentId: Long, newStatus: ShipmentStatus, changedBy: String) {
        try {
            val workflowInstance = activeWorkflowInstances[shipmentId]
                ?: return
            
            val currentStep = workflowInstance.currentStep
            
            // Find next step for new status
            val nextStep = findNextStep(workflowInstance, newStatus)
            
            if (nextStep != null) {
                // Transition to next step
                transitionToStep(workflowInstance, nextStep, changedBy)
            } else {
                // Handle invalid transition
                handleInvalidTransition(workflowInstance, newStatus, changedBy)
            }
            
        } catch (e: Exception) {
            _workflowState.value = WorkflowState.Error("Failed to process state change: ${e.message}")
        }
    }
    
    /**
     * Execute workflow step
     */
    private fun executeWorkflowStep(workflowInstance: WorkflowInstance) {
        try {
            val step = workflowInstance.currentStep
            
            // Execute step actions
            step.actions.forEach { action ->
                executeAction(workflowInstance, action)
            }
            
            // Check conditions
            val conditionsMet = checkConditions(workflowInstance, step.conditions)
            
            if (conditionsMet) {
                // Step completed successfully
                workflowInstance.completedSteps.add(step)
                
                // Check for automatic transition
                if (step.nextSteps.size == 1) {
                    val nextStepId = step.nextSteps.first()
                    val workflowDefinition = workflowDefinitions[workflowInstance.workflowType]!!
                    val nextStep = workflowDefinition.steps.find { it.id == nextStepId }
                    
                    if (nextStep != null) {
                        transitionToStep(workflowInstance, nextStep, "system")
                    }
                }
            } else {
                // Handle failed conditions
                handleFailedConditions(workflowInstance, step)
            }
            
            // Update workflow instance
            workflowInstance.lastUpdateTime = Date()
            updateActiveWorkflows()
            
        } catch (e: Exception) {
            _workflowState.value = WorkflowState.Error("Failed to execute step: ${e.message}")
        }
    }
    
    /**
     * Transition to next step
     */
    private fun transitionToStep(workflowInstance: WorkflowInstance, nextStep: WorkflowStep, triggeredBy: String) {
        try {
            // Create transition record
            // val transition = WorkflowTransitionEntity(
            //     id = 0,
            //     shipmentId = workflowInstance.shipmentId,
                fromStep = workflowInstance.currentStep.id,
                toStep = nextStep.id,
                transitionTime = Date(),
                triggeredBy = triggeredBy,
                metadata = mapOf(
                    "workflow_type" to workflowInstance.workflowType,
                    "previous_step_duration" to (Date().time - workflowInstance.startTime.time)
                ).toString(),
                createdAt = Date()
            )
            
            // Save transition
            // Implementation would save to database
            
            // Update current step
            workflowInstance.currentStep = nextStep
            workflowInstance.lastUpdateTime = Date()
            
            // Execute new step
            executeWorkflowStep(workflowInstance)
            
        } catch (e: Exception) {
            _workflowState.value = WorkflowState.Error("Failed to transition step: ${e.message}")
        }
    }
    
