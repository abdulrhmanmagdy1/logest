    /**
     * Get workflow analytics
     */
    suspend fun getWorkflowAnalytics(): WorkflowAnalytics {
        return withContext(Dispatchers.IO) {
            // val allTransitions = database.workflowTransitionDao().getAllTransitions()
            val allInstances = activeWorkflowInstances.values.toList()
            
            val totalWorkflows = allInstances.size
            val completedWorkflows = allInstances.count { it.currentStep.id == "completed" }
            val averageCompletionTime = calculateAverageCompletionTime(allInstances)
            val stepCompletionRates = calculateStepCompletionRates(listOf())
            val stepCompletionRates = calculateStepCompletionRates(allTransitions)
            val workflowTypeDistribution = calculateWorkflowTypeDistribution(allInstances)
            val commonBottlenecks = identifyBottlenecks(allTransitions)
            val automationRate = calculateAutomationRate(allTransitions)
            
            WorkflowAnalytics(
                totalWorkflows = totalWorkflows,
                completedWorkflows = completedWorkflows,
                completionRate = if (totalWorkflows > 0) completedWorkflows.toFloat() / totalWorkflows else 1f,
                averageCompletionTime = averageCompletionTime,
                stepCompletionRates = stepCompletionRates,
                workflowTypeDistribution = workflowTypeDistribution,
                commonBottlenecks = commonBottlenecks,
                automationRate = automationRate
            )
        }
    }
    
    /**
     * Helper functions
     */
    private fun determineWorkflowType(shipment: ShipmentEntity): String {
        return when {
            shipment.priority == Priority.CRITICAL -> EXPRESS_WORKFLOW
            shipment.isColdChain -> COLD_CHAIN_WORKFLOW
            // Add other workflow type logic
            else -> STANDARD_WORKFLOW
        }
    }
    
    private fun findNextStep(workflowInstance: WorkflowInstance, newStatus: ShipmentStatus): WorkflowStep? {
        val workflowDefinition = workflowDefinitions[workflowInstance.workflowType]
            ?: return null
        
        return workflowDefinition.steps.find { it.status == newStatus }
    }
    
    private fun handleInvalidTransition(workflowInstance: WorkflowInstance, newStatus: ShipmentStatus, changedBy: String) {
        // Handle invalid transition - create alert or log
        _workflowState.value = WorkflowState.Error("Invalid transition from ${workflowInstance.currentStep.status} to $newStatus")
    }
    
    private fun checkConditions(workflowInstance: WorkflowInstance, conditions: List<String>): Boolean {
        return conditions.all { condition ->
            checkCondition(workflowInstance, condition)
        }
    }
    
    private fun checkCondition(workflowInstance: WorkflowInstance, condition: String): Boolean {
        // Implementation would check specific conditions
        return true // Placeholder
    }
    
    private fun handleFailedConditions(workflowInstance: WorkflowInstance, step: WorkflowStep) {
        workflowInstance.failedConditions.addAll(step.conditions)
        _workflowState.value = WorkflowState.Error("Failed conditions for step: ${step.id}")
    }
    
    private fun updateActiveWorkflows() {
        val activeWorkflows = activeWorkflowInstances.values.map { instance ->
            ActiveWorkflow(
                shipmentId = instance.shipmentId,
                workflowType = instance.workflowType,
                currentStep = instance.currentStep,
                startTime = instance.startTime,
                lastUpdateTime = instance.lastUpdateTime,
                completedSteps = instance.completedSteps.size,
                totalSteps = workflowDefinitions[instance.workflowType]?.steps?.size ?: 0,
                progress = instance.completedSteps.size.toFloat() / (workflowDefinitions[instance.workflowType]?.steps?.size ?: 1)
            )
        }
        
        _activeWorkflows.value = activeWorkflows
    }
    
