    // Analytics calculations
    private fun calculateAverageCompletionTime(instances: List<WorkflowInstance>): Double {
        val completedInstances = instances.filter { 
            it.currentStep.id == "completed" 
        }
        
        if (completedInstances.isEmpty()) return 0.0
        
        val totalTime = completedInstances.sumOf { instance ->
            instance.lastUpdateTime.time - instance.startTime.time
        }
        
        return totalTime / completedInstances.size / (1000 * 60) // Convert to minutes
    }
    
    private fun calculateStepCompletionRates(transitions: List<WorkflowTransitionEntity>): Map<String, Float> {
        // Implementation would calculate completion rates for each step
        return mapOf(
            "created" to 0.98f,
            "assigned" to 0.95f,
            "scheduled" to 0.92f,
            "pickup_confirmed" to 0.90f,
            "in_transit" to 0.88f,
            "delivered" to 0.95f
        )
    }
    
    private fun calculateWorkflowTypeDistribution(instances: List<WorkflowInstance>): Map<String, Int> {
        return instances.groupBy { it.workflowType }.mapValues { it.value.size }
    }
    
    private fun identifyBottlenecks(transitions: List<WorkflowTransitionEntity>): List<String> {
        // Implementation would identify workflow bottlenecks
        return listOf("assigned", "scheduled")
    }
    
    // private fun calculateAutomationRate(transitions: List<WorkflowTransitionEntity>): Float {
        val automatedTransitions = transitions.count { it.triggeredBy == "system" }
        return if (transitions.isNotEmpty()) {
            automatedTransitions.toFloat() / transitions.size
        } else 0f
    }
    
    /**
     * Get workflow state
     */
    fun getWorkflowState(): WorkflowState = _workflowState.value
}

/**
 * Data classes
 */
data class WorkflowDefinition(
    val name: String,
    val description: String,
    val steps: List<WorkflowStep>
)

data class WorkflowStep(
    val id: String,
    val name: String,
    val status: ShipmentStatus,
    val actions: List<String>,
    val conditions: List<String>,
    val timeout: Long,
    val nextSteps: List<String>
)

data class WorkflowInstance(
    val shipmentId: Long,
    val workflowType: String,
    var currentStep: WorkflowStep,
    val startTime: Date,
    var lastUpdateTime: Date,
    val completedSteps: MutableList<WorkflowStep>,
    val failedConditions: MutableList<String>,
    val metadata: MutableMap<String, Any>
)

data class ActiveWorkflow(
    val shipmentId: Long,
    val workflowType: String,
    val currentStep: WorkflowStep,
    val startTime: Date,
    val lastUpdateTime: Date,
    val completedSteps: Int,
    val totalSteps: Int,
    val progress: Float
)

data class WorkflowAnalytics(
    val totalWorkflows: Int,
    val completedWorkflows: Int,
    val completionRate: Float,
    val averageCompletionTime: Double,
    val stepCompletionRates: Map<String, Float>,
    val workflowTypeDistribution: Map<String, Int>,
    val commonBottlenecks: List<String>,
    val automationRate: Float
)

/**
 * Enums
 */
enum class WorkflowState {
    Idle,
    Initializing,
    Initialized,
    Processing,
    Completed,
    Error
}
