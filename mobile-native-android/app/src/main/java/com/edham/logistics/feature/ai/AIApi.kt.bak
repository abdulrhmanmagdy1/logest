package com.edham.logistics.feature.ai

import com.edham.logistics.data.local.entity.Shipment
import com.edham.logistics.data.local.entity.Driver
import com.edham.logistics.data.local.entity.Vehicle
import retrofit2.Response
import retrofit2.http.*

interface AIApi {
    
    // ETA Prediction
    @POST("api/v1/ai/eta/predict")
    suspend fun predictETA(@Body request: ETAPredictionRequest): Response<ETAPredictionResponse>
    
    @GET("api/v1/ai/eta/predictions")
    suspend fun getETAPredictions(@Query("shipmentId") shipmentId: String?): List<ETAPrediction>
    
    @POST("api/v1/ai/eta/batch")
    suspend fun predictETABatch(@Body requests: List<ETAPredictionRequest>): Response<List<ETAPredictionResponse>>
    
    // Delay Prediction
    @POST("api/v1/ai/delay/predict")
    suspend fun predictDelay(@Body request: DelayPredictionRequest): Response<DelayPredictionResponse>
    
    @GET("api/v1/ai/delay/predictions")
    suspend fun getDelayPredictions(@Query("shipmentId") shipmentId: String?): List<DelayPrediction>
    
    @POST("api/v1/ai/delay/prevent")
    suspend fun preventDelay(@Body request: DelayPreventionRequest): Response<DelayPreventionResponse>
    
    // Route Optimization
    @POST("api/v1/ai/route/optimize")
    suspend fun optimizeRoute(@Body request: RouteOptimizationRequest): Response<RouteOptimizationResponse>
    
    @GET("api/v1/ai/route/optimizations")
    suspend fun getRouteOptimizations(@Query("shipmentId") shipmentId: String?): List<RouteOptimization>
    
    @POST("api/v1/ai/route/compare")
    suspend fun compareRoutes(@Body request: RouteComparisonRequest): Response<RouteComparisonResponse>
    
    // Fuel Optimization
    @POST("api/v1/ai/fuel/optimize")
    suspend fun optimizeFuel(@Body request: FuelOptimizationRequest): Response<FuelOptimizationResponse>
    
    @GET("api/v1/ai/fuel/optimizations")
    suspend fun getFuelOptimizations(@Query("vehicleId") vehicleId: String?): List<FuelOptimization>
    
    @GET("api/v1/ai/fuel/analytics")
    suspend fun getFuelAnalytics(@Query("period") period: String): FuelAnalyticsResponse
    
    // Driver Behavior Analysis
    @POST("api/v1/ai/driver/analyze")
    suspend fun analyzeDriverBehavior(@Body request: DriverBehaviorRequest): Response<DriverBehaviorResponse>
    
    @GET("api/v1/ai/driver/behaviors")
    suspend fun getDriverBehaviors(@Query("driverId") driverId: String?): List<DriverBehaviorAnalysis>
    
    @POST("api/v1/ai/driver/improve")
    suspend fun improveDriverBehavior(@Body request: DriverImprovementRequest): Response<DriverImprovementResponse>
    
    // Predictive Maintenance
    @POST("api/v1/ai/maintenance/predict")
    suspend fun predictMaintenance(@Body request: MaintenancePredictionRequest): Response<MaintenancePredictionResponse>
    
    @GET("api/v1/ai/maintenance/predictions")
    suspend fun getMaintenancePredictions(@Query("vehicleId") vehicleId: String?): List<MaintenancePrediction>
    
    @POST("api/v1/ai/maintenance/schedule")
    suspend fun scheduleMaintenance(@Body request: MaintenanceScheduleRequest): Response<MaintenanceScheduleResponse>
    
    // Demand Forecasting
    @POST("api/v1/ai/demand/forecast")
    suspend fun forecastDemand(@Body request: DemandForecastRequest): Response<DemandForecastResponse>
    
    @GET("api/v1/ai/demand/forecasts")
    suspend fun getDemandForecasts(@Query("period") period: String): List<DemandForecast>
    
    @POST("api/v1/ai/demand/analyze")
    suspend fun analyzeDemand(@Body request: DemandAnalysisRequest): Response<DemandAnalysisResponse>
    
    // Risk Analysis
    @POST("api/v1/ai/risk/analyze")
    suspend fun analyzeRisk(@Body request: RiskAnalysisRequest): Response<RiskAnalysisResponse>
    
    @GET("api/v1/ai/risk/analyses")
    suspend fun getRiskAnalyses(@Query("shipmentId") shipmentId: String?): List<ShipmentRiskAnalysis>
    
    @POST("api/v1/ai/risk/mitigate")
    suspend fun mitigateRisk(@Body request: RiskMitigationRequest): Response<RiskMitigationResponse>
    
    // Smart Notifications
    @GET("api/v1/ai/notifications")
    suspend fun getSmartNotifications(@Query("type") type: String?, @Query("priority") priority: String?): List<SmartNotification>
    
    @POST("api/v1/ai/notifications/send")
    suspend fun sendNotification(@Body notification: SmartNotification): Response<Unit>
    
    @POST("api/v1/ai/notifications/acknowledge")
    suspend fun acknowledgeNotification(@Body request: NotificationAcknowledgeRequest): Response<Unit>
    
    // AI Insights
    @GET("api/v1/ai/insights")
    suspend fun getAIInsights(): AIInsightsResponse
    
    @GET("api/v1/ai/insights/performance")
    suspend fun getAIPerformance(): AIPerformanceResponse
    
    @GET("api/v1/ai/insights/metrics")
    suspend fun getAIMetrics(): AIMetricsResponse
    
    // Model Management
    @POST("api/v1/ai/models/train")
    suspend fun trainModel(@Body request: ModelTrainingRequest): Response<ModelTrainingResponse>
    
    @GET("api/v1/ai/models/status")
    suspend fun getModelStatus(): ModelStatusResponse
    
    @POST("api/v1/ai/models/update")
    suspend fun updateModel(@Body request: ModelUpdateRequest): Response<ModelUpdateResponse>
    
    // Analytics Processing
    @POST("api/v1/ai/analytics/process")
    suspend fun processAnalytics(@Body request: AnalyticsProcessingRequest): Response<AnalyticsProcessingResponse>
    
    @GET("api/v1/ai/analytics/results")
    suspend fun getAnalyticsResults(@Query("requestId") requestId: String): AnalyticsResultsResponse
    
    @POST("api/v1/ai/analytics/export")
    suspend fun exportAnalytics(@Body request: AnalyticsExportRequest): Response<AnalyticsExportResponse>
}

// Request data classes
data class ETAPredictionRequest(
    val shipmentId: String,
    val currentLocation: LocationPoint,
    val destination: LocationPoint,
    val route: List<LocationPoint>,
    val weatherConditions: String,
    val trafficConditions: String,
    val vehicleType: String,
    val driverExperience: Int
)

data class DelayPredictionRequest(
    val shipmentId: String,
    val route: List<LocationPoint>,
    val weatherConditions: String,
    val trafficConditions: String,
    val driverId: String,
    val vehicleId: String,
    val timeOfDay: String,
    val dayOfWeek: String
)

data class DelayPreventionRequest(
    val shipmentId: String,
    val delayRisk: Double,
    val recommendedActions: List<String>
)

data class RouteOptimizationRequest(
    val shipmentId: String,
    val origin: LocationPoint,
    val destination: LocationPoint,
    val currentRoute: List<LocationPoint>,
    val constraints: RouteConstraints,
    val objectives: List<String>
)

data class RouteComparisonRequest(
    val route1: List<LocationPoint>,
    val route2: List<LocationPoint>,
    val criteria: List<String>
)

data class FuelOptimizationRequest(
    val vehicleId: String,
    val currentRoute: List<LocationPoint>,
    val drivingBehavior: Map<String, Double>,
    val vehicleConditions: Map<String, Any>
)

data class DriverBehaviorRequest(
    val driverId: String,
    val timePeriod: String,
    val includeTelemetry: Boolean
)

data class DriverImprovementRequest(
    val driverId: String,
    val behaviorAnalysis: DriverBehaviorAnalysis,
    val improvementPlan: List<ImprovementAction>
)

data class MaintenancePredictionRequest(
    val vehicleId: String,
    val currentMileage: Long,
    val lastMaintenanceDate: Long,
    val vehicleConditions: Map<String, Any>,
    val usagePatterns: Map<String, Any>
)

data class MaintenanceScheduleRequest(
    val vehicleId: String,
    val maintenanceType: String,
    val scheduledDate: Long,
    val estimatedCost: Double,
    val priority: String
)

data class DemandForecastRequest(
    val period: String,
    val region: String,
    val serviceType: String,
    val includeSeasonality: Boolean,
    val includeEvents: Boolean
)

data class DemandAnalysisRequest(
    val period: String,
    val factors: List<String>,
    val includeExternalData: Boolean
)

data class RiskAnalysisRequest(
    val shipmentId: String,
    val route: List<LocationPoint>,
    val cargoType: String,
    val value: Double,
    val timeConstraints: Map<String, Any>,
    val externalFactors: List<String>
)

data class RiskMitigationRequest(
    val shipmentId: String,
    val riskAnalysis: ShipmentRiskAnalysis,
    val mitigationStrategies: List<MitigationStrategy>
)

data class NotificationAcknowledgeRequest(
    val notificationId: String,
    val userId: String,
    val action: String,
    val notes: String?
)

data class ModelTrainingRequest(
    val modelType: String,
    val trainingData: List<Map<String, Any>>,
    val parameters: Map<String, Any>,
    val validationData: List<Map<String, Any>>?
)

data class ModelUpdateRequest(
    val modelType: String,
    val updateData: List<Map<String, Any>>,
    val incremental: Boolean
)

data class AnalyticsProcessingRequest(
    val analysisType: String,
    val data: List<Map<String, Any>>,
    val parameters: Map<String, Any>,
    val outputFormat: String
)

data class AnalyticsExportRequest(
    val analysisType: String,
    val format: String,
    val filters: Map<String, Any>,
    val includeCharts: Boolean
)

data class ImprovementAction(
    val action: String,
    val priority: String,
    val expectedImpact: Double,
    val timeline: String
)

data class MitigationStrategy(
    val strategy: String,
    val effectiveness: Double,
    val cost: Double,
    val timeline: String
)

data class RouteConstraints(
    val maxDistance: Double?,
    val maxTime: Long?,
    val avoidTolls: Boolean,
    val avoidHighways: Boolean,
    val vehicleRestrictions: List<String>
)

data class LocationPoint(
    val latitude: Double,
    val longitude: Double,
    val address: String,
    val timestamp: Long
)

// Response data classes
data class ETAPredictionResponse(
    val shipmentId: String,
    val predictedETA: Long,
    val confidence: Double,
    val factors: List<PredictionFactor>,
    val alternativeRoutes: List<AlternativeRoute>,
    val timestamp: Long
)

data class DelayPredictionResponse(
    val shipmentId: String,
    val delayRisk: Double,
    val predictedDelayMinutes: Long,
    val delayCauses: List<String>,
    val preventionStrategies: List<String>,
    val delayPrevented: Boolean,
    val timestamp: Long
)

data class DelayPreventionResponse(
    val shipmentId: String,
    val preventionApplied: Boolean,
    val actionsTaken: List<String>,
    val riskReduction: Double,
    val timestamp: Long
)

data class RouteOptimizationResponse(
    val shipmentId: String,
    val optimizedRoute: List<LocationPoint>,
    val originalRoute: List<LocationPoint>,
    val potentialSavings: Double,
    val timeReduction: Long,
    val distanceReduction: Double,
    val fuelSavings: Double,
    val confidence: Double,
    val timestamp: Long
)

data class RouteComparisonResponse(
    val route1Score: Double,
    val route2Score: Double,
    val comparison: Map<String, Double>,
    val recommendation: String,
    val timestamp: Long
)

data class FuelOptimizationResponse(
    val vehicleId: String,
    val currentEfficiency: Double,
    val optimalEfficiency: Double,
    val potentialSavings: Double,
    val recommendations: List<String>,
    val fuelEfficiencyIssue: Boolean,
    val estimatedCostSavings: Double,
    val timestamp: Long
)

data class FuelAnalyticsResponse(
    val overallEfficiency: Double,
    val efficiencyTrend: List<EfficiencyTrend>,
    val costSavings: Double,
    val topPerformers: List<VehiclePerformance>,
    val improvementOpportunities: List<ImprovementOpportunity>,
    val period: String
)

data class DriverBehaviorResponse(
    val driverId: String,
    val riskScore: Double,
    val behaviorMetrics: Map<String, Double>,
    val recommendations: List<String>,
    val improvementAreas: List<String>,
    val performanceTrend: List<PerformanceTrend>,
    val trainingRecommendations: List<TrainingRecommendation>,
    val timestamp: Long
)

data class DriverImprovementResponse(
    val driverId: String,
    val improvementPlan: List<ImprovementAction>,
    val expectedImpact: Double,
    val timeline: String,
    val trackingMetrics: List<String>,
    val timestamp: Long
)

data class MaintenancePredictionResponse(
    val vehicleId: String,
    val maintenanceUrgency: Double,
    val daysUntilMaintenance: Int,
    val predictedIssues: List<String>,
    val maintenanceType: String,
    val estimatedCost: Double,
    val confidence: Double,
    val timestamp: Long
)

data class MaintenanceScheduleResponse(
    val vehicleId: String,
    val maintenanceId: String,
    val scheduledDate: Long,
    val maintenanceType: String,
    val estimatedCost: Double,
    val priority: String,
    val confirmation: Boolean,
    val timestamp: Long
)

data class DemandForecastResponse(
    val period: String,
    val predictedDemand: Int,
    val confidence: Double,
    val demandSpike: Double,
    val factors: List<String>,
    val accuracy: Double,
    val seasonalAdjustments: Map<String, Double>,
    val externalFactors: List<ExternalFactor>,
    val timestamp: Long
)

data class DemandAnalysisResponse(
    val period: String,
    val demandTrends: List<DemandTrend>,
    val influencingFactors: List<InfluencingFactor>,
    val seasonality: SeasonalityAnalysis,
    val correlations: List<Correlation>,
    val recommendations: List<String>,
    val timestamp: Long
)

data class RiskAnalysisResponse(
    val shipmentId: String,
    val overallRisk: Double,
    val riskFactors: Map<String, Double>,
    val recommendations: List<String>,
    val mitigationStrategies: List<MitigationStrategy>,
    val riskLevel: String,
    val confidence: Double,
    val timestamp: Long
)

data class RiskMitigationResponse(
    val shipmentId: String,
    val mitigationApplied: Boolean,
    val strategiesImplemented: List<String>,
    val riskReduction: Double,
    val cost: Double,
    val timestamp: Long
)

data class AIInsightsResponse(
    val totalPredictions: Int,
    val activeOptimizations: Int,
    val fuelSavings: Double,
    val delaysPrevented: Int,
    val maintenanceAlerts: Int,
    val driverImprovements: Int,
    val demandAccuracy: Double,
    val riskReduction: Double,
    val modelPerformance: Map<String, Double>,
    val systemHealth: SystemHealth,
    val lastUpdated: Long
)

data class AIPerformanceResponse(
    val modelAccuracy: Map<String, Double>,
    val processingTime: Map<String, Long>,
    val predictionVolume: Map<String, Int>,
    val errorRates: Map<String, Double>,
    val resourceUsage: ResourceUsage,
    val uptime: Double,
    val lastUpdated: Long
)

data class AIMetricsResponse(
    val dailyMetrics: List<DailyMetrics>,
    val weeklyMetrics: List<WeeklyMetrics>,
    val monthlyMetrics: List<MonthlyMetrics>,
    val performanceTrends: List<PerformanceTrend>,
    val efficiencyMetrics: EfficiencyMetrics,
    val costMetrics: CostMetrics,
    val qualityMetrics: QualityMetrics
)

data class ModelTrainingResponse(
    val modelId: String,
    val modelType: String,
    val trainingStatus: String,
    val accuracy: Double,
    val loss: Double,
    val trainingTime: Long,
    val datasetSize: Int,
    val validationResults: ValidationResults,
    val timestamp: Long
)

data class ModelStatusResponse(
    val models: List<ModelStatus>,
    val systemStatus: String,
    val lastTraining: Long,
    val nextTraining: Long,
    val performance: Map<String, Double>
)

data class ModelUpdateResponse(
    val modelId: String,
    val updateStatus: String,
    val accuracyImprovement: Double,
    val updateSize: Int,
    val processingTime: Long,
    val timestamp: Long
)

data class AnalyticsProcessingResponse(
    val requestId: String,
    val status: String,
    val estimatedCompletion: Long,
    val progress: Double,
    val results: AnalyticsResults?,
    val timestamp: Long
)

data class AnalyticsResultsResponse(
    val requestId: String,
    val status: String,
    val results: AnalyticsResults,
    val charts: List<ChartData>,
    val insights: List<Insight>,
    val recommendations: List<String>,
    val timestamp: Long
)

data class AnalyticsExportResponse(
    val exportId: String,
    val status: String,
    val downloadUrl: String,
    val format: String,
    val size: Long,
    val expiresAt: Long,
    val timestamp: Long
)

// Supporting data classes
data class AlternativeRoute(
    val route: List<LocationPoint>,
    val estimatedTime: Long,
    val distance: Double,
    val confidence: Double,
    val factors: List<String>
)

data class PredictionFactor(
    val factor: String,
    val impact: Double,
    val value: Double,
    val description: String
)

data class VehiclePerformance(
    val vehicleId: String,
    val efficiency: Double,
    val costPerMile: Double,
    val utilization: Double,
    val maintenanceScore: Double
)

data class ImprovementOpportunity(
    val vehicleId: String,
    val opportunity: String,
    val potentialSavings: Double,
    val priority: String,
    val effort: String
)

data class EfficiencyTrend(
    val date: String,
    val efficiency: Double,
    val cost: Double,
    val mileage: Double
)

data class PerformanceTrend(
    val date: String,
    val score: Double,
    val metric: String,
    val value: Double
)

data class TrainingRecommendation(
    val type: String,
    val priority: String,
    val duration: String,
    val expectedImprovement: Double,
    val cost: Double
)

data class ExternalFactor(
    val factor: String,
    val impact: Double,
    val description: String,
    val source: String
)

data class DemandTrend(
    val date: String,
    val demand: Int,
    val predicted: Int,
    val variance: Double
)

data class InfluencingFactor(
    val factor: String,
    val impact: Double,
    val correlation: Double,
    val description: String
)

data class SeasonalityAnalysis(
    val monthlyPatterns: Map<String, Double>,
    val weeklyPatterns: Map<String, Double>,
    val dailyPatterns: Map<String, Double>,
    val seasonalIndex: Double
)

data class Correlation(
    val factor1: String,
    val factor2: String,
    val correlation: Double,
    val significance: Double
)

data class SystemHealth(
    val status: String,
    val cpuUsage: Double,
    val memoryUsage: Double,
    val diskUsage: Double,
    val networkLatency: Long,
    val errorRate: Double
)

data class ResourceUsage(
    val cpu: Double,
    val memory: Double,
    val disk: Double,
    val network: Double,
    val gpu: Double
)

data class DailyMetrics(
    val date: String,
    val predictions: Int,
    val accuracy: Double,
    val processingTime: Long,
    val errors: Int
)

data class WeeklyMetrics(
    val week: String,
    val predictions: Int,
    val accuracy: Double,
    val processingTime: Long,
    val errors: Int
)

data class MonthlyMetrics(
    val month: String,
    val predictions: Int,
    val accuracy: Double,
    val processingTime: Long,
    val errors: Int
)

data class EfficiencyMetrics(
    val predictionAccuracy: Double,
    val processingSpeed: Double,
    val resourceUtilization: Double,
    val costEffectiveness: Double
)

data class CostMetrics(
    val operationalCost: Double,
    val costPerPrediction: Double,
    val savingsGenerated: Double,
    val roi: Double
)

data class QualityMetrics(
    val accuracy: Double,
    val precision: Double,
    val recall: Double,
    val f1Score: Double
)

data class ModelStatus(
    val modelId: String,
    val modelType: String,
    val status: String,
    val accuracy: Double,
    val lastTrained: Long,
    val version: String
)

data class ValidationResults(
    val accuracy: Double,
    val precision: Double,
    val recall: Double,
    val f1Score: Double,
    val confusionMatrix: Map<String, Map<String, Int>>
)

data class AnalyticsResults(
    val summary: Map<String, Any>,
    val details: List<Map<String, Any>>,
    val charts: List<ChartData>,
    val insights: List<Insight>
)

data class ChartData(
    val type: String,
    val title: String,
    val data: List<Map<String, Any>>,
    val config: Map<String, Any>
)

data class Insight(
    val type: String,
    val title: String,
    val description: String,
    val confidence: Double,
    val impact: String,
    val recommendations: List<String>
)
