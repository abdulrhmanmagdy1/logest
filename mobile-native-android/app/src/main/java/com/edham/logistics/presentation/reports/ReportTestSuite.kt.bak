package com.edham.logistics.presentation.reports

import androidx.test.ext.junit.runners.AndroidJUnit4
import com.edham.logistics.core.reports.ReportManager
import com.edham.logistics.core.reports.data.*
import com.edham.logistics.domain.reports.ReportUseCases
import com.edham.logistics.data.reports.ReportRepository
import dagger.hilt.android.testing.HiltAndroidTest
import kotlinx.coroutines.flow.first
import kotlinx.coroutines.test.runTest
import org.junit.Before
import org.junit.Test
import org.junit.runner.RunWith
import org.mockito.Mock
import org.mockito.Mockito.*
import javax.inject.Inject

/**
 * Report Test Suite - Comprehensive testing for Business Intelligence Reports
 * Tests all components of the reporting system including UI, business logic, and data layers
 */
@HiltAndroidTest
@RunWith(AndroidJUnit4::class)
class ReportTestSuite {

    @Inject
    lateinit var reportViewModel: ReportViewModel

    @Mock
    private lateinit var mockReportUseCases: ReportUseCases

    @Mock
    private lateinit var mockReportManager: ReportManager

    @Mock
    private lateinit var mockReportRepository: ReportRepository

    private lateinit var reportTestHelper: ReportTestHelper

    @Before
    fun setup() {
        reportTestHelper = ReportTestHelper()
    }

    // Revenue Report Tests
    @Test
    fun testRevenueReportGeneration() = runTest {
        // Arrange
        val startDate = System.currentTimeMillis() - 86400000L // Yesterday
        val endDate = System.currentTimeMillis()
        val expectedReport = reportTestHelper.createRevenueReport(startDate, endDate)

        `when`(mockReportUseCases.generateRevenueReport(startDate, endDate, RevenueReportType.DETAILED))
            .thenReturn(Result.success(expectedReport))

        // Act
        reportViewModel.generateRevenueReport(startDate, endDate, RevenueReportType.DETAILED)

        // Assert
        val state = reportViewModel.revenueReportState.first()
        assert(state is ReportState.Success)
        assert((state as ReportState.Success).data.id == expectedReport.id)
        assert((state).data.totalRevenue == expectedReport.totalRevenue)
    }

    @Test
    fun testRevenueReportGenerationFailure() = runTest {
        // Arrange
        val startDate = System.currentTimeMillis() - 86400000L
        val endDate = System.currentTimeMillis()
        val errorMessage = "Failed to generate revenue report"

        `when`(mockReportUseCases.generateRevenueReport(startDate, endDate, RevenueReportType.DETAILED))
            .thenReturn(Result.failure(Exception(errorMessage)))

        // Act
        reportViewModel.generateRevenueReport(startDate, endDate, RevenueReportType.DETAILED)

        // Assert
        val state = reportViewModel.revenueReportState.first()
        assert(state is ReportState.Error)
        assert((state as ReportState.Error).message == errorMessage)
    }

    // Shipment Performance Report Tests
    @Test
    fun testShipmentPerformanceReportGeneration() = runTest {
        // Arrange
        val startDate = System.currentTimeMillis() - 86400000L
        val endDate = System.currentTimeMillis()
        val expectedReport = reportTestHelper.createShipmentPerformanceReport(startDate, endDate)

        `when`(mockReportUseCases.generateShipmentPerformanceReport(startDate, endDate, ShipmentReportType.COMPREHENSIVE))
            .thenReturn(Result.success(expectedReport))

        // Act
        reportViewModel.generateShipmentPerformanceReport(startDate, endDate, ShipmentReportType.COMPREHENSIVE)

        // Assert
        val state = reportViewModel.shipmentReportState.first()
        assert(state is ReportState.Success)
        assert((state as ReportState.Success).data.id == expectedReport.id)
        assert((state).data.totalShipments == expectedReport.totalShipments)
    }

    // Driver Performance Report Tests
    @Test
    fun testDriverPerformanceReportGeneration() = runTest {
        // Arrange
        val startDate = System.currentTimeMillis() - 86400000L
        val endDate = System.currentTimeMillis()
        val expectedReport = reportTestHelper.createDriverPerformanceReport(startDate, endDate)

        `when`(mockReportUseCases.generateDriverPerformanceReport(startDate, endDate, DriverReportType.DETAILED))
            .thenReturn(Result.success(expectedReport))

        // Act
        reportViewModel.generateDriverPerformanceReport(startDate, endDate, DriverReportType.DETAILED)

        // Assert
        val state = reportViewModel.driverReportState.first()
        assert(state is ReportState.Success)
        assert((state as ReportState.Success).data.id == expectedReport.id)
        assert((state).data.driverPerformances.size == expectedReport.driverPerformances.size)
    }

    // Customer Behavior Report Tests
    @Test
    fun testCustomerBehaviorReportGeneration() = runTest {
        // Arrange
        val startDate = System.currentTimeMillis() - 86400000L
        val endDate = System.currentTimeMillis()
        val expectedReport = reportTestHelper.createCustomerBehaviorReport(startDate, endDate)

        `when`(mockReportUseCases.generateCustomerBehaviorReport(startDate, endDate, CustomerReportType.COMPREHENSIVE))
            .thenReturn(Result.success(expectedReport))

        // Act
        reportViewModel.generateCustomerBehaviorReport(startDate, endDate, CustomerReportType.COMPREHENSIVE)

        // Assert
        val state = reportViewModel.customerReportState.first()
        assert(state is ReportState.Success)
        assert((state as ReportState.Success).data.id == expectedReport.id)
        assert((state).data.customerInsights.size == expectedReport.customerInsights.size)
    }

    // Export Tests
    @Test
    fun testPDFExport() = runTest {
        // Arrange
        val report = reportTestHelper.createRevenueReport(System.currentTimeMillis() - 86400000L, System.currentTimeMillis())
        val fileName = "test_revenue_report"
        val expectedFilePath = "/path/to/test_revenue_report_20240131_143022.pdf"

        `when`(mockReportManager.exportToPDF(report, fileName))
            .thenReturn(expectedFilePath)

        // Act
        reportViewModel.exportToPDF(report, fileName)

        // Assert
        val state = reportViewModel.exportState.first()
        assert(state is ExportState.Success)
        assert((state as ExportState.Success).filePath == expectedFilePath)
    }

    @Test
    fun testExcelExport() = runTest {
        // Arrange
        val report = reportTestHelper.createRevenueReport(System.currentTimeMillis() - 86400000L, System.currentTimeMillis())
        val fileName = "test_revenue_report"
        val expectedFilePath = "/path/to/test_revenue_report_20240131_143022.xlsx"

        `when`(mockReportManager.exportToExcel(report, fileName))
            .thenReturn(expectedFilePath)

        // Act
        reportViewModel.exportToExcel(report, fileName)

        // Assert
        val state = reportViewModel.exportState.first()
        assert(state is ExportState.Success)
        assert((state as ExportState.Success).filePath == expectedFilePath)
    }

    @Test
    fun testExportFailure() = runTest {
        // Arrange
        val report = reportTestHelper.createRevenueReport(System.currentTimeMillis() - 86400000L, System.currentTimeMillis())
        val fileName = "test_revenue_report"
        val errorMessage = "Export failed"

        `when`(mockReportManager.exportToPDF(report, fileName))
            .thenThrow(Exception(errorMessage))

        // Act
        reportViewModel.exportToPDF(report, fileName)

        // Assert
        val state = reportViewModel.exportState.first()
        assert(state is ExportState.Error)
        assert((state as ExportState.Error).message == errorMessage)
    }

    // Report Management Tests
    @Test
    fun testReportSaving() = runTest {
        // Arrange
        val report = reportTestHelper.createRevenueReport(System.currentTimeMillis() - 86400000L, System.currentTimeMillis())
        val expectedReportId = "report_123"

        `when`(mockReportUseCases.saveReport(report))
            .thenReturn(Result.success(expectedReportId))

        // Act
        val result = reportViewModel.saveReport(report)

        // Assert
        assert(result.isSuccess)
        assert(result.getOrNull() == expectedReportId)
    }

    @Test
    fun testReportDeletion() = runTest {
        // Arrange
        val reportId = "report_123"
        val reportType = "revenue"

        `when`(mockReportUseCases.deleteReport(reportId, reportType))
            .thenReturn(Result.success(true))

        // Act
        reportViewModel.deleteReport(reportId, reportType)

        // Assert
        verify(mockReportUseCases, times(1)).deleteReport(reportId, reportType)
    }

    // UI State Tests
    @Test
    fun testReportTypeSelection() {
        // Act
        reportViewModel.updateSelectedReportType(ReportType.SHIPMENT)

        // Assert
        assert(reportViewModel.getCurrentReportType() == ReportType.SHIPMENT)
    }

    @Test
    fun testDateRangeUpdate() {
        // Arrange
        val startDate = System.currentTimeMillis() - 86400000L
        val endDate = System.currentTimeMillis()

        // Act
        reportViewModel.updateDateRange(startDate, endDate)

        // Assert
        val (actualStartDate, actualEndDate) = reportViewModel.getCurrentDateRange()
        assert(actualStartDate == startDate)
        assert(actualEndDate == endDate)
    }

    @Test
    fun testFilterUpdate() {
        // Arrange
        val filters = ReportFilters(
            customerIds = listOf("customer1", "customer2"),
            driverIds = listOf("driver1"),
            minAmount = 100.0,
            maxAmount = 1000.0
        )

        // Act
        reportViewModel.updateReportFilters(filters)

        // Assert
        val actualFilters = reportViewModel.getCurrentFilters()
        assert(actualFilters.customerIds == filters.customerIds)
        assert(actualFilters.driverIds == filters.driverIds)
        assert(actualFilters.minAmount == filters.minAmount)
        assert(actualFilters.maxAmount == filters.maxAmount)
    }

    // Quick Report Generation Tests
    @Test
    fun testTodayRevenueReportGeneration() = runTest {
        // Arrange
        val expectedReport = reportTestHelper.createRevenueReport(
            System.currentTimeMillis() - 86400000L,
            System.currentTimeMillis()
        )

        `when`(mockReportUseCases.generateRevenueReport(anyLong(), anyLong(), any()))
            .thenReturn(Result.success(expectedReport))

        // Act
        reportViewModel.generateTodayRevenueReport()

        // Assert
        val state = reportViewModel.revenueReportState.first()
        assert(state is ReportState.Success)
    }

    @Test
    fun testThisMonthShipmentReportGeneration() = runTest {
        // Arrange
        val expectedReport = reportTestHelper.createShipmentPerformanceReport(
            System.currentTimeMillis() - 2592000000L, // 30 days ago
            System.currentTimeMillis()
        )

        `when`(mockReportUseCases.generateShipmentPerformanceReport(anyLong(), anyLong(), any()))
            .thenReturn(Result.success(expectedReport))

        // Act
        reportViewModel.generateThisMonthShipmentReport()

        // Assert
        val state = reportViewModel.shipmentReportState.first()
        assert(state is ReportState.Success)
    }

    // State Clearing Tests
    @Test
    fun testReportStateClearing() {
        // Set initial state
        reportViewModel.updateSelectedReportType(ReportType.REVENUE)

        // Act
        reportViewModel.clearReportState(ReportType.REVENUE)

        // Assert
        val state = reportViewModel.revenueReportState.first()
        assert(state is ReportState.Idle)
    }

    @Test
    fun testExportStateClearing() {
        // Act
        reportViewModel.clearExportState()

        // Assert
        val state = reportViewModel.exportState.first()
        assert(state is ExportState.Idle)
    }

    // Performance Tests
    @Test
    fun testLargeReportGenerationPerformance() = runTest {
        // Arrange
        val startDate = System.currentTimeMillis() - 86400000L * 365 // 1 year ago
        val endDate = System.currentTimeMillis()
        val largeReport = reportTestHelper.createLargeRevenueReport(startDate, endDate)

        `when`(mockReportUseCases.generateRevenueReport(startDate, endDate, RevenueReportType.DETAILED))
            .thenReturn(Result.success(largeReport))

        // Act & Assert (should complete within reasonable time)
        val startTime = System.currentTimeMillis()
        reportViewModel.generateRevenueReport(startDate, endDate, RevenueReportType.DETAILED)
        val endTime = System.currentTimeMillis()

        // Should complete within 5 seconds for large report
        assert(endTime - startTime < 5000L)
        
        val state = reportViewModel.revenueReportState.first()
        assert(state is ReportState.Success)
    }

    // Integration Tests
    @Test
    fun testCompleteReportWorkflow() = runTest {
        // Arrange
        val startDate = System.currentTimeMillis() - 86400000L
        val endDate = System.currentTimeMillis()
        val report = reportTestHelper.createRevenueReport(startDate, endDate)
        val fileName = "workflow_test_report"
        val expectedFilePath = "/path/to/workflow_test_report_20240131_143022.pdf"

        `when`(mockReportUseCases.generateRevenueReport(startDate, endDate, RevenueReportType.DETAILED))
            .thenReturn(Result.success(report))
        `when`(mockReportUseCases.saveReport(report))
            .thenReturn(Result.success("report_123"))
        `when`(mockReportManager.exportToPDF(report, fileName))
            .thenReturn(expectedFilePath)

        // Act - Generate report
        reportViewModel.generateRevenueReport(startDate, endDate, RevenueReportType.DETAILED)
        val generateState = reportViewModel.revenueReportState.first()
        assert(generateState is ReportState.Success)

        // Act - Save report
        val saveResult = reportViewModel.saveReport(report)
        assert(saveResult.isSuccess)

        // Act - Export report
        reportViewModel.exportToPDF(report, fileName)
        val exportState = reportViewModel.exportState.first()
        assert(exportState is ExportState.Success)
        assert((exportState as ExportState.Success).filePath == expectedFilePath)
    }
}

/**
 * Report Test Helper - Utility class for creating test data
 */
class ReportTestHelper {

    fun createRevenueReport(startDate: Long, endDate: Long): RevenueReport {
        return RevenueReport(
            id = "revenue_${System.currentTimeMillis()}",
            title = "Revenue Report",
            startDate = startDate,
            endDate = endDate,
            reportType = RevenueReportType.DETAILED,
            generatedAt = System.currentTimeMillis(),
            totalRevenue = 150000.0,
            totalInvoices = 250,
            paidInvoices = 200,
            unpaidInvoices = 50,
            revenueByPeriod = listOf(
                RevenueByPeriod("2024-01-31", 5000.0, 10),
                RevenueByPeriod("2024-01-30", 4500.0, 8)
            ),
            revenueByCustomer = listOf(
                RevenueByCustomer("customer1", 25000.0, 25, 1000.0),
                RevenueByCustomer("customer2", 15000.0, 15, 1000.0)
            ),
            revenueByServiceType = listOf(
                RevenueByServiceType("Standard", 100000.0, 200, 500.0),
                RevenueByServiceType("Express", 50000.0, 50, 1000.0)
            ),
            paymentMethods = listOf(
                PaymentMethodAnalysis("Credit Card", 150, 100000.0, 666.67, 60.0),
                PaymentMethodAnalysis("Cash", 100, 50000.0, 500.0, 40.0)
            ),
            overdueAnalysis = OverdueAnalysis(
                overdueCount = 50,
                totalOverdueAmount = 25000.0,
                averageOverdueDays = 15.5,
                overduePercentage = 20.0
            ),
            averageInvoiceValue = 600.0,
            revenueGrowth = 15.5
        )
    }

    fun createShipmentPerformanceReport(startDate: Long, endDate: Long): ShipmentPerformanceReport {
        return ShipmentPerformanceReport(
            id = "shipment_${System.currentTimeMillis()}",
            title = "Shipment Performance Report",
            startDate = startDate,
            endDate = endDate,
            reportType = ShipmentReportType.COMPREHENSIVE,
            generatedAt = System.currentTimeMillis(),
            totalShipments = 500,
            deliveredShipments = 450,
            delayedShipments = 30,
            cancelledShipments = 20,
            onTimeDeliveryRate = 90.0,
            averageDeliveryTime = 3600000.0, // 1 hour in milliseconds
            performanceByRoute = listOf(
                RoutePerformance("Riyadh-Jeddah", 100, 95, 5, 95.0, 3500000.0),
                RoutePerformance("Riyadh-Dammam", 80, 75, 5, 93.75, 3200000.0)
            ),
            performanceByDriver = listOf(
                DriverPerformance("driver1", "Driver 1", 50, 48, 2, 96.0, 3400000.0, 12000.0, 4.5, 8.5, 96.0),
                DriverPerformance("driver2", "Driver 2", 45, 42, 3, 93.33, 3800000.0, 13500.0, 4.3, 8.2, 93.33)
            ),
            performanceByVehicleType = listOf(
                VehicleTypePerformance("Truck", 300, 280, 20, 93.33, 3700000.0),
                VehicleTypePerformance("Van", 200, 170, 10, 85.0, 3400000.0)
            ),
            delayAnalysis = DelayAnalysis(
                delayedCount = 30,
                averageDelayMinutes = 45.5,
                maxDelayMinutes = 120,
                delayPercentage = 6.0
            ),
            geographicPerformance = listOf(
                GeographicPerformance("Riyadh", 200, 190, 10, 95.0),
                GeographicPerformance("Jeddah", 150, 135, 15, 90.0)
            )
        )
    }

    fun createDriverPerformanceReport(startDate: Long, endDate: Long): DriverPerformanceReport {
        val drivers = listOf(
            DriverPerformance("driver1", "Ahmed Mohammed", 50, 48, 2, 96.0, 3400000.0, 12000.0, 4.5, 8.5, 96.0),
            DriverPerformance("driver2", "Mohammed Ali", 45, 42, 3, 93.33, 3800000.0, 13500.0, 4.3, 8.2, 93.33),
            DriverPerformance("driver3", "Saeed Khalid", 40, 38, 2, 95.0, 3500000.0, 12200.0, 4.6, 8.8, 95.0)
        )

        return DriverPerformanceReport(
            id = "driver_${System.currentTimeMillis()}",
            title = "Driver Performance Report",
            startDate = startDate,
            endDate = endDate,
            reportType = DriverReportType.DETAILED,
            generatedAt = System.currentTimeMillis(),
            driverPerformances = drivers,
            teamStatistics = TeamStatistics(
                totalDrivers = drivers.size,
                averageOnTimeDeliveryRate = drivers.map { it.onTimeDeliveryRate }.average(),
                averageCustomerSatisfaction = drivers.map { it.customerSatisfaction }.average(),
                totalRevenueGenerated = drivers.sumOf { it.revenueGenerated },
                topPerformer = drivers.maxByOrNull { it.rating }
            ),
            performanceTrends = emptyList(),
            topPerformers = drivers.sortedByDescending { it.rating }.take(5),
            areasForImprovement = listOf("تحسين معدل التسليم في الوقت المحدد", "رفع مستوى رضا العملاء")
        )
    }

    fun createCustomerBehaviorReport(startDate: Long, endDate: Long): CustomerBehaviorReport {
        val customers = listOf(
            CustomerInsight("customer1", "ABC Company", 25, 25000.0, 1000.0, 0.83, 8.5, listOf("Standard", "Express"), 
                PaymentBehavior(95.0, 2.5, listOf("Credit Card", "Bank Transfer")), listOf("Riyadh", "Jeddah"), RiskLevel.LOW, 8.0),
            CustomerInsight("customer2", "XYZ Corporation", 15, 15000.0, 1000.0, 0.5, 7.2, listOf("Standard"), 
                PaymentBehavior(85.0, 5.0, listOf("Cash")), listOf("Dammam"), RiskLevel.MEDIUM, 6.5)
        )

        return CustomerBehaviorReport(
            id = "customer_${System.currentTimeMillis()}",
            title = "Customer Behavior Report",
            startDate = startDate,
            endDate = endDate,
            reportType = CustomerReportType.COMPREHENSIVE,
            generatedAt = System.currentTimeMillis(),
            customerInsights = customers,
            marketSegmentation = MarketSegmentation(
                totalCustomers = customers.size,
                segments = listOf(
                    Segment("عملاء كبار", 1),
                    Segment("عملاء متوسطون", 1)
                )
            ),
            customerLifetimeValue = CustomerLifetimeValue(
                averageLifetimeValue = 20000.0,
                totalLifetimeValue = 40000.0,
                averageCustomerLifetime = 24.0
            ),
            churnAnalysis = ChurnAnalysis(
                churnRate = 5.2,
                atRiskCustomers = 1,
                retentionRate = 94.8
            ),
            seasonalPatterns = emptyList(),
            topCustomers = customers.sortedByDescending { it.totalRevenue }.take(10),
            atRiskCustomers = customers.filter { it.riskLevel == RiskLevel.HIGH }
        )
    }

    fun createLargeRevenueReport(startDate: Long, endDate: Long): RevenueReport {
        val baseReport = createRevenueReport(startDate, endDate)
        
        // Create large datasets for performance testing
        val largeRevenueByPeriod = (1..100).map { i ->
            RevenueByPeriod("2024-01-${i.toString().padStart(2, '0')}", 1000.0 * i, i * 2)
        }
        
        val largeRevenueByCustomer = (1..50).map { i ->
            RevenueByCustomer("customer$i", 5000.0 * i, i * 5, 1000.0)
        }
        
        val largeRevenueByServiceType = (1..10).map { i ->
            RevenueByServiceType("Service$i", 10000.0 * i, i * 10, 1000.0)
        }

        return baseReport.copy(
            totalInvoices = 1000,
            paidInvoices = 800,
            unpaidInvoices = 200,
            revenueByPeriod = largeRevenueByPeriod,
            revenueByCustomer = largeRevenueByCustomer,
            revenueByServiceType = largeRevenueByServiceType,
            totalRevenue = 500000.0
        )
    }
}
