package com.edham.logistics.performance

import android.app.ActivityManager
import android.content.Context
import android.graphics.Bitmap
import android.graphics.drawable.Drawable
import kotlinx.coroutines.*
import java.lang.ref.WeakReference
import java.util.concurrent.ConcurrentHashMap
import kotlin.math.min

/**
 * Memory Usage Optimizer for Reducing Memory Footprint
 */
class MemoryUsageOptimizer(private val context: Context) {
    
    private val memoryScope = CoroutineScope(Dispatchers.IO + SupervisorJob())
    private val memoryCache = ConcurrentHashMap<String, WeakReference<Any>>()
    private val bitmapCache = ConcurrentHashMap<String, WeakReference<Bitmap>>()
    private val objectPool = ConcurrentHashMap<Class<*>, MutableList<Any>>()
    
    // Memory monitoring
    private val memoryMonitor = MemoryMonitor()
    private val gcScheduler = ScheduledGC()
    
    // Memory thresholds
    private val lowMemoryThreshold = 0.75 // 75% of max memory
    private val criticalMemoryThreshold = 0.90 // 90% of max memory
    private val maxCacheSize = (Runtime.getRuntime().maxMemory() / 1024 / 8).toInt() // 1/8 of max memory
    
    init {
        startMemoryMonitoring()
        startGCScheduling()
    }
    
    /**
     * Cache data with weak references
     */
    fun cacheData(key: String, data: Any) {
        memoryCache[key] = WeakReference(data)
        
        // Check memory pressure
        if (memoryMonitor.isMemoryPressureHigh()) {
            cleanupWeakReferences()
        }
    }
    
    /**
     * Get cached data
     */
    @Suppress("UNCHECKED_CAST")
    fun <T> getCachedData(key: String): T? {
        val weakRef = memoryCache[key]
        val data = weakRef?.get()
        
        if (data == null) {
            memoryCache.remove(key)
        }
        
        return data as? T
    }
    
    /**
     * Cache bitmap with size optimization
     */
    fun cacheBitmap(key: String, bitmap: Bitmap) {
        val optimizedBitmap = optimizeBitmap(bitmap)
        bitmapCache[key] = WeakReference(optimizedBitmap)
        
        // Check memory pressure
        if (memoryMonitor.isBitmapMemoryHigh()) {
            cleanupBitmapCache()
        }
    }
    
    /**
     * Get cached bitmap
     */
    fun getCachedBitmap(key: String): Bitmap? {
        val weakRef = bitmapCache[key]
        val bitmap = weakRef?.get()
        
        if (bitmap == null) {
            bitmapCache.remove(key)
        }
        
        return bitmap
    }
    
    /**
     * Optimize bitmap size
     */
    fun optimizeBitmap(bitmap: Bitmap): Bitmap {
        val maxSize = 1024 // Max dimension
        val width = bitmap.width
        val height = bitmap.height
        
        if (width <= maxSize && height <= maxSize) {
            return bitmap
        }
        
        val ratio = min(maxSize.toFloat() / width, maxSize.toFloat() / height)
        val newWidth = (width * ratio).toInt()
        val newHeight = (height * ratio).toInt()
        
        return Bitmap.createScaledBitmap(bitmap, newWidth, newHeight, true)
    }
    
    /**
     * Get object from pool or create new
     */
    @Suppress("UNCHECKED_CAST")
    fun <T> getPooledObject(clazz: Class<T>, factory: () -> T): T {
        val pool = objectPool.getOrPut(clazz) { mutableListOf() }
        
        return synchronized(pool) {
            if (pool.isNotEmpty()) {
                pool.removeAt(pool.size - 1) as T
            } else {
                factory()
            }
        }
    }
    
    /**
     * Return object to pool
     */
    fun <T> returnToPool(obj: T, clazz: Class<*>) {
        val pool = objectPool.getOrPut(clazz) { mutableListOf() }
        
        synchronized(pool) {
            if (pool.size < 50) { // Limit pool size
                pool.add(obj)
            }
        }
    }
    
    /**
     * Clear all caches
     */
    fun clearAllCaches() {
        memoryCache.clear()
        bitmapCache.clear()
        objectPool.clear()
        System.gc()
    }
    
    /**
     * Get memory usage statistics
     */
    fun getMemoryStatistics(): MemoryStatistics {
        return MemoryStatistics(
            totalMemory = Runtime.getRuntime().totalMemory(),
            freeMemory = Runtime.getRuntime().freeMemory(),
            maxMemory = Runtime.getRuntime().maxMemory(),
            usedMemory = Runtime.getRuntime().totalMemory() - Runtime.getRuntime().freeMemory(),
            memoryUsagePercent = memoryMonitor.getMemoryUsagePercent(),
            cachedDataCount = memoryCache.size,
            cachedBitmapCount = bitmapCache.size,
            pooledObjectCount = objectPool.values.sumOf { it.size },
            memoryPressureLevel = memoryMonitor.getMemoryPressureLevel()
        )
    }
    
    /**
     * Start memory monitoring
     */
    private fun startMemoryMonitoring() {
        memoryMonitor.startMonitoring { pressureLevel ->
            when (pressureLevel) {
                MemoryPressureLevel.LOW -> {
                    // Normal operation
                }
                MemoryPressureLevel.MEDIUM -> {
                    cleanupWeakReferences()
                }
                MemoryPressureLevel.HIGH -> {
                    cleanupWeakReferences()
                    cleanupBitmapCache()
                }
                MemoryPressureLevel.CRITICAL -> {
                    clearAllCaches()
                }
            }
        }
    }
    
    /**
     * Start garbage collection scheduling
     */
    private fun startGCScheduling() {
        gcScheduler.startScheduling {
            if (memoryMonitor.shouldTriggerGC()) {
                System.gc()
            }
        }
    }
    
    /**
     * Cleanup weak references
     */
    private fun cleanupWeakReferences() {
        memoryCache.entries.removeIf { it.value.get() == null }
        bitmapCache.entries.removeIf { it.value.get() == null }
    }
    
    /**
     * Cleanup bitmap cache
     */
    private fun cleanupBitmapCache() {
        val entriesToRemove = bitmapCache.entries.shuffled().take(bitmapCache.size / 2)
        entriesToRemove.forEach { (key, _) ->
            bitmapCache.remove(key)
        }
    }
    
    /**
     * Memory monitor implementation
     */
    private inner class MemoryMonitor {
        private var isMonitoring = false
        private val monitoringJob = SupervisorJob()
        
        fun startMonitoring(onPressureChange: (MemoryPressureLevel) -> Unit) {
            if (isMonitoring) return
            
            isMonitoring = true
            memoryScope.launch(monitoringJob) {
                var lastPressureLevel = getMemoryPressureLevel()
                
                while (isMonitoring) {
                    val currentPressureLevel = getMemoryPressureLevel()
                    
                    if (currentPressureLevel != lastPressureLevel) {
                        onPressureChange(currentPressureLevel)
                        lastPressureLevel = currentPressureLevel
                    }
                    
                    delay(5000) // Check every 5 seconds
                }
            }
        }
        
        fun getMemoryUsagePercent(): Double {
            val runtime = Runtime.getRuntime()
            val usedMemory = runtime.totalMemory() - runtime.freeMemory()
            return (usedMemory.toDouble() / runtime.maxMemory()) * 100
        }
        
        fun isMemoryPressureHigh(): Boolean {
            return getMemoryUsagePercent() > lowMemoryThreshold * 100
        }
        
        fun isBitmapMemoryHigh(): Boolean {
            // Estimate bitmap memory usage
            val bitmapMemoryEstimate = bitmapCache.values.sumOf { weakRef ->
                weakRef.get()?.let { bitmap ->
                    bitmap.byteCount.toLong()
                } ?: 0L
            }
            
            val maxMemory = Runtime.getRuntime().maxMemory()
            return (bitmapMemoryEstimate.toDouble() / maxMemory) > 0.1 // 10% of max memory
        }
        
        fun getMemoryPressureLevel(): MemoryPressureLevel {
            val usagePercent = getMemoryUsagePercent()
            return when {
                usagePercent < lowMemoryThreshold * 100 -> MemoryPressureLevel.LOW
                usagePercent < criticalMemoryThreshold * 100 -> MemoryPressureLevel.HIGH
                else -> MemoryPressureLevel.CRITICAL
            }
        }
        
        fun shouldTriggerGC(): Boolean {
            return isMemoryPressureHigh() && bitmapCache.size > maxCacheSize
        }
        
        fun stopMonitoring() {
            isMonitoring = false
            monitoringJob.cancel()
        }
    }
    
    /**
     * Scheduled garbage collection
     */
    private inner class ScheduledGC {
        private var isScheduling = false
        private val schedulingJob = SupervisorJob()
        
        fun startScheduling(onGC: () -> Unit) {
            if (isScheduling) return
            
            isScheduling = true
            memoryScope.launch(schedulingJob) {
                while (isScheduling) {
                    delay(30000) // Every 30 seconds
                    onGC()
                }
            }
        }
        
        fun stopScheduling() {
            isScheduling = false
            schedulingJob.cancel()
        }
    }
    
    /**
     * Data classes
     */
    data class MemoryStatistics(
        val totalMemory: Long,
        val freeMemory: Long,
        val maxMemory: Long,
        val usedMemory: Long,
        val memoryUsagePercent: Double,
        val cachedDataCount: Int,
        val cachedBitmapCount: Int,
        val pooledObjectCount: Int,
        val memoryPressureLevel: MemoryPressureLevel
    )
    
    enum class MemoryPressureLevel {
        LOW, MEDIUM, HIGH, CRITICAL
    }
    
    /**
     * Cleanup resources
     */
    fun cleanup() {
        memoryMonitor.stopMonitoring()
        gcScheduler.stopScheduling()
        memoryScope.cancel()
        clearAllCaches()
    }
}
