                // Get driver performance data
                val totalDrivers = database.driverDao().getTotalDriversCount()
                val activeDrivers = database.driverDao().getActiveDriversCount()
                val driverPerformance = calculateIndividualDriverPerformance(dateRange)
                val topPerformers = getTopPerformingDrivers(dateRange, 10)
                val performanceByRegion = calculatePerformanceByRegion(dateRange)
                val averagePerformance = calculateAverageDriverPerformance(dateRange)
                
                val driverAnalytics = DriverPerformanceAnalytics(
                    period = dateRange,
                    totalDrivers = totalDrivers,
                    activeDrivers = activeDrivers,
                    averagePerformance = averagePerformance,
                    driverPerformance = driverPerformance,
                    topPerformers = topPerformers,
                    performanceByRegion = performanceByRegion,
                    generatedAt = Date()
                )
                
                _analyticsState.value = AnalyticsState.Ready
                Result.success(driverAnalytics)
                
            } catch (e: Exception) {
                _analyticsState.value = AnalyticsState.Error("Failed to get driver performance analytics: ${e.message}")
                Result.failure(e)
            }
        }
    }
    
