    /**
     * Helper functions
     */
    private suspend fun loadCachedAnalyticsData() {
        try {
            // Load cached analytics data from local storage
        } catch (e: Exception) {
            // Handle error
        }
    }
    
    private suspend fun initializeRealTimeKPIs() {
        calculateRealTimeKPIs()
    }
    
    private fun startAggregationTimer() {
        aggregationTimer = Timer()
        aggregationTimer?.scheduleAtFixedRate(object : TimerTask() {
            override fun run() {
                // Perform data aggregation
                performDataAggregation()
            }
        }, 0, AGGREGATION_INTERVAL_MS)
    }
    
    private fun startKPIUpdateTimer() {
        Timer().scheduleAtFixedRate(object : TimerTask() {
            override fun run() {
                // Update real-time KPIs
                calculateRealTimeKPIs()
            }
        }, 0, KPI_UPDATE_INTERVAL_MS)
    }
    
    private suspend fun performDataAggregation() {
        try {
            // Aggregate data for analytics
        } catch (e: Exception) {
            // Handle error
        }
    }
    
    private suspend fun calculateOnTimeDeliveryRate(): Float {
        val completedShipments = database.shipmentDao().getCompletedShipmentsCount(
            Date().apply { add(Calendar.DAY_OF_MONTH, -30) },
            Date()
        )
        val delayedShipments = database.shipmentDao().getDelayedShipmentsCount(
            Date().apply { add(Calendar.DAY_OF_MONTH, -30) },
            Date()
        )
        
        return if (completedShipments > 0) {
            ((completedShipments - delayedShipments).toFloat() / completedShipments) * 100f
        } else {
            0f
        }
    }
    
    private suspend fun calculateAverageFuelEfficiency(): Float {
        return database.fuelExpenseDao().getAverageFuelEfficiency(
            Date().apply { add(Calendar.DAY_OF_MONTH, -30) },
            Date()
        )
    }
    
    private suspend fun calculateFleetUtilization(dateRange: DateRange): FleetUtilization {
        val totalVehicles = database.vehicleDao().getTotalVehiclesCount()
        val activeVehicles = database.vehicleDao().getActiveVehiclesCount()
        val utilizationRate = if (totalVehicles > 0) (activeVehicles.toFloat() / totalVehicles) * 100f else 0f
        
        return FleetUtilization(
            totalVehicles = totalVehicles,
            activeVehicles = activeVehicles,
            utilizationRate = utilizationRate,
            averageHoursPerVehicle = calculateAverageHoursPerVehicle(dateRange)
        )
    }
    
    private suspend fun calculateVehiclePerformance(dateRange: DateRange): List<VehiclePerformance> {
        return database.vehicleDao().getAllVehicles().map { vehicle ->
            val trips = database.shipmentDao().getVehicleTrips(vehicle.id, dateRange.startDate, dateRange.endDate)
            val totalDistance = trips.sumOf { it.distance ?: 0.0 }
            val fuelConsumption = database.fuelExpenseDao().getVehicleFuelConsumption(vehicle.id, dateRange.startDate, dateRange.endDate)
            val efficiency = if (fuelConsumption > 0) totalDistance / fuelConsumption else 0.0
            
            VehiclePerformance(
                vehicleId = vehicle.id,
                vehicleNumber = vehicle.vehicleNumber,
                totalDistance = totalDistance,
                totalTrips = trips.size,
                fuelConsumption = fuelConsumption,
                efficiency = efficiency,
                utilization = calculateVehicleUtilization(vehicle.id, dateRange)
            )
        }
    }
    
    private suspend fun calculateMaintenanceAnalytics(dateRange: DateRange): MaintenanceAnalytics {
        val totalMaintenance = database.maintenanceExpenseDao().getTotalMaintenanceCost(dateRange.startDate, dateRange.endDate)
        val maintenanceByType = database.maintenanceExpenseDao().getMaintenanceCostByType(dateRange.startDate, dateRange.endDate)
        val averageDowntime = database.maintenanceExpenseDao().getAverageDowntime(dateRange.startDate, dateRange.endDate)
        
        return MaintenanceAnalytics(
            totalCost = totalMaintenance,
            costByType = maintenanceByType,
            averageDowntime = averageDowntime,
            preventiveMaintenanceRate = calculatePreventiveMaintenanceRate(dateRange)
        )
    }
    
    private suspend fun calculateFleetFuelAnalytics(dateRange: DateRange): FleetFuelAnalytics {
        val totalConsumption = database.fuelExpenseDao().getTotalFuelConsumption(dateRange.startDate, dateRange.endDate)
        val totalCost = database.fuelExpenseDao().getTotalFuelCost(dateRange.startDate, dateRange.endDate)
        val averagePrice = if (totalConsumption > 0) totalCost / totalConsumption else 0.0
        
        return FleetFuelAnalytics(
            totalConsumption = totalConsumption,
            totalCost = totalCost,
            averagePrice = averagePrice,
            consumptionTrend = calculateFuelConsumptionTrend(dateRange),
            priceTrend = calculateFuelPriceTrend(dateRange)
        )
    }
    
    private suspend fun calculateIndividualDriverPerformance(dateRange: DateRange): List<DriverPerformance> {
        return database.driverDao().getAllDrivers().map { driver ->
            val trips = database.shipmentDao().getDriverTrips(driver.id, dateRange.startDate, dateRange.endDate)
            val completedTrips = trips.count { it.status == ShipmentStatus.COMPLETED }
            val delayedTrips = trips.count { it.isDelayed }
            val totalDistance = trips.sumOf { it.distance ?: 0.0 }
            val totalRevenue = trips.sumOf { it.revenue ?: 0.0 }
            
            DriverPerformance(
                driverId = driver.id,
                driverName = driver.name,
                totalTrips = trips.size,
                completedTrips = completedTrips,
                delayedTrips = delayedTrips,
                completionRate = if (trips.isNotEmpty()) (completedTrips.toFloat() / trips.size) * 100f else 0f,
                onTimeDeliveryRate = if (completedTrips > 0) ((completedTrips - delayedTrips).toFloat() / completedTrips) * 100f else 0f,
                totalDistance = totalDistance,
                totalRevenue = totalRevenue,
                averageRating = calculateDriverAverageRating(driver.id, dateRange)
            )
        }
    }
    
    private suspend fun getTopPerformingDrivers(dateRange: DateRange, limit: Int): List<DriverPerformance> {
        return calculateIndividualDriverPerformance(dateRange)
            .sortedByDescending { it.completionRate * it.onTimeDeliveryRate }
            .take(limit)
    }
    
    private suspend fun calculatePerformanceByRegion(dateRange: DateRange): Map<String, RegionalPerformance> {
        // Implementation for calculating performance by region
        return emptyMap()
    }
    
    private suspend fun calculateAverageDriverPerformance(dateRange: DateRange): Float {
        val performances = calculateIndividualDriverPerformance(dateRange)
        return if (performances.isNotEmpty()) {
            performances.map { it.completionRate }.average().toFloat()
        } else {
            0f
        }
    }
    
    private suspend fun calculateDeliveryTimeAnalytics(dateRange: DateRange): DeliveryTimeAnalytics {
        val deliveryTimes = database.shipmentDao().getDeliveryTimes(dateRange.startDate, dateRange.endDate)
        val averageTime = if (deliveryTimes.isNotEmpty()) deliveryTimes.average() else 0.0
        val minTime = deliveryTimes.minOrNull() ?: 0.0
        val maxTime = deliveryTimes.maxOrNull() ?: 0.0
        
        return DeliveryTimeAnalytics(
            averageDeliveryTime = averageTime,
            minDeliveryTime = minTime,
            maxDeliveryTime = maxTime,
            deliveryTimeDistribution = calculateDeliveryTimeDistribution(deliveryTimes)
        )
    }
    
    private suspend fun calculateRevenueByShipment(dateRange: DateRange): Map<String, Double> {
        return database.invoiceDao().getRevenueByShipment(dateRange.startDate, dateRange.endDate)
    }
    
    private suspend fun calculateFuelEfficiencyByVehicle(dateRange: DateRange): Map<String, Float> {
        return database.fuelExpenseDao().getFuelEfficiencyByVehicle(dateRange.startDate, dateRange.endDate)
    }
    
    private suspend fun calculateFuelPriceTrends(dateRange: DateRange): List<PriceTrend> {
        return database.fuelExpenseDao().getFuelPriceTrends(dateRange.startDate, dateRange.endDate)
    }
    
    private suspend fun getTopFuelingStations(dateRange: DateRange, limit: Int): List<FuelingStation> {
        return database.fuelExpenseDao().getTopFuelingStations(dateRange.startDate, dateRange.endDate, limit)
    }
    
    private suspend fun calculateRevenueGrowth(dateRange: DateRange): RevenueGrowth {
        val currentPeriodRevenue = database.invoiceDao().getTotalRevenue(dateRange.startDate, dateRange.endDate)
        val previousPeriodRevenue = database.invoiceDao().getTotalRevenue(
            Date().apply { time = dateRange.startDate.time - (dateRange.endDate.time - dateRange.startDate.time) },
            dateRange.startDate
        )
        
        val growthRate = if (previousPeriodRevenue > 0) {
            ((currentPeriodRevenue - previousPeriodRevenue) / previousPeriodRevenue) * 100f
        } else {
            0f
        }
        
        return RevenueGrowth(
            currentPeriodRevenue = currentPeriodRevenue,
            previousPeriodRevenue = previousPeriodRevenue,
            growthRate = growthRate
        )
    }
    
    private suspend fun calculateAverageRevenuePerShipment(dateRange: DateRange): Double {
        val totalRevenue = database.invoiceDao().getTotalRevenue(dateRange.startDate, dateRange.endDate)
        val totalShipments = database.shipmentDao().getShipmentsCount(dateRange.startDate, dateRange.endDate)
        
        return if (totalShipments > 0) totalRevenue / totalShipments else 0.0
    }
    
    private suspend fun calculateTemperatureCompliance(dateRange: DateRange): TemperatureCompliance {
        val totalReadings = database.temperatureLogDao().getTotalReadings(dateRange.startDate, dateRange.endDate)
        val compliantReadings = database.temperatureLogDao().getCompliantReadings(dateRange.startDate, dateRange.endDate)
        
        return TemperatureCompliance(
            totalReadings = totalReadings,
            compliantReadings = compliantReadings,
            complianceRate = if (totalReadings > 0) (compliantReadings.toFloat() / totalReadings) * 100f else 100f
        )
    }
    
    private suspend fun calculateTemperatureTrends(dateRange: DateRange): List<TemperatureTrend> {
        return database.temperatureLogDao().getTemperatureTrends(dateRange.startDate, dateRange.endDate)
    }
    
    private suspend fun calculateColdChainEfficiency(dateRange: DateRange): Float {
        val totalShipments = database.shipmentDao().getShipmentsCount(dateRange.startDate, dateRange.endDate)
        val successfulColdChainShipments = database.shipmentDao().getSuccessfulColdChainShipments(dateRange.startDate, dateRange.endDate)
        
        return if (totalShipments > 0) (successfulColdChainShipments.toFloat() / totalShipments) * 100f else 100f
    }
    
    private suspend fun calculateAverageDelayTime(dateRange: DateRange): Double {
        return database.shipmentDao().getAverageDelayTime(dateRange.startDate, dateRange.endDate)
    }
    
    private suspend fun calculateDelayTrends(dateRange: DateRange): List<DelayTrend> {
        return database.shipmentDao().getDelayTrends(dateRange.startDate, dateRange.endDate)
    }
    
    private suspend fun calculateDelayCost(dateRange: DateRange): Double {
        return database.shipmentDao().getDelayCost(dateRange.startDate, dateRange.endDate)
    }
    
    private suspend fun calculateAverageIncidentResolutionTime(dateRange: DateRange): Double {
        return database.incidentDao().getAverageResolutionTime(dateRange.startDate, dateRange.endDate)
    }
    
    private suspend fun calculateIncidentTrends(dateRange: DateRange): List<IncidentTrend> {
        return database.incidentDao().getIncidentTrends(dateRange.startDate, dateRange.endDate)
    }
    
    private suspend fun calculateSafetyMetrics(dateRange: DateRange): SafetyMetrics {
        val totalIncidents = database.incidentDao().getIncidentsCount(dateRange.startDate, dateRange.endDate)
        val totalDistance = database.shipmentDao().getTotalDistance(dateRange.startDate, dateRange.endDate)
        val accidentRate = if (totalDistance > 0) (totalIncidents.toFloat() / (totalDistance / 1000f)) else 0f // incidents per 1000 km
        
        return SafetyMetrics(
            totalIncidents = totalIncidents,
            accidentRate = accidentRate,
            daysSinceLastIncident = calculateDaysSinceLastIncident(),
            safetyScore = calculateSafetyScore(dateRange)
        )
    }
    
    private suspend fun calculateAverageHoursPerVehicle(dateRange: DateRange): Float {
        return database.vehicleDao().getAverageHoursPerVehicle(dateRange.startDate, dateRange.endDate)
    }
    
    private suspend fun calculateVehicleUtilization(vehicleId: String, dateRange: DateRange): Float {
        val totalHours = database.vehicleDao().getVehicleOperatingHours(vehicleId, dateRange.startDate, dateRange.endDate)
        val periodHours = (dateRange.endDate.time - dateRange.startDate.time) / (1000 * 60 * 60)
        
        return if (periodHours > 0) (totalHours / periodHours) * 100f else 0f
    }
    
    private suspend fun calculatePreventiveMaintenanceRate(dateRange: DateRange): Float {
        val totalMaintenance = database.maintenanceExpenseDao().getTotalMaintenanceCount(dateRange.startDate, dateRange.endDate)
        val preventiveMaintenance = database.maintenanceExpenseDao().getPreventiveMaintenanceCount(dateRange.startDate, dateRange.endDate)
        
        return if (totalMaintenance > 0) (preventiveMaintenance.toFloat() / totalMaintenance) * 100f else 0f
    }
    
    private suspend fun calculateFuelConsumptionTrend(dateRange: DateRange): List<ConsumptionTrend> {
        return database.fuelExpenseDao().getFuelConsumptionTrends(dateRange.startDate, dateRange.endDate)
    }
    
    private suspend fun calculateDriverAverageRating(driverId: String, dateRange: DateRange): Float {
        return database.driverDao().getDriverAverageRating(driverId, dateRange.startDate, dateRange.endDate)
    }
    
    private suspend fun calculateDeliveryTimeDistribution(deliveryTimes: List<Double>): Map<String, Int> {
        return distributionOf(deliveryTimes) { time ->
            when {
                time < 2 -> "Under 2 hours"
                time < 4 -> "2-4 hours"
                time < 8 -> "4-8 hours"
                time < 24 -> "8-24 hours"
                else -> "Over 24 hours"
            }
        }
    }
    
    private fun <T> distributionOf(items: List<T>, classifier: (T) -> String): Map<String, Int> {
        return items.groupingBy { classifier(it) }.eachCount()
    }
    
    private suspend fun calculateDaysSinceLastIncident(): Long {
        val lastIncident = database.incidentDao().getLastIncident()
        return if (lastIncident != null) {
            (Date().time - lastIncident.date.time) / (1000 * 60 * 60 * 24)
        } else {
            Long.MAX_VALUE
        }
    }
    
    private suspend fun calculateSafetyScore(dateRange: DateRange): Float {
        val incidents = database.incidentDao().getIncidentsCount(dateRange.startDate, dateRange.endDate)
        val distance = database.shipmentDao().getTotalDistance(dateRange.startDate, dateRange.endDate)
        
        // Safety score calculation (100 - incidents per 1000km * 10)
        val incidentRate = if (distance > 0) (incidents.toFloat() / (distance / 1000f)) else 0f
        return maxOf(0f, 100f - (incidentRate * 10f))
    }
    
    /**
     * Get initialization status
     */
    fun isInitialized(): Boolean = isInitialized
    
    /**
     * Cleanup resources
     */
    fun cleanup() {
        aggregationTimer?.cancel()
        aggregationTimer = null
    }
}

/**
 * Data classes for analytics
 */
data class RealTimeKPIs(
    val activeShipments: Int = 0,
    val totalVehicles: Int = 0,
    val activeDrivers: Int = 0,
    val todayRevenue: Double = 0.0,
    val todayExpenses: Double = 0.0,
    val netProfit: Double = 0.0,
    val averageTemperature: Float = 0f,
    val activeAlerts: Int = 0,
    val onTimeDeliveryRate: Float = 0f,
    val fuelEfficiency: Float = 0f,
    val lastUpdated: Date = Date()
)

data class AnalyticsData(
    val fleetAnalytics: FleetAnalytics? = null,
    val shipmentAnalytics: ShipmentAnalytics? = null,
    val driverAnalytics: DriverPerformanceAnalytics? = null,
    val fuelAnalytics: FuelAnalytics? = null,
    val revenueAnalytics: RevenueAnalytics? = null,
    val temperatureAnalytics: TemperatureAnalytics? = null,
    val delayAnalytics: DelayAnalytics? = null,
    val incidentAnalytics: IncidentAnalytics? = null,
    val lastUpdated: Date = Date()
)

data class FleetAnalytics(
    val period: DateRange,
    val totalVehicles: Int,
    val activeVehicles: Int,
    val fleetUtilization: FleetUtilization,
    val vehiclePerformance: List<VehiclePerformance>,
    val maintenanceAnalytics: MaintenanceAnalytics,
    val fuelAnalytics: FleetFuelAnalytics,
    val generatedAt: Date
)

data class ShipmentAnalytics(
    val period: DateRange,
    val totalShipments: Int,
    val completedShipments: Int,
    val delayedShipments: Int,
    val completionRate: Float,
    val onTimeDeliveryRate: Float,
    val shipmentByStatus: Map<String, Int>,
    val shipmentByType: Map<String, Int>,
    val deliveryTimes: DeliveryTimeAnalytics,
    val revenueByShipment: Map<String, Double>,
    val generatedAt: Date
)

data class DriverPerformanceAnalytics(
    val period: DateRange,
    val totalDrivers: Int,
    val activeDrivers: Int,
    val averagePerformance: Float,
    val driverPerformance: List<DriverPerformance>,
    val topPerformers: List<DriverPerformance>,
    val performanceByRegion: Map<String, RegionalPerformance>,
    val generatedAt: Date
)

data class FuelAnalytics(
    val period: DateRange,
    val totalFuelConsumption: Double,
    val totalFuelCost: Double,
    val averageFuelPrice: Double,
    val fuelByVehicle: Map<String, Double>,
    val fuelEfficiency: Map<String, Float>,
    val fuelPriceTrends: List<PriceTrend>,
    val topFuelingStations: List<FuelingStation>,
    val generatedAt: Date
)

data class RevenueAnalytics(
    val period: DateRange,
    val totalRevenue: Double,
    val revenueByMonth: Map<String, Double>,
    val revenueByService: Map<String, Double>,
    val revenueByCustomer: Map<String, Double>,
    val revenueByRegion: Map<String, Double>,
    val revenueGrowth: RevenueGrowth,
    val averageRevenuePerShipment: Double,
    val generatedAt: Date
)

data class TemperatureAnalytics(
    val period: DateRange,
    val averageTemperature: Float,
    val temperatureByVehicle: Map<String, Float>,
    val temperatureAlerts: Int,
    val temperatureCompliance: TemperatureCompliance,
    val temperatureTrends: List<TemperatureTrend>,
    val coldChainEfficiency: Float,
    val generatedAt: Date
)

data class DelayAnalytics(
    val period: DateRange,
    val totalDelays: Int,
    val delayByReason: Map<String, Int>,
    val delayByRegion: Map<String, Int>,
    val averageDelayTime: Double,
    val delayTrends: List<DelayTrend>,
    val delayCost: Double,
    val generatedAt: Date
)

data class IncidentAnalytics(
    val period: DateRange,
    val totalIncidents: Int,
    val incidentsByType: Map<String, Int>,
    val incidentsBySeverity: Map<String, Int>,
    val incidentsByRegion: Map<String, Int>,
    val averageResolutionTime: Double,
    val incidentTrends: List<IncidentTrend>,
    val safetyMetrics: SafetyMetrics,
    val generatedAt: Date
)

// Supporting data classes
data class FleetUtilization(
    val totalVehicles: Int,
    val activeVehicles: Int,
    val utilizationRate: Float,
    val averageHoursPerVehicle: Float
)

data class VehiclePerformance(
    val vehicleId: String,
    val vehicleNumber: String,
    val totalDistance: Double,
    val totalTrips: Int,
    val fuelConsumption: Double,
    val efficiency: Double,
    val utilization: Float
)

data class MaintenanceAnalytics(
    val totalCost: Double,
    val costByType: Map<String, Double>,
    val averageDowntime: Double,
    val preventiveMaintenanceRate: Float
)

data class FleetFuelAnalytics(
    val totalConsumption: Double,
    val totalCost: Double,
    val averagePrice: Double,
    val consumptionTrend: List<ConsumptionTrend>,
    val priceTrend: List<PriceTrend>
)

data class DriverPerformance(
    val driverId: String,
    val driverName: String,
    val totalTrips: Int,
    val completedTrips: Int,
    val delayedTrips: Int,
    val completionRate: Float,
    val onTimeDeliveryRate: Float,
    val totalDistance: Double,
    val totalRevenue: Double,
    val averageRating: Float
)

data class RegionalPerformance(
    val region: String,
    val averageCompletionRate: Float,
    val averageOnTimeDeliveryRate: Float,
    val totalRevenue: Double
)

data class DeliveryTimeAnalytics(
    val averageDeliveryTime: Double,
    val minDeliveryTime: Double,
    val maxDeliveryTime: Double,
    val deliveryTimeDistribution: Map<String, Int>
)

data class RevenueGrowth(
    val currentPeriodRevenue: Double,
    val previousPeriodRevenue: Double,
    val growthRate: Float
)

data class TemperatureCompliance(
    val totalReadings: Int,
    val compliantReadings: Int,
    val complianceRate: Float
)

data class TemperatureTrend(
    val date: Date,
    val averageTemperature: Float,
    val minTemperature: Float,
    val maxTemperature: Float
)

data class PriceTrend(
    val date: Date,
    val price: Double
)

data class ConsumptionTrend(
    val date: Date,
    val consumption: Double
)

data class FuelingStation(
    val name: String,
    val totalFuel: Double,
    val totalCost: Double,
    val visitCount: Int
)

data class DelayTrend(
    val date: Date,
    val delayCount: Int,
    val averageDelayTime: Double
)

data class IncidentTrend(
    val date: Date,
    val incidentCount: Int,
    val averageSeverity: Float
)

data class SafetyMetrics(
    val totalIncidents: Int,
    val accidentRate: Float,
    val daysSinceLastIncident: Long,
    val safetyScore: Float
)

data class DateRange(
    val startDate: Date,
    val endDate: Date
) {
    companion object {
        fun last30Days(): DateRange {
            val calendar = Calendar.getInstance()
            val endDate = calendar.time
            calendar.add(Calendar.DAY_OF_MONTH, -30)
            val startDate = calendar.time
            return DateRange(startDate, endDate)
        }
        
        fun last7Days(): DateRange {
            val calendar = Calendar.getInstance()
            val endDate = calendar.time
            calendar.add(Calendar.DAY_OF_MONTH, -7)
            val startDate = calendar.time
            return DateRange(startDate, endDate)
        }
        
        fun today(): DateRange {
            val calendar = Calendar.getInstance()
            calendar.set(Calendar.HOUR_OF_DAY, 0)
            calendar.set(Calendar.MINUTE, 0)
            calendar.set(Calendar.SECOND, 0)
            calendar.set(Calendar.MILLISECOND, 0)
            val startDate = calendar.time
            
            calendar.add(Calendar.DAY_OF_MONTH, 1)
            val endDate = calendar.time
            
            return DateRange(startDate, endDate)
        }
    }
}

/**
 * Enums
 */
enum class AnalyticsState {
    Idle,
    Initializing,
    Ready,
    Processing,
    Calculating,
    Error
}
