package com.edham.logistics.feature.billing.presentation.ui

import androidx.lifecycle.viewModelScope
import com.edham.logistics.core.utils.Result
import com.edham.logistics.feature.billing.domain.model.*
import com.edham.logistics.feature.billing.domain.usecase.*
import com.edham.logistics.presentation.ui.base.BaseViewModel
import dagger.hilt.android.lifecycle.HiltViewModel
import kotlinx.coroutines.flow.MutableStateFlow
import kotlinx.coroutines.flow.StateFlow
import kotlinx.coroutines.flow.asStateFlow
import kotlinx.coroutines.launch
import javax.inject.Inject

@HiltViewModel
class AccountantBillingViewModel @Inject constructor(
    private val generateInvoiceUseCase: GenerateInvoiceUseCase,
    private val processPaymentUseCase: ProcessPaymentUseCase,
    private val exportInvoiceUseCase: ExportInvoiceUseCase
) : BaseViewModel<AccountantBillingViewModel.AccountantBillingUiState>() {

    private val _uiState = MutableStateFlow(AccountantBillingUiState())
    val uiState: StateFlow<AccountantBillingUiState> = _uiState.asStateFlow()

    override fun createInitialState(): AccountantBillingUiState = AccountantBillingUiState()

    fun initialize(userId: String) {
        _uiState.value = _uiState.value.copy(userId = userId)
        loadBillingData()
    }

    fun loadBillingData() {
        viewModelScope.launch {
            updateUiState { copy(isLoading = true) }
            
            // Load invoices, payments, and financial summary
            // This would typically call repository methods
            // For now, we'll simulate the data loading
            
            val invoices = listOf(
                Invoice(
                    id = "inv_001",
                    invoiceNumber = "INV-2024-001",
                    shipmentId = "shipment_001",
                    customerId = "customer_001",
                    customerName = "شركة النقل السريع",
                    customerEmail = "info@rapidtransport.com",
                    customerPhone = "+966501234567",
                    customerAddress = "الرياض، المملكة العربية السعودية",
                    issueDate = System.currentTimeMillis() - 7 * 24 * 60 * 60 * 1000,
                    dueDate = System.currentTimeMillis() + 23 * 24 * 60 * 60 * 1000,
                    status = InvoiceStatus.PAID,
                    subtotal = 1500.0,
                    taxAmount = 225.0,
                    discountAmount = 0.0,
                    totalAmount = 1725.0,
                    currency = "SAR",
                    items = listOf(
                        InvoiceItem(
                            id = "item_001",
                            invoiceId = "inv_001",
                            description = "رسوم الشحن - الرياض إلى جدة",
                            quantity = 1,
                            unitPrice = 1500.0,
                            totalPrice = 1500.0,
                            itemType = InvoiceItemType.SHIPPING_FEE,
                            metadata = emptyMap()
                        )
                    ),
                    paymentTerms = "دفع خلال 30 يوم",
                    notes = null,
                    attachments = emptyList(),
                    createdBy = "system",
                    createdAt = System.currentTimeMillis() - 7 * 24 * 60 * 60 * 1000,
                    updatedAt = System.currentTimeMillis() - 5 * 24 * 60 * 60 * 1000,
                    paidAt = System.currentTimeMillis() - 5 * 24 * 60 * 60 * 1000,
                    paymentMethod = "BANK_TRANSFER",
                    transactionId = "txn_001",
                    metadata = emptyMap()
                ),
                Invoice(
                    id = "inv_002",
                    invoiceNumber = "INV-2024-002",
                    shipmentId = "shipment_002",
                    customerId = "customer_002",
                    customerName = "مؤسسة الشحن المتقدم",
                    customerEmail = "contact@advancedshipping.com",
                    customerPhone = "+966502345678",
                    customerAddress = "جدة، المملكة العربية السعودية",
                    issueDate = System.currentTimeMillis() - 3 * 24 * 60 * 60 * 1000,
                    dueDate = System.currentTimeMillis() + 27 * 24 * 60 * 60 * 1000,
                    status = InvoiceStatus.ISSUED,
                    subtotal = 2800.0,
                    taxAmount = 420.0,
                    discountAmount = 100.0,
                    totalAmount = 3120.0,
                    currency = "SAR",
                    items = listOf(
                        InvoiceItem(
                            id = "item_002",
                            invoiceId = "inv_002",
                            description = "رسوم الشحن - جدة إلى الدمام",
                            quantity = 1,
                            unitPrice = 2800.0,
                            totalPrice = 2800.0,
                            itemType = InvoiceItemType.SHIPPING_FEE,
                            metadata = emptyMap()
                        ),
                        InvoiceItem(
                            id = "item_003",
                            invoiceId = "inv_002",
                            description = "رسوم التأمين",
                            quantity = 1,
                            unitPrice = 200.0,
                            totalPrice = 200.0,
                            itemType = InvoiceItemType.INSURANCE,
                            metadata = emptyMap()
                        )
                    ),
                    paymentTerms = "دفع خلال 30 يوم",
                    notes = "فاتورة خاصة بشحنة حساسة",
                    attachments = emptyList(),
                    createdBy = "system",
                    createdAt = System.currentTimeMillis() - 3 * 24 * 60 * 60 * 1000,
                    updatedAt = System.currentTimeMillis() - 3 * 24 * 60 * 60 * 1000,
                    paidAt = null,
                    paymentMethod = null,
                    transactionId = null,
                    metadata = emptyMap()
                )
            )

            val payments = listOf(
                Payment(
                    id = "pay_001",
                    invoiceId = "inv_001",
                    customerId = "customer_001",
                    amount = 1725.0,
                    currency = "SAR",
                    paymentMethod = PaymentMethod.BANK_TRANSFER,
                    paymentStatus = PaymentStatus.COMPLETED,
                    transactionId = "txn_001",
                    gatewayTransactionId = "bank_txn_001",
                    paymentDate = System.currentTimeMillis() - 5 * 24 * 60 * 60 * 1000,
                    processedAt = System.currentTimeMillis() - 5 * 24 * 60 * 60 * 1000,
                    failureReason = null,
                    gatewayResponse = mapOf("status" to "success"),
                    metadata = emptyMap(),
                    createdBy = "system",
                    createdAt = System.currentTimeMillis() - 5 * 24 * 60 * 60 * 1000,
                    updatedAt = System.currentTimeMillis() - 5 * 24 * 60 * 60 * 1000
                )
            )

            val financialSummary = FinancialSummary(
                revenue = SummaryMetric(4500.0, 3800.0, 18.4, TrendDirection.UP),
                expenses = SummaryMetric(1200.0, 1100.0, 9.1, TrendDirection.UP),
                profit = SummaryMetric(3300.0, 2700.0, 22.2, TrendDirection.UP),
                invoices = SummaryMetric(25.0, 22.0, 13.6, TrendDirection.UP),
                payments = SummaryMetric(23.0, 20.0, 15.0, TrendDirection.UP)
            )

            updateUiState { copy(
                isLoading = false,
                invoices = invoices,
                payments = payments,
                financialSummary = financialSummary,
                error = null
            )}
        }
    }

    fun generateInvoice(shipmentId: String) {
        viewModelScope.launch {
            updateUiState { copy(isGeneratingInvoice = true) }
            
            val request = GenerateInvoiceRequest(
                shipmentId = shipmentId,
                autoCalculate = true,
                customItems = null
            )
            
            when (val result = generateInvoiceUseCase(request)) {
                is Result.Success -> {
                    updateUiState { copy(
                        isGeneratingInvoice = false,
                        generatedInvoice = result.data
                    )}
                    loadBillingData() // Refresh data
                }
                is Result.Error -> {
                    updateUiState { copy(
                        isGeneratingInvoice = false,
                        error = result.exception.message ?: "فشل إنشاء الفاتورة"
                    )}
                }
                is Result.Loading -> {
                    updateUiState { copy(isGeneratingInvoice = true) }
                }
            }
        }
    }

    fun processPayment(invoiceId: String, amount: Double, paymentMethod: PaymentMethod) {
        viewModelScope.launch {
            updateUiState { copy(isProcessingPayment = true) }
            
            val request = ProcessPaymentRequest(
                invoiceId = invoiceId,
                amount = amount,
                paymentMethod = paymentMethod,
                gatewayId = "default_gateway",
                customerPaymentDetails = CustomerPaymentDetails(
                    cardNumber = null,
                    expiryDate = null,
                    cvv = null,
                    cardholderName = null,
                    bankAccountNumber = null,
                    bankRoutingNumber = null,
                    walletNumber = null,
                    billingAddress = null
                )
            )
            
            when (val result = processPaymentUseCase(request)) {
                is Result.Success -> {
                    updateUiState { copy(
                        isProcessingPayment = false,
                        processedPayment = result.data
                    )}
                    loadBillingData() // Refresh data
                }
                is Result.Error -> {
                    updateUiState { copy(
                        isProcessingPayment = false,
                        error = result.exception.message ?: "فشل معالجة الدفع"
                    )}
                }
                is Result.Loading -> {
                    updateUiState { copy(isProcessingPayment = true) }
                }
            }
        }
    }

    fun exportInvoice(invoiceId: String, format: ExportFormat) {
        viewModelScope.launch {
            updateUiState { copy(isExportingInvoice = true) }
            
            val request = ExportInvoiceRequest(
                invoiceId = invoiceId,
                format = format,
                includePaymentHistory = true,
                includeAttachments = false
            )
            
            when (val result = exportInvoiceUseCase(request)) {
                is Result.Success -> {
                    updateUiState { copy(
                        isExportingInvoice = false,
                        exportedInvoiceUrl = result.data
                    )}
                }
                is Result.Error -> {
                    updateUiState { copy(
                        isExportingInvoice = false,
                        error = result.exception.message ?: "فشل تصدير الفاتورة"
                    )}
                }
                is Result.Loading -> {
                    updateUiState { copy(isExportingInvoice = true) }
                }
            }
        }
    }

    fun markInvoiceAsPaid(invoiceId: String) {
        viewModelScope.launch {
            // This would update the invoice status to PAID
            updateUiState { copy(isLoading = true) }
            
            // Simulate API call
            kotlinx.coroutines.delay(1000)
            
            loadBillingData()
            updateUiState { copy(isLoading = false) }
        }
    }

    fun markInvoiceAsUnpaid(invoiceId: String) {
        viewModelScope.launch {
            // This would update the invoice status to ISSUED
            updateUiState { copy(isLoading = true) }
            
            // Simulate API call
            kotlinx.coroutines.delay(1000)
            
            loadBillingData()
            updateUiState { copy(isLoading = false) }
        }
    }

    fun refresh() {
        loadBillingData()
    }

    fun clearError() {
        updateUiState { copy(error = null) }
    }

    fun clearSuccessMessages() {
        updateUiState { copy(
            generatedInvoice = null,
            processedPayment = null,
            exportedInvoiceUrl = null
        )}
    }

    data class AccountantBillingUiState(
        val isLoading: Boolean = false,
        val userId: String = "",
        val invoices: List<Invoice> = emptyList(),
        val payments: List<Payment> = emptyList(),
        val financialSummary: FinancialSummary? = null,
        val isGeneratingInvoice: Boolean = false,
        val isProcessingPayment: Boolean = false,
        val isExportingInvoice: Boolean = false,
        val generatedInvoice: Invoice? = null,
        val processedPayment: Payment? = null,
        val exportedInvoiceUrl: String? = null,
        val error: String? = null
    ) : com.edham.logistics.presentation.ui.base.UiState {
        override fun copyLoading(isLoading: Boolean): UiState = copy(isLoading = isLoading)
        override fun copyError(error: String?): UiState = copy(error = error)
        override fun copySuccess(message: String?): UiState = this
    }
}
