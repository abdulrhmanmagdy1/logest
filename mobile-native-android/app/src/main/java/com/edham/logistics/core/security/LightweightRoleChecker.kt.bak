package com.edham.logistics.core.security

import com.edham.logistics.core.model.UserRole
import timber.log.Timber
import javax.inject.Inject
import javax.inject.Singleton

/**
 * Lightweight Role Checker - Simple role-based access control
 * Use for basic role checks without complex policy engine overhead
 * Only use PolicyEngine for sensitive operations
 */
@Singleton
class LightweightRoleChecker @Inject constructor() {
    
    /**
     * Check if user can access specific dashboard
     * This is the primary role check - only used for dashboard access
     */
    fun canAccessDashboard(userRole: UserRole): Boolean {
        return when (userRole) {
            UserRole.CUSTOMER -> true
            UserRole.DRIVER -> true
            UserRole.SUPERVISOR -> true
            UserRole.ACCOUNTANT -> true
            UserRole.WORKSHOP -> true
            UserRole.ADMIN -> true
        }
    }
    
    /**
     * Get dashboard destination for user role
     */
    fun getDashboardDestination(userRole: UserRole): Int {
        return when (userRole) {
            UserRole.CUSTOMER -> com.edham.logistics.R.id.customerDashboardFragment
            UserRole.DRIVER -> com.edham.logistics.R.id.driverDashboardFragment
            UserRole.SUPERVISOR -> com.edham.logistics.R.id.supervisorDashboardFragment
            UserRole.ACCOUNTANT -> com.edham.logistics.R.id.accountantDashboardFragment
            UserRole.WORKSHOP -> com.edham.logistics.R.id.workshopDashboardFragment
            UserRole.ADMIN -> com.edham.logistics.R.id.adminDashboardFragment
        }
    }
    
    /**
     * Check if operation is sensitive (requires PolicyEngine)
     */
    fun isSensitiveOperation(operation: String): Boolean {
        return when (operation) {
            "financial", "admin", "payment", "invoice", "manage_users", "manage_system" -> true
            else -> false
        }
    }
    
    /**
     * Simple role priority check
     */
    fun hasHigherOrEqualPriority(role: UserRole, targetRole: UserRole): Boolean {
        return UserRole.hasHigherOrEqualPriority(role, targetRole)
    }
    
    /**
     * Get role display name
     */
    fun getRoleDisplayName(userRole: UserRole): String {
        return userRole.displayName
    }
    
    /**
     * Check if user can perform basic operations (non-sensitive)
     */
    fun canPerformBasicOperation(userRole: UserRole, operation: String): Boolean {
        return when (operation) {
            "view_dashboard" -> true // All roles can view their dashboard
            "view_profile" -> true // All roles can view their profile
            "view_own_data" -> true // All roles can view their own data
            else -> false // Default to false for undefined operations
        }
    }
}
