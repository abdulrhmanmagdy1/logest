package com.edham.logistics.feature.chat.adapters

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.ImageView
import android.widget.LinearLayout
import android.widget.TextView
import androidx.recyclerview.widget.DiffUtil
import androidx.recyclerview.widget.ListAdapter
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.feature.chat.ChatMessage
import com.edham.logistics.feature.chat.MessageType
import java.text.SimpleDateFormat
import java.util.*

class MessageAdapter(
    private val onMessageClick: (ChatMessage) -> Unit
) : ListAdapter<ChatMessage, MessageAdapter.ViewHolder>(MessageDiffCallback()) {
    
    private val messages = mutableListOf<ChatMessage>()
    private val timeFormat = SimpleDateFormat("HH:mm", Locale.getDefault())
    private val dateFormat = SimpleDateFormat("MMM dd", Locale.getDefault())
    
    fun updateMessages(newMessages: List<ChatMessage>) {
        messages.clear()
        messages.addAll(newMessages)
        submitList(messages)
    }
    
    fun addMessage(message: ChatMessage) {
        messages.add(message)
        submitList(messages.toList())
    }
    
    fun updateMessageDeliveryStatus(messageId: String) {
        val index = messages.indexOfFirst { it.id == messageId }
        if (index != -1) {
            messages[index].isDelivered = true
            notifyItemChanged(index)
        }
    }
    
    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): ViewHolder {
        val view = LayoutInflater.from(parent.context)
            .inflate(R.layout.item_chat_message, parent, false)
        return ViewHolder(view)
    }
    
    override fun onBindViewHolder(holder: ViewHolder, position: Int) {
        holder.bind(messages[position])
    }
    
    override fun getItemCount(): Int = messages.size
    
    inner class ViewHolder(itemView: View) : RecyclerView.ViewHolder(itemView) {
        private val layoutMessageContainer: LinearLayout = itemView.findViewById(R.id.layoutMessageContainer)
        private val ivSenderAvatar: ImageView = itemView.findViewById(R.id.ivSenderAvatar)
        private val tvSenderName: TextView = itemView.findViewById(R.id.tvSenderName)
        private val tvMessageContent: TextView = itemView.findViewById(R.id.tvMessageContent)
        private val tvMessageTime: TextView = itemView.findViewById(R.id.tvMessageTime)
        private val ivMessageMedia: ImageView = itemView.findViewById(R.id.ivMessageMedia)
        private val viewDeliveryStatus: View = itemView.findViewById(R.id.viewDeliveryStatus)
        private val viewReadReceipt: View = itemView.findViewById(R.id.viewReadReceipt)
        private val layoutMediaPreview: LinearLayout = itemView.findViewById(R.id.layoutMediaPreview)
        private val tvMediaFileName: TextView = itemView.findViewById(R.id.tvMediaFileName)
        private val tvMediaFileSize: TextView = itemView.findViewById(R.id.tvMediaFileSize)
        private val ivPlayButton: ImageView = itemView.findViewById(R.id.ivPlayButton)
        private val layoutLocationPreview: LinearLayout = itemView.findViewById(R.id.layoutLocationPreview)
        private val tvLocationAddress: TextView = itemView.findViewById(R.id.tvLocationAddress)
        private val ivLocationIcon: ImageView = itemView.findViewById(R.id.ivLocationIcon)
        
        fun bind(message: ChatMessage) {
            // Set message layout based on sender
            setupMessageLayout(message)
            
            // Set sender info
            setupSenderInfo(message)
            
            // Set message content
            setupMessageContent(message)
            
            // Set media preview
            setupMediaPreview(message)
            
            // Set location preview
            setupLocationPreview(message)
            
            // Set timestamps
            setupTimestamps(message)
            
            // Set delivery and read status
            setupStatusIndicators(message)
            
            // Set click listeners
            setupClickListeners(message)
        }
        
        private fun setupMessageLayout(message: ChatMessage) {
            val isOwnMessage = isOwnMessage(message)
            
            // Layout alignment
            if (isOwnMessage) {
                layoutMessageContainer.layoutDirection = View.LAYOUT_DIRECTION_RTL
                layoutMessageContainer.setBackgroundResource(R.drawable.chat_message_sent_bg)
            } else {
                layoutMessageContainer.layoutDirection = View.LAYOUT_DIRECTION_LTR
                layoutMessageContainer.setBackgroundResource(R.drawable.chat_message_received_bg)
            }
            
            // Avatar visibility
            ivSenderAvatar.visibility = if (isOwnMessage) View.GONE else View.VISIBLE
            tvSenderName.visibility = if (isOwnMessage) View.GONE else View.VISIBLE
        }
        
        private fun setupSenderInfo(message: ChatMessage) {
            if (!isOwnMessage(message)) {
                tvSenderName.text = message.senderRole.name
                tvSenderName.setTextColor(getSenderRoleColor(message.senderRole))
                
                // Set avatar based on role
                val avatarRes = when (message.senderRole) {
                    UserRole.DRIVER -> R.drawable.ic_driver_avatar
                    UserRole.DISPATCHER -> R.drawable.ic_dispatcher_avatar
                    UserRole.ADMIN -> R.drawable.ic_admin_avatar
                    else -> R.drawable.ic_default_avatar
                }
                ivSenderAvatar.setImageResource(avatarRes)
            }
        }
        
        private fun setupMessageContent(message: ChatMessage) {
            when (message.messageType) {
                MessageType.TEXT -> {
                    tvMessageContent.text = message.content
                    tvMessageContent.visibility = View.VISIBLE
                    ivMessageMedia.visibility = View.GONE
                    layoutMediaPreview.visibility = View.GONE
                    layoutLocationPreview.visibility = View.GONE
                }
                MessageType.SYSTEM -> {
                    tvMessageContent.text = message.content
                    tvMessageContent.setTextColor(itemView.context.getColor(R.color.chat_system_message))
                    tvMessageContent.visibility = View.VISIBLE
                    ivMessageMedia.visibility = View.GONE
                    layoutMediaPreview.visibility = View.GONE
                    layoutLocationPreview.visibility = View.GONE
                }
                else -> {
                    tvMessageContent.visibility = View.GONE
                }
            }
        }
        
        private fun setupMediaPreview(message: ChatMessage) {
            when (message.messageType) {
                MessageType.IMAGE, MessageType.VIDEO, MessageType.FILE -> {
                    layoutMediaPreview.visibility = View.VISIBLE
                    tvMessageContent.visibility = View.GONE
                    layoutLocationPreview.visibility = View.GONE
                    
                    // Set media icon
                    val mediaIcon = when (message.messageType) {
                        MessageType.IMAGE -> R.drawable.ic_image
                        MessageType.VIDEO -> R.drawable.ic_video
                        MessageType.FILE -> R.drawable.ic_file
                        else -> R.drawable.ic_attachment
                    }
                    ivMessageMedia.setImageResource(mediaIcon)
                    ivMessageMedia.visibility = View.VISIBLE
                    
                    // Set file info
                    message.metadata?.let { metadata ->
                        tvMediaFileName.text = metadata.fileName ?: "Attachment"
                        tvMediaFileSize.text = formatFileSize(metadata.fileSize ?: 0)
                        
                        if (message.messageType == MessageType.VOICE_NOTE) {
                            ivPlayButton.visibility = View.VISIBLE
                            tvMediaFileName.text = "Voice Note"
                            tvMediaFileSize.text = formatDuration(metadata.duration ?: 0)
                        } else {
                            ivPlayButton.visibility = View.GONE
                        }
                    }
                }
                MessageType.VOICE_NOTE -> {
                    layoutMediaPreview.visibility = View.VISIBLE
                    tvMessageContent.visibility = View.GONE
                    layoutLocationPreview.visibility = View.GONE
                    
                    ivMessageMedia.setImageResource(R.drawable.ic_mic)
                    ivMessageMedia.visibility = View.VISIBLE
                    ivPlayButton.visibility = View.VISIBLE
                    
                    message.metadata?.let { metadata ->
                        tvMediaFileName.text = "Voice Note"
                        tvMediaFileSize.text = formatDuration(metadata.duration ?: 0)
                    }
                }
                else -> {
                    layoutMediaPreview.visibility = View.GONE
                    ivMessageMedia.visibility = View.GONE
                    ivPlayButton.visibility = View.GONE
                }
            }
        }
        
        private fun setupLocationPreview(message: ChatMessage) {
            if (message.messageType == MessageType.LOCATION) {
                layoutLocationPreview.visibility = View.VISIBLE
                tvMessageContent.visibility = View.GONE
                layoutMediaPreview.visibility = View.GONE
                
                ivLocationIcon.setImageResource(R.drawable.ic_location)
                
                message.metadata?.locationData?.let { location ->
                    tvLocationAddress.text = location.address
                }
            } else {
                layoutLocationPreview.visibility = View.GONE
            }
        }
        
        private fun setupTimestamps(message: ChatMessage) {
            val time = timeFormat.format(Date(message.timestamp))
            val date = dateFormat.format(Date(message.timestamp))
            
            tvMessageTime.text = time
            
            // Show date if message is from different day
            val shouldShowDate = shouldShowDate(message)
            if (shouldShowDate) {
                tvMessageTime.text = "$date, $time"
            }
        }
        
        private fun setupStatusIndicators(message: ChatMessage) {
            val isOwnMessage = isOwnMessage(message)
            
            if (isOwnMessage) {
                // Delivery status
                viewDeliveryStatus.visibility = View.VISIBLE
                viewDeliveryStatus.setBackgroundResource(
                    if (message.isDelivered) R.drawable.circle_delivered 
                    else R.drawable.circle_pending
                )
                
                // Read receipt
                viewReadReceipt.visibility = View.VISIBLE
                viewReadReceipt.setBackgroundResource(
                    if (message.isRead) R.drawable.circle_read 
                    else R.drawable.circle_unread
                )
            } else {
                viewDeliveryStatus.visibility = View.GONE
                viewReadReceipt.visibility = View.GONE
            }
        }
        
        private fun setupClickListeners(message: ChatMessage) {
            itemView.setOnClickListener {
                onMessageClick(message)
            }
            
            // Media click listeners
            ivMessageMedia.setOnClickListener {
                when (message.messageType) {
                    MessageType.IMAGE, MessageType.VIDEO -> {
                        // Open media viewer
                        onMessageClick(message)
                    }
                    MessageType.FILE -> {
                        // Open file
                        onMessageClick(message)
                    }
                    else -> {
                        // Handle other media types
                        onMessageClick(message)
                    }
                }
            }
            
            ivPlayButton.setOnClickListener {
                if (message.messageType == MessageType.VOICE_NOTE) {
                    // Play voice note
                    onMessageClick(message)
                }
            }
            
            layoutLocationPreview.setOnClickListener {
                if (message.messageType == MessageType.LOCATION) {
                    // Open map
                    onMessageClick(message)
                }
            }
        }
        
        private fun isOwnMessage(message: ChatMessage): Boolean {
            // Implementation would check against current user ID
            return message.senderRole == UserRole.DRIVER // Simplified for example
        }
        
        private fun getSenderRoleColor(role: UserRole): Int {
            return when (role) {
                UserRole.DRIVER -> itemView.context.getColor(R.color.driver_role)
                UserRole.DISPATCHER -> itemView.context.getColor(R.color.dispatcher_role)
                UserRole.ADMIN -> itemView.context.getColor(R.color.admin_role)
                else -> itemView.context.getColor(R.color.default_role)
            }
        }
        
        private fun shouldShowDate(message: ChatMessage): Boolean {
            // Implementation would check if message is from different day
            val calendar = Calendar.getInstance()
            calendar.timeInMillis = message.timestamp
            
            val today = Calendar.getInstance()
            
            return calendar.get(Calendar.DAY_OF_YEAR) != today.get(Calendar.DAY_OF_YEAR) ||
                   calendar.get(Calendar.YEAR) != today.get(Calendar.YEAR)
        }
        
        private fun formatFileSize(bytes: Long): String {
            val kb = bytes / 1024.0
            val mb = kb / 1024.0
            val gb = mb / 1024.0
            
            return when {
                gb >= 1 -> String.format("%.1f GB", gb)
                mb >= 1 -> String.format("%.1f MB", mb)
                kb >= 1 -> String.format("%.0f KB", kb)
                else -> String.format("%d B", bytes)
            }
        }
        
        private fun formatDuration(milliseconds: Long): String {
            val seconds = milliseconds / 1000
            val minutes = seconds / 60
            val hours = minutes / 60
            
            return when {
                hours > 0 -> String.format("%d:%02d:%02d", hours, minutes % 60, seconds % 60)
                minutes > 0 -> String.format("%d:%02d", minutes, seconds % 60)
                else -> String.format("0:%02d", seconds)
            }
        }
    }
    
    class MessageDiffCallback : DiffUtil.ItemCallback<ChatMessage>() {
        override fun areItemsTheSame(oldItem: ChatMessage, newItem: ChatMessage): Boolean {
            return oldItem.id == newItem.id
        }
        
        override fun areContentsTheSame(oldItem: ChatMessage, newItem: ChatMessage): Boolean {
            return oldItem == newItem
        }
        
        override fun getChangePayload(oldItem: ChatMessage, newItem: ChatMessage): Any? {
            return when {
                oldItem.isDelivered != newItem.isDelivered -> "delivery_status"
                oldItem.isRead != newItem.isRead -> "read_status"
                else -> null
            }
        }
    }
}
