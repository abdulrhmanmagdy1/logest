package com.edham.logistics.production

import android.content.Context
import android.content.pm.PackageInfo
import android.content.pm.PackageManager
import android.content.pm.Signature
import android.os.Build
import android.security.NetworkSecurityPolicy
import android.util.Base64
import androidx.security.crypto.EncryptedFile
import androidx.security.crypto.MasterKey
import com.edham.logistics.tracking.RealTimeLocationService
import kotlinx.coroutines.Dispatchers
import kotlinx.coroutines.withContext
import java.io.File
import java.security.MessageDigest
import java.security.SecureRandom
import javax.crypto.Cipher
import javax.crypto.KeyGenerator
import javax.crypto.SecretKey
import javax.crypto.spec.IvParameterSpec
import javax.crypto.spec.SecretKeySpec

/**
 * Security Manager for Edham Logistics
 * مدير الأمان لتطبيق إدهام اللوجستي
 */
class SecurityManager private constructor(private val context: Context) {

    companion object {
        @Volatile
        private var INSTANCE: SecurityManager? = null

        fun getInstance(context: Context): SecurityManager {
            return INSTANCE ?: synchronized(this) {
                INSTANCE ?: SecurityManager(context.applicationContext).also { INSTANCE = it }
            }
        }

        // Security constants
        private const val AES_ALGORITHM = "AES"
        private const val AES_CIPHER_TRANSFORMATION = "AES/CBC/PKCS5Padding"
        private const val MASTER_KEY_ALIAS = "edham_master_key"
        private const val ENCRYPTED_FILE_ALIAS = "edham_secure_data"
        private const val KEY_SIZE = 256
        private const val IV_SIZE = 16
        
        // Expected app signature hash (replace with actual hash)
        private const val EXPECTED_SIGNATURE_HASH = "a1b2c3d4e5f6789012345678901234567890abcd"
    }

    private val secureRandom = SecureRandom()
    private var masterKey: MasterKey? = null
    private var appSignatureVerified = false

    /**
     * Initialize security features
     * تهيئة ميزات الأمان
     */
    suspend fun initializeSecurity(): SecurityInitResult = withContext(Dispatchers.IO) {
        try {
            // Initialize master key
            initializeMasterKey()
            
            // Verify app integrity
            val integrityCheck = verifyAppIntegrity()
            
            // Initialize network security
            initializeNetworkSecurity()
            
            // Initialize data encryption
            initializeDataEncryption()
            
            // Initialize secure storage
            initializeSecureStorage()
            
            SecurityInitResult(
                success = true,
                integrityVerified = integrityCheck,
                networkSecurityEnabled = true,
                dataEncryptionEnabled = true,
                secureStorageEnabled = true
            )
            
        } catch (e: Exception) {
            e.printStackTrace()
            SecurityInitResult(
                success = false,
                integrityVerified = false,
                networkSecurityEnabled = false,
                dataEncryptionEnabled = false,
                secureStorageEnabled = false,
                error = e.message
            )
        }
    }

    /**
     * Initialize master key
     * تهيئة المفتاح الرئيسي
     */
    private fun initializeMasterKey() {
        try {
            masterKey = MasterKey.Builder(context)
                .setKeyScheme(MasterKey.KeyScheme.AES256_GCM)
                .setRequestParameter(1, false, "true")
                .build()
        } catch (e: Exception) {
            e.printStackTrace()
            throw SecurityException("Failed to initialize master key", e)
        }
    }

    /**
     * Verify app integrity
     * التحقق من سلامة التطبيق
     */
    private fun verifyAppIntegrity(): Boolean {
        try {
            if (appSignatureVerified) return true
            
            val packageManager = context.packageManager
            val packageInfo = if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.P) {
                packageManager.getPackageInfo(
                    context.packageName,
                    PackageManager.GET_SIGNING_CERTIFICATES
                )
            } else {
                @Suppress("DEPRECATION")
                packageManager.getPackageInfo(
                    context.packageName,
                    PackageManager.GET_SIGNATURES
                )
            }
            
            val signatures = if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.P) {
                packageInfo.signingInfo?.apkContentsSigners?.flatMap { it.certificateChain }
            } else {
                @Suppress("DEPRECATION")
                packageInfo.signatures?.toList()
            }
            
            signatures?.forEach { signature ->
                val md = MessageDigest.getInstance("SHA-256")
                md.update(signature.toByteArray())
                val hash = Base64.encodeToString(md.digest(), Base64.NO_WRAP)
                
                // Compare with expected hash
                if (hash == EXPECTED_SIGNATURE_HASH) {
                    appSignatureVerified = true
                    return true
                }
            }
            
            return false
            
        } catch (e: Exception) {
            e.printStackTrace()
            return false
        }
    }

    /**
     * Initialize network security
     * تهيئة أمان الشبكة
     */
    private fun initializeNetworkSecurity() {
        try {
            // Enable network security policy
            NetworkSecurityPolicy.getInstance().apply {
                // Enable certificate transparency
                isCertificateTransparencyPinningEnabled = true
                
                // Enable hostname verification
                isHostnameVerificationEnabled = true
                
                // Enable cleartext traffic prevention (except for localhost)
                isCleartextTrafficPermitted = false
            }
            
        } catch (e: Exception) {
            e.printStackTrace()
        }
    }

    /**
     * Initialize data encryption
     * تهيئة تشفير البيانات
     */
    private fun initializeDataEncryption() {
        try {
            // Generate AES key for data encryption
            val keyGenerator = KeyGenerator.getInstance(AES_ALGORITHM)
            keyGenerator.init(KEY_SIZE)
            
        } catch (e: Exception) {
            e.printStackTrace()
        }
    }

    /**
     * Initialize secure storage
     * تهيئة التخزين الآمن
     */
    private fun initializeSecureStorage() {
        try {
            // Create encrypted file for secure data storage
            val secureFile = File(context.filesDir, "secure_data.enc")
            if (!secureFile.exists()) {
                secureFile.createNewFile()
            }
            
        } catch (e: Exception) {
            e.printStackTrace()
        }
    }

    /**
     * Encrypt sensitive data
     * تشفير البيانات الحساسة
     */
    suspend fun encryptData(data: String): String? = withContext(Dispatchers.IO) {
        try {
            val secretKey = generateSecretKey()
            val cipher = Cipher.getInstance(AES_CIPHER_TRANSFORMATION)
            
            // Generate random IV
            val iv = ByteArray(IV_SIZE)
            secureRandom.nextBytes(iv)
            val ivSpec = IvParameterSpec(iv)
            
            cipher.init(Cipher.ENCRYPT_MODE, secretKey, ivSpec)
            val encryptedBytes = cipher.doFinal(data.toByteArray())
            
            // Combine IV and encrypted data
            val combined = iv + encryptedBytes
            Base64.encodeToString(combined, Base64.NO_WRAP)
            
        } catch (e: Exception) {
            e.printStackTrace()
            null
        }
    }

    /**
     * Decrypt sensitive data
     * فك تشفير البيانات الحساسة
     */
    suspend fun decryptData(encryptedData: String): String? = withContext(Dispatchers.IO) {
        try {
            val combined = Base64.decode(encryptedData, Base64.NO_WRAP)
            
            // Extract IV and encrypted data
            val iv = combined.sliceArray(0 until IV_SIZE)
            val encryptedBytes = combined.sliceArray(IV_SIZE until combined.size)
            
            val secretKey = generateSecretKey()
            val cipher = Cipher.getInstance(AES_CIPHER_TRANSFORMATION)
            val ivSpec = IvParameterSpec(iv)
            
            cipher.init(Cipher.DECRYPT_MODE, secretKey, ivSpec)
            val decryptedBytes = cipher.doFinal(encryptedBytes)
            
            String(decryptedBytes, Charsets.UTF_8)
            
        } catch (e: Exception) {
            e.printStackTrace()
            null
        }
    }

    /**
     * Save data to encrypted file
     * حفظ البيانات في ملف مشفر
     */
    suspend fun saveToEncryptedFile(filename: String, data: String): Boolean = withContext(Dispatchers.IO) {
        try {
            val encryptedData = encryptData(data) ?: return@withContext false
            
            val file = File(context.filesDir, "$filename.enc")
            file.writeText(encryptedData)
            
            true
            
        } catch (e: Exception) {
            e.printStackTrace()
            false
        }
    }

    /**
     * Load data from encrypted file
     * تحميل البيانات من ملف مشفر
     */
    suspend fun loadFromEncryptedFile(filename: String): String? = withContext(Dispatchers.IO) {
        try {
            val file = File(context.filesDir, "$filename.enc")
            if (!file.exists()) return@withContext null
            
            val encryptedData = file.readText()
            decryptData(encryptedData)
            
        } catch (e: Exception) {
            e.printStackTrace()
            null
        }
    }

    /**
     * Generate secret key
     * إنشاء مفتاح سري
     */
    private fun generateSecretKey(): SecretKey {
        val keyBytes = ByteArray(32)
        secureRandom.nextBytes(keyBytes)
        return SecretKeySpec(keyBytes, AES_ALGORITHM)
    }

    /**
     * Validate API response integrity
     * التحقق من سلامة استجابة API
     */
    fun validateApiResponse(response: String, signature: String): Boolean {
        try {
            val md = MessageDigest.getInstance("SHA-256")
            md.update(response.toByteArray())
            val calculatedHash = Base64.encodeToString(md.digest(), Base64.NO_WRAP)
            
            return calculatedHash == signature
            
        } catch (e: Exception) {
            e.printStackTrace()
            return false
        }
    }

    /**
     * Generate secure token
     * إنشاء رمز آمن
     */
    fun generateSecureToken(length: Int = 32): String {
        val chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789"
        val token = StringBuilder()
        
        repeat(length) {
            token.append(chars[secureRandom.nextInt(chars.length)])
        }
        
        return token.toString()
    }

    /**
     * Check if device is rooted/jailbroken
     * التحقق مما إذا كان الجهاز rooted/jailbroken
     */
    fun isDeviceCompromised(): Boolean {
        return try {
            // Check for root access files
            val rootFiles = listOf(
                "/system/app/Superuser.apk",
                "/sbin/su",
                "/system/bin/su",
                "/system/xbin/su",
                "/data/local/xbin/su",
                "/data/local/bin/su",
                "/system/sd/xbin/su",
                "/system/bin/failsafe/su",
                "/data/local/su"
            )
            
            rootFiles.any { File(it).exists() } ||
            // Check for su command
            Runtime.getRuntime().exec("su") != null ||
            // Check for test-keys
            Build.TAGS?.contains("test-keys") == true
            
        } catch (e: Exception) {
            e.printStackTrace()
            false
        }
    }

    /**
     * Get device security status
     * الحصول على حالة أمان الجهاز
     */
    fun getSecurityStatus(): SecurityStatus {
        return SecurityStatus(
            appIntegrityVerified = appSignatureVerified,
            deviceCompromised = isDeviceCompromised(),
            networkSecurityEnabled = NetworkSecurityPolicy.getInstance().isCleartextTrafficPermitted.not(),
            dataEncryptionEnabled = true,
            secureStorageEnabled = true,
            osVersion = Build.VERSION.RELEASE,
            securityPatchLevel = if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.M) {
                Build.VERSION.SECURITY_PATCH
            } else {
                "Unknown"
            }
        )
    }

    /**
     * Clear secure data
     * مسح البيانات الآمنة
     */
    fun clearSecureData() {
        try {
            // Clear encrypted files
            context.filesDir.listFiles()?.forEach { file ->
                if (file.name.endsWith(".enc")) {
                    file.delete()
                }
            }
            
            // Clear secure preferences
            val securePrefs = context.getSharedPreferences("secure_prefs", Context.MODE_PRIVATE)
            securePrefs.edit().clear().apply()
            
        } catch (e: Exception) {
            e.printStackTrace()
        }
    }

    // Data classes
    data class SecurityInitResult(
        val success: Boolean,
        val integrityVerified: Boolean,
        val networkSecurityEnabled: Boolean,
        val dataEncryptionEnabled: Boolean,
        val secureStorageEnabled: Boolean,
        val error: String? = null
    )

    data class SecurityStatus(
        val appIntegrityVerified: Boolean,
        val deviceCompromised: Boolean,
        val networkSecurityEnabled: Boolean,
        val dataEncryptionEnabled: Boolean,
        val secureStorageEnabled: Boolean,
        val osVersion: String,
        val securityPatchLevel: String
    )
}
