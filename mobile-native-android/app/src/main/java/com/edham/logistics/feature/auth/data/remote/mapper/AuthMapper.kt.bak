package com.edham.logistics.feature.auth.data.remote.mapper

import com.edham.logistics.feature.auth.data.remote.dto.LoginRequestDto
import com.edham.logistics.feature.auth.data.remote.dto.RegisterRequestDto
import com.edham.logistics.feature.auth.data.remote.dto.LoginResponseDto
import com.edham.logistics.feature.auth.data.remote.dto.UserDto
import com.edham.logistics.feature.auth.domain.model.LoginRequest
import com.edham.logistics.feature.auth.domain.model.RegisterRequest
import com.edham.logistics.feature.auth.domain.model.LoginResponse
import com.edham.logistics.feature.auth.domain.model.User
import javax.inject.Inject
import javax.inject.Singleton

@Singleton
class AuthMapper @Inject constructor() {

    fun mapToLoginRequestDto(domain: LoginRequest): LoginRequestDto {
        return LoginRequestDto(
            email = domain.email,
            password = domain.password,
            rememberMe = domain.rememberMe
        )
    }

    fun mapToRegisterRequestDto(domain: RegisterRequest): RegisterRequestDto {
        return RegisterRequestDto(
            name = domain.name,
            email = domain.email,
            phone = domain.phone,
            password = domain.password,
            confirmPassword = domain.confirmPassword,
            role = domain.role
        )
    }

    fun mapToLoginResponse(dto: LoginResponseDto): LoginResponse {
        return LoginResponse(
            user = mapToUser(dto.user),
            accessToken = dto.accessToken,
            refreshToken = dto.refreshToken,
            expiresIn = dto.expiresIn
        )
    }

    fun mapToUser(dto: UserDto): User {
        return User(
            id = dto.id,
            name = dto.name,
            email = dto.email,
            phone = dto.phone,
            role = dto.role,
            status = dto.status,
            profileImage = dto.profileImage,
            department = dto.department,
            position = dto.position,
            hireDate = dto.hireDate,
            lastLogin = dto.lastLogin,
            permissions = dto.permissions
        )
    }

    fun mapToUserDto(domain: User): UserDto {
        return UserDto(
            id = domain.id,
            name = domain.name,
            email = domain.email,
            phone = domain.phone,
            role = domain.role,
            status = domain.status,
            profileImage = domain.profileImage,
            department = domain.department,
            position = domain.position,
            hireDate = domain.hireDate,
            lastLogin = domain.lastLogin,
            permissions = domain.permissions
        )
    }
}
