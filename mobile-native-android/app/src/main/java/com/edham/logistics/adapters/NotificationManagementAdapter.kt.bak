package com.edham.logistics.adapters

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.ImageView
import android.widget.TextView
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.domain.model.Notification

class NotificationManagementAdapter(
    private var notifications: List<Notification>,
    private val onNotificationClick: (Notification) -> Unit
) : RecyclerView.Adapter<NotificationManagementAdapter.NotificationViewHolder>() {

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): NotificationViewHolder {
        val view = LayoutInflater.from(parent.context)
            .inflate(R.layout.item_notification_management, parent, false)
        return NotificationViewHolder(view)
    }

    override fun onBindViewHolder(holder: NotificationViewHolder, position: Int) {
        holder.bind(notifications[position])
    }

    override fun getItemCount(): Int = notifications.size

    fun updateNotifications(newNotifications: List<Notification>) {
        notifications = newNotifications
        notifyDataSetChanged()
    }

    inner class NotificationViewHolder(itemView: View) : RecyclerView.ViewHolder(itemView) {
        private val tvTitle: TextView = itemView.findViewById(R.id.tvTitle)
        private val tvMessage: TextView = itemView.findViewById(R.id.tvMessage)
        private val tvTime: TextView = itemView.findViewById(R.id.tvTime)
        private val ivNotificationIcon: ImageView = itemView.findViewById(R.id.ivNotificationIcon)
        private val ivReadIndicator: ImageView = itemView.findViewById(R.id.ivReadIndicator)

        fun bind(notification: Notification) {
            tvTitle.text = notification.title
            tvMessage.text = notification.message
            tvTime.text = notification.time

            // Set notification icon and color based on type
            when (notification.type) {
                "success" -> {
                    ivNotificationIcon.setImageResource(R.drawable.ic_check_circle)
                    ivNotificationIcon.setColorFilter(itemView.context.getColor(R.color.supervisor_success))
                }
                "warning" -> {
                    ivNotificationIcon.setImageResource(R.drawable.ic_warning)
                    ivNotificationIcon.setColorFilter(itemView.context.getColor(R.color.supervisor_warning))
                }
                "error" -> {
                    ivNotificationIcon.setImageResource(R.drawable.ic_error)
                    ivNotificationIcon.setColorFilter(itemView.context.getColor(R.color.supervisor_error))
                }
                "info" -> {
                    ivNotificationIcon.setImageResource(R.drawable.ic_info)
                    ivNotificationIcon.setColorFilter(itemView.context.getColor(R.color.supervisor_info))
                }
                else -> {
                    ivNotificationIcon.setImageResource(R.drawable.ic_info)
                    ivNotificationIcon.setColorFilter(itemView.context.getColor(R.color.text_secondary))
                }
            }

            // Set read indicator
            if (notification.isRead) {
                ivReadIndicator.setImageResource(R.drawable.circle_grey)
            } else {
                ivReadIndicator.setImageResource(R.drawable.circle_blue)
            }

            itemView.setOnClickListener {
                onNotificationClick(notification)
            }
        }
    }
}
