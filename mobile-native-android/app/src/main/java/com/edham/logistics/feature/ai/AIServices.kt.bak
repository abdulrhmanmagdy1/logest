package com.edham.logistics.feature.ai

import android.content.Context
import androidx.lifecycle.LiveData
import androidx.lifecycle.MutableLiveData
import com.edham.logistics.data.local.database.AIDatabase
import com.edham.logistics.data.local.entity.Shipment
import com.edham.logistics.data.local.entity.Driver
import com.edham.logistics.data.local.entity.Vehicle
import com.edham.logistics.data.remote.api.AIApi
import kotlinx.coroutines.*
import timber.log.Timber
import java.util.*
import java.util.concurrent.ConcurrentHashMap
import kotlin.math.*

/**
 * AI Services Architecture
 * Complete AI-powered services for smart logistics operations
 */
class AIServices(
    private val context: Context,
    private val api: AIApi,
    private val database: AIDatabase
) {
    
    private val serviceScope = CoroutineScope(Dispatchers.IO + SupervisorJob())
    
    // LiveData for real-time AI insights
    private val _etaPredictions = MutableLiveData<List<ETAPrediction>>()
    val etaPredictions: LiveData<List<ETAPrediction>> = _etaPredictions
    
    private val _delayPredictions = MutableLiveData<List<DelayPrediction>>()
    val delayPredictions: LiveData<List<DelayPrediction>> = _delayPredictions
    
    private val _routeOptimizations = MutableLiveData<List<RouteOptimization>>()
    val routeOptimizations: LiveData<List<RouteOptimization>> = _routeOptimizations
    
    private val _fuelOptimizations = MutableLiveData<List<FuelOptimization>>()
    val fuelOptimizations: LiveData<List<FuelOptimization>> = _fuelOptimizations
    
    private val _driverBehaviors = MutableLiveData<List<DriverBehaviorAnalysis>>()
    val driverBehaviors: LiveData<List<DriverBehaviorAnalysis>> = _driverBehaviors
    
    private val _maintenancePredictions = MutableLiveData<List<MaintenancePrediction>>()
    val maintenancePredictions: LiveData<List<MaintenancePrediction>> = _maintenancePredictions
    
    private val _demandForecasts = MutableLiveData<List<DemandForecast>>()
    val demandForecasts: LiveData<List<DemandForecast>> = _demandForecasts
    
    private val _riskAnalyses = MutableLiveData<List<ShipmentRiskAnalysis>>()
    val riskAnalyses: LiveData<List<ShipmentRiskAnalysis>> = _riskAnalyses
    
    private val _smartNotifications = MutableLiveData<List<SmartNotification>>()
    val smartNotifications: LiveData<List<SmartNotification>> = _smartNotifications
    
    private val _aiInsights = MutableLiveData<AIInsights>()
    val aiInsights: LiveData<AIInsights> = _aiInsights
    
    // AI prediction cache
    private val etaPredictionCache = ConcurrentHashMap<String, ETAPrediction>()
    private val delayPredictionCache = ConcurrentHashMap<String, DelayPrediction>()
    private val routeOptimizationCache = ConcurrentHashMap<String, RouteOptimization>()
    
    // AI models and processors
    private val etaPredictionEngine = ETAPredictionEngine()
    private val delayPredictionEngine = DelayPredictionEngine()
    private val routeOptimizationEngine = RouteOptimizationEngine()
    private val fuelOptimizationEngine = FuelOptimizationEngine()
    private val driverBehaviorEngine = DriverBehaviorEngine()
    private val maintenancePredictionEngine = MaintenancePredictionEngine()
    private val demandForecastingEngine = DemandForecastingEngine()
    private val riskAnalysisEngine = RiskAnalysisEngine()
    private val smartNotificationEngine = SmartNotificationEngine()
    
    companion object {
        private const val AI_UPDATE_INTERVAL = 300000L // 5 minutes
        private const val PREDICTION_CACHE_SIZE = 1000
        private const val MODEL_UPDATE_INTERVAL = 3600000L // 1 hour
    }
    
    /**
     * Initialize AI services
     */
    suspend fun initializeAIServices() {
        try {
            // Initialize AI engines
            initializeAIEngines()
            
            // Start real-time AI processing
            startRealTimeAIProcessing()
            
            // Load historical data for model training
            loadHistoricalData()
            
            // Start model training and updates
            startModelTraining()
            
            Timber.d("AI services initialized successfully")
            
        } catch (e: Exception) {
            Timber.e(e, "Error initializing AI services")
        }
    }
    
    /**
     * Initialize AI engines
     */
    private suspend fun initializeAIEngines() {
        try {
            etaPredictionEngine.initialize()
            delayPredictionEngine.initialize()
            routeOptimizationEngine.initialize()
            fuelOptimizationEngine.initialize()
            driverBehaviorEngine.initialize()
            maintenancePredictionEngine.initialize()
            demandForecastingEngine.initialize()
            riskAnalysisEngine.initialize()
            smartNotificationEngine.initialize()
            
        } catch (e: Exception) {
            Timber.e(e, "Error initializing AI engines")
        }
    }
    
    /**
     * Start real-time AI processing
     */
    private fun startRealTimeAIProcessing() {
        serviceScope.launch {
            while (true) {
                try {
                    // Process ETA predictions
                    processETAPredictions()
                    
                    // Process delay predictions
                    processDelayPredictions()
                    
                    // Process route optimizations
                    processRouteOptimizations()
                    
                    // Process fuel optimizations
                    processFuelOptimizations()
                    
                    // Process driver behavior analysis
                    processDriverBehaviorAnalysis()
                    
                    // Process maintenance predictions
                    processMaintenancePredictions()
                    
                    // Update AI insights
                    updateAIInsights()
                    
                    delay(AI_UPDATE_INTERVAL)
                    
                } catch (e: Exception) {
                    Timber.e(e, "Error in real-time AI processing")
                    delay(30000) // Wait before retrying
                }
            }
        }
    }
    
    /**
     * Load historical data for AI models
     */
    private suspend fun loadHistoricalData() {
        try {
            // Load shipment history
            val shipmentHistory = database.shipmentDao().getAllShipments()
            
            // Load driver history
            val driverHistory = database.driverDao().getAllDrivers()
            
            // Load vehicle history
            val vehicleHistory = database.vehicleDao().getAllVehicles()
            
            // Load maintenance history
            val maintenanceHistory = database.maintenanceDao().getAllMaintenanceRecords()
            
            // Train AI models with historical data
            etaPredictionEngine.trainModel(shipmentHistory)
            delayPredictionEngine.trainModel(shipmentHistory)
            routeOptimizationEngine.trainModel(shipmentHistory)
            fuelOptimizationEngine.trainModel(vehicleHistory)
            driverBehaviorEngine.trainModel(driverHistory)
            maintenancePredictionEngine.trainModel(maintenanceHistory)
            demandForecastingEngine.trainModel(shipmentHistory)
            riskAnalysisEngine.trainModel(shipmentHistory)
            
            Timber.d("Historical data loaded and models trained")
            
        } catch (e: Exception) {
            Timber.e(e, "Error loading historical data")
        }
    }
    
    /**
     * Start model training and updates
     */
    private fun startModelTraining() {
        serviceScope.launch {
            while (true) {
                try {
                    // Update AI models with latest data
                    updateAIModels()
                    
                    delay(MODEL_UPDATE_INTERVAL)
                    
                } catch (e: Exception) {
                    Timber.e(e, "Error in model training")
                    delay(300000) // Wait before retrying
                }
            }
        }
    }
    
    /**
     * Process ETA predictions
     */
    private suspend fun processETAPredictions() {
        try {
            // Get active shipments
            val activeShipments = database.shipmentDao().getActiveShipments()
            
            val predictions = mutableListOf<ETAPrediction>()
            
            activeShipments.forEach { shipment ->
                val cacheKey = "${shipment.id}_eta"
                
                // Check cache first
                val cachedPrediction = etaPredictionCache[cacheKey]
                if (cachedPrediction != null && 
                    System.currentTimeMillis() - cachedPrediction.timestamp < 300000) { // 5 minutes cache
                    predictions.add(cachedPrediction)
                    return@forEach
                }
                
                // Generate new prediction
                val prediction = etaPredictionEngine.predictETA(shipment)
                
                // Cache prediction
                etaPredictionCache[cacheKey] = prediction
                maintainCacheSize(etaPredictionCache)
                
                predictions.add(prediction)
            }
            
            _etaPredictions.postValue(predictions)
            
        } catch (e: Exception) {
            Timber.e(e, "Error processing ETA predictions")
        }
    }
    
    /**
     * Process delay predictions
     */
    private suspend fun processDelayPredictions() {
        try {
            // Get upcoming shipments
            val upcomingShipments = database.shipmentDao().getUpcomingShipments()
            
            val predictions = mutableListOf<DelayPrediction>()
            
            upcomingShipments.forEach { shipment ->
                val cacheKey = "${shipment.id}_delay"
                
                // Check cache first
                val cachedPrediction = delayPredictionCache[cacheKey]
                if (cachedPrediction != null && 
                    System.currentTimeMillis() - cachedPrediction.timestamp < 300000) {
                    predictions.add(cachedPrediction)
                    return@forEach
                }
                
                // Generate new prediction
                val prediction = delayPredictionEngine.predictDelay(shipment)
                
                // Cache prediction
                delayPredictionCache[cacheKey] = prediction
                maintainCacheSize(delayPredictionCache)
                
                predictions.add(prediction)
                
                // Generate smart notification for high delay risk
                if (prediction.delayRisk > 0.7) {
                    generateDelayAlert(shipment, prediction)
                }
            }
            
            _delayPredictions.postValue(predictions)
            
        } catch (e: Exception) {
            Timber.e(e, "Error processing delay predictions")
        }
    }
    
    /**
     * Process route optimizations
     */
    private suspend fun processRouteOptimizations() {
        try {
            // Get active shipments needing route optimization
            val activeShipments = database.shipmentDao().getActiveShipments()
            
            val optimizations = mutableListOf<RouteOptimization>()
            
            activeShipments.forEach { shipment ->
                val cacheKey = "${shipment.id}_route"
                
                // Check cache first
                val cachedOptimization = routeOptimizationCache[cacheKey]
                if (cachedOptimization != null && 
                    System.currentTimeMillis() - cachedOptimization.timestamp < 600000) { // 10 minutes cache
                    optimizations.add(cachedOptimization)
                    return@forEach
                }
                
                // Generate new optimization
                val optimization = routeOptimizationEngine.optimizeRoute(shipment)
                
                // Cache optimization
                routeOptimizationCache[cacheKey] = optimization
                maintainCacheSize(routeOptimizationCache)
                
                optimizations.add(optimization)
                
                // Generate smart notification for significant optimization
                if (optimization.potentialSavings > 15.0) {
                    generateRouteOptimizationAlert(shipment, optimization)
                }
            }
            
            _routeOptimizations.postValue(optimizations)
            
        } catch (e: Exception) {
            Timber.e(e, "Error processing route optimizations")
        }
    }
    
    /**
     * Process fuel optimizations
     */
    private suspend fun processFuelOptimizations() {
        try {
            // Get active vehicles
            val activeVehicles = database.vehicleDao().getActiveVehicles()
            
            val optimizations = mutableListOf<FuelOptimization>()
            
            activeVehicles.forEach { vehicle ->
                // Generate fuel optimization
                val optimization = fuelOptimizationEngine.optimizeFuelUsage(vehicle)
                optimizations.add(optimization)
                
                // Generate smart notification for fuel efficiency issues
                if (optimization.fuelEfficiencyIssue) {
                    generateFuelEfficiencyAlert(vehicle, optimization)
                }
            }
            
            _fuelOptimizations.postValue(optimizations)
            
        } catch (e: Exception) {
            Timber.e(e, "Error processing fuel optimizations")
        }
    }
    
    /**
     * Process driver behavior analysis
     */
    private suspend fun processDriverBehaviorAnalysis() {
        try {
            // Get active drivers
            val activeDrivers = database.driverDao().getActiveDrivers()
            
            val analyses = mutableListOf<DriverBehaviorAnalysis>()
            
            activeDrivers.forEach { driver ->
                // Generate behavior analysis
                val analysis = driverBehaviorEngine.analyzeBehavior(driver)
                analyses.add(analysis)
                
                // Generate smart notification for behavior issues
                if (analysis.riskScore > 0.7) {
                    generateDriverBehaviorAlert(driver, analysis)
                }
            }
            
            _driverBehaviors.postValue(analyses)
            
        } catch (e: Exception) {
            Timber.e(e, "Error processing driver behavior analysis")
        }
    }
    
    /**
     * Process maintenance predictions
     */
    private suspend fun processMaintenancePredictions() {
        try {
            // Get all vehicles
            val vehicles = database.vehicleDao().getAllVehicles()
            
            val predictions = mutableListOf<MaintenancePrediction>()
            
            vehicles.forEach { vehicle ->
                // Generate maintenance prediction
                val prediction = maintenancePredictionEngine.predictMaintenance(vehicle)
                predictions.add(prediction)
                
                // Generate smart notification for maintenance needs
                if (prediction.maintenanceUrgency > 0.8) {
                    generateMaintenanceAlert(vehicle, prediction)
                }
            }
            
            _maintenancePredictions.postValue(predictions)
            
        } catch (e: Exception) {
            Timber.e(e, "Error processing maintenance predictions")
        }
    }
    
    /**
     * Process demand forecasting
     */
    private suspend fun processDemandForecasting() {
        try {
            // Generate demand forecast for next 7 days
            val forecast = demandForecastingEngine.forecastDemand(7)
            
            _demandForecasts.postValue(listOf(forecast))
            
            // Generate smart notifications for demand spikes
            if (forecast.demandSpike > 1.5) {
                generateDemandSpikeAlert(forecast)
            }
            
        } catch (e: Exception) {
            Timber.e(e, "Error processing demand forecasting")
        }
    }
    
    /**
     * Process shipment risk analysis
     */
    private suspend fun processShipmentRiskAnalysis() {
        try {
            // Get active shipments
            val activeShipments = database.shipmentDao().getActiveShipments()
            
            val analyses = mutableListOf<ShipmentRiskAnalysis>()
            
            activeShipments.forEach { shipment ->
                // Generate risk analysis
                val analysis = riskAnalysisEngine.analyzeRisk(shipment)
                analyses.add(analysis)
                
                // Generate smart notification for high risk
                if (analysis.overallRisk > 0.8) {
                    generateRiskAlert(shipment, analysis)
                }
            }
            
            _riskAnalyses.postValue(analyses)
            
        } catch (e: Exception) {
            Timber.e(e, "Error processing shipment risk analysis")
        }
    }
    
    /**
     * Update AI insights
     */
    private suspend fun updateAIInsights() {
        try {
            val insights = AIInsights(
                totalPredictions = etaPredictionCache.size + delayPredictionCache.size,
                activeOptimizations = routeOptimizationCache.size,
                fuelSavings = calculateTotalFuelSavings(),
                delayPrevented = calculateDelaysPrevented(),
                maintenanceAlerts = calculateMaintenanceAlerts(),
                driverImprovements = calculateDriverImprovements(),
                demandAccuracy = calculateDemandAccuracy(),
                riskReduction = calculateRiskReduction(),
                lastUpdated = System.currentTimeMillis()
            )
            
            _aiInsights.postValue(insights)
            
        } catch (e: Exception) {
            Timber.e(e, "Error updating AI insights")
        }
    }
    
    /**
     * Generate smart notifications
     */
    private fun generateDelayAlert(shipment: Shipment, prediction: DelayPrediction) {
        val notification = SmartNotification(
            id = UUID.randomUUID().toString(),
            type = NotificationType.DELAY_RISK,
            title = "High Delay Risk Detected",
            message = "Shipment ${shipment.id} has ${(prediction.delayRisk * 100).toInt()}% delay risk",
            priority = NotificationPriority.HIGH,
            shipmentId = shipment.id,
            actionRequired = true,
            timestamp = System.currentTimeMillis()
        )
        
        smartNotificationEngine.sendNotification(notification)
    }
    
    private fun generateRouteOptimizationAlert(shipment: Shipment, optimization: RouteOptimization) {
        val notification = SmartNotification(
            id = UUID.randomUUID().toString(),
            type = NotificationType.ROUTE_OPTIMIZATION,
            title = "Route Optimization Available",
            message = "Potential savings: ${optimization.potentialSavings}% for shipment ${shipment.id}",
            priority = NotificationPriority.MEDIUM,
            shipmentId = shipment.id,
            actionRequired = false,
            timestamp = System.currentTimeMillis()
        )
        
        smartNotificationEngine.sendNotification(notification)
    }
    
    private fun generateFuelEfficiencyAlert(vehicle: Vehicle, optimization: FuelOptimization) {
        val notification = SmartNotification(
            id = UUID.randomUUID().toString(),
            type = NotificationType.FUEL_EFFICIENCY,
            title = "Fuel Efficiency Issue",
            message = "Vehicle ${vehicle.id} showing poor fuel efficiency",
            priority = NotificationPriority.MEDIUM,
            vehicleId = vehicle.id,
            actionRequired = true,
            timestamp = System.currentTimeMillis()
        )
        
        smartNotificationEngine.sendNotification(notification)
    }
    
    private fun generateDriverBehaviorAlert(driver: Driver, analysis: DriverBehaviorAnalysis) {
        val notification = SmartNotification(
            id = UUID.randomUUID().toString(),
            type = NotificationType.DRIVER_BEHAVIOR,
            title = "Driver Behavior Alert",
            message = "Driver ${driver.id} risk score: ${(analysis.riskScore * 100).toInt()}%",
            priority = NotificationPriority.HIGH,
            driverId = driver.id,
            actionRequired = true,
            timestamp = System.currentTimeMillis()
        )
        
        smartNotificationEngine.sendNotification(notification)
    }
    
    private fun generateMaintenanceAlert(vehicle: Vehicle, prediction: MaintenancePrediction) {
        val notification = SmartNotification(
            id = UUID.randomUUID().toString(),
            type = NotificationType.MAINTENANCE,
            title = "Maintenance Required",
            message = "Vehicle ${vehicle.id} needs maintenance within ${prediction.daysUntilMaintenance} days",
            priority = NotificationPriority.HIGH,
            vehicleId = vehicle.id,
            actionRequired = true,
            timestamp = System.currentTimeMillis()
        )
        
        smartNotificationEngine.sendNotification(notification)
    }
    
    private fun generateDemandSpikeAlert(forecast: DemandForecast) {
        val notification = SmartNotification(
            id = UUID.randomUUID().toString(),
            type = NotificationType.DEMAND_SPIKE,
            title = "Demand Spike Expected",
            message = "Demand spike of ${(forecast.demandSpike * 100).toInt()}% expected in ${forecast.period}",
            priority = NotificationPriority.MEDIUM,
            actionRequired = false,
            timestamp = System.currentTimeMillis()
        )
        
        smartNotificationEngine.sendNotification(notification)
    }
    
    private fun generateRiskAlert(shipment: Shipment, analysis: ShipmentRiskAnalysis) {
        val notification = SmartNotification(
            id = UUID.randomUUID().toString(),
            type = NotificationType.RISK_ALERT,
            title = "High Risk Shipment",
            message = "Shipment ${shipment.id} has ${(analysis.overallRisk * 100).toInt()}% risk score",
            priority = NotificationPriority.HIGH,
            shipmentId = shipment.id,
            actionRequired = true,
            timestamp = System.currentTimeMillis()
        )
        
        smartNotificationEngine.sendNotification(notification)
    }
    
    /**
     * Update AI models with latest data
     */
    private suspend fun updateAIModels() {
        try {
            // Get latest data
            val latestShipments = database.shipmentDao().getRecentShipments(1000)
            val latestDrivers = database.driverDao().getRecentDrivers(500)
            val latestVehicles = database.vehicleDao().getRecentVehicles(500)
            
            // Update models incrementally
            etaPredictionEngine.updateModel(latestShipments)
            delayPredictionEngine.updateModel(latestShipments)
            routeOptimizationEngine.updateModel(latestShipments)
            fuelOptimizationEngine.updateModel(latestVehicles)
            driverBehaviorEngine.updateModel(latestDrivers)
            maintenancePredictionEngine.updateModel(latestVehicles)
            demandForecastingEngine.updateModel(latestShipments)
            riskAnalysisEngine.updateModel(latestShipments)
            
            Timber.d("AI models updated successfully")
            
        } catch (e: Exception) {
            Timber.e(e, "Error updating AI models")
        }
    }
    
    /**
     * Utility functions
     */
    private fun maintainCacheSize(cache: ConcurrentHashMap<String, Any>) {
        if (cache.size > PREDICTION_CACHE_SIZE) {
            // Remove oldest entries
            val entriesToRemove = cache.size - PREDICTION_CACHE_SIZE
            cache.keys.take(entriesToRemove).forEach { key ->
                cache.remove(key)
            }
        }
    }
    
    private fun calculateTotalFuelSavings(): Double {
        return fuelOptimizationCache.values
            .filterIsInstance<FuelOptimization>()
            .sumOf { it.potentialSavings }
    }
    
    private fun calculateDelaysPrevented(): Int {
        return delayPredictionCache.values
            .filterIsInstance<DelayPrediction>()
            .count { it.delayPrevented }
    }
    
    private fun calculateMaintenanceAlerts(): Int {
        return maintenancePredictionCache.values
            .filterIsInstance<MaintenancePrediction>()
            .count { it.maintenanceUrgency > 0.8 }
    }
    
    private fun calculateDriverImprovements(): Int {
        return driverBehaviors.value?.count { it.riskScore < 0.3 } ?: 0
    }
    
    private fun calculateDemandAccuracy(): Double {
        val forecasts = demandForecasts.value ?: return 0.0
        return forecasts.map { it.accuracy }.average()
    }
    
    private fun calculateRiskReduction(): Double {
        val analyses = riskAnalyses.value ?: return 0.0
        return analyses.map { 1.0 - it.overallRisk }.average()
    }
    
    /**
     * Public API methods
     */
    suspend fun getETAPrediction(shipmentId: String): ETAPrediction? {
        return etaPredictionCache["${shipmentId}_eta"]
    }
    
    suspend fun getDelayPrediction(shipmentId: String): DelayPrediction? {
        return delayPredictionCache["${shipmentId}_delay"]
    }
    
    suspend fun getRouteOptimization(shipmentId: String): RouteOptimization? {
        return routeOptimizationCache["${shipmentId}_route"]
    }
    
    suspend fun getDriverBehavior(driverId: String): DriverBehaviorAnalysis? {
        return driverBehaviors.value?.find { it.driverId == driverId }
    }
    
    suspend fun getMaintenancePrediction(vehicleId: String): MaintenancePrediction? {
        return maintenancePredictions.value?.find { it.vehicleId == vehicleId }
    }
    
    suspend fun getShipmentRiskAnalysis(shipmentId: String): ShipmentRiskAnalysis? {
        return riskAnalyses.value?.find { it.shipmentId == shipmentId }
    }
    
    /**
     * Cleanup resources
     */
    fun cleanup() {
        serviceScope.cancel()
        
        // Clear caches
        etaPredictionCache.clear()
        delayPredictionCache.clear()
        routeOptimizationCache.clear()
        
        // Cleanup AI engines
        etaPredictionEngine.cleanup()
        delayPredictionEngine.cleanup()
        routeOptimizationEngine.cleanup()
        fuelOptimizationEngine.cleanup()
        driverBehaviorEngine.cleanup()
        maintenancePredictionEngine.cleanup()
        demandForecastingEngine.cleanup()
        riskAnalysisEngine.cleanup()
        smartNotificationEngine.cleanup()
        
        Timber.d("AI services cleaned up")
    }
}

// Data classes
data class ETAPrediction(
    val shipmentId: String,
    val predictedETA: Long,
    val confidence: Double,
    val factors: List<PredictionFactor>,
    val timestamp: Long
)

data class DelayPrediction(
    val shipmentId: String,
    val delayRisk: Double,
    val predictedDelayMinutes: Long,
    val delayCauses: List<String>,
    val delayPrevented: Boolean,
    val timestamp: Long
)

data class RouteOptimization(
    val shipmentId: String,
    val optimizedRoute: List<RoutePoint>,
    val originalRoute: List<RoutePoint>,
    val potentialSavings: Double,
    val timeReduction: Long,
    val distanceReduction: Double,
    val timestamp: Long
)

data class FuelOptimization(
    val vehicleId: String,
    val currentEfficiency: Double,
    val optimalEfficiency: Double,
    val potentialSavings: Double,
    val recommendations: List<String>,
    val fuelEfficiencyIssue: Boolean,
    val timestamp: Long
)

data class DriverBehaviorAnalysis(
    val driverId: String,
    val riskScore: Double,
    val behaviorMetrics: Map<String, Double>,
    val recommendations: List<String>,
    val improvementAreas: List<String>,
    val timestamp: Long
)

data class MaintenancePrediction(
    val vehicleId: String,
    val maintenanceUrgency: Double,
    val daysUntilMaintenance: Int,
    val predictedIssues: List<String>,
    val maintenanceType: String,
    val estimatedCost: Double,
    val timestamp: Long
)

data class DemandForecast(
    val period: String,
    val predictedDemand: Int,
    val confidence: Double,
    val demandSpike: Double,
    val factors: List<String>,
    val accuracy: Double,
    val timestamp: Long
)

data class ShipmentRiskAnalysis(
    val shipmentId: String,
    val overallRisk: Double,
    val riskFactors: Map<String, Double>,
    val recommendations: List<String>,
    val mitigationStrategies: List<String>,
    val timestamp: Long
)

data class SmartNotification(
    val id: String,
    val type: NotificationType,
    val title: String,
    val message: String,
    val priority: NotificationPriority,
    val shipmentId: String? = null,
    val driverId: String? = null,
    val vehicleId: String? = null,
    val actionRequired: Boolean,
    val timestamp: Long
)

data class AIInsights(
    val totalPredictions: Int = 0,
    val activeOptimizations: Int = 0,
    val fuelSavings: Double = 0.0,
    val delaysPrevented: Int = 0,
    val maintenanceAlerts: Int = 0,
    val driverImprovements: Int = 0,
    val demandAccuracy: Double = 0.0,
    val riskReduction: Double = 0.0,
    val lastUpdated: Long = 0
)

data class PredictionFactor(
    val factor: String,
    val impact: Double,
    val value: Double
)

data class RoutePoint(
    val latitude: Double,
    val longitude: Double,
    val address: String,
    val estimatedTime: Long
)

// Enums
enum class NotificationType {
    DELAY_RISK,
    ROUTE_OPTIMIZATION,
    FUEL_EFFICIENCY,
    DRIVER_BEHAVIOR,
    MAINTENANCE,
    DEMAND_SPIKE,
    RISK_ALERT
}

enum class NotificationPriority {
    LOW, MEDIUM, HIGH, CRITICAL
}
