package com.edham.logistics.fleet

import android.os.Bundle
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import androidx.fragment.app.Fragment
import androidx.lifecycle.ViewModelProvider
import androidx.lifecycle.lifecycleScope
import com.edham.logistics.R
import com.edham.logistics.databinding.FragmentAnalyticsChartsBinding
import com.edham.logistics.fleet.viewmodels.AnalyticsChartsViewModel
import com.github.mikephil.charting.charts.LineChart
import com.github.mikephil.charting.charts.BarChart
import com.github.mikephil.charting.charts.PieChart
import com.github.mikephil.charting.data.*
import com.github.mikephil.charting.formatter.PercentFormatter
import com.github.mikephil.charting.formatter.ValueFormatter
import com.github.mikephil.charting.interfaces.datasets.ILineDataSet
import kotlinx.coroutines.launch
import javax.inject.Inject

/**
 * Analytics Charts Fragment - Comprehensive fleet analytics visualization
 * 
 * Features:
 * - Interactive charts and graphs
 * - Real-time data updates
 * - Multiple time range views
 * - Performance metrics
 * - Cost analysis
 * - Fuel consumption tracking
 * - Export functionality
 */
class AnalyticsChartsFragment @Inject constructor() : Fragment() {

    private var _binding: FragmentAnalyticsChartsBinding? = null
    private val binding get() = _binding!!
    
    private lateinit var viewModel: AnalyticsChartsViewModel
    private var currentUtilizationPeriod = ChartPeriod.DAILY
    private var currentFuelPeriod = ChartPeriod.DAILY
    
    companion object {
        private const val ANIMATION_DURATION = 1000
    }

    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View {
        _binding = FragmentAnalyticsChartsBinding.inflate(inflater, container, false)
        return binding.root
    }

    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        
        setupViewModel()
        setupCharts()
        setupClickListeners()
        observeViewModel()
        
        // Load initial data
        viewModel.loadAnalyticsData()
    }

    private fun setupViewModel() {
        viewModel = ViewModelProvider(this)[AnalyticsChartsViewModel::class.java]
    }

    private fun setupCharts() {
        setupUtilizationChart()
        setupFuelConsumptionChart()
        setupCostAnalysisChart()
    }

    private fun setupClickListeners() {
        // Date range selector
        binding.btnDateRange.setOnClickListener {
            showDateRangePicker()
        }
        
        // Utilization chart period buttons
        binding.btnUtilizationDaily.setOnClickListener {
            updateUtilizationPeriod(ChartPeriod.DAILY)
        }
        
        binding.btnUtilizationWeekly.setOnClickListener {
            updateUtilizationPeriod(ChartPeriod.WEEKLY)
        }
        
        binding.btnUtilizationMonthly.setOnClickListener {
            updateUtilizationPeriod(ChartPeriod.MONTHLY)
        }
        
        // Fuel chart period buttons
        binding.btnFuelDaily.setOnClickListener {
            updateFuelPeriod(ChartPeriod.DAILY)
        }
        
        binding.btnFuelWeekly.setOnClickListener {
            updateFuelPeriod(ChartPeriod.WEEKLY)
        }
        
        binding.btnFuelMonthly.setOnClickListener {
            updateFuelPeriod(ChartPeriod.MONTHLY)
        }
        
        // Export button
        binding.fabExport.setOnClickListener {
            exportAnalyticsData()
        }
    }

    private fun observeViewModel() {
        viewLifecycleOwner.lifecycleScope.launch {
            viewModel.analyticsState.collect { state ->
                when (state) {
                    is AnalyticsState.Loading -> {
                        showLoadingState()
                    }
                    is AnalyticsState.Success -> {
                        hideLoadingState()
                        updateCharts(state.data)
                    }
                    is AnalyticsState.Error -> {
                        hideLoadingState()
                        showError(state.message)
                    }
                }
            }
        }

        viewLifecycleOwner.lifecycleScope.launch {
            viewModel.keyMetrics.collect { metrics ->
                updateKeyMetrics(metrics)
            }
        }

        viewLifecycleOwner.lifecycleScope.launch {
            viewModel.utilizationData.collect { data ->
                updateUtilizationChart(data)
            }
        }

        viewLifecycleOwner.lifecycleScope.launch {
            viewModel.fuelData.collect { data ->
                updateFuelChart(data)
            }
        }

        viewLifecycleOwner.lifecycleScope.launch {
            viewModel.costData.collect { data ->
                updateCostChart(data)
            }
        }
    }

    private fun setupUtilizationChart() {
        val chart = binding.chartUtilization
        
        // Chart appearance
        chart.description.isEnabled = false
        chart.legend.isEnabled = true
        chart.legend.textColor = requireContext().getColor(R.color.white)
        chart.legend.textSize = 12f
        
        // Axis configuration
        chart.xAxis.isEnabled = true
        chart.xAxis.textColor = requireContext().getColor(R.color.white_60)
        chart.xAxis.textSize = 10f
        chart.xAxis.setDrawGridLines(false)
        
        chart.axisLeft.isEnabled = true
        chart.axisLeft.textColor = requireContext().getColor(R.color.white_60)
        chart.axisLeft.textSize = 10f
        chart.axisLeft.setDrawGridLines(true)
        chart.axisLeft.gridColor = requireContext().getColor(R.color.white_20)
        chart.axisLeft.axisMinimum = 0f
        chart.axisLeft.axisMaximum = 100f
        chart.axisLeft.valueFormatter = PercentFormatter()
        
        chart.axisRight.isEnabled = false
        
        // Touch gestures
        chart.setTouchEnabled(true)
        chart.isDragEnabled = true
        chart.setScaleEnabled(true)
        chart.setPinchZoom(true)
        
        // Animation
        chart.animateX(ANIMATION_DURATION)
    }

    private fun setupFuelConsumptionChart() {
        val chart = binding.chartFuelConsumption
        
        // Chart appearance
        chart.description.isEnabled = false
        chart.legend.isEnabled = true
        chart.legend.textColor = requireContext().getColor(R.color.white)
        chart.legend.textSize = 12f
        
        // Axis configuration
        chart.xAxis.isEnabled = true
        chart.xAxis.textColor = requireContext().getColor(R.color.white_60)
        chart.xAxis.textSize = 10f
        chart.xAxis.setDrawGridLines(false)
        
        chart.axisLeft.isEnabled = true
        chart.axisLeft.textColor = requireContext().getColor(R.color.white_60)
        chart.axisLeft.textSize = 10f
        chart.axisLeft.setDrawGridLines(true)
        chart.axisLeft.gridColor = requireContext().getColor(R.color.white_20)
        chart.axisLeft.axisMinimum = 0f
        chart.axisLeft.valueFormatter = object : ValueFormatter() {
            override fun getFormattedValue(value: Float): String {
                return "${value.toInt()} لتر"
            }
        }
        
        chart.axisRight.isEnabled = false
        
        // Touch gestures
        chart.setTouchEnabled(true)
        chart.isDragEnabled = true
        chart.setScaleEnabled(true)
        chart.setPinchZoom(true)
        
        // Animation
        chart.animateY(ANIMATION_DURATION)
    }

    private fun setupCostAnalysisChart() {
        val chart = binding.chartCostAnalysis
        
        // Chart appearance
        chart.description.isEnabled = false
        chart.legend.isEnabled = true
        chart.legend.textColor = requireContext().getColor(R.color.white)
        chart.legend.textSize = 12f
        chart.legend.verticalAlignment = com.github.mikephil.charting.components.Legend.LegendVerticalAlignment.BOTTOM
        chart.legend.horizontalAlignment = com.github.mikephil.charting.components.Legend.LegendHorizontalAlignment.CENTER
        
        // Hole in the center
        chart.isDrawHoleEnabled = true
        chart.holeRadius = 40f
        chart.transparentCircleRadius = 45f
        chart.setHoleColor(requireContext().getColor(R.color.surface_dark))
        
        // Text in center
        chart.setDrawCenterText(true)
        chart.centerText = "التكاليف"
        chart.centerTextColor = requireContext().getColor(R.color.white)
        chart.centerTextSize = 16f
        
        // Rotation angle
        chart.rotationAngle = 0f
        chart.isRotationEnabled = true
        
        // Animation
        chart.animateY(ANIMATION_DURATION)
    }

    private fun updateCharts(data: AnalyticsData) {
        updateKeyMetrics(data.keyMetrics)
        updateUtilizationChart(data.utilizationData)
        updateFuelChart(data.fuelData)
        updateCostChart(data.costData)
        updatePerformanceMetrics(data.performanceMetrics)
    }

    private fun updateKeyMetrics(metrics: KeyMetrics) {
        binding.tvUtilizationRate.text = "${metrics.utilizationRate}%"
        binding.tvUtilizationTrend.text = if (metrics.utilizationTrend > 0) {
            "↑ ${metrics.utilizationTrend}%"
        } else {
            "↓ ${abs(metrics.utilizationTrend)}%"
        }
        binding.tvUtilizationTrend.setTextColor(
            requireContext().getColor(
                if (metrics.utilizationTrend > 0) R.color.green else R.color.red
            )
        )
        
        binding.tvCostPerMile.text = "${metrics.costPerMile} ريال"
        binding.tvCostTrend.text = if (metrics.costTrend > 0) {
            "↑ ${metrics.costTrend}%"
        } else {
            "↓ ${abs(metrics.costTrend)}%"
        }
        binding.tvCostTrend.setTextColor(
            requireContext().getColor(
                if (metrics.costTrend < 0) R.color.green else R.color.red
            )
        )
    }

    private fun updateUtilizationChart(data: UtilizationChartData) {
        val chart = binding.chartUtilization
        
        val entries = data.values.mapIndexed { index, value ->
            Entry(index.toFloat(), value)
        }
        
        val dataSet = LineDataSet(entries, "معدل الاستغلال").apply {
            color = requireContext().getColor(R.color.primary_blue)
            setCircleColor(requireContext().getColor(R.color.primary_blue))
            lineWidth = 2f
            circleRadius = 4f
            setDrawCircleHole(false)
            setDrawValues(false)
            mode = LineDataSet.Mode.CUBIC_BEZIER
            cubicIntensity = 0.2f
        }
        
        val lineData = LineData(dataSet)
        chart.data = lineData
        
        // Update X-axis labels
        chart.xAxis.valueFormatter = object : ValueFormatter() {
            override fun getFormattedValue(value: Float): String {
                val index = value.toInt()
                return if (index < data.labels.size) data.labels[index] else ""
            }
        }
        
        // Update statistics
        binding.tvUtilizationAverage.text = "${data.average}%"
        binding.tvUtilizationPeak.text = "${data.peak}%"
        
        chart.notifyDataSetChanged()
        chart.invalidate()
    }

    private fun updateFuelChart(data: FuelChartData) {
        val chart = binding.chartFuelConsumption
        
        val entries = data.values.mapIndexed { index, value ->
            BarEntry(index.toFloat(), value)
        }
        
        val dataSet = BarDataSet(entries, "استهلاك الوقود").apply {
            color = requireContext().getColor(R.color.teal)
            setDrawValues(false)
        }
        
        val barData = BarData(dataSet)
        chart.data = barData
        
        // Update X-axis labels
        chart.xAxis.valueFormatter = object : ValueFormatter() {
            override fun getFormattedValue(value: Float): String {
                val index = value.toInt()
                return if (index < data.labels.size) data.labels[index] else ""
            }
        }
        
        // Update statistics
        binding.tvFuelTotal.text = "${data.total} لتر"
        binding.tvFuelAverage.text = "${data.average} لتر"
        
        chart.notifyDataSetChanged()
        chart.invalidate()
    }

    private fun updateCostChart(data: CostChartData) {
        val chart = binding.chartCostAnalysis
        
        val entries = data.categories.mapIndexed { index, category ->
            PieEntry(category.value, category.label)
        }
        
        val colors = listOf(
            requireContext().getColor(R.color.primary_blue),
            requireContext().getColor(R.color.green),
            requireContext().getColor(R.color.orange),
            requireContext().getColor(R.color.red),
            requireContext().getColor(R.color.purple)
        )
        
        val dataSet = PieDataSet(entries, "تكاليف الأسطول").apply {
            this.colors = colors
            setDrawValues(true)
            valueTextColor = requireContext().getColor(R.color.white)
            valueTextSize = 12f
            valueFormatter = PercentFormatter(chart)
        }
        
        val pieData = PieData(dataSet)
        chart.data = pieData
        
        // Update total cost
        binding.tvTotalCost.text = "${data.total} ريال"
        
        chart.notifyDataSetChanged()
        chart.invalidate()
    }

    private fun updatePerformanceMetrics(metrics: PerformanceMetrics) {
        binding.tvOnTimeRate.text = "${metrics.onTimeDeliveryRate}%"
        binding.tvEfficiencyRate.text = "${metrics.vehicleEfficiencyRate}%"
        binding.tvAvgSpeed.text = "${metrics.averageSpeed} كم/س"
        binding.tvTotalDistance.text = "${metrics.totalDistance.formatNumber()} كم"
        
        // Update colors based on performance
        updateMetricColor(binding.tvOnTimeRate, metrics.onTimeDeliveryRate, 90f)
        updateMetricColor(binding.tvEfficiencyRate, metrics.vehicleEfficiencyRate, 85f)
    }

    private fun updateMetricColor(textView: android.widget.TextView, value: Float, threshold: Float) {
        val color = when {
            value >= threshold -> R.color.green
            value >= threshold * 0.8f -> R.color.yellow
            else -> R.color.red
        }
        textView.setTextColor(requireContext().getColor(color))
    }

    private fun updateUtilizationPeriod(period: ChartPeriod) {
        currentUtilizationPeriod = period
        
        // Update button styles
        updatePeriodButtons(
            listOf(binding.btnUtilizationDaily, binding.btnUtilizationWeekly, binding.btnUtilizationMonthly),
            period
        )
        
        // Load data for new period
        viewModel.loadUtilizationData(period)
    }

    private fun updateFuelPeriod(period: ChartPeriod) {
        currentFuelPeriod = period
        
        // Update button styles
        updatePeriodButtons(
            listOf(binding.btnFuelDaily, binding.btnFuelWeekly, binding.btnFuelMonthly),
            period
        )
        
        // Load data for new period
        viewModel.loadFuelData(period)
    }

    private fun updatePeriodButtons(buttons: List<android.widget.TextView>, selectedPeriod: ChartPeriod) {
        buttons.forEachIndexed { index, button ->
            val isSelected = when (selectedPeriod) {
                ChartPeriod.DAILY -> index == 0
                ChartPeriod.WEEKLY -> index == 1
                ChartPeriod.MONTHLY -> index == 2
            }
            
            if (isSelected) {
                button.setTextColor(requireContext().getColor(R.color.primary_blue))
                button.setBackgroundResource(R.drawable.bg_chart_tab_selected)
            } else {
                button.setTextColor(requireContext().getColor(R.color.white_60))
                button.setBackgroundResource(R.drawable.bg_chart_tab_unselected)
            }
        }
    }

    private fun showDateRangePicker() {
        // Show date range picker dialog
        val datePicker = com.google.android.material.datepicker.MaterialDatePicker.Builder
            .dateRangePicker()
            .setTitleText("اختر فترة التحليل")
            .build()
        
        datePicker.addOnPositiveButtonClickListener { selection ->
            val startDate = selection?.first
            val endDate = selection?.second
            // Update date range and reload data
            viewModel.updateDateRange(startDate, endDate)
        }
        
        datePicker.show(childFragmentManager, "date_range_picker")
    }

    private fun exportAnalyticsData() {
        viewModel.exportAnalyticsData { success, message ->
            if (success) {
                showSuccessMessage("تم تصدير البيانات بنجاح")
            } else {
                showErrorMessage("فشل تصدير البيانات: $message")
            }
        }
    }

    private fun showLoadingState() {
        // Show loading indicators
        binding.progressBar.visibility = View.VISIBLE
        binding.contentGroup.visibility = View.GONE
    }

    private fun hideLoadingState() {
        // Hide loading indicators
        binding.progressBar.visibility = View.GONE
        binding.contentGroup.visibility = View.VISIBLE
    }

    private fun showSuccessMessage(message: String) {
        com.google.android.material.snackbar.Snackbar.make(
            binding.root,
            message,
            com.google.android.material.snackbar.Snackbar.LENGTH_SHORT
        ).show()
    }

    private fun showErrorMessage(message: String) {
        com.google.android.material.snackbar.Snackbar.make(
            binding.root,
            message,
            com.google.android.material.snackbar.Snackbar.LENGTH_LONG
        ).show()
    }

    private fun Int.formatNumber(): String {
        return this.toString().reversed().chunked(3).joinToString(",").reversed()
    }

    private fun Float.formatNumber(): String {
        return this.toInt().formatNumber()
    }

    override fun onDestroyView() {
        super.onDestroyView()
        _binding = null
    }
}

/**
 * Enums and data classes
 */
enum class ChartPeriod {
    DAILY,
    WEEKLY,
    MONTHLY
}

data class KeyMetrics(
    val utilizationRate: Float,
    val utilizationTrend: Float,
    val costPerMile: Float,
    val costTrend: Float
)

data class UtilizationChartData(
    val labels: List<String>,
    val values: List<Float>,
    val average: Float,
    val peak: Float
)

data class FuelChartData(
    val labels: List<String>,
    val values: List<Float>,
    val total: Int,
    val average: Float
)

data class CostChartData(
    val categories: List<CostCategory>,
    val total: Float
)

data class CostCategory(
    val label: String,
    val value: Float
)

data class PerformanceMetrics(
    val onTimeDeliveryRate: Float,
    val vehicleEfficiencyRate: Float,
    val averageSpeed: Float,
    val totalDistance: Float
)

data class AnalyticsData(
    val keyMetrics: KeyMetrics,
    val utilizationData: UtilizationChartData,
    val fuelData: FuelChartData,
    val costData: CostChartData,
    val performanceMetrics: PerformanceMetrics
)

enum class AnalyticsState {
    Loading,
    Success,
    Error
}
