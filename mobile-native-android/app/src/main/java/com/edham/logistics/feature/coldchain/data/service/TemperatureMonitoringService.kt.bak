package com.edham.logistics.feature.coldchain.data.service

import android.annotation.SuppressLint
import android.app.Notification
import android.app.NotificationChannel
import android.app.NotificationManager
import android.app.Service
import android.content.Context
import android.content.Intent
import android.os.Build
import android.os.IBinder
import android.os.Looper
import android.util.Log
import androidx.core.app.NotificationCompat
import androidx.core.content.ContextCompat
import com.edham.logistics.R
import com.edham.logistics.core.utils.TokenManager
import com.edham.logistics.feature.coldchain.domain.model.UpdateTemperatureRequest
import com.edham.logistics.feature.coldchain.domain.usecase.UpdateTemperatureUseCase
import com.google.android.gms.location.*
import com.google.android.gms.maps.model.LatLng
import dagger.hilt.android.AndroidEntryPoint
import kotlinx.coroutines.CoroutineScope
import kotlinx.coroutines.Dispatchers
import kotlinx.coroutines.SupervisorJob
import kotlinx.coroutines.delay
import kotlinx.coroutines.flow.MutableStateFlow
import kotlinx.coroutines.flow.StateFlow
import kotlinx.coroutines.flow.asStateFlow
import kotlinx.coroutines.isActive
import kotlinx.coroutines.launch
import javax.inject.Inject

@AndroidEntryPoint
class TemperatureMonitoringService : Service() {

    @Inject
    lateinit var updateTemperatureUseCase: UpdateTemperatureUseCase
    
    @Inject
    lateinit var tokenManager: TokenManager

    private lateinit var fusedLocationClient: FusedLocationProviderClient
    
    private val serviceScope = CoroutineScope(Dispatchers.IO + SupervisorJob())
    
    private var currentShipmentId: String? = null
    private var currentSensorId: String? = null
    private var currentCargoType: String? = null
    
    private var isMonitoring = false
    private var lastTemperature: Double? = null
    private var lastHumidity: Double? = null
    private var lastUpdateTime: Long = 0
    
    private val _temperatureUpdates = MutableStateFlow<Double?>(null)
    val temperatureUpdates: StateFlow<Double?> = _temperatureUpdates.asStateFlow()
    
    private val _humidityUpdates = MutableStateFlow<Double?>(null)
    val humidityUpdates: StateFlow<Double?> = _humidityUpdates.asStateFlow()
    
    private val _monitoringStatus = MutableStateFlow(false)
    val monitoringStatus: StateFlow<Boolean> = _monitoringStatus.asStateFlow()
    
    companion object {
        private const val TAG = "TemperatureMonitoring"
        private const val NOTIFICATION_ID = 1002
        private const val NOTIFICATION_CHANNEL_ID = "temperature_monitoring_channel"
        private const val UPDATE_INTERVAL = 60000L // 1 minute
        private const val FASTEST_UPDATE_INTERVAL = 30000L // 30 seconds
        private const val TEMPERATURE_UPDATE_INTERVAL = 30000L // 30 seconds
        
        fun startMonitoring(
            context: Context,
            shipmentId: String,
            sensorId: String,
            cargoType: String
        ) {
            val intent = Intent(context, TemperatureMonitoringService::class.java).apply {
                putExtra("shipment_id", shipmentId)
                putExtra("sensor_id", sensorId)
                putExtra("cargo_type", cargoType)
            }
            ContextCompat.startForegroundService(context, intent)
        }
        
        fun stopMonitoring(context: Context) {
            val intent = Intent(context, TemperatureMonitoringService::class.java)
            context.stopService(intent)
        }
    }

    override fun onCreate() {
        super.onCreate()
        fusedLocationClient = LocationServices.getFusedLocationProviderClient(this)
        createNotificationChannel()
    }

    override fun onStartCommand(intent: Intent?, flags: Int, startId: Int): Int {
        intent?.let {
            currentShipmentId = it.getStringExtra("shipment_id")
            currentSensorId = it.getStringExtra("sensor_id")
            currentCargoType = it.getStringExtra("cargo_type")
        }
        
        if (currentShipmentId != null && currentSensorId != null) {
            startTemperatureMonitoring()
        }
        
        return START_STICKY
    }

    override fun onBind(intent: Intent?): IBinder? = null

    private fun startTemperatureMonitoring() {
        if (isMonitoring) return
        
        startForeground(NOTIFICATION_ID, createNotification())
        isMonitoring = true
        _monitoringStatus.value = true
        
        // Start periodic temperature readings
        serviceScope.launch {
            while (isActive && isMonitoring) {
                readTemperatureFromSensor()
                delay(TEMPERATURE_UPDATE_INTERVAL)
            }
        }
        
        Log.d(TAG, "Temperature monitoring started")
    }

    private fun stopTemperatureMonitoring() {
        if (!isMonitoring) return
        
        isMonitoring = false
        _monitoringStatus.value = false
        
        Log.d(TAG, "Temperature monitoring stopped")
    }

    private suspend fun readTemperatureFromSensor() {
        try {
            // Simulate reading from temperature sensor
            // In real implementation, this would connect to actual sensor hardware
            val temperature = simulateTemperatureReading()
            val humidity = simulateHumidityReading()
            
            // Get current location
            val location = getCurrentLocation()
            
            // Update state
            lastTemperature = temperature
            lastHumidity = humidity
            lastUpdateTime = System.currentTimeMillis()
            
            _temperatureUpdates.value = temperature
            _humidityUpdates.value = humidity
            
            // Send to server
            currentShipmentId?.let { shipmentId ->
                currentSensorId?.let { sensorId ->
                    val request = UpdateTemperatureRequest(
                        shipmentId = shipmentId,
                        sensorId = sensorId,
                        temperature = temperature,
                        humidity = humidity,
                        location = location,
                        batteryLevel = getBatteryLevel(),
                        signalStrength = getSignalStrength()
                    )
                    
                    when (val result = updateTemperatureUseCase(request)) {
                        is com.edham.logistics.core.utils.Result.Success -> {
                            Log.d(TAG, "Temperature data sent successfully: $temperature°C")
                        }
                        is com.edham.logistics.core.utils.Result.Error -> {
                            Log.e(TAG, "Failed to send temperature data: ${result.exception.message}")
                        }
                        is com.edham.logistics.core.utils.Result.Loading -> {
                            // Handle loading state if needed
                        }
                    }
                }
            }
            
        } catch (e: Exception) {
            Log.e(TAG, "Error reading temperature sensor", e)
        }
    }

    private fun simulateTemperatureReading(): Double {
        // Simulate temperature reading based on cargo type
        return when (currentCargoType) {
            "FOOD" -> 4.0 + (Math.random() - 0.5) * 4 // 2-6°C
            "MEDICAL" -> 20.0 + (Math.random() - 0.5) * 10 // 15-25°C
            "FROZEN_GOODS" -> -20.0 + (Math.random() - 0.5) * 10 // -25 to -15°C
            "PHARMACEUTICAL" -> 5.0 + (Math.random() - 0.5) * 6 // 2-8°C
            else -> 15.0 + (Math.random() - 0.5) * 10 // 10-20°C
        }
    }

    private fun simulateHumidityReading(): Double? {
        // Simulate humidity reading
        return 60.0 + (Math.random() - 0.5) * 40 // 40-80%
    }

    @SuppressLint("MissingPermission")
    private suspend fun getCurrentLocation(): LatLng? {
        return try {
            val locationResult = fusedLocationClient.lastLocation
            val location = locationResult.await()
            location?.let { LatLng(it.latitude, it.longitude) }
        } catch (e: Exception) {
            Log.e(TAG, "Error getting current location", e)
            null
        }
    }

    private fun getBatteryLevel(): Float? {
        return try {
            val batteryManager = getSystemService(Context.BATTERY_SERVICE) as android.os.BatteryManager
            batteryManager.getIntProperty(android.os.BatteryManager.BATTERY_PROPERTY_CAPACITY).toFloat()
        } catch (e: Exception) {
            Log.e(TAG, "Error getting battery level", e)
            null
        }
    }

    private fun getSignalStrength(): Float? {
        // Simulate signal strength (0-100)
        return (50 + Math.random() * 50).toFloat()
    }

    private fun createNotificationChannel() {
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            val channel = NotificationChannel(
                NOTIFICATION_CHANNEL_ID,
                "Temperature Monitoring Service",
                NotificationManager.IMPORTANCE_LOW
            ).apply {
                description = "Monitors temperature for cold chain shipments"
                setShowBadge(false)
                enableVibration(false)
                setSound(null, null)
            }
            
            val notificationManager = getSystemService(NotificationManager::class.java)
            notificationManager.createNotificationChannel(channel)
        }
    }

    private fun createNotification(): Notification {
        val temperatureText = lastTemperature?.let { "${it}°C" } ?: "--°C"
        val humidityText = lastHumidity?.let { "${it.toInt()}%" } ?: "--%"
        
        return NotificationCompat.Builder(this, NOTIFICATION_CHANNEL_ID)
            .setContentTitle("مراقبة درجة الحرارة نشطة")
            .setContentText("الحرارة: $temperatureText | الرطوبة: $humidityText")
            .setSmallIcon(R.drawable.ic_temperature)
            .setPriority(NotificationCompat.PRIORITY_LOW)
            .setOngoing(true)
            .setSilent(true)
            .build()
    }

    fun updateNotification() {
        if (isMonitoring) {
            val notification = createNotification()
            val notificationManager = getSystemService(NotificationManager::class.java)
            notificationManager.notify(NOTIFICATION_ID, notification)
        }
    }

    override fun onDestroy() {
        super.onDestroy()
        stopTemperatureMonitoring()
        serviceScope.cancel()
    }
}
