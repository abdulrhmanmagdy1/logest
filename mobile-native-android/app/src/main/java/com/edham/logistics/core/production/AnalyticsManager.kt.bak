package com.edham.logistics.core.production

import android.content.Context
import android.os.Bundle
import android.util.Log
import com.google.firebase.analytics.FirebaseAnalytics
import com.google.firebase.analytics.ktx.analytics
import com.google.firebase.ktx.Firebase
import dagger.hilt.android.qualifiers.ApplicationContext
import javax.inject.Inject
import javax.inject.Singleton

/**
 * Analytics Manager
 * Handles Firebase Analytics integration for production analytics
 */
@Singleton
class AnalyticsManager @Inject constructor(
    @ApplicationContext private val context: Context,
    private val productionConfig: ProductionConfig
) {
    
    private val firebaseAnalytics: FirebaseAnalytics by lazy {
        Firebase.analytics
    }
    
    companion object {
        private const val TAG = "AnalyticsManager"
        
        // Event names
        const val EVENT_APP_OPEN = "app_open"
        const val EVENT_LOGIN = "login"
        const val EVENT_LOGOUT = "logout"
        const val EVENT_SHIPMENT_CREATED = "shipment_created"
        const val EVENT_SHIPMENT_TRACKED = "shipment_tracked"
        const val EVENT_INVOICE_CREATED = "invoice_created"
        const val EVENT_INVOICE_PAID = "invoice_paid"
        const val EVENT_REPORT_GENERATED = "report_generated"
        const val EVENT_SEARCH_PERFORMED = "search_performed"
        const val EVENT_NOTIFICATION_RECEIVED = "notification_received"
        const val EVENT_BACKUP_CREATED = "backup_created"
        
        // Parameter names
        const val PARAM_USER_ROLE = "user_role"
        const val PARAM_SHIPMENT_ID = "shipment_id"
        const val PARAM_SHIPMENT_STATUS = "shipment_status"
        const val PARAM_INVOICE_ID = "invoice_id"
        const val PARAM_INVOICE_AMOUNT = "invoice_amount"
        const val PARAM_REPORT_TYPE = "report_type"
        const val PARAM_SEARCH_QUERY = "search_query"
        const val PARAM_SEARCH_RESULTS = "search_results"
        const val PARAM_NOTIFICATION_TYPE = "notification_type"
        const val PARAM_ERROR_TYPE = "error_type"
        const val PARAM_SCREEN_NAME = "screen_name"
        const val PARAM_SESSION_DURATION = "session_duration"
        
        // User properties
        const val USER_PROPERTY_ROLE = "user_role"
        const val USER_PROPERTY_APP_VERSION = "app_version"
        const val USER_PROPERTY_DEVICE_CATEGORY = "device_category"
        const val USER_PROPERTY_PREFERRED_LANGUAGE = "preferred_language"
    }
    
    /**
     * Initialize analytics
     */
    fun initialize() {
        if (productionConfig.isProductionMode()) {
            setupAnalytics()
            setUserProperties()
            Log.i(TAG, "Analytics initialized")
        } else {
            Log.d(TAG, "Analytics disabled in non-production mode")
        }
    }
    
    /**
     * Setup Firebase Analytics
     */
    private fun setupAnalytics() {
        try {
            // Set analytics collection enabled
            firebaseAnalytics.setAnalyticsCollectionEnabled(true)
            
            // Set default event parameters
            firebaseAnalytics.setDefaultEventParameters(
                Bundle().apply {
                    putString("app_name", "Edham Logistics")
                    putString("app_version", productionConfig.getBuildInfo()["versionName"])
                }
            )
            
            Log.i(TAG, "Firebase Analytics setup completed")
        } catch (e: Exception) {
            Log.e(TAG, "Failed to setup Firebase Analytics", e)
        }
    }
    
    /**
     * Set user properties
     */
    private fun setUserProperties() {
        try {
            // App version
            firebaseAnalytics.setUserProperty(
                USER_PROPERTY_APP_VERSION,
                productionConfig.getBuildInfo()["versionName"]
            )
            
            // Device category
            val deviceCategory = getDeviceCategory()
            firebaseAnalytics.setUserProperty(USER_PROPERTY_DEVICE_CATEGORY, deviceCategory)
            
            // Preferred language
            val language = getPreferredLanguage()
            firebaseAnalytics.setUserProperty(USER_PROPERTY_PREFERRED_LANGUAGE, language)
            
            Log.i(TAG, "User properties set")
        } catch (e: Exception) {
            Log.e(TAG, "Failed to set user properties", e)
        }
    }
    
    /**
     * Track app open
     */
    fun trackAppOpen() {
        if (productionConfig.isProductionMode()) {
            try {
                firebaseAnalytics.logEvent(EVENT_APP_OPEN, Bundle().apply {
                    putLong("timestamp", System.currentTimeMillis())
                })
                Log.d(TAG, "App open tracked")
            } catch (e: Exception) {
                Log.e(TAG, "Failed to track app open", e)
            }
        }
    }
    
    /**
     * Track login event
     */
    fun trackLogin(userRole: String, userId: String) {
        if (productionConfig.isProductionMode()) {
            try {
                firebaseAnalytics.logEvent(EVENT_LOGIN, Bundle().apply {
                    putString(PARAM_USER_ROLE, userRole)
                    putString("user_id", userId)
                    putLong("timestamp", System.currentTimeMillis())
                })
                
                // Set user role property
                firebaseAnalytics.setUserProperty(USER_PROPERTY_ROLE, userRole)
                
                Log.d(TAG, "Login tracked for role: $userRole")
            } catch (e: Exception) {
                Log.e(TAG, "Failed to track login", e)
            }
        }
    }
    
    /**
     * Track logout event
     */
    fun trackLogout(userRole: String, sessionDuration: Long) {
        if (productionConfig.isProductionMode()) {
            try {
                firebaseAnalytics.logEvent(EVENT_LOGOUT, Bundle().apply {
                    putString(PARAM_USER_ROLE, userRole)
                    putLong(PARAM_SESSION_DURATION, sessionDuration)
                    putLong("timestamp", System.currentTimeMillis())
                })
                
                // Clear user role property
                firebaseAnalytics.setUserProperty(USER_PROPERTY_ROLE, null)
                
                Log.d(TAG, "Logout tracked for role: $userRole")
            } catch (e: Exception) {
                Log.e(TAG, "Failed to track logout", e)
            }
        }
    }
    
    /**
     * Track shipment created
     */
    fun trackShipmentCreated(shipmentId: String, userRole: String) {
        if (productionConfig.isProductionMode()) {
            try {
                firebaseAnalytics.logEvent(EVENT_SHIPMENT_CREATED, Bundle().apply {
                    putString(PARAM_SHIPMENT_ID, shipmentId)
                    putString(PARAM_USER_ROLE, userRole)
                    putLong("timestamp", System.currentTimeMillis())
                })
                Log.d(TAG, "Shipment created tracked: $shipmentId")
            } catch (e: Exception) {
                Log.e(TAG, "Failed to track shipment created", e)
            }
        }
    }
    
    /**
     * Track shipment tracked
     */
    fun trackShipmentTracked(shipmentId: String, userRole: String) {
        if (productionConfig.isProductionMode()) {
            try {
                firebaseAnalytics.logEvent(EVENT_SHIPMENT_TRACKED, Bundle().apply {
                    putString(PARAM_SHIPMENT_ID, shipmentId)
                    putString(PARAM_USER_ROLE, userRole)
                    putLong("timestamp", System.currentTimeMillis())
                })
                Log.d(TAG, "Shipment tracked: $shipmentId")
            } catch (e: Exception) {
                Log.e(TAG, "Failed to track shipment tracked", e)
            }
        }
    }
    
    /**
     * Track invoice created
     */
    fun trackInvoiceCreated(invoiceId: String, amount: Double, userRole: String) {
        if (productionConfig.isProductionMode()) {
            try {
                firebaseAnalytics.logEvent(EVENT_INVOICE_CREATED, Bundle().apply {
                    putString(PARAM_INVOICE_ID, invoiceId)
                    putDouble(PARAM_INVOICE_AMOUNT, amount)
                    putString(PARAM_USER_ROLE, userRole)
                    putLong("timestamp", System.currentTimeMillis())
                })
                Log.d(TAG, "Invoice created tracked: $invoiceId")
            } catch (e: Exception) {
                Log.e(TAG, "Failed to track invoice created", e)
            }
        }
    }
    
    /**
     * Track invoice paid
     */
    fun trackInvoicePaid(invoiceId: String, amount: Double, userRole: String) {
        if (productionConfig.isProductionMode()) {
            try {
                firebaseAnalytics.logEvent(EVENT_INVOICE_PAID, Bundle().apply {
                    putString(PARAM_INVOICE_ID, invoiceId)
                    putDouble(PARAM_INVOICE_AMOUNT, amount)
                    putString(PARAM_USER_ROLE, userRole)
                    putLong("timestamp", System.currentTimeMillis())
                })
                Log.d(TAG, "Invoice paid tracked: $invoiceId")
            } catch (e: Exception) {
                Log.e(TAG, "Failed to track invoice paid", e)
            }
        }
    }
    
    /**
     * Track report generated
     */
    fun trackReportGenerated(reportType: String, userRole: String) {
        if (productionConfig.isProductionMode()) {
            try {
                firebaseAnalytics.logEvent(EVENT_REPORT_GENERATED, Bundle().apply {
                    putString(PARAM_REPORT_TYPE, reportType)
                    putString(PARAM_USER_ROLE, userRole)
                    putLong("timestamp", System.currentTimeMillis())
                })
                Log.d(TAG, "Report generated tracked: $reportType")
            } catch (e: Exception) {
                Log.e(TAG, "Failed to track report generated", e)
            }
        }
    }
    
    /**
     * Track search performed
     */
    fun trackSearchPerformed(query: String, resultCount: Int, userRole: String) {
        if (productionConfig.isProductionMode()) {
            try {
                firebaseAnalytics.logEvent(EVENT_SEARCH_PERFORMED, Bundle().apply {
                    putString(PARAM_SEARCH_QUERY, query)
                    putInt(PARAM_SEARCH_RESULTS, resultCount)
                    putString(PARAM_USER_ROLE, userRole)
                    putLong("timestamp", System.currentTimeMillis())
                })
                Log.d(TAG, "Search performed tracked: $query")
            } catch (e: Exception) {
                Log.e(TAG, "Failed to track search performed", e)
            }
        }
    }
    
    /**
     * Track notification received
     */
    fun trackNotificationReceived(notificationType: String, userRole: String) {
        if (productionConfig.isProductionMode()) {
            try {
                firebaseAnalytics.logEvent(EVENT_NOTIFICATION_RECEIVED, Bundle().apply {
                    putString(PARAM_NOTIFICATION_TYPE, notificationType)
                    putString(PARAM_USER_ROLE, userRole)
                    putLong("timestamp", System.currentTimeMillis())
                })
                Log.d(TAG, "Notification received tracked: $notificationType")
            } catch (e: Exception) {
                Log.e(TAG, "Failed to track notification received", e)
            }
        }
    }
    
    /**
     * Track backup created
     */
    fun trackBackupCreated(backupSize: Long, userRole: String) {
        if (productionConfig.isProductionMode()) {
            try {
                firebaseAnalytics.logEvent(EVENT_BACKUP_CREATED, Bundle().apply {
                    putLong("backup_size", backupSize)
                    putString(PARAM_USER_ROLE, userRole)
                    putLong("timestamp", System.currentTimeMillis())
                })
                Log.d(TAG, "Backup created tracked: $backupSize bytes")
            } catch (e: Exception) {
                Log.e(TAG, "Failed to track backup created", e)
            }
        }
    }
    
    /**
     * Track screen view
     */
    fun trackScreenView(screenName: String, userRole: String? = null) {
        if (productionConfig.isProductionMode()) {
            try {
                val params = Bundle().apply {
                    putString(PARAM_SCREEN_NAME, screenName)
                    putLong("timestamp", System.currentTimeMillis())
                }
                
                userRole?.let { putString(PARAM_USER_ROLE, it) }
                
                firebaseAnalytics.logEvent("screen_view", params)
                Log.d(TAG, "Screen view tracked: $screenName")
            } catch (e: Exception) {
                Log.e(TAG, "Failed to track screen view", e)
            }
        }
    }
    
    /**
     * Track custom event
     */
    fun trackCustomEvent(eventName: String, parameters: Map<String, Any> = emptyMap()) {
        if (productionConfig.isProductionMode()) {
            try {
                val params = Bundle().apply {
                    parameters.forEach { (key, value) ->
                        when (value) {
                            is String -> putString(key, value)
                            is Int -> putInt(key, value)
                            is Long -> putLong(key, value)
                            is Double -> putDouble(key, value)
                            is Boolean -> putBoolean(key, value)
                            else -> putString(key, value.toString())
                        }
                    }
                    putLong("timestamp", System.currentTimeMillis())
                }
                
                firebaseAnalytics.logEvent(eventName, params)
                Log.d(TAG, "Custom event tracked: $eventName")
            } catch (e: Exception) {
                Log.e(TAG, "Failed to track custom event", e)
            }
        }
    }
    
    /**
     * Track error event
     */
    fun trackError(errorType: String, errorMessage: String, userRole: String? = null) {
        if (productionConfig.isProductionMode()) {
            try {
                firebaseAnalytics.logEvent("app_error", Bundle().apply {
                    putString(PARAM_ERROR_TYPE, errorType)
                    putString("error_message", errorMessage)
                    putLong("timestamp", System.currentTimeMillis())
                })
                
                userRole?.let { putString(PARAM_USER_ROLE, it) }
                
                Log.d(TAG, "Error tracked: $errorType")
            } catch (e: Exception) {
                Log.e(TAG, "Failed to track error", e)
            }
        }
    }
    
    /**
     * Get device category
     */
    private fun getDeviceCategory(): String {
        return when {
            android.os.Build.MODEL.contains("Tablet", ignoreCase = true) -> "Tablet"
            android.os.Build.MODEL.contains("TV", ignoreCase = true) -> "TV"
            else -> "Mobile"
        }
    }
    
    /**
     * Get preferred language
     */
    private fun getPreferredLanguage(): String {
        return try {
            context.resources.configuration.locales[0].language
        } catch (e: Exception) {
            "unknown"
        }
    }
    
    /**
     * Enable/disable analytics
     */
    fun setAnalyticsEnabled(enabled: Boolean) {
        try {
            firebaseAnalytics.setAnalyticsCollectionEnabled(enabled)
            Log.i(TAG, "Analytics ${if (enabled) "enabled" else "disabled"}")
        } catch (e: Exception) {
            Log.e(TAG, "Failed to set analytics enabled", e)
        }
    }
    
    /**
     * Check if analytics is enabled
     */
    fun isAnalyticsEnabled(): Boolean {
        return try {
            firebaseAnalytics.analyticsCollectionEnabled
        } catch (e: Exception) {
            Log.e(TAG, "Failed to check analytics status", e)
            false
        }
    }
    
    /**
     * Set user ID
     */
    fun setUserId(userId: String) {
        if (productionConfig.isProductionMode()) {
            try {
                firebaseAnalytics.setUserId(userId)
                Log.d(TAG, "User ID set: $userId")
            } catch (e: Exception) {
                Log.e(TAG, "Failed to set user ID", e)
            }
        }
    }
    
    /**
     * Clear user ID
     */
    fun clearUserId() {
        if (productionConfig.isProductionMode()) {
            try {
                firebaseAnalytics.setUserId(null)
                Log.d(TAG, "User ID cleared")
            } catch (e: Exception) {
                Log.e(TAG, "Failed to clear user ID", e)
            }
        }
    }
}
