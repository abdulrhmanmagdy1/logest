package com.edham.logistics.data.local.database.dao

import androidx.lifecycle.LiveData
import androidx.paging.PagingSource
import androidx.room.*
import com.edham.logistics.data.local.database.entities.ShipmentEntity
import com.edham.logistics.data.local.database.entities.ShipmentStatus
import kotlinx.coroutines.flow.Flow
import java.util.*

/**
 * Shipment Data Access Object
 * وصول البيانات للشحنات
 */
@Dao
interface ShipmentDao {
    
    /**
     * Basic CRUD Operations
     */
    @Insert(onConflict = OnConflictStrategy.REPLACE)
    suspend fun insertShipment(shipment: ShipmentEntity)
    
    @Insert(onConflict = OnConflictStrategy.REPLACE)
    suspend fun insertShipments(shipments: List<ShipmentEntity>)
    
    @Update
    suspend fun updateShipment(shipment: ShipmentEntity)
    
    @Delete
    suspend fun deleteShipment(shipment: ShipmentEntity)
    
    @Query("DELETE FROM shipments WHERE id = :shipmentId")
    suspend fun deleteShipmentById(shipmentId: String)
    
    /**
     * Get Operations
     */
    @Query("SELECT * FROM shipments WHERE id = :shipmentId")
    suspend fun getShipmentById(shipmentId: String): ShipmentEntity?
    
    @Query("SELECT * FROM shipments WHERE tracking_number = :trackingNumber")
    suspend fun getShipmentByTrackingNumber(trackingNumber: String): ShipmentEntity?
    
    @Query("SELECT * FROM shipments WHERE user_id = :userId ORDER BY created_at DESC")
    fun getUserShipments(userId: String): LiveData<List<ShipmentEntity>>
    
    @Query("SELECT * FROM shipments WHERE user_id = :userId ORDER BY created_at DESC")
    fun getUserShipmentsPagingSource(userId: String): PagingSource<Int, ShipmentEntity>
    
    @Query("SELECT * FROM shipments WHERE driver_id = :driverId ORDER BY created_at DESC")
    fun getDriverShipments(driverId: String): LiveData<List<ShipmentEntity>>
    
    @Query("SELECT * FROM shipments WHERE driver_id = :driverId ORDER BY created_at DESC")
    fun getDriverShipmentsPagingSource(driverId: String): PagingSource<Int, ShipmentEntity>
    
    /**
     * Status-based Queries
     */
    @Query("SELECT * FROM shipments WHERE status = :status ORDER BY created_at DESC")
    fun getShipmentsByStatus(status: String): LiveData<List<ShipmentEntity>>
    
    @Query("SELECT * FROM shipments WHERE user_id = :userId AND status = :status ORDER BY created_at DESC")
    fun getUserShipmentsByStatus(userId: String, status: String): LiveData<List<ShipmentEntity>>
    
    @Query("SELECT * FROM shipments WHERE driver_id = :driverId AND status = :status ORDER BY created_at DESC")
    fun getDriverShipmentsByStatus(driverId: String, status: String): LiveData<List<ShipmentEntity>>
    
    @Query("SELECT * FROM shipments WHERE status IN (:statuses) ORDER BY created_at DESC")
    fun getShipmentsByStatuses(statuses: List<String>): LiveData<List<ShipmentEntity>>
    
    /**
     * Location-based Queries
     */
    @Query("SELECT * FROM shipments WHERE pickup_latitude BETWEEN :minLat AND :maxLat AND pickup_longitude BETWEEN :minLng AND :maxLng ORDER BY created_at DESC")
    fun getShipmentsByPickupLocation(minLat: Double, maxLat: Double, minLng: Double, maxLng: Double): LiveData<List<ShipmentEntity>>
    
    @Query("SELECT * FROM shipments WHERE delivery_latitude BETWEEN :minLat AND :maxLat AND delivery_longitude BETWEEN :minLng AND :maxLng ORDER BY created_at DESC")
    fun getShipmentsByDeliveryLocation(minLat: Double, maxLat: Double, minLng: Double, maxLng: Double): LiveData<List<ShipmentEntity>>
    
    /**
     * Date-based Queries
     */
    @Query("SELECT * FROM shipments WHERE created_at >= :startDate AND created_at <= :endDate ORDER BY created_at DESC")
    fun getShipmentsByDateRange(startDate: Date, endDate: Date): LiveData<List<ShipmentEntity>>
    
    @Query("SELECT * FROM shipments WHERE user_id = :userId AND created_at >= :startDate AND created_at <= :endDate ORDER BY created_at DESC")
    fun getUserShipmentsByDateRange(userId: String, startDate: Date, endDate: Date): LiveData<List<ShipmentEntity>>
    
    @Query("SELECT * FROM shipments WHERE delivery_at >= :startDate AND delivery_at <= :endDate ORDER BY delivery_at DESC")
    fun getDeliveredShipmentsByDateRange(startDate: Date, endDate: Date): LiveData<List<ShipmentEntity>>
    
    /**
     * Temperature-related Queries
     */
    @Query("SELECT * FROM shipments WHERE temperature_required = 1 ORDER BY created_at DESC")
    fun getTemperatureControlledShipments(): LiveData<List<ShipmentEntity>>
    
    @Query("SELECT * FROM shipments WHERE temperature_required = 1 AND current_temperature < :minTemp ORDER BY created_at DESC")
    fun getShipmentsWithLowTemperature(minTemp: Double): LiveData<List<ShipmentEntity>>
    
    @Query("SELECT * FROM shipments WHERE temperature_required = 1 AND current_temperature > :maxTemp ORDER BY created_at DESC")
    fun getShipmentsWithHighTemperature(maxTemp: Double): LiveData<List<ShipmentEntity>>
    
    /**
     * Payment-related Queries
     */
    @Query("SELECT * FROM shipments WHERE paid = 0 ORDER BY created_at DESC")
    fun getUnpaidShipments(): LiveData<List<ShipmentEntity>>
    
    @Query("SELECT * FROM shipments WHERE user_id = :userId AND paid = 0 ORDER BY created_at DESC")
    fun getUserUnpaidShipments(userId: String): LiveData<List<ShipmentEntity>>
    
    @Query("SELECT SUM(cost) FROM shipments WHERE user_id = :userId AND paid = 1")
    suspend fun getUserPaidAmount(userId: String): Double?
    
    @Query("SELECT SUM(cost) FROM shipments WHERE user_id = :userId AND paid = 0")
    suspend fun getUserUnpaidAmount(userId: String): Double?
    
    /**
     * Statistics and Analytics
     */
    @Query("SELECT COUNT(*) FROM shipments WHERE user_id = :userId")
    suspend fun getUserShipmentCount(userId: String): Int
    
    @Query("SELECT COUNT(*) FROM shipments WHERE user_id = :userId AND status = :status")
    suspend fun getUserShipmentCountByStatus(userId: String, status: String): Int
    
    @Query("SELECT COUNT(*) FROM shipments WHERE driver_id = :driverId")
    suspend fun getDriverShipmentCount(driverId: String): Int
    
    @Query("SELECT COUNT(*) FROM shipments WHERE status = :status")
    suspend fun getShipmentCountByStatus(status: String): Int
    
    @Query("SELECT AVG(cost) FROM shipments WHERE user_id = :userId AND paid = 1")
    suspend fun getUserAverageShipmentCost(userId: String): Double?
    
    @Query("SELECT * FROM shipments WHERE created_at >= :startDate GROUP BY DATE(created_at) ORDER BY DATE(created_at) DESC")
    fun getDailyShipmentStats(startDate: Date): LiveData<List<ShipmentEntity>>
    
    /**
     * Search Operations
     */
    @Query("SELECT * FROM shipments WHERE tracking_number LIKE '%' || :query || '%' OR pickup_address LIKE '%' || :query || '%' OR delivery_address LIKE '%' || :query || '%' ORDER BY created_at DESC")
    fun searchShipments(query: String): LiveData<List<ShipmentEntity>>
    
    @Query("SELECT * FROM shipments WHERE user_id = :userId AND (tracking_number LIKE '%' || :query || '%' OR pickup_address LIKE '%' || :query || '%' OR delivery_address LIKE '%' || :query || '%') ORDER BY created_at DESC")
    fun searchUserShipments(userId: String, query: String): LiveData<List<ShipmentEntity>>
    
    @Query("SELECT * FROM shipments WHERE driver_id = :driverId AND (tracking_number LIKE '%' || :query || '%' OR pickup_address LIKE '%' || :query || '%' OR delivery_address LIKE '%' || :query || '%') ORDER BY created_at DESC")
    fun searchDriverShipments(driverId: String, query: String): LiveData<List<ShipmentEntity>>
    
    /**
     * Sync Operations
     */
    @Query("SELECT * FROM shipments WHERE synced = 0 ORDER BY created_at ASC")
    suspend fun getUnsyncedShipments(): List<ShipmentEntity>
    
    @Query("UPDATE shipments SET synced = 1, last_sync_at = :syncTime WHERE id = :shipmentId")
    suspend fun markShipmentAsSynced(shipmentId: String, syncTime: Date)
    
    @Query("UPDATE shipments SET synced = 0 WHERE id = :shipmentId")
    suspend fun markShipmentAsUnsynced(shipmentId: String)
    
    /**
     * Batch Operations
     */
    @Query("DELETE FROM shipments WHERE created_at < :cutoffDate")
    suspend fun deleteOldShipments(cutoffDate: Date)
    
    @Query("UPDATE shipments SET driver_id = :driverId, status = :status WHERE id IN (:shipmentIds)")
    suspend fun assignDriverToShipments(shipmentIds: List<String>, driverId: String, status: String)
    
    @Query("UPDATE shipments SET status = :status WHERE id = :shipmentId")
    suspend fun updateShipmentStatus(shipmentId: String, status: String)
    
    @Query("UPDATE shipments SET current_latitude = :latitude, current_longitude = :longitude, last_updated = :updatedAt WHERE id = :shipmentId")
    suspend fun updateShipmentLocation(shipmentId: String, latitude: Double, longitude: Double, updatedAt: Date)
    
    @Query("UPDATE shipments SET current_temperature = :temperature WHERE id = :shipmentId")
    suspend fun updateShipmentTemperature(shipmentId: String, temperature: Double)
    
    /**
     * Complex Queries
     */
    @Query("""
        SELECT s.*, d.name as driver_name, d.phone as driver_phone 
        FROM shipments s 
        LEFT JOIN drivers d ON s.driver_id = d.id 
        WHERE s.user_id = :userId 
        ORDER BY s.created_at DESC
    """)
    fun getUserShipmentsWithDriverInfo(userId: String): LiveData<List<ShipmentWithDriverInfo>>
    
    @Query("""
        SELECT s.*, u.name as customer_name, u.phone as customer_phone 
        FROM shipments s 
        LEFT JOIN users u ON s.user_id = u.id 
        WHERE s.driver_id = :driverId 
        ORDER BY s.created_at DESC
    """)
    fun getDriverShipmentsWithCustomerInfo(driverId: String): LiveData<List<ShipmentWithCustomerInfo>>
    
    /**
     * Flow-based Reactive Queries
     */
    @Query("SELECT * FROM shipments WHERE user_id = :userId ORDER BY created_at DESC")
    fun getUserShipmentsFlow(userId: String): Flow<List<ShipmentEntity>>
    
    @Query("SELECT * FROM shipments WHERE status = :status ORDER BY created_at DESC")
    fun getShipmentsByStatusFlow(status: String): Flow<List<ShipmentEntity>>
    
    @Query("SELECT * FROM shipments WHERE temperature_required = 1 AND (current_temperature < :minTemp OR current_temperature > :maxTemp)")
    fun getTemperatureAlertShipmentsFlow(minTemp: Double, maxTemp: Double): Flow<List<ShipmentEntity>>
}

/**
 * Data classes for complex queries
 */
data class ShipmentWithDriverInfo(
    val id: String,
    val trackingNumber: String,
    val status: String,
    val driverName: String?,
    val driverPhone: String?,
    // ... other shipment fields
)

data class ShipmentWithCustomerInfo(
    val id: String,
    val trackingNumber: String,
    val status: String,
    val customerName: String?,
    val customerPhone: String?,
    // ... other shipment fields
)
