package com.edham.logistics.ui.security

import android.os.Bundle
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.TextView
import androidx.fragment.app.Fragment
import androidx.recyclerview.widget.LinearLayoutManager
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.adapters.SecurityManagementAdapter
import com.edham.logistics.domain.model.SecuritySetting

class SecurityFragment : Fragment() {

    private lateinit var rvSecuritySettings: RecyclerView
    private lateinit var securityAdapter: SecurityManagementAdapter

    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View? {
        return inflater.inflate(R.layout.fragment_security, container, false)
    }

    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        
        initViews(view)
        setupRecyclerView()
        loadSecurityData()
    }

    private fun initViews(view: View) {
        rvSecuritySettings = view.findViewById(R.id.rvSecuritySettings)
    }

    private fun setupRecyclerView() {
        securityAdapter = SecurityManagementAdapter(getSampleSecuritySettings()) { setting ->
            // Handle security setting change
            // TODO: Implement security setting update
        }
        
        rvSecuritySettings.apply {
            layoutManager = LinearLayoutManager(requireContext())
            adapter = securityAdapter
        }
    }

    private fun loadSecurityData() {
        val securitySettings = getSampleSecuritySettings()
        securityAdapter.updateSecuritySettings(securitySettings)
    }

    private fun getSampleSecuritySettings(): List<SecuritySetting> {
        return listOf(
            SecuritySetting("1", "change_password", "true", "boolean", false, "تحديث كلمة المرور الخاصة بك", "2024-05-12T00:00:00"),
            SecuritySetting("2", "two_factor_auth", "false", "boolean", false, "تفعيل المصادقة الثنائية", "2024-05-12T00:00:00"),
            SecuritySetting("3", "biometric_login", "true", "boolean", false, "تفعيل تسجيل الدخول بالبصمة", "2024-05-12T00:00:00"),
            SecuritySetting("4", "login_history", "enabled", "string", false, "عرض سجل عمليات الدخول", "2024-05-12T00:00:00"),
            SecuritySetting("5", "trusted_devices", "[]", "json", false, "إدارة الأجهزة الموثوقة", "2024-05-12T00:00:00"),
            SecuritySetting("6", "security_notifications", "true", "boolean", false, "إعدادات الإشعارات الأمنية", "2024-05-12T00:00:00"),
            SecuritySetting("7", "backup_enabled", "true", "boolean", false, "إدارة النسخ الاحتياطي للبيانات", "2024-05-12T00:00:00"),
            SecuritySetting("8", "encryption_level", "high", "string", false, "إعدادات تشفير البيانات", "2024-05-12T00:00:00")
        )
    }
}
