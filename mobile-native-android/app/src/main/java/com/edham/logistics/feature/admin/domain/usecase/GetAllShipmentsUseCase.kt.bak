package com.edham.logistics.feature.admin.domain.usecase

import com.edham.logistics.core.utils.Result
import com.edham.logistics.feature.admin.domain.model.AdminShipment
import com.edham.logistics.feature.admin.domain.repository.AdminRepository
import kotlinx.coroutines.flow.Flow
import javax.inject.Inject

class GetAllShipmentsUseCase @Inject constructor(
    private val adminRepository: AdminRepository
) {
    
    suspend operator fun invoke(
        page: Int = 1,
        pageSize: Int = 20,
        status: String? = null,
        search: String? = null
    ): Flow<Result<List<AdminShipment>>> {
        return adminRepository.getAllShipments(page, pageSize, status, search)
    }
}
