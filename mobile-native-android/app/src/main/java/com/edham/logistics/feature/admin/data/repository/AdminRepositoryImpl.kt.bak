    private fun createMockSystemSettings(): List<SystemSettings> {
        return listOf(
            SystemSettings(
                id = "1",
                key = "app_name",
                value = "Edham Logistics",
                description = "Application name",
                category = "General",
                isEditable = true,
                dataType = "string"
            ),
            SystemSettings(
                id = "2",
                key = "max_shipments_per_day",
                value = "100",
                description = "Maximum shipments allowed per day",
                category = "Operations",
                isEditable = true,
                dataType = "number"
            ),
            SystemSettings(
                id = "3",
                key = "enable_notifications",
                value = "true",
                description = "Enable push notifications",
                category = "Notifications",
                isEditable = true,
                dataType = "boolean"
            )
        )
