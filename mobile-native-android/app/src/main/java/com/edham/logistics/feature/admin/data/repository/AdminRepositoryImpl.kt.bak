    private fun createMockActivityLogs(): List<ActivityLog> {
        return listOf(
            ActivityLog(
                id = "1",
                userId = "1",
                userName = "أحمد محمد",
                action = "login",
                resource = "system",
                timestamp = "2024-01-20 09:30:00",
                ipAddress = "192.168.1.100",
                userAgent = "Edham Logistics Android App v1.0.0"
            ),
            ActivityLog(
                id = "2",
