package com.edham.logistics.feature.admin.data.repository

import com.edham.logistics.core.utils.Result
import com.edham.logistics.core.utils.safeCall
import com.edham.logistics.core.network.ApiService
import com.edham.logistics.feature.admin.data.remote.dto.DashboardStatsDto
import com.edham.logistics.feature.admin.data.remote.dto.UserManagementDto
import com.edham.logistics.feature.admin.data.remote.mapper.AdminMapper
import com.edham.logistics.feature.admin.domain.model.DashboardStats
import com.edham.logistics.feature.admin.domain.model.UserManagement
import com.edham.logistics.feature.admin.domain.model.SystemSettings
import com.edham.logistics.feature.admin.domain.model.ActivityLog
import com.edham.logistics.feature.admin.domain.repository.AdminRepository
import kotlinx.coroutines.flow.Flow
import kotlinx.coroutines.flow.flow
import kotlinx.coroutines.flow.map
import javax.inject.Inject
import javax.inject.Singleton

@Singleton
class AdminRepositoryImpl @Inject constructor(
    private val apiService: ApiService,
    private val adminMapper: AdminMapper
) : AdminRepository {

    override suspend fun getDashboardStats(): Result<DashboardStats> {
        return safeCall {
            // In a real app, this would call the API
            // For now, we'll return mock data
            createMockDashboardStats()
        }
    }

    override suspend fun getUsers(page: Int, pageSize: Int): Result<List<UserManagement>> {
        return safeCall {
            // In a real app, this would call the API
            // For now, we'll return mock data
            createMockUsers()
        }
    }

    override suspend fun getUserById(id: String): Result<UserManagement> {
        return safeCall {
            // In a real app, this would call the API
            val users = createMockUsers()
            users.find { it.id == id }
                ?: throw Exception("User not found")
        }
    }

    override suspend fun createUser(user: UserManagement): Result<UserManagement> {
        return safeCall {
            // In a real app, this would call the API
            // For now, we'll just return the user with a generated ID
            user.copy(id = generateId())
        }
    }

    override suspend fun updateUser(user: UserManagement): Result<UserManagement> {
        return safeCall {
            // In a real app, this would call the API
            // For now, we'll just return the user
            user
        }
    }

    override suspend fun deleteUser(id: String): Result<Unit> {
        return safeCall {
            // In a real app, this would call the API
            // For now, we'll just return success
            Unit
        }
    }

    override suspend fun searchUsers(query: String): Result<List<UserManagement>> {
        return safeCall {
            val users = createMockUsers()
            users.filter { user ->
                user.name.contains(query, ignoreCase = true) ||
                user.email.contains(query, ignoreCase = true) ||
                user.phone.contains(query, ignoreCase = true)
            }
        }
    }

    override suspend fun getUsersByRole(role: String): Result<List<UserManagement>> {
        return safeCall {
            val users = createMockUsers()
            users.filter { it.role == role }
        }
    }

    override suspend fun getUsersByStatus(status: String): Result<List<UserManagement>> {
        return safeCall {
            val users = createMockUsers()
            users.filter { it.status == status }
        }
    }

    override suspend fun getSystemSettings(): Result<List<SystemSettings>> {
        return safeCall {
            createMockSystemSettings()
        }
    }

    override suspend fun updateSystemSetting(setting: SystemSettings): Result<SystemSettings> {
        return safeCall {
            // In a real app, this would call the API
            setting
        }
    }

    override suspend fun resetToDefaults(): Result<Unit> {
        return safeCall {
            // In a real app, this would call the API
            Unit
        }
    }

    override suspend fun getActivityLogs(page: Int, pageSize: Int): Result<List<ActivityLog>> {
        return safeCall {
            createMockActivityLogs()
        }
    }

    override suspend fun getActivityLogsByUser(userId: String): Result<List<ActivityLog>> {
        return safeCall {
            val logs = createMockActivityLogs()
            logs.filter { it.userId == userId }
        }
    }

    override suspend fun getActivityLogsByAction(action: String): Result<List<ActivityLog>> {
        return safeCall {
            val logs = createMockActivityLogs()
            logs.filter { it.action == action }
        }
    }

    override fun observeDashboardStats(): Flow<DashboardStats> {
        return flow {
            // In a real app, this would observe real-time changes
            emit(createMockDashboardStats())
        }
    }

    override fun observeUsers(): Flow<List<UserManagement>> {
        return flow {
            // In a real app, this would observe real-time changes
            emit(createMockUsers())
        }
    }

    override fun observeActivityLogs(): Flow<List<ActivityLog>> {
        return flow {
            // In a real app, this would observe real-time changes
            emit(createMockActivityLogs())
        }
    }

    // Mock data methods
    private fun createMockDashboardStats(): DashboardStats {
        return DashboardStats(
            totalShipments = 1250,
            activeShipments = 45,
            completedShipments = 1180,
            cancelledShipments = 25,
            totalDrivers = 85,
            activeDrivers = 42,
            totalVehicles = 65,
            availableVehicles = 23,
            totalRevenue = 2500000.0,
            monthlyRevenue = 450000.0,
            totalCustomers = 320,
            newCustomersThisMonth = 28,
            pendingTasks = 12,
            overdueTasks = 3,
            systemHealth = com.edham.logistics.feature.admin.domain.model.SystemHealth(
                overallHealth = "healthy",
                apiStatus = "online",
                databaseStatus = "online",
                lastBackupTime = "2024-01-15 02:30:00",
                storageUsage = 65.5,
                memoryUsage = 72.3,
                cpuUsage = 45.8
            )
        )
    }

