package com.edham.logistics.ui.notifications

import android.os.Bundle
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.TextView
import androidx.fragment.app.Fragment
import androidx.recyclerview.widget.LinearLayoutManager
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.adapters.NotificationManagementAdapter
import com.edham.logistics.domain.model.Notification

class NotificationCenterFragment : Fragment() {

    private lateinit var rvNotifications: RecyclerView
    private lateinit var tvTotalNotifications: TextView
    private lateinit var tvUnreadNotifications: TextView
    private lateinit var notificationAdapter: NotificationManagementAdapter

    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View? {
        return inflater.inflate(R.layout.fragment_notification_center, container, false)
    }

    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        
        initViews(view)
        setupRecyclerView()
        loadNotificationData()
    }

    private fun initViews(view: View) {
        rvNotifications = view.findViewById(R.id.rv_notifications)
        tvTotalNotifications = view.findViewById(R.id.tv_total_notifications)
        tvUnreadNotifications = view.findViewById(R.id.tv_unread_notifications)
    }

    private fun setupRecyclerView() {
        notificationAdapter = NotificationManagementAdapter(getSampleNotifications()) { notification ->
            // Handle notification click
            // TODO: Navigate to notification details
        }
        
        rvNotifications.apply {
            layoutManager = LinearLayoutManager(requireContext())
            adapter = notificationAdapter
        }
    }

    private fun loadNotificationData() {
        val notifications = getSampleNotifications()
        val unreadCount = notifications.count { !it.isRead }
        
        tvTotalNotifications.text = notifications.size.toString()
        tvUnreadNotifications.text = unreadCount.toString()
        
        notificationAdapter.updateNotifications(notifications)
    }

    private fun getSampleNotifications(): List<Notification> {
        return listOf(
            Notification("1", "شحنة جديدة", "تم إنشاء شحنة #1234", "info", "user-001", false, emptyMap(), "2024-05-12T14:30:00"),
            Notification("2", "تحديث حالة الشحنة", "شحنة #1235 في طريقها إلى الوجهة", "success", "user-001", true, emptyMap(), "2024-05-12T13:45:00"),
            Notification("3", "تنبيه هام", "درجة حرارة الشحنة #1236 خارج النطاق الآمن", "warning", "user-001", false, emptyMap(), "2024-05-12T12:15:00"),
            Notification("4", "مهمة مكتملة", "تم تسليم شحنة #1237 بنجاح", "success", "user-001", true, emptyMap(), "2024-05-12T11:30:00"),
            Notification("5", "مشكلة فنية", "انقطع الاتصال بالسائق أحمد محمد", "error", "user-001", false, emptyMap(), "2024-05-12T10:20:00"),
            Notification("6", "صيانة مجدولة", "صيانة سيارة #1234 غداً الساعة 9 صباحاً", "info", "user-001", true, emptyMap(), "2024-05-12T09:00:00")
        )
    }
}
