package com.edham.logistics.feature.analytics.domain.repository

import com.edham.logistics.core.utils.Result
import com.edham.logistics.feature.analytics.domain.model.*
import kotlinx.coroutines.flow.Flow

interface AnalyticsRepository {
    
    // Dashboard Data
    suspend fun getAdminDashboardData(userId: String, filters: FilterOptions?): Result<AdminDashboardData>
    suspend fun getCustomerDashboardData(userId: String, filters: FilterOptions?): Result<CustomerDashboardData>
    suspend fun getDriverDashboardData(userId: String, filters: FilterOptions?): Result<DriverDashboardData>
    suspend fun getAccountantDashboardData(userId: String, filters: FilterOptions?): Result<AccountantDashboardData>
    
    // Real-time Updates
    suspend fun observeDashboardUpdates(userId: String, userRole: String): Flow<Result<DashboardData>>
    suspend fun observeMetricUpdates(userId: String, userRole: String): Flow<Result<List<MetricCard>>>
    
    // Analytics Data
    suspend fun getRevenueAnalytics(userId: String, filters: FilterOptions?): Result<RevenueAnalytics>
    suspend fun getPerformanceAnalytics(userId: String, filters: FilterOptions?): Result<PerformanceAnalytics>
    suspend fun getUsageAnalytics(userId: String, filters: FilterOptions?): Result<UsageAnalytics>
    
    // Chart Data
    suspend fun getChartData(userId: String, chartType: ChartType, filters: FilterOptions?): Result<ChartData>
    suspend fun getRevenueChartData(userId: String, period: String): Result<ChartData>
    suspend fun getPerformanceChartData(userId: String, period: String): Result<ChartData>
    suspend fun getUsageChartData(userId: String, period: String): Result<ChartData>
    
    // Reports
    suspend fun generateReport(userId: String, reportType: ReportType, filters: FilterOptions?): Result<Report>
    suspend fun exportReport(reportId: String, format: ExportFormat): Result<String>
    suspend fun scheduleReport(userId: String, reportType: ReportType, schedule: ReportSchedule): Result<String>
    
    // Metrics
    suspend fun getMetrics(userId: String, userRole: String, metricTypes: List<MetricType>): Result<List<MetricCard>>
    suspend fun updateMetric(userId: String, metricType: MetricType, value: Double): Result<Unit>
    
    // Activity Logs
    suspend fun getActivityLogs(userId: String, userRole: String, limit: Int): Result<List<ActivityLog>>
    suspend fun logActivity(activity: ActivityLog): Result<Unit>
    
    // WebSocket/Real-time
    suspend fun connectToAnalyticsWebSocket(): Result<Unit>
    suspend fun disconnectFromAnalyticsWebSocket(): Result<Unit>
    suspend fun observeAnalyticsMessages(): Flow<Result<AnalyticsWebSocketMessage>>
    
    // Caching
    suspend fun refreshDashboardData(userId: String, userRole: String): Result<Unit>
    suspend fun clearCache(userId: String): Result<Unit>
    
    // Filtering and Search
    suspend fun searchAnalyticsData(userId: String, query: String, filters: FilterOptions?): Result<List<Any>>
    suspend fun getFilteredData(userId: String, filters: FilterOptions): Result<Map<String, Any>>
}

enum class ChartType {
    REVENUE_CHART,
    PERFORMANCE_CHART,
    USAGE_CHART,
    SHIPMENT_CHART,
    DELIVERY_CHART,
    COST_CHART
}

enum class ReportType {
    REVENUE_REPORT,
    PERFORMANCE_REPORT,
    USAGE_REPORT,
    SHIPMENT_REPORT,
    FINANCIAL_REPORT,
    CUSTOM_REPORT
}

enum class ExportFormat {
    PDF,
    EXCEL,
    CSV,
    JSON
}

enum class MetricType {
    TOTAL_SHIPMENTS,
    ACTIVE_SHIPMENTS,
    COMPLETED_SHIPMENTS,
    REVENUE,
    EXPENSES,
    PROFIT,
    CUSTOMER_SATISFACTION,
    DRIVER_PERFORMANCE,
    DELIVERY_TIME,
    ON_TIME_RATE,
    FUEL_EFFICIENCY,
    USER_ENGAGEMENT,
    SYSTEM_HEALTH
}

data class Report(
    val id: String,
    val type: ReportType,
    val title: String,
    val description: String,
    val generatedAt: Long,
    val data: Map<String, Any>,
    val metadata: ReportMetadata
)

data class ReportMetadata(
    val userId: String,
    val filters: FilterOptions?,
    val period: String,
    val format: ExportFormat,
    val size: Long
)

data class ReportSchedule(
    val frequency: String, // daily, weekly, monthly
    val time: String, // HH:mm format
    val recipients: List<String>,
    val format: ExportFormat,
    val enabled: Boolean
)
