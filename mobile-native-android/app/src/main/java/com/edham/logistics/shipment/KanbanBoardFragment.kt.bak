package com.edham.logistics.shipment

import android.os.Bundle
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import androidx.fragment.app.Fragment
import androidx.fragment.app.viewModels
import androidx.lifecycle.lifecycleScope
import androidx.navigation.fragment.findNavController
import androidx.recyclerview.widget.LinearLayoutManager
import com.edham.logistics.R
import com.edham.logistics.databinding.FragmentKanbanBoardBinding
import com.edham.logistics.shipment.adapters.KanbanShipmentAdapter
import com.google.android.material.bottomsheet.BottomSheetBehavior
import dagger.hilt.android.AndroidEntryPoint
import kotlinx.coroutines.launch
import javax.inject.Inject

/**
 * Kanban Board Fragment - Interactive shipment management board
 * 
 * Features:
 * - Drag and drop shipments between columns
 * - Real-time updates
 * - Smart filtering and search
 * - Priority indicators
 * - Status tracking
 */
@AndroidEntryPoint
class KanbanBoardFragment : Fragment() {

    private var _binding: FragmentKanbanBoardBinding? = null
    private val binding get() = _binding!!

    @Inject
    lateinit var shipmentManager: ShipmentManager

    @Inject
    lateinit var statusTrackingManager: StatusTrackingManager

    private val viewModel: KanbanBoardViewModel by viewModels()
    private lateinit var createdAdapter: KanbanShipmentAdapter
    private lateinit var assignedAdapter: KanbanShipmentAdapter
    private lateinit var inTransitAdapter: KanbanShipmentAdapter
    private lateinit var deliveredAdapter: KanbanShipmentAdapter

    private lateinit var filterBottomSheetBehavior: BottomSheetBehavior<View>
    private var currentFilters: KanbanFilters = KanbanFilters()

    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View {
        _binding = FragmentKanbanBoardBinding.inflate(inflater, container, false)
        return binding.root
    }

    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        
        setupUI()
        setupAdapters()
        setupObservers()
        setupClickListeners()
        setupDragAndDrop()
        setupFilterBottomSheet()
        
        // Load initial data
        loadShipments()
    }

    override fun onDestroyView() {
        super.onDestroyView()
        _binding = null
    }

    private fun setupUI() {
        // Setup toolbar
        binding.toolbar.apply {
            setNavigationOnClickListener {
                // Open navigation drawer
            }
            
            setOnMenuItemClickListener { item ->
                when (item.itemId) {
                    R.id.action_refresh -> {
                        refreshShipments()
                        true
                    }
                    R.id.action_export -> {
                        exportBoardData()
                        true
                    }
                    R.id.action_settings -> {
                        openBoardSettings()
                        true
                    }
                    else -> false
                }
            }
        }
        
        // Setup search
        setupSearchView()
        
        // Setup filter bottom sheet
        filterBottomSheetBehavior = BottomSheetBehavior.from(binding.filterBottomSheet)
        filterBottomSheetBehavior.state = BottomSheetBehavior.STATE_HIDDEN
    }

    private fun setupAdapters() {
        createdAdapter = KanbanShipmentAdapter { shipment, action ->
            handleShipmentAction(shipment, action)
        }
        
        assignedAdapter = KanbanShipmentAdapter { shipment, action ->
            handleShipmentAction(shipment, action)
        }
        
        inTransitAdapter = KanbanShipmentAdapter { shipment, action ->
            handleShipmentAction(shipment, action)
        }
        
        deliveredAdapter = KanbanShipmentAdapter { shipment, action ->
            handleShipmentAction(shipment, action)
        }
        
        binding.createdRecyclerView.apply {
            layoutManager = LinearLayoutManager(context)
            adapter = createdAdapter
        }
        
        binding.assignedRecyclerView.apply {
            layoutManager = LinearLayoutManager(context)
            adapter = assignedAdapter
        }
        
        binding.inTransitRecyclerView.apply {
            layoutManager = LinearLayoutManager(context)
            adapter = inTransitAdapter
        }
        
        binding.deliveredRecyclerView.apply {
            layoutManager = LinearLayoutManager(context)
            adapter = deliveredAdapter
        }
    }

    private fun setupObservers() {
        // Observe shipment data
        viewLifecycleOwner.lifecycleScope.launch {
            viewModel.createdShipments.collect { shipments ->
                createdAdapter.submitList(shipments)
                binding.createdCount.text = shipments.size.toString()
            }
        }

        viewLifecycleOwner.lifecycleScope.launch {
            viewModel.assignedShipments.collect { shipments ->
                assignedAdapter.submitList(shipments)
                binding.assignedCount.text = shipments.size.toString()
            }
        }

        viewLifecycleOwner.lifecycleScope.launch {
            viewModel.inTransitShipments.collect { shipments ->
                inTransitAdapter.submitList(shipments)
                binding.inTransitCount.text = shipments.size.toString()
            }
        }

        viewLifecycleOwner.lifecycleScope.launch {
            viewModel.deliveredShipments.collect { shipments ->
                deliveredAdapter.submitList(shipments)
                binding.deliveredCount.text = shipments.size.toString()
            }
        }

        // Observe loading state
        viewLifecycleOwner.lifecycleScope.launch {
            viewModel.uiState.collect { state ->
                updateUIState(state)
            }
        }

        // Observe search results
        viewLifecycleOwner.lifecycleScope.launch {
            viewModel.searchResults.collect { results ->
                updateSearchResults(results)
            }
        }
    }

    private fun setupClickListeners() {
        // Add shipment FAB
        binding.fabAddShipment.setOnClickListener {
            navigateToCreateShipment()
        }
        
        // Filter button
        binding.filterButton.setOnClickListener {
            toggleFilterBottomSheet()
        }
        
        // Filter actions
        binding.applyFilters.setOnClickListener {
            applyFilters()
        }
        
        binding.clearFilters.setOnClickListener {
            clearFilters()
        }
    }

    private fun setupDragAndDrop() {
        // Setup drag and drop between columns
        setupColumnDragAndDrop(binding.createdRecyclerView, ShipmentStatus.CREATED)
        setupColumnDragAndDrop(binding.assignedRecyclerView, ShipmentStatus.ASSIGNED)
        setupColumnDragAndDrop(binding.inTransitRecyclerView, ShipmentStatus.IN_TRANSIT)
        setupColumnDragAndDrop(binding.deliveredRecyclerView, ShipmentStatus.DELIVERED)
    }

    private fun setupFilterBottomSheet() {
        // Setup priority chips
        binding.priorityChipGroup.setOnCheckedChangeListener { group, checkedId ->
            // Handle priority filter changes
        }
        
        // Setup date pickers
        setupDatePickers()
    }

    private fun setupSearchView() {
        binding.searchEditText.setOnFocusChangeListener { _, hasFocus ->
            if (hasFocus) {
                binding.clearSearch.visibility = View.VISIBLE
            } else {
                if (binding.searchEditText.text.isBlank()) {
                    binding.clearSearch.visibility = View.GONE
                }
            }
        }
        
        binding.searchEditText.setOnTextChanged { text ->
            val query = text.toString()
            binding.clearSearch.visibility = if (query.isNotBlank()) View.VISIBLE else View.GONE
            viewModel.searchShipments(query)
        }
        
        binding.clearSearch.setOnClickListener {
            binding.searchEditText.text.clear()
        }
    }

    private fun setupDatePickers() {
        // Setup date picker dialogs
        binding.dateFrom.setOnClickListener {
            showDatePicker(binding.dateFrom)
        }
        
        binding.dateTo.setOnClickListener {
            showDatePicker(binding.dateTo)
        }
    }

    private fun loadShipments() {
        viewModel.loadShipments(currentFilters)
    }

    private fun refreshShipments() {
        viewModel.refreshShipments(currentFilters)
    }

    private fun handleShipmentAction(shipment: ShipmentItem, action: ShipmentAction) {
        when (action) {
            ShipmentAction.VIEW_DETAILS -> {
                navigateToShipmentDetails(shipment.id)
            }
            ShipmentAction.EDIT -> {
                navigateToEditShipment(shipment.id)
            }
            ShipmentAction.ASSIGN_DRIVER -> {
                navigateToAssignDriver(shipment.id)
            }
            ShipmentAction.TRACK -> {
                navigateToTrackShipment(shipment.id)
            }
            ShipmentAction.CALL_DRIVER -> {
                callDriver(shipment.driverPhone)
            }
            ShipmentAction.VIEW_TIMELINE -> {
                navigateToShipmentTimeline(shipment.id)
            }
            ShipmentAction.SCAN_BARCODE -> {
                scanShipmentBarcode(shipment.id)
            }
            ShipmentAction.CONFIRM_DELIVERY -> {
                navigateToDeliveryConfirmation(shipment.id)
            }
        }
    }

    private fun setupColumnDragAndDrop(recyclerView: androidx.recyclerview.widget.RecyclerView, targetStatus: ShipmentStatus) {
        // Setup drag and drop functionality
        // This would use ItemTouchHelper for drag and drop between columns
    }

    private fun toggleFilterBottomSheet() {
        if (filterBottomSheetBehavior.state == BottomSheetBehavior.STATE_HIDDEN) {
            filterBottomSheetBehavior.state = BottomSheetBehavior.STATE_EXPANDED
        } else {
            filterBottomSheetBehavior.state = BottomSheetBehavior.STATE_HIDDEN
        }
    }

    private fun applyFilters() {
        // Collect filter values
        val selectedPriorities = binding.priorityChipGroup.checkedChipIds.mapNotNull { chipId ->
            when (chipId) {
                R.id.chip_critical -> Priority.CRITICAL
                R.id.chip_high -> Priority.HIGH
                R.id.chip_normal -> Priority.NORMAL
                R.id.chip_low -> Priority.LOW
                else -> null
            }
        }.toSet()
        
        val dateFrom = binding.dateFrom.text.toString()
        val dateTo = binding.dateTo.text.toString()
        
        currentFilters = KanbanFilters(
            priorities = selectedPriorities,
            dateFrom = dateFrom,
            dateTo = dateTo
        )
        
        // Apply filters
        viewModel.applyFilters(currentFilters)
        
        // Hide bottom sheet
        filterBottomSheetBehavior.state = BottomSheetBehavior.STATE_HIDDEN
    }

    private fun clearFilters() {
        // Clear all filters
        binding.priorityChipGroup.clearCheck()
        binding.dateFrom.text.clear()
        binding.dateTo.text.clear()
        
        currentFilters = KanbanFilters()
        viewModel.clearFilters()
        
        // Hide bottom sheet
        filterBottomSheetBehavior.state = BottomSheetBehavior.STATE_HIDDEN
    }

    private fun updateUIState(state: KanbanUIState) {
        when (state) {
            is KanbanUIState.Loading -> {
                // Show loading indicators
            }
            is KanbanUIState.Content -> {
                // Hide loading indicators
            }
            is KanbanUIState.Error -> {
                // Show error message
            }
        }
    }

    private fun updateSearchResults(results: List<ShipmentItem>) {
        // Update all adapters with search results
        val created = results.filter { it.status == ShipmentStatus.CREATED }
        val assigned = results.filter { it.status == ShipmentStatus.ASSIGNED }
        val inTransit = results.filter { it.status == ShipmentStatus.IN_TRANSIT }
        val delivered = results.filter { it.status == ShipmentStatus.DELIVERED }
        
        createdAdapter.submitList(created)
        assignedAdapter.submitList(assigned)
        inTransitAdapter.submitList(inTransit)
        deliveredAdapter.submitList(delivered)
    }

    private fun showDatePicker(textField: com.google.android.material.textfield.TextInputEditText) {
        // Show date picker dialog
    }

    private fun navigateToCreateShipment() {
        val bundle = Bundle()
        findNavController().navigate(R.id.createShipmentFragment, bundle)
    }

    private fun navigateToShipmentDetails(shipmentId: Long) {
        val bundle = Bundle().apply {
            putLong("shipmentId", shipmentId)
        }
        findNavController().navigate(R.id.shipmentDetailFragment, bundle)
    }

    private fun navigateToEditShipment(shipmentId: Long) {
        val bundle = Bundle().apply {
            putLong("shipmentId", shipmentId)
        }
        findNavController().navigate(R.id.createShipmentFragment, bundle)
    }

    private fun navigateToAssignDriver(shipmentId: Long) {
        val bundle = Bundle().apply {
            putLong("shipmentId", shipmentId)
        }
        findNavController().navigate(R.id.driversFragment, bundle)
    }

    private fun navigateToTrackShipment(shipmentId: Long) {
        val bundle = Bundle().apply {
            putLong("shipmentId", shipmentId)
        }
        findNavController().navigate(R.id.trackingFragment, bundle)
    }

    private fun navigateToShipmentTimeline(shipmentId: Long) {
        val bundle = Bundle().apply {
            putLong("shipmentId", shipmentId)
        }
        findNavController().navigate(R.id.shipmentDetailFragment, bundle)
    }

    private fun navigateToDeliveryConfirmation(shipmentId: Long) {
        val bundle = Bundle().apply {
            putLong("shipmentId", shipmentId)
        }
        findNavController().navigate(R.id.shipmentDetailFragment, bundle)
    }

    private fun callDriver(phoneNumber: String?) {
        // Implement phone call functionality
    }

    private fun scanShipmentBarcode(shipmentId: Long) {
        // Implement barcode scanning
    }

    private fun exportBoardData() {
        // Export board data to CSV/Excel
    }

    private fun openBoardSettings() {
        // Open board settings
    }

    companion object {
        private const val TAG = "KanbanBoardFragment"
    }
}

/**
 * Data classes
 */
data class ShipmentItem(
    val id: Long,
    val shipmentId: String,
    val customerName: String,
    val route: String,
    val packageInfo: String,
    val priority: Priority,
    val status: ShipmentStatus,
    val driverName: String?,
    val driverPhone: String?,
    val isColdChain: Boolean,
    val isMultiStop: Boolean,
    val stopCount: Int,
    val isDelayed: Boolean,
    val progress: Int,
    val eta: String?,
    val timeInfo: String,
    val createdTime: Date
)

data class KanbanFilters(
    val priorities: Set<Priority> = emptySet(),
    val dateFrom: String = "",
    val dateTo: String = "",
    val searchQuery: String = ""
)

/**
 * Enums
 */
enum class ShipmentAction {
    VIEW_DETAILS,
    EDIT,
    ASSIGN_DRIVER,
    TRACK,
    CALL_DRIVER,
    VIEW_TIMELINE,
    SCAN_BARCODE,
    CONFIRM_DELIVERY
}

/**
 * UI States
 */
sealed class KanbanUIState {
    object Loading : KanbanUIState()
    object Content : KanbanUIState()
    data class Error(val message: String) : KanbanUIState()
}
