package com.edham.logistics.feature.telematics

import android.os.Bundle
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.*
import androidx.fragment.app.Fragment
import androidx.lifecycle.lifecycleScope
import androidx.recyclerview.widget.LinearLayoutManager
import androidx.recyclerview.widget.RecyclerView
import com.github.mikephil.charting.charts.BarChart
import com.github.mikephil.charting.charts.LineChart
import com.github.mikephil.charting.charts.PieChart
import com.github.mikephil.charting.data.*
import kotlinx.coroutines.launch
import java.time.LocalDateTime
import java.time.format.DateTimeFormatter

/**
 * Driver Score Dashboard - Comprehensive driver behavior scoring and analytics
 * Displays driver scores, safety metrics, efficiency indicators, and coaching insights
 */
class DriverScoreDashboard : Fragment() {
    
    private lateinit var overallScoreCard: View
    private lateinit var safetyScoreCard: View
    private lateinit var efficiencyScoreCard: View
    private lateinit var complianceScoreCard: View
    private lateinit var performanceScoreCard: View
    
    private lateinit var overallScoreValue: TextView
    private lateinit var safetyScoreValue: TextView
    private lateinit var efficiencyScoreValue: TextView
    private lateinit var complianceScoreValue: TextView
    private lateinit var performanceScoreValue: TextView
    
    private lateinit var scoreTrendChart: LineChart
    private lateinit var scoreDistributionChart: PieChart
    private lateinit var weeklyPerformanceChart: BarChart
    
    private lateinit var coachingInsightsRecyclerView: RecyclerView
    private lateinit var behaviorIndicatorsRecyclerView: RecyclerView
    private lateinit var driverRankingRecyclerView: RecyclerView
    
    private lateinit var timeFilterSpinner: Spinner
    private lateinit var refreshButton: ImageButton
    
    private val coachingInsightsAdapter = CoachingInsightsAdapter()
    private val behaviorIndicatorsAdapter = BehaviorIndicatorsAdapter()
    private val driverRankingAdapter = DriverRankingAdapter()
    
    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View? {
        return inflater.inflate(R.layout.fragment_driver_score_dashboard, container, false)
    }
    
    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        initializeViews(view)
        setupCharts()
        setupRecyclerViews()
        setupListeners()
        loadDriverScoreData()
    }
    
    private fun initializeViews(view: View) {
        // Score cards
        overallScoreCard = view.findViewById(R.id.overallScoreCard)
        safetyScoreCard = view.findViewById(R.id.safetyScoreCard)
        efficiencyScoreCard = view.findViewById(R.id.efficiencyScoreCard)
        complianceScoreCard = view.findViewById(R.id.complianceScoreCard)
        performanceScoreCard = view.findViewById(R.id.performanceScoreCard)
        
        // Score values
        overallScoreValue = view.findViewById(R.id.overallScoreValue)
        safetyScoreValue = view.findViewById(R.id.safetyScoreValue)
        efficiencyScoreValue = view.findViewById(R.id.efficiencyScoreValue)
        complianceScoreValue = view.findViewById(R.id.complianceScoreValue)
        performanceScoreValue = view.findViewById(R.id.performanceScoreValue)
        
        // Charts
        scoreTrendChart = view.findViewById(R.id.scoreTrendChart)
        scoreDistributionChart = view.findViewById(R.id.scoreDistributionChart)
        weeklyPerformanceChart = view.findViewById(R.id.weeklyPerformanceChart)
        
        // RecyclerViews
        coachingInsightsRecyclerView = view.findViewById(R.id.coachingInsightsRecyclerView)
        behaviorIndicatorsRecyclerView = view.findViewById(R.id.behaviorIndicatorsRecyclerView)
        driverRankingRecyclerView = view.findViewById(R.id.driverRankingRecyclerView)
        
        // Controls
        timeFilterSpinner = view.findViewById(R.id.timeFilterSpinner)
        refreshButton = view.findViewById(R.id.refreshButton)
        
        setupTimeFilter()
    }
    
    private fun setupCharts() {
        setupScoreTrendChart()
        setupScoreDistributionChart()
        setupWeeklyPerformanceChart()
    }
    
    private fun setupScoreTrendChart() {
        scoreTrendChart.apply {
            description.isEnabled = false
            legend.isEnabled = false
            setTouchEnabled(true)
            setDrawGridBackground(false)
            
            // Configure axes
            axisRight.isEnabled = false
            axisLeft.apply {
                setDrawGridLines(false)
                axisMinimum = 0f
                axisMaximum = 100f
                granularity = 10f
            }
            xAxis.apply {
                setDrawGridLines(false)
                granularity = 1f
            }
        }
    }
    
    private fun setupScoreDistributionChart() {
        scoreDistributionChart.apply {
            description.isEnabled = false
            legend.isEnabled = true
            setUsePercentValues(true)
            setDrawEntryLabels(false)
            setHoleColor(android.graphics.Color.WHITE)
            setHoleRadius(40f)
            setTransparentCircleRadius(45f)
        }
    }
    
    private fun setupWeeklyPerformanceChart() {
        weeklyPerformanceChart.apply {
            description.isEnabled = false
            legend.isEnabled = true
            setTouchEnabled(true)
            setDrawGridBackground(false)
            
            axisRight.isEnabled = false
            axisLeft.apply {
                setDrawGridLines(false)
                axisMinimum = 0f
                axisMaximum = 100f
                granularity = 20f
            }
            xAxis.apply {
                setDrawGridLines(false)
                granularity = 1f
            }
        }
    }
    
    private fun setupRecyclerViews() {
        // Coaching Insights
        coachingInsightsRecyclerView.apply {
            layoutManager = LinearLayoutManager(context)
            adapter = coachingInsightsAdapter
        }
        
        // Behavior Indicators
        behaviorIndicatorsRecyclerView.apply {
            layoutManager = LinearLayoutManager(context, LinearLayoutManager.HORIZONTAL, false)
            adapter = behaviorIndicatorsAdapter
        }
        
        // Driver Ranking
        driverRankingRecyclerView.apply {
            layoutManager = LinearLayoutManager(context)
            adapter = driverRankingAdapter
        }
    }
    
    private fun setupListeners() {
        refreshButton.setOnClickListener {
            loadDriverScoreData()
        }
        
        timeFilterSpinner.onItemSelectedListener = object : AdapterView.OnItemSelectedListener {
            override fun onItemSelected(parent: AdapterView<*>?, view: View?, position: Int, id: Long) {
                loadDriverScoreData()
            }
            
            override fun onNothingSelected(parent: AdapterView<*>?) {}
        }
    }
    
    private fun setupTimeFilter() {
        val timeFilters = arrayOf("Today", "This Week", "This Month", "Last 3 Months", "This Year")
        val adapter = ArrayAdapter(requireContext(), android.R.layout.simple_spinner_item, timeFilters)
        adapter.setDropDownViewResource(android.R.layout.simple_spinner_dropdown_item)
        timeFilterSpinner.adapter = adapter
    }
    
    private fun loadDriverScoreData() {
        lifecycleScope.launch {
            try {
                // Show loading state
                showLoadingState()
                
                // Load driver scores (mock data for now)
                val driverScores = loadDriverScores()
                val scoreTrend = loadScoreTrend()
                val coachingInsights = loadCoachingInsights()
                val behaviorIndicators = loadBehaviorIndicators()
                val driverRanking = loadDriverRanking()
                
                // Update UI
                updateScoreCards(driverScores)
                updateScoreTrendChart(scoreTrend)
                updateScoreDistributionChart(driverScores)
                updateWeeklyPerformanceChart()
                updateCoachingInsights(coachingInsights)
                updateBehaviorIndicators(behaviorIndicators)
                updateDriverRanking(driverRanking)
                
                // Hide loading state
                hideLoadingState()
                
            } catch (e: Exception) {
                showErrorState()
            }
        }
    }
    
    private fun updateScoreCards(scores: DriverScores) {
        overallScoreValue.text = String.format("%.1f", scores.overall)
        safetyScoreValue.text = String.format("%.1f", scores.safety)
        efficiencyScoreValue.text = String.format("%.1f", scores.efficiency)
        complianceScoreValue.text = String.format("%.1f", scores.compliance)
        performanceScoreValue.text = String.format("%.1f", scores.performance)
        
        // Update card colors based on score
        updateScoreCardColor(overallScoreCard, scores.overall)
        updateScoreCardColor(safetyScoreCard, scores.safety)
        updateScoreCardColor(efficiencyScoreCard, scores.efficiency)
        updateScoreCardColor(complianceScoreCard, scores.compliance)
        updateScoreCardColor(performanceScoreCard, scores.performance)
    }
    
    private fun updateScoreCardColor(card: View, score: Double) {
        val backgroundColor = when {
            score >= 90 -> R.color.score_excellent
            score >= 80 -> R.color.score_good
            score >= 70 -> R.color.score_average
            score >= 60 -> R.color.score_below_average
            else -> R.color.score_poor
        }
        
        card.findViewById<View>(R.id.scoreCardBackground)?.setBackgroundColor(
            resources.getColor(backgroundColor, null)
        )
    }
    
    private fun updateScoreTrendChart(trend: List<ScoreTrendPoint>) {
        val entries = trend.map { 
            Entry(it.day.toFloat(), it.score.toFloat()) 
        }.toMutableList()
        
        val dataSet = LineDataSet(entries, "Score Trend").apply {
            color = resources.getColor(R.color.primary_color, null)
            setCircleColor(resources.getColor(R.color.primary_color, null))
            setLineWidth(2f)
            setCircleRadius(4f)
            setDrawCircleHole(true)
            setDrawValues(true)
            setValueTextSize(10f)
            mode = LineDataSet.Mode.CUBIC_BEZIER
            setDrawFilled(true)
            fillColor = resources.getColor(R.color.primary_color_light, null)
        }
        
        val lineData = LineData(dataSet)
        scoreTrendChart.data = lineData
        scoreTrendChart.invalidate()
    }
    
    private fun updateScoreDistributionChart(scores: DriverScores) {
        val entries = listOf(
            PieEntry(scores.safety.toFloat(), "Safety"),
            PieEntry(scores.efficiency.toFloat(), "Efficiency"),
            PieEntry(scores.compliance.toFloat(), "Compliance"),
            PieEntry(scores.performance.toFloat(), "Performance")
        )
        
        val colors = listOf(
            resources.getColor(R.color.safety_color, null),
            resources.getColor(R.color.efficiency_color, null),
            resources.getColor(R.color.compliance_color, null),
            resources.getColor(R.color.performance_color, null)
        )
        
        val dataSet = PieDataSet(entries, "Score Distribution").apply {
            setColors(colors)
            setDrawValues(true)
            setValueTextSize(12f)
            setValueTextColor(android.graphics.Color.WHITE)
        }
        
        val pieData = PieData(dataSet)
        scoreDistributionChart.data = pieData
        scoreDistributionChart.invalidate()
    }
    
    private fun updateWeeklyPerformanceChart() {
        val entries = mutableListOf<BarEntry>()
        val labels = mutableListOf<String>()
        
        // Mock weekly data
        val weeklyData = listOf(85, 88, 82, 90, 87, 92, 89)
        val days = listOf("Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun")
        
        weeklyData.forEachIndexed { index, score ->
            entries.add(BarEntry(index.toFloat(), score.toFloat()))
            labels.add(days[index])
        }
        
        val dataSet = BarDataSet(entries, "Weekly Performance").apply {
            color = resources.getColor(R.color.primary_color, null)
            setDrawValues(true)
            setValueTextSize(10f)
        }
        
        val barData = BarData(dataSet)
        weeklyPerformanceChart.data = barData
        weeklyPerformanceChart.xAxis.valueFormatter = IndexAxisValueFormatter(labels)
        weeklyPerformanceChart.invalidate()
    }
    
    private fun updateCoachingInsights(insights: List<CoachingInsight>) {
        coachingInsightsAdapter.updateInsights(insights)
    }
    
    private fun updateBehaviorIndicators(indicators: List<BehaviorIndicator>) {
        behaviorIndicatorsAdapter.updateIndicators(indicators)
    }
    
    private fun updateDriverRanking(ranking: List<DriverRankingItem>) {
        driverRankingAdapter.updateRanking(ranking)
    }
    
    private fun showLoadingState() {
        // Show loading indicators
        overallScoreValue.text = "..."
        safetyScoreValue.text = "..."
        efficiencyScoreValue.text = "..."
        complianceScoreValue.text = "..."
        performanceScoreValue.text = "..."
        
        refreshButton.isEnabled = false
        refreshButton.alpha = 0.5f
    }
    
    private fun hideLoadingState() {
        refreshButton.isEnabled = true
        refreshButton.alpha = 1.0f
    }
    
    private fun showErrorState() {
        Toast.makeText(context, "Error loading driver scores", Toast.LENGTH_SHORT).show()
        hideLoadingState()
    }
    
    // Data loading methods (mock data for now)
    private fun loadDriverScores(): DriverScores {
        return DriverScores(
            safety = 85.5,
            efficiency = 78.2,
            compliance = 92.1,
            performance = 88.7,
            overall = 86.1,
            lastUpdated = LocalDateTime.now()
        )
    }
    
    private fun loadScoreTrend(): List<ScoreTrendPoint> {
        return listOf(
            ScoreTrendPoint(1, 82.5),
            ScoreTrendPoint(2, 84.1),
            ScoreTrendPoint(3, 83.7),
            ScoreTrendPoint(4, 86.2),
            ScoreTrendPoint(5, 85.9),
            ScoreTrendPoint(6, 87.3),
            ScoreTrendPoint(7, 86.1)
        )
    }
    
    private fun loadCoachingInsights(): List<CoachingInsight> {
        return listOf(
            CoachingInsight(
                category = TelematicsEngine.ScoringCategory.SAFETY,
                priority = CoachingInsight.Priority.HIGH,
                title = "Improve Following Distance",
                description = "Multiple harsh braking events detected. Maintain safe following distance.",
                recommendation = "Keep 3-second following distance and anticipate traffic flow",
                potentialImprovement = 12.0
            ),
            CoachingInsight(
                category = TelematicsEngine.ScoringCategory.EFFICIENCY,
                priority = CoachingInsight.Priority.MEDIUM,
                title = "Reduce Idle Time",
                description = "Excessive idling detected. Turn off engine during long stops.",
                recommendation = "Turn off engine if stopped for more than 30 seconds",
                potentialImprovement = 8.0
            )
        )
    }
    
    private fun loadBehaviorIndicators(): List<BehaviorIndicator> {
        return listOf(
            BehaviorIndicator(
                type = "Harsh Braking",
                value = 3,
                trend = "decreasing",
                status = "good",
                icon = R.drawable.ic_braking
            ),
            BehaviorIndicator(
                type = "Over-speeding",
                value = 1,
                trend = "stable",
                status = "excellent",
                icon = R.drawable.ic_speed
            ),
            BehaviorIndicator(
                type = "Idle Time",
                value = 15,
                trend = "increasing",
                status = "warning",
                icon = R.drawable.ic_idle
            ),
            BehaviorIndicator(
                type = "Fuel Efficiency",
                value = 8.2,
                trend = "stable",
                status = "good",
                icon = R.drawable.ic_fuel
            )
        )
    }
    
    private fun loadDriverRanking(): List<DriverRankingItem> {
        return listOf(
            DriverRankingItem(
                rank = 1,
                driverName = "Ahmed Mohammed",
                overallScore = 92.5,
                safetyScore = 95.0,
                efficiencyScore = 90.0,
                avatar = R.drawable.ic_driver_avatar
            ),
            DriverRankingItem(
                rank = 2,
                driverName = "Sarah Ali",
                overallScore = 89.2,
                safetyScore = 88.0,
                efficiencyScore = 91.0,
                avatar = R.drawable.ic_driver_avatar
            ),
            DriverRankingItem(
                rank = 3,
                driverName = "You",
                overallScore = 86.1,
                safetyScore = 85.5,
                efficiencyScore = 78.2,
                avatar = R.drawable.ic_current_user
            )
        )
    }
}

/**
 * Coaching Insights Adapter
 */
class CoachingInsightsAdapter : RecyclerView.Adapter<CoachingInsightsAdapter.ViewHolder>() {
    
    private var insights = listOf<CoachingInsight>()
    
    fun updateInsights(newInsights: List<CoachingInsight>) {
        insights = newInsights
        notifyDataSetChanged()
    }
    
    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): ViewHolder {
        val view = LayoutInflater.from(parent.context)
            .inflate(R.layout.item_coaching_insight, parent, false)
        return ViewHolder(view)
    }
    
    override fun onBindViewHolder(holder: ViewHolder, position: Int) {
        val insight = insights[position]
        holder.bind(insight)
    }
    
    override fun getItemCount(): Int = insights.size
    
    class ViewHolder(itemView: View) : RecyclerView.ViewHolder(itemView) {
        private val title: TextView = itemView.findViewById(R.id.insightTitle)
        private val description: TextView = itemView.findViewById(R.id.insightDescription)
        private val recommendation: TextView = itemView.findViewById(R.id.insightRecommendation)
        private val priority: TextView = itemView.findViewById(R.id.insightPriority)
        private val improvement: TextView = itemView.findViewById(R.id.potentialImprovement)
        
        fun bind(insight: CoachingInsight) {
            title.text = insight.title
            description.text = insight.description
            recommendation.text = insight.recommendation
            improvement.text = "+${String.format("%.1f", insight.potentialImprovement)}% improvement"
            
            priority.text = insight.priority.name
            priority.setBackgroundColor(getPriorityColor(insight.priority))
        }
        
        private fun getPriorityColor(priority: CoachingInsight.Priority): Int {
            return when (priority) {
                CoachingInsight.Priority.CRITICAL -> android.graphics.Color.parseColor("#FF5252")
                CoachingInsight.Priority.HIGH -> android.graphics.Color.parseColor("#FF9800")
                CoachingInsight.Priority.MEDIUM -> android.graphics.Color.parseColor("#FFC107")
                CoachingInsight.Priority.LOW -> android.graphics.Color.parseColor("#4CAF50")
            }
        }
    }
}

/**
 * Behavior Indicators Adapter
 */
class BehaviorIndicatorsAdapter : RecyclerView.Adapter<BehaviorIndicatorsAdapter.ViewHolder>() {
    
    private var indicators = listOf<BehaviorIndicator>()
    
    fun updateIndicators(newIndicators: List<BehaviorIndicator>) {
        indicators = newIndicators
        notifyDataSetChanged()
    }
    
    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): ViewHolder {
        val view = LayoutInflater.from(parent.context)
            .inflate(R.layout.item_behavior_indicator, parent, false)
        return ViewHolder(view)
    }
    
    override fun onBindViewHolder(holder: ViewHolder, position: Int) {
        val indicator = indicators[position]
        holder.bind(indicator)
    }
    
    override fun getItemCount(): Int = indicators.size
    
    class ViewHolder(itemView: View) : RecyclerView.ViewHolder(itemView) {
        private val type: TextView = itemView.findViewById(R.id.indicatorType)
        private val value: TextView = itemView.findViewById(R.id.indicatorValue)
        private val trend: TextView = itemView.findViewById(R.id.indicatorTrend)
        private val status: TextView = itemView.findViewById(R.id.indicatorStatus)
        private val icon: ImageView = itemView.findViewById(R.id.indicatorIcon)
        
        fun bind(indicator: BehaviorIndicator) {
            type.text = indicator.type
            value.text = indicator.value.toString()
            trend.text = indicator.trend
            status.text = indicator.status
            
            icon.setImageResource(indicator.icon)
            status.setBackgroundColor(getStatusColor(indicator.status))
        }
        
        private fun getStatusColor(status: String): Int {
            return when (status.lowercase()) {
                "excellent", "good" -> android.graphics.Color.parseColor("#4CAF50")
                "warning" -> android.graphics.Color.parseColor("#FFC107")
                "poor" -> android.graphics.Color.parseColor("#FF5252")
                else -> android.graphics.Color.parseColor("#9E9E9E")
            }
        }
    }
}

/**
 * Driver Ranking Adapter
 */
class DriverRankingAdapter : RecyclerView.Adapter<DriverRankingAdapter.ViewHolder>() {
    
    private var ranking = listOf<DriverRankingItem>()
    
    fun updateRanking(newRanking: List<DriverRankingItem>) {
        ranking = newRanking
        notifyDataSetChanged()
    }
    
    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): ViewHolder {
        val view = LayoutInflater.from(parent.context)
            .inflate(R.layout.item_driver_ranking, parent, false)
        return ViewHolder(view)
    }
    
    override fun onBindViewHolder(holder: ViewHolder, position: Int) {
        val driver = ranking[position]
        holder.bind(driver)
    }
    
    override fun getItemCount(): Int = ranking.size
    
    class ViewHolder(itemView: View) : RecyclerView.ViewHolder(itemView) {
        private val rank: TextView = itemView.findViewById(R.id.driverRank)
        private val name: TextView = itemView.findViewById(R.id.driverName)
        private val overallScore: TextView = itemView.findViewById(R.id.overallScore)
        private val safetyScore: TextView = itemView.findViewById(R.id.safetyScore)
        private val efficiencyScore: TextView = itemView.findViewById(R.id.efficiencyScore)
        private val avatar: ImageView = itemView.findViewById(R.id.driverAvatar)
        
        fun bind(driver: DriverRankingItem) {
            rank.text = "#${driver.rank}"
            name.text = driver.driverName
            overallScore.text = String.format("%.1f", driver.overallScore)
            safetyScore.text = String.format("%.1f", driver.safetyScore)
            efficiencyScore.text = String.format("%.1f", driver.efficiencyScore)
            
            avatar.setImageResource(driver.avatar)
            
            // Highlight current user
            if (driver.driverName == "You") {
                itemView.setBackgroundColor(android.graphics.Color.parseColor("#E3F2FD"))
            }
        }
    }
}

/**
 * Data classes for dashboard
 */
data class ScoreTrendPoint(
    val day: Int,
    val score: Double
)

data class BehaviorIndicator(
    val type: String,
    val value: Int,
    val trend: String,
    val status: String,
    val icon: Int
)

data class DriverRankingItem(
    val rank: Int,
    val driverName: String,
    val overallScore: Double,
    val safetyScore: Double,
    val efficiencyScore: Double,
    val avatar: Int
)
