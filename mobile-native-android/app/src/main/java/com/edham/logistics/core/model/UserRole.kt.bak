package com.edham.logistics.core.model

/**
 * Enhanced UserRole enum with comprehensive role definitions
 * Each role includes display name, description, and priority level
 */
enum class UserRole(
    val displayName: String,
    val description: String,
    val priority: Int,
    val permissions: Set<Permission>
) {
    ADMIN(
        displayName = "المدير",
        description = "صلاحيات كاملة على النظام",
        priority = 100,
        permissions = Permission.values().toSet()
    ),
    SUPERVISOR(
        displayName = "المشرف",
        description = "إدارة العمليات اليومية والأسطول",
        priority = 80,
        permissions = setOf(
            Permission.VIEW_DASHBOARD,
            Permission.MANAGE_SHIPMENTS,
            Permission.ASSIGN_DRIVERS,
            Permission.VIEW_FLEET,
            Permission.VIEW_REPORTS,
            Permission.MANAGE_OPERATIONS,
            Permission.VIEW_ANALYTICS,
            Permission.ACCESS_OPERATIONS_ROOM,
            Permission.MANAGE_DISPATCH,
            Permission.VIEW_DRIVER_PERFORMANCE
        )
    ),
    DRIVER(
        displayName = "السائق",
        description = "تنفيذ المهام وتحديث الموقع",
        priority = 60,
        permissions = setOf(
            Permission.VIEW_DASHBOARD,
            Permission.VIEW_TASKS,
            Permission.UPDATE_LOCATION,
            Permission.UPDATE_TASK_STATUS,
            Permission.VIEW_EARNINGS,
            Permission.VIEW_SCHEDULE,
            Permission.UPLOAD_PROOF_OF_DELIVERY,
            Permission.VIEW_OWN_TASKS_ONLY,
            Permission.UPDATE_OWN_TASK_STATUS_ONLY
        )
    ),
    CUSTOMER(
        displayName = "العميل",
        description = "إنشاء وتتبع الشحنات",
        priority = 40,
        permissions = setOf(
            Permission.VIEW_DASHBOARD,
            Permission.CREATE_SHIPMENT,
            Permission.VIEW_OWN_SHIPMENTS,
            Permission.TRACK_SHIPMENT,
            Permission.VIEW_SHIPMENT_HISTORY,
            Permission.MANAGE_PROFILE,
            Permission.VIEW_WALLET,
            Permission.MAKE_PAYMENTS,
            Permission.GET_QUOTES,
            Permission.VIEW_OWN_ORDERS_ONLY
        )
    ),
    ACCOUNTANT(
        displayName = "المحاسب",
        description = "إدارة الشؤون المالية والفواتير",
        priority = 70,
        permissions = setOf(
            Permission.VIEW_DASHBOARD,
            Permission.MANAGE_INVOICES,
            Permission.VIEW_TRANSACTIONS,
            Permission.GENERATE_REPORTS,
            Permission.MANAGE_PAYMENTS,
            Permission.VIEW_TAX_REPORTS,
            Permission.MANAGE_FINANCIAL_RECORDS,
            Permission.EXPORT_FINANCIAL_DATA,
            Permission.APPROVE_PAYMENTS,
            Permission.VIEW_FINANCIAL_ANALYTICS
        )
    ),
    WORKSHOP(
        displayName = "الورشة",
        description = "إدارة صيانة الأسطول والقطع",
        priority = 50,
        permissions = setOf(
            Permission.VIEW_DASHBOARD,
            Permission.MANAGE_MAINTENANCE,
            Permission.VIEW_FLEET_HEALTH,
            Permission.MANAGE_PARTS,
            Permission.VIEW_SCHEDULE,
            Permission.UPDATE_MAINTENANCE_STATUS,
            Permission.MANAGE_WORKSHOP_OPERATIONS,
            Permission.VIEW_VEHICLE_DIAGNOSTICS,
            Permission.MANAGE_INVENTORY,
            Permission.CREATE_MAINTENANCE_REQUESTS
        )
    );

    companion object {
        fun fromRaw(value: String?): UserRole {
            if (value.isNullOrBlank()) return ADMIN
            return entries.firstOrNull { it.name == value.trim().uppercase() } ?: ADMIN
        }
        
        /**
         * Get all roles sorted by priority (highest first)
         */
        fun getAllRolesSorted(): List<UserRole> {
            return entries.sortedByDescending { it.priority }
        }
        
        /**
         * Get roles with specific permission
         */
        fun getRolesWithPermission(permission: Permission): List<UserRole> {
            return entries.filter { it.permissions.contains(permission) }
        }
        
        /**
         * Check if role has higher or equal priority
         */
        fun hasHigherOrEqualPriority(role: UserRole, targetRole: UserRole): Boolean {
            return role.priority >= targetRole.priority
        }
        
        /**
         * Get role hierarchy path
         */
        fun getRoleHierarchy(): List<UserRole> {
            return getAllRolesSorted()
        }
    }
    
    /**
     * Check if this role has specific permission
     */
    fun hasPermission(permission: Permission): Boolean {
        return permissions.contains(permission)
    }
    
    /**
     * Check if this role has any of the specified permissions
     */
    fun hasAnyPermission(vararg permissions: Permission): Boolean {
        return permissions.any { this.permissions.contains(it) }
    }
    
    /**
     * Check if this role has all of the specified permissions
     */
    fun hasAllPermissions(vararg permissions: Permission): Boolean {
        return permissions.all { this.permissions.contains(it) }
    }
    
    /**
     * Get role capabilities as formatted string
     */
    fun getCapabilities(): String {
        return buildString {
            appendLine("🎯 $displayName - $description")
            appendLine("📋 الصلاحيات:")
            permissions.sortedBy { it.displayName }.forEach { permission ->
                appendLine("   • ${permission.displayName}")
            }
        }
    }
}
