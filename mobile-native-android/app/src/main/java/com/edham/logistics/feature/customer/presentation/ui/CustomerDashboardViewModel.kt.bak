package com.edham.logistics.feature.customer.presentation.ui

import androidx.lifecycle.viewModelScope
import com.edham.logistics.core.utils.Result
import com.edham.logistics.feature.customer.domain.usecase.GetCustomerDashboardUseCase
import com.edham.logistics.feature.customer.domain.usecase.CreateShipmentUseCase
import com.edham.logistics.feature.customer.domain.usecase.TrackShipmentUseCase
import com.edham.logistics.feature.customer.domain.model.ShipmentCreationRequest
import com.edham.logistics.feature.customer.domain.model.CustomerShipment
import com.edham.logistics.presentation.ui.base.BaseViewModel
import dagger.hilt.android.lifecycle.HiltViewModel
import kotlinx.coroutines.flow.MutableStateFlow
import kotlinx.coroutines.flow.StateFlow
import kotlinx.coroutines.flow.asStateFlow
import kotlinx.coroutines.launch
import javax.inject.Inject

@HiltViewModel
class CustomerDashboardViewModel @Inject constructor(
    private val getCustomerDashboardUseCase: GetCustomerDashboardUseCase,
    private val createShipmentUseCase: CreateShipmentUseCase,
    private val trackShipmentUseCase: TrackShipmentUseCase
) : BaseViewModel<CustomerDashboardViewModel.CustomerDashboardUiState>() {

    private val _uiState = MutableStateFlow(CustomerDashboardUiState())
    val uiState: StateFlow<CustomerDashboardUiState> = _uiState.asStateFlow()

    override fun createInitialState(): CustomerDashboardUiState = CustomerDashboardUiState()

    init {
        loadDashboardData()
    }

    private fun loadDashboardData() {
        viewModelScope.launch {
            // In a real app, you'd get the current user ID
            val customerId = "customer_123"
            
            when (val result = getCustomerDashboardUseCase(customerId)) {
                is Result.Success -> {
                    updateUiState {
                        copy(
                            isLoading = false,
                            dashboardData = result.data,
                            error = null
                        )
                    }
                }
                is Result.Error -> {
                    updateUiState {
                        copy(
                            isLoading = false,
                            error = result.exception.message
                        )
                    }
                }
                is Result.Loading -> {
                    updateUiState { copy(isLoading = true) }
                }
            }
        }
    }

    fun createShipment(request: ShipmentCreationRequest) {
        viewModelScope.launch {
            updateUiState { copy(isCreatingShipment = true, error = null) }
            
            when (val result = createShipmentUseCase(request)) {
                is Result.Success -> {
                    updateUiState {
                        copy(
                            isCreatingShipment = false,
                            createdShipment = result.data,
                            error = null
                        )
                    }
                    // Refresh dashboard data
                    loadDashboardData()
                }
                is Result.Error -> {
                    updateUiState {
                        copy(
                            isCreatingShipment = false,
                            error = result.exception.message
                        )
                    }
                }
                is Result.Loading -> {
                    updateUiState { copy(isCreatingShipment = true) }
                }
            }
        }
    }

    fun trackShipment(trackingNumber: String) {
        viewModelScope.launch {
            updateUiState { copy(isTracking = true, error = null) }
            
            when (val result = trackShipmentUseCase(trackingNumber)) {
                is Result.Success -> {
                    updateUiState {
                        copy(
                            isTracking = false,
                            trackingData = result.data,
                            error = null
                        )
                    }
                }
                is Result.Error -> {
                    updateUiState {
                        copy(
                            isTracking = false,
                            error = result.exception.message
                        )
                    }
                }
                is Result.Loading -> {
                    updateUiState { copy(isTracking = true) }
                }
            }
        }
    }

    fun refreshDashboard() {
        loadDashboardData()
    }

    fun clearError() {
        updateUiState { copy(error = null) }
    }

    fun onShipmentCreatedHandled() {
        updateUiState { copy(createdShipment = null) }
    }

    fun onTrackingHandled() {
        updateUiState { copy(trackingData = null) }
    }

    data class CustomerDashboardUiState(
        val isLoading: Boolean = false,
        val isCreatingShipment: Boolean = false,
        val isTracking: Boolean = false,
        val dashboardData: com.edham.logistics.feature.customer.domain.model.CustomerDashboardData? = null,
        val createdShipment: CustomerShipment? = null,
        val trackingData: com.edham.logistics.feature.customer.domain.model.ShipmentTrackingData? = null,
        val error: String? = null
    ) : com.edham.logistics.presentation.ui.base.UiState {
        override fun copyLoading(isLoading: Boolean): UiState = copy(isLoading = isLoading)
        override fun copyError(error: String?): UiState = copy(error = error)
        override fun copySuccess(message: String?): UiState = this // Dashboard doesn't use success messages
    }
}
