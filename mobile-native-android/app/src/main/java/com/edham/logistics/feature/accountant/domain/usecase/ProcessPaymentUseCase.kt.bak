package com.edham.logistics.feature.accountant.domain.usecase

import com.edham.logistics.core.utils.Result
import com.edham.logistics.feature.accountant.domain.model.Payment
import com.edham.logistics.feature.accountant.domain.repository.AccountantRepository
import javax.inject.Inject

class ProcessPaymentUseCase @Inject constructor(
    private val accountantRepository: AccountantRepository
) {
    
    suspend operator fun invoke(request: com.edham.logistics.feature.accountant.domain.model.CreatePaymentRequest): Result<Payment> {
        return accountantRepository.recordPayment(request)
    }
}
