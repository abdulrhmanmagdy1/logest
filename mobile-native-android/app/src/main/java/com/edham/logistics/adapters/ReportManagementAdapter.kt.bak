package com.edham.logistics.adapters

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.ImageView
import android.widget.TextView
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.domain.model.Report

class ReportManagementAdapter(
    private var reports: List<Report>,
    private val onReportClick: (Report) -> Unit
) : RecyclerView.Adapter<ReportManagementAdapter.ReportViewHolder>() {

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): ReportViewHolder {
        val view = LayoutInflater.from(parent.context)
            .inflate(R.layout.item_report_management, parent, false)
        return ReportViewHolder(view)
    }

    override fun onBindViewHolder(holder: ReportViewHolder, position: Int) {
        holder.bind(reports[position])
    }

    override fun getItemCount(): Int = reports.size

    fun updateReports(newReports: List<Report>) {
        reports = newReports
        notifyDataSetChanged()
    }

    inner class ReportViewHolder(itemView: View) : RecyclerView.ViewHolder(itemView) {
        private val tvReportTitle: TextView = itemView.findViewById(R.id.tvReportTitle)
        private val tvReportDescription: TextView = itemView.findViewById(R.id.tvReportDescription)
        private val tvStatus: TextView = itemView.findViewById(R.id.tvStatus)
        private val tvDate: TextView = itemView.findViewById(R.id.tvDate)
        private val tvAuthor: TextView = itemView.findViewById(R.id.tvAuthor)
        private val ivReportIcon: ImageView = itemView.findViewById(R.id.ivReportIcon)

        fun bind(report: Report) {
            tvReportTitle.text = report.title
            tvReportDescription.text = report.description
            tvStatus.text = report.status
            tvDate.text = report.date
            tvAuthor.text = report.author

            // Set report icon and color based on status
            when (report.status) {
                "مكتمل" -> {
                    ivReportIcon.setImageResource(R.drawable.ic_check_circle)
                    ivReportIcon.setColorFilter(itemView.context.getColor(R.color.supervisor_success))
                    tvStatus.setTextColor(itemView.context.getColor(R.color.supervisor_success))
                }
                "قيد المعالجة" -> {
                    ivReportIcon.setImageResource(R.drawable.ic_info)
                    ivReportIcon.setColorFilter(itemView.context.getColor(R.color.supervisor_info))
                    tvStatus.setTextColor(itemView.context.getColor(R.color.supervisor_info))
                }
                "معلق" -> {
                    ivReportIcon.setImageResource(R.drawable.ic_warning)
                    ivReportIcon.setColorFilter(itemView.context.getColor(R.color.supervisor_warning))
                    tvStatus.setTextColor(itemView.context.getColor(R.color.supervisor_warning))
                }
                "فشل" -> {
                    ivReportIcon.setImageResource(R.drawable.ic_error)
                    ivReportIcon.setColorFilter(itemView.context.getColor(R.color.supervisor_error))
                    tvStatus.setTextColor(itemView.context.getColor(R.color.supervisor_error))
                }
                else -> {
                    ivReportIcon.setImageResource(R.drawable.ic_info)
                    ivReportIcon.setColorFilter(itemView.context.getColor(R.color.text_secondary))
                    tvStatus.setTextColor(itemView.context.getColor(R.color.text_secondary))
                }
            }

            itemView.setOnClickListener {
                onReportClick(report)
            }
        }
    }
}
