        voiceAlertManager.speak("Opening demand forecasting")
        
        // Navigate to demand forecasting screen
        val demandForecastingFragment = DemandForecastingFragment()
        parentFragmentManager.beginTransaction()
            .replace(R.id.fragment_container, demandForecastingFragment)
            .addToBackStack(null)
            .commit()
    }
    
