package com.edham.logistics.feature.ai.adapters

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.ImageView
import android.widget.TextView
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.feature.ai.SmartNotification
import com.edham.logistics.feature.ai.NotificationType
import com.edham.logistics.feature.ai.NotificationPriority
import java.text.SimpleDateFormat
import java.util.*

class SmartAlertAdapter(
    private val onAlertClick: (SmartNotification) -> Unit
) : RecyclerView.Adapter<SmartAlertAdapter.ViewHolder>() {
    
    private var alerts = mutableListOf<SmartNotification>()
    private val timeFormat = SimpleDateFormat("HH:mm", Locale.getDefault())
    
    fun updateAlerts(newAlerts: List<SmartNotification>) {
        alerts.clear()
        alerts.addAll(newAlerts)
        notifyDataSetChanged()
    }
    
    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): ViewHolder {
        val view = LayoutInflater.from(parent.context).inflate(R.layout.item_smart_alert, parent, false)
        return ViewHolder(view)
    }
    
    override fun onBindViewHolder(holder: ViewHolder, position: Int) {
        holder.bind(alerts[position])
    }
    
    override fun getItemCount(): Int = alerts.size
    
    inner class ViewHolder(itemView: View) : RecyclerView.ViewHolder(itemView) {
        private val alertIcon: ImageView = itemView.findViewById(R.id.alertIcon)
        private val alertType: TextView = itemView.findViewById(R.id.alertType)
        private val alertTitle: TextView = itemView.findViewById(R.id.alertTitle)
        private val alertMessage: TextView = itemView.findViewById(R.id.alertMessage)
        private val alertTime: TextView = itemView.findViewById(R.id.alertTime)
        private val alertPriority: TextView = itemView.findViewById(R.id.alertPriority)
        private val actionRequired: TextView = itemView.findViewById(R.id.actionRequired)
        private val priorityIndicator: View = itemView.findViewById(R.id.priorityIndicator)
        
        fun bind(alert: SmartNotification) {
            // Set alert icon and type based on notification type
            val (iconRes, typeText, colorRes) = when (alert.type) {
                NotificationType.DELAY_RISK -> Triple(R.drawable.ic_delay_alert, "DELAY", R.color.alert_delay)
                NotificationType.ROUTE_OPTIMIZATION -> Triple(R.drawable.ic_route_alert, "ROUTE", R.color.alert_route)
                NotificationType.FUEL_EFFICIENCY -> Triple(R.drawable.ic_fuel_alert, "FUEL", R.color.alert_fuel)
                NotificationType.DRIVER_BEHAVIOR -> Triple(R.drawable.ic_driver_alert, "DRIVER", R.color.alert_driver)
                NotificationType.MAINTENANCE -> Triple(R.drawable.ic_maintenance_alert, "MAINT", R.color.alert_maintenance)
                NotificationType.DEMAND_SPIKE -> Triple(R.drawable.ic_demand_alert, "DEMAND", R.color.alert_demand)
                NotificationType.RISK_ALERT -> Triple(R.drawable.ic_risk_alert, "RISK", R.color.alert_risk)
            }
            
            alertIcon.setImageResource(iconRes)
            alertIcon.setColorFilter(itemView.context.getColor(colorRes))
            alertType.text = typeText
            alertTitle.text = alert.title
            alertMessage.text = alert.message
            alertTime.text = timeFormat.format(Date(alert.timestamp))
            
            // Set priority badge
            val (priorityText, priorityColor) = when (alert.priority) {
                NotificationPriority.CRITICAL -> Triple("CRITICAL", R.color.priority_critical)
                NotificationPriority.HIGH -> Triple("HIGH", R.color.priority_high)
                NotificationPriority.MEDIUM -> Triple("MEDIUM", R.color.priority_medium)
                NotificationPriority.LOW -> Triple("LOW", R.color.priority_low)
            }
            
            alertPriority.text = priorityText
            alertPriority.setTextColor(itemView.context.getColor(priorityColor))
            priorityIndicator.setBackgroundColor(itemView.context.getColor(priorityColor))
            
            // Set action required indicator
            actionRequired.text = if (alert.actionRequired) "Action Required" else "Information"
            actionRequired.setTextColor(
                if (alert.actionRequired) {
                    itemView.context.getColor(R.color.action_required)
                } else {
                    itemView.context.getColor(R.color.action_info)
                }
            )
            
            // Set background color based on priority
            val backgroundColor = when (alert.priority) {
                NotificationPriority.CRITICAL -> itemView.context.getColor(R.color.alert_critical_bg)
                NotificationPriority.HIGH -> itemView.context.getColor(R.color.alert_high_bg)
                NotificationPriority.MEDIUM -> itemView.context.getColor(R.color.alert_medium_bg)
                NotificationPriority.LOW -> itemView.context.getColor(R.color.alert_low_bg)
            }
            
            itemView.setBackgroundColor(backgroundColor)
            
            // Set click listener
            itemView.setOnClickListener {
                onAlertClick(alert)
            }
        }
    }
}
