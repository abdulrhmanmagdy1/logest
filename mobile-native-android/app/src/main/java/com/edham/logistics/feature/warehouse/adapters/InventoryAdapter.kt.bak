package com.edham.logistics.feature.warehouse.adapters

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.ImageView
import android.widget.TextView
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.data.local.entity.InventoryItem
import java.text.SimpleDateFormat
import java.util.*

class InventoryAdapter(
    private val onItemClick: (InventoryItem) -> Unit
) : RecyclerView.Adapter<InventoryAdapter.ViewHolder>() {
    
    private var inventoryItems = mutableListOf<InventoryItem>()
    private val dateFormat = SimpleDateFormat("MMM dd", Locale.getDefault())
    
    fun updateItems(newItems: List<InventoryItem>) {
        inventoryItems.clear()
        inventoryItems.addAll(newItems)
        notifyDataSetChanged()
    }
    
    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): ViewHolder {
        val view = LayoutInflater.from(parent.context).inflate(R.layout.item_inventory, parent, false)
        return ViewHolder(view)
    }
    
    override fun onBindViewHolder(holder: ViewHolder, position: Int) {
        holder.bind(inventoryItems[position])
    }
    
    override fun getItemCount(): Int = inventoryItems.size
    
    inner class ViewHolder(itemView: View) : RecyclerView.ViewHolder(itemView) {
        private val itemName: TextView = itemView.findViewById(R.id.itemName)
        private val itemSku: TextView = itemView.findViewById(R.id.itemSku)
        private val itemQuantity: TextView = itemView.findViewById(R.id.itemQuantity)
        private val itemLocation: TextView = itemView.findViewById(R.id.itemLocation)
        private val itemCategory: TextView = itemView.findViewById(R.id.itemCategory)
        private val itemPrice: TextView = itemView.findViewById(R.id.itemPrice)
        private val stockStatus: TextView = itemView.findViewById(R.id.stockStatus)
        private val stockIndicator: View = itemView.findViewById(R.id.stockIndicator)
        private val itemBarcode: TextView = itemView.findViewById(R.id.itemBarcode)
        private val lastUpdated: TextView = itemView.findViewById(R.id.lastUpdated)
        private val quickActions: View = itemView.findViewById(R.id.quickActions)
        
        fun bind(item: InventoryItem) {
            // Set item information
            itemName.text = item.name
            itemSku.text = "SKU: ${item.sku}"
            itemQuantity.text = "${item.quantity} units"
            itemLocation.text = "Location: ${item.location}"
            itemCategory.text = item.category
            itemPrice.text = String.format("$%.2f", item.unitPrice)
            itemBarcode.text = "Barcode: ${item.barcode}"
            lastUpdated.text = "Updated: ${dateFormat.format(Date(item.lastUpdated))}"
            
            // Set stock status and indicator
            val (statusText, statusColor, indicatorColor) = when {
                item.quantity == 0 -> {
                    Triple("OUT OF STOCK", itemView.context.getColor(R.color.status_error), itemView.context.getColor(R.color.status_error))
                }
                item.quantity <= item.minStockLevel -> {
                    Triple("LOW STOCK", itemView.context.getColor(R.color.status_warning), itemView.context.getColor(R.color.status_warning))
                }
                item.quantity >= item.maxStockLevel -> {
                    Triple("OVERSTOCK", itemView.context.getColor(R.color.status_warning), itemView.context.getColor(R.color.status_warning))
                }
                else -> {
                    Triple("IN STOCK", itemView.context.getColor(R.color.status_completed), itemView.context.getColor(R.color.status_completed))
                }
            }
            
            stockStatus.text = statusText
            stockStatus.setTextColor(statusColor)
            stockIndicator.setBackgroundColor(indicatorColor)
            
            // Set background color based on stock status
            when {
                item.quantity == 0 -> {
                    itemView.setBackgroundColor(itemView.context.getColor(R.color.out_of_stock_bg))
                }
                item.quantity <= item.minStockLevel -> {
                    itemView.setBackgroundColor(itemView.context.getColor(R.color.low_stock_bg))
                }
                else -> {
                    itemView.setBackgroundColor(itemView.context.getColor(R.color.normal_stock_bg))
                }
            }
            
            // Set click listeners
            itemView.setOnClickListener {
                onItemClick(item)
            }
            
            quickActions.setOnClickListener {
                showQuickActions(item)
            }
            
            // Long click for details
            itemView.setOnLongClickListener {
                showItemDetails(item)
                true
            }
        }
        
        private fun showQuickActions(item: InventoryItem) {
            // Show quick actions dialog
            val actions = listOf(
                "View Details",
                "Edit Item",
                "Move Location",
                "Adjust Stock",
                "Scan Barcode",
                "View History"
            )
            
            // Implementation would show actions in a bottom sheet or dialog
        }
        
        private fun showItemDetails(item: InventoryItem) {
            // Show detailed item information
            val details = """
                Item Details
                ===========
                SKU: ${item.sku}
                Name: ${item.name}
                Description: ${item.description}
                Quantity: ${item.quantity}
                Min Stock: ${item.minStockLevel}
                Max Stock: ${item.maxStockLevel}
                Unit Price: $${item.unitPrice}
                Location: ${item.location}
                Zone: ${item.zoneId}
                Shelf: ${item.shelfId}
                Category: ${item.category}
                Supplier: ${item.supplier}
                Barcode: ${item.barcode}
                QR Code: ${item.qrCode}
                Created: ${SimpleDateFormat("yyyy-MM-dd HH:mm", Locale.getDefault()).format(Date(item.createdAt))}
                Last Updated: ${SimpleDateFormat("yyyy-MM-dd HH:mm", Locale.getDefault()).format(Date(item.lastUpdated))}
            """.trimIndent()
            
            // Implementation would show details in a dialog
        }
    }
}
