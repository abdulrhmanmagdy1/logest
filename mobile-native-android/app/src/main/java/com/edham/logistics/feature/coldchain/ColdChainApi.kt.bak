package com.edham.logistics.feature.coldchain

import com.edham.logistics.data.local.entity.TemperatureReading
import com.edham.logistics.data.remote.dto.SensorDto
import retrofit2.Response
import retrofit2.http.*

interface ColdChainApi {
    
    @GET("api/v1/coldchain/sensors")
    suspend fun getAvailableSensors(@Query("shipmentId") shipmentId: String): List<SensorDto>
    
    @POST("api/v1/coldchain/stream")
    suspend fun streamSensorData(
        @Query("shipmentId") shipmentId: String,
        @Body readings: List<TemperatureReading>
    ): Response<Unit>
    
    @POST("api/v1/coldchain/alerts")
    suspend fun sendAlert(@Body alert: ColdChainAlert): Response<Unit>
    
    @PUT("api/v1/coldchain/alerts/{alertId}/acknowledge")
    suspend fun acknowledgeAlert(@Path("alertId") alertId: String): Response<Unit>
    
    @PUT("api/v1/coldchain/alerts/{alertId}/resolve")
    suspend fun resolveAlert(@Path("alertId") alertId: String): Response<Unit>
    
    @GET("api/v1/coldchain/readings")
    suspend fun getHistoricalReadings(
        @Query("shipmentId") shipmentId: String,
        @Query("startDate") startDate: Long,
        @Query("endDate") endDate: Long
    ): List<TemperatureReading>
    
    @GET("api/v1/coldchain/alerts")
    suspend fun getAlerts(
        @Query("shipmentId") shipmentId: String,
        @Query("startDate") startDate: Long?,
        @Query("endDate") endDate: Long?
    ): List<ColdChainAlert>
    
    @POST("api/v1/coldchain/reports")
    suspend fun generateReport(@Body reportRequest: ComplianceReportRequest): Response<ComplianceReport>
}
