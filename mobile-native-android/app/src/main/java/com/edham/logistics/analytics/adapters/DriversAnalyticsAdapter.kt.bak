package com.edham.logistics.analytics.adapters

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.TextView
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.analytics.DriversAnalytics

class DriversAnalyticsAdapter(
    private val drivers: List<DriversAnalytics>
) : RecyclerView.Adapter<DriversAnalyticsAdapter.ViewHolder>() {

    class ViewHolder(view: View) : RecyclerView.ViewHolder(view) {
        val tvTotalDrivers: TextView = view.findViewById(R.id.tv_total_drivers)
        val tvActiveDrivers: TextView = view.findViewById(R.id.tv_active_drivers)
        val tvInactiveDrivers: TextView = view.findViewById(R.id.tv_inactive_drivers)
        val tvOnDuty: TextView = view.findViewById(R.id.tv_on_duty)
    }

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): ViewHolder {
        val view = LayoutInflater.from(parent.context)
            .inflate(R.layout.item_drivers_analytics, parent, false)
        return ViewHolder(view)
    }

    override fun onBindViewHolder(holder: ViewHolder, position: Int) {
        val driver = drivers[position]
        holder.tvTotalDrivers.text = driver.totalDrivers.toString()
        holder.tvActiveDrivers.text = driver.activeDrivers.toString()
        holder.tvInactiveDrivers.text = driver.driversByStatus["inactive"]?.toString() ?: "0"
        holder.tvOnDuty.text = driver.driversByStatus["on_duty"]?.toString() ?: "0"
    }

    override fun getItemCount(): Int = drivers.size
}
