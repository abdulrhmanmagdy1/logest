package com.edham.logistics.presentation.reports.adapter

import android.view.LayoutInflater
import android.view.ViewGroup
import androidx.recyclerview.widget.DiffUtil
import androidx.recyclerview.widget.ListAdapter
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.core.reports.data.ReportHistory
import com.edham.logistics.databinding.ItemReportHistoryBinding
import java.text.SimpleDateFormat
import java.util.*

/**
 * Report History Adapter - RecyclerView adapter for report history
 * Displays list of previously generated reports with click handling
 */
class ReportHistoryAdapter(
    private val onReportClick: (ReportHistory) -> Unit
) : ListAdapter<ReportHistory, ReportHistoryAdapter.ReportHistoryViewHolder>(ReportHistoryDiffCallback()) {

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): ReportHistoryViewHolder {
        val binding = ItemReportHistoryBinding.inflate(
            LayoutInflater.from(parent.context),
            parent,
            false
        )
        return ReportHistoryViewHolder(binding, onReportClick)
    }

    override fun onBindViewHolder(holder: ReportHistoryViewHolder, position: Int) {
        holder.bind(getItem(position))
    }

    class ReportHistoryViewHolder(
        private val binding: ItemReportHistoryBinding,
        private val onReportClick: (ReportHistory) -> Unit
    ) : RecyclerView.ViewHolder(binding.root) {

        private val dateFormat = SimpleDateFormat("MMM dd, yyyy", Locale.getDefault())
        private val timeFormat = SimpleDateFormat("HH:mm", Locale.getDefault())

        fun bind(reportHistory: ReportHistory) {
            binding.apply {
                // Report Title
                textViewReportTitle.text = reportHistory.title

                // Report Type
                textViewReportType.text = when (reportHistory.reportType) {
                    "revenue" -> "Revenue Report"
                    "shipment" -> "Shipment Performance"
                    "driver" -> "Driver Performance"
                    "customer" -> "Customer Behavior"
                    else -> reportHistory.reportType.capitalize()
                }

                // Report Type Icon
                imageViewReportType.setImageResource(
                    when (reportHistory.reportType) {
                        "revenue" -> R.drawable.ic_revenue
                        "shipment" -> R.drawable.ic_shipment
                        "driver" -> R.drawable.ic_driver
                        "customer" -> R.drawable.ic_customer
                        else -> R.drawable.ic_report
                    }
                )

                // Date and Time
                val date = Date(reportHistory.generatedAt)
                textViewReportDate.text = dateFormat.format(date)
                textViewReportTime.text = timeFormat.format(date)

                // Status
                textViewReportStatus.text = when (reportHistory.status) {
                    "completed" -> "Completed"
                    "generating" -> "Generating"
                    "failed" -> "Failed"
                    else -> reportHistory.status
                }

                // Status Color and Icon
                when (reportHistory.status) {
                    "completed" -> {
                        textViewReportStatus.setTextColor(root.context.getColor(R.color.success_color))
                        imageViewReportStatus.setImageResource(R.drawable.ic_check_circle)
                        imageViewReportStatus.imageTintList = root.context.getColorStateList(R.color.success_color)
                    }
                    "generating" -> {
                        textViewReportStatus.setTextColor(root.context.getColor(R.color.warning_color))
                        imageViewReportStatus.setImageResource(R.drawable.ic_refresh)
                        imageViewReportStatus.imageTintList = root.context.getColorStateList(R.color.warning_color)
                    }
                    "failed" -> {
                        textViewReportStatus.setTextColor(root.context.getColor(R.color.error_color))
                        imageViewReportStatus.setImageResource(R.drawable.ic_error)
                        imageViewReportStatus.imageTintList = root.context.getColorStateList(R.color.error_color)
                    }
                    else -> {
                        textViewReportStatus.setTextColor(root.context.getColor(R.color.text_secondary))
                        imageViewReportStatus.setImageResource(R.drawable.ic_info)
                        imageViewReportStatus.imageTintList = root.context.getColorStateList(R.color.text_secondary)
                    }
                }

                // Period
                val startDate = Date(reportHistory.startDate)
                val endDate = Date(reportHistory.endDate)
                val dateRange = if (dateFormat.format(startDate) == dateFormat.format(endDate)) {
                    dateFormat.format(startDate)
                } else {
                    "${dateFormat.format(startDate)} - ${dateFormat.format(endDate)}"
                }
                textViewReportPeriod.text = dateRange

                // File Size (if available)
                if (reportHistory.fileSize != null) {
                    textViewReportSize.text = formatFileSize(reportHistory.fileSize)
                    textViewReportSize.visibility = android.view.View.VISIBLE
                } else {
                    textViewReportSize.visibility = android.view.View.GONE
                }

                // Click Listener
                root.setOnClickListener {
                    onReportClick(reportHistory)
                }
            }
        }

        private fun formatFileSize(bytes: Long): String {
            val kb = bytes / 1024.0
            val mb = kb / 1024.0
            return when {
                mb >= 1 -> "%.1f MB".format(mb)
                kb >= 1 -> "%.1f KB".format(kb)
                else -> "$bytes B"
            }
        }
    }

    class ReportHistoryDiffCallback : DiffUtil.ItemCallback<ReportHistory>() {
        override fun areItemsTheSame(oldItem: ReportHistory, newItem: ReportHistory): Boolean {
            return oldItem.reportId == newItem.reportId
        }

        override fun areContentsTheSame(oldItem: ReportHistory, newItem: ReportHistory): Boolean {
            return oldItem == newItem
        }
    }
}
