package com.edham.logistics.finance.tax

import android.content.Context
import com.edham.logistics.data.local.database.EdhamDatabase
import com.edham.logistics.data.remote.api.TaxApi
import com.edham.logistics.utils.NetworkUtils
import com.edham.logistics.utils.SecurityUtils
import kotlinx.coroutines.Dispatchers
import kotlinx.coroutines.flow.MutableStateFlow
import kotlinx.coroutines.flow.StateFlow
import kotlinx.coroutines.flow.asStateFlow
import kotlinx.coroutines.withContext
import java.util.*
import javax.inject.Inject
import javax.inject.Singleton

/**
 * Tax Calculation Service - Manages tax calculations and compliance
 * 
 * Features:
 * - VAT calculation (15% for Saudi Arabia)
 * - Tax exemption management
 * - Tax reporting and analytics
 * - Tax compliance tracking
 * - Multi-currency tax support
 * - Tax audit trail
 * - Tax optimization recommendations
 */
@Singleton
class TaxCalculationService @Inject constructor(
    private val context: Context,
    private val database: EdhamDatabase,
    private val taxApi: TaxApi,
    private val networkUtils: NetworkUtils,
    private val securityUtils: SecurityUtils
) {
    
    private val _taxCalculationState = MutableStateFlow<TaxCalculationState>(TaxCalculationState.Idle)
    val taxCalculationState: StateFlow<TaxCalculationState> = _taxCalculationState.asStateFlow()
    
    private val _taxCalculations = MutableStateFlow<List<TaxCalculation>>(emptyList())
    val taxCalculations: StateFlow<List<TaxCalculation>> = _taxCalculations.asStateFlow()
    
    private val _taxStats = MutableStateFlow<TaxStats>(TaxStats())
    val taxStats: StateFlow<TaxStats> = _taxStats.asStateFlow()
    
    private var isInitialized = false
    
    companion object {
        private const val TAG = "TaxCalculationService"
        private const val DEFAULT_CURRENCY = "SAR"
        private const val SAUDI_VAT_RATE = 0.15f // 15% VAT
        private const val TAX_REPORTING_PERIOD_MONTHS = 3 // Quarterly reporting
    }
    
    /**
     * Initialize tax calculation service
     */
    suspend fun initialize(): Result<Boolean> {
        return withContext(Dispatchers.IO) {
            try {
                _taxCalculationState.value = TaxCalculationState.Initializing
                
                // Load tax configuration
                loadTaxConfiguration()
                
                // Load tax rates
                loadTaxRates()
                
                // Load recent tax calculations
                loadRecentTaxCalculations()
                
                isInitialized = true
                _taxCalculationState.value = TaxCalculationState.Ready
                Result.success(true)
                
            } catch (e: Exception) {
                _taxCalculationState.value = TaxCalculationState.Error("Failed to initialize tax calculation service: ${e.message}")
                Result.failure(e)
            }
        }
    }
    
    /**
     * Calculate tax for invoice
     */
    suspend fun calculateInvoiceTax(
        invoiceId: String,
        taxableAmount: Float,
        currency: String = DEFAULT_CURRENCY,
        taxExemptions: List<TaxExemption> = emptyList()
    ): Result<TaxCalculation> {
        return withContext(Dispatchers.IO) {
            try {
                if (!isInitialized) {
                    throw Exception("Tax calculation service not initialized")
                }
                
                _taxCalculationState.value = TaxCalculationState.Processing
                
                // Validate inputs
                validateTaxCalculationInputs(taxableAmount, currency)
                
                // Get tax rates for currency
                val taxRates = getTaxRatesForCurrency(currency)
                
                // Calculate tax
                val taxCalculation = calculateTax(
                    invoiceId = invoiceId,
                    taxableAmount = taxableAmount,
                    currency = currency,
                    taxRates = taxRates,
                    taxExemptions = taxExemptions,
                    taxType = TaxType.INVOICE_TAX
                )
                
                // Save tax calculation
                val savedTaxCalculation = database.taxCalculationDao().insertTaxCalculation(taxCalculation.toEntity())
                    .let { id -> taxCalculation.copy(id = id.toString()) }
                
                // Add to tax calculations list
                addToTaxCalculations(savedTaxCalculation)
                
                // Update stats
                updateTaxStats()
                
                _taxCalculationState.value = TaxCalculationState.Ready
                Result.success(savedTaxCalculation)
                
            } catch (e: Exception) {
                _taxCalculationState.value = TaxCalculationState.Error("Tax calculation failed: ${e.message}")
                Result.failure(e)
            }
        }
    }
    
    /**
     * Calculate tax for expense
     */
    suspend fun calculateExpenseTax(
        expenseId: String,
        expenseAmount: Float,
        currency: String = DEFAULT_CURRENCY,
        expenseCategory: String,
        taxExemptions: List<TaxExemption> = emptyList()
    ): Result<TaxCalculation> {
        return withContext(Dispatchers.IO) {
            try {
                if (!isInitialized) {
                    throw Exception("Tax calculation service not initialized")
                }
                
                _taxCalculationState.value = TaxCalculationState.Processing
                
                // Validate inputs
                validateTaxCalculationInputs(expenseAmount, currency)
                
                // Check if expense is tax-deductible
                val isTaxDeductible = isExpenseTaxDeductible(expenseCategory)
                
                // Get tax rates for currency
                val taxRates = getTaxRatesForCurrency(currency)
                
                // Calculate tax
                val taxCalculation = if (isTaxDeductible) {
                    calculateTax(
                        invoiceId = expenseId,
                        taxableAmount = expenseAmount,
                        currency = currency,
                        taxRates = taxRates,
                        taxExemptions = taxExemptions,
                        taxType = TaxType.EXPENSE_TAX
                    )
                } else {
                    createZeroTaxCalculation(
                        invoiceId = expenseId,
                        amount = expenseAmount,
                        currency = currency,
                        taxType = TaxType.EXPENSE_TAX,
                        reason = "Expense category is not tax-deductible"
                    )
                }
                
                // Save tax calculation
                val savedTaxCalculation = database.taxCalculationDao().insertTaxCalculation(taxCalculation.toEntity())
                    .let { id -> taxCalculation.copy(id = id.toString()) }
                
                // Add to tax calculations list
                addToTaxCalculations(savedTaxCalculation)
                
                // Update stats
                updateTaxStats()
                
                _taxCalculationState.value = TaxCalculationState.Ready
                Result.success(savedTaxCalculation)
                
            } catch (e: Exception) {
                _taxCalculationState.value = TaxCalculationState.Error("Expense tax calculation failed: ${e.message}")
                Result.failure(e)
            }
        }
    }
    
    /**
     * Get tax calculation by ID
     */
    suspend fun getTaxCalculation(taxCalculationId: String): TaxCalculation? {
        return withContext(Dispatchers.IO) {
            try {
                // Try cache first
                _taxCalculations.value.find { it.id == taxCalculationId }
                    ?: database.taxCalculationDao().getTaxCalculationById(taxCalculationId.toLong())?.toDomainModel()
            } catch (e: Exception) {
                null
            }
        }
    }
    
    /**
     * Get tax calculation history
     */
    suspend fun getTaxCalculationHistory(
        dateRange: DateRange = DateRange.last30Days(),
        taxType: TaxType? = null
    ): Result<List<TaxCalculation>> {
        return withContext(Dispatchers.IO) {
            try {
                val taxCalculations = database.taxCalculationDao().getTaxCalculationHistory(
                    startDate = dateRange.startDate,
                    endDate = dateRange.endDate,
                    taxType = taxType
                ).map { it.toDomainModel() }
                
                Result.success(taxCalculations)
                
            } catch (e: Exception) {
                Result.failure(e)
            }
        }
    }
    
    /**
     * Generate tax report
     */
    suspend fun generateTaxReport(
        dateRange: DateRange = DateRange.currentQuarter(),
        reportType: TaxReportType = TaxReportType.QUARTERLY
    ): Result<TaxReport> {
        return withContext(Dispatchers.IO) {
            try {
                if (!isInitialized) {
                    throw Exception("Tax calculation service not initialized")
                }
                
                _taxCalculationState.value = TaxCalculationState.Processing
                
                // Get tax calculations for the period
                val taxCalculations = getTaxCalculationHistory(dateRange).getOrThrow()
                
                // Separate by tax type
                val invoiceTaxes = taxCalculations.filter { it.taxType == TaxType.INVOICE_TAX }
                val expenseTaxes = taxCalculations.filter { it.taxType == TaxType.EXPENSE_TAX }
                
                // Calculate totals
                val totalTaxableAmount = taxCalculations.sumOf { it.taxableAmount.toDouble() }.toFloat()
                val totalTaxAmount = taxCalculations.sumOf { it.taxAmount.toDouble() }.toFloat()
                val totalInvoiceTax = invoiceTaxes.sumOf { it.taxAmount.toDouble() }.toFloat()
                val totalExpenseTax = expenseTaxes.sumOf { it.taxAmount.toDouble() }.toFloat()
                
                // Group by currency
                val taxByCurrency = taxCalculations.groupBy { it.currency }
                    .mapValues { (_, calculations) ->
                        TaxByCurrency(
                            currency = calculations.first().currency,
                            taxableAmount = calculations.sumOf { it.taxableAmount.toDouble() }.toFloat(),
                            taxAmount = calculations.sumOf { it.taxAmount.toDouble() }.toFloat(),
                            calculationCount = calculations.size
                        )
                    }
                
                // Generate monthly breakdown
                val monthlyBreakdown = generateMonthlyTaxBreakdown(taxCalculations, dateRange)
                
                // Generate tax recommendations
                val recommendations = generateTaxRecommendations(taxCalculations, dateRange)
                
                val taxReport = TaxReport(
                    id = UUID.randomUUID().toString(),
                    reportType = reportType,
                    period = dateRange,
                    totalTaxableAmount = totalTaxableAmount,
                    totalTaxAmount = totalTaxAmount,
                    totalInvoiceTax = totalInvoiceTax,
                    totalExpenseTax = totalExpenseTax,
                    taxByCurrency = taxByCurrency.values.toList(),
                    monthlyBreakdown = monthlyBreakdown,
                    taxCalculations = taxCalculations,
                    recommendations = recommendations,
                    generatedAt = Date(),
                    currency = DEFAULT_CURRENCY
                )
                
                _taxCalculationState.value = TaxCalculationState.Ready
                Result.success(taxReport)
                
            } catch (e: Exception) {
                _taxCalculationState.value = TaxCalculationState.Error("Tax report generation failed: ${e.message}")
                Result.failure(e)
            }
        }
    }
    
    /**
     * Get tax compliance status
     */
    suspend fun getTaxComplianceStatus(
        dateRange: DateRange = DateRange.currentQuarter()
    ): Result<TaxComplianceStatus> {
        return withContext(Dispatchers.IO) {
            try {
                val taxCalculations = getTaxCalculationHistory(dateRange).getOrThrow()
                
                // Check compliance requirements
                val hasAllRequiredCalculations = checkRequiredTaxCalculations(taxCalculations, dateRange)
                val hasValidTaxRates = validateTaxRates(taxCalculations)
                val hasProperDocumentation = checkTaxDocumentation(taxCalculations)
                val isWithinReportingDeadlines = checkReportingDeadlines(dateRange)
                
                val complianceStatus = TaxComplianceStatus(
                    isCompliant = hasAllRequiredCalculations && hasValidTaxRates && hasProperDocumentation && isWithinReportingDeadlines,
                    hasAllRequiredCalculations = hasAllRequiredCalculations,
                    hasValidTaxRates = hasValidTaxRates,
                    hasProperDocumentation = hasProperDocumentation,
                    isWithinReportingDeadlines = isWithinReportingDeadlines,
                    totalCalculations = taxCalculations.size,
                    missingCalculations = getMissingTaxCalculations(dateRange),
                    invalidCalculations = getInvalidTaxCalculations(taxCalculations),
                    nextReportingDeadline = getNextReportingDeadline(),
                    recommendations = generateComplianceRecommendations(taxCalculations, dateRange)
                )
                
                Result.success(complianceStatus)
                
            } catch (e: Exception) {
                Result.failure(e)
            }
        }
    }
    
    /**
     * Get tax optimization recommendations
     */
    suspend fun getTaxOptimizationRecommendations(
        dateRange: DateRange = DateRange.last12Months()
    ): Result<List<TaxOptimizationRecommendation>> {
        return withContext(Dispatchers.IO) {
            try {
                val taxCalculations = getTaxCalculationHistory(dateRange).getOrThrow()
                
                val recommendations = mutableListOf<TaxOptimizationRecommendation>()
                
                // Analyze expense patterns for tax optimization
                val expenseTaxes = taxCalculations.filter { it.taxType == TaxType.EXPENSE_TAX }
                val expenseByCategory = expenseTaxes.groupBy { it.metadata["category"] ?: "Unknown" }
                
                expenseByCategory.forEach { (category, expenses) ->
                    val totalExpense = expenses.sumOf { it.taxableAmount.toDouble() }.toFloat()
                    val totalTaxPaid = expenses.sumOf { it.taxAmount.toDouble() }.toFloat()
                    val effectiveTaxRate = if (totalExpense > 0) (totalTaxPaid / totalExpense) * 100f else 0f
                    
                    // Check if category could be optimized
                    if (effectiveTaxRate > SAUDI_VAT_RATE * 100 && totalExpense > 10000f) {
                        recommendations.add(
                            TaxOptimizationRecommendation(
                                type = OptimizationType.EXPENSE_CATEGORIZATION,
                                category = category,
                                description = "Consider reviewing expense categorization for $category to optimize tax deductions",
                                potentialSavings = calculatePotentialSavings(totalExpense, effectiveTaxRate),
                                priority = if (totalExpense > 50000f) RecommendationPriority.HIGH else RecommendationPriority.MEDIUM
                            )
                        )
                    }
                }
                
                // Check for tax exemption opportunities
                val taxExemptions = taxCalculations.filter { it.taxExemptions.isNotEmpty() }
                val totalExemptedAmount = taxExemptions.sumOf { it.taxableAmount.toDouble() }.toFloat()
                
                if (totalExemptedAmount < 1000f) {
                    recommendations.add(
                        TaxOptimizationRecommendation(
                            type = OptimizationType.TAX_EXEMPTIONS,
                            category = "General",
                            description = "Consider exploring tax exemption opportunities for qualifying expenses",
                            potentialSavings = 500f, // Estimated
                            priority = RecommendationPriority.LOW
                        )
                    )
                }
                
                Result.success(recommendations)
                
            } catch (e: Exception) {
                Result.failure(e)
            }
        }
    }
    
    /**
     * Helper functions
     */
    private suspend fun loadTaxConfiguration() {
        // Load tax configuration from API or local storage
    }
    
    private suspend fun loadTaxRates() {
