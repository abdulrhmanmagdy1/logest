    private fun createNotificationFromRequest(request: SendNotificationRequest, notificationId: String): Notification {
        return Notification(
            id = notificationId,
            title = request.title,
            message = request.message,
            type = request.type,
            category = request.category,
            priority = request.priority,
            userId = request.userIds.first(), // Simplified for single user
            userRole = UserRole.CUSTOMER, // Default, should be determined from user data
            shipmentId = null,
            driverId = null,
            customerId = null,
            data = request.data,
            imageUrl = request.imageUrl,
            actionUrl = request.actionUrl,
            isRead = false,
            isPush = true,
            timestamp = System.currentTimeMillis(),
            expiresAt = null,
            sound = request.sound ?: "default",
            vibration = request.vibration,
            badge = null,
            deepLink = request.deepLink
        )
    }
