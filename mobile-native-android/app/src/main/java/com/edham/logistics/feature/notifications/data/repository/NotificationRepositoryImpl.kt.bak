import com.edham.logistics.feature.notifications.data.api.NotificationApiService
import com.edham.logistics.feature.notifications.data.database.NotificationDatabase
import com.edham.logistics.feature.notifications.data.service.FirebaseNotificationService
import com.edham.logistics.feature.notifications.data.service.NotificationWebSocketService
import com.edham.logistics.feature.notifications.domain.model.*
