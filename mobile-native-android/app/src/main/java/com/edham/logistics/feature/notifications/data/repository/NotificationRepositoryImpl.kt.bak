    override suspend fun getNotifications(request: GetNotificationsRequest): Result<List<Notification>> {
        return try {
            // Try local database first
            val localNotifications = notificationDatabase.notificationDao()
                .getNotifications(request.userId, request.userRole.name, request.limit, request.offset)
            
            if (localNotifications.isNotEmpty()) {
                Result.Success(localNotifications.map { it.toDomainModel() })
            } else {
                // Fetch from API if not in local database
                val response = notificationApiService.getNotifications(request)
                if (response.isSuccessful) {
                    response.body()?.let { notifications ->
                        // Save to local database
                        notifications.forEach { notification ->
                            notificationDatabase.notificationDao().insertNotification(notification.toEntity())
                        }
                        Result.Success(notifications)
                    } ?: Result.Success(emptyList())
                } else {
                    Result.Error(Exception("Failed to get notifications: ${response.code()}"))
                }
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun observeNotifications(userId: String, userRole: UserRole): Flow<Result<List<Notification>>> {
        return flow {
            try {
                // Emit local data first
                val localNotifications = notificationDatabase.notificationDao()
                    .getNotifications(userId, userRole.name, 50, 0)
                emit(Result.Success(localNotifications.map { it.toDomainModel() }))

                // Listen for WebSocket updates
                notificationWebSocketService.messageFlow.collect { message ->
                    when (message.type) {
                        NotificationWebSocketType.NOTIFICATION_SENT,
                        NotificationWebSocketType.NOTIFICATION_DELIVERED -> {
                            // Refresh notifications
                            val response = notificationApiService.getNotifications(
                                GetNotificationsRequest(
                                    userId = userId,
                                    userRole = userRole,
                                    limit = 50,
                                    offset = 0
                                )
                            )
                            if (response.isSuccessful) {
                                response.body()?.let { notifications ->
                                    emit(Result.Success(notifications))
                                }
                            }
                        }
                        else -> {}
                    }
                }
            } catch (e: Exception) {
                emit(Result.Error(e))
            }
        }
    }

