import kotlinx.coroutines.flow.flow
import kotlinx.coroutines.flow.map
import javax.inject.Inject
import javax.inject.Singleton

@Singleton
class NotificationRepositoryImpl @Inject constructor(
    private val notificationApiService: NotificationApiService,
    private val notificationDatabase: NotificationDatabase,
    private val notificationWebSocketService: NotificationWebSocketService,
    private val firebaseNotificationService: FirebaseNotificationService
) : NotificationRepository {

    override suspend fun sendNotification(request: SendNotificationRequest): Result<String> {
        return try {
            val response = notificationApiService.sendNotification(request)
            if (response.isSuccessful) {
                response.body()?.let { notificationId ->
                    // Save to local database
                    val notification = createNotificationFromRequest(request, notificationId)
                    notificationDatabase.notificationDao().insertNotification(notification.toEntity())
                    Result.Success(notificationId)
                } ?: Result.Error(Exception("Empty response"))
            } else {
                Result.Error(Exception("Failed to send notification: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun sendBulkNotification(request: SendBulkNotificationRequest): Result<List<String>> {
        return try {
            val response = notificationApiService.sendBulkNotification(request)
            if (response.isSuccessful) {
                response.body()?.let { notificationIds ->
                    // Save to local database
                    notificationIds.forEach { notificationId ->
                        val notification = createNotificationFromRequest(request.notification, notificationId)
                        notificationDatabase.notificationDao().insertNotification(notification.toEntity())
                    }
                    Result.Success(notificationIds)
                } ?: Result.Error(Exception("Empty response"))
            } else {
                Result.Error(Exception("Failed to send bulk notifications: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun sendPushNotification(payload: PushNotificationPayload): Result<String> {
        return try {
            val response = notificationApiService.sendPushNotification(payload)
            if (response.isSuccessful) {
                response.body()?.let { messageId ->
                    Result.Success(messageId)
                } ?: Result.Error(Exception("Empty response"))
            } else {
                Result.Error(Exception("Failed to send push notification: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

