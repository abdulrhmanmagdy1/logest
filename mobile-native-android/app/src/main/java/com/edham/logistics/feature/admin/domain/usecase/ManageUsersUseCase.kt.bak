package com.edham.logistics.feature.admin.domain.usecase

import com.edham.logistics.core.utils.Result
import com.edham.logistics.feature.admin.domain.model.UpdateUserRequest
import com.edham.logistics.feature.admin.domain.model.User
import com.edham.logistics.feature.admin.domain.repository.AdminRepository
import kotlinx.coroutines.flow.Flow
import javax.inject.Inject

class ManageUsersUseCase @Inject constructor(
    private val adminRepository: AdminRepository
) {
    
    suspend fun getAllUsers(
        page: Int = 1,
        pageSize: Int = 20,
        role: String? = null,
        search: String? = null
    ): Flow<Result<List<User>>> {
        return adminRepository.getAllUsers(page, pageSize, role, search)
    }
    
    suspend fun updateUser(
        userId: String,
        name: String,
        phone: String,
        email: String,
        isActive: Boolean,
        role: String
    ): Result<User> {
        val request = UpdateUserRequest(
            userId = userId,
            name = name,
            phone = phone,
            email = email,
            isActive = isActive,
            role = role
        )
        return adminRepository.updateUser(request)
    }
    
    suspend fun deactivateUser(userId: String): Result<Unit> {
        return adminRepository.deactivateUser(userId)
    }
    
    suspend fun activateUser(userId: String): Result<Unit> {
        return adminRepository.activateUser(userId)
    }
}
