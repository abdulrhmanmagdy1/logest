package com.edham.logistics.tracking

import android.Manifest
import android.annotation.SuppressLint
import android.app.*
import android.content.Context
import android.content.Intent
import android.content.pm.PackageManager
import android.location.*
import android.os.*
import android.util.Log
import androidx.core.app.ActivityCompat
import androidx.core.app.NotificationCompat
import androidx.core.app.NotificationManagerCompat
import com.google.android.gms.location.*
import kotlinx.coroutines.*
import kotlinx.coroutines.flow.*
import java.util.concurrent.*
import kotlin.math.*

/**
 * Enhanced Location Tracking Service - Optimized GPS tracking with battery efficiency
 */
class EnhancedLocationTrackingService : Service() {
    
    companion object {
        private const val TAG = "EnhancedLocationTracking"
        private const val NOTIFICATION_ID = 1001
        private const val CHANNEL_ID = "location_tracking_channel"
        private const val LOCATION_UPDATE_INTERVAL = 15000L // 15 seconds
        private const val FASTEST_UPDATE_INTERVAL = 10000L // 10 seconds
        private const val ACCURACY_THRESHOLD = 50.0f // 50 meters
        private const val BATTERY_OPTIMIZATION_INTERVAL = 30000L // 30 seconds for battery saving
        private const val GPS_TIMEOUT = 30000L // 30 seconds timeout
        
        // Location smoothing parameters
        private const val SMOOTHING_WINDOW_SIZE = 5
        private const val SMOOTHING_ALPHA = 0.3f
        private const val MIN_MOVEMENT_THRESHOLD = 5.0f // 5 meters minimum movement
        
        // Battery optimization parameters
        private const val LOW_BATTERY_THRESHOLD = 20
        private const val MEDIUM_BATTERY_THRESHOLD = 50
    }
    
    private lateinit var fusedLocationClient: FusedLocationProviderClient
    private lateinit var locationManager: LocationManager
    private lateinit var batteryManager: BatteryManager
    
    private var locationCallback: LocationCallback? = null
    private var locationRequest: LocationRequest? = null
    
    // Location smoothing
    private val locationBuffer = mutableListOf<LocationData>()
    private val smoothedLocationFlow = MutableStateFlow<LocationData?>(null)
    private val rawLocationFlow = MutableStateFlow<LocationData?>(null)
    
    // Battery optimization
    private var currentBatteryLevel = 100
    private var isBatteryOptimizationEnabled = false
    private var adaptiveUpdateInterval = LOCATION_UPDATE_INTERVAL
    
    // GPS loss handling
    private var lastKnownLocation: Location? = null
    private var gpsLossStartTime: Long = 0
    private var isGpsAvailable = true
    private val gpsStatusFlow = MutableStateFlow<GpsStatus>(GpsStatus.AVAILABLE)
    
    // Service management
    private var isTracking = false
    private var trackingScope: CoroutineScope? = null
    private var locationUpdateJob: Job? = null
    private var batteryMonitorJob: Job? = null
    private var gpsMonitorJob: Job? = null
    
    // Location accuracy monitoring
    private var accuracyStats = LocationAccuracyStats()
    private val accuracyFlow = MutableStateFlow<LocationAccuracyStats>(accuracyStats)
    
    override fun onCreate() {
        super.onCreate()
        
        fusedLocationClient = LocationServices.getFusedLocationProviderClient(this)
        locationManager = getSystemService(Context.LOCATION_SERVICE) as LocationManager
        batteryManager = getSystemService(Context.BATTERY_SERVICE) as BatteryManager
        
        createNotificationChannel()
        initializeLocationRequest()
        initializeLocationCallback()
        
        trackingScope = CoroutineScope(Dispatchers.IO + SupervisorJob())
    }
    
    override fun onStartCommand(intent: Intent?, flags: Int, startId: Int): Int {
        when (intent?.action) {
            "START_TRACKING" -> startLocationTracking()
            "STOP_TRACKING" -> stopLocationTracking()
            else -> Log.w(TAG, "Unknown action: ${intent?.action}")
        }
        return START_STICKY
    }
    
    override fun onBind(intent: Intent?): IBinder? = null
    
    private fun createNotificationChannel() {
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            val channel = NotificationChannel(
                CHANNEL_ID,
                "Location Tracking",
                NotificationManager.IMPORTANCE_LOW
            ).apply {
                description = "GPS location tracking for logistics"
                setShowBadge(false)
                enableVibration(false)
                setSound(null, null)
            }
            
            NotificationManagerCompat.from(this).createNotificationChannel(channel)
        }
    }
    
    private fun createNotification(): Notification {
        val intent = Intent(this, EnhancedLocationTrackingService::class.java).apply {
            action = "STOP_TRACKING"
        }
        
        val pendingIntent = PendingIntent.getService(
            this, 0, intent,
            PendingIntent.FLAG_UPDATE_CURRENT or PendingIntent.FLAG_IMMUTABLE
        )
        
        return NotificationCompat.Builder(this, CHANNEL_ID)
            .setContentTitle("GPS Tracking Active")
            .setContentText("Monitoring location for logistics")
            .setSmallIcon(android.R.drawable.ic_menu_mylocation)
            .setOngoing(true)
            .addAction(android.R.drawable.ic_delete, "Stop", pendingIntent)
            .build()
    }
    
    private fun initializeLocationRequest() {
        locationRequest = LocationRequest.Builder(Priority.PRIORITY_HIGH_ACCURACY)
            .setIntervalMillis(adaptiveUpdateInterval)
            .setMinUpdateIntervalMillis(FASTEST_UPDATE_INTERVAL)
            .setMaxUpdateDelayMillis(LOCATION_UPDATE_INTERVAL * 2)
            .setWaitForAccurateLocation(true)
            .setMinUpdateIntervalMillis(FASTEST_UPDATE_INTERVAL)
            .setDurationMillis(TimeUnit.HOURS.toMillis(1))
            .setMaxUpdates(Int.MAX_VALUE)
            .build()
    }
    
    private fun initializeLocationCallback() {
        locationCallback = object : LocationCallback() {
            override fun onLocationResult(result: LocationResult) {
                result.lastLocation?.let { location ->
                    handleNewLocation(location)
                }
            }
            
            override fun onLocationAvailability(availability: LocationAvailability) {
                super.onLocationAvailability(availability)
                handleLocationAvailability(availability.isLocationAvailable)
            }
        }
    }
    
    private fun handleNewLocation(location: Location) {
        // Reset GPS loss timer if we get a location
        if (!isGpsAvailable) {
            isGpsAvailable = true
            gpsLossStartTime = 0
            gpsStatusFlow.value = GpsStatus.AVAILABLE
        }
        
        // Create location data
        val locationData = LocationData(
            latitude = location.latitude,
            longitude = location.longitude,
            accuracy = location.accuracy,
            altitude = location.altitude,
            speed = location.speed,
            bearing = location.bearing,
            timestamp = System.currentTimeMillis(),
            provider = location.provider
        )
        
        // Update accuracy statistics
        updateAccuracyStats(locationData)
        
        // Add to buffer for smoothing
        locationBuffer.add(locationData)
        if (locationBuffer.size > SMOOTHING_WINDOW_SIZE) {
            locationBuffer.removeAt(0)
        }
        
        // Emit raw location
        rawLocationFlow.value = locationData
        
        // Apply smoothing algorithm
        val smoothedLocation = applyLocationSmoothing(locationData)
        smoothedLocationFlow.value = smoothedLocation
        
        // Update last known location
        lastKnownLocation = location
        
        Log.d(TAG, "New location: ${location.latitude}, ${location.longitude}, Accuracy: ${location.accuracy}m")
    }
    
    private fun handleLocationAvailability(isAvailable: Boolean) {
        if (isAvailable != isGpsAvailable) {
            isGpsAvailable = isAvailable
            
            if (!isAvailable) {
                // GPS lost
                gpsLossStartTime = System.currentTimeMillis()
                gpsStatusFlow.value = GpsStatus.LOST
                Log.w(TAG, "GPS signal lost")
                
                // Start GPS recovery
                startGpsRecovery()
            } else {
                // GPS recovered
                gpsLossStartTime = 0
                gpsStatusFlow.value = GpsStatus.AVAILABLE
                Log.i(TAG, "GPS signal recovered")
            }
        }
    }
    
    private fun applyLocationSmoothing(currentLocation: LocationData): LocationData {
        if (locationBuffer.size < 2) {
            return currentLocation
        }
        
        // Kalman-like smoothing
        val smoothedLat = smoothCoordinate(currentLocation.latitude, locationBuffer.map { it.latitude })
        val smoothedLng = smoothCoordinate(currentLocation.longitude, locationBuffer.map { it.longitude })
        
        // Check if movement is significant enough
        if (lastKnownLocation != null) {
            val distance = calculateDistance(
                lastKnownLocation!!.latitude,
                lastKnownLocation!!.longitude,
                smoothedLat,
                smoothedLng
            )
            
            if (distance < MIN_MOVEMENT_THRESHOLD) {
                // Movement too small, use last known location
                return LocationData(
                    latitude = lastKnownLocation!!.latitude,
                    longitude = lastKnownLocation!!.longitude,
                    accuracy = currentLocation.accuracy,
                    altitude = currentLocation.altitude,
                    speed = 0f,
                    bearing = currentLocation.bearing,
                    timestamp = currentLocation.timestamp,
                    provider = currentLocation.provider
                )
            }
        }
        
        return currentLocation.copy(
            latitude = smoothedLat,
            longitude = smoothedLng,
            accuracy = maxOf(currentLocation.accuracy, calculateSmoothedAccuracy())
        )
    }
    
    private fun smoothCoordinate(current: Double, history: List<Double>): Double {
        if (history.size < 2) return current
        
        // Weighted moving average
        var weightedSum = current * SMOOTHING_ALPHA
        var weightSum = SMOOTHING_ALPHA
        
        for (i in history.size - 1 downTo 0) {
            val weight = SMOOTHING_ALPHA * (1 - SMOOTHING_ALPHA).pow(history.size - 1 - i)
            weightedSum += history[i] * weight
            weightSum += weight
        }
        
        return weightedSum / weightSum
    }
    
    private fun calculateSmoothedAccuracy(): Float {
        if (locationBuffer.isEmpty()) return 0f
        
        val accuracies = locationBuffer.map { it.accuracy }
        val weightedSum = accuracies.foldIndexed(0f) { index, acc, accuracy ->
            val weight = (index + 1).toFloat() / accuracies.size
            acc + accuracy * weight
        }
        
        return weightedSum / accuracies.size
    }
    
    private fun calculateDistance(lat1: Double, lng1: Double, lat2: Double, lng2: Double): Float {
        val results = FloatArray(1)
        Location.distanceBetween(lat1, lng1, lat2, lng2, results)
        return results[0]
    }
    
    private fun updateAccuracyStats(locationData: LocationData) {
        accuracyStats.apply {
            totalUpdates++
            
            if (locationData.accuracy <= ACCURACY_THRESHOLD) {
                accurateUpdates++
            }
            
            averageAccuracy = ((averageAccuracy * (totalUpdates - 1)) + locationData.accuracy) / totalUpdates
            bestAccuracy = minOf(bestAccuracy, locationData.accuracy)
            worstAccuracy = maxOf(worstAccuracy, locationData.accuracy)
            
            // Update accuracy percentage
            accuracyPercentage = (accurateUpdates.toFloat() / totalUpdates * 100)
        }
        
        accuracyFlow.value = accuracyStats
    }
    
    private fun startGpsRecovery() {
        trackingScope?.launch {
            delay(5000) // Wait 5 seconds before recovery attempt
            
            if (!isGpsAvailable) {
                Log.i(TAG, "Attempting GPS recovery")
                
                // Try to get last known location
                try {
                    if (ActivityCompat.checkSelfPermission(
                            this@EnhancedLocationTrackingService,
                            Manifest.permission.ACCESS_FINE_LOCATION
                        ) == PackageManager.PERMISSION_GRANTED
                    ) {
                        fusedLocationClient.lastLocation
                            .addOnSuccessListener { location ->
                                if (location != null) {
                                    handleNewLocation(location)
                                    Log.i(TAG, "GPS recovery successful with last known location")
                                } else {
                                    // Try alternative location providers
                                    tryAlternativeProviders()
                                }
                            }
                            .addOnFailureListener { e ->
                                Log.e(TAG, "Failed to get last known location", e)
                                tryAlternativeProviders()
                            }
                    }
                } catch (e: Exception) {
                    Log.e(TAG, "Error during GPS recovery", e)
                }
            }
        }
    }
    
    private fun tryAlternativeProviders() {
        try {
            // Try network provider as fallback
            locationManager.requestLocationUpdates(
                LocationManager.NETWORK_PROVIDER,
                10000L, // 10 seconds
                100f,   // 100 meters
                object : LocationListener {
                    override fun onLocationChanged(location: Location) {
                        handleNewLocation(location)
                        locationManager.removeUpdates(this)
                        Log.i(TAG, "Network provider location received")
                    }
                    
                    @Deprecated("Deprecated in Java")
                    override fun onStatusChanged(provider: String?, status: Int, extras: Bundle?) {}
                    override fun onProviderEnabled(provider: String) {}
                    override fun onProviderDisabled(provider: String) {}
                }
            )
        } catch (e: Exception) {
            Log.e(TAG, "Network provider not available", e)
        }
    }
    
    private fun startLocationTracking() {
        if (isTracking) return
        
        Log.i(TAG, "Starting enhanced location tracking")
        
        startForeground(NOTIFICATION_ID, createNotification())
        isTracking = true
        
        // Check permissions
        if (ActivityCompat.checkSelfPermission(
                this,
                Manifest.permission.ACCESS_FINE_LOCATION
            ) != PackageManager.PERMISSION_GRANTED
        ) {
            Log.e(TAG, "Location permissions not granted")
            stopSelf()
            return
        }
        
        // Start location updates
        try {
            fusedLocationClient.requestLocationUpdates(
                locationRequest!!,
                locationCallback!!,
                Looper.getMainLooper()
            )
            
            // Start background jobs
            startBackgroundJobs()
            
        } catch (e: Exception) {
            Log.e(TAG, "Failed to start location updates", e)
            stopLocationTracking()
        }
    }
    
    private fun stopLocationTracking() {
        if (!isTracking) return
        
        Log.i(TAG, "Stopping location tracking")
        
        isTracking = false
        
        // Stop location updates
        locationCallback?.let { callback ->
            fusedLocationClient.removeLocationUpdates(callback)
        }
        
        // Stop background jobs
        locationUpdateJob?.cancel()
        batteryMonitorJob?.cancel()
        gpsMonitorJob?.cancel()
        
        // Clean up
        locationBuffer.clear()
        lastKnownLocation = null
        
        stopForeground(true)
        stopSelf()
    }
    
    private fun startBackgroundJobs() {
        // Battery monitoring job
        batteryMonitorJob = trackingScope?.launch {
            while (isTracking) {
                updateBatteryLevel()
                adjustUpdateInterval()
                delay(60000) // Check every minute
            }
        }
        
        // GPS status monitoring job
        gpsMonitorJob = trackingScope?.launch {
            while (isTracking) {
                checkGpsStatus()
                delay(30000) // Check every 30 seconds
            }
        }
        
        // Location update optimization job
        locationUpdateJob = trackingScope?.launch {
            while (isTracking) {
                optimizeLocationUpdates()
                delay(30000) // Check every 30 seconds
            }
        }
    }
    
    private fun updateBatteryLevel() {
        currentBatteryLevel = batteryManager.getIntProperty(BatteryManager.BATTERY_PROPERTY_CAPACITY)
        
        // Enable battery optimization based on battery level
        isBatteryOptimizationEnabled = when (currentBatteryLevel) {
            in 0..LOW_BATTERY_THRESHOLD -> true
            in LOW_BATTERY_THRESHOLD + 1..MEDIUM_BATTERY_THRESHOLD -> false
            else -> false
        }
        
        Log.d(TAG, "Battery level: $currentBatteryLevel%, Optimization: $isBatteryOptimizationEnabled")
    }
    
    private fun adjustUpdateInterval() {
        val newInterval = when {
            isBatteryOptimizationEnabled -> BATTERY_OPTIMIZATION_INTERVAL
            currentBatteryLevel < MEDIUM_BATTERY_THRESHOLD -> LOCATION_UPDATE_INTERVAL * 2
            else -> LOCATION_UPDATE_INTERVAL
        }
        
        if (newInterval != adaptiveUpdateInterval) {
            adaptiveUpdateInterval = newInterval
            
            // Update location request with new interval
            locationRequest = LocationRequest.Builder(Priority.PRIORITY_HIGH_ACCURACY)
                .setIntervalMillis(adaptiveUpdateInterval)
                .setMinUpdateIntervalMillis(FASTEST_UPDATE_INTERVAL)
                .setWaitForAccurateLocation(true)
                .build()
            
            // Restart location updates with new interval
            if (isTracking) {
                fusedLocationClient.removeLocationUpdates(locationCallback!!)
                fusedLocationClient.requestLocationUpdates(
                    locationRequest!!,
                    locationCallback!!,
                    Looper.getMainLooper()
                )
            }
            
            Log.d(TAG, "Adjusted update interval to ${adaptiveUpdateInterval}ms")
        }
    }
    
    private fun checkGpsStatus() {
        val isGpsEnabled = locationManager.isProviderEnabled(LocationManager.GPS_PROVIDER)
        
        if (!isGpsEnabled && isGpsAvailable) {
            handleLocationAvailability(false)
        } else if (isGpsEnabled && !isGpsAvailable) {
            handleLocationAvailability(true)
        }
    }
    
    private fun optimizeLocationUpdates() {
        // Check if we're getting accurate locations
        val recentAccuracy = locationBuffer.takeLast(3).map { it.accuracy }.average()
        
        if (recentAccuracy > ACCURACY_THRESHOLD * 2) {
            Log.w(TAG, "Low accuracy detected (${recentAccuracy}m), requesting higher accuracy")
            
            // Temporarily request higher accuracy
            val highAccuracyRequest = LocationRequest.Builder(Priority.PRIORITY_HIGH_ACCURACY)
                .setIntervalMillis(5000L) // 5 seconds
                .setMinUpdateIntervalMillis(2000L) // 2 seconds
                .setWaitForAccurateLocation(true)
                .setMaxUpdateDelayMillis(10000L) // 10 seconds
                .setDurationMillis(60000L) // 1 minute
                .build()
            
            fusedLocationClient.requestLocationUpdates(
                highAccuracyRequest,
                locationCallback!!,
                Looper.getMainLooper()
            )
            
            // Revert to normal interval after 1 minute
            trackingScope?.launch {
                delay(60000)
                if (isTracking) {
                    fusedLocationClient.removeLocationUpdates(locationCallback!!)
                    fusedLocationClient.requestLocationUpdates(
                        locationRequest!!,
                        locationCallback!!,
                        Looper.getMainLooper()
                    )
                }
            }
        }
    }
    
    override fun onDestroy() {
        super.onDestroy()
        stopLocationTracking()
        trackingScope?.cancel()
    }
    
    // Public API for location data
    fun getSmoothedLocationFlow(): StateFlow<LocationData?> = smoothedLocationFlow.asStateFlow()
    fun getRawLocationFlow(): StateFlow<LocationData?> = rawLocationFlow.asStateFlow()
    fun getGpsStatusFlow(): StateFlow<GpsStatus> = gpsStatusFlow.asStateFlow()
    fun getAccuracyFlow(): StateFlow<LocationAccuracyStats> = accuracyFlow.asStateFlow()
    fun getBatteryLevel(): Int = currentBatteryLevel
    fun isTrackingActive(): Boolean = isTracking
}

/**
 * Location data class
 */
data class LocationData(
    val latitude: Double,
    val longitude: Double,
    val accuracy: Float,
    val altitude: Double,
    val speed: Float,
    val bearing: Float,
    val timestamp: Long,
    val provider: String?
)

/**
 * GPS status enum
 */
enum class GpsStatus {
    AVAILABLE,
    LOST,
    RECOVERING,
    DISABLED
}

/**
 * Location accuracy statistics
 */
data class LocationAccuracyStats(
    var totalUpdates: Long = 0,
    var accurateUpdates: Long = 0,
    var averageAccuracy: Float = 0f,
    var bestAccuracy: Float = Float.MAX_VALUE,
    var worstAccuracy: Float = 0f,
    var accuracyPercentage: Float = 0f
) {
    fun reset() {
        totalUpdates = 0
        accurateUpdates = 0
        averageAccuracy = 0f
        bestAccuracy = Float.MAX_VALUE
        worstAccuracy = 0f
        accuracyPercentage = 0f
    }
}
