package com.edham.logistics.core.navigation

import com.android.tools.lint.detector.api.*
import com.android.tools.lint.detector.api.Category.Companion.CORRECTNESS
import com.intellij.psi.PsiMethod
import org.jetbrains.uast.UCallExpression

/**
 * Custom Lint Rules to prevent direct navigation usage
 * Enforces use of AppNavigationController for all navigation operations
 */
@Suppress("UnstableApiUsage")
class NavigationLintRules : Detector(), Detector.UastScanner {
    
    override fun getApplicableUastTypes() = listOf(UCallExpression::class.java)
    
    override fun visitMethodCall(context: JavaContext, node: UCallExpression, method: PsiMethod) {
        val methodName = method.name
        
        // Check for direct NavController.navigate() calls
        if (isDirectNavigationCall(methodName, method)) {
            context.report(
                issue = DIRECT_NAVIGATION_ISSUE,
                scope = node,
                location = context.getNameLocation(node),
                message = "Direct navigation detected. Use AppNavigationController instead."
            )
        }
        
        // Check for direct NavController.popBackStack() calls
        if (isDirectBackNavigationCall(methodName, method)) {
            context.report(
                issue = DIRECT_BACK_NAVIGATION_ISSUE,
                scope = node,
                location = context.getNameLocation(node),
                message = "Direct back navigation detected. Use AppNavigationController.navigateBack() instead."
            )
        }
    }
    
    private fun isDirectNavigationCall(methodName: String, method: PsiMethod): Boolean {
        return methodName == "navigate" && 
               method.containingClass?.qualifiedName == "androidx.navigation.NavController"
    }
    
    private fun isDirectBackNavigationCall(methodName: String, method: PsiMethod): Boolean {
        return (methodName == "popBackStack" || methodName == "navigateUp") && 
               method.containingClass?.qualifiedName == "androidx.navigation.NavController"
    }
    
    companion object {
        val DIRECT_NAVIGATION_ISSUE = Issue.create(
            id = "DirectNavigationUsage",
            briefDescription = "Direct navigation usage detected",
            explanation = """
                Direct navigation using NavController.navigate() is discouraged for sensitive operations.
                Use AppNavigationController.navigateToDestination() for sensitive operations like financial or admin screens.
                For simple fragment-to-fragment navigation within the same flow, NavController.navigate() is acceptable.
                Consider using SimpleNavigationHelper for basic navigation needs.
            """.trimIndent(),
            category = CORRECTNESS,
            priority = 3,
            severity = Severity.WARNING,
            implementation = Implementation(
                NavigationLintRules::class.java,
                Scope.JAVA_FILE_SCOPE
            )
        )
        
        val DIRECT_BACK_NAVIGATION_ISSUE = Issue.create(
            id = "DirectBackNavigationUsage",
            briefDescription = "Direct back navigation usage detected",
            explanation = """
                Direct back navigation using NavController.popBackStack() or navigateUp() is generally acceptable.
                Use AppNavigationController.navigateBack() only for sensitive operations that require state tracking.
                For most cases, NavController.navigateUp() is fine.
            """.trimIndent(),
            category = CORRECTNESS,
            priority = 2,
            severity = Severity.WARNING,
            implementation = Implementation(
                NavigationLintRules::class.java,
                Scope.JAVA_FILE_SCOPE
            )
        )
    }
}
