package com.edham.logistics

import android.os.Bundle
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.TextView
import androidx.fragment.app.Fragment

class ShipmentDetailFragment : Fragment() {
    private lateinit var tvShipmentNumber: TextView
    private lateinit var tvShipmentStatus: TextView
    private lateinit var tvCustomerName: TextView
    private lateinit var tvCustomerPhone: TextView
    private lateinit var tvDriverName: TextView
    private lateinit var tvDriverPhone: TextView
    private lateinit var tvVehicleNumber: TextView
    private lateinit var tvTemperature: TextView
    private lateinit var tvHumidity: TextView
    private lateinit var tvPickupLocation: TextView
    private lateinit var tvDeliveryLocation: TextView
    private lateinit var tvEstimatedTime: TextView

    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View? {
        return inflater.inflate(R.layout.fragment_shipment_detail, container, false)
    }

    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)

        // Initialize views
        tvShipmentNumber = view.findViewById(R.id.tv_shipment_number)
        tvShipmentStatus = view.findViewById(R.id.tv_shipment_status)
        tvCustomerName = view.findViewById(R.id.tv_customer_name)
        tvCustomerPhone = view.findViewById(R.id.tv_customer_phone)
        tvDriverName = view.findViewById(R.id.tv_driver_name)
        tvDriverPhone = view.findViewById(R.id.tv_driver_phone)
        tvVehicleNumber = view.findViewById(R.id.tv_vehicle_number)
        tvTemperature = view.findViewById(R.id.tv_temperature)
        tvHumidity = view.findViewById(R.id.tv_humidity)
        tvPickupLocation = view.findViewById(R.id.tv_pickup_location)
        tvDeliveryLocation = view.findViewById(R.id.tv_delivery_location)
        tvEstimatedTime = view.findViewById(R.id.tv_estimated_time)

        // Set Arabic titles
        view.findViewById<TextView>(R.id.tv_title).text = "تفاصيل الشحنة"
        view.findViewById<TextView>(R.id.tv_customer_info_title).text = "معلومات العميل"
        view.findViewById<TextView>(R.id.tv_driver_info_title).text = "معلومات السائق"
        view.findViewById<TextView>(R.id.tv_shipment_info_title).text = "معلومات الشحنة"
        view.findViewById<TextView>(R.id.tv_tracking_info_title).text = "معلومات التتبع"
        view.findViewById<TextView>(R.id.tv_cold_chain_title).text = "معلومات التبريد"

        // Set sample data
        tvShipmentNumber.text = "SH-2024-1234"
        tvShipmentStatus.text = "في الطريق"
        tvCustomerName.text = "أحمد محمد علي"
        tvCustomerPhone.text = "+966 50 123 4567"
        tvDriverName.text = "خالد عبدالله"
        tvDriverPhone.text = "+966 55 987 6543"
        tvVehicleNumber.text = "نقل 1234"
        tvTemperature.text = "-18.5°C"
        tvHumidity.text = "78%"
        tvPickupLocation.text = "الرياض، حي النخيل"
        tvDeliveryLocation.text = "جدة، حي الروضة"
        tvEstimatedTime.text = "3 ساعات"

    }
}
