import javax.inject.Inject

/**
 * Temperature Analytics Fragment - Comprehensive temperature monitoring and analytics
 * 
 * Features:
 * - Temperature overview and monitoring
 * - Cold chain compliance metrics
 * - Temperature violation analysis
 * - Sensor performance analytics
 * - Temperature trends and patterns
 * - Alert and notification metrics
 * - Compliance reporting
 * - Interactive charts
 */
@AndroidEntryPoint
class TemperatureAnalyticsFragment : Fragment() {
    
    @Inject
    lateinit var analyticsEngineService: AnalyticsEngineService
    
    private val viewModel: TemperatureAnalyticsViewModel by viewModels()
    
    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View {
        return ComposeView(requireContext()).apply {
            setContent {
                EdhamLogisticsTheme {
                    TemperatureAnalyticsScreen(
                        viewModel = viewModel,
                        analyticsEngineService = analyticsEngineService
                    )
                }
            }
        }
    }
    
    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        
        // Initialize analytics engine
        lifecycleScope.launch {
            analyticsEngineService.initialize()
        }
        
        // Load temperature analytics
        viewModel.loadTemperatureAnalytics()
    }
}

@Composable
fun TemperatureAnalyticsScreen(
    viewModel: TemperatureAnalyticsViewModel,
    analyticsEngineService: AnalyticsEngineService
) {
    val temperatureAnalytics by viewModel.temperatureAnalytics.collectAsStateWithLifecycle()
    val isLoading by viewModel.isLoading.collectAsStateWithLifecycle()
    val errorMessage by viewModel.errorMessage.collectAsStateWithLifecycle()
    val selectedTimeRange by viewModel.selectedTimeRange.collectAsStateWithLifecycle()
    
    LaunchedEffect(selectedTimeRange) {
        viewModel.loadTemperatureAnalytics()
    }
    
    Column(
        modifier = Modifier
            .fillMaxSize()
            .padding(16.dp),
        verticalArrangement = Arrangement.spacedBy(16.dp)
    ) {
        // Header with time range selector
        TemperatureAnalyticsHeader(
            selectedTimeRange = selectedTimeRange,
            onTimeRangeChanged = viewModel::setTimeRange,
            onRefresh = viewModel::refreshAnalytics,
            isLoading = isLoading
        )
        
        // Error message
        errorMessage?.let { error ->
            Card(
                modifier = Modifier.fillMaxWidth(),
                colors = CardDefaults.cardColors(
                    containerColor = ErrorRed.copy(alpha = 0.1f)
                ),
                elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
            ) {
                Text(
                    text = error,
                    modifier = Modifier.padding(16.dp),
                    color = ErrorRed,
                    style = MaterialTheme.typography.bodyMedium
                )
            }
        }
        
        // Temperature Analytics Content
        temperatureAnalytics?.let { analytics ->
            // Temperature Overview
            TemperatureOverviewSection(analytics = analytics)
            
            // Cold Chain Compliance
            ColdChainComplianceSection(analytics = analytics)
            
            // Temperature Violations
            TemperatureViolationsSection(analytics = analytics)
            
            // Sensor Performance
            SensorPerformanceSection(analytics = analytics)
            
            // Temperature Trends
            TemperatureTrendsSection(analytics = analytics)
            
            // Alert Metrics
            TemperatureAlertsSection(analytics = analytics)
            
            // Compliance Reporting
            ComplianceReportingSection(analytics = analytics)
        }
        
        // Loading indicator
        if (isLoading) {
            Box(
                modifier = Modifier.fillMaxWidth(),
                contentAlignment = Alignment.Center
            ) {
                CircularProgressIndicator(
                    color = EdhamOrange,
                    strokeWidth = 3.dp
                )
            }
        }
    }
}

@Composable
fun TemperatureAnalyticsHeader(
    selectedTimeRange: TimeRange,
    onTimeRangeChanged: (TimeRange) -> Unit,
    onRefresh: () -> Unit,
    isLoading: Boolean
) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.surface
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Row(
                modifier = Modifier.fillMaxWidth(),
                horizontalArrangement = Arrangement.SpaceBetween,
                verticalAlignment = Alignment.CenterVertically
            ) {
                Text(
                    text = "Temperature Analytics",
                    style = MaterialTheme.typography.headlineMedium,
                    color = EdhamOrange,
                    fontWeight = FontWeight.Bold
                )
                
                Row {
                    // Time range selector
                    TimeRangeSelector(
                        selectedTimeRange = selectedTimeRange,
                        onTimeRangeChanged = onTimeRangeChanged
                    )
                    
                    Spacer(modifier = Modifier.width(8.dp))
                    
                    // Refresh button
                    IconButton(
                        onClick = onRefresh,
                        enabled = !isLoading
                    ) {
                        Icon(
                            painter = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_rotate),
                            contentDescription = "Refresh",
                            tint = EdhamOrange
                        )
                    }
                }
            }
        }
    }
}

@Composable
fun TemperatureOverviewSection(analytics: TemperatureAnalytics) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.surface
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Text(
                text = "Temperature Overview",
                style = MaterialTheme.typography.titleMedium,
                color = EdhamOrange,
                fontWeight = FontWeight.Bold
            )
            
            Spacer(modifier = Modifier.height(16.dp))
            
            LazyColumn(
                verticalArrangement = Arrangement.spacedBy(12.dp)
            ) {
                item {
                    OverviewMetric(
                        title = "Active Temperature Sensors",
                        value = analytics.activeSensors.toString(),
                        subtitle = "Currently monitoring",
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_camera),
                        color = IceBlue,
                        change = analytics.activeSensorsChange
                    )
                }
                
                item {
                    OverviewMetric(
                        title = "Average Temperature",
                        value = "${String.format("%.1f", analytics.averageTemperature)}°C",
                        subtitle = "Across all sensors",
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_view),
                        color = if (analytics.averageTemperature >= 2 && analytics.averageTemperature <= 8) SuccessGreen else WarningYellow,
                        change = analytics.averageTemperatureChange
                    )
                }
                
                item {
                    OverviewMetric(
                        title = "Temperature Compliance Rate",
                        value = "${String.format("%.1f", analytics.complianceRate)}%",
                        subtitle = "Within acceptable range",
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_preferences),
                        color = if (analytics.complianceRate >= 95) SuccessGreen else WarningYellow,
                        change = analytics.complianceRateChange
                    )
                }
                
                item {
                    OverviewMetric(
                        title = "Total Temperature Readings",
                        value = "${String.format("%,d", analytics.totalReadings)}",
                        subtitle = "In selected period",
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_agenda),
                        color = EdhamOrange,
                        change = analytics.readingsChange
                    )
                }
            }
        }
    }
}

@Composable
fun ColdChainComplianceSection(analytics: TemperatureAnalytics) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.surface
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Text(
                text = "Cold Chain Compliance",
                style = MaterialTheme.typography.titleMedium,
                color = EdhamOrange,
                fontWeight = FontWeight.Bold
            )
            
            Spacer(modifier = Modifier.height(16.dp))
            
            // Compliance chart placeholder
            Box(
                modifier = Modifier
                    .fillMaxWidth()
                    .height(200.dp)
                    .clip(RoundedCornerShape(8.dp))
                    .background(MaterialTheme.colorScheme.surfaceVariant),
                contentAlignment = Alignment.Center
            ) {
                Column(
                    horizontalAlignment = Alignment.CenterHorizontally
                ) {
                    Icon(
                        painter = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_gallery),
                        contentDescription = "Chart",
                        tint = MaterialTheme.colorScheme.onSurfaceVariant,
                        modifier = Modifier.size(48.dp)
                    )
                    
                    Spacer(modifier = Modifier.height(8.dp))
                    
                    Text(
                        text = "Compliance Trends Chart",
                        style = MaterialTheme.typography.bodyMedium,
                        color = MaterialTheme.colorScheme.onSurfaceVariant
                    )
                    
                    Text(
                        text = "Interactive chart coming soon",
                        style = MaterialTheme.typography.bodySmall,
                        color = MaterialTheme.colorScheme.onSurfaceVariant.copy(alpha = 0.7f)
                    )
                }
            }
            
            Spacer(modifier = Modifier.height(16.dp))
            
            LazyColumn(
                verticalArrangement = Arrangement.spacedBy(8.dp)
            ) {
                item {
                    ComplianceMetric(
                        title = "Refrigerated Compliance",
                        value = "${String.format("%.1f", analytics.refrigeratedCompliance)}%",
                        target = 95f,
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_star),
                        color = if (analytics.refrigeratedCompliance >= 95) SuccessGreen else WarningYellow
                    )
                }
                
                item {
                    ComplianceMetric(
                        title = "Frozen Compliance",
                        value = "${String.format("%.1f", analytics.frozenCompliance)}%",
                        target = 98f,
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_save),
                        color = if (analytics.frozenCompliance >= 98) SuccessGreen else WarningYellow
                    )
                }
                
                item {
                    ComplianceMetric(
                        title = "Ambient Compliance",
                        value = "${String.format("%.1f", analytics.ambientCompliance)}%",
                        target = 90f,
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_info_details),
                        color = if (analytics.ambientCompliance >= 90) SuccessGreen else WarningYellow
                    )
                }
            }
        }
    }
}

@Composable
fun ComplianceMetric(
    title: String,
    value: String,
    target: Float,
    icon: androidx.compose.ui.graphics.painter.Painter,
    color: Color
) {
    Row(
        modifier = Modifier.fillMaxWidth(),
        verticalAlignment = Alignment.CenterVertically
    ) {
        Card(
            modifier = Modifier.size(40.dp),
            colors = CardDefaults.cardColors(
                containerColor = color.copy(alpha = 0.1f)
            ),
            elevation = CardDefaults.cardElevation(defaultElevation = 1.dp)
        ) {
            Box(
                modifier = Modifier.fillMaxSize(),
                contentAlignment = Alignment.Center
            ) {
                Icon(
                    painter = icon,
                    contentDescription = null,
                    tint = color,
                    modifier = Modifier.size(20.dp)
                )
            }
        }
        
        Spacer(modifier = Modifier.width(12.dp))
        
        Column(modifier = Modifier.weight(1f)) {
            Text(
                text = title,
                style = MaterialTheme.typography.bodyMedium,
                color = MaterialTheme.colorScheme.onSurface
            )
            
            Row(
                verticalAlignment = Alignment.CenterVertically
            ) {
                Text(
                    text = value,
                    style = MaterialTheme.typography.titleMedium,
                    color = color,
                    fontWeight = FontWeight.Bold
                )
                
                Spacer(modifier = Modifier.width(8.dp))
                
                Text(
                    text = "(Target: $target%)",
                    style = MaterialTheme.typography.bodySmall,
                    color = MaterialTheme.colorScheme.onSurface.copy(alpha = 0.7f)
                )
            }
        }
        
        // Status indicator
        Card(
            colors = CardDefaults.cardColors(
                containerColor = color
            ),
            shape = RoundedCornerShape(12.dp)
        ) {
            Text(
                text = if (color == SuccessGreen) "Compliant" else "Needs Attention",
                modifier = Modifier.padding(horizontal = 12.dp, vertical = 4.dp),
                style = MaterialTheme.typography.bodySmall,
                color = Color.White,
                fontWeight = FontWeight.Medium
            )
        }
    }
}

