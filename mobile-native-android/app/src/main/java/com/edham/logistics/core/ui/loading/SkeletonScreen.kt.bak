package com.edham.logistics.core.ui.loading

import android.animation.ValueAnimator
import android.content.Context
import android.graphics.Canvas
import android.graphics.Paint
import android.graphics.RectF
import android.util.AttributeSet
import android.view.View
import androidx.core.content.ContextCompat
import com.edham.logistics.R
import kotlin.math.random

/**
 * Skeleton screen for loading states with shimmer effect
 */
class SkeletonScreen @JvmOverloads constructor(
    context: Context,
    attrs: AttributeSet? = null,
    defStyleAttr: Int = 0
) : View(context, attrs, defStyleAttr) {

    private val skeletonPaint = Paint(Paint.ANTI_ALIAS_FLAG).apply {
        color = ContextCompat.getColor(context, R.color.skeleton_color)
    }
    
    private val shimmerPaint = Paint(Paint.ANTI_ALIAS_FLAG).apply {
        color = ContextCompat.getColor(context, R.color.skeleton_shimmer_color)
    }
    
    private val backgroundPaint = Paint(Paint.ANTI_ALIAS_FLAG).apply {
        color = ContextCompat.getColor(context, R.color.skeleton_background)
    }
    
    private var skeletonItems = mutableListOf<SkeletonItem>()
    private var shimmerAnimator: ValueAnimator? = null
    private var shimmerOffset = 0f
    private var isShimmering = false
    
    init {
        setupShimmerAnimation()
    }
    
    /**
     * Add skeleton item
     */
    fun addSkeletonItem(item: SkeletonItem) {
        skeletonItems.add(item)
        invalidate()
    }
    
    /**
     * Add multiple skeleton items
     */
    fun addSkeletonItems(items: List<SkeletonItem>) {
        skeletonItems.addAll(items)
        invalidate()
    }
    
    /**
     * Clear all skeleton items
     */
    fun clearSkeletonItems() {
        skeletonItems.clear()
        invalidate()
    }
    
    /**
     * Start shimmer animation
     */
    fun startShimmer() {
        if (!isShimmering) {
            isShimmering = true
            shimmerAnimator?.start()
        }
    }
    
    /**
     * Stop shimmer animation
     */
    fun stopShimmer() {
        isShimmering = false
        shimmerAnimator?.cancel()
        shimmerOffset = 0f
        invalidate()
    }
    
    /**
     * Setup shimmer animation
     */
    private fun setupShimmerAnimation() {
        shimmerAnimator = ValueAnimator.ofFloat(0f, 1f).apply {
            duration = 1000
            repeatCount = ValueAnimator.INFINITE
            addUpdateListener { animator ->
                shimmerOffset = animator.animatedValue as Float
                invalidate()
            }
        }
    }
    
    override fun onDraw(canvas: Canvas) {
        super.onDraw(canvas)
        
        // Draw background
        canvas.drawRect(0f, 0f, width.toFloat(), height.toFloat(), backgroundPaint)
        
        // Draw skeleton items
        skeletonItems.forEach { item ->
            drawSkeletonItem(canvas, item)
        }
        
        // Draw shimmer effect
        if (isShimmering) {
            drawShimmerEffect(canvas)
        }
    }
    
    /**
     * Draw individual skeleton item
     */
    private fun drawSkeletonItem(canvas: Canvas, item: SkeletonItem) {
        when (item.type) {
            SkeletonType.RECTANGLE -> {
                canvas.drawRoundRect(
                    item.bounds,
                    item.cornerRadius,
                    item.cornerRadius,
                    skeletonPaint
                )
            }
            SkeletonType.CIRCLE -> {
                val radius = minOf(item.bounds.width(), item.bounds.height()) / 2f
                canvas.drawCircle(
                    item.bounds.centerX(),
                    item.bounds.centerY(),
                    radius,
                    skeletonPaint
                )
            }
            SkeletonType.LINE -> {
                val lineHeight = item.bounds.height()
                canvas.drawRoundRect(
                    item.bounds,
                    lineHeight / 2f,
                    lineHeight / 2f,
                    skeletonPaint
                )
            }
        }
    }
    
    /**
     * Draw shimmer effect
     */
    private fun drawShimmerEffect(canvas: Canvas) {
        skeletonItems.forEach { item ->
            drawShimmerForItem(canvas, item)
        }
    }
    
    /**
     * Draw shimmer for specific item
     */
    private fun drawShimmerForItem(canvas: Canvas, item: SkeletonItem) {
        val shimmerWidth = item.bounds.width() * 0.3f
        val shimmerX = item.bounds.left + (item.bounds.width() * shimmerOffset) - shimmerWidth
        
        if (shimmerX + shimmerWidth > item.bounds.left && shimmerX < item.bounds.right) {
            val shimmerRect = RectF(
                maxOf(shimmerX, item.bounds.left),
                item.bounds.top,
                minOf(shimmerX + shimmerWidth, item.bounds.right),
                item.bounds.bottom
            )
            
            when (item.type) {
                SkeletonType.RECTANGLE -> {
                    canvas.drawRoundRect(
                        shimmerRect,
                        item.cornerRadius,
                        item.cornerRadius,
                        shimmerPaint
                    )
                }
                SkeletonType.CIRCLE -> {
                    val radius = minOf(shimmerRect.width(), shimmerRect.height()) / 2f
                    canvas.drawCircle(
                        shimmerRect.centerX(),
                        shimmerRect.centerY(),
                        radius,
                        shimmerPaint
                    )
                }
                SkeletonType.LINE -> {
                    val lineHeight = item.bounds.height()
                    canvas.drawRoundRect(
                        shimmerRect,
                        lineHeight / 2f,
                        lineHeight / 2f,
                        shimmerPaint
                    )
                }
            }
        }
    }
    
    override fun onDetachedFromWindow() {
        super.onDetachedFromWindow()
        shimmerAnimator?.cancel()
    }
}

/**
 * Skeleton item data class
 */
data class SkeletonItem(
    val type: SkeletonType,
    val bounds: RectF,
    val cornerRadius: Float = 8f
)

/**
 * Skeleton types
 */
enum class SkeletonType {
    RECTANGLE,
    CIRCLE,
    LINE
}

/**
 * Skeleton builder for easy creation
 */
class SkeletonBuilder {
    private val items = mutableListOf<SkeletonItem>()
    
    fun addRectangle(
        left: Float,
        top: Float,
        right: Float,
        bottom: Float,
        cornerRadius: Float = 8f
    ): SkeletonBuilder {
        items.add(
            SkeletonItem(
                type = SkeletonType.RECTANGLE,
                bounds = RectF(left, top, right, bottom),
                cornerRadius = cornerRadius
            )
        )
        return this
    }
    
    fun addCircle(
        centerX: Float,
        centerY: Float,
        radius: Float
    ): SkeletonBuilder {
        val bounds = RectF(
            centerX - radius,
            centerY - radius,
            centerX + radius,
            centerY + radius
        )
        items.add(
            SkeletonItem(
                type = SkeletonType.CIRCLE,
                bounds = bounds
            )
        )
        return this
    }
    
    fun addLine(
        left: Float,
        top: Float,
        right: Float,
        bottom: Float
    ): SkeletonBuilder {
        items.add(
            SkeletonItem(
                type = SkeletonType.LINE,
                bounds = RectF(left, top, right, bottom)
            )
        )
        return this
    }
    
    fun build(): List<SkeletonItem> {
        return items.toList()
    }
}

/**
 * Extension functions for common skeleton patterns
 */
fun SkeletonBuilder.addCardSkeleton(
    left: Float,
    top: Float,
    width: Float,
    height: Float
): SkeletonBuilder {
    // Card background
    addRectangle(left, top, left + width, top + height, 12f)
    
    // Title line
    addLine(left + 16f, top + 16f, left + width - 16f, top + 28f)
    
    // Subtitle line
    addLine(left + 16f, top + 36f, left + width * 0.6f, top + 48f)
    
    // Content lines
    for (i in 0 until 3) {
        val lineTop = top + 68f + (i * 16f)
        val lineWidth = if (i == 2) width * 0.4f else width
        addLine(left + 16f, lineTop, left + lineWidth - 16f, lineTop + 12f)
    }
    
    return this
}

fun SkeletonBuilder.addListItemSkeleton(
    left: Float,
    top: Float,
    width: Float,
    height: Float
): SkeletonBuilder {
    // Avatar
    addCircle(left + 16f, top + height / 2f, 24f)
    
    // Title line
    addLine(left + 56f, top + 16f, left + width * 0.7f, top + 28f)
    
    // Subtitle line
    addLine(left + 56f, top + 36f, left + width * 0.5f, top + 48f)
    
    // Content line
    addLine(left + 56f, top + 56f, left + width - 16f, top + 68f)
    
    return this
}

fun SkeletonBuilder.addDashboardCardSkeleton(
    left: Float,
    top: Float,
    width: Float,
    height: Float
): SkeletonBuilder {
    // Card background
    addRectangle(left, top, left + width, top + height, 8f)
    
    // Icon circle
    addCircle(left + 16f, top + 16f, 12f)
    
    // Title line
    addLine(left + 36f, top + 8f, left + width * 0.6f, top + 20f)
    
    // Value
    addRectangle(left + 16f, top + 32f, left + width * 0.4f, top + 56f, 4f)
    
    // Trend line
    addLine(left + 16f, top + 64f, left + width * 0.3f, top + 76f)
    
    return this
}

fun SkeletonBuilder.addChartSkeleton(
    left: Float,
    top: Float,
    width: Float,
    height: Float
): SkeletonBuilder {
    // Chart background
    addRectangle(left, top, left + width, top + height, 8f)
    
    // Chart bars
    val barCount = 5
    val barWidth = width / (barCount * 2)
    val barSpacing = barWidth
    
    for (i in 0 until barCount) {
        val barLeft = left + 16f + (i * (barWidth + barSpacing))
        val barHeight = (height * 0.6f * (0.3f + (0.7f * random()))).toFloat()
        val barTop = top + height - barHeight - 16f
        
        addRectangle(barLeft, barTop, barLeft + barWidth, top + height - 16f, 4f)
    }
    
    return this
}
