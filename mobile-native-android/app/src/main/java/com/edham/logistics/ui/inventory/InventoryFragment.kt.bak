package com.edham.logistics.ui.inventory

import android.os.Bundle
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.TextView
import androidx.fragment.app.Fragment
import androidx.recyclerview.widget.LinearLayoutManager
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.adapters.InventoryManagementAdapter
import com.edham.logistics.domain.model.InventoryItem

class InventoryFragment : Fragment() {

    private lateinit var rvInventory: RecyclerView
    private lateinit var tvTotalItems: TextView
    private lateinit var tvLowStock: TextView
    private lateinit var tvTotalValue: TextView
    private lateinit var inventoryAdapter: InventoryManagementAdapter

    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View? {
        return inflater.inflate(R.layout.fragment_inventory, container, false)
    }

    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        
        initViews(view)
        setupRecyclerView()
        loadInventoryData()
    }

    private fun initViews(view: View) {
        rvInventory = view.findViewById(R.id.rvInventory)
        tvTotalItems = view.findViewById(R.id.tvTotalItems)
        tvLowStock = view.findViewById(R.id.tvLowStock)
        tvTotalValue = view.findViewById(R.id.tvTotalValue)
    }

    private fun setupRecyclerView() {
        inventoryAdapter = InventoryManagementAdapter(getSampleInventory()) { item ->
            // Handle inventory item click
            // TODO: Navigate to item details
        }
        
        rvInventory.apply {
            layoutManager = LinearLayoutManager(requireContext())
            adapter = inventoryAdapter
        }
    }

    private fun loadInventoryData() {
        val inventory = getSampleInventory()
        val lowStockCount = inventory.count { it.quantity <= it.reorderLevel }
        val totalValue = inventory.sumOf { it.unitCost * it.quantity }
        
        tvTotalItems.text = inventory.size.toString()
        tvLowStock.text = lowStockCount.toString()
        tvTotalValue.text = String.format("%.2f ريال", totalValue)
        
        inventoryAdapter.updateInventory(inventory)
    }

    private fun getSampleInventory(): List<InventoryItem> {
        return listOf(
            InventoryItem("1", "صندوق كبير", "BOX-LRG-001", 50, "piece", "packaging", "WH-001", "A1", 20, 10.0, "2024-05-12T00:00:00", "2024-05-12T00:00:00"),
            InventoryItem("2", "صندوق متوسط", "BOX-MED-002", 8, "piece", "packaging", "WH-001", "A2", 15, 7.5, "2024-05-12T00:00:00", "2024-05-12T00:00:00"),
            InventoryItem("3", "لفافة بلاستيك", "PLA-ROL-003", 200, "roll", "packaging", "WH-002", "B1", 50, 0.5, "2024-05-12T00:00:00", "2024-05-12T00:00:00"),
            InventoryItem("4", "شريط لاصق", "TAP-ROL-004", 5, "roll", "packaging", "WH-002", "B2", 10, 2.0, "2024-05-12T00:00:00", "2024-05-12T00:00:00"),
            InventoryItem("5", "قفازات", "GLO-PAI-005", 100, "pair", "safety", "WH-003", "C1", 30, 1.5, "2024-05-12T00:00:00", "2024-05-12T00:00:00"),
            InventoryItem("6", "علامة أمان", "SEC-TAG-006", 3, "piece", "safety", "WH-003", "C2", 5, 5.0, "2024-05-12T00:00:00", "2024-05-12T00:00:00")
        )
    }
}
