package com.edham.logistics.offline.driver

import android.app.*
import android.content.Context
import android.content.Intent
import android.os.Build
import android.os.IBinder
import androidx.core.app.NotificationCompat
import dagger.hilt.android.AndroidEntryPoint
import kotlinx.coroutines.*
import kotlinx.coroutines.flow.*
import timber.log.Timber
import java.util.concurrent.ConcurrentLinkedQueue
import javax.inject.Inject

/**
 * Offline Driver Mode Service
 * Enables drivers to work completely offline with full functionality
 * Handles location tracking, status updates, and data synchronization
 */

// @AndroidEntryPoint
// Temporarily disabled due to missing dependencies
class OfflineDriverModeService : Service() {

    // @Inject
    // lateinit var offlineDriverManager: OfflineDriverManager

    // @Inject
    // lateinit var networkMonitor: NetworkMonitor

    @Inject
    lateinit var locationTracker: OfflineLocationTracker

    private val serviceScope = CoroutineScope(Dispatchers.IO + SupervisorJob())
    private var isServiceRunning = false
    private var locationTrackingJob: Job? = null

    companion object {
        const val NOTIFICATION_CHANNEL_ID = "edham_offline_driver"
        const val NOTIFICATION_ID = 2001
        const val ACTION_START_OFFLINE_MODE = "com.edham.logistics.START_OFFLINE_MODE"
        const val ACTION_STOP_OFFLINE_MODE = "com.edham.logistics.STOP_OFFLINE_MODE"
        const val ACTION_UPDATE_LOCATION = "com.edham.logistics.UPDATE_LOCATION"
        const val ACTION_UPDATE_STATUS = "com.edham.logistics.UPDATE_STATUS"

        fun startOfflineMode(context: Context) {
            val intent = Intent(context, OfflineDriverModeService::class.java).apply {
                action = ACTION_START_OFFLINE_MODE
            }
            if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
                context.startForegroundService(intent)
            } else {
                context.startService(intent)
            }
        }

        fun stopOfflineMode(context: Context) {
            val intent = Intent(context, OfflineDriverModeService::class.java).apply {
                action = ACTION_STOP_OFFLINE_MODE
            }
            context.startService(intent)
        }

        fun updateLocation(context: Context, latitude: Double, longitude: Double) {
            val intent = Intent(context, OfflineDriverModeService::class.java).apply {
                action = ACTION_UPDATE_LOCATION
                putExtra("latitude", latitude)
                putExtra("longitude", longitude)
            }
            context.startService(intent)
        }

        fun updateStatus(context: Context, status: String) {
            val intent = Intent(context, OfflineDriverModeService::class.java).apply {
                action = ACTION_UPDATE_STATUS
                putExtra("status", status)
            }
            context.startService(intent)
        }
    }

    override fun onCreate() {
        super.onCreate()
        createNotificationChannel()
        Timber.d("OfflineDriverModeService created")
    }

    override fun onStartCommand(intent: Intent?, flags: Int, startId: Int): Int {
        return when (intent?.action) {
            ACTION_START_OFFLINE_MODE -> {
                startOfflineMode()
                START_STICKY
            }
            ACTION_STOP_OFFLINE_MODE -> {
                stopOfflineMode()
                START_NOT_STICKY
            }
            ACTION_UPDATE_LOCATION -> {
                handleLocationUpdate(intent)
                START_STICKY
            }
            ACTION_UPDATE_STATUS -> {
                handleStatusUpdate(intent)
                START_STICKY
            }
            else -> {
                startOfflineMode()
                START_STICKY
            }
        }
    }

    override fun onBind(intent: Intent?): IBinder? = null

    private fun startOfflineMode() {
        if (isServiceRunning) return

        isServiceRunning = true
        startForeground(NOTIFICATION_ID, createOfflineNotification())

        serviceScope.launch {
            try {
                // Initialize offline driver mode
                offlineDriverManager.initializeOfflineMode()
                
                // Start location tracking
                startLocationTracking()
                
                // Monitor network status for auto-sync
                monitorNetworkStatus()
                
                // Start periodic data sync
                startPeriodicSync()
                
                updateNotification("Offline mode active - Full functionality available")
                Timber.d("Offline driver mode started")
                
            } catch (e: Exception) {
                Timber.e(e, "Error starting offline driver mode")
                handleOfflineModeError(e)
            }
        }
    }

    private fun startLocationTracking() {
        locationTrackingJob = serviceScope.launch {
            try {
                locationTracker.startTracking()
                
                locationTracker.locationUpdates.collect { location ->
                    try {
                        // Save location to local cache
                        offlineDriverManager.saveLocationUpdate(location)
                        
                        // Update notification with location info
                        updateNotification("Offline mode - Location: ${location.latitude}, ${location.longitude}")
                        
                    } catch (e: Exception) {
                        Timber.e(e, "Error processing location update")
                    }
                }
                
            } catch (e: Exception) {
                Timber.e(e, "Error starting location tracking")
            }
        }
    }

    private fun monitorNetworkStatus() {
        serviceScope.launch {
            networkMonitor.observeNetworkStatus()
                .distinctUntilChanged()
                .collect { networkStatus ->
                    when (networkStatus) {
                        NetworkStatus.ONLINE -> {
                            Timber.d("Network available, starting auto-sync")
                            offlineDriverManager.startAutoSync()
                            updateNotification("Offline mode - Syncing data...")
                        }
                        NetworkStatus.OFFLINE -> {
                            Timber.d("Network unavailable, continuing offline mode")
                            updateNotification("Offline mode active - Full functionality available")
                        }
                        NetworkStatus.CONNECTING -> {
                            updateNotification("Offline mode - Connecting...")
                        }
                    }
                }
        }
    }

    private fun startPeriodicSync() {
        serviceScope.launch {
            while (isActive) {
                try {
                    // Check for data that needs to be synced
                    val pendingOperations = offlineDriverManager.getPendingOperations()
                    
                    if (pendingOperations.isNotEmpty()) {
                        updateNotification("Offline mode - ${pendingOperations.size} pending operations")
                    }
                    
                    // Periodically save driver status
                    offlineDriverManager.saveDriverStatus()
                    
                    delay(30000) // Check every 30 seconds
                    
                } catch (e: Exception) {
                    Timber.e(e, "Error in periodic sync")
                    delay(60000) // Wait longer on error
                }
            }
        }
    }

    private fun handleLocationUpdate(intent: Intent) {
        val latitude = intent.getDoubleExtra("latitude", 0.0)
        val longitude = intent.getDoubleExtra("longitude", 0.0)
        
        serviceScope.launch {
            try {
                val location = LocationUpdate(
                    latitude = latitude,
                    longitude = longitude,
                    timestamp = System.currentTimeMillis(),
                    accuracy = 10.0f,
                    speed = 0.0f,
                    bearing = 0.0f
                )
                
                offlineDriverManager.saveLocationUpdate(location)
                Timber.d("Location update received: $latitude, $longitude")
                
            } catch (e: Exception) {
                Timber.e(e, "Error handling location update")
            }
        }
    }

    private fun handleStatusUpdate(intent: Intent) {
        val status = intent.getStringExtra("status") ?: return
        
        serviceScope.launch {
            try {
                offlineDriverManager.updateDriverStatus(status)
                updateNotification("Offline mode - Status: $status")
                Timber.d("Status update received: $status")
                
            } catch (e: Exception) {
                Timber.e(e, "Error handling status update")
            }
        }
    }

    private fun stopOfflineMode() {
        isServiceRunning = false
        
        // Stop location tracking
        locationTrackingJob?.cancel()
        locationTracker.stopTracking()
        
        // Final sync before stopping
        serviceScope.launch {
            try {
                offlineDriverManager.finalSync()
                updateNotification("Offline mode stopped - Syncing completed")
                delay(3000)
            } catch (e: Exception) {
                Timber.e(e, "Error during final sync")
            } finally {
                stopForeground(true)
                stopSelf()
            }
        }
        
        Timber.d("Offline driver mode stopped")
    }

    private fun handleOfflineModeError(error: Exception) {
        Timber.e(error, "Offline mode error")
        updateNotification("Offline mode error - ${error.message}")
        
        serviceScope.launch {
            // Try to recover
            delay(5000)
            if (isServiceRunning) {
                startOfflineMode()
            }
        }
    }

    private fun createNotificationChannel() {
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            val channel = NotificationChannel(
                NOTIFICATION_CHANNEL_ID,
                "Edham Offline Driver Mode",
                NotificationManager.IMPORTANCE_LOW
            ).apply {
                description = "Offline driver mode notifications"
                setShowBadge(false)
                enableVibration(false)
                setSound(null, null)
            }
            
            val notificationManager = getSystemService(Context.NOTIFICATION_SERVICE) as NotificationManager
            notificationManager.createNotificationChannel(channel)
        }
    }

    private fun createOfflineNotification(): Notification {
        return NotificationCompat.Builder(this, NOTIFICATION_CHANNEL_ID)
            .setContentTitle("Edham Logistics - Offline Mode")
            .setContentText("Full functionality available without internet")
            .setSmallIcon(android.R.drawable.ic_menu_mylocation)
            .setOngoing(true)
            .setSilent(true)
            .setCategory(NotificationCompat.CATEGORY_SERVICE)
            .build()
    }

    private fun updateNotification(text: String) {
        val notification = NotificationCompat.Builder(this, NOTIFICATION_CHANNEL_ID)
            .setContentTitle("Edham Logistics - Offline Mode")
            .setContentText(text)
            .setSmallIcon(android.R.drawable.ic_menu_mylocation)
            .setOngoing(true)
            .setSilent(true)
            .setCategory(NotificationCompat.CATEGORY_SERVICE)
            .build()
        
        val notificationManager = getSystemService(Context.NOTIFICATION_SERVICE) as NotificationManager
        notificationManager.notify(NOTIFICATION_ID, notification)
    }

    override fun onDestroy() {
        super.onDestroy()
        isServiceRunning = false
        locationTrackingJob?.cancel()
        serviceScope.cancel()
        Timber.d("OfflineDriverModeService destroyed")
    }
}

/**
 * Offline Driver Manager - Core logic for offline driver operations
 */
class OfflineDriverManager @Inject constructor(
    private val offlineDatabase: OfflineDatabase,
    private val syncQueue: SyncQueue,
    private val shipmentCache: ShipmentCache,
    private val mapsCache: MapsCache
) {

    private val locationUpdates = ConcurrentLinkedQueue<LocationUpdate>()
    private val statusUpdates = ConcurrentLinkedQueue<StatusUpdate>()
    private val driverId = "current_driver" // Would get from auth/session

    suspend fun initializeOfflineMode() {
        try {
            // Load driver's assigned shipments
            loadAssignedShipments()
            
            // Load driver's route data
            loadRouteData()
            
            // Load driver's vehicle information
            loadVehicleInfo()
            
            // Initialize offline settings
            initializeOfflineSettings()
            
            Timber.d("Offline driver mode initialized")
            
        } catch (e: Exception) {
            Timber.e(e, "Error initializing offline driver mode")
            throw e
        }
    }

    suspend fun saveLocationUpdate(location: LocationUpdate) {
        try {
            // Save to local database
            val locationEntity = LocationEntity(
                id = generateLocationId(),
                shipmentId = getCurrentShipmentId(),
                driverId = driverId,
                latitude = location.latitude,
                longitude = location.longitude,
                timestamp = location.timestamp,
                accuracy = location.accuracy,
                speed = location.speed,
                bearing = location.bearing,
                syncStatus = "PENDING"
            )
            
            offlineDatabase.locationDao().insertLocation(locationEntity)
            
            // Add to queue for sync
            val operation = SyncOperation(
                id = generateOperationId(),
                type = OperationType.UPDATE_LOCATION,
                data = location,
                timestamp = System.currentTimeMillis()
            )
            
            syncQueue.enqueue(operation)
            
            // Update maps cache if needed
            updateMapsCache(location)
            
            Timber.d("Location update saved: ${location.latitude}, ${location.longitude}")
            
        } catch (e: Exception) {
            Timber.e(e, "Error saving location update")
        }
    }

    suspend fun updateDriverStatus(status: String) {
        try {
            val statusUpdate = StatusUpdate(
                driverId = driverId,
                status = status,
                timestamp = System.currentTimeMillis(),
                shipmentId = getCurrentShipmentId()
            )
            
            // Save to local database
            offlineDatabase.driverDao().updateDriverStatus(driverId, status)
            
            // Add to queue for sync
            val operation = SyncOperation(
                id = generateOperationId(),
                type = OperationType.UPDATE_STATUS,
                data = statusUpdate,
                timestamp = System.currentTimeMillis()
            )
            
            syncQueue.enqueue(operation)
            
            Timber.d("Driver status updated: $status")
            
        } catch (e: Exception) {
            Timber.e(e, "Error updating driver status")
        }
    }

    suspend fun saveDriverStatus() {
        try {
            // Save current driver status to local database
            val currentStatus = getCurrentDriverStatus()
            offlineDatabase.driverDao().updateDriverStatus(driverId, currentStatus)
            
        } catch (e: Exception) {
            Timber.e(e, "Error saving driver status")
        }
    }

    suspend fun startAutoSync() {
        try {
            // Trigger immediate sync of pending operations
            val pendingOperations = getPendingOperations()
            
            for (operation in pendingOperations) {
                syncQueue.enqueue(operation)
            }
            
            Timber.d("Auto-sync started with ${pendingOperations.size} operations")
            
        } catch (e: Exception) {
            Timber.e(e, "Error starting auto-sync")
        }
    }

    suspend fun getPendingOperations(): List<SyncOperation> {
        return try {
            syncQueue.getPendingOperations()
        } catch (e: Exception) {
            Timber.e(e, "Error getting pending operations")
            emptyList()
        }
    }

    suspend fun finalSync() {
        try {
            // Force sync all pending operations
            val pendingOperations = getPendingOperations()
            
            for (operation in pendingOperations) {
                syncQueue.enqueue(operation)
            }
            
            // Save final driver status
            saveDriverStatus()
            
            Timber.d("Final sync completed with ${pendingOperations.size} operations")
            
        } catch (e: Exception) {
            Timber.e(e, "Error during final sync")
        }
    }

    // Private helper methods

    private suspend fun loadAssignedShipments() {
        try {
            // Load driver's assigned shipments from cache or database
            val shipments = offlineDatabase.shipmentDao().getShipmentsByDriver(driverId).first()
            
            // Preload cache
            shipmentCache.putShipments(shipments)
            
            Timber.d("Loaded ${shipments.size} assigned shipments")
            
        } catch (e: Exception) {
            Timber.e(e, "Error loading assigned shipments")
        }
    }

    private suspend fun loadRouteData() {
        try {
            // Load route data for current shipment
            val currentShipment = getCurrentShipment()
            if (currentShipment != null) {
                val routeKey = generateRouteKey(currentShipment.origin, currentShipment.destination)
                mapsCache.getRoute(routeKey)
            }
            
        } catch (e: Exception) {
            Timber.e(e, "Error loading route data")
        }
    }

    private suspend fun loadVehicleInfo() {
        try {
            // Load vehicle information
            val vehicles = offlineDatabase.vehicleDao().getVehiclesByDriver(driverId)
            
            Timber.d("Loaded ${vehicles.size} vehicles")
            
        } catch (e: Exception) {
            Timber.e(e, "Error loading vehicle info")
        }
    }

    private suspend fun initializeOfflineSettings() {
        try {
            // Set default offline settings
            val settings = listOf(
                OfflineSettingsEntity("offline_mode_enabled", "true"),
                OfflineSettingsEntity("location_tracking_interval", "30"),
                OfflineSettingsEntity("auto_sync_enabled", "true"),
                OfflineSettingsEntity("cache_expiry_hours", "24")
            )
            
            settings.forEach { setting ->
                offlineDatabase.offlineSettingsDao().insertSetting(setting)
            }
            
        } catch (e: Exception) {
            Timber.e(e, "Error initializing offline settings")
        }
    }

    private suspend fun updateMapsCache(location: LocationUpdate) {
        try {
            // Update maps cache with current location
            val locationKey = "current_location"
            mapsCache.putGeocoding(locationKey, "${location.latitude},${location.longitude}")
            
        } catch (e: Exception) {
            Timber.e(e, "Error updating maps cache")
        }
    }

    private suspend fun getCurrentShipmentId(): String {
        return try {
            val shipments = offlineDatabase.shipmentDao().getShipmentsByDriver(driverId).first()
            shipments.firstOrNull { it.status in listOf("ACCEPTED", "PREPARING", "LOADED", "IN_TRANSIT") }?.id ?: ""
        } catch (e: Exception) {
            Timber.e(e, "Error getting current shipment ID")
            ""
        }
    }

    private suspend fun getCurrentShipment(): ShipmentEntity? {
        return try {
            val shipmentId = getCurrentShipmentId()
            if (shipmentId.isNotEmpty()) {
                offlineDatabase.shipmentDao().getShipmentById(shipmentId)
            } else null
        } catch (e: Exception) {
            Timber.e(e, "Error getting current shipment")
            null
        }
    }

    private suspend fun getCurrentDriverStatus(): String {
        return try {
            val driver = offlineDatabase.driverDao().getDriverById(driverId)
            driver?.status ?: "OFFLINE"
        } catch (e: Exception) {
            Timber.e(e, "Error getting current driver status")
            "OFFLINE"
        }
    }

    private fun generateLocationId(): String {
        return "loc_${driverId}_${System.currentTimeMillis()}"
    }

    private fun generateOperationId(): String {
        return "op_${driverId}_${System.currentTimeMillis()}"
    }

    private fun generateRouteKey(origin: String, destination: String): String {
        return "route_${origin.hashCode()}_${destination.hashCode()}"
    }
}

// Data classes for offline driver mode

data class LocationUpdate(
    val latitude: Double,
    val longitude: Double,
    val timestamp: Long,
    val accuracy: Float,
    val speed: Float?,
    val bearing: Float?
)

data class StatusUpdate(
    val driverId: String,
    val status: String,
    val timestamp: Long,
    val shipmentId: String?
)

/**
 * Offline Location Tracker - Handles GPS tracking in offline mode
 */
class OfflineLocationTracker @Inject constructor() {

    private val _locationUpdates = MutableSharedFlow<LocationUpdate>()
    val locationUpdates: SharedFlow<LocationUpdate> = _locationUpdates.asSharedFlow()
    
    private var isTracking = false
    private val trackingScope = CoroutineScope(Dispatchers.IO + SupervisorJob())

    fun startTracking() {
        if (isTracking) return
        
        isTracking = true
        trackingScope.launch {
            while (isActive) {
                try {
                    // Simulate location updates (in real app, use GPS)
                    val location = LocationUpdate(
                        latitude = 24.7136 + (Math.random() * 0.01 - 0.005), // Riyadh area
                        longitude = 46.6753 + (Math.random() * 0.01 - 0.005),
                        timestamp = System.currentTimeMillis(),
                        accuracy = 10.0f,
                        speed = (Math.random() * 60).toFloat(), // 0-60 km/h
                        bearing = (Math.random() * 360).toFloat()
                    )
                    
                    _locationUpdates.emit(location)
                    delay(30000) // Update every 30 seconds
                    
                } catch (e: Exception) {
                    delay(60000) // Wait longer on error
                }
            }
        }
    }

    fun stopTracking() {
        isTracking = false
        trackingScope.cancel()
    }
}
