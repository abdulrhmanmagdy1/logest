package com.edham.logistics.feature.driver.adapters

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import androidx.recyclerview.widget.DiffUtil
import androidx.recyclerview.widget.ListAdapter
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.databinding.ItemTodayTripBinding
import com.edham.logistics.feature.driver.DriverTrip

/**
 * Adapter for Today's Trips with large touch targets
 * Optimized for one-hand usage and high visibility
 */
class TodayTripsAdapter(
    private val onTripClicked: (DriverTrip) -> Unit
) : ListAdapter<DriverTrip, TodayTripsAdapter.TripViewHolder>(TripDiffCallback()) {
    
    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): TripViewHolder {
        val binding = ItemTodayTripBinding.inflate(
            LayoutInflater.from(parent.context),
            parent,
            false
        )
        return TripViewHolder(binding, onTripClicked)
    }
    
    override fun onBindViewHolder(holder: TripViewHolder, position: Int) {
        holder.bind(getItem(position))
    }
    
    class TripViewHolder(
        private val binding: ItemTodayTripBinding,
        private val onTripClicked: (DriverTrip) -> Unit
    ) : RecyclerView.ViewHolder(binding.root) {
        
        fun bind(trip: DriverTrip) {
            binding.apply {
                // Set trip details
                tvDestination.text = trip.destinationAddress
                tvCustomerName.text = trip.customerName
                tvTime.text = trip.startTime
                tvDuration.text = trip.estimatedDuration
                
                // Set priority indicator with high visibility colors
                val priorityColor = when (trip.priority.uppercase()) {
                    "HIGH" -> R.color.priority_high
                    "MEDIUM" -> R.color.priority_medium
                    "LOW" -> R.color.priority_low
                    else -> R.color.priority_default
                }
                
                viewPriorityIndicator.setBackgroundColor(
                    itemView.context.getColor(priorityColor)
                )
                
                tvPriority.text = trip.priority
                tvPriority.setTextColor(itemView.context.getColor(priorityColor))
                
                // Set status with high visibility colors
                val statusColor = when (trip.status.uppercase()) {
                    "ACTIVE" -> R.color.status_active
                    "COMPLETED" -> R.color.status_completed
                    "CANCELLED" -> R.color.status_cancelled
                    "PENDING" -> R.color.status_pending
                    else -> R.color.status_default
                }
                
                viewStatusIndicator.setBackgroundColor(
                    itemView.context.getColor(statusColor)
                )
                
                tvStatus.text = trip.status
                tvStatus.setTextColor(itemView.context.getColor(statusColor))
                
                // Set large touch target
                root.minimumHeight = 80.dp
                root.minimumWidth = 120.dp
                
                // Set click listener
                root.setOnClickListener {
                    onTripClicked(trip)
                }
                
                // Set long click for additional options
                root.setOnLongClickListener {
                    showTripOptions(trip)
                    true
                }
                
                // Animate item entrance
                root.alpha = 0f
                root.animate()
                    .alpha(1f)
                    .setDuration(300)
                    .start()
            }
        }
        
        private fun showTripOptions(trip: DriverTrip) {
            // Show trip options dialog
            // Navigate, Call Customer, etc.
        }
        
        // Extension for dp to pixels
        private val Int.dp: Int
            get() = (this * itemView.context.resources.displayMetrics.density).toInt()
    }
}

/**
 * DiffUtil callback for efficient list updates
 */
class TripDiffCallback : DiffUtil.ItemCallback<DriverTrip>() {
    override fun areItemsTheSame(oldItem: DriverTrip, newItem: DriverTrip): Boolean {
        return oldItem.id == newItem.id
    }
    
    override fun areContentsTheSame(oldItem: DriverTrip, newItem: DriverTrip): Boolean {
        return oldItem == newItem
    }
}
