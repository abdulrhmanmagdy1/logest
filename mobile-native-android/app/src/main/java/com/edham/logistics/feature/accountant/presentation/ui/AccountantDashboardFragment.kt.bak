package com.edham.logistics.feature.accountant.presentation.ui

import android.os.Bundle
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import androidx.fragment.app.Fragment
import androidx.fragment.app.viewModels
import androidx.lifecycle.lifecycleScope
import androidx.navigation.fragment.findNavController
import androidx.recyclerview.widget.LinearLayoutManager
import com.edham.logistics.core.extensions.gone
import com.edham.logistics.core.extensions.visible
import com.edham.logistics.core.extensions.showSnackbar
import com.edham.logistics.databinding.FragmentAccountantDashboardBinding
import com.edham.logistics.feature.accountant.presentation.ui.AccountantDashboardViewModel
import com.edham.logistics.feature.accountant.presentation.adapter.InvoicesAdapter
import com.edham.logistics.feature.accountant.presentation.adapter.PaymentsAdapter
import com.edham.logistics.feature.accountant.presentation.adapter.DebtsAdapter
import com.edham.logistics.feature.accountant.presentation.adapter.MonthlyRevenueAdapter
import dagger.hilt.android.AndroidEntryPoint
import kotlinx.coroutines.launch
import javax.inject.Inject

@AndroidEntryPoint
class AccountantDashboardFragment : Fragment() {

    private var _binding: FragmentAccountantDashboardBinding? = null
    private val binding get() = _binding!!
    
    private val viewModel: AccountantDashboardViewModel by viewModels()
    
    @Inject
    lateinit var invoicesAdapter: InvoicesAdapter
    
    @Inject
    lateinit var paymentsAdapter: PaymentsAdapter
    
    @Inject
    lateinit var debtsAdapter: DebtsAdapter
    
    @Inject
    lateinit var monthlyRevenueAdapter: MonthlyRevenueAdapter

    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View {
        _binding = FragmentAccountantDashboardBinding.inflate(inflater, container, false)
        return binding.root
    }

    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        setupAdapters()
        observeViewModel()
        setupClickListeners()
        
        // Initialize dashboard
        viewModel.initialize()
    }

    private fun setupAdapters() {
        invoicesAdapter = InvoicesAdapter { invoice, action ->
            when (action) {
                "details" -> navigateToInvoiceDetails(invoice.id)
                "edit" -> navigateToEditInvoice(invoice.id)
                "payment" -> navigateToRecordPayment(invoice.id)
            }
        }
        
        monthlyRevenueAdapter = MonthlyRevenueAdapter()
        
        // Setup RecyclerViews
        binding.rvRecentInvoices.apply {
            adapter = invoicesAdapter
            layoutManager = LinearLayoutManager(requireContext())
        }
    }

    private fun observeViewModel() {
        viewLifecycleOwner.lifecycleScope.launch {
            viewModel.uiState.collect { uiState ->
                updateUI(uiState)
            }
        }
    }

    private fun setupClickListeners() {
        // Simplified - layout doesn't have these buttons
    }

    private fun updateUI(uiState: AccountantDashboardViewModel.AccountantDashboardUiState) {
        when {
            uiState.isLoading -> {
                // Show loading state if needed
            }
            uiState.error != null -> {
                // Show error state if needed
            }
            else -> {
                uiState.dashboardData?.let { dashboard ->
                    updateRecentInvoices(dashboard.recentInvoices)
                }
            }
        }
    }

    private fun updateRecentInvoices(invoices: List<com.edham.logistics.feature.accountant.domain.model.Invoice>) {
        invoicesAdapter.submitList(invoices.take(5))
    }

    // Navigation methods - simplified for now
    private fun navigateToInvoiceDetails(invoiceId: String) {
        // TODO: Implement navigation
    }

    override fun onDestroyView() {
        super.onDestroyView()
        _binding = null
    }
}
