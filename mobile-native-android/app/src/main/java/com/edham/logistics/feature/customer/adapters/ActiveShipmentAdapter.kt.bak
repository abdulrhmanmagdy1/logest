package com.edham.logistics.feature.customer.adapters

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.ImageView
import android.widget.TextView
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.data.local.entity.Shipment
import java.text.SimpleDateFormat
import java.util.*

class ActiveShipmentAdapter(
    private val onShipmentClick: (Shipment) -> Unit
) : RecyclerView.Adapter<ActiveShipmentAdapter.ViewHolder>() {
    
    private var shipments = mutableListOf<Shipment>()
    private val dateFormat = SimpleDateFormat("MMM dd", Locale.getDefault())
    private val timeFormat = SimpleDateFormat("HH:mm", Locale.getDefault())
    
    fun updateShipments(newShipments: List<Shipment>) {
        shipments.clear()
        shipments.addAll(newShipments)
        notifyDataSetChanged()
    }
    
    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): ViewHolder {
        val view = LayoutInflater.from(parent.context).inflate(R.layout.item_active_shipment, parent, false)
        return ViewHolder(view)
    }
    
    override fun onBindViewHolder(holder: ViewHolder, position: Int) {
        holder.bind(shipments[position])
    }
    
    override fun getItemCount(): Int = shipments.size
    
    inner class ViewHolder(itemView: View) : RecyclerView.ViewHolder(itemView) {
        private val statusIndicator: View = itemView.findViewById(R.id.statusIndicator)
        private val shipmentIcon: ImageView = itemView.findViewById(R.id.shipmentIcon)
        private val trackingNumber: TextView = itemView.findViewById(R.id.trackingNumber)
        private val shipmentStatus: TextView = itemView.findViewById(R.id.shipmentStatus)
        private val destination: TextView = itemView.findViewById(R.id.destination)
        private val eta: TextView = itemView.findViewById(R.id.eta)
        private val progress: TextView = itemView.findViewById(R.id.progress)
        private val date: TextView = itemView.findViewById(R.id.date)
        
        fun bind(shipment: Shipment) {
            // Set status indicator and icon
            val (colorRes, iconRes, statusText) = when (shipment.status) {
                "created" -> Triple(R.color.status_created, R.drawable.ic_package_created, "Created")
                "picked_up" -> Triple(R.color.status_picked_up, R.drawable.ic_package_picked_up, "Picked Up")
                "in_transit" -> Triple(R.color.status_in_transit, R.drawable.ic_package_transit, "In Transit")
                "out_for_delivery" -> Triple(R.color.status_out_for_delivery, R.drawable.ic_package_delivery, "Out for Delivery")
                "delivered" -> Triple(R.color.status_delivered, R.drawable.ic_package_delivered, "Delivered")
                "delayed" -> Triple(R.color.status_delayed, R.drawable.ic_package_delayed, "Delayed")
                "cancelled" -> Triple(R.color.status_cancelled, R.drawable.ic_package_cancelled, "Cancelled")
                else -> Triple(R.color.status_unknown, R.drawable.ic_package_unknown, "Unknown")
            }
            
            statusIndicator.setBackgroundColor(itemView.context.getColor(colorRes))
            shipmentIcon.setImageResource(iconRes)
            shipmentStatus.text = statusText
            shipmentStatus.setTextColor(itemView.context.getColor(colorRes))
            
            // Set shipment details
            trackingNumber.text = shipment.trackingNumber
            destination.text = shipment.destinationAddress
            eta.text = timeFormat.format(Date(shipment.estimatedTime))
            
            // Calculate progress
            val progressPercent = calculateProgress(shipment)
            progress.text = "${progressPercent}%"
            
            // Set date
            date.text = dateFormat.format(Date(shipment.createdAt))
            
            // Set click listener
            itemView.setOnClickListener {
                onShipmentClick(shipment)
            }
            
            // Set background based on status
            val backgroundColor = when (shipment.status) {
                "delivered" -> itemView.context.getColor(R.color.shipment_delivered_bg)
                "delayed" -> itemView.context.getColor(R.color.shipment_delayed_bg)
                "cancelled" -> itemView.context.getColor(R.color.shipment_cancelled_bg)
                else -> itemView.context.getColor(R.color.shipment_active_bg)
            }
            
            itemView.setBackgroundColor(backgroundColor)
        }
        
        private fun calculateProgress(shipment: Shipment): Int {
            return when (shipment.status) {
                "created" -> 0
                "picked_up" -> 20
                "in_transit" -> 50
                "out_for_delivery" -> 80
                "delivered" -> 100
                "delayed" -> 50
                "cancelled" -> 0
                else -> 0
            }
        }
    }
}
