package com.edham.logistics.notification

import android.content.Context
import com.edham.logistics.data.local.database.EdhamDatabase
import com.edham.logistics.data.remote.api.SensorApi
import com.edham.logistics.utils.NetworkUtils
import kotlinx.coroutines.Dispatchers
import kotlinx.coroutines.flow.MutableStateFlow
import kotlinx.coroutines.flow.StateFlow
import kotlinx.coroutines.flow.asStateFlow
import kotlinx.coroutines.withContext
import java.util.*
import javax.inject.Inject
import javax.inject.Singleton

/**
 * Temperature Alert Service - Specialized service for temperature-related alerts
 * 
 * Features:
 * - Real-time temperature monitoring
 * - Temperature threshold management
 * - Temperature violation detection
 * - Multi-sensor support
 * - Temperature trend analysis
 * - Critical temperature alerts
 * - Temperature recovery alerts
 * - Sensor health monitoring
 * - Temperature analytics and reporting
 */
// Temporarily disabled due to missing dependencies
// @Singleton
// class TemperatureAlertService @Inject constructor(
//     private val context: Context,
//     private val database: EdhamDatabase,
//     private val sensorApi: SensorApi,
//     private val networkUtils: NetworkUtils,
//     private val smartNotificationManager: SmartNotificationManager
// ) {
class TemperatureAlertService {
    
    private val _temperatureAlertState = MutableStateFlow<TemperatureAlertState>(TemperatureAlertState.Idle)
    val temperatureAlertState: StateFlow<TemperatureAlertState> = _temperatureAlertState.asStateFlow()
    
    private val _activeTemperatureAlerts = MutableStateFlow<List<TemperatureAlert>>(emptyList())
    val activeTemperatureAlerts: StateFlow<List<TemperatureAlert>> = _activeTemperatureAlerts.asStateFlow()
    
    private val _temperatureAnalytics = MutableStateFlow<TemperatureAnalytics>(TemperatureAnalytics())
    val temperatureAnalytics: StateFlow<TemperatureAnalytics> = _temperatureAnalytics.asStateFlow()
    
    private val _sensorStatus = MutableStateFlow<Map<String, SensorStatus>>(emptyMap())
    val sensorStatus: StateFlow<Map<String, SensorStatus>> = _sensorStatus.asStateFlow()
    
    private var isInitialized = false
    private val temperatureAlertListeners = mutableListOf<TemperatureAlertListener>()
    
    companion object {
        private const val TAG = "TemperatureAlertService"
        private const val MINOR_VIOLATION_THRESHOLD = 2.0f
        private const val MODERATE_VIOLATION_THRESHOLD = 5.0f
        private const val SEVERE_VIOLATION_THRESHOLD = 10.0f
        private const val CRITICAL_VIOLATION_THRESHOLD = 15.0f
        private const val TEMPERATURE_MONITORING_INTERVAL_MS = 30000L // 30 seconds
        private const val SENSOR_OFFLINE_THRESHOLD_MS = 300000L // 5 minutes
        private const val MAX_ACTIVE_TEMPERATURE_ALERTS = 100
    }
    
    /**
     * Initialize temperature alert service
     */
    suspend fun initialize(): Result<Boolean> {
        return withContext(Dispatchers.IO) {
            try {
                _temperatureAlertState.value = TemperatureAlertState.Initializing
                
                // Load temperature alert configuration
                loadTemperatureAlertConfiguration()
                
                // Initialize sensor monitoring
                initializeSensorMonitoring()
                
                // Load active temperature alerts
                loadActiveTemperatureAlerts()
                
                // Load sensor status
                loadSensorStatus()
                
                // Start temperature monitoring
                startTemperatureMonitoring()
                
                isInitialized = true
                _temperatureAlertState.value = TemperatureAlertState.Ready
                Result.success(true)
                
            } catch (e: Exception) {
                _temperatureAlertState.value = TemperatureAlertState.Error("Failed to initialize temperature alert service: ${e.message}")
                Result.failure(e)
            }
        }
    }
    
    /**
     * Create temperature alert
     */
    suspend fun createTemperatureAlert(
        sensorId: String,
        temperatureData: TemperatureAlertData
    ): Result<TemperatureAlert> {
        return withContext(Dispatchers.IO) {
            try {
                if (!isInitialized) {
                    throw Exception("Temperature alert service not initialized")
                }
                
                // Validate temperature data
                validateTemperatureAlertData(sensorId, temperatureData)
                
                // Determine alert severity
                val severity = determineTemperatureSeverity(temperatureData.currentTemperature, temperatureData.threshold)
                
                // Check for duplicate alerts
                if (isDuplicateTemperatureAlert(sensorId, severity)) {
                    throw Exception("Duplicate temperature alert detected")
                }
                
                // Create alert
                val alert = TemperatureAlert(
                    id = UUID.randomUUID().toString(),
                    sensorId = sensorId,
                    severity = severity,
                    currentTemperature = temperatureData.currentTemperature,
                    threshold = temperatureData.threshold,
                    unit = temperatureData.unit,
                    location = temperatureData.location,
                    violationDegree = calculateViolationDegree(temperatureData.currentTemperature, temperatureData.threshold),
                    trend = temperatureData.trend,
                    recipients = determineTemperatureRecipients(sensorId, severity, temperatureData),
                    metadata = temperatureData.toMetadata(),
                    status = TemperatureAlertStatus.ACTIVE,
                    createdAt = Date(),
                    updatedAt = Date(),
                    acknowledgedAt = null,
                    acknowledgedBy = null,
                    resolvedAt = null,
                    resolvedBy = null,
                    resolution = null
                )
                
                // Save alert to database
                database.temperatureAlertDao().insertAlert(alert.toEntity())
                
                // Add to active alerts
                addToActiveTemperatureAlerts(alert)
                
                // Process alert
                processTemperatureAlert(alert)
                
                // Update analytics
                updateTemperatureAnalytics()
                
                // Notify listeners
                notifyTemperatureAlertCreated(alert)
                
                Result.success(alert)
                
            } catch (e: Exception) {
                Result.failure(e)
            }
        }
    }
    
    /**
     * Handle temperature reading
     */
    suspend fun handleTemperatureReading(
        sensorId: String,
        temperature: Float,
        unit: String,
        timestamp: Date
    ): Result<List<TemperatureAlert>> {
        return withContext(Dispatchers.IO) {
            try {
                val alerts = mutableListOf<TemperatureAlert>()
                
                // Get sensor configuration
                val sensor = database.sensorDao().getSensorById(sensorId)
                    ?: throw Exception("Sensor not found")
                
                // Check for temperature violation
                val violation = checkTemperatureViolation(temperature, sensor.threshold, unit)
                
                if (violation.isViolation) {
                    // Get temperature trend
                    val trend = calculateTemperatureTrend(sensorId, temperature, timestamp)
                    
                    // Create temperature alert data
                    val temperatureData = TemperatureAlertData(
                        sensorId = sensorId,
                        currentTemperature = temperature,
                        threshold = sensor.threshold,
                        unit = unit,
                        location = sensor.location,
                        trend = trend,
                        isCritical = violation.severity == TemperatureViolationSeverity.CRITICAL,
                        metadata = mapOf(
                            "sensorName" to sensor.name,
                            "sensorType" to sensor.type,
                            "violationDegree" to violation.degree.toString()
                        )
                    )
                    
                    val alertResult = createTemperatureAlert(sensorId, temperatureData)
                    if (alertResult.isSuccess) {
                        alerts.add(alertResult.getOrThrow())
                    }
                }
                
                // Update sensor status
                updateSensorStatus(sensorId, SensorStatus.ONLINE, timestamp)
                
                Result.success(alerts)
                
            } catch (e: Exception) {
                Result.failure(e)
            }
        }
    }
    
    /**
     * Handle sensor offline
     */
    suspend fun handleSensorOffline(
        sensorId: String,
        lastSeen: Date
    ): Result<TemperatureAlert> {
        return withContext(Dispatchers.IO) {
            try {
                // Get sensor details
                val sensor = database.sensorDao().getSensorById(sensorId)
                    ?: throw Exception("Sensor not found")
                
                // Create sensor offline alert
                val temperatureData = TemperatureAlertData(
                    sensorId = sensorId,
                    currentTemperature = 0f,
                    threshold = sensor.threshold,
                    unit = sensor.unit,
                    location = sensor.location,
                    trend = TemperatureTrend.UNKNOWN,
                    isCritical = true,
                    metadata = mapOf(
                        "alertType" to "SENSOR_OFFLINE",
                        "lastSeen" to lastSeen.toString(),
                        "sensorName" to sensor.name,
                        "sensorType" to sensor.type
                    )
                )
                
                val alertResult = createTemperatureAlert(sensorId, temperatureData)
                
                // Update sensor status
                updateSensorStatus(sensorId, SensorStatus.OFFLINE, lastSeen)
                
                alertResult
                
            } catch (e: Exception) {
                Result.failure(e)
            }
        }
    }
    
    /**
     * Handle temperature recovery
     */
    suspend fun handleTemperatureRecovery(
        sensorId: String,
        currentTemperature: Float,
        threshold: Float,
        unit: String
    ): Result<Boolean> {
        return withContext(Dispatchers.IO) {
            try {
                // Get active alerts for this sensor
                val activeAlerts = _activeTemperatureAlerts.value.filter { 
                    it.sensorId == sensorId && it.status == TemperatureAlertStatus.ACTIVE 
                }
                
                // Resolve all active alerts
                activeAlerts.forEach { alert ->
                    resolveTemperatureAlert(
                        alert.id,
                        "SYSTEM",
                        "Temperature returned to normal range: $currentTemperature$unit",
                        currentTemperature
                    )
                }
                
                // Update sensor status
                updateSensorStatus(sensorId, SensorStatus.ONLINE, Date())
                
                Result.success(true)
                
            } catch (e: Exception) {
                Result.failure(e)
            }
        }
    }
    
    /**
     * Update temperature threshold
     */
    suspend fun updateTemperatureThreshold(
        sensorId: String,
        newThreshold: Float
    ): Result<Boolean> {
        return withContext(Dispatchers.IO) {
            try {
                // Update sensor threshold in database
                database.sensorDao().updateThreshold(sensorId, newThreshold)
                
                // Check for existing violations with new threshold
                val currentReading = database.sensorReadingDao().getLatestReading(sensorId)
                currentReading?.let { reading ->
                    val violation = checkTemperatureViolation(reading.temperature, newThreshold, reading.unit)
                    if (violation.isViolation) {
                        // Create new alert if violation exists
                        val sensor = database.sensorDao().getSensorById(sensorId)
                        sensor?.let {
                            val temperatureData = TemperatureAlertData(
                                sensorId = sensorId,
                                currentTemperature = reading.temperature,
                                threshold = newThreshold,
                                unit = reading.unit,
                                location = sensor.location,
                                trend = TemperatureTrend.UNKNOWN,
                                isCritical = violation.severity == TemperatureViolationSeverity.CRITICAL,
                                metadata = mapOf(
                                    "alertType" to "THRESHOLD_UPDATE",
                                    "oldThreshold" to sensor.threshold.toString(),
                                    "newThreshold" to newThreshold.toString()
                                )
                            )
                            
                            createTemperatureAlert(sensorId, temperatureData)
                        }
                    }
                }
                
                Result.success(true)
                
            } catch (e: Exception) {
                Result.failure(e)
            }
        }
    }
    
    /**
     * Resolve temperature alert
     */
    suspend fun resolveTemperatureAlert(
        alertId: String,
        resolvedBy: String,
        resolution: String,
        finalTemperature: Float
    ): Result<Boolean> {
        return withContext(Dispatchers.IO) {
            try {
                // Get alert
                val alert = _activeTemperatureAlerts.value.find { it.id == alertId }
                    ?: throw Exception("Temperature alert not found")
                
                // Update alert status
                val resolvedAlert = alert.copy(
                    status = TemperatureAlertStatus.RESOLVED,
                    resolvedAt = Date(),
                    resolvedBy = resolvedBy,
                    resolution = resolution,
                    finalTemperature = finalTemperature,
                    updatedAt = Date()
                )
                
                // Update in database
                database.temperatureAlertDao().updateAlert(resolvedAlert.toEntity())
                
                // Remove from active alerts
                removeFromActiveTemperatureAlerts(alertId)
                
                // Update analytics
                updateTemperatureAnalytics()
                
                // Notify listeners
                notifyTemperatureAlertResolved(resolvedAlert)
                
                Result.success(true)
                
            } catch (e: Exception) {
                Result.failure(e)
            }
        }
    }
    
    /**
     * Get temperature alerts by severity
     */
    suspend fun getTemperatureAlertsBySeverity(severity: TemperatureSeverity): List<TemperatureAlert> {
        return _activeTemperatureAlerts.value.filter { it.severity == severity }
    }
    
    /**
     * Get temperature alerts by sensor
     */
    suspend fun getTemperatureAlertsBySensor(sensorId: String): List<TemperatureAlert> {
        return _activeTemperatureAlerts.value.filter { it.sensorId == sensorId }
    }
    
    /**
     * Get active temperature alerts
     */
    suspend fun getActiveTemperatureAlerts(): List<TemperatureAlert> {
        return _activeTemperatureAlerts.value.filter { it.status == TemperatureAlertStatus.ACTIVE }
    }
    
    /**
     * Get temperature analytics
     */
    suspend fun getTemperatureAnalytics(dateRange: DateRange = DateRange.last30Days()): Result<TemperatureAnalytics> {
        return withContext(Dispatchers.IO) {
            try {
                val analytics = database.temperatureAlertDao().getTemperatureAnalytics(dateRange.startDate, dateRange.endDate)
                Result.success(analytics)
            } catch (e: Exception) {
                Result.failure(e)
            }
        }
    }
    
    /**
     * Add temperature alert listener
     */
    fun addTemperatureAlertListener(listener: TemperatureAlertListener) {
        temperatureAlertListeners.add(listener)
    }
    
    /**
     * Remove temperature alert listener
     */
    fun removeTemperatureAlertListener(listener: TemperatureAlertListener) {
        temperatureAlertListeners.remove(listener)
    }
    
    /**
     * Helper functions
     */
    private suspend fun loadTemperatureAlertConfiguration() {
        // Load temperature alert configuration
    }
    
    private suspend fun initializeSensorMonitoring() {
        // Initialize sensor monitoring
    }
    
    private suspend fun loadActiveTemperatureAlerts() {
        try {
            val alerts = database.temperatureAlertDao().getActiveAlerts()
                .map { it.toDomainModel() }
                .sortedByDescending { it.createdAt }
                .take(MAX_ACTIVE_TEMPERATURE_ALERTS)
            
            _activeTemperatureAlerts.value = alerts
        } catch (e: Exception) {
            // Handle error
        }
    }
    
    private suspend fun loadSensorStatus() {
        try {
            val sensors = database.sensorDao().getAllSensors()
            val statusMap = sensors.associate { sensor ->
                sensor.id to SensorStatus(
                    sensorId = sensor.id,
                    status = SensorConnectionStatus.ONLINE,
                    lastReading = Date(),
                    batteryLevel = null,
                    signalStrength = null
                )
            }
            _sensorStatus.value = statusMap
        } catch (e: Exception) {
            // Handle error
        }
    }
    
    private suspend fun startTemperatureMonitoring() {
        // Start temperature monitoring
    }
    
    private fun validateTemperatureAlertData(sensorId: String, temperatureData: TemperatureAlertData) {
        if (sensorId.isBlank()) throw Exception("Sensor ID cannot be empty")
        if (temperatureData.unit.isBlank()) throw Exception("Temperature unit cannot be empty")
    }
    
    private fun checkTemperatureViolation(
        temperature: Float,
        threshold: Float,
        unit: String
    ): TemperatureViolation {
        val difference = kotlin.math.abs(temperature - threshold)
        val severity = when {
            difference >= CRITICAL_VIOLATION_THRESHOLD -> TemperatureViolationSeverity.CRITICAL
            difference >= SEVERE_VIOLATION_THRESHOLD -> TemperatureViolationSeverity.SEVERE
            difference >= MODERATE_VIOLATION_THRESHOLD -> TemperatureViolationSeverity.MODERATE
            difference >= MINOR_VIOLATION_THRESHOLD -> TemperatureViolationSeverity.MINOR
            else -> TemperatureViolationSeverity.NONE
        }
        
        return TemperatureViolation(
            isViolation = severity != TemperatureViolationSeverity.NONE,
            severity = severity,
            degree = difference,
            isAboveThreshold = temperature > threshold,
            isBelowThreshold = temperature < threshold
        )
    }
    
    private fun calculateViolationDegree(currentTemperature: Float, threshold: Float): Float {
        return kotlin.math.abs(currentTemperature - threshold)
    }
    
    private fun calculateTemperatureTrend(
        sensorId: String,
        currentTemperature: Float,
        timestamp: Date
    ): TemperatureTrend {
        try {
            // Get recent readings for trend analysis
            val recentReadings = database.sensorReadingDao().getRecentReadings(sensorId, 10)
            
            if (recentReadings.size < 3) {
                return TemperatureTrend.UNKNOWN
            }
            
            // Calculate trend using linear regression
            val timePoints = recentReadings.mapIndexed { index, reading ->
                index.toFloat()
            }
            val temperatures = recentReadings.map { it.temperature }
            
            val slope = calculateLinearRegressionSlope(timePoints, temperatures)
            
            return when {
                slope > 0.5f -> TemperatureTrend.RISING
                slope < -0.5f -> TemperatureTrend.FALLING
                else -> TemperatureTrend.STABLE
            }
            
        } catch (e: Exception) {
            return TemperatureTrend.UNKNOWN
        }
    }
    
    private fun calculateLinearRegressionSlope(x: List<Float>, y: List<Float>): Float {
        val n = x.size
        val sumX = x.sum()
        val sumY = y.sum()
        val sumXY = x.zip(y) { a, b -> a * b }.sum()
        val sumX2 = x.map { it * it }.sum()
        
        return (n * sumXY - sumX * sumY) / (n * sumX2 - sumX * sumX)
    }
    
    private fun determineTemperatureSeverity(
        currentTemperature: Float,
        threshold: Float
    ): TemperatureSeverity {
        val violation = checkTemperatureViolation(currentTemperature, threshold, "C")
        return when (violation.severity) {
            TemperatureViolationSeverity.CRITICAL -> TemperatureSeverity.CRITICAL
            TemperatureViolationSeverity.SEVERE -> TemperatureSeverity.SEVERE
            TemperatureViolationSeverity.MODERATE -> TemperatureSeverity.MODERATE
            TemperatureViolationSeverity.MINOR -> TemperatureSeverity.MINOR
            TemperatureViolationSeverity.NONE -> TemperatureSeverity.NORMAL
        }
    }
    
    private fun isDuplicateTemperatureAlert(sensorId: String, severity: TemperatureSeverity): Boolean {
        val cutoffTime = Date(System.currentTimeMillis() - 2 * 60 * 1000L) // 2 minutes
        return _activeTemperatureAlerts.value.any { alert ->
            alert.sensorId == sensorId &&
            alert.severity == severity &&
            alert.createdAt.after(cutoffTime)
        }
    }
    
    private fun determineTemperatureRecipients(
        sensorId: String,
        severity: TemperatureSeverity,
        temperatureData: TemperatureAlertData
    ): List<NotificationRecipient> {
        val recipients = mutableListOf<NotificationRecipient>()
        
        // Get sensor details
        val sensor = database.sensorDao().getSensorById(sensorId)
        
        // Always notify admin for critical alerts
        if (severity == TemperatureSeverity.CRITICAL) {
            recipients.add(
                NotificationRecipient(
                    id = "temperature_admin",
                    type = RecipientType.ADMIN,
                    address = "admin@edham.com",
                    name = "Temperature Admin"
                )
            )
        }
        
        // Notify responsible parties based on sensor location
        sensor?.let {
            when (it.type) {
                "VEHICLE" -> {
                    // Notify driver and fleet manager
                    val vehicle = database.vehicleDao().getVehicleBySensorId(sensorId)
                    vehicle?.driverId?.let { driverId ->
                        recipients.add(
                            NotificationRecipient(
                                id = driverId,
                                type = RecipientType.DRIVER,
                                address = "",
                                name = "Driver"
                            )
                        )
                    }
                }
                "WAREHOUSE" -> {
                    // Notify warehouse manager
                    recipients.add(
                        NotificationRecipient(
                            id = "warehouse_manager",
                            type = RecipientType.ADMIN,
                            address = "warehouse@edham.com",
                            name = "Warehouse Manager"
                        )
                    )
                }
                "CONTAINER" -> {
                    // Notify logistics team
                    recipients.add(
                        NotificationRecipient(
                            id = "logistics_team",
                            type = RecipientType.ADMIN,
                            address = "logistics@edham.com",
                            name = "Logistics Team"
                        )
                    )
                }
            }
        }
        
        return recipients
    }
    
    private suspend fun processTemperatureAlert(alert: TemperatureAlert) {
        try {
            // Create notification request
            val notificationRequest = NotificationRequest(
                title = generateAlertTitle(alert),
                message = generateAlertMessage(alert),
                category = NotificationCategory.TEMPERATURE,
                priority = mapSeverityToPriority(alert.severity),
                recipients = alert.recipients,
                data = alert.metadata + mapOf(
                    "alertId" to alert.id,
                    "sensorId" to alert.sensorId,
                    "currentTemperature" to alert.currentTemperature.toString(),
                    "threshold" to alert.threshold.toString(),
                    "unit" to alert.unit,
                    "violationDegree" to alert.violationDegree.toString()
                ),
                channels = determineNotificationChannels(alert)
            )
            
            // Send notification
            smartNotificationManager.sendNotification(notificationRequest)
            
        } catch (e: Exception) {
            // Handle error
        }
    }
    
    private fun generateAlertTitle(alert: TemperatureAlert): String {
        return when (alert.severity) {
            TemperatureSeverity.NORMAL -> "درجة حرارة طبيعية"
            TemperatureSeverity.MINOR -> "انحراف طفيف في درجة الحرارة"
            TemperatureSeverity.MODERATE -> "انحراف متوسط في درجة الحرارة"
            TemperatureSeverity.SEVERE -> "انحراف شديد في درجة الحرارة"
            TemperatureSeverity.CRITICAL -> "انتهاك حرجة حرارة حرج"
        }
    }
    
    private fun generateAlertMessage(alert: TemperatureAlert): String {
        val direction = if (alert.currentTemperature > alert.threshold) "فوق" else "تحت"
        return """
            درجة الحرارة ${alert.currentTemperature}${alert.unit} $direction الحد المسموح (${alert.threshold}${alert.unit}).
            الموقع: ${alert.location}
            درجة الانتهاك: ${alert.violationDegree}${alert.unit}
            ${if (alert.isCritical) "⚠️ حالة حرجة" else ""}
        """.trimIndent()
    }
    
    private fun mapSeverityToPriority(severity: TemperatureSeverity): NotificationPriority {
        return when (severity) {
            TemperatureSeverity.NORMAL -> NotificationPriority.NORMAL
            TemperatureSeverity.MINOR -> NotificationPriority.NORMAL
            TemperatureSeverity.MODERATE -> NotificationPriority.HIGH
            TemperatureSeverity.SEVERE -> NotificationPriority.HIGH
            TemperatureSeverity.CRITICAL -> NotificationPriority.EMERGENCY
        }
    }
    
    private fun determineNotificationChannels(alert: TemperatureAlert): List<NotificationChannel> {
        return when (alert.severity) {
            TemperatureSeverity.CRITICAL -> listOf(
                NotificationChannel.PUSH,
                NotificationChannel.SMS,
                NotificationChannel.EMAIL,
                NotificationChannel.IN_APP
            )
            TemperatureSeverity.SEVERE -> listOf(
                NotificationChannel.PUSH,
                NotificationChannel.SMS,
                NotificationChannel.EMAIL
            )
            TemperatureSeverity.MODERATE -> listOf(
                NotificationChannel.PUSH,
                NotificationChannel.EMAIL
            )
            TemperatureSeverity.MINOR -> listOf(
                NotificationChannel.PUSH,
                NotificationChannel.IN_APP
            )
            TemperatureSeverity.NORMAL -> listOf(
                NotificationChannel.IN_APP
            )
        }
    }
    
    private suspend fun updateSensorStatus(sensorId: String, status: SensorConnectionStatus, timestamp: Date) {
        try {
            val currentStatus = _sensorStatus.value[sensorId]
            val updatedStatus = currentStatus?.copy(
                status = status,
                lastReading = timestamp
            ) ?: SensorStatus(
                sensorId = sensorId,
                status = status,
                lastReading = timestamp,
                batteryLevel = null,
                signalStrength = null
            )
            
            val statusMap = _sensorStatus.value.toMutableMap()
            statusMap[sensorId] = updatedStatus
            _sensorStatus.value = statusMap
            
        } catch (e: Exception) {
            // Handle error
        }
    }
    
    private fun addToActiveTemperatureAlerts(alert: TemperatureAlert) {
        val currentAlerts = _activeTemperatureAlerts.value.toMutableList()
        currentAlerts.add(0, alert)
        
        // Keep only max alerts
        if (currentAlerts.size > MAX_ACTIVE_TEMPERATURE_ALERTS) {
            currentAlerts.removeAt(currentAlerts.size - 1)
        }
        
        _activeTemperatureAlerts.value = currentAlerts
    }
    
    private fun removeFromActiveTemperatureAlerts(alertId: String) {
        val currentAlerts = _activeTemperatureAlerts.value.toMutableList()
        currentAlerts.removeAll { it.id == alertId }
        _activeTemperatureAlerts.value = currentAlerts
    }
    
    private suspend fun updateTemperatureAnalytics() {
        try {
            val alerts = _activeTemperatureAlerts.value
            val analytics = TemperatureAnalytics(
                totalActive = alerts.size,
                normalAlerts = alerts.count { it.severity == TemperatureSeverity.NORMAL },
                minorAlerts = alerts.count { it.severity == TemperatureSeverity.MINOR },
                moderateAlerts = alerts.count { it.severity == TemperatureSeverity.MODERATE },
                severeAlerts = alerts.count { it.severity == TemperatureSeverity.SEVERE },
                criticalAlerts = alerts.count { it.severity == TemperatureSeverity.CRITICAL },
                averageViolationDegree = if (alerts.isNotEmpty()) alerts.map { it.violationDegree }.average().toFloat() else 0f,
                sensorStats = alerts.groupBy { it.sensorId }
                    .mapValues { it.value.size },
                locationStats = alerts.groupBy { it.location }
                    .mapValues { it.value.size }
            )
            
            _temperatureAnalytics.value = analytics
            
        } catch (e: Exception) {
            // Handle error
        }
    }
    
    private fun notifyTemperatureAlertCreated(alert: TemperatureAlert) {
        temperatureAlertListeners.forEach { listener ->
            listener.onTemperatureAlertCreated(alert)
        }
    }
    
    private fun notifyTemperatureAlertResolved(alert: TemperatureAlert) {
        temperatureAlertListeners.forEach { listener ->
            listener.onTemperatureAlertResolved(alert)
        }
    }
    
    /**
     * Get initialization status
     */
    fun isInitialized(): Boolean = isInitialized
}

/**
 * Data classes
 */
data class TemperatureAlertData(
    val sensorId: String,
    val currentTemperature: Float,
    val threshold: Float,
    val unit: String,
    val location: String,
    val trend: TemperatureTrend,
    val isCritical: Boolean = false,
    val metadata: Map<String, String> = emptyMap()
) {
    fun toMetadata(): Map<String, String> {
        return metadata + mapOf(
            "sensorId" to sensorId,
            "currentTemperature" to currentTemperature.toString(),
            "threshold" to threshold.toString(),
            "unit" to unit,
            "location" to location,
            "trend" to trend.name,
            "isCritical" to isCritical.toString()
        )
    }
}

data class TemperatureAlert(
    val id: String,
    val sensorId: String,
    val severity: TemperatureSeverity,
    val currentTemperature: Float,
    val threshold: Float,
    val unit: String,
    val location: String,
    val violationDegree: Float,
    val trend: TemperatureTrend,
    val recipients: List<NotificationRecipient>,
    val metadata: Map<String, String>,
    val status: TemperatureAlertStatus,
    val createdAt: Date,
    val updatedAt: Date,
    val acknowledgedAt: Date?,
    val acknowledgedBy: String?,
    val resolvedAt: Date?,
    val resolvedBy: String?,
    val resolution: String?,
    val finalTemperature: Float? = null
)

data class TemperatureAnalytics(
    val totalActive: Int = 0,
    val normalAlerts: Int = 0,
    val minorAlerts: Int = 0,
    val moderateAlerts: Int = 0,
    val severeAlerts: Int = 0,
    val criticalAlerts: Int = 0,
    val averageViolationDegree: Float = 0f,
    val sensorStats: Map<String, Int> = emptyMap(),
    val locationStats: Map<String, Int> = emptyMap()
)

data class TemperatureViolation(
    val isViolation: Boolean,
    val severity: TemperatureViolationSeverity,
    val degree: Float,
    val isAboveThreshold: Boolean,
    val isBelowThreshold: Boolean
)

data class SensorStatus(
    val sensorId: String,
    val status: SensorConnectionStatus,
    val lastReading: Date,
    val batteryLevel: Float?,
    val signalStrength: Float?
)

/**
 * Interfaces
 */
interface TemperatureAlertListener {
    fun onTemperatureAlertCreated(alert: TemperatureAlert)
    fun onTemperatureAlertResolved(alert: TemperatureAlert)
    fun onSensorStatusChanged(sensorId: String, status: SensorStatus)
}

/**
 * Enums
 */
enum class TemperatureAlertState {
    Idle,
    Initializing,
    Ready,
    Processing,
    Error
}

enum class TemperatureSeverity {
    NORMAL,
    MINOR,
    MODERATE,
    SEVERE,
    CRITICAL
}

enum class TemperatureAlertStatus {
    ACTIVE,
    ACKNOWLEDGED,
    RESOLVED
}

enum class TemperatureTrend {
    RISING,
    FALLING,
    STABLE,
    UNKNOWN
}

enum class TemperatureViolationSeverity {
    NONE,
    MINOR,
    MODERATE,
    SEVERE,
    CRITICAL
}

enum class SensorConnectionStatus {
    ONLINE,
    OFFLINE,
    ERROR,
    MAINTENANCE
}
