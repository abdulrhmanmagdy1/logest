package com.edham.logistics.feature.customer

import com.edham.logistics.feature.customer.data.repository.CustomerRepositoryImpl
import com.edham.logistics.feature.customer.domain.repository.CustomerRepository
import com.edham.logistics.feature.customer.domain.usecase.GetCustomerProfileUseCase
import com.edham.logistics.feature.customer.domain.usecase.UpdateCustomerProfileUseCase
import com.edham.logistics.feature.customer.domain.usecase.CreateShipmentUseCase
import com.edham.logistics.feature.customer.domain.usecase.GetCustomerShipmentsUseCase
import com.edham.logistics.feature.customer.domain.usecase.TrackShipmentUseCase
import com.edham.logistics.feature.customer.domain.usecase.CancelShipmentUseCase
import dagger.Binds
import dagger.Module
import dagger.hilt.InstallIn
import dagger.hilt.components.SingletonComponent
import javax.inject.Singleton

@Module
@InstallIn(SingletonComponent::class)
abstract class CustomerModule {

    @Binds
    @Singleton
    abstract fun bindCustomerRepository(
        customerRepositoryImpl: CustomerRepositoryImpl
    ): CustomerRepository

    @Binds
    @Singleton
    abstract fun bindGetCustomerProfileUseCase(
        getCustomerProfileUseCase: GetCustomerProfileUseCase
    ): com.edham.logistics.feature.customer.domain.usecase.GetCustomerProfileUseCase

    @Binds
    @Singleton
    abstract fun bindUpdateCustomerProfileUseCase(
        updateCustomerProfileUseCase: UpdateCustomerProfileUseCase
    ): com.edham.logistics.feature.customer.domain.usecase.UpdateCustomerProfileUseCase

    @Binds
    @Singleton
    abstract fun bindCreateShipmentUseCase(
        createShipmentUseCase: CreateShipmentUseCase
    ): com.edham.logistics.feature.customer.domain.usecase.CreateShipmentUseCase

    @Binds
    @Singleton
    abstract fun bindGetCustomerShipmentsUseCase(
        getCustomerShipmentsUseCase: GetCustomerShipmentsUseCase
    ): com.edham.logistics.feature.customer.domain.usecase.GetCustomerShipmentsUseCase

    @Binds
    @Singleton
    abstract fun bindTrackShipmentUseCase(
        trackShipmentUseCase: TrackShipmentUseCase
    ): com.edham.logistics.feature.customer.domain.usecase.TrackShipmentUseCase

    @Binds
    @Singleton
    abstract fun bindCancelShipmentUseCase(
        cancelShipmentUseCase: CancelShipmentUseCase
    ): com.edham.logistics.feature.customer.domain.usecase.CancelShipmentUseCase
}
