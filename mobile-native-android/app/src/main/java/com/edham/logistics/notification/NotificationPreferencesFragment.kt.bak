package com.edham.logistics.notification

import android.os.Bundle
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import androidx.fragment.app.Fragment
import androidx.fragment.app.viewModels
import androidx.lifecycle.lifecycleScope
import com.edham.logistics.databinding.FragmentNotificationSettingsBinding
import com.edham.logistics.notification.viewmodel.NotificationPreferencesViewModel
import dagger.hilt.android.AndroidEntryPoint
import kotlinx.coroutines.launch

/**
 * Notification Preferences Fragment - Manages notification settings and preferences
 * 
 * Features:
 * - General notification settings (silent mode, do not disturb)
 * - Notification channel preferences (push, SMS, email)
 * - Category preferences (shipment, maintenance, payment, driver)
 * - Priority level settings
 * - Emergency override settings
 * - Save and restore preferences
 */
@AndroidEntryPoint
class NotificationPreferencesFragment : Fragment() {

    private var _binding: FragmentNotificationSettingsBinding? = null
    private val binding get() = _binding!!

    private val viewModel: NotificationPreferencesViewModel by viewModels()

    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View {
        _binding = FragmentNotificationSettingsBinding.inflate(inflater, container, false)
        return binding.root
    }

    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        
        setupUI()
        setupObservers()
        setupClickListeners()
        
        // Load current preferences
        viewModel.loadPreferences()
    }

    private fun setupUI() {
        // Setup toolbar
        binding.toolbar.setNavigationOnClickListener {
            requireActivity().onBackPressed()
        }
    }

    private fun setupObservers() {
        viewLifecycleOwner.lifecycleScope.launch {
            viewModel.preferences.collect { preferences ->
                updateUI(preferences)
            }
        }

        viewLifecycleOwner.lifecycleScope.launch {
            viewModel.isLoading.collect { isLoading ->
                binding.btnSavePreferences.isEnabled = !isLoading
            }
        }

        viewLifecycleOwner.lifecycleScope.launch {
            viewModel.saveSuccess.collect { success ->
                if (success) {
                    showSuccessMessage()
                }
            }
        }

        viewLifecycleOwner.lifecycleScope.launch {
            viewModel.errorMessage.collect { errorMessage ->
                if (errorMessage != null) {
                    showErrorMessage(errorMessage)
                }
            }
        }
    }

    private fun setupClickListeners() {
        // General settings
        binding.switchSilentMode.setOnCheckedChangeListener { _, isChecked ->
            viewModel.updateSilentMode(isChecked)
        }

        binding.switchDoNotDisturb.setOnCheckedChangeListener { _, isChecked ->
            viewModel.updateDoNotDisturb(isChecked)
        }

        binding.switchVibration.setOnCheckedChangeListener { _, isChecked ->
            viewModel.updateVibration(isChecked)
        }

        // Notification channels
        binding.switchPushNotifications.setOnCheckedChangeListener { _, isChecked ->
            viewModel.updatePushNotifications(isChecked)
        }

        binding.switchSmsNotifications.setOnCheckedChangeListener { _, isChecked ->
            viewModel.updateSmsNotifications(isChecked)
        }

        binding.switchEmailNotifications.setOnCheckedChangeListener { _, isChecked ->
            viewModel.updateEmailNotifications(isChecked)
        }

        // Categories
        binding.switchShipmentNotifications.setOnCheckedChangeListener { _, isChecked ->
            viewModel.updateShipmentNotifications(isChecked)
        }

        binding.switchMaintenanceNotifications.setOnCheckedChangeListener { _, isChecked ->
            viewModel.updateMaintenanceNotifications(isChecked)
        }

        binding.switchPaymentNotifications.setOnCheckedChangeListener { _, isChecked ->
            viewModel.updatePaymentNotifications(isChecked)
        }

        binding.switchDriverNotifications.setOnCheckedChangeListener { _, isChecked ->
            viewModel.updateDriverNotifications(isChecked)
        }

        // Priority level
        binding.rgPriorityLevel.setOnCheckedChangeListener { _, checkedId ->
            val priorityLevel = when (checkedId) {
                R.id.rb_priority_all -> PriorityLevel.ALL
                R.id.rb_priority_high -> PriorityLevel.HIGH
                R.id.rb_priority_emergency -> PriorityLevel.EMERGENCY
                else -> PriorityLevel.ALL
            }
            viewModel.updatePriorityLevel(priorityLevel)
        }

        // Emergency override
        binding.switchEmergencyOverride.setOnCheckedChangeListener { _, isChecked ->
            viewModel.updateEmergencyOverride(isChecked)
        }

        // Save button
        binding.btnSavePreferences.setOnClickListener {
            viewModel.savePreferences()
        }
    }

    private fun updateUI(preferences: NotificationPreferences) {
        // General settings
        binding.switchSilentMode.isChecked = preferences.silentMode
        binding.switchDoNotDisturb.isChecked = preferences.doNotDisturbMode
        binding.switchVibration.isChecked = preferences.vibrationEnabled

        // Notification channels
        binding.switchPushNotifications.isChecked = preferences.channelPreferences.pushNotifications
        binding.switchSmsNotifications.isChecked = preferences.channelPreferences.smsNotifications
        binding.switchEmailNotifications.isChecked = preferences.channelPreferences.emailNotifications

        // Categories
        binding.switchShipmentNotifications.isChecked = preferences.categoryPreferences.shipmentNotifications
        binding.switchMaintenanceNotifications.isChecked = preferences.categoryPreferences.maintenanceNotifications
        binding.switchPaymentNotifications.isChecked = preferences.categoryPreferences.paymentNotifications
        binding.switchDriverNotifications.isChecked = preferences.categoryPreferences.driverNotifications

        // Priority level
        when (preferences.priorityLevel) {
            PriorityLevel.ALL -> binding.rbPriorityAll.isChecked = true
            PriorityLevel.HIGH -> binding.rbPriorityHigh.isChecked = true
            PriorityLevel.EMERGENCY -> binding.rbPriorityEmergency.isChecked = true
        }

        // Emergency override
        binding.switchEmergencyOverride.isChecked = preferences.emergencyOverride
    }

    private fun showSuccessMessage() {
        // Show success message (could use Snackbar, Toast, or custom dialog)
        // Implementation depends on UI requirements
    }

    private fun showErrorMessage(message: String) {
        // Show error message (could use Snackbar, Toast, or custom dialog)
        // Implementation depends on UI requirements
    }

    override fun onDestroyView() {
        super.onDestroyView()
        _binding = null
    }
}
