package com.edham.logistics.feature.dispatch.utils

import com.edham.logistics.R

/**
 * Utility class for priority handling in dispatch system
 */
object PriorityUtils {
    
    /**
     * Get priority icon resource based on priority level
     */
    fun getPriorityIcon(priority: String): Int {
        return when (priority.lowercase()) {
            "urgent" -> R.drawable.ic_priority_urgent
            "high" -> R.drawable.ic_priority_high
            "normal" -> R.drawable.ic_priority_normal
            "low" -> R.drawable.ic_priority_low
            else -> R.drawable.ic_priority_normal
        }
    }
    
    /**
     * Get priority color based on priority level
     */
    fun getPriorityColor(priority: String): Int {
        return when (priority.lowercase()) {
            "urgent" -> R.color.priority_urgent
            "high" -> R.color.priority_high
            "normal" -> R.color.priority_normal
            "low" -> R.color.priority_low
            else -> R.color.priority_normal
        }
    }
    
    /**
     * Get priority text in Arabic
     */
    fun getPriorityText(priority: String): String {
        return when (priority.lowercase()) {
            "urgent" -> "عاجل"
            "high" -> "عالي"
            "normal" -> "عادي"
            "low" -> "منخفض"
            else -> "عادي"
        }
    }
    
    /**
     * Get priority weight for sorting
     */
    fun getPriorityWeight(priority: String): Double {
        return when (priority.lowercase()) {
            "urgent" -> 4.0
            "high" -> 3.0
            "normal" -> 2.0
            "low" -> 1.0
            else -> 2.0
        }
    }
}
