package com.edham.logistics.feature.customer.domain.usecase

import com.edham.logistics.core.utils.Result
import com.edham.logistics.feature.customer.domain.model.CustomerDashboardData
import com.edham.logistics.feature.customer.domain.repository.CustomerRepository
import kotlinx.coroutines.flow.Flow
import javax.inject.Inject
import javax.inject.Singleton

@Singleton
class GetCustomerDashboardUseCase @Inject constructor(
    private val customerRepository: CustomerRepository
) {
    suspend operator fun invoke(customerId: String): Result<CustomerDashboardData> {
        return try {
            val shipments = customerRepository.getCustomerShipments(customerId, 1, 100)
            when (shipments) {
                is Result.Success -> {
                    val allShipments = shipments.data
                    val activeShipments = allShipments.filter { 
                        it.status == "pending" || it.status == "in_transit" 
                    }
                    val completedShipments = allShipments.filter { it.status == "delivered" }
                    val pendingShipments = allShipments.filter { it.status == "pending" }
                    
                    val dashboardData = CustomerDashboardData(
                        totalShipments = allShipments.size,
                        activeShipments = activeShipments.size,
                        completedShipments = completedShipments.size,
                        pendingShipments = pendingShipments.size,
                        recentShipments = allShipments.take(5),
                        activeShipmentsList = activeShipments,
                        completedShipmentsList = completedShipments.take(10),
                        pendingShipmentsList = pendingShipments
                    )
                    Result.Success(dashboardData)
                }
                is Result.Error -> {
                    Result.Error(shipments.exception)
                }
                is Result.Loading -> {
                    Result.Loading
                }
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }
    
    fun observeDashboardData(customerId: String): Flow<CustomerDashboardData> {
        return customerRepository.observeCustomerShipments(customerId) { shipments ->
            val activeShipments = shipments.filter { 
                it.status == "pending" || it.status == "in_transit" 
            }
            val completedShipments = shipments.filter { it.status == "delivered" }
            val pendingShipments = shipments.filter { it.status == "pending" }
            
            CustomerDashboardData(
                totalShipments = shipments.size,
                activeShipments = activeShipments.size,
                completedShipments = completedShipments.size,
                pendingShipments = pendingShipments.size,
                recentShipments = shipments.take(5),
                activeShipmentsList = activeShipments,
                completedShipmentsList = completedShipments.take(10),
                pendingShipmentsList = pendingShipments
            )
        }
    }
}
