package com.edham.logistics.core.database

import androidx.room.Database
import androidx.room.RoomDatabase
import androidx.room.TypeConverters
import com.edham.logistics.core.database.converters.DateConverters
import com.edham.logistics.data.local.dao.ShipmentDao
import com.edham.logistics.data.local.dao.DriverDao
import com.edham.logistics.data.local.dao.VehicleDao
import com.edham.logistics.data.local.dao.InvoiceDao
import com.edham.logistics.data.local.entity.ShipmentEntity
import com.edham.logistics.data.local.entity.DriverEntity
import com.edham.logistics.data.local.entity.VehicleEntity
import com.edham.logistics.data.local.entity.InvoiceEntity

@Database(
    entities = [
        ShipmentEntity::class,
        DriverEntity::class,
        VehicleEntity::class,
        InvoiceEntity::class
    ],
    version = 1,
    exportSchema = false
)
@TypeConverters(DateConverters::class)
abstract class AppDatabase : RoomDatabase() {
    abstract fun shipmentDao(): ShipmentDao
    abstract fun driverDao(): DriverDao
    abstract fun vehicleDao(): VehicleDao
    abstract fun invoiceDao(): InvoiceDao
}
