package com.edham.logistics.onboarding

import android.os.Bundle
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import androidx.fragment.app.Fragment
import androidx.fragment.app.viewModels
import androidx.navigation.fragment.findNavController
import androidx.viewpager2.widget.ViewPager2
import com.edham.logistics.R
import com.edham.logistics.databinding.FragmentOnboardingBinding
import com.google.android.material.tabs.TabLayout
import com.google.android.material.tabs.TabLayoutMediator
import dagger.hilt.android.AndroidEntryPoint

/**
 * Onboarding Fragment - Smooth user onboarding experience
 * 
 * Features:
 * - Multiple onboarding pages
 * - Smooth animations
 * - Language switching
 * - Skip option
 * - Progress indicators
 * - Arabic RTL support
 */
@AndroidEntryPoint
class OnboardingFragment : Fragment() {

    private var _binding: FragmentOnboardingBinding? = null
    private val binding get() = _binding!!

    private val viewModel: OnboardingViewModel by viewModels()
    private lateinit var onboardingAdapter: OnboardingAdapter

    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View {
        _binding = FragmentOnboardingBinding.inflate(inflater, container, false)
        return binding.root
    }

    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        
        setupUI()
        setupViewPager()
        setupClickListeners()
        setupObservers()
    }

    override fun onDestroyView() {
        super.onDestroyView()
        _binding = null
    }

    private fun setupUI() {
        // Configure text direction for RTL support
        if (isRTL()) {
            binding.viewPager.layoutDirection = View.LAYOUT_DIRECTION_RTL
        }
        
        // Initially set up button states
        updateButtonStates(0)
    }

    private fun setupViewPager() {
        onboardingAdapter = OnboardingAdapter(requireContext())
        binding.viewPager.adapter = onboardingAdapter
        
        // Set up page change callback
        binding.viewPager.registerOnPageChangeCallback(object : ViewPager2.OnPageChangeCallback() {
            override fun onPageSelected(position: Int) {
                updateButtonStates(position)
                updatePageIndicator(position)
            }
        })
        
        // Set up tab layout for page indicators
        setupPageIndicator()
    }

    private fun setupPageIndicator() {
        TabLayoutMediator(binding.tabLayout, binding.viewPager) { tab, position ->
            // Custom tab view for page indicators
            tab.view.background = null
        }.attach()
    }

    private fun setupClickListeners() {
        binding.nextButton.setOnClickListener {
            handleNextClick()
        }

        binding.skipButton.setOnClickListener {
            handleSkipClick()
        }

        binding.languageSwitch.setOnClickListener {
            toggleLanguage()
        }
    }

    private fun setupObservers() {
        // Observe onboarding completion
        viewModel.onboardingCompleted.observe(viewLifecycleOwner) { completed ->
            if (completed) {
                navigateToAuth()
            }
        }

        // Observe language changes
        viewModel.currentLanguage.observe(viewLifecycleOwner) { language ->
            binding.languageSwitch.text = language.displayName
        }
    }

    private fun handleNextClick() {
        val currentPosition = binding.viewPager.currentItem
        val totalPages = onboardingAdapter.itemCount

        if (currentPosition < totalPages - 1) {
            // Go to next page
            binding.viewPager.currentItem = currentPosition + 1
        } else {
            // Complete onboarding
            completeOnboarding()
        }
    }

    private fun handleSkipClick() {
        // Show confirmation dialog or directly skip
        completeOnboarding()
    }

    private fun completeOnboarding() {
        viewModel.completeOnboarding()
    }

    private fun updateButtonStates(position: Int) {
        val totalPages = onboardingAdapter.itemCount
        val isLastPage = position == totalPages - 1

        // Update next button text
        binding.nextButton.text = if (isLastPage) {
            getString(R.string.get_started)
        } else {
            getString(R.string.next)
        }

        // Update skip button visibility (hide on last page)
        binding.skipButton.visibility = if (isLastPage) View.GONE else View.VISIBLE

        // Animate button changes
        animateButtonChange(isLastPage)
    }

    private fun updatePageIndicator(position: Int) {
        // Update tab layout indicators
        for (i in 0 until binding.tabLayout.tabCount) {
            val tab = binding.tabLayout.getTabAt(i)
            tab?.view?.let { tabView ->
                val indicator = tabView.findViewById<View>(R.id.tab_indicator)
                if (indicator != null) {
                    // Update indicator appearance based on current page
                    indicator.isSelected = i == position
                }
            }
        }
    }

    private fun animateButtonChange(isLastPage: Boolean) {
        // Animate button appearance change
        binding.nextButton.apply {
            animate()
                .scaleX(0.95f)
                .scaleY(0.95f)
                .setDuration(100)
                .withEndAction {
                    text = if (isLastPage) getString(R.string.get_started) else getString(R.string.next)
                    animate()
                        .scaleX(1.0f)
                        .scaleY(1.0f)
                        .setDuration(100)
                        .start()
                }
                .start()
        }

        // Animate skip button visibility
        if (isLastPage) {
            binding.skipButton.animate()
                .alpha(0f)
                .setDuration(200)
                .withEndAction {
                    binding.skipButton.visibility = View.GONE
                }
                .start()
        } else {
            binding.skipButton.apply {
                alpha = 0f
                visibility = View.VISIBLE
                animate()
                    .alpha(1f)
                    .setDuration(200)
                    .start()
            }
        }
    }

    private fun toggleLanguage() {
        val currentLanguage = viewModel.currentLanguage.value
        val newLanguage = if (currentLanguage == Language.ARABIC) Language.ENGLISH else Language.ARABIC
        
        viewModel.setLanguage(newLanguage)
        
        // Restart activity with new language
        requireActivity().recreate()
    }

    private fun navigateToAuth() {
        findNavController().navigate(R.id.action_onboardingFragment_to_loginFragment)
    }

    private fun isRTL(): Boolean {
        return resources.configuration.layoutDirection == View.LAYOUT_DIRECTION_RTL
    }

    companion object {
        private const val TAG = "OnboardingFragment"
        const val PREF_NAME = "onboarding_prefs"
        const val KEY_ONBOARDING_COMPLETED = "onboarding_completed"
    }
}

/**
 * Language enum for onboarding
 */
enum class Language(val displayName: String) {
    ENGLISH("English"),
    ARABIC("العربية")
}
