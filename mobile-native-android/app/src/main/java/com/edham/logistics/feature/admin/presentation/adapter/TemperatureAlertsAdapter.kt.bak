package com.edham.logistics.feature.admin.presentation.adapter

import android.view.LayoutInflater
import android.view.ViewGroup
import androidx.recyclerview.widget.DiffUtil
import androidx.recyclerview.widget.ListAdapter
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.databinding.ItemTemperatureAlertBinding
import com.edham.logistics.feature.admin.domain.model.TemperatureAlert
import javax.inject.Inject

class TemperatureAlertsAdapter @Inject constructor(
    private val onAlertAction: (TemperatureAlert, String) -> Unit
) : ListAdapter<TemperatureAlert, TemperatureAlertsAdapter.TemperatureAlertViewHolder>(TemperatureAlertDiffCallback()) {

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): TemperatureAlertViewHolder {
        val binding = ItemTemperatureAlertBinding.inflate(
            LayoutInflater.from(parent.context),
            parent,
            false
        )
        return TemperatureAlertViewHolder(binding)
    }

    override fun onBindViewHolder(holder: TemperatureAlertViewHolder, position: Int) {
        holder.bind(getItem(position))
    }

    inner class TemperatureAlertViewHolder(
        private val binding: ItemTemperatureAlertBinding
    ) : RecyclerView.ViewHolder(binding.root) {

        fun bind(alert: TemperatureAlert) {
            binding.apply {
                textTrackingNumber.text = alert.trackingNumber
                textDriverName.text = alert.driverName
                textCurrentTemperature.text = "${String.format("%.1f", alert.currentTemperature)}°C"
                textRequiredTemperature.text = "${String.format("%.1f", alert.requiredTemperature)}°C"
                textLocation.text = alert.location.address
                textTimestamp.text = formatDateTime(alert.timestamp)
                textStatus.text = formatAlertLevel(alert.alertLevel)
                
                // Set alert level color
                textStatus.setTextColor(getAlertLevelColor(alert.alertLevel))
                
                // Set temperature difference
                val difference = alert.currentTemperature - alert.requiredTemperature
                textTemperatureDifference.text = "${String.format("%.1f", difference)}°C"
                textTemperatureDifference.setTextColor(
                    when {
                        difference > 0 -> android.graphics.Color.parseColor("#F44336") // Red for high
                        difference < 0 -> android.graphics.Color.parseColor("#2196F3") // Blue for low
                        else -> android.graphics.Color.parseColor("#4CAF50") // Green for normal
                    }
                )
                
                // Set resolved status
                if (alert.isResolved) {
                    textResolvedStatus.text = "تم الحل"
                    textResolvedStatus.setTextColor(android.graphics.Color.parseColor("#4CAF50"))
                    buttonResolve.gone()
                } else {
                    textResolvedStatus.text = "قيد الانتظار"
                    textResolvedStatus.setTextColor(android.graphics.Color.parseColor("#FF9800"))
                    buttonResolve.visible()
                }
                
                // Set click listeners
                buttonResolve.setOnClickListener {
                    onAlertAction(alert, "resolve")
                }
                
                root.setOnClickListener {
                    onAlertAction(alert, "details")
                }
                
                // Set alert level icon
                imageAlertLevel.setImageResource(getAlertLevelIcon(alert.alertLevel))
                imageAlertLevel.setColorFilter(getAlertLevelColor(alert.alertLevel))
            }
        }
        
        private fun formatAlertLevel(alertLevel: com.edham.logistics.feature.admin.domain.model.AlertLevel): String {
            return when (alertLevel) {
                com.edham.logistics.feature.admin.domain.model.AlertLevel.LOW -> "منخفض"
                com.edham.logistics.feature.admin.domain.model.AlertLevel.MEDIUM -> "متوسط"
                com.edham.logistics.feature.admin.domain.model.AlertLevel.HIGH -> "مرتفع"
                com.edham.logistics.feature.admin.domain.model.AlertLevel.CRITICAL -> "حرج"
            }
        }
        
        private fun formatDateTime(dateTime: String): String {
            // In real app, we would format date time properly
            return dateTime.substring(0, 16).replace("T", " ")
        }
        
        private fun getAlertLevelColor(alertLevel: com.edham.logistics.feature.admin.domain.model.AlertLevel): Int {
            return when (alertLevel) {
                com.edham.logistics.feature.admin.domain.model.AlertLevel.LOW -> android.graphics.Color.parseColor("#4CAF50")
                com.edham.logistics.feature.admin.domain.model.AlertLevel.MEDIUM -> android.graphics.Color.parseColor("#FF9800")
                com.edham.logistics.feature.admin.domain.model.AlertLevel.HIGH -> android.graphics.Color.parseColor("#FF5722")
                com.edham.logistics.feature.admin.domain.model.AlertLevel.CRITICAL -> android.graphics.Color.parseColor("#F44336")
            }
        }
        
        private fun getAlertLevelIcon(alertLevel: com.edham.logistics.feature.admin.domain.model.AlertLevel): Int {
            return when (alertLevel) {
                com.edham.logistics.feature.admin.domain.model.AlertLevel.LOW -> com.edham.logistics.R.drawable.ic_alert_low
                com.edham.logistics.feature.admin.domain.model.AlertLevel.MEDIUM -> com.edham.logistics.R.drawable.ic_alert_medium
                com.edham.logistics.feature.admin.domain.model.AlertLevel.HIGH -> com.edham.logistics.R.drawable.ic_alert_high
                com.edham.logistics.feature.admin.domain.model.AlertLevel.CRITICAL -> com.edham.logistics.R.drawable.ic_alert_critical
            }
        }
    }

    private class TemperatureAlertDiffCallback : DiffUtil.ItemCallback<TemperatureAlert>() {
        override fun areItemsTheSame(oldItem: TemperatureAlert, newItem: TemperatureAlert): Boolean {
            return oldItem.id == newItem.id
        }

        override fun areContentsTheSame(oldItem: TemperatureAlert, newItem: TemperatureAlert): Boolean {
            return oldItem == newItem
        }
    }
}
