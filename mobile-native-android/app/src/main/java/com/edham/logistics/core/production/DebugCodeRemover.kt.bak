package com.edham.logistics.core.production

import android.util.Log
import com.edham.logistics.BuildConfig
import javax.inject.Inject
import javax.inject.Singleton

/**
 * Debug Code Remover
 * Handles removal and validation of debug code in production builds
 */
@Singleton
class DebugCodeRemover @Inject constructor(
    private val productionConfig: ProductionConfig
) {
    
    companion object {
        private const val TAG = "DebugCodeRemover"
        
        // Debug patterns to remove
        val DEBUG_PATTERNS = listOf(
            "Log.d(",
            "Log.v(",
            "Log.i(",
            "System.out.println",
            "System.err.println",
            "Toast.makeText",
            "DEBUG",
            "debug",
            "test",
            "mock",
            "stub"
        )
        
        // Debug files to check
        val DEBUG_FILES = listOf(
            "Test",
            "Debug",
            "Mock",
            "Stub",
            "Fake"
        )
        
        // Debug annotations
        val DEBUG_ANNOTATIONS = listOf(
            "@VisibleForTesting",
            "@Ignore",
            "@Debug"
        )
        
        // Hardcoded values to remove
        val HARDCODED_VALUES = listOf(
            "http://localhost",
            "http://127.0.0.1",
            "http://10.0.2.2",
            "test_api_key",
            "debug_token",
            "mock_data"
        )
    }
    
    /**
     * Remove all debug code
     */
    fun removeDebugCode(): Boolean {
        if (productionConfig.isProductionMode()) {
            Log.i(TAG, "Starting debug code removal process")
            
            val issues = mutableListOf<String>()
            
            // Check for debug logging
            issues.addAll(checkDebugLogging())
            
            // Check for debug files
            issues.addAll(checkDebugFiles())
            
            // Check for debug annotations
            issues.addAll(checkDebugAnnotations())
            
            // Check for hardcoded values
            issues.addAll(checkHardcodedValues())
            
            // Check for debug UI elements
            issues.addAll(checkDebugUIElements())
            
            // Check for debug network configurations
            issues.addAll(checkDebugNetworkConfig())
            
            return if (issues.isEmpty()) {
                Log.i(TAG, "Debug code removal completed successfully")
                true
            } else {
                Log.e(TAG, "Debug code removal failed with issues: ${issues.joinToString(", ")}")
                false
            }
        } else {
            Log.d(TAG, "Debug code removal skipped in non-production mode")
            return true
        }
    }
    
    /**
     * Check for debug logging statements
     */
    private fun checkDebugLogging(): List<String> {
        val issues = mutableListOf<String>()
        
        // In production, debug logging should be removed
        if (productionConfig.isProductionMode()) {
            DEBUG_PATTERNS.forEach { pattern ->
                if (pattern.contains("Log.") || pattern.contains("println")) {
                    issues.add("Debug logging pattern found: $pattern")
                }
            }
        }
        
        return issues
    }
    
    /**
     * Check for debug files
     */
    private fun checkDebugFiles(): List<String> {
        val issues = mutableListOf<String>()
        
        // Check for files with debug names
        DEBUG_FILES.forEach { fileName ->
            if (fileName.contains("Test") || fileName.contains("Debug")) {
                issues.add("Debug file found: $fileName")
            }
        }
        
        return issues
    }
    
    /**
     * Check for debug annotations
     */
    private fun checkDebugAnnotations(): List<String> {
        val issues = mutableListOf<String>()
        
        // Check for testing annotations in production
        if (productionConfig.isProductionMode()) {
            DEBUG_ANNOTATIONS.forEach { annotation ->
                issues.add("Debug annotation found: $annotation")
            }
        }
        
        return issues
    }
    
    /**
     * Check for hardcoded debug values
     */
    private fun checkHardcodedValues(): List<String> {
        val issues = mutableListOf<String>()
        
        HARDCODED_VALUES.forEach { value ->
            if (value.contains("localhost") || value.contains("test_")) {
                issues.add("Hardcoded debug value found: $value")
            }
        }
        
        return issues
    }
    
    /**
     * Check for debug UI elements
     */
    private fun checkDebugUIElements(): List<String> {
        val issues = mutableListOf<String>()
        
        // Check for debug UI elements
        val debugUIElements = listOf(
            "debug_button",
            "test_menu",
            "developer_options",
            "debug_info",
            "test_data"
        )
        
        debugUIElements.forEach { element ->
            issues.add("Debug UI element found: $element")
        }
        
        return issues
    }
    
    /**
     * Check for debug network configurations
     */
    private fun checkDebugNetworkConfig(): List<String> {
        val issues = mutableListOf<String>()
        
        // Check for debug network configurations
        val debugUrls = listOf(
            "http://localhost",
            "http://127.0.0.1",
            "http://10.0.2.2",
            "debug_api",
            "test_server"
        )
        
        debugUrls.forEach { url ->
            issues.add("Debug network configuration found: $url")
        }
        
        return issues
    }
    
    /**
     * Validate debug code removal
     */
    fun validateDebugCodeRemoval(): List<String> {
        val issues = mutableListOf<String>()
        
        // Check if debug logging is disabled
        if (productionConfig.isProductionMode()) {
            if (productionConfig.isFeatureEnabled("debug_logging")) {
                issues.add("Debug logging should be disabled in production")
            }
        }
        
        // Check for debug build flags
        if (BuildConfig.DEBUG) {
            issues.add("Build should not be in DEBUG mode for production")
        }
        
        // Check for test variants
        if (BuildConfig.BUILD_TYPE.contains("debug")) {
            issues.add("Build type should not be debug for production")
        }
        
        return issues
    }
    
    /**
     * Get debug code removal report
     */
    fun getDebugCodeRemovalReport(): Map<String, Any> {
        return mapOf(
            "debugLogging" to checkDebugLogging(),
            "debugFiles" to checkDebugFiles(),
            "debugAnnotations" to checkDebugAnnotations(),
            "hardcodedValues" to checkHardcodedValues(),
            "debugUIElements" to checkDebugUIElements(),
            "debugNetworkConfig" to checkDebugNetworkConfig(),
            "validation" to validateDebugCodeRemoval(),
            "isProduction" to productionConfig.isProductionMode(),
            "buildType" to BuildConfig.BUILD_TYPE,
            "isDebug" to BuildConfig.DEBUG
        )
    }
    
    /**
     * Clean debug code recommendations
     */
    fun getDebugCodeCleanupRecommendations(): List<String> {
        val recommendations = mutableListOf<String>()
        
        if (productionConfig.isProductionMode()) {
            recommendations.add("Remove all Log.d() and Log.v() statements")
            recommendations.add("Remove System.out.println() statements")
            recommendations.add("Remove Toast.makeText() debug messages")
            recommendations.add("Remove @VisibleForTesting annotations from production code")
            recommendations.add("Remove hardcoded localhost URLs")
            recommendations.add("Remove debug UI elements and menus")
            recommendations.add("Remove test data and mock objects")
            recommendations.add("Remove debug network configurations")
            recommendations.add("Remove developer options and debug settings")
        }
        
        return recommendations
    }
    
    /**
     * Check if code is production ready
     */
    fun isProductionReady(): Boolean {
        val issues = validateDebugCodeRemoval()
        val debugIssues = getDebugCodeRemovalReport()
        
        val totalIssues = issues.size + 
            (debugIssues["debugLogging"] as? List<*> ?: emptyList<String>()).size +
            (debugIssues["debugFiles"] as? List<*> ?: emptyList<String>()).size +
            (debugIssues["debugAnnotations"] as? List<*> ?: emptyList<String>()).size +
            (debugIssues["hardcodedValues"] as? List<*> ?: emptyList<String>()).size +
            (debugIssues["debugUIElements"] as? List<*> ?: emptyList<String>()).size +
            (debugIssues["debugNetworkConfig"] as? List<*> ?: emptyList<String>()).size
        
        return totalIssues == 0
    }
    
    /**
     * Get production readiness score
     */
    fun getProductionReadinessScore(): Int {
        val totalChecks = 7 // Number of check categories
        var passedChecks = 0
        
        val report = getDebugCodeRemovalReport()
        
        if ((report["debugLogging"] as? List<*> ?: emptyList<String>()).isEmpty()) passedChecks++
        if ((report["debugFiles"] as? List<*> ?: emptyList<String>()).isEmpty()) passedChecks++
        if ((report["debugAnnotations"] as? List<*> ?: emptyList<String>()).isEmpty()) passedChecks++
        if ((report["hardcodedValues"] as? List<*> ?: emptyList<String>()).isEmpty()) passedChecks++
        if ((report["debugUIElements"] as? List<*> ?: emptyList<String>()).isEmpty()) passedChecks++
        if ((report["debugNetworkConfig"] as? List<*> ?: emptyList<String>()).isEmpty()) passedChecks++
        if ((report["validation"] as? List<*> ?: emptyList<String>()).isEmpty()) passedChecks++
        
        return (passedChecks * 100) / totalChecks
    }
    
    /**
     * Generate debug code removal summary
     */
    fun generateDebugCodeRemovalSummary(): Map<String, Any> {
        val report = getDebugCodeRemovalReport()
        val score = getProductionReadinessScore()
        val isReady = isProductionReady()
        val recommendations = getDebugCodeCleanupRecommendations()
        
        return mapOf(
            "score" to score,
            "isReady" to isReady,
            "issues" to report,
            "recommendations" to recommendations,
            "summary" to when {
                score == 100 -> "Excellent - No debug code found"
                score >= 80 -> "Good - Minimal debug code found"
                score >= 60 -> "Fair - Some debug code found"
                score >= 40 -> "Poor - Significant debug code found"
                else -> "Critical - Extensive debug code found"
            }
        )
    }
}
