package com.edham.logistics.feature.driver

import com.edham.logistics.feature.driver.data.repository.DriverRepositoryImpl
import com.edham.logistics.feature.driver.domain.repository.DriverRepository
import com.edham.logistics.feature.driver.domain.usecase.GetDriverProfileUseCase
import com.edham.logistics.feature.driver.domain.usecase.UpdateDriverProfileUseCase
import com.edham.logistics.feature.driver.domain.usecase.GetDriverShipmentsUseCase
import com.edham.logistics.feature.driver.domain.usecase.UpdateShipmentStatusUseCase
import com.edham.logistics.feature.driver.domain.usecase.UpdateDriverLocationUseCase
import dagger.Binds
import dagger.Module
import dagger.hilt.InstallIn
import dagger.hilt.components.SingletonComponent
import javax.inject.Singleton

@Module
@InstallIn(SingletonComponent::class)
abstract class DriverModule {

    @Binds
    @Singleton
    abstract fun bindDriverRepository(
        driverRepositoryImpl: DriverRepositoryImpl
    ): DriverRepository

    @Binds
    @Singleton
    abstract fun bindGetDriverProfileUseCase(
        getDriverProfileUseCase: GetDriverProfileUseCase
    ): com.edham.logistics.feature.driver.domain.usecase.GetDriverProfileUseCase

    @Binds
    @Singleton
    abstract fun bindUpdateDriverProfileUseCase(
        updateDriverProfileUseCase: UpdateDriverProfileUseCase
    ): com.edham.logistics.feature.driver.domain.usecase.UpdateDriverProfileUseCase

    @Binds
    @Singleton
    abstract fun bindGetDriverShipmentsUseCase(
        getDriverShipmentsUseCase: GetDriverShipmentsUseCase
    ): com.edham.logistics.feature.driver.domain.usecase.GetDriverShipmentsUseCase

    @Binds
    @Singleton
    abstract fun bindUpdateShipmentStatusUseCase(
        updateShipmentStatusUseCase: UpdateShipmentStatusUseCase
    ): com.edham.logistics.feature.driver.domain.usecase.UpdateShipmentStatusUseCase

    @Binds
    @Singleton
    abstract fun bindUpdateDriverLocationUseCase(
        updateDriverLocationUseCase: UpdateDriverLocationUseCase
    ): com.edham.logistics.feature.driver.domain.usecase.UpdateDriverLocationUseCase
}
