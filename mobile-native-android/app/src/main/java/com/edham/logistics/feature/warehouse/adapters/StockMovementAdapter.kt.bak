package com.edham.logistics.feature.warehouse.adapters

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.ImageView
import android.widget.TextView
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.data.local.entity.StockMovement
import java.text.SimpleDateFormat
import java.util.*

class StockMovementAdapter : RecyclerView.Adapter<StockMovementAdapter.ViewHolder>() {
    
    private var movements = mutableListOf<StockMovement>()
    private val timeFormat = SimpleDateFormat("HH:mm:ss", Locale.getDefault())
    private val dateFormat = SimpleDateFormat("MMM dd", Locale.getDefault())
    
    fun updateMovements(newMovements: List<StockMovement>) {
        movements.clear()
        movements.addAll(newMovements)
        notifyDataSetChanged()
    }
    
    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): ViewHolder {
        val view = LayoutInflater.from(parent.context).inflate(R.layout.item_stock_movement, parent, false)
        return ViewHolder(view)
    }
    
    override fun onBindViewHolder(holder: ViewHolder, position: Int) {
        holder.bind(movements[position])
    }
    
    override fun getItemCount(): Int = movements.size
    
    inner class ViewHolder(itemView: View) : RecyclerView.ViewHolder(itemView) {
        private val movementType: TextView = itemView.findViewById(R.id.movementType)
        private val movementQuantity: TextView = itemView.findViewById(R.id.movementQuantity)
        private val movementLocations: TextView = itemView.findViewById(R.id.movementLocations)
        private val movementTime: TextView = itemView.findViewById(R.id.movementTime)
        private val movementUser: TextView = itemView.findViewById(R.id.movementUser)
        private val movementNotes: TextView = itemView.findViewById(R.id.movementNotes)
        private val movementIcon: ImageView = itemView.findViewById(R.id.movementIcon)
        private val typeIndicator: View = itemView.findViewById(R.id.typeIndicator)
        
        fun bind(movement: StockMovement) {
            // Set movement type and icon
            val (typeText, iconRes, colorRes) = when (movement.movementType) {
                MovementType.RECEIVED -> {
                    Triple("RECEIVED", R.drawable.ic_receive, R.color.movement_received)
                }
                MovementType.DISPATCHED -> {
                    Triple("DISPATCHED", R.drawable.ic_dispatch, R.color.movement_dispatched)
                }
                MovementType.TRANSFER -> {
                    Triple("TRANSFER", R.drawable.ic_transfer, R.color.movement_transfer)
                }
                MovementType.DAMAGED -> {
                    Triple("DAMAGED", R.drawable.ic_damaged, R.color.movement_damaged)
                }
                MovementType.AUDIT_ADJUSTMENT -> {
                    Triple("AUDIT", R.drawable.ic_audit, R.color.movement_audit)
                }
                MovementType.RETURNED -> {
                    Triple("RETURNED", R.drawable.ic_return, R.color.movement_returned)
                }
            }
            
            movementType.text = typeText
            movementIcon.setImageResource(iconRes)
            movementIcon.setColorFilter(itemView.context.getColor(colorRes))
            typeIndicator.setBackgroundColor(itemView.context.getColor(colorRes))
            
            // Set movement details
            movementQuantity.text = "${movement.quantity} units"
            movementLocations.text = "${movement.fromLocation} → ${movement.toLocation}"
            
            // Set time
            val calendar = Calendar.getInstance()
            calendar.timeInMillis = movement.timestamp
            
            val today = Calendar.getInstance()
            val isToday = calendar.get(Calendar.DAY_OF_YEAR) == today.get(Calendar.DAY_OF_YEAR) &&
                    calendar.get(Calendar.YEAR) == today.get(Calendar.YEAR)
            
            movementTime.text = if (isToday) {
                timeFormat.format(calendar.time)
            } else {
                dateFormat.format(calendar.time)
            }
            
            // Set user and notes
            movementUser.text = "User: ${movement.userId}"
            movementNotes.text = movement.notes
            
            if (movement.notes.isBlank()) {
                movementNotes.visibility = View.GONE
            } else {
                movementNotes.visibility = View.VISIBLE
            }
            
            // Set background based on movement type
            val backgroundColor = when (movement.movementType) {
                MovementType.RECEIVED -> itemView.context.getColor(R.color.movement_received_bg)
                MovementType.DISPATCHED -> itemView.context.getColor(R.color.movement_dispatched_bg)
                MovementType.TRANSFER -> itemView.context.getColor(R.color.movement_transfer_bg)
                MovementType.DAMAGED -> itemView.context.getColor(R.color.movement_damaged_bg)
                MovementType.AUDIT_ADJUSTMENT -> itemView.context.getColor(R.color.movement_audit_bg)
                MovementType.RETURNED -> itemView.context.getColor(R.color.movement_returned_bg)
            }
            
            itemView.setBackgroundColor(backgroundColor)
            
            // Set click listener for details
            itemView.setOnClickListener {
                showMovementDetails(movement)
            }
        }
        
        private fun showMovementDetails(movement: StockMovement) {
            // Show detailed movement information
            val details = """
                Movement Details
                ===============
                Type: ${movement.movementType.name}
                Quantity: ${movement.quantity} units
                From: ${movement.fromLocation}
                To: ${movement.toLocation}
                Time: ${SimpleDateFormat("yyyy-MM-dd HH:mm:ss", Locale.getDefault()).format(Date(movement.timestamp))}
                User: ${movement.userId}
                Notes: ${movement.notes}
                ID: ${movement.id}
                Item ID: ${movement.itemId}
            """.trimIndent()
            
            // Implementation would show details in a dialog
        }
    }
}
