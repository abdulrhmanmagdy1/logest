package com.edham.logistics.analytics.adapters

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.TextView
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.analytics.DelayedShipmentsAnalytics

class DelayedShipmentsAnalyticsAdapter(
    private val delayedShipments: List<DelayedShipmentsAnalytics>
) : RecyclerView.Adapter<DelayedShipmentsAnalyticsAdapter.ViewHolder>() {

    class ViewHolder(view: View) : RecyclerView.ViewHolder(view) {
        val tvTotalDelayed: TextView = view.findViewById(R.id.tv_total_delayed)
        val tvAverageDelay: TextView = view.findViewById(R.id.tv_average_delay)
        val tvOnTimeRate: TextView = view.findViewById(R.id.tv_on_time_rate)
        val tvDelayReason: TextView = view.findViewById(R.id.tv_delay_reason)
    }

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): ViewHolder {
        val view = LayoutInflater.from(parent.context)
            .inflate(R.layout.item_delayed_shipments_analytics, parent, false)
        return ViewHolder(view)
    }

    override fun onBindViewHolder(holder: ViewHolder, position: Int) {
        val delayed = delayedShipments[position]
        holder.tvTotalDelayed.text = delayed.totalDelayedShipments.toString()
        holder.tvAverageDelay.text = "${delayed.averageDelayHours}h"
        holder.tvOnTimeRate.text = "${(delayed.onTimeDeliveryRate * 100).toInt()}%"
        holder.tvDelayReason.text = delayed.delayedByReason.keys.firstOrNull() ?: "Unknown"
    }

    override fun getItemCount(): Int = delayedShipments.size
}
