package com.edham.logistics.feature.admin.domain.usecase

import com.edham.logistics.core.utils.Result
import com.edham.logistics.feature.admin.domain.model.TemperatureAlert
import com.edham.logistics.feature.admin.domain.repository.AdminRepository
import kotlinx.coroutines.flow.Flow
import javax.inject.Inject

class GetTemperatureAlertsUseCase @Inject constructor(
    private val adminRepository: AdminRepository
) {
    
    suspend operator fun invoke(
        alertLevel: String? = null,
        isResolved: Boolean? = null
    ): Flow<Result<List<TemperatureAlert>>> {
        return adminRepository.getTemperatureAlerts(alertLevel, isResolved)
    }
}
