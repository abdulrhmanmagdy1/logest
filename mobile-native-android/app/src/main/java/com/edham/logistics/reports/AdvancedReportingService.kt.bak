    /**
     * Get export format information
     */
    fun getExportFormatInfo(): Map<String, Map<String, String>> {
        return mapOf(
            "PDF" to mapOf(
                "name" to "PDF",
                "description" to "تنسيق PDF مع رسوم بيانية وتنسيق احترافي",
                "mimeType" to "application/pdf",
                "extension" to ".pdf"
            ),
            "EXCEL" to mapOf(
                "name" to "Excel",
                "description" to "تنسيق Excel مع جداول قابلة للتعديل",
                "mimeType" to "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                "extension" to ".xlsx"
            ),
            "CSV" to mapOf(
                "name" to "CSV",
                "description" to "تنسيق CSV للتحليل في برامج أخرى",
                "mimeType" to "text/csv",
                "extension" to ".csv"
            )
        )
    }
    
    /**
     * Clear all data (for testing)
     */
    fun clearAllData() {
        reportsMap.clear()
        updateStatistics()
    }
}
