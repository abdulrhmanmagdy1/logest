package com.edham.logistics.feature.dispatch.adapters

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.ImageView
import android.widget.TextView
import androidx.recyclerview.widget.DiffUtil
import androidx.recyclerview.widget.ListAdapter
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.feature.dispatch.DispatchAssignment
import com.edham.logistics.utils.StatusUtils

/**
 * Assignment Adapter for dispatch board
 * Shows current driver-shipment assignments
 */
class AssignmentAdapter(
    private val onAssignmentAction: (DispatchAssignment, String) -> Unit
) : ListAdapter<DispatchAssignment, AssignmentAdapter.AssignmentViewHolder>(AssignmentDiffCallback()) {
    
    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): AssignmentViewHolder {
        val view = LayoutInflater.from(parent.context)
            .inflate(R.layout.item_assignment_card_dispatch, parent, false)
        return AssignmentViewHolder(view)
    }
    
    override fun onBindViewHolder(holder: AssignmentViewHolder, position: Int) {
        val assignment = getItem(position)
        holder.bind(assignment, onAssignmentAction)
    }
    
    override fun getItemCount(): Int = currentList.size
    
    class AssignmentViewHolder(itemView: View) : RecyclerView.ViewHolder(itemView) {
        private val imageStatus: ImageView = itemView.findViewById(R.id.imageStatus)
        private val textDriverName: TextView = itemView.findViewById(R.id.textDriverName)
        private val textShipmentRef: TextView = itemView.findViewById(R.id.textShipmentRef)
        private val textPickupTime: TextView = itemView.findViewById(R.id.textPickupTime)
        private val textEstimatedDuration: TextView = itemView.findViewById(R.id.textEstimatedDuration)
        private val textDistance: TextView = itemView.findViewById(R.id.textDistance)
        private val textStatus: TextView = itemView.findViewById(R.id.textStatus)
        private val textAssignmentType: TextView = itemView.findViewById(R.id.textAssignmentType)
        private val layoutActions: ViewGroup = itemView.findViewById(R.id.layoutActions)
        
        fun bind(assignment: DispatchAssignment, onAssignmentAction: (DispatchAssignment, String) -> Unit) {
            // Set status indicator
            val statusIcon = StatusUtils.getAssignmentStatusIcon(assignment.status)
            val statusColor = StatusUtils.getAssignmentStatusColor(assignment.status)
            
            imageStatus.setImageResource(statusIcon)
            imageStatus.setColorFilter(itemView.context.getColor(statusColor))
            
            // Set assignment information
            textDriverName.text = assignment.driverName
            textShipmentRef.text = assignment.shipmentReference
            textPickupTime.text = "الالتقاط: ${formatTime(assignment.estimatedPickupTime)}"
            textEstimatedDuration.text = "المدة: ${assignment.estimatedDuration} ساعة"
            textDistance.text = "${assignment.distance.toInt()} كم"
            textStatus.text = getStatusText(assignment.status)
            textAssignmentType.text = assignment.assignmentType
            
            // Set status color
            textStatus.setTextColor(itemView.context.getColor(statusColor))
            
            // Setup action buttons
            setupActionButtons(assignment, onAssignmentAction)
        }
        
        private fun getStatusText(status: DispatchAssignment.Status): String {
            return when (status) {
                DispatchAssignment.Status.ASSIGNED -> "معين"
                DispatchAssignment.Status.IN_PROGRESS -> "قيد التنفيذ"
                DispatchAssignment.Status.COMPLETED -> "مكتمل"
                DispatchAssignment.Status.DELAYED -> "متأخر"
                DispatchAssignment.Status.CANCELLED -> "ملغي"
                else -> "غير معروف"
            }
        }
        
        private fun formatTime(time: java.time.LocalDateTime): String {
            return try {
                val formatter = java.time.format.DateTimeFormatter.ofPattern("HH:mm")
                time.format(formatter)
            } catch (e: Exception) {
                "غير معروف"
            }
        }
        
        private fun setupActionButtons(
            assignment: DispatchAssignment, 
            onAssignmentAction: (DispatchAssignment, String) -> Unit
        ) {
            // Clear existing action buttons
            layoutActions.removeAllViews()
            
            // Add action buttons based on assignment status
            when (assignment.status) {
                DispatchAssignment.Status.ASSIGNED -> {
                    addActionButton("تفاصيل", "VIEW_DETAILS")
                    addActionButton("إلغاء", "CANCEL")
                    addActionButton("تتبع", "TRACK")
                }
                
                DispatchAssignment.Status.IN_PROGRESS -> {
                    addActionButton("تفاصيل", "VIEW_DETAILS")
                    addActionButton("اتصال بالسائق", "CONTACT_DRIVER")
                    addActionButton("تتبع", "TRACK")
                }
                
                DispatchAssignment.Status.DELAYED -> {
                    addActionButton("تفاصيل", "VIEW_DETAILS")
                    addActionButton("حل التأخير", "RESOLVE_DELAY")
                    addActionButton("إعادة تعيين", "REASSIGN")
                }
                
                DispatchAssignment.Status.COMPLETED -> {
                    addActionButton("تفاصيل", "VIEW_DETAILS")
                    addActionButton("إثبات التسليم", "VIEW_PROOF")
                }
                
                else -> {
                    addActionButton("تفاصيل", "VIEW_DETAILS")
                }
            }
        }
        
        private fun addActionButton(text: String, action: String) {
            val button = android.widget.Button(itemView.context).apply {
                setText(text)
                setTextColor(itemView.context.getColor(R.color.white))
                setBackgroundColor(itemView.context.getColor(R.color.primary))
                layoutParams = ViewGroup.LayoutParams(
                    ViewGroup.LayoutParams.WRAP_CONTENT,
                    ViewGroup.LayoutParams.WRAP_CONTENT
                ).apply {
                    setMargins(4, 0, 4, 0)
                }
                
                setOnClickListener {
                    onAssignmentAction.invoke(getItem(bindingAdapterPosition), action)
                }
            }
            
            layoutActions.addView(button)
        }
    }
    
    private class AssignmentDiffCallback : DiffUtil.ItemCallback<DispatchAssignment>() {
        override fun areItemsTheSame(oldItem: DispatchAssignment, newItem: DispatchAssignment): Boolean {
            return oldItem.id == newItem.id
        }
        
        override fun areContentsTheSame(oldItem: DispatchAssignment, newItem: DispatchAssignment): Boolean {
            return oldItem == newItem
        }
    }
}
