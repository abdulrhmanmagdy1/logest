package com.edham.logistics.analytics.adapters

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.TextView
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.analytics.TemperatureViolationsAnalytics

class TemperatureViolationsAnalyticsAdapter(
    private val violations: List<TemperatureViolationsAnalytics>
) : RecyclerView.Adapter<TemperatureViolationsAnalyticsAdapter.ViewHolder>() {

    class ViewHolder(view: View) : RecyclerView.ViewHolder(view) {
        val tvTotalViolations: TextView = view.findViewById(R.id.tv_total_violations)
        val tvCriticalViolations: TextView = view.findViewById(R.id.tv_critical_violations)
        val tvResolutionRate: TextView = view.findViewById(R.id.tv_resolution_rate)
        val tvViolationType: TextView = view.findViewById(R.id.tv_violation_type)
    }

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): ViewHolder {
        val view = LayoutInflater.from(parent.context)
            .inflate(R.layout.item_temperature_violations_analytics, parent, false)
        return ViewHolder(view)
    }

    override fun onBindViewHolder(holder: ViewHolder, position: Int) {
        val violation = violations[position]
        holder.tvTotalViolations.text = violation.totalViolations.toString()
        holder.tvCriticalViolations.text = violation.violationsBySeverity["critical"]?.toString() ?: "0"
        holder.tvResolutionRate.text = "${(violation.resolutionRate * 100).toInt()}%"
        holder.tvViolationType.text = violation.violationsByType.keys.firstOrNull() ?: "Unknown"
    }

    override fun getItemCount(): Int = violations.size
}
