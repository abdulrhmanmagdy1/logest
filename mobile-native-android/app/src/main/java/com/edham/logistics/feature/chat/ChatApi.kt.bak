package com.edham.logistics.feature.chat

import okhttp3.MultipartBody
import okhttp3.RequestBody
import retrofit2.Response
import retrofit2.http.*

interface ChatApi {
    
    // WebSocket base URL
    @GET
    suspend fun getWebSocketBaseUrl(): Response<String>
    
    // Message endpoints
    @POST("api/v1/chat/messages")
    suspend fun sendMessage(@Body message: ChatMessage): Response<ChatMessage>
    
    @GET("api/v1/chat/conversations/{conversationId}/messages")
    suspend fun getConversationMessages(
        @Path("conversationId") conversationId: String,
        @Query("limit") limit: Int = 50,
        @Query("offset") offset: Int = 0
    ): Response<List<ChatMessage>>
    
    @GET("api/v1/chat/messages/search")
    suspend fun searchMessages(
        @Query("conversationId") conversationId: String,
        @Query("query") query: String
    ): Response<List<ChatMessage>>
    
    @DELETE("api/v1/chat/messages/{messageId}")
    suspend fun deleteMessage(@Path("messageId") messageId: String): Response<Unit>
    
    // Conversation endpoints
    @GET("api/v1/chat/conversations")
    suspend fun getConversations(
        @Query("userId") userId: String,
        @Query("userRole") userRole: String
    ): Response<List<Conversation>>
    
    @POST("api/v1/chat/conversations")
    suspend fun createConversation(@Body conversation: Conversation): Response<Conversation>
    
    @GET("api/v1/chat/conversations/{conversationId}")
    suspend fun getConversation(@Path("conversationId") conversationId: String): Response<Conversation>
    
    @PUT("api/v1/chat/conversations/{conversationId}")
    suspend fun updateConversation(
        @Path("conversationId") conversationId: String,
        @Body conversation: Conversation
    ): Response<Conversation>
    
    @DELETE("api/v1/chat/conversations/{conversationId}")
    suspend fun deleteConversation(@Path("conversationId") conversationId: String): Response<Unit>
    
    @POST("api/v1/chat/conversations/{conversationId}/participants")
    suspend fun addParticipants(
        @Path("conversationId") conversationId: String,
        @Body participantIds: List<String>
    ): Response<Unit>
    
    @DELETE("api/v1/chat/conversations/{conversationId}/participants/{participantId}")
    suspend fun removeParticipant(
        @Path("conversationId") conversationId: String,
        @Path("participantId") participantId: String
    ): Response<Unit>
    
    // Media upload endpoints
    @Multipart
    @POST("api/v1/chat/media/upload")
    suspend fun uploadMedia(
        @Part file: MultipartBody.Part
    ): Response<MediaUploadResponse>
    
    @GET("api/v1/chat/media/{mediaId}")
    suspend fun getMedia(@Path("mediaId") mediaId: String): Response<MediaInfo>
    
    @DELETE("api/v1/chat/media/{mediaId}")
    suspend fun deleteMedia(@Path("mediaId") mediaId: String): Response<Unit>
    
    // Typing indicators
    @POST("api/v1/chat/typing")
    suspend fun sendTypingIndicator(@Body indicator: TypingIndicator): Response<Unit>
    
    @GET("api/v1/chat/conversations/{conversationId}/typing")
    suspend fun getTypingUsers(@Path("conversationId") conversationId: String): Response<List<TypingIndicator>>
    
    // Read receipts
    @POST("api/v1/chat/read-receipts")
    suspend fun sendReadReceipt(@Body receipt: ReadReceipt): Response<Unit>
    
    @GET("api/v1/chat/messages/{messageId}/read-receipts")
    suspend fun getMessageReadReceipts(@Path("messageId") messageId: String): Response<List<ReadReceipt>>
    
    // Emergency broadcasts
    @POST("api/v1/chat/emergency/broadcast")
    suspend fun sendEmergencyBroadcast(@Body emergencyMessage: EmergencyMessage): Response<EmergencyMessage>
    
    @GET("api/v1/chat/emergency/broadcasts")
    suspend fun getEmergencyBroadcasts(
        @Query("userRole") userRole: String,
        @Query("limit") limit: Int = 50
    ): Response<List<EmergencyMessage>>
    
    @PUT("api/v1/chat/emergency/broadcasts/{broadcastId}/read")
    suspend fun markEmergencyBroadcastAsRead(@Path("broadcastId") broadcastId: String): Response<Unit>
    
    // Online users
    @GET("api/v1/chat/online-users")
    suspend fun getOnlineUsers(): Response<List<OnlineUser>>
    
    @POST("api/v1/chat/online-users/{userId}/heartbeat")
    suspend fun sendHeartbeat(@Path("userId") userId: String): Response<Unit>
    
    // Unread counts
    @GET("api/v1/chat/unread-counts")
    suspend fun getUnreadCounts(@Query("userId") userId: String): Response<Map<String, Int>>
    
    @PUT("api/v1/chat/conversations/{conversationId}/mark-read")
    suspend fun markConversationAsRead(
        @Path("conversationId") conversationId: String,
        @Body request: MarkReadRequest
    ): Response<Unit>
    
    // Message reactions
    @POST("api/v1/chat/messages/{messageId}/reactions")
    suspend fun addMessageReaction(
        @Path("messageId") messageId: String,
        @Body reaction: MessageReaction
    ): Response<MessageReaction>
    
    @DELETE("api/v1/chat/messages/{messageId}/reactions/{reactionId}")
    suspend fun removeMessageReaction(
        @Path("messageId") messageId: String,
        @Path("reactionId") reactionId: String
    ): Response<Unit>
    
    @GET("api/v1/chat/messages/{messageId}/reactions")
    suspend fun getMessageReactions(@Path("messageId") messageId: String): Response<List<MessageReaction>>
    
    // Message forwarding
    @POST("api/v1/chat/messages/{messageId}/forward")
    suspend fun forwardMessage(
        @Path("messageId") messageId: String,
        @Body request: ForwardMessageRequest
    ): Response<ChatMessage>
    
    // Message editing
    @PUT("api/v1/chat/messages/{messageId}")
    suspend fun editMessage(
        @Path("messageId") messageId: String,
        @Body request: EditMessageRequest
    ): Response<ChatMessage>
    
    // Message pinning
    @POST("api/v1/chat/messages/{messageId}/pin")
    suspend fun pinMessage(@Path("messageId") messageId: String): Response<Unit>
    
    @DELETE("api/v1/chat/messages/{messageId}/pin")
    suspend fun unpinMessage(@Path("messageId") messageId: String): Response<Unit>
    
    @GET("api/v1/chat/conversations/{conversationId}/pinned-messages")
    suspend fun getPinnedMessages(@Path("conversationId") conversationId: String): Response<List<ChatMessage>>
    
    // Chat settings
    @GET("api/v1/chat/settings")
    suspend fun getChatSettings(@Query("userId") userId: String): Response<ChatSettings>
    
    @PUT("api/v1/chat/settings")
    suspend fun updateChatSettings(
        @Body settings: ChatSettings
    ): Response<ChatSettings>
    
    // Mute/unmute conversations
    @POST("api/v1/chat/conversations/{conversationId}/mute")
    suspend fun muteConversation(
        @Path("conversationId") conversationId: String,
        @Body request: MuteRequest
    ): Response<Unit>
    
    @DELETE("api/v1/chat/conversations/{conversationId}/mute")
    suspend fun unmuteConversation(@Path("conversationId") conversationId: String): Response<Unit>
    
    // Block/unblock users
    @POST("api/v1/chat/users/{userId}/block")
    suspend fun blockUser(@Path("userId") userId: String): Response<Unit>
    
    @DELETE("api/v1/chat/users/{userId}/block")
    suspend fun unblockUser(@Path("userId") userId: String): Response<Unit>
    
    @GET("api/v1/chat/blocked-users")
    suspend fun getBlockedUsers(@Query("userId") userId: String): Response<List<BlockedUser>>
    
    // Chat analytics
    @GET("api/v1/chat/analytics/summary")
    suspend fun getChatAnalytics(
        @Query("userId") userId: String,
        @Query("userRole") userRole: String,
        @Query("period") period: String // "day", "week", "month", "year"
    ): Response<ChatAnalytics>
    
    @GET("api/v1/chat/analytics/conversations/{conversationId}")
    suspend fun getConversationAnalytics(@Path("conversationId") conversationId: String): Response<ConversationAnalytics>
}

// Request/Response data classes
data class MediaUploadResponse(
    val success: Boolean,
    val url: String,
    val mediaId: String,
    val fileName: String,
    val fileSize: Long,
    val mimeType: String
)

data class MediaInfo(
    val id: String,
    val url: String,
    val fileName: String,
    val fileSize: Long,
    val mimeType: String,
    val uploadedAt: Long,
    val uploadedBy: String
)

data class OnlineUser(
    val userId: String,
    val userName: String,
    val userRole: String,
    val lastSeen: Long,
    val isActive: Boolean
)

data class MarkReadRequest(
    val userId: String,
    val messageIds: List<String>
)

data class MessageReaction(
    val id: String,
    val messageId: String,
    val userId: String,
    val emoji: String,
    val createdAt: Long
)

data class ForwardMessageRequest(
    val targetConversationId: String,
    val senderId: String,
    val senderRole: String
)

data class EditMessageRequest(
    val content: String,
    val editedAt: Long
)

data class MuteRequest(
    val userId: String,
    val duration: Long? = null, // null for permanent mute
    val reason: String? = null
)

data class BlockedUser(
    val userId: String,
    val userName: String,
    val userRole: String,
    val blockedAt: Long,
    val reason: String? = null
)

data class ChatSettings(
    val userId: String,
    val notificationsEnabled: Boolean,
    val soundEnabled: Boolean,
    val vibrationEnabled: Boolean,
    val typingIndicatorsEnabled: Boolean,
    val readReceiptsEnabled: Boolean,
    val onlineStatusEnabled: Boolean,
    val messagePreviewEnabled: Boolean,
    val autoDownloadMedia: Boolean,
    val maxFileSize: Long,
    val language: String,
    val theme: String
)

data class ChatAnalytics(
    val totalMessages: Int,
    val totalConversations: Int,
    val messagesSent: Int,
    val messagesReceived: Int,
    val mediaShared: Int,
    val voiceNotesSent: Int,
    val locationsShared: Int,
    val averageResponseTime: Long,
    val mostActiveHour: Int,
    val mostActiveDay: String,
    val topContacts: List<ContactAnalytics>
)

data class ConversationAnalytics(
    val conversationId: String,
    val totalMessages: Int,
    val participantCount: Int,
    val messagesPerParticipant: Map<String, Int>,
    val mediaCount: Int,
    val voiceNoteCount: Int,
    val locationShareCount: Int,
    val averageResponseTime: Long,
    val mostActiveParticipant: String,
    val createdAt: Long,
    val lastActivityAt: Long
)

data class ContactAnalytics(
    val userId: String,
    val userName: String,
    val userRole: String,
    val messageCount: Int,
    val mediaCount: Int,
    val voiceNoteCount: Int,
    val lastInteraction: Long
)
