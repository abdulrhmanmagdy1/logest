package com.edham.logistics.feature.admin.adapters

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.ImageView
import android.widget.TextView
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.data.local.entity.ActivityLog
import java.text.SimpleDateFormat
import java.util.*

class ActivityLogAdapter : RecyclerView.Adapter<ActivityLogAdapter.ViewHolder>() {
    
    private var logs = mutableListOf<ActivityLog>()
    private val timeFormat = SimpleDateFormat("HH:mm:ss", Locale.getDefault())
    private val dateFormat = SimpleDateFormat("MMM dd", Locale.getDefault())
    
    fun updateLogs(newLogs: List<ActivityLog>) {
        logs.clear()
        logs.addAll(newLogs)
        notifyDataSetChanged()
    }
    
    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): ViewHolder {
        val view = LayoutInflater.from(parent.context).inflate(R.layout.item_activity_log, parent, false)
        return ViewHolder(view)
    }
    
    override fun onBindViewHolder(holder: ViewHolder, position: Int) {
        holder.bind(logs[position])
    }
    
    override fun getItemCount(): Int = logs.size
    
    inner class ViewHolder(itemView: View) : RecyclerView.ViewHolder(itemView) {
        private val actionIcon: ImageView = itemView.findViewById(R.id.actionIcon)
        private val actionType: TextView = itemView.findViewById(R.id.actionType)
        private val actionDetails: TextView = itemView.findViewById(R.id.actionDetails)
        private val actionTime: TextView = itemView.findViewById(R.id.actionTime)
        private val actionUser: TextView = itemView.findViewById(R.id.actionUser)
        private val resourceInfo: TextView = itemView.findViewById(R.id.resourceInfo)
        private val typeIndicator: View = itemView.findViewById(R.id.typeIndicator)
        
        fun bind(log: ActivityLog) {
            // Set action type and icon
            val (actionText, iconRes, colorRes) = when (log.action) {
                "USER_CREATED" -> Triple("User Created", R.drawable.ic_user_add, R.color.action_create)
                "USER_UPDATED" -> Triple("User Updated", R.drawable.ic_user_edit, R.color.action_update)
                "USER_DELETED" -> Triple("User Deleted", R.drawable.ic_user_delete, R.color.action_delete)
                "ROLE_CREATED" -> Triple("Role Created", R.drawable.ic_role_add, R.color.action_create)
                "ROLE_UPDATED" -> Triple("Role Updated", R.drawable.ic_role_edit, R.color.action_update)
                "ROLE_DELETED" -> Triple("Role Deleted", R.drawable.ic_role_delete, R.color.action_delete)
                "PERMISSION_CREATED" -> Triple("Permission Created", R.drawable.ic_permission_add, R.color.action_create)
                "SETTING_UPDATED" -> Triple("Setting Updated", R.drawable.ic_setting_edit, R.color.action_update)
                "SYSTEM_STARTED" -> Triple("System Started", R.drawable.ic_system_start, R.color.action_system)
                "ADMIN_SYSTEM_STARTED" -> Triple("Admin System Started", R.drawable.ic_admin_start, R.color.action_system)
                else -> Triple(log.action, R.drawable.ic_activity, R.color.action_default)
            }
            
            actionType.text = actionText
            actionIcon.setImageResource(iconRes)
            actionIcon.setColorFilter(itemView.context.getColor(colorRes))
            typeIndicator.setBackgroundColor(itemView.context.getColor(colorRes))
            
            // Set action details
            actionDetails.text = log.details
            
            // Set time
            val calendar = Calendar.getInstance()
            calendar.timeInMillis = log.timestamp
            
            val today = Calendar.getInstance()
            val isToday = calendar.get(Calendar.DAY_OF_YEAR) == today.get(Calendar.DAY_OF_YEAR) &&
                    calendar.get(Calendar.YEAR) == today.get(Calendar.YEAR)
            
            actionTime.text = if (isToday) {
                timeFormat.format(calendar.time)
            } else {
                dateFormat.format(calendar.time)
            }
            
            // Set user
            actionUser.text = "User: ${log.userId}"
            
            // Set resource information
            val resourceText = "${log.resourceType}: ${log.resourceId}"
            resourceInfo.text = resourceText
            
            // Set background based on action type
            val backgroundColor = when (log.action) {
                "USER_CREATED", "ROLE_CREATED", "PERMISSION_CREATED" -> {
                    itemView.context.getColor(R.color.action_create_bg)
                }
                "USER_UPDATED", "ROLE_UPDATED", "SETTING_UPDATED" -> {
                    itemView.context.getColor(R.color.action_update_bg)
                }
                "USER_DELETED", "ROLE_DELETED" -> {
                    itemView.context.getColor(R.color.action_delete_bg)
                }
                "SYSTEM_STARTED", "ADMIN_SYSTEM_STARTED" -> {
                    itemView.context.getColor(R.color.action_system_bg)
                }
                else -> {
                    itemView.context.getColor(R.color.action_default_bg)
                }
            }
            
            itemView.setBackgroundColor(backgroundColor)
            
            // Set click listener for details
            itemView.setOnClickListener {
                showLogDetails(log)
            }
        }
        
        private fun showLogDetails(log: ActivityLog) {
            // Show detailed log information
            val details = """
                Activity Log Details
                ===================
                Action: ${log.action}
                Resource: ${log.resourceType} (${log.resourceId})
                Details: ${log.details}
                User: ${log.userId}
                IP Address: ${log.ipAddress}
                User Agent: ${log.userAgent}
                Timestamp: ${SimpleDateFormat("yyyy-MM-dd HH:mm:ss", Locale.getDefault()).format(Date(log.timestamp))}
                Log ID: ${log.id}
            """.trimIndent()
            
            // Implementation would show details in a dialog
        }
    }
}
