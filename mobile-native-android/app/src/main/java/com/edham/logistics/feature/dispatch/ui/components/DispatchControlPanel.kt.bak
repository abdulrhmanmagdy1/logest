package com.edham.logistics.feature.dispatch.ui.components

import android.content.Context
import android.os.Bundle
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.Button
import android.widget.LinearLayout
import android.widget.TextView
import androidx.fragment.app.DialogFragment
import com.edham.logistics.R
import com.edham.logistics.feature.dispatch.SmartDispatchService
import kotlinx.coroutines.launch

/**
 * Dispatch Control Panel - Control center for dispatch operations
 */
class DispatchControlPanel(
    private val context: Context,
    private val dispatchService: SmartDispatchService
) : DialogFragment() {
    
    private var onControlAction: (String, Any?) -> Unit = { action, data -> }
    
    fun setOnControlAction(listener: (String, Any?) -> Unit) {
        onControlAction = listener
    }
    
    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View? {
        return inflater.inflate(R.layout.dialog_dispatch_control_panel, container, false)
    }
    
    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        
        setupControlButtons(view)
        observeDispatchData()
    }
    
    private fun setupControlButtons(view: View) {
        // Auto Assignment Controls
        view.findViewById<Button>(R.id.buttonStartAutoAssign).setOnClickListener {
            onControlAction("START_AUTO_ASSIGN", null)
        }
        
        view.findViewById<Button>(R.id.buttonStopAutoAssign).setOnClickListener {
            onControlAction("STOP_AUTO_ASSIGN", null)
        }
        
        view.findViewById<Button>(R.id.buttonPauseAutoAssign).setOnClickListener {
            onControlAction("PAUSE_AUTO_ASSIGN", null)
        }
        
        view.findViewById<Button>(R.id.buttonClearAssignments).setOnClickListener {
            onControlAction("CLEAR_ASSIGNMENTS", null)
        }
        
        // Driver Management Controls
        view.findViewById<Button>(R.id.buttonRefreshDrivers).setOnClickListener {
            onControlAction("REFRESH_DRIVERS", null)
        }
        
        view.findViewById<Button>(R.id.buttonSetAllAvailable).setOnClickListener {
            onControlAction("SET_ALL_AVAILABLE", null)
        }
        
        view.findViewById<Button>(R.id.buttonSetAllUnavailable).setOnClickListener {
            onControlAction("SET_ALL_UNAVAILABLE", null)
        }
        
        // Shipment Management Controls
        view.findViewById<Button>(R.id.buttonRefreshShipments).setOnClickListener {
            onControlAction("REFRESH_SHIPMENTS", null)
        }
        
        view.findViewById<Button>(R.id.buttonPrioritizeAll).setOnClickListener {
            onControlAction("PRIORITIZE_ALL", null)
        }
        
        view.findViewById<Button>(R.id.buttonClearPending).setOnClickListener {
            onControlAction("CLEAR_PENDING", null)
        }
        
        // Conflict Resolution Controls
        view.findViewById<Button>(R.id.buttonResolveConflicts).setOnClickListener {
            onControlAction("RESOLVE_CONFLICTS", null)
        }
        
        view.findViewById<Button>(R.id.buttonIgnoreConflicts).setOnClickListener {
            onControlAction("IGNORE_CONFLICTS", null)
        }
        
        // Statistics Controls
        view.findViewById<Button>(R.id.buttonRefreshStats).setOnClickListener {
            onControlAction("REFRESH_STATS", null)
        }
        
        view.findViewById<Button>(R.id.buttonExportStats).setOnClickListener {
            onControlAction("EXPORT_STATS", null)
        }
    }
    
    private fun observeDispatchData() {
        // Observe dispatch statistics
        dispatchService.getDispatchStatistics().observe(viewLifecycleOwner) { stats ->
            updateStatisticsDisplay(stats)
        }
        
        // Observe assignment conflicts
        dispatchService.getAssignmentConflicts().observe(viewLifecycleOwner) { conflicts ->
            updateConflictDisplay(conflicts)
        }
    }
    
    private fun updateStatisticsDisplay(stats: com.edham.logistics.feature.dispatch.DispatchStats) {
        view?.let { v ->
            v.findViewById<TextView>(R.id.textTotalAssignments)?.text = stats.totalAssignments.toString()
            v.findViewById<TextView>(R.id.textPendingAssignments)?.text = stats.pendingAssignments.toString()
            v.findViewById<TextView>(R.id.textAvailableDrivers)?.text = stats.availableDrivers.toString()
            v.findViewById<TextView>(R.id.textConflictRate)?.text = "%.1f%%".format(stats.conflictRate)
            v.findViewById<TextView>(R.id.textOnTimeRate)?.text = "%.1f%%".format(stats.onTimeAssignmentRate)
        }
    }
    
    private fun updateConflictDisplay(conflicts: List<com.edham.logistics.feature.dispatch.DispatchConflict>) {
        view?.let { v ->
            val conflictsCount = conflicts.size
            v.findViewById<TextView>(R.id.textConflictsCount)?.text = conflictsCount.toString()
            
            if (conflictsCount > 0) {
                v.findViewById<Button>(R.id.buttonResolveConflicts)?.visibility = View.VISIBLE
                v.findViewById<Button>(R.id.buttonIgnoreConflicts)?.visibility = View.VISIBLE
            } else {
                v.findViewById<Button>(R.id.buttonResolveConflicts)?.visibility = View.GONE
                v.findViewById<Button>(R.id.buttonIgnoreConflicts)?.visibility = View.GONE
            }
        }
    }
    
    override fun onCreateDialog(savedInstanceState: Bundle?): android.app.AlertDialog {
        return android.app.AlertDialog.Builder(requireContext())
            .setTitle("لوحة التحكم في التوزيع")
            .setIcon(R.drawable.ic_dispatch_control)
            .setPositiveButton("إغاء") { _, _ -> dismiss() }
            .create()
    }
}
