package com.edham.logistics.feature.telematics

import android.util.Log
import kotlinx.coroutines.Dispatchers
import kotlinx.coroutines.withContext
import java.time.LocalDateTime

/**
 * Behavior Analytics System - Advanced driver behavior analysis and insights
 * Provides comprehensive analytics on driving patterns, risk assessment, and performance trends
 */
class BehaviorAnalytics {
    
    companion object {
        private const val TAG = "BehaviorAnalytics"
    }
    
    /**
     * Analyze driver behavior patterns
     */
    suspend fun analyzeDriverBehavior(
        driverId: String,
        sessions: List<DrivingSession>,
        timeWindow: TimeWindow = TimeWindow.LAST_30_DAYS
    ): BehaviorAnalysisResult {
        return withContext(Dispatchers.IO) {
            try {
                Log.d(TAG, "Analyzing behavior for driver $driverId")
                
                // Calculate behavior metrics
                val riskScore = calculateRiskScore(sessions)
                val consistencyScore = calculateConsistencyScore(sessions)
                val efficiencyScore = calculateEfficiencyScore(sessions)
                val safetyScore = calculateSafetyScore(sessions)
                
                // Generate behavior insights
                val insights = generateBehaviorInsights(sessions)
                
                // Determine behavior profile
                val profile = determineBehaviorProfile(riskScore, consistencyScore, efficiencyScore, safetyScore)
                
                val result = BehaviorAnalysisResult(
                    driverId = driverId,
                    riskScore = riskScore,
                    consistencyScore = consistencyScore,
                    efficiencyScore = efficiencyScore,
                    safetyScore = safetyScore,
                    profile = profile,
                    insights = insights,
                    timeWindow = timeWindow,
                    analyzedAt = LocalDateTime.now()
                )
                
                Log.d(TAG, "Behavior analysis completed for driver $driverId")
                result
                
            } catch (e: Exception) {
                Log.e(TAG, "Error analyzing driver behavior", e)
                BehaviorAnalysisResult.createError(driverId, timeWindow)
            }
        }
    }
    
    private fun calculateRiskScore(sessions: List<DrivingSession>): Double {
        if (sessions.isEmpty()) return 100.0
        
        val totalEvents = sessions.sumOf { 
            it.harshBrakingCount + it.rapidAccelerationCount + it.overSpeedingCount + 
            it.sharpTurnCount + it.seatbeltViolations 
        }
        
        val totalDistance = sessions.sumOf { it.distance }
        val eventsPer100km = if (totalDistance > 0) (totalEvents / totalDistance) * 100 else 0.0
        
        return maxOf(0.0, 100.0 - (eventsPer100km * 5))
    }
    
    private fun calculateConsistencyScore(sessions: List<DrivingSession>): Double {
        if (sessions.size < 2) return 100.0
        
        val scores = sessions.mapNotNull { it.overallScore }
        if (scores.isEmpty()) return 100.0
        
        val mean = scores.average()
        val variance = scores.map { (it - mean) * (it - mean) }.average()
        val standardDeviation = kotlin.math.sqrt(variance)
        
        return maxOf(0.0, 100.0 - (standardDeviation * 2))
    }
    
    private fun calculateEfficiencyScore(sessions: List<DrivingSession>): Double {
        if (sessions.isEmpty()) return 100.0
        
        val totalFuel = sessions.sumOf { it.fuelConsumed }
        val totalDistance = sessions.sumOf { it.distance }
        val totalIdle = sessions.sumOf { it.idleTime }
        val totalDuration = sessions.sumOf { it.duration }
        
        val fuelEfficiency = if (totalFuel > 0) totalDistance / totalFuel else 0.0
        val idlePercentage = if (totalDuration > 0) (totalIdle / totalDuration) * 100 else 0.0
        
        val fuelScore = minOf(100.0, fuelEfficiency * 10)
        val idleScore = maxOf(0.0, 100.0 - idlePercentage)
        
        return (fuelScore + idleScore) / 2.0
    }
    
    private fun calculateSafetyScore(sessions: List<DrivingSession>): Double {
        if (sessions.isEmpty()) return 100.0
        
        val safetyScores = sessions.mapNotNull { it.safetyScore }
        return if (safetyScores.isNotEmpty()) safetyScores.average() else 100.0
    }
    
    private fun generateBehaviorInsights(sessions: List<DrivingSession>): List<BehaviorInsight> {
        val insights = mutableListOf<BehaviorInsight>()
        
        if (sessions.isEmpty()) return insights
        
        // Analyze event patterns
        val totalEvents = sessions.sumOf { 
            it.harshBrakingCount + it.rapidAccelerationCount + it.overSpeedingCount 
        }
        
        if (totalEvents > sessions.size * 5) {
            insights.add(
                BehaviorInsight(
                    type = BehaviorInsight.Type.HIGH_EVENT_FREQUENCY,
                    severity = BehaviorInsight.Severity.HIGH,
                    title = "Frequent Safety Events",
                    description = "Driver has high frequency of safety events",
                    recommendation = "Focus on defensive driving techniques"
                )
            )
        }
        
        return insights
    }
    
    private fun determineBehaviorProfile(
        riskScore: Double,
        consistencyScore: Double,
        efficiencyScore: Double,
        safetyScore: Double
    ): BehaviorProfile {
        val overallScore = (riskScore + consistencyScore + efficiencyScore + safetyScore) / 4.0
        
        return when {
            overallScore >= 90 -> BehaviorProfile.EXCELLENT
            overallScore >= 80 -> BehaviorProfile.GOOD
            overallScore >= 70 -> BehaviorProfile.AVERAGE
            overallScore >= 60 -> BehaviorProfile.BELOW_AVERAGE
            else -> BehaviorProfile.POOR
        }
    }
}

// Data classes
data class BehaviorAnalysisResult(
    val driverId: String,
    val riskScore: Double,
    val consistencyScore: Double,
    val efficiencyScore: Double,
    val safetyScore: Double,
    val profile: BehaviorProfile,
    val insights: List<BehaviorInsight>,
    val timeWindow: TimeWindow,
    val analyzedAt: LocalDateTime,
    val errorMessage: String? = null
) {
    companion object {
        fun createError(driverId: String, timeWindow: TimeWindow): BehaviorAnalysisResult {
            return BehaviorAnalysisResult(
                driverId = driverId,
                riskScore = 0.0,
                consistencyScore = 0.0,
                efficiencyScore = 0.0,
                safetyScore = 0.0,
                profile = BehaviorProfile.POOR,
                insights = emptyList(),
                timeWindow = timeWindow,
                analyzedAt = LocalDateTime.now(),
                errorMessage = "Error analyzing behavior"
            )
        }
    }
}

data class BehaviorInsight(
    val type: Type,
    val severity: Severity,
    val title: String,
    val description: String,
    val recommendation: String
) {
    enum class Type {
        HIGH_EVENT_FREQUENCY,
        INCONSISTENT_PERFORMANCE,
        POOR_EFFICIENCY,
        SAFETY_CONCERNS
    }
    
    enum class Severity {
        LOW,
        MEDIUM,
        HIGH,
        CRITICAL
    }
}

enum class BehaviorProfile {
    EXCELLENT,
    GOOD,
    AVERAGE,
    BELOW_AVERAGE,
    POOR
}
