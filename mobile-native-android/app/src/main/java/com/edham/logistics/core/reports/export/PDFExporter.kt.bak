package com.edham.logistics.core.reports.export

import android.content.Context
import com.edham.logistics.core.reports.data.*
import kotlinx.coroutines.Dispatchers
import kotlinx.coroutines.withContext
import java.io.File
import java.io.FileOutputStream
import java.text.SimpleDateFormat
import java.util.*
import com.itextpdf.text.*
import com.itextpdf.text.pdf.*

/**
 * PDF Exporter - Handles export of reports to PDF format
 * Provides professional PDF generation with charts and tables
 */
class PDFExporter(private val context: Context) {

    private val dateFormat = SimpleDateFormat("yyyy-MM-dd", Locale.getDefault())
    private val dateTimeFormat = SimpleDateFormat("yyyy-MM-dd HH:mm:ss", Locale.getDefault())

    /**
     * Export revenue report to PDF
     */
    suspend fun exportRevenueReport(report: RevenueReport, fileName: String): String = withContext(Dispatchers.IO) {
        val file = createPDFFile(fileName)
        val document = Document(PageSize.A4)
        val writer = PdfWriter.getInstance(document, FileOutputStream(file))
        
        document.open()
        
        try {
            // Add fonts
            val arabicFont = Font(Font.FontFamily.HELVETICA, 12f, Font.NORMAL)
            val titleFont = Font(Font.FontFamily.HELVETICA, 18f, Font.BOLD)
            val headerFont = Font(Font.FontFamily.HELVETICA, 14f, Font.BOLD)
            
            // Add title
            document.add(Paragraph(report.title, titleFont))
            document.add(Paragraph("Generated: ${dateTimeFormat.format(Date(report.generatedAt))}", arabicFont))
            document.add(Paragraph("Period: ${dateFormat.format(Date(report.startDate))} - ${dateFormat.format(Date(report.endDate))}", arabicFont))
            document.add(Chunk.NEWLINE)
            
            // Executive Summary
            document.add(Paragraph("Executive Summary", headerFont))
            document.add(Chunk.NEWLINE)
            
            val summaryData = arrayOf(
                arrayOf("Total Revenue", "${report.totalRevenue} SAR"),
                arrayOf("Total Invoices", report.totalInvoices.toString()),
                arrayOf("Paid Invoices", report.paidInvoices.toString()),
                arrayOf("Unpaid Invoices", report.unpaidInvoices.toString()),
                arrayOf("Average Invoice Value", "${report.averageInvoiceValue} SAR"),
                arrayOf("Revenue Growth", "${report.revenueGrowth}%")
            )
            
            addTable(document, summaryData, arrayOf("Metric", "Value"), arabicFont)
            document.add(Chunk.NEWLINE)
            
            // Revenue by Period
            if (report.revenueByPeriod.isNotEmpty()) {
                document.add(Paragraph("Revenue by Period", headerFont))
                document.add(Chunk.NEWLINE)
                
                val periodData = report.revenueByPeriod.map { period ->
                    arrayOf(period.period, "${period.revenue} SAR", period.transactionCount.toString())
                }.toTypedArray()
                
                addTable(document, periodData, arrayOf("Period", "Revenue", "Transactions"), arabicFont)
                document.add(Chunk.NEWLINE)
            }
            
            // Top Customers
            if (report.revenueByCustomer.isNotEmpty()) {
                document.add(Paragraph("Top Customers by Revenue", headerFont))
                document.add(Chunk.NEWLINE)
                
                val customerData = report.revenueByCustomer.take(10).map { customer ->
                    arrayOf(customer.customerId, "${customer.revenue} SAR", customer.invoiceCount.toString())
                }.toTypedArray()
                
                addTable(document, customerData, arrayOf("Customer ID", "Revenue", "Invoices"), arabicFont)
                document.add(Chunk.NEWLINE)
            }
            
            // Revenue by Service Type
            if (report.revenueByServiceType.isNotEmpty()) {
                document.add(Paragraph("Revenue by Service Type", headerFont))
                document.add(Chunk.NEWLINE)
                
                val serviceData = report.revenueByServiceType.map { service ->
                    arrayOf(service.serviceType, "${service.revenue} SAR", service.invoiceCount.toString())
                }.toTypedArray()
                
                addTable(document, serviceData, arrayOf("Service Type", "Revenue", "Invoices"), arabicFont)
                document.add(Chunk.NEWLINE)
            }
            
            // Payment Methods
            if (report.paymentMethods.isNotEmpty()) {
                document.add(Paragraph("Payment Methods Analysis", headerFont))
                document.add(Chunk.NEWLINE)
                
                val paymentData = report.paymentMethods.map { payment ->
                    arrayOf(payment.paymentMethod, payment.transactionCount.toString(), 
                          "${payment.totalAmount} SAR", "${payment.percentage}%")
                }.toTypedArray()
                
                addTable(document, paymentData, arrayOf("Method", "Transactions", "Amount", "Percentage"), arabicFont)
                document.add(Chunk.NEWLINE)
            }
            
            // Overdue Analysis
            document.add(Paragraph("Overdue Payments Analysis", headerFont))
            document.add(Chunk.NEWLINE)
            
            val overdueData = arrayOf(
                arrayOf("Overdue Invoices", report.overdueAnalysis.overdueCount.toString()),
                arrayOf("Total Overdue Amount", "${report.overdueAnalysis.totalOverdueAmount} SAR"),
                arrayOf("Average Overdue Days", "%.1f".format(report.overdueAnalysis.averageOverdueDays)),
                arrayOf("Overdue Percentage", "%.1f%%".format(report.overdueAnalysis.overduePercentage))
            )
            
            addTable(document, overdueData, arrayOf("Metric", "Value"), arabicFont)
            
        } catch (e: Exception) {
            throw Exception("Failed to generate PDF: ${e.message}", e)
        } finally {
            document.close()
            writer.close()
        }
        
        file.absolutePath
    }

    /**
     * Export shipment performance report to PDF
     */
    suspend fun exportShipmentReport(report: ShipmentPerformanceReport, fileName: String): String = withContext(Dispatchers.IO) {
        val file = createPDFFile(fileName)
        val document = Document(PageSize.A4)
        val writer = PdfWriter.getInstance(document, FileOutputStream(file))
        
        document.open()
        
        try {
            val arabicFont = Font(Font.FontFamily.HELVETICA, 12f, Font.NORMAL)
            val titleFont = Font(Font.FontFamily.HELVETICA, 18f, Font.BOLD)
            val headerFont = Font(Font.FontFamily.HELVETICA, 14f, Font.BOLD)
            
            // Add title
            document.add(Paragraph(report.title, titleFont))
            document.add(Paragraph("Generated: ${dateTimeFormat.format(Date(report.generatedAt))}", arabicFont))
            document.add(Paragraph("Period: ${dateFormat.format(Date(report.startDate))} - ${dateFormat.format(Date(report.endDate))}", arabicFont))
            document.add(Chunk.NEWLINE)
            
            // Executive Summary
            document.add(Paragraph("Executive Summary", headerFont))
            document.add(Chunk.NEWLINE)
            
            val summaryData = arrayOf(
                arrayOf("Total Shipments", report.totalShipments.toString()),
                arrayOf("Delivered Shipments", report.deliveredShipments.toString()),
                arrayOf("Delayed Shipments", report.delayedShipments.toString()),
                arrayOf("Cancelled Shipments", report.cancelledShipments.toString()),
                arrayOf("On-Time Delivery Rate", "%.1f%%".format(report.onTimeDeliveryRate)),
                arrayOf("Average Delivery Time", "%.1f hours".format(report.averageDeliveryTime / (1000 * 60 * 60)))
            )
            
            addTable(document, summaryData, arrayOf("Metric", "Value"), arabicFont)
            document.add(Chunk.NEWLINE)
            
            // Route Performance
            if (report.performanceByRoute.isNotEmpty()) {
                document.add(Paragraph("Performance by Route", headerFont))
                document.add(Chunk.NEWLINE)
                
                val routeData = report.performanceByRoute.take(10).map { route ->
                    arrayOf(route.route, route.totalShipments.toString(), route.deliveredShipments.toString(),
                          "%.1f%%".format(route.onTimeDeliveryRate))
                }.toTypedArray()
                
                addTable(document, routeData, arrayOf("Route", "Total", "Delivered", "On-Time Rate"), arabicFont)
                document.add(Chunk.NEWLINE)
            }
            
            // Driver Performance
            if (report.performanceByDriver.isNotEmpty()) {
                document.add(Paragraph("Performance by Driver", headerFont))
                document.add(Chunk.NEWLINE)
                
                val driverData = report.performanceByDriver.take(10).map { driver ->
                    arrayOf(driver.driverName, driver.totalShipments.toString(), driver.deliveredShipments.toString(),
                          "%.1f%%".format(driver.onTimeDeliveryRate))
                }.toTypedArray()
                
                addTable(document, driverData, arrayOf("Driver", "Total", "Delivered", "On-Time Rate"), arabicFont)
                document.add(Chunk.NEWLINE)
            }
            
            // Vehicle Type Performance
            if (report.performanceByVehicleType.isNotEmpty()) {
                document.add(Paragraph("Performance by Vehicle Type", headerFont))
                document.add(Chunk.NEWLINE)
                
                val vehicleData = report.performanceByVehicleType.map { vehicle ->
                    arrayOf(vehicle.vehicleType, vehicle.totalShipments.toString(), vehicle.deliveredShipments.toString(),
                          "%.1f%%".format(vehicle.onTimeDeliveryRate))
                }.toTypedArray()
                
                addTable(document, vehicleData, arrayOf("Vehicle Type", "Total", "Delivered", "On-Time Rate"), arabicFont)
                document.add(Chunk.NEWLINE)
            }
            
            // Geographic Performance
            if (report.geographicPerformance.isNotEmpty()) {
                document.add(Paragraph("Geographic Performance", headerFont))
                document.add(Chunk.NEWLINE)
                
                val geoData = report.geographicPerformance.take(10).map { geo ->
                    arrayOf(geo.location, geo.totalShipments.toString(), geo.deliveredShipments.toString(),
                          "%.1f%%".format(geo.onTimeDeliveryRate))
                }.toTypedArray()
                
                addTable(document, geoData, arrayOf("Location", "Total", "Delivered", "On-Time Rate"), arabicFont)
                document.add(Chunk.NEWLINE)
            }
            
            // Delay Analysis
            document.add(Paragraph("Delay Analysis", headerFont))
            document.add(Chunk.NEWLINE)
            
            val delayData = arrayOf(
                arrayOf("Delayed Shipments", report.delayAnalysis.delayedCount.toString()),
                arrayOf("Average Delay", "%.1f minutes".format(report.delayAnalysis.averageDelayMinutes)),
                arrayOf("Maximum Delay", "${report.delayAnalysis.maxDelayMinutes} minutes"),
                arrayOf("Delay Percentage", "%.1f%%".format(report.delayAnalysis.delayPercentage))
            )
            
            addTable(document, delayData, arrayOf("Metric", "Value"), arabicFont)
            
        } catch (e: Exception) {
            throw Exception("Failed to generate PDF: ${e.message}", e)
        } finally {
            document.close()
            writer.close()
        }
        
        file.absolutePath
    }

    /**
     * Export driver performance report to PDF
     */
    suspend fun exportDriverReport(report: DriverPerformanceReport, fileName: String): String = withContext(Dispatchers.IO) {
        val file = createPDFFile(fileName)
        val document = Document(PageSize.A4)
        val writer = PdfWriter.getInstance(document, FileOutputStream(file))
        
        document.open()
        
        try {
            val arabicFont = Font(Font.FontFamily.HELVETICA, 12f, Font.NORMAL)
            val titleFont = Font(Font.FontFamily.HELVETICA, 18f, Font.BOLD)
            val headerFont = Font(Font.FontFamily.HELVETICA, 14f, Font.BOLD)
            
            // Add title
            document.add(Paragraph(report.title, titleFont))
            document.add(Paragraph("Generated: ${dateTimeFormat.format(Date(report.generatedAt))}", arabicFont))
            document.add(Paragraph("Period: ${dateFormat.format(Date(report.startDate))} - ${dateFormat.format(Date(report.endDate))}", arabicFont))
            document.add(Chunk.NEWLINE)
            
            // Team Statistics
            document.add(Paragraph("Team Statistics", headerFont))
            document.add(Chunk.NEWLINE)
            
            val teamData = arrayOf(
                arrayOf("Total Drivers", report.teamStatistics.totalDrivers.toString()),
                arrayOf("Average On-Time Rate", "%.1f%%".format(report.teamStatistics.averageOnTimeDeliveryRate)),
                arrayOf("Average Satisfaction", "%.1f".format(report.teamStatistics.averageCustomerSatisfaction)),
                arrayOf("Total Revenue Generated", "${report.teamStatistics.totalRevenueGenerated} SAR")
            )
            
            addTable(document, teamData, arrayOf("Metric", "Value"), arabicFont)
            document.add(Chunk.NEWLINE)
            
            // Top Performers
            if (report.topPerformers.isNotEmpty()) {
                document.add(Paragraph("Top Performers", headerFont))
                document.add(Chunk.NEWLINE)
                
                val topData = report.topPerformers.map { driver ->
                    arrayOf(driver.driverName, driver.totalShipments.toString(), driver.deliveredShipments.toString(),
                          "%.1f%%".format(driver.onTimeDeliveryRate), "%.1f".format(driver.rating))
                }.toTypedArray()
                
                addTable(document, topData, arrayOf("Driver", "Total", "Delivered", "On-Time Rate", "Rating"), arabicFont)
                document.add(Chunk.NEWLINE)
            }
            
            // All Driver Performance
            document.add(Paragraph("All Driver Performance", headerFont))
            document.add(Chunk.NEWLINE)
            
            val driverData = report.driverPerformances.map { driver ->
                arrayOf(driver.driverName, driver.totalShipments.toString(), driver.deliveredShipments.toString(),
                      "%.1f%%".format(driver.onTimeDeliveryRate), "${driver.revenueGenerated} SAR", 
                      "%.1f".format(driver.customerSatisfaction))
            }.toTypedArray()
            
            addTable(document, driverData, arrayOf("Driver", "Total", "Delivered", "On-Time Rate", "Revenue", "Satisfaction"), arabicFont)
            document.add(Chunk.NEWLINE)
            
            // Areas for Improvement
            if (report.areasForImprovement.isNotEmpty()) {
                document.add(Paragraph("Areas for Improvement", headerFont))
                document.add(Chunk.NEWLINE)
                
                report.areasForImprovement.forEach { area ->
                    document.add(Paragraph("• $area", arabicFont))
                }
                document.add(Chunk.NEWLINE)
            }
            
        } catch (e: Exception) {
            throw Exception("Failed to generate PDF: ${e.message}", e)
        } finally {
            document.close()
            writer.close()
        }
        
        file.absolutePath
    }

    /**
     * Export customer behavior report to PDF
     */
    suspend fun exportCustomerReport(report: CustomerBehaviorReport, fileName: String): String = withContext(Dispatchers.IO) {
        val file = createPDFFile(fileName)
        val document = Document(PageSize.A4)
        val writer = PdfWriter.getInstance(document, FileOutputStream(file))
        
        document.open()
        
        try {
            val arabicFont = Font(Font.FontFamily.HELVETICA, 12f, Font.NORMAL)
            val titleFont = Font(Font.FontFamily.HELVETICA, 18f, Font.BOLD)
            val headerFont = Font(Font.FontFamily.HELVETICA, 14f, Font.BOLD)
            
            // Add title
            document.add(Paragraph(report.title, titleFont))
            document.add(Paragraph("Generated: ${dateTimeFormat.format(Date(report.generatedAt))}", arabicFont))
            document.add(Paragraph("Period: ${dateFormat.format(Date(report.startDate))} - ${dateFormat.format(Date(report.endDate))}", arabicFont))
            document.add(Chunk.NEWLINE)
            
            // Market Segmentation
            document.add(Paragraph("Market Segmentation", headerFont))
            document.add(Chunk.NEWLINE)
            
            val segmentData = report.marketSegmentation.segments.map { segment ->
                arrayOf(segment.name, segment.customerCount.toString())
            }.toTypedArray()
            
            addTable(document, segmentData, arrayOf("Segment", "Customers"), arabicFont)
            document.add(Chunk.NEWLINE)
            
            // Customer Lifetime Value
            document.add(Paragraph("Customer Lifetime Value", headerFont))
            document.add(Chunk.NEWLINE)
            
            val clvData = arrayOf(
                arrayOf("Average CLV", "${report.customerLifetimeValue.averageLifetimeValue} SAR"),
                arrayOf("Total CLV", "${report.customerLifetimeValue.totalLifetimeValue} SAR"),
                arrayOf("Average Customer Lifetime", "%.1f months".format(report.customerLifetimeValue.averageCustomerLifetime))
            )
            
            addTable(document, clvData, arrayOf("Metric", "Value"), arabicFont)
            document.add(Chunk.NEWLINE)
            
            // Churn Analysis
            document.add(Paragraph("Churn Analysis", headerFont))
            document.add(Chunk.NEWLINE)
            
            val churnData = arrayOf(
                arrayOf("Churn Rate", "%.1f%%".format(report.churnAnalysis.churnRate)),
                arrayOf("At Risk Customers", report.churnAnalysis.atRiskCustomers.toString()),
                arrayOf("Retention Rate", "%.1f%%".format(report.churnAnalysis.retentionRate))
            )
            
            addTable(document, churnData, arrayOf("Metric", "Value"), arabicFont)
            document.add(Chunk.NEWLINE)
            
            // Top Customers
            if (report.topCustomers.isNotEmpty()) {
                document.add(Paragraph("Top Customers by Revenue", headerFont))
                document.add(Chunk.NEWLINE)
                
                val topData = report.topCustomers.take(10).map { customer ->
                    arrayOf(customer.customerName, customer.totalShipments.toString(), 
                          "${customer.totalRevenue} SAR", customer.loyaltyScore.toString())
                }.toTypedArray()
                
                addTable(document, topData, arrayOf("Customer", "Shipments", "Revenue", "Loyalty Score"), arabicFont)
                document.add(Chunk.NEWLINE)
            }
            
            // At Risk Customers
            if (report.atRiskCustomers.isNotEmpty()) {
                document.add(Paragraph("At Risk Customers", headerFont))
                document.add(Chunk.NEWLINE)
                
                val riskData = report.atRiskCustomers.take(10).map { customer ->
                    arrayOf(customer.customerName, customer.totalShipments.toString(), 
                          "${customer.totalRevenue} SAR", customer.riskLevel.toString())
                }.toTypedArray()
                
                addTable(document, riskData, arrayOf("Customer", "Shipments", "Revenue", "Risk Level"), arabicFont)
                document.add(Chunk.NEWLINE)
            }
            
        } catch (e: Exception) {
            throw Exception("Failed to generate PDF: ${e.message}", e)
        } finally {
            document.close()
            writer.close()
        }
        
        file.absolutePath
    }

    /**
     * Create table in PDF document
     */
    private fun addTable(document: Document, data: Array<Array<String>>, headers: Array<String>, font: Font) {
        val table = PdfPTable(headers.size)
        table.widthPercentage = 100f
        
        // Add headers
        headers.forEach { header ->
            val cell = PdfPCell(Phrase(header, Font(Font.FontFamily.HELVETICA, 12f, Font.BOLD)))
            cell.backgroundColor = BaseColor.LIGHT_GRAY
            table.addCell(cell)
        }
        
        // Add data
        data.forEach { row ->
            row.forEach { cellData ->
                table.addCell(Phrase(cellData, font))
            }
        }
        
        document.add(table)
    }

    /**
     * Create PDF file
     */
    private fun createPDFFile(fileName: String): File {
        val downloadsDir = File(context.getExternalFilesDir(null), "Reports")
        if (!downloadsDir.exists()) {
            downloadsDir.mkdirs()
        }
        
        val timestamp = SimpleDateFormat("yyyyMMdd_HHmmss", Locale.getDefault()).format(Date())
        val finalFileName = "${fileName}_$timestamp.pdf"
        
        return File(downloadsDir, finalFileName)
    }
}
