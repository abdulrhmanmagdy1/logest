package com.edham.logistics.feature.warehouse

import android.content.Context
import androidx.lifecycle.LiveData
import androidx.lifecycle.MutableLiveData
import com.edham.logistics.data.local.database.WarehouseDatabase
import com.edham.logistics.data.local.entity.InventoryItem
import com.edham.logistics.data.local.entity.StockMovement
import com.edham.logistics.data.local.entity.WarehouseZone
import com.edham.logistics.data.local.entity.Shelf
import com.edham.logistics.data.remote.api.WarehouseApi
import kotlinx.coroutines.*
import timber.log.Timber
import java.util.*
import java.util.concurrent.ConcurrentHashMap

/**
 * Warehouse Management Service
 * Complete warehouse management with inventory tracking, barcode scanning, and real-time sync
 */
class WarehouseManagementService(
    private val context: Context,
    private val api: WarehouseApi,
    private val database: WarehouseDatabase
) {
    
    private val serviceScope = CoroutineScope(Dispatchers.IO + SupervisorJob())
    
    // LiveData for real-time updates
    private val _inventoryItems = MutableLiveData<List<InventoryItem>>()
    val inventoryItems: LiveData<List<InventoryItem>> = _inventoryItems
    
    private val _stockMovements = MutableLiveData<List<StockMovement>>()
    val stockMovements: LiveData<List<StockMovement>> = _stockMovements
    
    private val _warehouseZones = MutableLiveData<List<WarehouseZone>>()
    val warehouseZones: LiveData<List<WarehouseZone>> = _warehouseZones
    
    private val _shelves = MutableLiveData<List<Shelf>>()
    val shelves: LiveData<List<Shelf>> = _shelves
    
    private val _syncStatus = MutableLiveData<SyncStatus>()
    val syncStatus: LiveData<SyncStatus> = _syncStatus
    
    // Warehouse state
    private val inventoryMap = ConcurrentHashMap<String, InventoryItem>()
    private val zoneMap = ConcurrentHashMap<String, WarehouseZone>()
    private val shelfMap = ConcurrentHashMap<String, Shelf>()
    private val movementHistory = mutableListOf<StockMovement>()
    
    // Barcode and QR code management
    private val barcodeScanner = BarcodeScanner(context)
    private val qrCodeScanner = QRCodeScanner(context)
    
    companion object {
        private const val SYNC_INTERVAL = 30000L // 30 seconds
        private const val BATCH_SIZE = 50
        private const val MAX_MOVEMENT_HISTORY = 1000
    }
    
    /**
     * Initialize warehouse management
     */
    suspend fun initializeWarehouse(warehouseId: String) {
        try {
            _syncStatus.postValue(SyncStatus.INITIALIZING)
            
            // Load warehouse data
            loadWarehouseData(warehouseId)
            
            // Start real-time sync
            startRealTimeSync()
            
            // Initialize scanners
            initializeScanners()
            
            _syncStatus.postValue(SyncStatus.SYNCED)
            
            Timber.d("Warehouse management initialized for: $warehouseId")
            
        } catch (e: Exception) {
            Timber.e(e, "Error initializing warehouse management")
            _syncStatus.postValue(SyncStatus.ERROR)
        }
    }
    
    /**
     * Load warehouse data from local database and API
     */
    private suspend fun loadWarehouseData(warehouseId: String) {
        try {
            // Load from local database first
            val localInventory = database.inventoryDao().getAllItems()
            val localZones = database.warehouseDao().getAllZones()
            val localShelves = database.warehouseDao().getAllShelves()
            
            // Update local maps
            localInventory.forEach { item ->
                inventoryMap[item.id] = item
            }
            
            localZones.forEach { zone ->
                zoneMap[zone.id] = zone
            }
            
            localShelves.forEach { shelf ->
                shelfMap[shelf.id] = shelf
            }
            
            // Update LiveData
            _inventoryItems.postValue(localInventory)
            _warehouseZones.postValue(localZones)
            _shelves.postValue(localShelves)
            
            // Sync with API
            syncWithAPI(warehouseId)
            
        } catch (e: Exception) {
            Timber.e(e, "Error loading warehouse data")
        }
    }
    
    /**
     * Sync data with API
     */
    private suspend fun syncWithAPI(warehouseId: String) {
        try {
            _syncStatus.postValue(SyncStatus.SYNCING)
            
            // Get latest data from API
            val apiInventory = api.getInventory(warehouseId)
            val apiZones = api.getWarehouseZones(warehouseId)
            val apiShelves = api.getWarehouseShelves(warehouseId)
            
            // Update local database
            database.inventoryDao().insertAll(apiInventory)
            database.warehouseDao().insertZones(apiZones)
            database.warehouseDao().insertShelves(apiShelves)
            
            // Update maps
            apiInventory.forEach { item ->
                inventoryMap[item.id] = item
            }
            
            apiZones.forEach { zone ->
                zoneMap[zone.id] = zone
            }
            
            apiShelves.forEach { shelf ->
                shelfMap[shelf.id] = shelf
            }
            
            // Update LiveData
            _inventoryItems.postValue(apiInventory)
            _warehouseZones.postValue(apiZones)
            _shelves.postValue(apiShelves)
            
            _syncStatus.postValue(SyncStatus.SYNCED)
            
        } catch (e: Exception) {
            Timber.e(e, "Error syncing with API")
            _syncStatus.postValue(SyncStatus.ERROR)
        }
    }
    
    /**
     * Start real-time synchronization
     */
    private fun startRealTimeSync() {
        serviceScope.launch {
            while (true) {
                try {
                    // Sync pending movements
                    syncPendingMovements()
                    
                    // Check for updates
                    checkForUpdates()
                    
                    delay(SYNC_INTERVAL)
                    
                } catch (e: Exception) {
                    Timber.e(e, "Error in real-time sync")
                    delay(5000) // Wait before retrying
                }
            }
        }
    }
    
    /**
     * Initialize barcode and QR scanners
     */
    private fun initializeScanners() {
        barcodeScanner.initialize()
        qrCodeScanner.initialize()
    }
    
    /**
     * Scan barcode or QR code
     */
    suspend fun scanCode(code: String, scanType: ScanType): ScanResult {
        return try {
            when (scanType) {
                ScanType.BARCODE -> {
                    barcodeScanner.scanBarcode(code)
                }
                ScanType.QR_CODE -> {
                    qrCodeScanner.scanQRCode(code)
                }
            }
        } catch (e: Exception) {
            Timber.e(e, "Error scanning code")
            ScanResult.ERROR
        }
    }
    
    /**
     * Receive shipment
     */
    suspend fun receiveShipment(
        shipmentId: String,
        items: List<ReceivedItem>
    ): ReceiveResult {
        return try {
            _syncStatus.postValue(SyncStatus.PROCESSING)
            
            val receivedItems = mutableListOf<InventoryItem>()
            val movements = mutableListOf<StockMovement>()
            
            items.forEach { receivedItem ->
                // Find or create inventory item
                val inventoryItem = inventoryMap[receivedItem.sku]
                    ?: createInventoryItem(receivedItem)
                
                // Update quantity
                inventoryItem.quantity += receivedItem.quantity
                inventoryItem.lastUpdated = System.currentTimeMillis()
                
                // Create stock movement
                val movement = StockMovement(
                    id = UUID.randomUUID().toString(),
                    itemId = inventoryItem.id,
                    movementType = MovementType.RECEIVED,
                    quantity = receivedItem.quantity,
                    fromLocation = "RECEIVING",
                    toLocation = receivedItem.targetLocation,
                    timestamp = System.currentTimeMillis(),
                    userId = getCurrentUserId(),
                    notes = "Received from shipment: $shipmentId"
                )
                
                receivedItems.add(inventoryItem)
                movements.add(movement)
                
                // Update maps
                inventoryMap[inventoryItem.id] = inventoryItem
            }
            
            // Save to database
            database.inventoryDao().insertAll(receivedItems)
            database.stockMovementDao().insertAll(movements)
            
            // Add to movement history
            movementHistory.addAll(movements)
            maintainMovementHistorySize()
            
            // Update LiveData
            _inventoryItems.postValue(inventoryMap.values.toList())
            _stockMovements.postValue(movementHistory.toList())
            
            _syncStatus.postValue(SyncStatus.SYNCED)
            
            ReceiveResult.SUCCESS(receivedItems.size)
            
        } catch (e: Exception) {
            Timber.e(e, "Error receiving shipment")
            _syncStatus.postValue(SyncStatus.ERROR)
            ReceiveResult.ERROR
        }
    }
    
    /**
     * Dispatch items
     */
    suspend fun dispatchItems(
        dispatchItems: List<DispatchItem>
    ): DispatchResult {
        return try {
            _syncStatus.postValue(SyncStatus.PROCESSING)
            
            val dispatchedItems = mutableListOf<InventoryItem>()
            val movements = mutableListOf<StockMovement>()
            val errors = mutableListOf<String>()
            
            dispatchItems.forEach { dispatchItem ->
                val inventoryItem = inventoryMap[dispatchItem.sku]
                
                if (inventoryItem == null) {
                    errors.add("Item not found: ${dispatchItem.sku}")
                    return@forEach
                }
                
                if (inventoryItem.quantity < dispatchItem.quantity) {
                    errors.add("Insufficient stock for ${dispatchItem.sku}")
                    return@forEach
                }
                
                // Update quantity
                inventoryItem.quantity -= dispatchItem.quantity
                inventoryItem.lastUpdated = System.currentTimeMillis()
                
                // Create stock movement
                val movement = StockMovement(
                    id = UUID.randomUUID().toString(),
                    itemId = inventoryItem.id,
                    movementType = MovementType.DISPATCHED,
                    quantity = dispatchItem.quantity,
                    fromLocation = inventoryItem.location,
                    toLocation = dispatchItem.destination,
                    timestamp = System.currentTimeMillis(),
                    userId = getCurrentUserId(),
                    notes = "Dispatched to: ${dispatchItem.destination}"
                )
                
                dispatchedItems.add(inventoryItem)
                movements.add(movement)
                
                // Update maps
                inventoryMap[inventoryItem.id] = inventoryItem
            }
            
            // Save to database
            database.inventoryDao().insertAll(dispatchedItems)
            database.stockMovementDao().insertAll(movements)
            
            // Add to movement history
            movementHistory.addAll(movements)
            maintainMovementHistorySize()
            
            // Update LiveData
            _inventoryItems.postValue(inventoryMap.values.toList())
            _stockMovements.postValue(movementHistory.toList())
            
            _syncStatus.postValue(SyncStatus.SYNCED)
            
            DispatchResult.SUCCESS(dispatchedItems.size, errors)
            
        } catch (e: Exception) {
            Timber.e(e, "Error dispatching items")
            _syncStatus.postValue(SyncStatus.ERROR)
            DispatchResult.ERROR
        }
    }
    
    /**
     * Transfer inventory between locations
     */
    suspend fun transferInventory(
        itemId: String,
        quantity: Int,
        fromLocation: String,
        toLocation: String
    ): TransferResult {
        return try {
            val inventoryItem = inventoryMap[itemId]
            
            if (inventoryItem == null) {
                return TransferResult.ITEM_NOT_FOUND
            }
            
            if (inventoryItem.quantity < quantity) {
                return TransferResult.INSUFFICIENT_STOCK
            }
            
            _syncStatus.postValue(SyncStatus.PROCESSING)
            
            // Update quantity
            inventoryItem.quantity -= quantity
            inventoryItem.lastUpdated = System.currentTimeMillis()
            
            // Create transfer movement
            val movement = StockMovement(
                id = UUID.randomUUID().toString(),
                itemId = inventoryItem.id,
                movementType = MovementType.TRANSFER,
                quantity = quantity,
                fromLocation = fromLocation,
                toLocation = toLocation,
                timestamp = System.currentTimeMillis(),
                userId = getCurrentUserId(),
                notes = "Transfer from $fromLocation to $toLocation"
            )
            
            // Save to database
            database.inventoryDao().update(inventoryItem)
            database.stockMovementDao().insert(movement)
            
            // Add to movement history
            movementHistory.add(movement)
            maintainMovementHistorySize()
            
            // Update maps
            inventoryMap[itemId] = inventoryItem
            
            // Update LiveData
            _inventoryItems.postValue(inventoryMap.values.toList())
            _stockMovements.postValue(movementHistory.toList())
            
            _syncStatus.postValue(SyncStatus.SYNCED)
            
            TransferResult.SUCCESS
            
        } catch (e: Exception) {
            Timber.e(e, "Error transferring inventory")
            _syncStatus.postValue(SyncStatus.ERROR)
            TransferResult.ERROR
        }
    }
    
    /**
     * Report damaged goods
     */
    suspend fun reportDamagedGoods(
        itemId: String,
        quantity: Int,
        damageType: DamageType,
        notes: String
    ): DamageResult {
        return try {
            val inventoryItem = inventoryMap[itemId]
            
            if (inventoryItem == null) {
                return DamageResult.ITEM_NOT_FOUND
            }
            
            if (inventoryItem.quantity < quantity) {
                return DamageResult.INSUFFICIENT_STOCK
            }
            
            _syncStatus.postValue(SyncStatus.PROCESSING)
            
            // Update quantity
            inventoryItem.quantity -= quantity
            inventoryItem.lastUpdated = System.currentTimeMillis()
            
            // Create damage movement
            val movement = StockMovement(
                id = UUID.randomUUID().toString(),
                itemId = inventoryItem.id,
                movementType = MovementType.DAMAGED,
                quantity = quantity,
                fromLocation = inventoryItem.location,
                toLocation = "DAMAGED",
                timestamp = System.currentTimeMillis(),
                userId = getCurrentUserId(),
                notes = "Damaged: $damageType - $notes"
            )
            
            // Save to database
            database.inventoryDao().update(inventoryItem)
            database.stockMovementDao().insert(movement)
            
            // Add to movement history
            movementHistory.add(movement)
            maintainMovementHistorySize()
            
            // Update maps
            inventoryMap[itemId] = inventoryItem
            
            // Update LiveData
            _inventoryItems.postValue(inventoryMap.values.toList())
            _stockMovements.postValue(movementHistory.toList())
            
            _syncStatus.postValue(SyncStatus.SYNCED)
            
            DamageResult.SUCCESS
            
        } catch (e: Exception) {
            Timber.e(e, "Error reporting damaged goods")
            _syncStatus.postValue(SyncStatus.ERROR)
            DamageResult.ERROR
        }
    }
    
    /**
     * Perform inventory audit
     */
    suspend fun performAudit(
        auditItems: List<AuditItem>
    ): AuditResult {
        return try {
            _syncStatus.postValue(SyncStatus.PROCESSING)
            
            val discrepancies = mutableListOf<InventoryDiscrepancy>()
            val adjustments = mutableListOf<InventoryItem>()
            val movements = mutableListOf<StockMovement>()
            
            auditItems.forEach { auditItem ->
                val inventoryItem = inventoryMap[auditItem.sku]
                
                if (inventoryItem == null) {
                    discrepancies.add(
                        InventoryDiscrepancy(
                            sku = auditItem.sku,
                            expectedQuantity = 0,
                            actualQuantity = auditItem.actualQuantity,
                            discrepancy = auditItem.actualQuantity,
                            type = DiscrepancyType.ITEM_NOT_FOUND
                        )
                    )
                    return@forEach
                }
                
                val discrepancy = auditItem.actualQuantity - inventoryItem.quantity
                
                if (discrepancy != 0) {
                    // Create discrepancy record
                    discrepancies.add(
                        InventoryDiscrepancy(
                            sku = auditItem.sku,
                            expectedQuantity = inventoryItem.quantity,
                            actualQuantity = auditItem.actualQuantity,
                            discrepancy = discrepancy,
                            type = if (discrepancy > 0) DiscrepancyType.OVERSTOCK else DiscrepancyType.UNDERSTOCK
                        )
                    )
                    
                    // Adjust inventory
                    inventoryItem.quantity = auditItem.actualQuantity
                    inventoryItem.lastUpdated = System.currentTimeMillis()
                    
                    // Create adjustment movement
                    val movement = StockMovement(
                        id = UUID.randomUUID().toString(),
                        itemId = inventoryItem.id,
                        movementType = MovementType.AUDIT_ADJUSTMENT,
                        quantity = kotlin.math.abs(discrepancy),
                        fromLocation = inventoryItem.location,
                        toLocation = inventoryItem.location,
                        timestamp = System.currentTimeMillis(),
                        userId = getCurrentUserId(),
                        notes = "Audit adjustment: $discrepancy units"
                    )
                    
                    adjustments.add(inventoryItem)
                    movements.add(movement)
                    
                    // Update maps
                    inventoryMap[inventoryItem.id] = inventoryItem
                }
            }
            
            // Save to database
            database.inventoryDao().updateAll(adjustments)
            database.stockMovementDao().insertAll(movements)
            
            // Add to movement history
            movementHistory.addAll(movements)
            maintainMovementHistorySize()
            
            // Update LiveData
            _inventoryItems.postValue(inventoryMap.values.toList())
            _stockMovements.postValue(movementHistory.toList())
            
            _syncStatus.postValue(SyncStatus.SYNCED)
            
            AuditResult.SUCCESS(discrepancies, adjustments.size)
            
        } catch (e: Exception) {
            Timber.e(e, "Error performing audit")
            _syncStatus.postValue(SyncStatus.ERROR)
            AuditResult.ERROR
        }
    }
    
    /**
     * Get inventory analytics
     */
    suspend fun getInventoryAnalytics(): InventoryAnalytics {
        return try {
            val totalItems = inventoryMap.size
            val totalQuantity = inventoryMap.values.sumOf { it.quantity }
            val lowStockItems = inventoryMap.values.filter { it.quantity <= it.minStockLevel }
            val outOfStockItems = inventoryMap.values.filter { it.quantity == 0 }
            val totalValue = inventoryMap.values.sumOf { it.quantity * it.unitPrice }
            
            // Zone distribution
            val zoneDistribution = zoneMap.values.map { zone ->
                val zoneItems = inventoryMap.values.filter { it.zoneId == zone.id }
                ZoneAnalytics(
                    zoneId = zone.id,
                    zoneName = zone.name,
                    itemCount = zoneItems.size,
                    totalQuantity = zoneItems.sumOf { it.quantity },
                    totalValue = zoneItems.sumOf { it.quantity * it.unitPrice }
                )
            }
            
            // Movement analytics
            val recentMovements = movementHistory.takeLast(100)
            val movementsByType = recentMovements.groupBy { it.movementType }
                .mapValues { it.value.size }
            
            InventoryAnalytics(
                totalItems = totalItems,
                totalQuantity = totalQuantity,
                lowStockItems = lowStockItems.size,
                outOfStockItems = outOfStockItems.size,
                totalValue = totalValue,
                zoneDistribution = zoneDistribution,
                movementsByType = movementsByType,
                lastUpdated = System.currentTimeMillis()
            )
            
        } catch (e: Exception) {
            Timber.e(e, "Error getting inventory analytics")
            InventoryAnalytics()
        }
    }
    
    /**
     * Create new inventory item
     */
    private fun createInventoryItem(receivedItem: ReceivedItem): InventoryItem {
        return InventoryItem(
            id = UUID.randomUUID().toString(),
            sku = receivedItem.sku,
            name = receivedItem.name,
            description = receivedItem.description,
            quantity = 0,
            minStockLevel = receivedItem.minStockLevel,
            maxStockLevel = receivedItem.maxStockLevel,
            unitPrice = receivedItem.unitPrice,
            location = receivedItem.targetLocation,
            zoneId = getZoneIdFromLocation(receivedItem.targetLocation),
            shelfId = getShelfIdFromLocation(receivedItem.targetLocation),
            barcode = receivedItem.barcode,
            qrCode = receivedItem.qrCode,
            category = receivedItem.category,
            supplier = receivedItem.supplier,
            createdAt = System.currentTimeMillis(),
            lastUpdated = System.currentTimeMillis()
        )
    }
    
    /**
     * Get zone ID from location
     */
    private fun getZoneIdFromLocation(location: String): String {
        return zoneMap.values.find { location.startsWith(it.name) }?.id ?: "UNKNOWN"
    }
    
    /**
     * Get shelf ID from location
     */
    private fun getShelfIdFromLocation(location: String): String {
        return shelfMap.values.find { location.contains(it.name) }?.id ?: "UNKNOWN"
    }
    
    /**
     * Get current user ID
     */
    private fun getCurrentUserId(): String {
        // Implementation would get current user from authentication
        return "user_123"
    }
    
    /**
     * Sync pending movements
     */
    private suspend fun syncPendingMovements() {
        try {
            val pendingMovements = database.stockMovementDao().getPendingMovements()
            
            pendingMovements.chunked(BATCH_SIZE).forEach { batch ->
                api.syncStockMovements(batch)
                
                // Mark as synced
                batch.forEach { movement ->
                    movement.synced = true
                }
                
                database.stockMovementDao().updateAll(pendingMovements)
            }
            
        } catch (e: Exception) {
            Timber.e(e, "Error syncing pending movements")
        }
    }
    
    /**
     * Check for updates
     */
    private suspend fun checkForUpdates() {
        try {
            val lastSyncTime = getLastSyncTime()
            val updates = api.getInventoryUpdates(lastSyncTime)
            
            if (updates.isNotEmpty()) {
                // Apply updates
                updates.forEach { update ->
                    val existingItem = inventoryMap[update.itemId]
                    existingItem?.let {
                        it.quantity = update.newQuantity
                        it.lastUpdated = System.currentTimeMillis()
                        inventoryMap[update.itemId] = it
                    }
                }
                
                // Update LiveData
                _inventoryItems.postValue(inventoryMap.values.toList())
                
                // Update last sync time
                updateLastSyncTime(System.currentTimeMillis())
            }
            
        } catch (e: Exception) {
            Timber.e(e, "Error checking for updates")
        }
    }
    
    /**
     * Get last sync time
     */
    private fun getLastSyncTime(): Long {
        // Implementation would get from preferences
        return System.currentTimeMillis() - (24 * 60 * 60 * 1000) // 24 hours ago
    }
    
    /**
     * Update last sync time
     */
    private fun updateLastSyncTime(timestamp: Long) {
        // Implementation would save to preferences
    }
    
    /**
     * Maintain movement history size
     */
    private fun maintainMovementHistorySize() {
        if (movementHistory.size > MAX_MOVEMENT_HISTORY) {
            movementHistory.removeAt(0)
        }
    }
    
    /**
     * Search inventory
     */
    suspend fun searchInventory(query: String): List<InventoryItem> {
        return try {
            val results = inventoryMap.values.filter { item ->
                item.sku.contains(query, ignoreCase = true) ||
                item.name.contains(query, ignoreCase = true) ||
                item.description.contains(query, ignoreCase = true) ||
                item.barcode.contains(query, ignoreCase = true) ||
                item.category.contains(query, ignoreCase = true)
            }
            
            results
            
        } catch (e: Exception) {
            Timber.e(e, "Error searching inventory")
            emptyList()
        }
    }
    
    /**
     * Filter inventory
     */
    suspend fun filterInventory(filters: InventoryFilters): List<InventoryItem> {
        return try {
            var results = inventoryMap.values.toList()
            
            // Filter by category
            filters.category?.let { category ->
                results = results.filter { it.category == category }
            }
            
            // Filter by zone
            filters.zoneId?.let { zoneId ->
                results = results.filter { it.zoneId == zoneId }
            }
            
            // Filter by stock level
            when (filters.stockLevel) {
                StockLevelFilter.IN_STOCK -> {
                    results = results.filter { it.quantity > 0 }
                }
                StockLevelFilter.LOW_STOCK -> {
                    results = results.filter { it.quantity > 0 && it.quantity <= it.minStockLevel }
                }
                StockLevelFilter.OUT_OF_STOCK -> {
                    results = results.filter { it.quantity == 0 }
                }
                null -> { /* No filter */ }
            }
            
            // Filter by price range
            filters.minPrice?.let { minPrice ->
                results = results.filter { it.unitPrice >= minPrice }
            }
            
            filters.maxPrice?.let { maxPrice ->
                results = results.filter { it.unitPrice <= maxPrice }
            }
            
            results
            
        } catch (e: Exception) {
            Timber.e(e, "Error filtering inventory")
            emptyList()
        }
    }
    
    /**
     * Cleanup resources
     */
    fun cleanup() {
        serviceScope.cancel()
        barcodeScanner.cleanup()
        qrCodeScanner.cleanup()
        
        Timber.d("Warehouse management service cleaned up")
    }
}

// Data classes
data class ReceivedItem(
    val sku: String,
    val name: String,
    val description: String,
    val quantity: Int,
    val minStockLevel: Int,
    val maxStockLevel: Int,
    val unitPrice: Double,
    val targetLocation: String,
    val barcode: String,
    val qrCode: String,
    val category: String,
    val supplier: String
)

data class DispatchItem(
    val sku: String,
    val quantity: Int,
    val destination: String
)

data class AuditItem(
    val sku: String,
    val actualQuantity: Int
)

data class InventoryDiscrepancy(
    val sku: String,
    val expectedQuantity: Int,
    val actualQuantity: Int,
    val discrepancy: Int,
    val type: DiscrepancyType
)

data class ZoneAnalytics(
    val zoneId: String,
    val zoneName: String,
    val itemCount: Int,
    val totalQuantity: Int,
    val totalValue: Double
)

data class InventoryAnalytics(
    val totalItems: Int = 0,
    val totalQuantity: Int = 0,
    val lowStockItems: Int = 0,
    val outOfStockItems: Int = 0,
    val totalValue: Double = 0.0,
    val zoneDistribution: List<ZoneAnalytics> = emptyList(),
    val movementsByType: Map<MovementType, Int> = emptyMap(),
    val lastUpdated: Long = System.currentTimeMillis()
)

data class InventoryFilters(
    val category: String? = null,
    val zoneId: String? = null,
    val stockLevel: StockLevelFilter? = null,
    val minPrice: Double? = null,
    val maxPrice: Double? = null
)

// Enums
enum class ScanType {
    BARCODE, QR_CODE
}

enum class ScanResult {
    SUCCESS, ERROR, NOT_FOUND, INVALID_FORMAT
}

enum class ReceiveResult {
    SUCCESS, ERROR, PARTIAL_SUCCESS
}

enum class DispatchResult {
    SUCCESS, ERROR, PARTIAL_SUCCESS
}

enum class TransferResult {
    SUCCESS, ERROR, ITEM_NOT_FOUND, INSUFFICIENT_STOCK
}

enum class DamageResult {
    SUCCESS, ERROR, ITEM_NOT_FOUND, INSUFFICIENT_STOCK
}

enum class AuditResult {
    SUCCESS, ERROR, PARTIAL_SUCCESS
}

enum class SyncStatus {
    INITIALIZING, SYNCING, SYNCED, ERROR, PROCESSING
}

enum class MovementType {
    RECEIVED, DISPATCHED, TRANSFER, DAMAGED, AUDIT_ADJUSTMENT, RETURNED
}

enum class DamageType {
    BROKEN, DAMAGED, EXPIRED, LOST, OTHER
}

enum class DiscrepancyType {
    OVERSTOCK, UNDERSTOCK, ITEM_NOT_FOUND
}

enum class StockLevelFilter {
    IN_STOCK, LOW_STOCK, OUT_OF_STOCK
}
