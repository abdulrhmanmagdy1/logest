package com.edham.logistics.feature.coldchain.adapters

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.ImageView
import android.widget.ProgressBar
import android.widget.TextView
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.feature.coldchain.SensorStatus
import java.text.SimpleDateFormat
import java.util.*

class SensorStatusAdapter : RecyclerView.Adapter<SensorStatusAdapter.ViewHolder>() {
    
    private var sensors = mutableListOf<SensorStatus>()
    private val timeFormat = SimpleDateFormat("HH:mm", Locale.getDefault())
    
    fun updateSensors(newSensors: List<SensorStatus>) {
        sensors.clear()
        sensors.addAll(newSensors)
        notifyDataSetChanged()
    }
    
    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): ViewHolder {
        val view = LayoutInflater.from(parent.context).inflate(R.layout.item_sensor_status, parent, false)
        return ViewHolder(view)
    }
    
    override fun onBindViewHolder(holder: ViewHolder, position: Int) {
        holder.bind(sensors[position])
    }
    
    override fun getItemCount(): Int = sensors.size
    
    inner class ViewHolder(itemView: View) : RecyclerView.ViewHolder(itemView) {
        private val sensorIcon: ImageView = itemView.findViewById(R.id.sensorIcon)
        private val sensorName: TextView = itemView.findViewById(R.id.sensorName)
        private val sensorStatus: TextView = itemView.findViewById(R.id.sensorStatus)
        private val batteryLevel: TextView = itemView.findViewById(R.id.batteryLevel)
        private val batteryProgressBar: ProgressBar = itemView.findViewById(R.id.batteryProgressBar)
        private val lastUpdate: TextView = itemView.findViewById(R.id.lastUpdate)
        private val statusIndicator: View = itemView.findViewById(R.id.statusIndicator)
        
        fun bind(sensor: SensorStatus) {
            // Set sensor name
            sensorName.text = "Sensor ${sensor.id.takeLast(4)}"
            
            // Set status
            val statusText = if (sensor.isActive) "ACTIVE" else "OFFLINE"
            sensorStatus.text = statusText
            
            // Set battery level
            batteryLevel.text = String.format("%.0f%%", sensor.batteryLevel)
            batteryProgressBar.progress = sensor.batteryLevel.toInt()
            
            // Set last update time
            lastUpdate.text = if (sensor.lastReading != null) {
                timeFormat.format(Date(sensor.lastReading!!.timestamp))
            } else {
                "No data"
            }
            
            // Set colors and icons based on status
            if (sensor.isActive) {
                // Active sensor
                statusIndicator.setBackgroundColor(itemView.context.getColor(R.color.status_active))
                sensorIcon.setImageResource(R.drawable.ic_sensor_active)
                sensorIcon.setColorFilter(itemView.context.getColor(R.color.status_active))
                
                // Battery color based on level
                val batteryColor = when {
                    sensor.batteryLevel > 60 -> itemView.context.getColor(R.color.battery_good)
                    sensor.batteryLevel > 20 -> itemView.context.getColor(R.color.battery_warning)
                    else -> itemView.context.getColor(R.color.battery_critical)
                }
                
                batteryLevel.setTextColor(batteryColor)
                batteryProgressBar.progressDrawable?.setTint(batteryColor)
                
                // Show last reading info
                sensor.lastReading?.let { reading ->
                    val tempInfo = String.format("%.1f°C", reading.temperature)
                    val humidityInfo = String.format("%.1f%%", reading.humidity)
                    
                    // You could add additional TextViews for temperature and humidity
                }
                
            } else {
                // Offline sensor
                statusIndicator.setBackgroundColor(itemView.context.getColor(R.color.status_offline))
                sensorIcon.setImageResource(R.drawable.ic_sensor_offline)
                sensorIcon.setColorFilter(itemView.context.getColor(R.color.status_offline))
                
                batteryLevel.setTextColor(itemView.context.getColor(R.color.text_secondary))
                batteryProgressBar.progressDrawable?.setTint(itemView.context.getColor(R.color.text_secondary))
            }
            
            // Set card background based on status
            val backgroundColor = if (sensor.isActive) {
                itemView.context.getColor(R.color.sensor_active_bg)
            } else {
                itemView.context.getColor(R.color.sensor_offline_bg)
            }
            
            itemView.setBackgroundColor(backgroundColor)
            
            // Set click listener for sensor details
            itemView.setOnClickListener {
                // Show sensor details dialog
                showSensorDetails(sensor)
            }
        }
        
        private fun showSensorDetails(sensor: SensorStatus) {
            // Implementation would show a dialog with detailed sensor information
            // including calibration data, error history, maintenance schedule, etc.
        }
    }
}
