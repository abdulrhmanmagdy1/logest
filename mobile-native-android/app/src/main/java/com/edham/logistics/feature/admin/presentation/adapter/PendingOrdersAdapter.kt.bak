package com.edham.logistics.feature.admin.presentation.adapter

import android.view.LayoutInflater
import android.view.ViewGroup
import androidx.recyclerview.widget.DiffUtil
import androidx.recyclerview.widget.ListAdapter
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.databinding.ItemPendingOrderBinding
import com.edham.logistics.feature.admin.domain.model.AdminOrder
import javax.inject.Inject

class PendingOrdersAdapter @Inject constructor(
    private val onOrderAction: (AdminOrder, String) -> Unit
) : ListAdapter<AdminOrder, PendingOrdersAdapter.PendingOrderViewHolder>(PendingOrderDiffCallback()) {

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): PendingOrderViewHolder {
        val binding = ItemPendingOrderBinding.inflate(
            LayoutInflater.from(parent.context),
            parent,
            false
        )
        return PendingOrderViewHolder(binding)
    }

    override fun onBindViewHolder(holder: PendingOrderViewHolder, position: Int) {
        holder.bind(getItem(position))
    }

    inner class PendingOrderViewHolder(
        private val binding: ItemPendingOrderBinding
    ) : RecyclerView.ViewHolder(binding.root) {

        fun bind(order: AdminOrder) {
            binding.apply {
                textOrderNumber.text = order.orderNumber
                textCustomerName.text = order.customerName
                textCustomerPhone.text = order.customerPhone
                textPickupLocation.text = order.pickupLocation.address
                textDeliveryLocation.text = order.deliveryLocation.address
                textCargoType.text = formatCargoType(order.cargoType)
                textWeight.text = "${order.weight} كجم"
                textEstimatedPrice.text = formatPrice(order.estimatedPrice)
                textStatus.text = formatOrderStatus(order.status)
                
                // Set status color
                textStatus.setTextColor(getOrderStatusColor(order.status))
                
                // Show special instructions if available
                if (order.specialInstructions?.isNotBlank() == true) {
                    textSpecialInstructions.text = order.specialInstructions
                    textSpecialInstructions.visible()
                } else {
                    textSpecialInstructions.gone()
                }
                
                // Show priority badge
                textPriority.text = formatPriority(order.priority)
                textPriority.setBackgroundColor(getPriorityColor(order.priority))
                
                // Set click listeners
                buttonApprove.setOnClickListener {
                    onOrderAction(order, "approve")
                }
                
                buttonReject.setOnClickListener {
                    onOrderAction(order, "reject")
                }
                
                root.setOnClickListener {
                    onOrderAction(order, "details")
                }
                
                // Show/hide action buttons based on status
                buttonApprove.visibility = when (order.status) {
                    com.edham.logistics.feature.admin.domain.model.OrderStatus.PENDING -> android.view.View.VISIBLE
                    else -> android.view.View.GONE
                }
                
                buttonReject.visibility = when (order.status) {
                    com.edham.logistics.feature.admin.domain.model.OrderStatus.PENDING -> android.view.View.VISIBLE
                    else -> android.view.View.GONE
                }
            }
        }
        
        private fun formatCargoType(cargoType: String): String {
            return when (cargoType) {
                "general" -> "بضائع عامة"
                "refrigerated" -> "بضائع مبردة"
                "fragile" -> "بضائع قابلة للكسر"
                "heavy" -> "بضائع ثقيلة"
                "urgent" -> "بضائع عاجلة"
                "documents" -> "مستندات"
                "electronics" -> "إلكترونيات"
                "food" -> "مواد غذائية"
                "medical" -> "معدات طبية"
                "chemicals" -> "مواد كيميائية"
                "livestock" -> "مواشي"
                "vehicles" -> "مركبات"
                else -> cargoType
            }
        }
        
        private fun formatOrderStatus(status: com.edham.logistics.feature.admin.domain.model.OrderStatus): String {
            return when (status) {
                com.edham.logistics.feature.admin.domain.model.OrderStatus.PENDING -> "في انتظار"
                com.edham.logistics.feature.admin.domain.model.OrderStatus.APPROVED -> "موافق عليه"
                com.edham.logistics.feature.admin.domain.model.OrderStatus.REJECTED -> "مرفوض"
                com.edham.logistics.feature.admin.domain.model.OrderStatus.CANCELLED -> "ملغي"
            }
        }
        
        private fun formatPriority(priority: String): String {
            return when (priority) {
                "normal" -> "عادي"
                "express" -> "سريع"
                "urgent" -> "عاجل"
                "economy" -> "اقتصادي"
                else -> priority
            }
        }
        
        private fun formatPrice(price: Double): String {
            return String.format("%.2f ريال", price)
        }
        
        private fun getOrderStatusColor(status: com.edham.logistics.feature.admin.domain.model.OrderStatus): Int {
            return when (status) {
                com.edham.logistics.feature.admin.domain.model.OrderStatus.PENDING -> android.graphics.Color.parseColor("#FF9800")
                com.edham.logistics.feature.admin.domain.model.OrderStatus.APPROVED -> android.graphics.Color.parseColor("#4CAF50")
                com.edham.logistics.feature.admin.domain.model.OrderStatus.REJECTED -> android.graphics.Color.parseColor("#F44336")
                com.edham.logistics.feature.admin.domain.model.OrderStatus.CANCELLED -> android.graphics.Color.parseColor("#9E9E9E")
            }
        }
        
        private fun getPriorityColor(priority: String): Int {
            return when (priority) {
                "normal" -> android.graphics.Color.parseColor("#9E9E9E")
                "express" -> android.graphics.Color.parseColor("#2196F3")
                "urgent" -> android.graphics.Color.parseColor("#F44336")
                "economy" -> android.graphics.Color.parseColor("#4CAF50")
                else -> android.graphics.Color.parseColor("#9E9E9E")
            }
        }
    }

    private class PendingOrderDiffCallback : DiffUtil.ItemCallback<AdminOrder>() {
        override fun areItemsTheSame(oldItem: AdminOrder, newItem: AdminOrder): Boolean {
            return oldItem.id == newItem.id
        }

        override fun areContentsTheSame(oldItem: AdminOrder, newItem: AdminOrder): Boolean {
            return oldItem == newItem
        }
    }
}
