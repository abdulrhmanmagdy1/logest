package com.edham.logistics.feature.analytics.domain.usecase

import com.edham.logistics.core.utils.Result
import com.edham.logistics.feature.analytics.domain.model.*
import com.edham.logistics.feature.analytics.domain.repository.AnalyticsRepository
import kotlinx.coroutines.flow.Flow
import javax.inject.Inject

class GetAnalyticsUseCase @Inject constructor(
    private val analyticsRepository: AnalyticsRepository
) {
    
    suspend operator fun invoke(request: GetAnalyticsRequest): Result<AnalyticsData> {
        return when (request.analyticsType) {
            AnalyticsType.REVENUE_ANALYTICS -> getRevenueAnalytics(request)
            AnalyticsType.PERFORMANCE_ANALYTICS -> getPerformanceAnalytics(request)
            AnalyticsType.USAGE_ANALYTICS -> getUsageAnalytics(request)
            else -> Result.Error(Exception("Invalid analytics type"))
        }
    }
    
    private suspend fun getRevenueAnalytics(request: GetAnalyticsRequest): Result<RevenueAnalytics> {
        return analyticsRepository.getRevenueAnalytics(request.userId, request.filters)
    }
    
    private suspend fun getPerformanceAnalytics(request: GetAnalyticsRequest): Result<PerformanceAnalytics> {
        return analyticsRepository.getPerformanceAnalytics(request.userId, request.filters)
    }
    
    private suspend fun getUsageAnalytics(request: GetAnalyticsRequest): Result<UsageAnalytics> {
        return analyticsRepository.getUsageAnalytics(request.userId, request.filters)
    }
    
    suspend fun observeDashboardUpdates(userId: String, userRole: String): Flow<Result<DashboardData>> {
        return analyticsRepository.observeDashboardUpdates(userId, userRole)
    }
}

// Additional analytics data types
data class RevenueAnalytics(
    val totalRevenue: Double,
    val monthlyRevenue: List<MonthlyRevenue>,
    val revenueByCategory: Map<String, Double>,
    val revenueGrowth: Double,
    val topRevenueSources: List<RevenueSource>,
    val forecast: RevenueForecast
)

data class PerformanceAnalytics(
    val overallScore: Double,
    val keyMetrics: Map<String, Double>,
    val trends: List<PerformanceTrend>,
    val benchmarks: Map<String, Double>,
    val recommendations: List<String>
)

data class UsageAnalytics(
    val totalUsers: Long,
    val activeUsers: Long,
    val usageByFeature: Map<String, Long>,
    val userRetention: Double,
    val engagementMetrics: Map<String, Double>
)

data class PerformanceTrend(
    val metric: String,
    val currentValue: Double,
    val previousValue: Double,
    val trend: TrendDirection,
    val period: String
)

data class RevenueForecast(
    val nextMonth: Double,
    val nextQuarter: Double,
    val confidence: Double,
    val factors: List<String>
)
