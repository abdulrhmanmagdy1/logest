package com.edham.logistics.feature.customer.presentation.adapter

import android.view.LayoutInflater
import android.view.ViewGroup
import androidx.recyclerview.widget.DiffUtil
import androidx.recyclerview.widget.ListAdapter
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.databinding.ItemRecentShipmentBinding
import com.edham.logistics.feature.customer.domain.model.CustomerShipment
import com.edham.logistics.presentation.util.DateFormatter
import javax.inject.Inject

class RecentShipmentsAdapter @Inject constructor(
    private val dateFormatter: DateFormatter
) : ListAdapter<CustomerShipment, RecentShipmentsAdapter.RecentShipmentViewHolder>(RecentShipmentDiffCallback()) {

    private var onItemClickListener: ((CustomerShipment) -> Unit)? = null

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): RecentShipmentViewHolder {
        val binding = ItemRecentShipmentBinding.inflate(
            LayoutInflater.from(parent.context),
            parent,
            false
        )
        return RecentShipmentViewHolder(binding)
    }

    override fun onBindViewHolder(holder: RecentShipmentViewHolder, position: Int) {
        holder.bind(getItem(position))
    }

    fun setOnItemClickListener(listener: (CustomerShipment) -> Unit) {
        onItemClickListener = listener
    }

    inner class RecentShipmentViewHolder(
        private val binding: ItemRecentShipmentBinding
    ) : RecyclerView.ViewHolder(binding.root) {

        fun bind(shipment: CustomerShipment) {
            binding.apply {
                textTrackingNumber.text = shipment.trackingNumber
                textCargoType.text = formatCargoType(shipment.cargoType)
                textPickupAddress.text = shipment.pickupAddress
                textDeliveryAddress.text = shipment.deliveryAddress
                textPrice.text = formatPrice(shipment.price)
                textStatus.text = formatStatus(shipment.status)
                textDate.text = dateFormatter.formatRelativeTime(shipment.createdAt)
                
                // Set status color
                textStatus.setTextColor(getStatusColor(shipment.status))
                
                // Set status icon
                imageStatusIcon.setImageResource(getStatusIcon(shipment.status))
                imageStatusIcon.setColorFilter(getStatusColor(shipment.status))
                
                // Show temperature if available
                if (shipment.temperature != null) {
                    textTemperature.text = "${shipment.temperature}°C"
                    layoutTemperature.visible()
                } else {
                    layoutTemperature.gone()
                }
                
                root.setOnClickListener {
                    onItemClickListener?.invoke(shipment)
                }
            }
        }
        
        private fun formatCargoType(cargoType: String): String {
            return when (cargoType) {
                "general" -> "بضائع عامة"
                "refrigerated" -> "بضائع مبردة"
                "fragile" -> "بضائع قابلة للكسر"
                "heavy" -> "بضائع ثقيلة"
                "urgent" -> "بضائع عاجلة"
                "documents" -> "مستندات"
                "electronics" -> "إلكترونيات"
                "food" -> "مواد غذائية"
                "medical" -> "معدات طبية"
                "chemicals" -> "مواد كيميائية"
                "livestock" -> "مواشي"
                "vehicles" -> "مركبات"
                else -> cargoType
            }
        }
        
        private fun formatStatus(status: String): String {
            return when (status) {
                "pending" -> "في انتظار"
                "received" -> "تم الاستلام"
                "preparing" -> "قيد التحضير"
                "loaded" -> "تم التحميل"
                "in_transit" -> "قيد النقل"
                "out_for_delivery" -> "خارج للتسليم"
                "delivered" -> "تم التسليم"
                "cancelled" -> "ملغي"
                "delayed" -> "متأخر"
                else -> status
            }
        }
        
        private fun formatPrice(price: Double): String {
            return String.format("%.2f ريال", price)
        }
        
        private fun getStatusColor(status: String): Int {
            return when (status) {
                "pending" -> android.graphics.Color.parseColor("#FF9800")
                "received" -> android.graphics.Color.parseColor("#2196F3")
                "preparing" -> android.graphics.Color.parseColor("#673AB7")
                "loaded" -> android.graphics.Color.parseColor("#4CAF50")
                "in_transit" -> android.graphics.Color.parseColor("#2196F3")
                "out_for_delivery" -> android.graphics.Color.parseColor("#9C27B0")
                "delivered" -> android.graphics.Color.parseColor("#4CAF50")
                "cancelled" -> android.graphics.Color.parseColor("#F44336")
                "delayed" -> android.graphics.Color.parseColor("#FF5722")
                else -> android.graphics.Color.parseColor("#9E9E9E")
            }
        }
        
        private fun getStatusIcon(status: String): Int {
            return when (status) {
                "pending" -> com.edham.logistics.R.drawable.ic_pending
                "received" -> com.edham.logistics.R.drawable.ic_received
                "preparing" -> com.edham.logistics.R.drawable.ic_preparing
                "loaded" -> com.edham.logistics.R.drawable.ic_loaded
                "in_transit" -> com.edham.logistics.R.drawable.ic_transit
                "out_for_delivery" -> com.edham.logistics.R.drawable.ic_out_for_delivery
                "delivered" -> com.edham.logistics.R.drawable.ic_delivered
                "cancelled" -> com.edham.logistics.R.drawable.ic_cancelled
                "delayed" -> com.edham.logistics.R.drawable.ic_delayed
                else -> com.edham.logistics.R.drawable.ic_pending
            }
        }
    }

    private class RecentShipmentDiffCallback : DiffUtil.ItemCallback<CustomerShipment>() {
        override fun areItemsTheSame(oldItem: CustomerShipment, newItem: CustomerShipment): Boolean {
            return oldItem.id == newItem.id
        }

        override fun areContentsTheSame(oldItem: CustomerShipment, newItem: CustomerShipment): Boolean {
            return oldItem == newItem
        }
    }
}
