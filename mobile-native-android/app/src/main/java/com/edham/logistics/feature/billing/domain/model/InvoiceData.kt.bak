package com.edham.logistics.feature.billing.domain.model

// Invoice Data Models
data class Invoice(
    val id: String,
    val invoiceNumber: String,
    val shipmentId: String,
    val customerId: String,
    val customerName: String,
    val customerEmail: String,
    val customerPhone: String,
    val customerAddress: String,
    val issueDate: Long,
    val dueDate: Long,
    val status: InvoiceStatus,
    val subtotal: Double,
    val taxAmount: Double,
    val discountAmount: Double,
    val totalAmount: Double,
    val currency: String,
    val items: List<InvoiceItem>,
    val paymentTerms: String,
    val notes: String?,
    val attachments: List<String>,
    val createdBy: String,
    val createdAt: Long,
    val updatedAt: Long,
    val paidAt: Long?,
    val paymentMethod: String?,
    val transactionId: String?,
    val metadata: Map<String, Any>
)

data class InvoiceItem(
    val id: String,
    val invoiceId: String,
    val description: String,
    val quantity: Int,
    val unitPrice: Double,
    val totalPrice: Double,
    val itemType: InvoiceItemType,
    val metadata: Map<String, Any>
)

enum class InvoiceStatus {
    DRAFT,
    ISSUED,
    SENT,
    PAID,
    PARTIALLY_PAID,
    OVERDUE,
    CANCELLED,
    REFUNDED
}

enum class InvoiceItemType {
    SHIPPING_FEE,
    INSURANCE,
    FUEL_SURCHARGE,
    HANDLING_FEE,
    STORAGE_FEE,
    DELAY_PENALTY,
    SPECIAL_SERVICE,
    DISCOUNT,
    TAX
}

// Payment Data Models
data class Payment(
    val id: String,
    val invoiceId: String,
    val customerId: String,
    val amount: Double,
    val currency: String,
    val paymentMethod: PaymentMethod,
    val paymentStatus: PaymentStatus,
    val transactionId: String,
    val gatewayTransactionId: String?,
    val paymentDate: Long,
    val processedAt: Long?,
    val failureReason: String?,
    val gatewayResponse: Map<String, Any>?,
    val metadata: Map<String, Any>,
    val createdBy: String,
    val createdAt: Long,
    val updatedAt: Long
)

enum class PaymentMethod {
    CREDIT_CARD,
    DEBIT_CARD,
    BANK_TRANSFER,
    CASH,
    CHECK,
    ONLINE_PAYMENT,
    MOBILE_WALLET,
    CRYPTOCURRENCY
}

enum class PaymentStatus {
    PENDING,
    PROCESSING,
    COMPLETED,
    FAILED,
    CANCELLED,
    REFUNDED,
    PARTIALLY_REFUNDED
}

// Payment Gateway Models
data class PaymentGateway(
    val id: String,
    val name: String,
    val type: PaymentGatewayType,
    val isActive: Boolean,
    val configuration: PaymentGatewayConfig,
    val supportedMethods: List<PaymentMethod>,
    val supportedCurrencies: List<String>,
    val fees: PaymentGatewayFees,
    val createdAt: Long,
    val updatedAt: Long
)

enum class PaymentGatewayType {
    STRIPE,
    PAYPAL,
    SQUARE,
    AUTHORIZENET,
    LOCAL_BANK,
    MOBILE_PAYMENT
}

data class PaymentGatewayConfig(
    val publicKey: String,
    val secretKey: String,
    val webhookUrl: String?,
    val environment: String, // sandbox, production
    val additionalConfig: Map<String, Any>
)

data class PaymentGatewayFees(
    val transactionFee: Double,
    val fixedFee: Double,
    val percentageFee: Double,
    val currency: String
)

// Billing Settings
data class BillingSettings(
    val id: String,
    val companyId: String,
    val defaultCurrency: String,
    val taxRate: Double,
    autoGenerateInvoices: Boolean,
    val paymentTerms: String,
    val lateFeePercentage: Double,
    val lateFeeGracePeriod: Int, // days
    val invoicePrefix: String,
    val invoiceNumberFormat: String,
    val emailTemplates: Map<String, EmailTemplate>,
    val smsTemplates: Map<String, SmsTemplate>,
    val paymentGateways: List<PaymentGateway>,
    val createdAt: Long,
    val updatedAt: Long
)

data class EmailTemplate(
    val id: String,
    val type: EmailTemplateType,
    val subject: String,
    val body: String,
    val variables: List<String>,
    val isActive: Boolean
)

enum class EmailTemplateType {
    INVOICE_ISSUED,
    PAYMENT_RECEIVED,
    PAYMENT_FAILED,
    OVERDUE_REMINDER,
    INVOICE_CANCELLED
}

data class SmsTemplate(
    val id: String,
    val type: SmsTemplateType,
    val message: String,
    val variables: List<String>,
    val isActive: Boolean
)

enum class SmsTemplateType {
    PAYMENT_RECEIVED,
    PAYMENT_FAILED,
    OVERDUE_REMINDER,
    PAYMENT_CONFIRMATION
}

// Financial Reports
data class FinancialReport(
    val id: String,
    val type: FinancialReportType,
    val title: String,
    val description: String,
    val period: ReportPeriod,
    val generatedAt: Long,
    val generatedBy: String,
    val data: FinancialReportData,
    val summary: FinancialSummary,
    val charts: List<Chart>,
    val tables: List<Table>
)

enum class FinancialReportType {
    REVENUE_REPORT,
    EXPENSE_REPORT,
    PROFIT_LOSS_REPORT,
    CASH_FLOW_REPORT,
    AGING_REPORT,
    TAX_REPORT,
    CUSTOMER_REPORT
}

data class ReportPeriod(
    val startDate: Long,
    val endDate: Long,
    val type: ReportPeriodType
)

enum class ReportPeriodType {
    DAILY,
    WEEKLY,
    MONTHLY,
    QUARTERLY,
    YEARLY,
    CUSTOM
}

data class FinancialReportData(
    val totalRevenue: Double,
    val totalExpenses: Double,
    val netProfit: Double,
    val totalInvoices: Long,
    val paidInvoices: Long,
    val unpaidInvoices: Long,
    val overdueInvoices: Long,
    val totalPayments: Double,
    val averageInvoiceAmount: Double,
    val revenueByMonth: List<MonthlyRevenue>,
    val expensesByCategory: Map<String, Double>,
    val topCustomers: List<CustomerRevenue>,
    val paymentMethods: Map<PaymentMethod, Double>
)

data class FinancialSummary(
    val revenue: SummaryMetric,
    val expenses: SummaryMetric,
    val profit: SummaryMetric,
    val invoices: SummaryMetric,
    val payments: SummaryMetric
)

data class SummaryMetric(
    val current: Double,
    val previous: Double,
    val growth: Double,
    val trend: TrendDirection
)

data class CustomerRevenue(
    val customerId: String,
    val customerName: String,
    val totalRevenue: Double,
    val invoiceCount: Long,
    val averageInvoiceAmount: Double,
    val lastPaymentDate: Long?
)

data class Chart(
    val id: String,
    val type: ChartType,
    val title: String,
    val data: ChartData,
    val options: ChartOptions
)

enum class ChartType {
    LINE_CHART,
    BAR_CHART,
    PIE_CHART,
    AREA_CHART
}

data class ChartData(
    val labels: List<String>,
    val datasets: List<DataSet>
)

data class DataSet(
    val label: String,
    val data: List<Double>,
    val backgroundColor: String?,
    val borderColor: String?,
    val borderWidth: Int = 1
)

data class ChartOptions(
    val responsive: Boolean = true,
    val maintainAspectRatio: Boolean = false,
    val legend: Boolean = true,
    val animation: Boolean = true
)

data class Table(
    val id: String,
    val title: String,
    val headers: List<String>,
    val rows: List<List<String>>,
    val sortable: Boolean = true,
    val filterable: Boolean = true
)

// Request/Response Models
data class CreateInvoiceRequest(
    val shipmentId: String,
    val customerId: String,
    val items: List<CreateInvoiceItemRequest>,
    val issueDate: Long,
    val dueDate: Long,
    val paymentTerms: String,
    val notes: String?,
    val autoSend: Boolean = false
)

data class CreateInvoiceItemRequest(
    val description: String,
    val quantity: Int,
    val unitPrice: Double,
    val itemType: InvoiceItemType
)

data class UpdateInvoiceRequest(
    val id: String,
    val status: InvoiceStatus?,
    val dueDate: Long?,
    val notes: String?,
    val items: List<UpdateInvoiceItemRequest>?
)

data class UpdateInvoiceItemRequest(
    val id: String,
    val description: String?,
    val quantity: Int?,
    val unitPrice: Double?
)

data class ProcessPaymentRequest(
    val invoiceId: String,
    val amount: Double,
    val paymentMethod: PaymentMethod,
    val gatewayId: String,
    val customerPaymentDetails: CustomerPaymentDetails
)

data class CustomerPaymentDetails(
    val cardNumber: String?,
    val expiryDate: String?,
    val cvv: String?,
    val cardholderName: String?,
    val bankAccountNumber: String?,
    val bankRoutingNumber: String?,
    val walletNumber: String?,
    val billingAddress: BillingAddress?
)

data class BillingAddress(
    val street: String,
    val city: String,
    val state: String,
    val zipCode: String,
    val country: String
)

data class GenerateInvoiceRequest(
    val shipmentId: String,
    val autoCalculate: Boolean = true,
    val customItems: List<CreateInvoiceItemRequest>?
)

data class ExportInvoiceRequest(
    val invoiceId: String,
    val format: ExportFormat,
    val includePaymentHistory: Boolean = false,
    val includeAttachments: Boolean = false
)

enum class ExportFormat {
    PDF,
    EXCEL,
    CSV,
    JSON
}

data class GetInvoicesRequest(
    val customerId: String?,
    val status: InvoiceStatus?,
    val dateRange: DateRange?,
    val limit: Int = 50,
    val offset: Int = 0,
    val sortBy: String = "createdAt",
    val sortOrder: String = "desc"
)

data class GetPaymentsRequest(
    val invoiceId: String?,
    val customerId: String?,
    val paymentMethod: PaymentMethod?,
    val paymentStatus: PaymentStatus?,
    val dateRange: DateRange?,
    val limit: Int = 50,
    val offset: Int = 0,
    val sortBy: String = "createdAt",
    val sortOrder: String = "desc"
)

data class DateRange(
    val startDate: Long,
    val endDate: Long
)

// WebSocket Models
data class BillingWebSocketMessage(
    val type: BillingWebSocketType,
    val data: Any,
    val timestamp: Long,
    val userId: String?,
    val userRole: String?
)

enum class BillingWebSocketType {
    INVOICE_CREATED,
    INVOICE_UPDATED,
    PAYMENT_RECEIVED,
    PAYMENT_FAILED,
    INVOICE_OVERDUE,
    REPORT_GENERATED
}
