package com.edham.logistics.feature.driver.adapters

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.TextView
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.feature.driver.EarningRecord
import java.text.SimpleDateFormat
import java.util.*

class EarningsAdapter(
    private val earnings: List<EarningRecord>
) : RecyclerView.Adapter<EarningsAdapter.ViewHolder>() {
    
    private val dateFormat = SimpleDateFormat("MMM dd, yyyy", Locale.getDefault())
    private val currencyFormat = java.text.NumberFormat.getCurrencyInstance(Locale.US)
    
    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): ViewHolder {
        val view = LayoutInflater.from(parent.context).inflate(R.layout.item_earning_record, parent, false)
        return ViewHolder(view)
    }
    
    override fun onBindViewHolder(holder: ViewHolder, position: Int) {
        holder.bind(earnings[position])
    }
    
    override fun getItemCount(): Int = earnings.size
    
    inner class ViewHolder(itemView: View) : RecyclerView.ViewHolder(itemView) {
        private val earningDate: TextView = itemView.findViewById(R.id.earningDate)
        private val earningAmount: TextView = itemView.findViewById(R.id.earningAmount)
        private val earningType: TextView = itemView.findViewById(R.id.earningType)
        private val earningDescription: TextView = itemView.findViewById(R.id.earningDescription)
        private val earningTrips: TextView = itemView.findViewById(R.id.earningTrips)
        private val earningDistance: TextView = itemView.findViewById(R.id.earningDistance)
        private val earningBonus: TextView = itemView.findViewById(R.id.earningBonus)
        private val typeIndicator: View = itemView.findViewById(R.id.typeIndicator)
        
        fun bind(earning: EarningRecord) {
            // Set date
            earningDate.text = dateFormat.format(Date(earning.date))
            
            // Set amount with currency format
            earningAmount.text = currencyFormat.format(earning.amount)
            
            // Set type and description
            earningType.text = earning.type
            earningDescription.text = earning.description
            
            // Set metrics
            earningTrips.text = "${earning.trips} trips"
            earningDistance.text = String.format("%.1f km", earning.distance)
            
            // Set bonus if applicable
            if (earning.bonus > 0) {
                earningBonus.text = "Bonus: ${currencyFormat.format(earning.bonus)}"
                earningBonus.visibility = View.VISIBLE
            } else {
                earningBonus.visibility = View.GONE
            }
            
            // Set type indicator color
            val color = when (earning.type) {
                "DELIVERY" -> itemView.context.getColor(R.color.earning_delivery)
                "BONUS" -> itemView.context.getColor(R.color.earning_bonus)
                "TIP" -> itemView.context.getColor(R.color.earning_tip)
                "PENALTY" -> itemView.context.getColor(R.color.earning_penalty)
                else -> itemView.context.getColor(R.color.earning_default)
            }
            
            typeIndicator.setBackgroundColor(color)
            
            // Set text color based on type
            when (earning.type) {
                "PENALTY" -> {
                    earningAmount.setTextColor(itemView.context.getColor(R.color.text_penalty))
                }
                "BONUS", "TIP" -> {
                    earningAmount.setTextColor(itemView.context.getColor(R.color.text_bonus))
                }
                else -> {
                    earningAmount.setTextColor(itemView.context.getColor(R.color.text_primary))
                }
            }
        }
    }
}
