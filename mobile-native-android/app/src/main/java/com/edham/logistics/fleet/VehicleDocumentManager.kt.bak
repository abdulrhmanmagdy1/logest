package com.edham.logistics.fleet

import android.content.Context
import com.edham.logistics.data.local.database.EdhamDatabase
import com.edham.logistics.data.local.entity.VehicleEntity
import com.edham.logistics.data.local.entity.VehicleDocumentEntity
import com.edham.logistics.data.remote.api.FleetApi
import com.edham.logistics.tracking.LiveTrackingManager
import com.edham.logistics.utils.NetworkUtils
import kotlinx.coroutines.Dispatchers
import kotlinx.coroutines.flow.MutableStateFlow
import kotlinx.coroutines.flow.StateFlow
import kotlinx.coroutines.flow.asStateFlow
import kotlinx.coroutines.withContext
import java.util.*
import javax.inject.Inject
import javax.inject.Singleton

/**
 * Vehicle Document Manager - Comprehensive vehicle document management system
 * 
 * Features:
 * - Document storage and management
 * - Document categorization
 * - Expiry tracking
 * - Compliance monitoring
 * - Document versioning
 * - Digital signatures
 * - Document sharing
 * - Audit trail
 */
@Singleton
class VehicleDocumentManager @Inject constructor(
    private val context: Context,
    private val database: EdhamDatabase,
    private val fleetApi: FleetApi,
    private val liveTrackingManager: LiveTrackingManager,
    private val networkUtils: NetworkUtils
) {
    
    private val _documentState = MutableStateFlow<DocumentState>(DocumentState.Idle)
    val documentState: StateFlow<DocumentState> = _documentState.asStateFlow()
    
    private val _vehicleDocuments = MutableStateFlow<List<VehicleDocumentEntity>>(emptyList())
    val vehicleDocuments: StateFlow<List<VehicleDocumentEntity>> = _vehicleDocuments.asStateFlow()
    
    private val _documentAnalytics = MutableStateFlow<DocumentAnalytics?>(null)
    val documentAnalytics: StateFlow<DocumentAnalytics?> = _documentAnalytics.asStateFlow()
    
    private val _documentAlerts = MutableStateFlow<List<DocumentAlert>>(emptyList())
    val documentAlerts: StateFlow<List<DocumentAlert>> = _documentAlerts.asStateFlow()
    
    private val _complianceStatus = MutableStateFlow<Map<Long, ComplianceStatus>>(emptyMap())
    val complianceStatus: StateFlow<Map<Long, ComplianceStatus>> = _complianceStatus.asStateFlow()
    
    private var isMonitoring = false
    private val documentListeners = mutableListOf<DocumentManagementListener>()
    
    companion object {
        private const val TAG = "VehicleDocumentManager"
        private const val MONITORING_INTERVAL = 86400000L // 24 hours
        private const val EXPIRY_WARNING_DAYS = 30
        private const val CRITICAL_EXPIRY_DAYS = 7
        private const val MAX_DOCUMENT_SIZE = 10 * 1024 * 1024 // 10MB
        private const val SUPPORTED_DOCUMENT_TYPES = "pdf,doc,docx,xls,xlsx,jpg,jpeg,png"
    }
    
    /**
     * Initialize document management system
     */
    suspend fun initialize(): Result<Boolean> {
        return withContext(Dispatchers.IO) {
            try {
                _documentState.value = DocumentState.Initializing
                
                // Load all vehicle documents
                loadVehicleDocuments()
                
                // Start monitoring
                startDocumentMonitoring()
                
                // Check for alerts
                checkDocumentAlerts()
                
                // Update compliance status
                updateComplianceStatus()
                
                _documentState.value = DocumentState.Ready
                Result.success(true)
                
            } catch (e: Exception) {
                _documentState.value = DocumentState.Error("Failed to initialize document management: ${e.message}")
                Result.failure(e)
            }
        }
    }
    
    /**
     * Upload vehicle document
     */
    suspend fun uploadDocument(request: UploadDocumentRequest): Result<VehicleDocumentEntity> {
        return withContext(Dispatchers.IO) {
            try {
                _documentState.value = DocumentState.UploadingDocument
                
                // Validate request
                validateDocumentRequest(request)
                
                // Generate document ID
                val documentId = generateDocumentId()
                
                // Create document entity
                val document = VehicleDocumentEntity(
                    id = 0,
                    documentId = documentId,
                    vehicleId = request.vehicleId,
                    documentType = request.documentType,
                    documentCategory = request.documentCategory,
                    title = request.title,
                    description = request.description,
                    fileName = request.fileName,
                    fileSize = request.fileSize,
                    mimeType = request.mimeType,
                    filePath = request.filePath,
                    uploadDate = Date(),
                    expiryDate = request.expiryDate,
                    status = DocumentStatus.ACTIVE,
                    version = 1,
                    uploadedBy = request.uploadedBy,
                    approvedBy = null,
                    approvedDate = null,
                    tags = request.tags,
                    metadata = request.metadata,
                    digitalSignature = null,
                    accessLevel = request.accessLevel,
                    isPublic = request.isPublic,
                    downloadCount = 0,
                    lastAccessed = null,
                    createdAt = Date(),
                    updatedAt = Date()
                )
                
                // Save document
                val documentIdLong = database.vehicleDocumentDao().insertDocument(document)
                val savedDocument = document.copy(id = documentIdLong)
                
                // Update documents list
                updateVehicleDocuments()
                
                // Update compliance status
                updateComplianceStatus()
                
                // Notify listeners
                notifyDocumentUploaded(savedDocument)
                
                _documentState.value = DocumentState.DocumentUploaded
                Result.success(savedDocument)
                
            } catch (e: Exception) {
                _documentState.value = DocumentState.Error("Failed to upload document: ${e.message}")
                Result.failure(e)
            }
        }
    }
    
    /**
     * Update document
     */
    suspend fun updateDocument(documentId: Long, request: UpdateDocumentRequest): Result<VehicleDocumentEntity> {
        return withContext(Dispatchers.IO) {
            try {
                val existingDocument = database.vehicleDocumentDao().getDocumentById(documentId)
                    ?: throw Exception("Document not found")
                
                // Create new version if file is updated
                val newVersion = if (request.filePath != null && request.filePath != existingDocument.filePath) {
                    existingDocument.version + 1
                } else existingDocument.version
                
                // Update document
                val updatedDocument = existingDocument.copy(
                    title = request.title ?: existingDocument.title,
                    description = request.description ?: existingDocument.description,
                    expiryDate = request.expiryDate ?: existingDocument.expiryDate,
                    status = request.status ?: existingDocument.status,
                    tags = request.tags ?: existingDocument.tags,
                    metadata = request.metadata ?: existingDocument.metadata,
                    accessLevel = request.accessLevel ?: existingDocument.accessLevel,
                    isPublic = request.isPublic ?: existingDocument.isPublic,
                    version = newVersion,
                    updatedAt = Date()
                )
                
                database.vehicleDocumentDao().updateDocument(updatedDocument)
                
                // Update documents list
                updateVehicleDocuments()
                
                // Update compliance status
                updateComplianceStatus()
                
                // Notify listeners
                notifyDocumentUpdated(updatedDocument)
                
                Result.success(updatedDocument)
                
            } catch (e: Exception) {
                Result.failure(e)
            }
        }
    }
    
    /**
     * Delete document
     */
    suspend fun deleteDocument(documentId: Long, deletedBy: String): Result<Boolean> {
        return withContext(Dispatchers.IO) {
            try {
                val existingDocument = database.vehicleDocumentDao().getDocumentById(documentId)
                    ?: throw Exception("Document not found")
                
                // Soft delete by updating status
                val deletedDocument = existingDocument.copy(
                    status = DocumentStatus.DELETED,
                    updatedAt = Date()
                )
                
                database.vehicleDocumentDao().updateDocument(deletedDocument)
                
                // Update documents list
                updateVehicleDocuments()
                
                // Update compliance status
                updateComplianceStatus()
                
                // Notify listeners
                notifyDocumentDeleted(deletedDocument)
                
                Result.success(true)
                
            } catch (e: Exception) {
                Result.failure(e)
            }
        }
    }
    
    /**
     * Approve document
     */
    suspend fun approveDocument(documentId: Long, approvedBy: String): Result<VehicleDocumentEntity> {
        return withContext(Dispatchers.IO) {
            try {
                val existingDocument = database.vehicleDocumentDao().getDocumentById(documentId)
                    ?: throw Exception("Document not found")
                
                // Approve document
                val approvedDocument = existingDocument.copy(
                    status = DocumentStatus.APPROVED,
                    approvedBy = approvedBy,
                    approvedDate = Date(),
                    updatedAt = Date()
                )
                
                database.vehicleDocumentDao().updateDocument(approvedDocument)
                
                // Update documents list
                updateVehicleDocuments()
                
                // Notify listeners
                notifyDocumentApproved(approvedDocument)
                
                Result.success(approvedDocument)
                
            } catch (e: Exception) {
                Result.failure(e)
            }
        }
    }
    
    /**
     * Get documents for vehicle
     */
    suspend fun getVehicleDocuments(vehicleId: Long, category: DocumentCategory? = null): List<VehicleDocumentEntity> {
        return withContext(Dispatchers.IO) {
            if (category != null) {
                database.vehicleDocumentDao().getDocumentsByVehicleAndCategory(vehicleId, category)
            } else {
                database.vehicleDocumentDao().getDocumentsByVehicle(vehicleId)
            }
        }
    }
    
    /**
     * Get documents by type
     */
    suspend fun getDocumentsByType(documentType: DocumentType): List<VehicleDocumentEntity> {
        return withContext(Dispatchers.IO) {
            database.vehicleDocumentDao().getDocumentsByType(documentType)
        }
    }
    
    /**
     * Search documents
     */
    suspend fun searchDocuments(query: String, filters: DocumentFilters = DocumentFilters()): List<VehicleDocumentEntity> {
        return withContext(Dispatchers.IO) {
            var documents = database.vehicleDocumentDao().getAllDocuments()
            
            // Apply search query
            if (query.isNotBlank()) {
                documents = documents.filter { document ->
                    document.title.contains(query, ignoreCase = true) ||
                    document.description.contains(query, ignoreCase = true) ||
                    document.tags.any { it.contains(query, ignoreCase = true) }
                }
            }
            
            // Apply filters
            if (filters.vehicleId != null) {
                documents = documents.filter { it.vehicleId == filters.vehicleId }
            }
            
            if (filters.documentType != null) {
                documents = documents.filter { it.documentType == filters.documentType }
            }
            
            if (filters.documentCategory != null) {
                documents = documents.filter { it.documentCategory == filters.documentCategory }
            }
            
            if (filters.status != null) {
                documents = documents.filter { it.status == filters.status }
            }
            
            if (filters.expiryStatus != null) {
                documents = documents.filter { document ->
                    when (filters.expiryStatus) {
                        ExpiryStatus.EXPIRED -> document.expiryDate?.before(Date()) == true
                        ExpiryStatus.EXPIRING_SOON -> {
                            val daysUntilExpiry = document.expiryDate?.let {
                                ((it.time - System.currentTimeMillis()) / (24 * 60 * 60 * 1000)).toInt()
                            } ?: Int.MAX_VALUE
                            daysUntilExpiry in 1..EXPIRY_WARNING_DAYS
                        }
                        ExpiryStatus.VALID -> {
                            document.expiryDate?.after(Date()) == true
                        }
                        ExpiryStatus.NO_EXPIRY -> document.expiryDate == null
                    }
                }
            }
            
            documents
        }
    }
    
    /**
     * Get document analytics
     */
    suspend fun getDocumentAnalytics(dateRange: DateRange = DateRange.last90Days()): DocumentAnalytics {
        return withContext(Dispatchers.IO) {
            try {
                val allDocuments = database.vehicleDocumentDao().getAllDocuments()
                
                val totalDocuments = allDocuments.size
                val activeDocuments = allDocuments.count { it.status == DocumentStatus.ACTIVE }
                val expiredDocuments = allDocuments.count { it.status == DocumentStatus.EXPIRED }
                val pendingDocuments = allDocuments.count { it.status == DocumentStatus.PENDING }
                val approvedDocuments = allDocuments.count { it.status == DocumentStatus.APPROVED }
                
                val documentsByType = allDocuments.groupBy { it.documentType }.mapValues { it.value.size }
                val documentsByCategory = allDocuments.groupBy { it.documentCategory }.mapValues { it.value.size }
                val documentsByVehicle = allDocuments.groupBy { it.vehicleId }.mapValues { it.value.size }
                
                val documentsExpiringSoon = allDocuments.count { document ->
                    document.expiryDate?.let { expiry ->
                        val daysUntilExpiry = ((expiry.time - System.currentTimeMillis()) / (24 * 60 * 60 * 1000)).toInt()
                        daysUntilExpiry in 1..EXPIRY_WARNING_DAYS
                    } == false
                }
                
                val expiredDocumentsCount = allDocuments.count { document ->
                    document.expiryDate?.before(Date()) == true
                }
                
                val totalStorageUsed = allDocuments.sumOf { it.fileSize.toLong() }
                val averageFileSize = if (allDocuments.isNotEmpty()) {
                    totalStorageUsed / allDocuments.size
                } else 0L
                
                val uploadTrends = calculateUploadTrends(allDocuments, dateRange)
                val complianceAnalysis = calculateComplianceAnalysis(allDocuments)
                val accessPatterns = calculateAccessPatterns(allDocuments)
                
                DocumentAnalytics(
                    totalDocuments = totalDocuments,
                    activeDocuments = activeDocuments,
                    expiredDocuments = expiredDocuments,
                    pendingDocuments = pendingDocuments,
                    approvedDocuments = approvedDocuments,
                    documentsByType = documentsByType,
                    documentsByCategory = documentsByCategory,
                    documentsByVehicle = documentsByVehicle,
                    documentsExpiringSoon = documentsExpiringSoon,
                    expiredDocumentsCount = expiredDocumentsCount,
                    totalStorageUsed = totalStorageUsed,
                    averageFileSize = averageFileSize,
                    uploadTrends = uploadTrends,
                    complianceAnalysis = complianceAnalysis,
                    accessPatterns = accessPatterns,
                    dateRange = dateRange
                )
                
            } catch (e: Exception) {
                DocumentAnalytics()
            }
        }
    }
    
    /**
     * Get compliance status for vehicle
     */
    suspend fun getVehicleComplianceStatus(vehicleId: Long): VehicleComplianceStatus {
        return withContext(Dispatchers.IO) {
            try {
                val documents = database.vehicleDocumentDao().getDocumentsByVehicle(vehicleId)
                val requiredDocuments = getRequiredDocuments()
                
                val missingDocuments = mutableListOf<DocumentType>()
                val expiredDocuments = mutableListOf<DocumentType>()
                val expiringSoonDocuments = mutableListOf<DocumentType>()
                
                requiredDocuments.forEach { requiredType ->
                    val document = documents.find { it.documentType == requiredType && it.status == DocumentStatus.ACTIVE }
                    
                    when {
                        document == null -> missingDocuments.add(requiredType)
                        document.expiryDate?.before(Date()) == true -> expiredDocuments.add(requiredType)
                        document.expiryDate?.let { expiry ->
                            val daysUntilExpiry = ((expiry.time - System.currentTimeMillis()) / (24 * 60 * 60 * 1000)).toInt()
                            daysUntilExpiry in 1..EXPIRY_WARNING_DAYS
                        } == true -> expiringSoonDocuments.add(requiredType)
                    }
                }
                
                val complianceLevel = when {
                    missingDocuments.isNotEmpty() -> ComplianceLevel.NON_COMPLIANT
                    expiredDocuments.isNotEmpty() -> ComplianceLevel.NON_COMPLIANT
                    expiringSoonDocuments.isNotEmpty() -> ComplianceLevel.WARNING
                    else -> ComplianceLevel.COMPLIANT
                }
                
                val complianceScore = calculateComplianceScore(missingDocuments, expiredDocuments, expiringSoonDocuments)
                
                VehicleComplianceStatus(
                    vehicleId = vehicleId,
                    complianceLevel = complianceLevel,
                    complianceScore = complianceScore,
                    missingDocuments = missingDocuments,
                    expiredDocuments = expiredDocuments,
                    expiringSoonDocuments = expiringSoonDocuments,
                    lastChecked = Date()
                )
                
            } catch (e: Exception) {
                VehicleComplianceStatus(
                    vehicleId = vehicleId,
                    complianceLevel = ComplianceLevel.UNKNOWN,
                    complianceScore = 0f,
                    missingDocuments = emptyList(),
                    expiredDocuments = emptyList(),
                    expiringSoonDocuments = emptyList(),
                    lastChecked = Date()
                )
            }
        }
    }
    
    /**
     * Add document management listener
     */
    fun addDocumentManagementListener(listener: DocumentManagementListener) {
        documentListeners.add(listener)
    }
    
    /**
     * Remove document management listener
     */
    fun removeDocumentManagementListener(listener: DocumentManagementListener) {
        documentListeners.remove(listener)
    }
    
    /**
     * Helper functions
     */
    private suspend fun loadVehicleDocuments() {
        val documents = database.vehicleDocumentDao().getAllDocuments()
        _vehicleDocuments.value = documents
    }
    
    private fun startDocumentMonitoring() {
        isMonitoring = true
        // Implementation would start periodic document monitoring
    }
    
    private suspend fun checkDocumentAlerts() {
        val documents = _vehicleDocuments.value
        val alerts = mutableListOf<DocumentAlert>()
        
        documents.forEach { document ->
            val documentAlerts = checkDocumentAlerts(document)
            alerts.addAll(documentAlerts)
        }
        
        _documentAlerts.value = alerts
    }
    
    private suspend fun checkDocumentAlerts(document: VehicleDocumentEntity): List<DocumentAlert> {
        val alerts = mutableListOf<DocumentAlert>()
        
        // Expiry alerts
        document.expiryDate?.let { expiry ->
            val daysUntilExpiry = ((expiry.time - System.currentTimeMillis()) / (24 * 60 * 60 * 1000)).toInt()
            
            when {
                daysUntilExpiry < 0 -> {
                    alerts.add(DocumentAlert(
                        id = 0,
                        documentId = document.id,
                        type = DocumentAlertType.DOCUMENT_EXPIRED,
                        message = "Document '${document.title}' has expired",
                        severity = AlertSeverity.CRITICAL,
                        timestamp = Date(),
                        resolved = false
                    ))
                }
                daysUntilExpiry <= CRITICAL_EXPIRY_DAYS -> {
                    alerts.add(DocumentAlert(
                        id = 0,
                        documentId = document.id,
                        type = DocumentAlertType.DOCUMENT_EXPIRING,
                        message = "Document '${document.title}' expires in $daysUntilExpiry days",
                        severity = AlertSeverity.CRITICAL,
                        timestamp = Date(),
                        resolved = false
                    ))
                }
                daysUntilExpiry <= EXPIRY_WARNING_DAYS -> {
                    alerts.add(DocumentAlert(
                        id = 0,
                        documentId = document.id,
                        type = DocumentAlertType.DOCUMENT_EXPIRING,
                        message = "Document '${document.title}' expires in $daysUntilExpiry days",
                        severity = AlertSeverity.HIGH,
                        timestamp = Date(),
                        resolved = false
                    ))
                }
            }
        }
        
        return alerts
    }
    
    private suspend fun updateComplianceStatus() {
        val allVehicles = database.vehicleDao().getAllVehicles()
        val complianceMap = mutableMapOf<Long, ComplianceStatus>()
        
        allVehicles.forEach { vehicle ->
            val complianceStatus = getVehicleComplianceStatus(vehicle.id)
            complianceMap[vehicle.id] = when (complianceStatus.complianceLevel) {
                ComplianceLevel.COMPLIANT -> ComplianceStatus.COMPLIANT
                ComplianceLevel.WARNING -> ComplianceStatus.WARNING
                ComplianceLevel.NON_COMPLIANT -> ComplianceStatus.NON_COMPLIANT
                else -> ComplianceStatus.UNKNOWN
            }
        }
        
        _complianceStatus.value = complianceMap
    }
    
    private fun validateDocumentRequest(request: UploadDocumentRequest) {
        if (request.vehicleId <= 0) throw Exception("Valid vehicle ID is required")
        if (request.title.isBlank()) throw Exception("Document title is required")
        if (request.fileName.isBlank()) throw Exception("File name is required")
        if (request.fileSize > MAX_DOCUMENT_SIZE) throw Exception("File size exceeds maximum limit")
        if (!SUPPORTED_DOCUMENT_TYPES.contains(request.mimeType.split("/").lastOrNull())) {
            throw Exception("Unsupported file type")
        }
    }
    
    private fun generateDocumentId(): String {
        val timestamp = System.currentTimeMillis()
        val random = (1000..9999).random()
        return "DOC-$timestamp-$random"
    }
    
    private fun getRequiredDocuments(): List<DocumentType> {
        return listOf(
            DocumentType.REGISTRATION,
            DocumentType.INSURANCE,
            DocumentType.INSPECTION,
            DocumentType.POLLUTION_CERTIFICATE,
            DocumentType.ROAD_WORTHINESS
        )
    }
    
    private fun calculateComplianceScore(
        missing: List<DocumentType>,
        expired: List<DocumentType>,
        expiringSoon: List<DocumentType>
    ): Float {
        val requiredCount = getRequiredDocuments().size
        val compliantCount = requiredCount - missing.size - expired.size
        return (compliantCount.toFloat() / requiredCount) * 100f
    }
    
    private suspend fun updateVehicleDocuments() {
        loadVehicleDocuments()
    }
    
    private fun calculateUploadTrends(documents: List<VehicleDocumentEntity>, dateRange: DateRange): UploadTrends {
        val documentsInRange = documents.filter { 
            it.uploadDate.after(dateRange.startDate) && it.uploadDate.before(dateRange.endDate)
        }
        
        val uploadsByDay = documentsInRange.groupBy {
            val calendar = Calendar.getInstance()
            calendar.time = it.uploadDate
            "${calendar.get(Calendar.YEAR)}-${String.format("%02d", calendar.get(Calendar.MONTH) + 1)}-${String.format("%02d", calendar.get(Calendar.DAY_OF_MONTH))}"
        }.mapValues { it.value.size }
        
        return UploadTrends(
            totalUploads = documentsInRange.size,
            uploadsByDay = uploadsByDay,
            averageUploadsPerDay = documentsInRange.size.toFloat() / dateRange.days
        )
    }
    
    private fun calculateComplianceAnalysis(documents: List<VehicleDocumentEntity>): ComplianceAnalysis {
        val allVehicles = database.vehicleDao().getAllVehicles()
        val compliantVehicles = mutableListOf<Long>()
        val nonCompliantVehicles = mutableListOf<Long>()
        
        allVehicles.forEach { vehicle ->
            val vehicleDocuments = documents.filter { it.vehicleId == vehicle.id && it.status == DocumentStatus.ACTIVE }
            val requiredDocuments = getRequiredDocuments()
            val hasAllRequired = requiredDocuments.all { requiredType ->
                vehicleDocuments.any { it.documentType == requiredType }
            }
            
            if (hasAllRequired) {
                compliantVehicles.add(vehicle.id)
            } else {
                nonCompliantVehicles.add(vehicle.id)
            }
        }
        
        val complianceRate = if (allVehicles.isNotEmpty()) {
            (compliantVehicles.size.toFloat() / allVehicles.size) * 100f
        } else 100f
        
        return ComplianceAnalysis(
            totalVehicles = allVehicles.size,
            compliantVehicles = compliantVehicles.size,
            nonCompliantVehicles = nonCompliantVehicles.size,
            complianceRate = complianceRate
        )
    }
    
    private fun calculateAccessPatterns(documents: List<VehicleDocumentEntity>): AccessPatterns {
        val totalAccesses = documents.sumOf { it.downloadCount.toLong() }
        val averageAccesses = if (documents.isNotEmpty()) {
            totalAccesses / documents.size
        } else 0L
        
        val mostAccessedDocuments = documents.sortedByDescending { it.downloadCount }.take(5)
        
        return AccessPatterns(
            totalAccesses = totalAccesses,
            averageAccesses = averageAccesses,
            mostAccessedDocuments = mostAccessedDocuments
        )
    }
    
    private fun notifyDocumentUploaded(document: VehicleDocumentEntity) {
        documentListeners.forEach { listener ->
            listener.onDocumentUploaded(document)
        }
    }
    
    private fun notifyDocumentUpdated(document: VehicleDocumentEntity) {
        documentListeners.forEach { listener ->
            listener.onDocumentUpdated(document)
        }
    }
    
    private fun notifyDocumentDeleted(document: VehicleDocumentEntity) {
        documentListeners.forEach { listener ->
            listener.onDocumentDeleted(document)
        }
    }
    
    private fun notifyDocumentApproved(document: VehicleDocumentEntity) {
        documentListeners.forEach { listener ->
            listener.onDocumentApproved(document)
        }
    }
    
    /**
     * Get monitoring status
     */
    fun isMonitoring(): Boolean = isMonitoring
}

/**
 * Data classes
 */
data class UploadDocumentRequest(
    val vehicleId: Long,
    val documentType: DocumentType,
    val documentCategory: DocumentCategory,
    val title: String,
    val description: String,
    val fileName: String,
    val fileSize: Long,
    val mimeType: String,
    val filePath: String,
    val expiryDate: Date?,
    val uploadedBy: String,
    val tags: List<String>,
    val metadata: Map<String, String>,
    val accessLevel: AccessLevel,
    val isPublic: Boolean
)

data class UpdateDocumentRequest(
    val title: String? = null,
    val description: String? = null,
    val expiryDate: Date? = null,
    val status: DocumentStatus? = null,
    val tags: List<String>? = null,
    val metadata: Map<String, String>? = null,
    val accessLevel: AccessLevel? = null,
    val isPublic: Boolean? = null
)

data class DocumentFilters(
    val vehicleId: Long? = null,
    val documentType: DocumentType? = null,
    val documentCategory: DocumentCategory? = null,
    val status: DocumentStatus? = null,
    val expiryStatus: ExpiryStatus? = null
)

data class DocumentAnalytics(
    val totalDocuments: Int = 0,
    val activeDocuments: Int = 0,
    val expiredDocuments: Int = 0,
    val pendingDocuments: Int = 0,
    val approvedDocuments: Int = 0,
    val documentsByType: Map<DocumentType, Int> = emptyMap(),
    val documentsByCategory: Map<DocumentCategory, Int> = emptyMap(),
    val documentsByVehicle: Map<Long, Int> = emptyMap(),
    val documentsExpiringSoon: Int = 0,
    val expiredDocumentsCount: Int = 0,
    val totalStorageUsed: Long = 0L,
    val averageFileSize: Long = 0L,
    val uploadTrends: UploadTrends = UploadTrends(),
    val complianceAnalysis: ComplianceAnalysis = ComplianceAnalysis(),
    val accessPatterns: AccessPatterns = AccessPatterns(),
    val dateRange: DateRange = DateRange()
)

data class VehicleComplianceStatus(
    val vehicleId: Long,
    val complianceLevel: ComplianceLevel,
    val complianceScore: Float,
    val missingDocuments: List<DocumentType>,
    val expiredDocuments: List<DocumentType>,
    val expiringSoonDocuments: List<DocumentType>,
    val lastChecked: Date
)

data class UploadTrends(
    val totalUploads: Int = 0,
    val uploadsByDay: Map<String, Int> = emptyMap(),
    val averageUploadsPerDay: Float = 0f
)

data class ComplianceAnalysis(
    val totalVehicles: Int = 0,
    val compliantVehicles: Int = 0,
    val nonCompliantVehicles: Int = 0,
    val complianceRate: Float = 0f
)

data class AccessPatterns(
    val totalAccesses: Long = 0L,
    val averageAccesses: Long = 0L,
    val mostAccessedDocuments: List<VehicleDocumentEntity> = emptyList()
)

data class DocumentAlert(
    val id: Long,
    val documentId: Long,
    val type: DocumentAlertType,
    val message: String,
    val severity: AlertSeverity,
    val timestamp: Date,
    val resolved: Boolean
)

/**
 * Interfaces
 */
interface DocumentManagementListener {
    fun onDocumentUploaded(document: VehicleDocumentEntity)
    fun onDocumentUpdated(document: VehicleDocumentEntity)
    fun onDocumentDeleted(document: VehicleDocumentEntity)
    fun onDocumentApproved(document: VehicleDocumentEntity)
    fun onDocumentExpired(documentId: Long)
    fun onDocumentAlert(alert: DocumentAlert)
}

/**
 * Enums
 */
enum class DocumentState {
    Idle,
    Initializing,
    Ready,
    UploadingDocument,
    DocumentUploaded,
    UpdatingDocument,
    DocumentUpdated,
    DeletingDocument,
    DocumentDeleted,
    ApprovingDocument,
    DocumentApproved,
    Error
}

enum class DocumentType {
    REGISTRATION,
    INSURANCE,
    INSPECTION,
    POLLUTION_CERTIFICATE,
    ROAD_WORTHINESS,
    PERMIT,
    LICENSE,
    MAINTENANCE_RECORD,
    ACCIDENT_REPORT,
    PHOTOGRAPH,
    OTHER
}

enum class DocumentCategory {
    LEGAL,
    TECHNICAL,
    FINANCIAL,
    OPERATIONAL,
    SAFETY,
    MAINTENANCE,
    COMPLIANCE,
    COMMUNICATION
}

enum class DocumentStatus {
    ACTIVE,
    EXPIRED,
    PENDING,
    APPROVED,
    REJECTED,
    DELETED,
    ARCHIVED
}

enum class AccessLevel {
    PUBLIC,
    INTERNAL,
    CONFIDENTIAL,
    RESTRICTED
}

enum class ExpiryStatus {
    VALID,
    EXPIRING_SOON,
    EXPIRED,
    NO_EXPIRY
}

enum class ComplianceLevel {
