package com.edham.logistics.feature.customer.domain.usecase

import com.edham.logistics.core.utils.Result
import com.edham.logistics.feature.customer.domain.model.ShipmentSummary
import com.edham.logistics.feature.customer.domain.repository.CustomerRepository
import javax.inject.Inject

class GetCustomerShipmentsUseCase @Inject constructor(
    private val customerRepository: CustomerRepository
) {
    
    suspend operator fun invoke(customerId: String, page: Int = 1, pageSize: Int = 20): Result<List<ShipmentSummary>> {
        return customerRepository.getCustomerShipments(customerId, page, pageSize)
    }
}
