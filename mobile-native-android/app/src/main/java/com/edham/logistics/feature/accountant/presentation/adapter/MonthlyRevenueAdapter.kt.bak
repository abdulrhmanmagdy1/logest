package com.edham.logistics.feature.accountant.presentation.adapter

import android.view.LayoutInflater
import android.view.ViewGroup
import androidx.recyclerview.widget.DiffUtil
import androidx.recyclerview.widget.ListAdapter
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.databinding.ItemMonthlyRevenueBinding
import com.edham.logistics.feature.accountant.domain.model.MonthlyRevenue
import javax.inject.Inject

class MonthlyRevenueAdapter @Inject constructor() : ListAdapter<MonthlyRevenue, MonthlyRevenueAdapter.MonthlyRevenueViewHolder>(MonthlyRevenueDiffCallback()) {

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): MonthlyRevenueViewHolder {
        val binding = ItemMonthlyRevenueBinding.inflate(
            LayoutInflater.from(parent.context),
            parent,
            false
        )
        return MonthlyRevenueViewHolder(binding)
    }

    override fun onBindViewHolder(holder: MonthlyRevenueViewHolder, position: Int) {
        holder.bind(getItem(position))
    }

    inner class MonthlyRevenueViewHolder(
        private val binding: ItemMonthlyRevenueBinding
    ) : RecyclerView.ViewHolder(binding.root) {

        fun bind(monthlyRevenue: MonthlyRevenue) {
            binding.apply {
                textMonth.text = formatMonth(monthlyRevenue.month)
                textYear.text = monthlyRevenue.year.toString()
                textRevenue.text = formatCurrency(monthlyRevenue.revenue)
                textInvoices.text = "${monthlyRevenue.invoices} فاتورة"
                textPayments.text = "${monthlyRevenue.payments} دفعة"
                
                // Set revenue growth indicator (mock data for demo)
                val growth = calculateGrowth(monthlyRevenue.revenue)
                textGrowth.text = String.format("%.1f%%", growth)
                textGrowth.setTextColor(
                    when {
                        growth > 0 -> android.graphics.Color.parseColor("#4CAF50")
                        growth < 0 -> android.graphics.Color.parseColor("#F44336")
                        else -> android.graphics.Color.parseColor("#9E9E9E")
                    }
                )
                
                // Set progress bar based on revenue (mock max revenue for demo)
                val maxRevenue = 60000.0
                val progress = (monthlyRevenue.revenue / maxRevenue) * 100
                progressBar.progress = progress.toInt()
            }
        }
        
        private fun formatMonth(month: String): String {
            return when (month) {
                "01" -> "يناير"
                "02" -> "فبراير"
                "03" -> "مارس"
                "04" -> "أبريل"
                "05" -> "مايو"
                "06" -> "يونيو"
                "07" -> "يوليو"
                "08" -> "أغسطس"
                "09" -> "سبتمبر"
                "10" -> "أكتوبر"
                "11" -> "نوفمبر"
                "12" -> "ديسمبر"
                else -> month
            }
        }
        
        private fun formatCurrency(amount: Double): String {
            return String.format("%.0f ريال", amount)
        }
        
        private fun calculateGrowth(currentRevenue: Double): Double {
            // Mock growth calculation - in real app, this would compare with previous month
            return when (currentRevenue) {
                in 0..20000 -> 5.0
                in 20001..40000 -> 12.5
                in 40001..60000 -> -3.2
                else -> 8.7
            }
        }
    }

    private class MonthlyRevenueDiffCallback : DiffUtil.ItemCallback<MonthlyRevenue>() {
        override fun areItemsTheSame(oldItem: MonthlyRevenue, newItem: MonthlyRevenue): Boolean {
            return oldItem.month == newItem.month && oldItem.year == newItem.year
        }

        override fun areContentsTheSame(oldItem: MonthlyRevenue, newItem: MonthlyRevenue): Boolean {
            return oldItem == newItem
        }
    }
}
