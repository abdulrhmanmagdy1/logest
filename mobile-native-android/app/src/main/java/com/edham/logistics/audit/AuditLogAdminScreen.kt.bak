package com.edham.logistics.audit

import android.content.Context
import androidx.compose.animation.*
import androidx.compose.animation.core.*
import androidx.compose.foundation.background
import androidx.compose.foundation.layout.*
import androidx.compose.foundation.lazy.LazyColumn
import androidx.compose.foundation.lazy.items
import androidx.compose.foundation.rememberScrollState
import androidx.compose.foundation.verticalScroll
import androidx.compose.foundation.shape.RoundedCornerShape
import androidx.compose.material.icons.Icons
import androidx.compose.material.icons.filled.*
import androidx.compose.material3.*
import androidx.compose.runtime.*
import androidx.compose.ui.Alignment
import androidx.compose.ui.Modifier
import androidx.compose.ui.draw.clip
import androidx.compose.ui.graphics.Color
import androidx.compose.ui.graphics.vector.ImageVector
import androidx.compose.ui.platform.LocalContext
import androidx.compose.ui.text.font.FontWeight
import androidx.compose.ui.text.style.TextAlign
import androidx.compose.ui.unit.dp
import androidx.compose.ui.unit.sp
import kotlinx.coroutines.launch
import java.text.SimpleDateFormat
import java.util.*

/**
 * Audit Log Admin Screen - Comprehensive audit log viewing for administrators
 */
@OptIn(ExperimentalMaterial3Api::class)
@Composable
fun AuditLogAdminScreen(
    modifier: Modifier = Modifier,
    onBack: () -> Unit = {}
) {
    val context = LocalContext.current
    val auditSystem = remember { AuditLogSystem.getInstance(context) }
    val scope = rememberCoroutineScope()
    
    // State management
    var selectedTab by remember { mutableStateOf(AuditTab.OVERVIEW) }
    var isLoading by remember { mutableStateOf(false) }
    var auditLogs by remember { mutableStateOf<List<Map<String, Any>>>(emptyList()) }
    var statistics by remember { mutableStateOf<Map<String, Any>>(emptyMap()) }
    var searchQuery by remember { mutableStateOf("") }
    var selectedEntityType by remember { mutableStateOf("ALL") }
    var selectedOperation by remember { mutableStateOf("ALL") }
    var selectedDateRange by remember { mutableStateOf(DateRange.TODAY) }
    var exportFormat by remember { mutableStateOf(ExportFormat.JSON) }
    var showExportDialog by remember { mutableStateOf(false) }
    var showFilterDialog by remember { mutableStateOf(false) }
    
    // Load data
    LaunchedEffect(selectedTab, selectedEntityType, selectedOperation, selectedDateRange) {
        isLoading = true
        try {
            when (selectedTab) {
                AuditTab.OVERVIEW -> {
                    statistics = auditSystem.getAuditStatistics()
                }
                AuditTab.SHIPMENTS -> {
                    auditLogs = auditSystem.getAuditLogs(
                        entityType = if (selectedEntityType == "ALL") null else selectedEntityType,
                        operation = if (selectedOperation == "ALL") null else AuditOperation.valueOf(selectedOperation),
                        startDate = selectedDateRange.startDate,
                        endDate = selectedDateRange.endDate,
                        limit = 100
                    ).map { it.toMap() }
                }
                AuditTab.USERS -> {
                    auditLogs = auditSystem.getAuditLogs(
                        entityType = "USER",
                        startDate = selectedDateRange.startDate,
                        endDate = selectedDateRange.endDate,
                        limit = 100
                    ).map { it.toMap() }
                }
                AuditTab.PAYMENTS -> {
                    auditLogs = auditSystem.getAuditLogs(
                        entityType = "PAYMENT",
                        startDate = selectedDateRange.startDate,
                        endDate = selectedDateRange.endDate,
                        limit = 100
                    ).map { it.toMap() }
                }
                AuditTab.STATUS_CHANGES -> {
                    auditLogs = auditSystem.getAuditLogs(
                        operation = AuditOperation.STATUS_CHANGE,
                        startDate = selectedDateRange.startDate,
                        endDate = selectedDateRange.endDate,
                        limit = 100
                    ).map { it.toMap() }
                }
                AuditTab.SEARCH -> {
                    if (searchQuery.isNotEmpty()) {
                        auditLogs = auditSystem.searchAuditLogs(searchQuery, 100).map { it.toMap() }
                    }
                }
            }
        } catch (e: Exception) {
            // Handle error
        } finally {
            isLoading = false
        }
    }
    
    Column(
        modifier = modifier
            .fillMaxSize()
            .background(Color(0xFFF5F5F5))
    ) {
        // Header
        AuditLogHeader(
            selectedTab = selectedTab,
            onTabSelected = { selectedTab = it },
            onBack = onBack,
            onExport = { showExportDialog = true },
            onFilter = { showFilterDialog = true }
        )
        
        // Content
        when (selectedTab) {
            AuditTab.OVERVIEW -> {
                AuditLogOverview(
                    statistics = statistics,
                    onTabSelected = { selectedTab = it }
                )
            }
            AuditTab.SEARCH -> {
                AuditLogSearch(
                    searchQuery = searchQuery,
                    onSearchQueryChanged = { searchQuery = it },
                    auditLogs = auditLogs,
                    isLoading = isLoading
                )
            }
            else -> {
                AuditLogList(
                    auditLogs = auditLogs,
                    isLoading = isLoading,
                    selectedTab = selectedTab
                )
            }
        }
    }
    
    // Export Dialog
    if (showExportDialog) {
        AuditLogExportDialog(
            exportFormat = exportFormat,
            onExportFormatChanged = { exportFormat = it },
            onExport = {
                scope.launch {
                    try {
                        val exportedData = auditSystem.exportAuditLogs(
                            startDate = selectedDateRange.startDate,
                            endDate = selectedDateRange.endDate,
                            format = exportFormat
                        )
                        // Handle export (save to file, share, etc.)
                        showExportDialog = false
                    } catch (e: Exception) {
                        // Handle error
                    }
                }
            },
            onDismiss = { showExportDialog = false }
        )
    }
    
    // Filter Dialog
    if (showFilterDialog) {
        AuditLogFilterDialog(
            selectedEntityType = selectedEntityType,
            onEntityTypeSelected = { selectedEntityType = it },
            selectedOperation = selectedOperation,
            onOperationSelected = { selectedOperation = it },
            selectedDateRange = selectedDateRange,
            onDateRangeSelected = { selectedDateRange = it },
            onDismiss = { showFilterDialog = false }
        )
    }
}

/**
 * Audit Log Header
 */
@Composable
private fun AuditLogHeader(
    selectedTab: AuditTab,
    onTabSelected: (AuditTab) -> Unit,
    onBack: () -> Unit,
    onExport: () -> Unit,
    onFilter: () -> Unit
) {
    Column {
        // Top bar
        Row(
            modifier = Modifier
                .fillMaxWidth()
                .background(Color.White)
                .padding(16.dp),
            horizontalArrangement = Arrangement.SpaceBetween,
            verticalAlignment = Alignment.CenterVertically
        ) {
            Row(
                verticalAlignment = Alignment.CenterVertically,
                horizontalArrangement = Arrangement.spacedBy(8.dp)
            ) {
                IconButton(onClick = onBack) {
                    Icon(
                        imageVector = Icons.Default.ArrowBack,
                        contentDescription = "Back",
                        tint = Color(0xFF2C3E50)
                    )
                }
                
                Text(
                    text = "سجل العمليات",
                    fontSize = 20.sp,
                    fontWeight = FontWeight.Bold,
                    color = Color(0xFF2C3E50)
                )
            }
            
            Row(
                horizontalArrangement = Arrangement.spacedBy(8.dp)
            ) {
                IconButton(onClick = onFilter) {
                    Icon(
                        imageVector = Icons.Default.FilterList,
                        contentDescription = "Filter",
                        tint = Color(0xFF3498DB)
                    )
                }
                
                IconButton(onClick = onExport) {
                    Icon(
                        imageVector = Icons.Default.Download,
                        contentDescription = "Export",
                        tint = Color(0xFF27AE60)
                    )
                }
            }
        }
        
        // Tabs
        ScrollableTabRow(
            selectedTabIndex = selectedTab.ordinal,
            modifier = Modifier.background(Color.White),
            containerColor = Color.White,
            contentColor = Color(0xFF2C3E50),
            indicatorColor = Color(0xFF3498DB)
        ) {
            AuditTab.values().forEach { tab ->
                Tab(
                    selected = selectedTab == tab,
                    onClick = { onTabSelected(tab) },
                    text = {
                        Text(
                            text = when (tab) {
                                AuditTab.OVERVIEW -> "نظرة عامة"
                                AuditTab.SHIPMENTS -> "الشحنات"
                                AuditTab.USERS -> "المستخدمون"
                                AuditTab.PAYMENTS -> "المدفوعات"
                                AuditTab.STATUS_CHANGES -> "تغييرات الحالة"
                                AuditTab.SEARCH -> "بحث"
                            },
                            fontSize = 14.sp,
                            fontWeight = if (selectedTab == tab) FontWeight.Bold else FontWeight.Normal
                        )
                    }
                )
            }
        }
    }
}

/**
 * Audit Log Overview
 */
@Composable
private fun AuditLogOverview(
    statistics: Map<String, Any>,
    onTabSelected: (AuditTab) -> Unit
) {
    LazyColumn(
        modifier = Modifier
            .fillMaxSize()
            .padding(16.dp),
        verticalArrangement = Arrangement.spacedBy(16.dp)
    ) {
        item {
            // Statistics Cards
            StatisticsCards(statistics = statistics)
        }
        
        item {
            // Quick Actions
            QuickActions(onTabSelected = onTabSelected)
        }
        
        item {
            // Recent Activity
            RecentActivityCard(statistics = statistics)
        }
        
        item {
            // Entity Type Distribution
            EntityTypeDistribution(statistics = statistics)
        }
    }
}

/**
 * Statistics Cards
 */
@Composable
private fun StatisticsCards(statistics: Map<String, Any>) {
    val totalLogs = (statistics["totalLogs"] as? Int) ?: 0
    val recentActivity = (statistics["recentActivityCount"] as? Int) ?: 0
    
    Row(
        modifier = Modifier.fillMaxWidth(),
        horizontalArrangement = Arrangement.spacedBy(16.dp)
    ) {
        StatCard(
            modifier = Modifier.weight(1f),
            title = "إجمالي السجلات",
            value = totalLogs.toString(),
            icon = Icons.Default.Assignment,
            color = Color(0xFF3498DB)
        )
        
        StatCard(
            modifier = Modifier.weight(1f),
            title = "النشاط الأخير (24ساعة)",
            value = recentActivity.toString(),
            icon = Icons.Default.TrendingUp,
            color = Color(0xFF27AE60)
        )
    }
}

/**
 * Stat Card
 */
@Composable
private fun StatCard(
    modifier: Modifier = Modifier,
    title: String,
    value: String,
    icon: ImageVector,
    color: Color
) {
    Card(
        modifier = modifier,
        colors = CardDefaults.cardColors(
            containerColor = Color.White
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 4.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp),
            horizontalAlignment = Alignment.CenterHorizontally
        ) {
            Icon(
                imageVector = icon,
                contentDescription = null,
                tint = color,
                modifier = Modifier.size(32.dp)
            )
            
            Spacer(modifier = Modifier.height(8.dp))
            
            Text(
                text = value,
                fontSize = 24.sp,
                fontWeight = FontWeight.Bold,
                color = color
            )
            
            Text(
                text = title,
                fontSize = 12.sp,
                color = Color.Gray,
                textAlign = TextAlign.Center
            )
        }
    }
}

/**
 * Quick Actions
 */
@Composable
private fun QuickActions(onTabSelected: (AuditTab) -> Unit) {
    Card(
        colors = CardDefaults.cardColors(
            containerColor = Color.White
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 4.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Text(
                text = "إجراءات سريعة",
                fontSize = 18.sp,
                fontWeight = FontWeight.Bold,
                color = Color(0xFF2C3E50)
            )
            
            Spacer(modifier = Modifier.height(16.dp))
            
            Row(
                modifier = Modifier.fillMaxWidth(),
                horizontalArrangement = Arrangement.spacedBy(8.dp)
            ) {
                QuickActionButton(
                    modifier = Modifier.weight(1f),
                    text = "الشحنات",
                    icon = Icons.Default.LocalShipping,
                    onClick = { onTabSelected(AuditTab.SHIPMENTS) }
                )
                
                QuickActionButton(
                    modifier = Modifier.weight(1f),
                    text = "المستخدمون",
                    icon = Icons.Default.People,
                    onClick = { onTabSelected(AuditTab.USERS) }
                )
                
                QuickActionButton(
                    modifier = Modifier.weight(1f),
                    text = "المدفوعات",
                    icon = Icons.Default.Payment,
                    onClick = { onTabSelected(AuditTab.PAYMENTS) }
                )
            }
        }
    }
}

/**
 * Quick Action Button
 */
@Composable
private fun QuickActionButton(
    modifier: Modifier = Modifier,
    text: String,
    icon: ImageVector,
    onClick: () -> Unit
) {
    OutlinedButton(
        onClick = onClick,
        modifier = modifier,
        colors = ButtonDefaults.outlinedButtonColors(
            contentColor = Color(0xFF3498DB)
        )
    ) {
        Column(
            horizontalAlignment = Alignment.CenterHorizontally
        ) {
            Icon(
                imageVector = icon,
                contentDescription = null,
                modifier = Modifier.size(24.dp)
            )
            
            Text(
                text = text,
                fontSize = 12.sp
            )
        }
    }
}

/**
 * Recent Activity Card
 */
@Composable
private fun RecentActivityCard(statistics: Map<String, Any>) {
    Card(
        colors = CardDefaults.cardColors(
            containerColor = Color.White
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 4.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Text(
                text = "النشاط الأخير",
                fontSize = 18.sp,
                fontWeight = FontWeight.Bold,
                color = Color(0xFF2C3E50)
            )
            
            Spacer(modifier = Modifier.height(16.dp))
            
            val recentActivity = (statistics["recentActivityCount"] as? Int) ?: 0
            Text(
                text = "سجلات النشاط في آخر 24 ساعة: $recentActivity",
                fontSize = 14.sp,
                color = Color.Gray
            )
        }
    }
}

/**
 * Entity Type Distribution
 */
@Composable
private fun EntityTypeDistribution(statistics: Map<String, Any>) {
    val logsByType = (statistics["logsByEntityType"] as? List<Map<String, Any>>) ?: emptyList()
    
    Card(
        colors = CardDefaults.cardColors(
            containerColor = Color.White
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 4.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Text(
                text = "توزيع السجلات حسب النوع",
                fontSize = 18.sp,
                fontWeight = FontWeight.Bold,
                color = Color(0xFF2C3E50)
            )
            
            Spacer(modifier = Modifier.height(16.dp))
            
            logsByType.forEach { item ->
                Row(
                    modifier = Modifier
                        .fillMaxWidth()
                        .padding(vertical = 4.dp),
                    horizontalArrangement = Arrangement.SpaceBetween
                ) {
                    Text(
                        text = (item["entityType"] as? String) ?: "Unknown",
                        fontSize = 14.sp,
                        color = Color.Gray
                    )
                    
                    Text(
                        text = (item["count"] as? Int)?.toString() ?: "0",
                        fontSize = 14.sp,
                        fontWeight = FontWeight.Bold,
                        color = Color(0xFF3498DB)
                    )
                }
            }
        }
    }
}

/**
 * Audit Log List
 */
@Composable
private fun AuditLogList(
    auditLogs: List<Map<String, Any>>,
    isLoading: Boolean,
    selectedTab: AuditTab
) {
    if (isLoading) {
        Box(
            modifier = Modifier.fillMaxSize(),
            contentAlignment = Alignment.Center
        ) {
            CircularProgressIndicator()
        }
    } else if (auditLogs.isEmpty()) {
        Box(
            modifier = Modifier.fillMaxSize(),
            contentAlignment = Alignment.Center
        ) {
            Text(
                text = "لا توجد سجلات متاحة",
                fontSize = 16.sp,
                color = Color.Gray
            )
        }
    } else {
        LazyColumn(
            modifier = Modifier
                .fillMaxSize()
                .padding(16.dp),
            verticalArrangement = Arrangement.spacedBy(8.dp)
        ) {
            items(auditLogs) { log ->
                AuditLogItem(log = log)
            }
        }
    }
}

/**
 * Audit Log Item
 */
@Composable
private fun AuditLogItem(log: Map<String, Any>) {
    Card(
        colors = CardDefaults.cardColors(
            containerColor = Color.White
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Row(
                modifier = Modifier.fillMaxWidth(),
                horizontalArrangement = Arrangement.SpaceBetween,
                verticalAlignment = Alignment.Top
            ) {
                Column(
                    modifier = Modifier.weight(1f)
                ) {
                    Text(
                        text = (log["description"] as? String) ?: "",
                        fontSize = 14.sp,
                        fontWeight = FontWeight.Medium,
                        color = Color(0xFF2C3E50)
                    )
                    
                    Spacer(modifier = Modifier.height(4.dp))
                    
                    Text(
                        text = "المستخدم: ${log["userId"]}",
                        fontSize = 12.sp,
                        color = Color.Gray
                    )
                    
                    Text(
                        text = "العملية: ${log["operation"]}",
                        fontSize = 12.sp,
                        color = Color.Gray
                    )
                }
                
                Text(
                    text = formatTimestamp((log["timestamp"] as? Long) ?: 0L),
                    fontSize = 12.sp,
                    color = Color.Gray
                )
            }
            
            // Show before/after data if available
            val beforeData = log["beforeData"] as? Map<String, Any>
            val afterData = log["afterData"] as? Map<String, Any>
            
            if (beforeData != null || afterData != null) {
                Spacer(modifier = Modifier.height(8.dp))
                
                Row(
                    horizontalArrangement = Arrangement.spacedBy(16.dp)
                ) {
                    beforeData?.let {
                        DataChangeCard(
                            title = "قبل",
                            data = it,
                            color = Color(0xFFE74C3C)
                        )
                    }
                    
                    afterData?.let {
                        DataChangeCard(
                            title = "بعد",
                            data = it,
                            color = Color(0xFF27AE60)
                        )
                    }
                }
            }
        }
    }
}

/**
 * Data Change Card
 */
@Composable
private fun DataChangeCard(
    title: String,
    data: Map<String, Any>,
    color: Color
) {
    Card(
        modifier = Modifier.clip(RoundedCornerShape(8.dp)),
        colors = CardDefaults.cardColors(
            containerColor = color.copy(alpha = 0.1f)
        )
    ) {
        Column(
            modifier = Modifier.padding(8.dp)
        ) {
            Text(
                text = title,
                fontSize = 12.sp,
                fontWeight = FontWeight.Bold,
                color = color
            )
            
            data.forEach { (key, value) ->
                Text(
                    text = "$key: $value",
                    fontSize = 10.sp,
                    color = Color.Gray
                )
            }
        }
    }
}

/**
 * Audit Log Search
 */
@Composable
private fun AuditLogSearch(
    searchQuery: String,
    onSearchQueryChanged: (String) -> Unit,
    auditLogs: List<Map<String, Any>>,
    isLoading: Boolean
) {
    Column(
        modifier = Modifier
            .fillMaxSize()
            .padding(16.dp)
    ) {
        // Search Field
        OutlinedTextField(
            value = searchQuery,
            onValueChange = onSearchQueryChanged,
            modifier = Modifier.fillMaxWidth(),
            placeholder = {
                Text(
                    text = "ابحث في سجلات العمليات...",
                    color = Color.Gray
                )
            },
            leadingIcon = {
                Icon(
                    imageVector = Icons.Default.Search,
                    contentDescription = "Search",
                    tint = Color.Gray
                )
            }
        )
        
        Spacer(modifier = Modifier.height(16.dp))
        
        // Search Results
        AuditLogList(
            auditLogs = auditLogs,
            isLoading = isLoading,
            selectedTab = AuditTab.SEARCH
        )
    }
}

/**
 * Audit Log Export Dialog
 */
@Composable
private fun AuditLogExportDialog(
    exportFormat: ExportFormat,
    onExportFormatChanged: (ExportFormat) -> Unit,
    onExport: () -> Unit,
    onDismiss: () -> Unit
) {
    AlertDialog(
        onDismissRequest = onDismiss,
        title = {
            Text(
                text = "تصدير سجلات العمليات",
                fontWeight = FontWeight.Bold
            )
        },
        text = {
            Column {
                Text(
                    text = "اختر تنسيق التصدير:",
                    fontSize = 14.sp
                )
                
                Spacer(modifier = Modifier.height(16.dp))
                
                ExportFormat.values().forEach { format ->
                    Row(
                        modifier = Modifier
                            .fillMaxWidth()
                            .clickable { onExportFormatChanged(format) },
                        verticalAlignment = Alignment.CenterVertically
                    ) {
                        RadioButton(
                            selected = exportFormat == format,
                            onClick = { onExportFormatChanged(format) }
                        )
                        
                        Spacer(modifier = Modifier.width(8.dp))
                        
                        Text(
                            text = when (format) {
                                ExportFormat.JSON -> "JSON"
                                ExportFormat.CSV -> "CSV"
                                ExportFormat.XML -> "XML"
                            }
                        )
                    }
                }
            }
        },
        confirmButton = {
            TextButton(onClick = onExport) {
                Text("تصدير")
            }
        },
        dismissButton = {
            TextButton(onClick = onDismiss) {
                Text("إلغاء")
            }
        }
    )
}

/**
 * Audit Log Filter Dialog
 */
@Composable
private fun AuditLogFilterDialog(
    selectedEntityType: String,
    onEntityTypeSelected: (String) -> Unit,
    selectedOperation: String,
    onOperationSelected: (String) -> Unit,
    selectedDateRange: DateRange,
    onDateRangeSelected: (DateRange) -> Unit,
    onDismiss: () -> Unit
) {
    AlertDialog(
        onDismissRequest = onDismiss,
        title = {
            Text(
                text = "تصفية السجلات",
                fontWeight = FontWeight.Bold
            )
        },
        text = {
            Column(
                modifier = Modifier.verticalScroll(rememberScrollState())
            ) {
                // Entity Type Filter
                Text(
                    text = "نوع الكيان:",
                    fontSize = 14.sp,
                    fontWeight = FontWeight.Medium
                )
                
                val entityTypes = listOf("ALL", "SHIPMENT", "USER", "PAYMENT", "VEHICLE", "DRIVER")
                entityTypes.forEach { type ->
                    Row(
                        modifier = Modifier
                            .fillMaxWidth()
                            .clickable { onEntityTypeSelected(type) },
                        verticalAlignment = Alignment.CenterVertically
                    ) {
                        RadioButton(
                            selected = selectedEntityType == type,
                            onClick = { onEntityTypeSelected(type) }
                        )
                        
                        Spacer(modifier = Modifier.width(8.dp))
                        
                        Text(
                            text = when (type) {
                                "ALL" -> "الكل"
                                "SHIPMENT" -> "شحنة"
                                "USER" -> "مستخدم"
                                "PAYMENT" -> "دفع"
                                "VEHICLE" -> "مركبة"
                                "DRIVER" -> "سائق"
                                else -> type
                            }
                        )
                    }
                }
                
                Spacer(modifier = Modifier.height(16.dp))
                
                // Date Range Filter
                Text(
                    text = "نطاق التاريخ:",
                    fontSize = 14.sp,
                    fontWeight = FontWeight.Medium
                )
                
                DateRange.values().forEach { range ->
                    Row(
                        modifier = Modifier
                            .fillMaxWidth()
                            .clickable { onDateRangeSelected(range) },
                        verticalAlignment = Alignment.CenterVertically
                    ) {
                        RadioButton(
                            selected = selectedDateRange == range,
                            onClick = { onDateRangeSelected(range) }
                        )
                        
                        Spacer(modifier = Modifier.width(8.dp))
                        
                        Text(
                            text = when (range) {
                                DateRange.TODAY -> "اليوم"
                                DateRange.YESTERDAY -> "أمس"
                                DateRange.LAST_WEEK -> "الأسبوع الماضي"
                                DateRange.LAST_MONTH -> "الشهر الماضي"
                                DateRange.CUSTOM -> "مخصص"
                            }
                        )
                    }
                }
            }
        },
        confirmButton = {
            TextButton(onClick = onDismiss) {
                Text("تطبيق")
            }
        },
        dismissButton = {
            TextButton(onClick = onDismiss) {
                Text("إلغاء")
            }
        }
    )
}

// Helper functions
private fun formatTimestamp(timestamp: Long): String {
    val sdf = SimpleDateFormat("dd/MM/yyyy HH:mm", Locale.getDefault())
    return sdf.format(Date(timestamp))
}

private fun AuditLogEntry.toMap(): Map<String, Any> {
    return mapOf(
        "id" to id,
        "userId" to userId,
        "operation" to operation.name,
        "description" to description,
        "timestamp" to timestamp,
        "beforeData" to beforeData,
        "afterData" to afterData,
        "metadata" to metadata,
        "ipAddress" to ipAddress
    )
}

// Enums
enum class AuditTab {
    OVERVIEW,
    SHIPMENTS,
    USERS,
    PAYMENTS,
    STATUS_CHANGES,
    SEARCH
}

enum class DateRange(val startDate: Long, val endDate: Long) {
    TODAY(
        startDate = System.currentTimeMillis() - (System.currentTimeMillis() % (24 * 60 * 60 * 1000L)),
        endDate = System.currentTimeMillis()
    ),
    YESTERDAY(
        startDate = System.currentTimeMillis() - (24 * 60 * 60 * 1000L) - (System.currentTimeMillis() % (24 * 60 * 60 * 1000L)),
        endDate = System.currentTimeMillis() - (System.currentTimeMillis() % (24 * 60 * 60 * 1000L))
    ),
    LAST_WEEK(
        startDate = System.currentTimeMillis() - (7 * 24 * 60 * 60 * 1000L),
        endDate = System.currentTimeMillis()
    ),
    LAST_MONTH(
        startDate = System.currentTimeMillis() - (30 * 24 * 60 * 60 * 1000L),
        endDate = System.currentTimeMillis()
    ),
    CUSTOM(
        startDate = 0L,
        endDate = System.currentTimeMillis()
    )
}
