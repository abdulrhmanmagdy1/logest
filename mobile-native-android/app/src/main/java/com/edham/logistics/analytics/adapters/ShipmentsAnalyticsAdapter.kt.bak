package com.edham.logistics.analytics.adapters

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.TextView
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.analytics.ShipmentsAnalytics

class ShipmentsAnalyticsAdapter(
    private val shipments: List<ShipmentsAnalytics>
) : RecyclerView.Adapter<ShipmentsAnalyticsAdapter.ViewHolder>() {

    class ViewHolder(view: View) : RecyclerView.ViewHolder(view) {
        val tvTotalShipments: TextView = view.findViewById(R.id.tv_total_shipments)
        val tvInTransit: TextView = view.findViewById(R.id.tv_in_transit)
        val tvDelivered: TextView = view.findViewById(R.id.tv_delivered)
        val tvPending: TextView = view.findViewById(R.id.tv_pending)
    }

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): ViewHolder {
        val view = LayoutInflater.from(parent.context)
            .inflate(R.layout.item_shipments_analytics, parent, false)
        return ViewHolder(view)
    }

    override fun onBindViewHolder(holder: ViewHolder, position: Int) {
        val shipment = shipments[position]
        holder.tvTotalShipments.text = shipment.totalShipments.toString()
        holder.tvInTransit.text = shipment.shipmentsByStatus["in_transit"]?.toString() ?: "0"
        holder.tvDelivered.text = shipment.shipmentsByStatus["delivered"]?.toString() ?: "0"
        holder.tvPending.text = shipment.shipmentsByStatus["pending"]?.toString() ?: "0"
    }

    override fun getItemCount(): Int = shipments.size
}
