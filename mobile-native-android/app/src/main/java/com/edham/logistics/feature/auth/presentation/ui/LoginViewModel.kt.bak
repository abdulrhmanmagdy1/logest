package com.edham.logistics.feature.auth.presentation.ui

import androidx.lifecycle.viewModelScope
import com.edham.logistics.core.utils.Result
import com.edham.logistics.feature.auth.domain.model.LoginRequest
import com.edham.logistics.feature.auth.domain.model.LoginResponse
import com.edham.logistics.feature.auth.domain.usecase.LoginUseCase
import com.edham.logistics.feature.auth.domain.usecase.RoleBasedRoutingUseCase
import com.edham.logistics.presentation.ui.base.BaseViewModel
import dagger.hilt.android.lifecycle.HiltViewModel
import kotlinx.coroutines.flow.MutableStateFlow
import kotlinx.coroutines.flow.StateFlow
import kotlinx.coroutines.flow.asStateFlow
import kotlinx.coroutines.launch
import javax.inject.Inject

@HiltViewModel
class LoginViewModel @Inject constructor(
    private val loginUseCase: LoginUseCase,
    private val roleBasedRoutingUseCase: RoleBasedRoutingUseCase
) : BaseViewModel<LoginViewModel.LoginUiState>() {

    private val _uiState = MutableStateFlow(LoginUiState())
    val uiState: StateFlow<LoginUiState> = _uiState.asStateFlow()

    override fun createInitialState(): LoginUiState = LoginUiState()

    fun login(email: String, password: String, rememberMe: Boolean) {
        val request = LoginRequest(
            email = email.trim(),
            password = password,
            rememberMe = rememberMe
        )

        executeOperation(
            operation = { loginUseCase(request) },
            onSuccess = { handleLoginSuccess(it) },
            onError = { handleLoginError(it) },
            onLoading = { setLoading(true) }
        )
    }

    private fun handleLoginSuccess(response: LoginResponse) {
        val routingDestination = roleBasedRoutingUseCase(response.user)
        
        updateUiState {
            copy(
                isLoading = false,
                isLoggedIn = true,
                user = response.user,
                routingDestination = routingDestination,
                error = null
            )
        }
    }

    private fun handleLoginError(error: String) {
        updateUiState {
            copy(
                isLoading = false,
                error = error
            )
        }
    }

    fun clearError() {
        updateUiState { copy(error = null) }
    }

    fun updateEmail(email: String) {
        updateUiState { copy(email = email) }
    }

    fun updatePassword(password: String) {
        updateUiState { copy(password = password) }
    }

    fun updateRememberMe(rememberMe: Boolean) {
        updateUiState { copy(rememberMe = rememberMe) }
    }

    fun onNavigationHandled() {
        updateUiState { copy(routingDestination = null) }
    }

    data class LoginUiState(
        val email: String = "",
        val password: String = "",
        val rememberMe: Boolean = false,
        val isLoading: Boolean = false,
        val isLoggedIn: Boolean = false,
        val user: com.edham.logistics.feature.auth.domain.model.User? = null,
        val routingDestination: com.edham.logistics.feature.auth.domain.usecase.RoutingDestination? = null,
        val error: String? = null
    ) : com.edham.logistics.presentation.ui.base.UiState {
        override fun copyLoading(isLoading: Boolean): UiState = copy(isLoading = isLoading)
        override fun copyError(error: String?): UiState = copy(error = error)
        override fun copySuccess(message: String?): UiState = this // Login doesn't use success messages
    }
}
