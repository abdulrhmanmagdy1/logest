package com.edham.logistics.ui.support

import android.os.Bundle
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.TextView
import androidx.fragment.app.Fragment
import androidx.recyclerview.widget.LinearLayoutManager
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.adapters.SupportManagementAdapter
import com.edham.logistics.domain.model.SupportTicket

class CustomerSupportFragment : Fragment() {

    private lateinit var rvSupportTickets: RecyclerView
    private lateinit var tvTotalTickets: TextView
    private lateinit var tvOpenTickets: TextView
    private lateinit var tvResolvedTickets: TextView
    private lateinit var supportAdapter: SupportManagementAdapter

    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View? {
        return inflater.inflate(R.layout.fragment_customer_support, container, false)
    }

    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        
        initViews(view)
        setupRecyclerView()
        loadSupportData()
    }

    private fun initViews(view: View) {
        rvSupportTickets = view.findViewById(R.id.rvSupportTickets)
        tvTotalTickets = view.findViewById(R.id.tvTotalTickets)
        tvOpenTickets = view.findViewById(R.id.tvOpenTickets)
        tvResolvedTickets = view.findViewById(R.id.tvResolvedTickets)
    }

    private fun setupRecyclerView() {
        supportAdapter = SupportManagementAdapter(getSampleTickets()) { ticket ->
            // Handle ticket click
            // TODO: Navigate to ticket details
        }
        
        rvSupportTickets.apply {
            layoutManager = LinearLayoutManager(requireContext())
            adapter = supportAdapter
        }
    }

    private fun loadSupportData() {
        val tickets = getSampleTickets()
        val openCount = tickets.count { it.status == "مفتوح" || it.status == "قيد المعالجة" }
        val resolvedCount = tickets.count { it.status == "مغلوق" || it.status == "محلول" }
        
        tvTotalTickets.text = tickets.size.toString()
        tvOpenTickets.text = openCount.toString()
        tvResolvedTickets.text = resolvedCount.toString()
        
        supportAdapter.updateTickets(tickets)
    }

    private fun getSampleTickets(): List<SupportTicket> {
        return listOf(
            SupportTicket("1", "مشكلة في التوصيل", "العميل يشتكي من تأخر الشحنة", "مفتوح", "عالي", "أحمد محمد", null, "2024-05-12T14:30:00", "2024-05-12T14:30:00"),
            SupportTicket("2", "استفسار عن الأسعار", "سؤال عن أسعار الشحنات", "قيد المعالجة", "متوسط", "محمد علي", null, "2024-05-12T13:45:00", "2024-05-12T13:45:00"),
            SupportTicket("3", "مشكلة في التطبيق", "التطبيق لا يعمل بشكل صحيح", "محلول", "منخفض", "عبدالله سالم", null, "2024-05-12T12:15:00", "2024-05-12T12:15:00"),
            SupportTicket("4", "شكوى من الخدمة", "عميل غير راضٍ عن الخدمة", "مفتوح", "عالي", "سالم خالد", null, "2024-05-12T11:30:00", "2024-05-12T11:30:00"),
            SupportTicket("5", "طلب استرجاع", "طلب استرجاع أموال", "قيد المعالجة", "عالي", "خالد أحمد", null, "2024-05-12T10:20:00", "2024-05-12T10:20:00")
        )
    }
}
