/**
 * Data classes
 */
data class MaintenanceCostData(
    val costType: MaintenanceCostType,
    val laborCost: Float,
    val partsCost: Float,
    val materialCost: Float,
    val otherCost: Float,
    val currency: String,
    val recordedBy: String,
    val notes: String,
    val attachments: List<String>,
    val vendorId: String? = null
)

data class RepairCostData(
    val repairType: RepairType,
    val laborCost: Float,
    val partsCost: Float,
    val materialCost: Float,
    val otherCost: Float,
    val currency: String,
    val recordedBy: String,
    val notes: String,
    val attachments: List<String>,
    val vendorId: String? = null
)

data class TrackedMaintenanceCost(
    val id: Long,
    val maintenanceId: Long,
    val costType: MaintenanceCostType,
    val laborCost: Float,
    val partsCost: Float,
    val materialCost: Float,
    val otherCost: Float,
    val totalCost: Float,
    val currency: String,
    val recordedBy: String,
    val recordedAt: Date,
    val notes: String,
    val attachments: List<String>
)

data class TrackedRepairCost(
    val id: Long,
    val repairId: Long,
    val repairType: RepairType,
    val laborCost: Float,
    val partsCost: Float,
    val materialCost: Float,
    val otherCost: Float,
    val totalCost: Float,
    val currency: String,
    val recordedBy: String,
    val recordedAt: Date,
    val notes: String,
    val attachments: List<String>
)

data class BudgetData(
    val budgetAmount: Float,
    val currency: String,
    val period: BudgetPeriod,
    val startDate: Date,
    val endDate: Date,
    val alertThreshold: Float
)

data class MaintenanceBudget(
    val id: Long,
    val budgetType: BudgetType,
    val budgetAmount: Float,
    val spentAmount: Float,
    val remainingAmount: Float,
    val currency: String,
    val period: BudgetPeriod,
    val startDate: Date,
    val endDate: Date,
    val alertThreshold: Float,
    val isActive: Boolean,
    val createdAt: Date,
    val updatedAt: Date
)

data class BudgetTracking(
    val totalBudget: Float,
    val totalSpent: Float,
    val totalRemaining: Float,
    val budgetUtilization: Float,
    val warningThresholds: Map<BudgetType, Float>
)

data class CostAnalysis(
    val dateRange: DateRange,
    val totalMaintenanceCost: Float,
    val totalRepairCost: Float,
    val totalCost: Float,
    val costBreakdown: CostBreakdown,
    val costTrends: CostTrends,
    val costByCategory: Map<String, Float>,
    val costByVehicle: Map<String, Float>,
    val costByVendor: Map<String, Float>,
    val costMetrics: CostMetrics,
    val predictions: List<CostPrediction>,
    val roiAnalysis: ROIAnalysis,
    val generatedAt: Date
)

data class CostBreakdown(
    val laborCost: Float,
    val partsCost: Float,
    val materialCost: Float,
    val otherCost: Float,
    val totalCost: Float,
    val maintenanceCostPercentage: Float,
    val repairCostPercentage: Float
)

data class CostTrends(
    val monthlyTrend: Float,
    val quarterlyTrend: Float,
    val yearlyTrend: Float,
    val averageMonthlyCost: Float,
    val averageQuarterlyCost: Float,
    val averageYearlyCost: Float
)

data class CostMetrics(
    val costPerMile: Float,
    val costPerHour: Float,
    val averageMaintenanceCost: Float,
    val averageRepairCost: Float,
    val costEfficiencyScore: Float,
    val costVariance: Float
)

data class CostPrediction(
    val predictionDate: Date,
    val predictedCost: Float,
    val confidence: Float,
    val category: String,
    val factors: List<String>
)

data class ROIAnalysis(
    val totalInvestment: Float,
    val totalSavings: Float,
    val netROI: Float,
    val paybackPeriod: Int,
    val annualizedReturn: Float
)

data class CostForecasting(
    val forecastPeriod: Int,
    val predictions: List<CostPrediction>,
    val accuracy: Float,
    val insights: List<String>,
    val generatedAt: Date
)

data class VendorCostData(
    val vendorId: String,
    val totalCost: Float,
    val projectCount: Int,
    val averageCostPerProject: Float,
    val lastCostDate: Date,
    val performanceRating: Float
)

data class CostOptimization(
    val id: String,
    val type: OptimizationType,
    val title: String,
    val description: String,
    val potentialSavings: Float,
    val implementation: String,
    val priority: OptimizationPriority,
    val impact: String
)

data class HistoricalCostData(
    val date: Date,
    val cost: Float,
    val category: String,
    val vehicleId: String,
    val vendorId: String?
)

/**
 * Interfaces
 */
interface CostTrackingListener {
    fun onMaintenanceCostTracked(cost: TrackedMaintenanceCost)
    fun onRepairCostTracked(cost: TrackedRepairCost)
    fun onBudgetSet(budget: MaintenanceBudget)
    fun onBudgetWarning(tracking: BudgetTracking)
    fun onCostAnalysisGenerated(analysis: CostAnalysis)
    fun onCostForecastGenerated(forecasting: CostForecasting)
    fun onCostOptimizationGenerated(optimizations: List<CostOptimization>)
}

/**
 * Enums
 */
enum class CostTrackingState {
    Idle,
    Initializing,
    Ready,
    TrackingCost,
    Analyzing,
    AnalysisGenerated,
    Forecasting,
    ForecastGenerated,
    Error
}

enum class MaintenanceCostType {
    ROUTINE,
    PREVENTIVE,
    CORRECTIVE,
    EMERGENCY,
    OIL_CHANGE,
    TIRE_REPLACEMENT,
    BRAKE_SERVICE,
    BATTERY_SERVICE,
    TRANSMISSION_SERVICE
}

enum class BudgetType {
    MAINTENANCE,
    REPAIRS,
    PARTS,
    LABOR,
    OVERALL
}

enum class BudgetPeriod {
    WEEKLY,
    MONTHLY,
    QUARTERLY,
    YEARLY
}

enum class OptimizationType {
    VENDOR_NEGOTIATION,
    PREVENTIVE_MAINTENANCE,
    PARTS_OPTIMIZATION,
    LABOR_EFFICIENCY,
    MAINTENANCE_FREQUENCY,
    BULK_PURCHASING
}

enum class OptimizationPriority {
    LOW,
    MEDIUM,
    HIGH,
    CRITICAL
}
