        }
    }
    
    private fun notifyBudgetWarning(tracking: BudgetTracking) {
        costTrackingListeners.forEach { listener ->
            listener.onBudgetWarning(tracking)
        }
    }
    
    private fun notifyCostTracked(cost: TrackedMaintenanceCost) {
        costTrackingListeners.forEach { listener ->
            listener.onMaintenanceCostTracked(cost)
        }
    }
    
    private fun notifyRepairCostTracked(cost: TrackedRepairCost) {
