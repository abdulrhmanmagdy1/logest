package com.edham.logistics.feature.auth.presentation.ui

import android.os.Bundle
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import androidx.fragment.app.Fragment
import androidx.fragment.app.viewModels
import androidx.lifecycle.lifecycleScope
import androidx.navigation.fragment.findNavController
import com.edham.logistics.core.extensions.gone
import com.edham.logistics.core.extensions.visible
import com.edham.logistics.core.extensions.showSnackbar
import com.edham.logistics.databinding.FragmentLogoutBinding
import com.edham.logistics.feature.auth.presentation.ui.LogoutViewModel
import dagger.hilt.android.AndroidEntryPoint
import kotlinx.coroutines.launch
import javax.inject.Inject

@AndroidEntryPoint
class LogoutFragment : Fragment() {

    private var _binding: FragmentLogoutBinding? = null
    private val binding get() = _binding!!
    
    private val viewModel: LogoutViewModel by viewModels()

    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View {
        _binding = FragmentLogoutBinding.inflate(inflater, container, false)
        return binding.root
    }

    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        setupUI()
        observeViewModel()
        setupClickListeners()
    }

    private fun setupUI() {
        // Initially hide logout button until we confirm user is logged in
        binding.buttonLogout.gone()
        binding.layoutUserInfo.gone()
        binding.layoutNotLoggedIn.gone()
    }

    private fun observeViewModel() {
        viewLifecycleOwner.lifecycleScope.launch {
            viewModel.uiState.collect { uiState ->
                updateUI(uiState)
            }
        }
    }

    private fun setupClickListeners() {
        binding.buttonLogout.setOnClickListener {
            viewModel.logout()
        }
        
        binding.buttonLogin.setOnClickListener {
            navigateToLogin()
        }
    }

    private fun updateUI(uiState: LogoutViewModel.LogoutUiState) {
        when {
            uiState.isLoggingOut -> {
                showLoggingOut()
            }
            uiState.logoutSuccess -> {
                showLogoutSuccess()
                navigateToLogin()
                viewModel.onLogoutHandled()
            }
            uiState.error != null -> {
                showError(uiState.error)
            }
            uiState.isLoggedIn && uiState.currentUser != null -> {
                showUserInfo(uiState.currentUser!!)
            }
            !uiState.isLoggedIn -> {
                showNotLoggedIn()
            }
        }
    }

    private fun showUserInfo(user: com.edham.logistics.feature.auth.domain.model.User) {
        binding.progressBar.gone()
        binding.layoutUserInfo.visible()
        binding.layoutNotLoggedIn.gone()
        binding.buttonLogout.visible()
        
        binding.textUserName.text = user.name
        binding.textUserEmail.text = user.email
        binding.textUserRole.text = formatRole(user.role)
        
        // Set user avatar if available
        user.profileImage?.let { imageUrl ->
            // Load user profile image using Coil or similar
            // binding.imageUserAvatar.load(imageUrl)
        }
    }

    private fun showNotLoggedIn() {
        binding.progressBar.gone()
        binding.layoutUserInfo.gone()
        binding.layoutNotLoggedIn.visible()
        binding.buttonLogout.gone()
        binding.buttonLogin.visible()
    }

    private fun showLoggingOut() {
        binding.progressBar.visible()
        binding.layoutUserInfo.gone()
        binding.layoutNotLoggedIn.gone()
        binding.buttonLogout.gone()
        binding.buttonLogin.gone()
    }

    private fun showLogoutSuccess() {
        binding.progressBar.gone()
        showSnackbar("تم تسجيل الخروج بنجاح")
    }

    private fun showError(error: String?) {
        binding.progressBar.gone()
        error?.let {
            showSnackbar(it)
        }
    }

    private fun formatRole(role: String): String {
        return when (role) {
            "admin" -> "مدير النظام"
            "supervisor" -> "مشرف العمليات"
            "driver" -> "سائق"
            "customer" -> "عميل"
            "accountant" -> "محاسب"
            "workshop" -> "فني ورشة"
            else -> role
        }
    }

    private fun navigateToLogin() {
        findNavController().navigate(R.id.action_logoutFragment_to_loginFragment)
    }

    override fun onDestroyView() {
        super.onDestroyView()
        _binding = null
    }
}
