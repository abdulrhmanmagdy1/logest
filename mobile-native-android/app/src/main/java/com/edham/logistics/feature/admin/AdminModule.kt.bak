package com.edham.logistics.feature.admin

import com.edham.logistics.feature.admin.data.repository.AdminRepositoryImpl
import com.edham.logistics.feature.admin.domain.repository.AdminRepository
import com.edham.logistics.feature.admin.domain.usecase.GetDashboardStatsUseCase
import com.edham.logistics.feature.admin.domain.usecase.GetUsersUseCase
import com.edham.logistics.feature.admin.domain.usecase.CreateUserUseCase
import com.edham.logistics.feature.admin.domain.usecase.UpdateUserUseCase
import com.edham.logistics.feature.admin.domain.usecase.DeleteUserUseCase
import dagger.Binds
import dagger.Module
import dagger.hilt.InstallIn
import dagger.hilt.components.SingletonComponent
import javax.inject.Singleton

@Module
@InstallIn(SingletonComponent::class)
abstract class AdminModule {

    @Binds
    @Singleton
    abstract fun bindAdminRepository(
        adminRepositoryImpl: AdminRepositoryImpl
    ): AdminRepository

    @Binds
    @Singleton
    abstract fun bindGetDashboardStatsUseCase(
        getDashboardStatsUseCase: GetDashboardStatsUseCase
    ): com.edham.logistics.feature.admin.domain.usecase.GetDashboardStatsUseCase

    @Binds
    @Singleton
    abstract fun bindGetUsersUseCase(
        getUsersUseCase: GetUsersUseCase
    ): com.edham.logistics.feature.admin.domain.usecase.GetUsersUseCase

    @Binds
    @Singleton
    abstract fun bindCreateUserUseCase(
        createUserUseCase: CreateUserUseCase
    ): com.edham.logistics.feature.admin.domain.usecase.CreateUserUseCase

    @Binds
    @Singleton
    abstract fun bindUpdateUserUseCase(
        updateUserUseCase: UpdateUserUseCase
    ): com.edham.logistics.feature.admin.domain.usecase.UpdateUserUseCase

    @Binds
    @Singleton
    abstract fun bindDeleteUserUseCase(
        deleteUserUseCase: DeleteUserUseCase
    ): com.edham.logistics.feature.admin.domain.usecase.DeleteUserUseCase
}
