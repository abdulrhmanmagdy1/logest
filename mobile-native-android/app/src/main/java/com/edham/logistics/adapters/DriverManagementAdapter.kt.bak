package com.edham.logistics.adapters

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.ImageView
import android.widget.TextView
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.domain.model.Driver

class DriverManagementAdapter(
    private var drivers: List<Driver>,
    private val onDriverClick: (Driver) -> Unit
) : RecyclerView.Adapter<DriverManagementAdapter.DriverViewHolder>() {

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): DriverViewHolder {
        val view = LayoutInflater.from(parent.context)
            .inflate(R.layout.item_driver_management, parent, false)
        return DriverViewHolder(view)
    }

    override fun onBindViewHolder(holder: DriverViewHolder, position: Int) {
        holder.bind(drivers[position])
    }

    override fun getItemCount(): Int = drivers.size

    fun updateDrivers(newDrivers: List<Driver>) {
        drivers = newDrivers
        notifyDataSetChanged()
    }

    inner class DriverViewHolder(itemView: View) : RecyclerView.ViewHolder(itemView) {
        private val tvDriverName: TextView = itemView.findViewById(R.id.tvDriverName)
        private val tvVehicleNumber: TextView = itemView.findViewById(R.id.tvVehicleNumber)
        private val tvDriverStatus: TextView = itemView.findViewById(R.id.tvDriverStatus)
        private val tvCurrentTask: TextView = itemView.findViewById(R.id.tvCurrentTask)
        private val tvPhoneNumber: TextView = itemView.findViewById(R.id.tvPhoneNumber)
        private val ivStatusIndicator: ImageView = itemView.findViewById(R.id.ivStatusIndicator)

        fun bind(driver: Driver) {
            tvDriverName.text = driver.name
            tvVehicleNumber.text = driver.vehicleNumber
            tvDriverStatus.text = driver.status
            tvCurrentTask.text = driver.currentTask
            tvPhoneNumber.text = driver.phoneNumber

            // Set status indicator and color
            when (driver.status) {
                "نشط" -> {
                    ivStatusIndicator.setImageResource(R.drawable.circle_green)
                    tvDriverStatus.setTextColor(itemView.context.getColor(R.color.supervisor_success))
                }
                "في مهمة" -> {
                    ivStatusIndicator.setImageResource(R.drawable.circle_warning)
                    tvDriverStatus.setTextColor(itemView.context.getColor(R.color.supervisor_warning))
                }
                "متوقف" -> {
                    ivStatusIndicator.setImageResource(R.drawable.circle_red)
                    tvDriverStatus.setTextColor(itemView.context.getColor(R.color.supervisor_error))
                }
                "غير متصل" -> {
                    ivStatusIndicator.setImageResource(R.drawable.circle_grey)
                    tvDriverStatus.setTextColor(itemView.context.getColor(R.color.text_secondary))
                }
                else -> {
                    ivStatusIndicator.setImageResource(R.drawable.circle_grey)
                    tvDriverStatus.setTextColor(itemView.context.getColor(R.color.text_secondary))
                }
            }

            itemView.setOnClickListener {
                onDriverClick(driver)
            }
        }
    }
}
