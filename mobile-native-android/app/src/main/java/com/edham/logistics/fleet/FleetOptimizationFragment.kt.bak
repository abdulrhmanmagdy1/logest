package com.edham.logistics.fleet

import android.os.Bundle
import androidx.compose.foundation.layout.*
import androidx.compose.foundation.lazy.LazyColumn
import androidx.compose.foundation.lazy.items
import androidx.compose.material3.*
import androidx.compose.runtime.*
import androidx.compose.ui.Alignment
import androidx.compose.ui.Modifier
import androidx.compose.ui.graphics.Color
import androidx.compose.ui.text.font.FontWeight
import androidx.compose.ui.unit.dp
import androidx.fragment.app.Fragment
import androidx.lifecycle.viewmodel.compose.viewModel
import kotlinx.coroutines.launch

/**
 * Fleet Optimization Fragment - UI for fleet management
 */
class FleetOptimizationFragment : Fragment() {
    
    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
    }
    
    override fun onCreateView(
        inflater: android.view.LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): android.view.View {
        return ComposeView(requireContext()).apply {
            setContent {
                FleetOptimizationScreen()
            }
        }
    }
}

@Composable
fun FleetOptimizationScreen() {
    val viewModel: FleetOptimizationViewModel = viewModel()
    val scope = rememberCoroutineScope()
    
    // Collect fleet data
    val fleetData by viewModel.fleetOptimizationData.collectAsState()
    val isLoading by viewModel.isLoading.collectAsState()
    val error by viewModel.error.collectAsState()
    
    LaunchedEffect(Unit) {
        viewModel.refreshFleetData()
    }
    
    Column(
        modifier = Modifier
            .fillMaxSize()
            .padding(16.dp)
    ) {
        // Header
        FleetOptimizationHeader(
            onRefresh = { viewModel.refreshFleetData() },
            isLoading = isLoading
        )
        
        Spacer(modifier = Modifier.height(16.dp))
        
        // Main content
        when {
            isLoading -> {
                LoadingIndicator()
            }
            error != null -> {
                ErrorMessage(error = error, onRetry = { viewModel.refreshFleetData() })
            }
            else -> {
                fleetData?.let { data ->
                    LazyColumn(
                        verticalArrangement = Arrangement.spacedBy(16.dp)
                    ) {
                        // Fleet Overview
                        item {
                            FleetOverviewCard(fleetData = data.fleetData)
                        }
                        
                        // Utilization Analysis
                        item {
                            UtilizationAnalysisCard(utilizationData = data.utilizationAnalysis)
                        }
                        
                        // Idle Vehicles
                        if (data.idleVehicles.isNotEmpty()) {
                            item {
                                IdleVehiclesCard(idleVehicles = data.idleVehicles)
                            }
                        }
                        
                        // Maintenance Alerts
                        if (data.maintenanceAlerts.isNotEmpty()) {
                            item {
                                MaintenanceAlertsCard(alerts = data.maintenanceAlerts)
                            }
                        }
                        
                        // Fleet Health Score
                        item {
                            FleetHealthScoreCard(healthScore = data.healthScore)
                        }
                        
                        // Recommendations
                        if (data.recommendations.isNotEmpty()) {
                            item {
                                RecommendationsCard(recommendations = data.recommendations)
                            }
                        }
                        
                        // Assignment Optimization
                        item {
                            AssignmentOptimizationCard(
                                assignmentData = data.assignmentOptimization,
                                onAssignVehicle = { shipmentId, vehicleId ->
                                    scope.launch {
                                        viewModel.assignVehicle(shipmentId, vehicleId)
                                    }
                                }
                            )
                        }
                    }
                }
            }
        }
    }
}

@Composable
fun FleetOptimizationHeader(
    onRefresh: () -> Unit,
    isLoading: Boolean
) {
    Row(
        modifier = Modifier.fillMaxWidth(),
        horizontalArrangement = Arrangement.SpaceBetween,
        verticalAlignment = Alignment.CenterVertically
    ) {
        Text(
            text = "Fleet Optimization",
            style = MaterialTheme.typography.headlineMedium,
            fontWeight = FontWeight.Bold
        )
        
        Button(
            onClick = onRefresh,
            enabled = !isLoading
        ) {
            if (isLoading) {
                CircularProgressIndicator(
                    modifier = Modifier.size(24.dp),
                    strokeWidth = 2.dp
                )
            } else {
                Text("Refresh")
            }
        }
    }
}

@Composable
fun FleetOverviewCard(fleetData: FleetData) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        elevation = CardDefaults.cardElevation(defaultElevation = 4.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Text(
                text = "Fleet Overview",
                style = MaterialTheme.typography.titleMedium,
                fontWeight = FontWeight.Bold
            )
            
            Spacer(modifier = Modifier.height(12.dp))
            
            Row(
                modifier = Modifier.fillMaxWidth(),
                horizontalArrangement = Arrangement.SpaceEvenly
            ) {
                FleetOverviewItem(
                    label = "Total Vehicles",
                    value = fleetData.totalVehicles.toString(),
                    color = MaterialTheme.colorScheme.primary
                )
                
                FleetOverviewItem(
                    label = "Active",
                    value = fleetData.activeVehicles.toString(),
                    color = Color(0xFF10B981) // Green
                )
                
                FleetOverviewItem(
                    label = "In Maintenance",
                    value = fleetData.vehiclesInMaintenance.toString(),
                    color = Color(0xFFF59E0B) // Orange
                )
                
                FleetOverviewItem(
                    label = "Available",
                    value = (fleetData.totalVehicles - fleetData.activeVehicles - fleetData.vehiclesInMaintenance).toString(),
                    color = Color(0xFF3B82F6) // Blue
                )
            }
        }
    }
}

@Composable
fun FleetOverviewItem(
    label: String,
    value: String,
    color: Color
) {
    Column(
        horizontalAlignment = Alignment.CenterHorizontally
    ) {
        Text(
            text = value,
            style = MaterialTheme.typography.headlineSmall,
            fontWeight = FontWeight.Bold,
            color = color
        )
        
        Text(
            text = label,
            style = MaterialTheme.typography.bodySmall,
            color = MaterialTheme.colorScheme.onSurfaceVariant
        )
    }
}

@Composable
fun UtilizationAnalysisCard(utilizationData: VehicleUtilizationAnalysis) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        elevation = CardDefaults.cardElevation(defaultElevation = 4.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Text(
                text = "Vehicle Utilization",
                style = MaterialTheme.typography.titleMedium,
                fontWeight = FontWeight.Bold
            )
            
            Spacer(modifier = Modifier.height(12.dp))
            
            // Overall utilization
            UtilizationProgressBar(
                label = "Overall Utilization",
                percentage = utilizationData.overallUtilization,
                color = when {
                    utilizationData.overallUtilization >= 0.8 -> Color(0xFF10B981) // Green
                    utilizationData.overallUtilization >= 0.5 -> Color(0xFFF59E0B) // Orange
                    else -> Color(0xFFEF4444) // Red
                }
            )
            
            Spacer(modifier = Modifier.height(8.dp))
            
            // Utilization by type
            Text(
                text = "Utilization by Type",
                style = MaterialTheme.typography.bodyMedium,
                fontWeight = FontWeight.Medium
            )
            
            Spacer(modifier = Modifier.height(8.dp))
            
            utilizationData.averageUtilizationByType.forEach { (type, utilization) ->
                Row(
                    modifier = Modifier.fillMaxWidth(),
                    horizontalArrangement = Arrangement.SpaceBetween,
                    verticalAlignment = Alignment.CenterVertically
                ) {
                    Text(
                        text = type,
                        style = MaterialTheme.typography.bodyMedium
                    )
                    
                    Text(
                        text = "${String.format("%.1f", utilization * 100)}%",
                        style = MaterialTheme.typography.bodyMedium,
                        fontWeight = FontWeight.Medium
                    )
                }
                
                Spacer(modifier = Modifier.height(4.dp))
            }
        }
    }
}

@Composable
fun UtilizationProgressBar(
    label: String,
    percentage: Double,
    color: Color
) {
    Column {
        Row(
            modifier = Modifier.fillMaxWidth(),
            horizontalArrangement = Arrangement.SpaceBetween
        ) {
            Text(
                text = label,
                style = MaterialTheme.typography.bodyMedium
            )
            
            Text(
                text = "${String.format("%.1f", percentage * 100)}%",
                style = MaterialTheme.typography.bodyMedium,
                fontWeight = FontWeight.Medium
            )
        }
        
        Spacer(modifier = Modifier.height(8.dp))
        
        LinearProgressIndicator(
            progress = { percentage.toFloat() },
            modifier = Modifier
                .fillMaxWidth()
                .height(8.dp),
            color = color,
            trackColor = MaterialTheme.colorScheme.surfaceVariant,
        )
    }
}

@Composable
fun IdleVehiclesCard(idleVehicles: List<IdleVehicle>) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        elevation = CardDefaults.cardElevation(defaultElevation = 4.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Text(
                text = "Idle Vehicles (${idleVehicles.size})",
                style = MaterialTheme.typography.titleMedium,
                fontWeight = FontWeight.Bold,
                color = Color(0xFFF59E0B) // Orange
            )
            
            Spacer(modifier = Modifier.height(12.dp))
            
            idleVehicles.take(5).forEach { vehicle ->
                IdleVehicleItem(vehicle = vehicle)
                Spacer(modifier = Modifier.height(8.dp))
            }
            
            if (idleVehicles.size > 5) {
                TextButton(
                    onClick = { /* Navigate to full list */ }
                ) {
                    Text("View All ${idleVehicles.size} Idle Vehicles")
                }
            }
        }
    }
}

@Composable
fun IdleVehicleItem(vehicle: IdleVehicle) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.surfaceVariant
        )
    ) {
        Column(
            modifier = Modifier.padding(12.dp)
        ) {
            Row(
                modifier = Modifier.fillMaxWidth(),
                horizontalArrangement = Arrangement.SpaceBetween
            ) {
                Column {
                    Text(
                        text = vehicle.licensePlate,
                        style = MaterialTheme.typography.bodyLarge,
                        fontWeight = FontWeight.Medium
                    )
                    
                    Text(
                        text = vehicle.vehicleType.toString(),
                        style = MaterialTheme.typography.bodyMedium,
                        color = MaterialTheme.colorScheme.onSurfaceVariant
                    )
                }
                
                Text(
                    text = "Idle for ${vehicle.idleDuration.toHours()}h",
                    style = MaterialTheme.typography.bodySmall,
                    color = Color(0xFFF59E0B)
                )
            }
            
            if (vehicle.location != null) {
                Text(
                    text = "Location: ${String.format("%.4f", vehicle.location.latitude)}, ${String.format("%.4f", vehicle.location.longitude)}",
                    style = MaterialTheme.typography.bodySmall,
                    color = MaterialTheme.colorScheme.onSurfaceVariant
                )
            }
        }
    }
}

@Composable
fun MaintenanceAlertsCard(alerts: List<MaintenanceAlert>) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        elevation = CardDefaults.cardElevation(defaultElevation = 4.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Text(
                text = "Maintenance Alerts (${alerts.size})",
                style = MaterialTheme.typography.titleMedium,
                fontWeight = FontWeight.Bold,
                color = Color(0xFFEF4444) // Red
            )
            
            Spacer(modifier = Modifier.height(12.dp))
            
            alerts.take(3).forEach { alert ->
                MaintenanceAlertItem(alert = alert)
                Spacer(modifier = Modifier.height(8.dp))
            }
            
            if (alerts.size > 3) {
                TextButton(
                    onClick = { /* Navigate to maintenance */ }
                ) {
                    Text("View All ${alerts.size} Alerts")
                }
            }
        }
    }
}

@Composable
fun MaintenanceAlertItem(alert: MaintenanceAlert) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(
            containerColor = when (alert.priority) {
                Priority.HIGH -> Color(0xFFFEE2E2)
                Priority.MEDIUM -> Color(0xFFFEF3C7)
                else -> MaterialTheme.colorScheme.surface
            }
        )
    ) {
        Column(
            modifier = Modifier.padding(12.dp)
        ) {
            Row(
                modifier = Modifier.fillMaxWidth(),
                horizontalArrangement = Arrangement.SpaceBetween
            ) {
                Column(modifier = Modifier.weight(1f)) {
                    Text(
                        text = alert.licensePlate,
                        style = MaterialTheme.typography.bodyLarge,
                        fontWeight = FontWeight.Medium
                    )
                    
                    Text(
                        text = alert.description,
                        style = MaterialTheme.typography.bodyMedium,
                        color = MaterialTheme.colorScheme.onSurface
                    )
                }
                
                Text(
                    text = alert.priority.toString(),
                    style = MaterialTheme.typography.bodySmall,
                    fontWeight = FontWeight.Bold,
                    color = when (alert.priority) {
                        Priority.HIGH -> Color(0xFFEF4444)
                        Priority.MEDIUM -> Color(0xFFF59E0B)
                        else -> MaterialTheme.colorScheme.primary
                    }
                )
            }
            
            Spacer(modifier = Modifier.height(4.dp))
            
            Text(
                text = "Recommended: ${alert.recommendedDate}",
                style = MaterialTheme.typography.bodySmall,
                color = MaterialTheme.colorScheme.onSurfaceVariant
            )
        }
    }
}

@Composable
fun FleetHealthScoreCard(healthScore: FleetHealthScore) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        elevation = CardDefaults.cardElevation(defaultElevation = 4.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Text(
                text = "Fleet Health Score",
                style = MaterialTheme.typography.titleMedium,
                fontWeight = FontWeight.Bold
            )
            
            Spacer(modifier = Modifier.height(12.dp))
            
            // Overall score
            Row(
                modifier = Modifier.fillMaxWidth(),
                horizontalArrangement = Arrangement.SpaceBetween,
                verticalAlignment = Alignment.CenterVertically
            ) {
                Text(
                    text = "Overall Health",
                    style = MaterialTheme.typography.bodyLarge
                )
                
                Text(
                    text = "${String.format("%.1f", healthScore.overallHealthScore)}/100",
                    style = MaterialTheme.typography.headlineMedium,
                    fontWeight = FontWeight.Bold,
                    color = when {
                        healthScore.overallHealthScore >= 80 -> Color(0xFF10B981) // Green
                        healthScore.overallHealthScore >= 60 -> Color(0xFFF59E0B) // Orange
                        else -> Color(0xFFEF4444) // Red
                    }
                )
            }
            
            Spacer(modifier = Modifier.height(16.dp))
            
            // Health metrics
            HealthMetricRow(
                label = "Availability",
                value = "${String.format("%.1f", healthScore.availabilityRate * 100)}%"
            )
            
            HealthMetricRow(
                label = "Avg Health",
                value = "${String.format("%.1f", healthScore.averageHealthScore * 100)}%"
            )
            
            HealthMetricRow(
                label = "Avg Utilization",
                value = "${String.format("%.1f", healthScore.averageUtilization * 100)}%"
            )
        }
    }
}

@Composable
fun HealthMetricRow(
    label: String,
    value: String
) {
    Row(
        modifier = Modifier.fillMaxWidth(),
        horizontalArrangement = Arrangement.SpaceBetween
    ) {
        Text(
            text = label,
            style = MaterialTheme.typography.bodyMedium
        )
        
        Text(
            text = value,
            style = MaterialTheme.typography.bodyMedium,
            fontWeight = FontWeight.Medium
        )
    }
}

