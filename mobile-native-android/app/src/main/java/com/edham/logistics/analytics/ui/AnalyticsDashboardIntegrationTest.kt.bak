package com.edham.logistics.analytics.ui

import androidx.compose.ui.test.*
import androidx.compose.ui.test.junit4.createComposeRule
import androidx.test.ext.junit.runners.AndroidJUnit4
import dagger.hilt.android.testing.HiltAndroidRule
import dagger.hilt.android.testing.HiltAndroidTest
import kotlinx.coroutines.ExperimentalCoroutinesApi
import kotlinx.coroutines.test.runTest
import org.junit.Before
import org.junit.Rule
import org.junit.Test
import org.junit.runner.RunWith
import javax.inject.Inject

/**
 * Analytics Dashboard Integration Test - Comprehensive testing for all analytics components
 * 
 * This test class validates the integration between all analytics dashboard components:
 * - Real-time KPIs
 * - Fleet Analytics
 * - Shipment Analytics
 * - Driver Performance
 * - Fuel Analytics
 * - Revenue Analytics
 * - Temperature Analytics
 * - Delay Analytics
 * - Incident Analytics
 * - Interactive Charts
 * - Live Widgets
 * - Real-time Indicators
 * - Exportable Reports
 * - Filters & Date Ranges
 */
@HiltAndroidTest
@RunWith(AndroidJUnit4::class)
@ExperimentalCoroutinesApi
class AnalyticsDashboardIntegrationTest {
    
    @get:Rule
    val composeTestRule = createComposeRule()
    
    @get:Rule
    val hiltRule = HiltAndroidRule(this)
    
    @Inject
    lateinit var analyticsEngineService: com.edham.logistics.analytics.AnalyticsEngineService
    
    private lateinit var viewModel: AnalyticsDashboardViewModel
    
    @Before
    fun setup() {
        hiltRule.inject()
        viewModel = AnalyticsDashboardViewModel(analyticsEngineService)
    }
    
    @Test
    fun testRealTimeKPIsIntegration() = runTest {
        // Test Real-time KPIs component integration
        composeTestRule.setContent {
            RealTimeKPIsScreen(
                viewModel = viewModel,
                analyticsEngineService = analyticsEngineService
            )
        }
        
        // Verify KPI cards are displayed
        composeTestRule
            .onNodeWithText("Real-Time KPIs")
            .assertIsDisplayed()
        
        composeTestRule
            .onNodeWithText("Shipments")
            .assertIsDisplayed()
        
        composeTestRule
            .onNodeWithText("Fleet")
            .assertIsDisplayed()
        
        composeTestRule
            .onNodeWithText("Financial")
            .assertIsDisplayed()
        
        composeTestRule
            .onNodeWithText("Operations")
            .assertIsDisplayed()
        
        // Test refresh functionality
        composeTestRule
            .onNodeWithContentDescription("Refresh")
            .performClick()
        
        // Verify refresh indicator appears
        composeTestRule
            .onNodeWithContentDescription("Loading")
            .assertIsDisplayed()
    }
    
