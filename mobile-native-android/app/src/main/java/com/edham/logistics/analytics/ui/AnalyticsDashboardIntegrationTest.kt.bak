    @Test
    fun testCrossComponentDataFlow() = runTest {
        // Test data flow between different analytics components
        composeTestRule.setContent {
            // Create a container that includes multiple analytics components
            Column {
                RealTimeKPIsScreen(
                    viewModel = viewModel,
                    analyticsEngineService = analyticsEngineService
                )
                
                FleetAnalyticsScreen(
                    viewModel = viewModel,
                    analyticsEngineService = analyticsEngineService
                )
                
                ShipmentAnalyticsScreen(
                    viewModel = viewModel,
                    analyticsEngineService = analyticsEngineService
                )
            }
        }
        
        // Verify all components are displayed
        composeTestRule
            .onNodeWithText("Real-Time KPIs")
            .assertIsDisplayed()
        
        composeTestRule
            .onNodeWithText("Fleet Analytics")
            .assertIsDisplayed()
        
        composeTestRule
            .onNodeWithText("Shipment Analytics")
            .assertIsDisplayed()
        
        // Test time range synchronization
        composeTestRule
            .onAllNodesWithText("Last 24 Hours")
            .onFirst()
            .performClick()
        
        // Verify all components update with the same time range
        composeTestRule
            .onAllNodesWithText("Last 24 Hours")
            .assertCountEquals(3) // Should be 3 instances
    }
    
    @Test
    fun testErrorHandlingIntegration() = runTest {
        // Test error handling across all analytics components
        composeTestRule.setContent {
            RealTimeKPIsScreen(
                viewModel = viewModel,
                analyticsEngineService = analyticsEngineService
            )
        }
        
        // Simulate error state
        viewModel.setError("Network connection failed")
        
        // Verify error message is displayed
        composeTestRule
            .onNodeWithText("Network connection failed")
            .assertIsDisplayed()
        
        // Test error recovery
        viewModel.clearError()
        
        // Verify error message is cleared
        composeTestRule
            .onNodeWithText("Network connection failed")
            .assertDoesNotExist()
    }
    
    @Test
    fun testLoadingStatesIntegration() = runTest {
        // Test loading states across all analytics components
        composeTestRule.setContent {
            FleetAnalyticsScreen(
                viewModel = viewModel,
                analyticsEngineService = analyticsEngineService
            )
        }
        
        // Set loading state
        viewModel.setLoading(true)
        
        // Verify loading indicator is displayed
        composeTestRule
            .onNodeWithContentDescription("Loading")
            .assertIsDisplayed()
        
        // Clear loading state
        viewModel.setLoading(false)
        
        // Verify content is displayed after loading
        composeTestRule
            .onNodeWithText("Fleet Analytics")
            .assertIsDisplayed()
    }
    
    @Test
    fun testPerformanceIntegration() = runTest {
        // Test performance of analytics dashboard integration
        val startTime = System.currentTimeMillis()
        
        composeTestRule.setContent {
            Column {
                RealTimeKPIsScreen(
                    viewModel = viewModel,
                    analyticsEngineService = analyticsEngineService
                )
                
                FleetAnalyticsScreen(
                    viewModel = viewModel,
                    analyticsEngineService = analyticsEngineService
                )
                
                ShipmentAnalyticsScreen(
                    viewModel = viewModel,
                    analyticsEngineService = analyticsEngineService
                )
                
                DriverPerformanceScreen(
                    viewModel = viewModel,
                    analyticsEngineService = analyticsEngineService
                )
                
                FuelAnalyticsScreen(
                    viewModel = viewModel,
                    analyticsEngineService = analyticsEngineService
                )
            }
        }
        
        val endTime = System.currentTimeMillis()
        val loadTime = endTime - startTime
        
        // Verify dashboard loads within acceptable time (less than 3 seconds)
        assert(loadTime < 3000) { "Dashboard should load within 3 seconds, but took ${loadTime}ms" }
        
        // Verify all components are displayed
        composeTestRule
            .onNodeWithText("Real-Time KPIs")
            .assertIsDisplayed()
        
        composeTestRule
            .onNodeWithText("Fleet Analytics")
            .assertIsDisplayed()
        
        composeTestRule
            .onNodeWithText("Shipment Analytics")
            .assertIsDisplayed()
        
        composeTestRule
            .onNodeWithText("Driver Performance Analytics")
            .assertIsDisplayed()
        
        composeTestRule
            .onNodeWithText("Fuel Analytics")
            .assertIsDisplayed()
    }
    
