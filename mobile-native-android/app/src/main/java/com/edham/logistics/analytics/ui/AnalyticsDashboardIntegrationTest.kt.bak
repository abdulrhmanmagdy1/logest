    @Test
    fun testMemoryUsageIntegration() = runTest {
        // Test memory usage when multiple analytics components are loaded
        val runtime = Runtime.getRuntime()
        val initialMemory = runtime.totalMemory() - runtime.freeMemory()
        
        composeTestRule.setContent {
            Column {
                // Load all analytics components
                RealTimeKPIsScreen(
                    viewModel = viewModel,
                    analyticsEngineService = analyticsEngineService
                )
                
                FleetAnalyticsScreen(
                    viewModel = viewModel,
                    analyticsEngineService = analyticsEngineService
                )
                
                ShipmentAnalyticsScreen(
                    viewModel = viewModel,
                    analyticsEngineService = analyticsEngineService
                )
                
                DriverPerformanceScreen(
                    viewModel = viewModel,
                    analyticsEngineService = analyticsEngineService
                )
                
                FuelAnalyticsScreen(
                    viewModel = viewModel,
                    analyticsEngineService = analyticsEngineService
                )
                
                RevenueAnalyticsScreen(
                    viewModel = viewModel,
                    analyticsEngineService = analyticsEngineService
                )
                
                TemperatureAnalyticsScreen(
                    viewModel = viewModel,
                    analyticsEngineService = analyticsEngineService
                )
                
                DelayAnalyticsScreen(
                    viewModel = viewModel,
                    analyticsEngineService = analyticsEngineService
                )
                
                IncidentAnalyticsScreen(
                    viewModel = viewModel,
                    analyticsEngineService = analyticsEngineService
                )
                
                InteractiveChartsScreen(
                    viewModel = viewModel,
                    analyticsEngineService = analyticsEngineService
                )
                
                LiveWidgetsScreen(
                    viewModel = viewModel,
                    analyticsEngineService = analyticsEngineService
                )
                
                RealTimeIndicatorsScreen(
                    viewModel = viewModel,
                    analyticsEngineService = analyticsEngineService
                )
                
                ExportableReportsScreen(
                    viewModel = viewModel,
                    analyticsEngineService = analyticsEngineService
                )
                
                FiltersAndDateRangesScreen(
                    viewModel = viewModel,
                    analyticsEngineService = analyticsEngineService
                )
            }
        }
        
        // Force garbage collection
        System.gc()
        Thread.sleep(100)
        
        val finalMemory = runtime.totalMemory() - runtime.freeMemory()
        val memoryIncrease = finalMemory - initialMemory
        
        // Verify memory usage is reasonable (less than 50MB increase)
        assert(memoryIncrease < 50 * 1024 * 1024) { 
            "Memory increase should be less than 50MB, but was ${memoryIncrease / (1024 * 1024)}MB" 
        }
        
        // Verify all components are still functional
        composeTestRule
            .onNodeWithText("Real-Time KPIs")
            .assertIsDisplayed()
    }
}
