class SupervisorDashboardEnhancedFragment : Fragment() {

    // Main Views
    private lateinit var drawerLayout: DrawerLayout
    private lateinit var navigationView: NavigationView
    private lateinit var navigationController: SupervisorNavigationController
    
    // Header Views
    private lateinit var ivMenu: ImageView
    private lateinit var ivNotifications: ImageView
    private lateinit var tvActiveDrivers: TextView
    private lateinit var tvCompletedTasks: TextView
    private lateinit var tvPendingTasks: TextView
    private lateinit var tvPendingTasksAlt: TextView
    private lateinit var tvTeamEfficiency: TextView
    private lateinit var tvTeamEfficiencyAlt: TextView
    
    // Map Section
    private lateinit var mapContainer: MaterialCardView
    private lateinit var rvDriverStatus: RecyclerView
    private lateinit var rvRecentActivities: RecyclerView
    
    // Performance Metrics
    private lateinit var pbOnTimeDelivery: ProgressBar
    private lateinit var pbCustomerSatisfaction: ProgressBar
    private lateinit var pbFuelEfficiency: ProgressBar
    
    // Quick Actions
    private lateinit var btnAddDriver: CardView
    private lateinit var btnNewShipment: CardView
    private lateinit var btnQuickReport: CardView
    
    // Adapters
    private lateinit var driverStatusAdapter: DriverStatusAdapter
    private lateinit var recentActivitiesAdapter: RecentActivitiesAdapter
    private lateinit var sidebarMenuAdapter: SidebarMenuAdapter

    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View? {
        return inflater.inflate(R.layout.fragment_supervisor_dashboard_enhanced, container, false)
    }

    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        
        // Initialize navigation controller
        navigationController = SupervisorNavigationController(requireContext(), findNavController())
        
        initViews(view)
        setupClickListeners()
        setupRecyclerViews()
        animateCounters()
        animateProgressBars()
        loadDriverStatus()
        loadRecentActivities()
        setupSidebarMenu()
    }

    private fun initViews(view: View) {
        // Drawer and Navigation
        drawerLayout = view.findViewById(R.id.drawerLayout)
        navigationView = view.findViewById(R.id.navigationView)
        
        // Header
        ivMenu = view.findViewById(R.id.ivMenu)
        ivNotifications = view.findViewById(R.id.ivNotifications)
        tvActiveDrivers = view.findViewById(R.id.tv_active_drivers)
        tvCompletedTasks = view.findViewById(R.id.tv_completed_tasks)
        tvPendingTasks = view.findViewById(R.id.tv_pending_tasks)
        tvPendingTasksAlt = view.findViewById(R.id.tv_pending_tasks_alt)
        tvTeamEfficiency = view.findViewById(R.id.tv_team_efficiency)
        tvTeamEfficiencyAlt = view.findViewById(R.id.tv_team_efficiency_alt)
        
        // Map Section
        mapContainer = view.findViewById(R.id.mapContainer)
        rvDriverStatus = view.findViewById(R.id.rvDriverStatus)
        rvRecentActivities = view.findViewById(R.id.rvRecentActivities)
        
        // Performance Metrics
        pbOnTimeDelivery = view.findViewById(R.id.pbOnTimeDelivery)
        pbCustomerSatisfaction = view.findViewById(R.id.pbCustomerSatisfaction)
        pbFuelEfficiency = view.findViewById(R.id.pbFuelEfficiency)
        
        // Quick Actions
        btnAddDriver = view.findViewById(R.id.btnAddDriver)
        btnNewShipment = view.findViewById(R.id.btnNewShipment)
        btnQuickReport = view.findViewById(R.id.btnQuickReport)
    }

    private fun setupClickListeners() {
        ivMenu.setOnClickListener {
            toggleDrawer()
        }
        
        ivNotifications.setOnClickListener {
            openNotifications()
        }
        
        btnAddDriver.setOnClickListener {
            navigateToAddDriver()
        }
        
        btnNewShipment.setOnClickListener {
            navigateToNewShipment()
        }
        
        btnQuickReport.setOnClickListener {
            navigateToQuickReport()
        }
    }

    private fun setupRecyclerViews() {
        // Driver Status RecyclerView
        driverStatusAdapter = DriverStatusAdapter(getSampleDriverStatus())
        rvDriverStatus.layoutManager = LinearLayoutManager(requireContext())
        rvDriverStatus.adapter = driverStatusAdapter
        
        // Recent Activities RecyclerView
        recentActivitiesAdapter = RecentActivitiesAdapter(getSampleActivities())
        rvRecentActivities.layoutManager = LinearLayoutManager(requireContext())
        rvRecentActivities.adapter = recentActivitiesAdapter
    }

    private fun setupSidebarMenu() {
        val menuItems = getSidebarMenuItems()
        sidebarMenuAdapter = SidebarMenuAdapter(menuItems) { position ->
            handleSidebarItemClick(position)
        }
        
        val rvSidebarMenu = navigationView.findViewById<RecyclerView>(R.id.rvSidebarMenu)
        rvSidebarMenu.layoutManager = LinearLayoutManager(requireContext())
        rvSidebarMenu.adapter = sidebarMenuAdapter
    }

    private fun animateCounters() {
        animateCounter(tvActiveDrivers, 45)
        animateCounter(tvCompletedTasks, 127)
        animateCounter(tvPendingTasks, 23, mirror = tvPendingTasksAlt)
        animateCounter(tvTeamEfficiency, 92, "%", tvTeamEfficiencyAlt)
    }

    private fun animateProgressBars() {
        animateProgressBar(pbOnTimeDelivery, 94)
        animateProgressBar(pbCustomerSatisfaction, 96)
        animateProgressBar(pbFuelEfficiency, 87)
    }

    private fun animateCounter(
        textView: TextView,
        targetValue: Int,
        suffix: String = "",
        mirror: TextView? = null,
    ) {
        val handler = Handler(Looper.getMainLooper())
        var currentValue = 0
        val increment = Math.max(1, targetValue / 30)
        val delay = 30L

        val runnable = object : Runnable {
            override fun run() {
                if (currentValue < targetValue) {
                    currentValue = Math.min(currentValue + increment, targetValue)
                    val text = "$currentValue$suffix"
                    textView.text = text
                    mirror?.text = text
                    handler.postDelayed(this, delay)
                } else {
                    val text = "$targetValue$suffix"
                    textView.text = text
                    mirror?.text = text
                }
            }
        }
        handler.post(runnable)
    }

    private fun animateProgressBar(progressBar: ProgressBar, targetProgress: Int) {
        val animator = ObjectAnimator.ofInt(progressBar, "progress", 0, targetProgress)
        animator.duration = 1500
        animator.interpolator = AccelerateDecelerateInterpolator()
        animator.start()
    }

    private fun toggleDrawer() {
        if (drawerLayout.isDrawerOpen(navigationView)) {
            drawerLayout.closeDrawer(navigationView)
        } else {
            drawerLayout.openDrawer(navigationView)
        }
    }

    private fun openNotifications() {
        navigationController.navigateToNotifications()
    }

    private fun navigateToAddDriver() {
        navigationController.navigateToAddDriver()
    }

    private fun navigateToNewShipment() {
        navigationController.navigateToNewShipment()
    }

    private fun navigateToQuickReport() {
        navigationController.navigateToQuickReport()
    }

    private fun handleSidebarItemClick(position: Int) {
        val menuItem = getSidebarMenuItems()[position]
        
        when (menuItem.title) {
            "لوحة المشرف" -> {
                // Already on dashboard
                navigationController.clearBackStack()
                drawerLayout.closeDrawer(navigationView)
            }
            "إدارة السائقين" -> {
                navigationController.navigateToMenuItem("drivers")
            }
            "مراقبة الشحنات" -> {
                navigationController.navigateToMenuItem("shipments")
            }
            "توزيع المهام" -> {
                navigationController.navigateToMenuItem("tasks")
            }
            "تحليل الأداء" -> {
                navigationController.navigateToAnalytics()
            }
            "التنبيهات" -> {
                navigationController.navigateToMenuItem("notifications")
            }
            "التقارير" -> {
                navigationController.navigateToMenuItem("reports")
            }
            "الإعدادات" -> {
                navigationController.navigateToMenuItem("settings")
            }
            "المخزون" -> {
                navigationController.navigateToMenuItem("inventory")
            }
            "المدفوعات" -> {
                navigationController.navigateToMenuItem("payments")
            }
            "دعم العملاء" -> {
                navigationController.navigateToMenuItem("support")
            }
            "الأمان والخصوصية" -> {
                navigationController.navigateToMenuItem("security")
            }
        }
        
        drawerLayout.closeDrawer(navigationView)
    }

    private fun loadDriverStatus() {
        // Load driver status data
        // TODO: Implement actual data loading
    }

    private fun loadRecentActivities() {
        // Load recent activities data
        // TODO: Implement actual data loading
    }

    // Sample Data Methods
