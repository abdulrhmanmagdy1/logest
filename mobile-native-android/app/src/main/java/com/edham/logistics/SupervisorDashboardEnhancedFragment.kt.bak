        return listOf(
            DriverStatus("أحمد محمد", "نشط", "سيارة #1234", "متاح"),
            DriverStatus("محمد علي", "في مهمة", "سيارة #5678", "توصيل"),
            DriverStatus("عبدالله سالم", "نشط", "سيارة #9012", "متاح"),
            DriverStatus("سالم خالد", "في مهمة", "سيارة #3456", "توصيل"),
            DriverStatus("خالد أحمد", "متوقف", "سيارة #7890", "صيانة")
        )
    }

    private fun getSampleActivities(): List<RecentActivity> {
        return listOf(
            RecentActivity("تسليم شحنة #1234", "تم التسليم بنجاح", "10 دقائق مضت", "success"),
            RecentActivity("مهمة جديدة", "تم تعيين مهمة جديدة للسائق أحمد", "15 دقيقة مضت", "info"),
            RecentActivity("تنبيه درجة حرارة", "انتهاك عتبة التبريد للشحنة #5678", "30 دقيقة مضت", "warning"),
            RecentActivity("تأخير شحنة", "تأخير متوقع للشحنة #9012", "45 دقيقة مضت", "error"),
            RecentActivity("صيانة مركبة", "بدء صيانة للسيارة #3456", "ساعة مضت", "info")
        )
    }

    private fun getSidebarMenuItems(): List<SidebarMenuItem> {
        return listOf(
            SidebarMenuItem("لوحة المشرف", R.drawable.ic_dashboard, "الرئيسية"),
            SidebarMenuItem("إدارة السائقين", R.drawable.ic_people, "إدارة السائقين"),
            SidebarMenuItem("مراقبة الشحنات", R.drawable.ic_local_shipping, "مراقبة الشحنات"),
            SidebarMenuItem("توزيع المهام", R.drawable.ic_assignment, "توزيع المهام"),
            SidebarMenuItem("تحليل الأداء", R.drawable.ic_analytics, "تحليل الأداء"),
            SidebarMenuItem("التنبيهات", R.drawable.ic_warning, "التنبيهات"),
            SidebarMenuItem("التقارير", R.drawable.ic_report, "التقارير"),
            SidebarMenuItem("الإعدادات", R.drawable.ic_settings, "الإعدادات"),
            SidebarMenuItem("المخزون", R.drawable.ic_inventory, "المخزون"),
            SidebarMenuItem("المدفوعات", R.drawable.ic_payment, "المدفوعات"),
            SidebarMenuItem("دعم العملاء", R.drawable.ic_support, "دعم العملاء"),
            SidebarMenuItem("الأمان والخصوصية", R.drawable.ic_security, "الأمان والخصوصية")
        )
    }
}

// Data Classes
data class DriverStatus(
    val name: String,
    val status: String,
    val vehicle: String,
    val currentTask: String
)

data class RecentActivity(
    val title: String,
    val description: String,
    val time: String,
    val type: String
)

data class SidebarMenuItem(
    val title: String,
    val icon: Int,
    val description: String
)
