package com.edham.logistics.feature.driver.presentation.ui

import androidx.lifecycle.viewModelScope
import com.edham.logistics.core.utils.Result
import com.edham.logistics.feature.driver.domain.usecase.UpdateTripStatusUseCase
import com.edham.logistics.feature.driver.domain.model.*
import com.edham.logistics.presentation.ui.base.BaseViewModel
import dagger.hilt.android.lifecycle.HiltViewModel
import kotlinx.coroutines.flow.MutableStateFlow
import kotlinx.coroutines.flow.StateFlow
import kotlinx.coroutines.flow.asStateFlow
import kotlinx.coroutines.launch
import javax.inject.Inject

@HiltViewModel
class NavigationViewModel @Inject constructor(
    private val updateTripStatusUseCase: UpdateTripStatusUseCase
) : BaseViewModel<NavigationViewModel.NavigationUiState>() {

    private val _uiState = MutableStateFlow(NavigationUiState())
    val uiState: StateFlow<NavigationUiState> = _uiState.asStateFlow()

    override fun createInitialState(): NavigationUiState = NavigationUiState()

    private var currentTripId: String = ""

    fun initialize(tripId: String) {
        this.currentTripId = tripId
        loadMockTripData()
    }

    private fun loadMockTripData() {
        val mockTrip = DriverTrip(
            id = currentTripId,
            trackingNumber = "EDHAM-2024-001",
            customerName = "محمد أحمد",
            customerPhone = "+966501234567",
            pickupLocation = LocationPoint(
                latitude = 24.7136,
                longitude = 46.6753,
                address = "الرياض، شارع الملك، بناية 123",
                city = "الرياض",
                timestamp = null
            ),
            deliveryLocation = LocationPoint(
                latitude = 21.4225,
                longitude = 39.8262,
                address = "جدة، شارع الأمير، بناية 456",
                city = "جدة",
                timestamp = null
            ),
            cargoType = "general",
            weight = 15.5,
            priority = "normal",
            specialInstructions = null,
            estimatedDuration = 180,
            estimatedDistance = 950.0,
            price = 250.0,
            status = TripStatus.IN_TRANSIT,
            assignedAt = "2024-01-18T08:00:00Z",
            acceptedAt = "2024-01-18T08:30:00Z",
            startedAt = "2024-01-18T09:00:00Z",
            completedAt = null,
            deliveryProof = null,
            currentLocation = LocationPoint(
                latitude = 24.7136,
                longitude = 46.6753,
                address = "الرياض، شارع الملك",
                city = "الرياض",
                timestamp = "2024-01-18T09:30:00Z"
            ),
            route = createMockRoute()
        )
        
        updateUiState { copy(trip = mockTrip) }
    }

    private fun createMockRoute(): RouteInfo {
        return RouteInfo(
            distance = 950.0,
            duration = 180,
            steps = listOf(
                RouteStep(
                    instruction = "اتجاه شمال على شارع الملك",
                    distance = 2.5,
                    duration = 8,
                    startLocation = LocationPoint(
                        latitude = 24.7136,
                        longitude = 46.6753,
                        address = "الرياض، شارع الملك",
                        city = "الرياض",
                        timestamp = null
                    ),
                    endLocation = LocationPoint(
                        latitude = 24.7250,
                        longitude = 46.6800,
                        address = "الرياض، تقاطع شارع الأمير",
                        city = "الرياض",
                        timestamp = null
                    )
                ),
                RouteStep(
                    instruction = "انعطاف يمين على طريق الملك فهد",
                    distance = 15.0,
                    duration = 12,
                    startLocation = LocationPoint(
                        latitude = 24.7250,
                        longitude = 46.6800,
                        address = "الرياض، تقاطع شارع الأمير",
                        city = "الرياض",
                        timestamp = null
                    ),
                    endLocation = LocationPoint(
                        latitude = 24.7400,
                        longitude = 46.7200,
                        address = "الرياض، طريق الملك فهد",
                        city = "الرياض",
                        timestamp = null
                    )
                ),
                RouteStep(
                    instruction = "استمر على طريق الملك فهد لمسافة 850 كم",
                    distance = 850.0,
                    duration = 120,
                    startLocation = LocationPoint(
                        latitude = 24.7400,
                        longitude = 46.7200,
                        address = "الرياض، طريق الملك فهد",
                        city = "الرياض",
                        timestamp = null
                    ),
                    endLocation = LocationPoint(
                        latitude = 21.4500,
                        longitude = 39.8000,
                        address = "جدة، مدخل المدينة",
                        city = "جدة",
                        timestamp = null
                    )
                ),
                RouteStep(
                    instruction = "انعطاف يسار إلى شارع الأمير",
                    distance = 5.0,
                    duration = 15,
                    startLocation = LocationPoint(
                        latitude = 21.4500,
                        longitude = 39.8000,
                        address = "جدة، مدخل المدينة",
                        city = "جدة",
                        timestamp = null
                    ),
                    endLocation = LocationPoint(
                        latitude = 21.4225,
                        longitude = 39.8262,
                        address = "جدة، شارع الأمير، بناية 456",
                        city = "جدة",
                        timestamp = null
                    )
                )
            )
        )
    }

    fun updateCurrentLocation(location: LocationPoint) {
        updateUiState { state ->
            state.trip?.let { trip ->
                copy(trip = trip.copy(currentLocation = location))
            } ?: state
        }
    }

    fun markArrived() {
        val currentLocation = _uiState.value.trip?.currentLocation
        if (currentLocation != null) {
            viewModelScope.launch {
                when (val result = updateTripStatusUseCase(
                    currentTripId, TripStatus.ARRIVED, currentLocation, "وصلت إلى موقع التسليم"
                )) {
                    is Result.Success -> {
                        updateUiState { copy(
                            actionSuccess = "تم تحديث الحالة: وصلت",
                            error = null
                        )}
                        // Update local trip status
                        updateUiState { state ->
                            state.trip?.let { trip ->
                                copy(trip = trip.copy(status = TripStatus.ARRIVED))
                            } ?: state
                        }
                    }
                    is Result.Error -> {
                        updateUiState { copy(error = result.exception.message ?: "فشل تحديث الحالة") }
                    }
                    is Result.Loading -> {
                        updateUiState { copy(isLoading = true) }
                    }
                }
            }
        }
    }

    fun clearError() {
        updateUiState { copy(error = null) }
    }

    fun clearSuccess() {
        updateUiState { copy(actionSuccess = null) }
    }

    fun refreshRoute() {
        // In real app, this would fetch updated route from API
        loadMockTripData()
    }

    data class NavigationUiState(
        val isLoading: Boolean = false,
        val trip: DriverTrip? = null,
        val error: String? = null,
        val actionSuccess: String? = null
    ) : com.edham.logistics.presentation.ui.base.UiState {
        override fun copyLoading(isLoading: Boolean): UiState = copy(isLoading = isLoading)
        override fun copyError(error: String?): UiState = copy(error = error)
        override fun copySuccess(message: String?): UiState = copy(actionSuccess = message)
    }
}
