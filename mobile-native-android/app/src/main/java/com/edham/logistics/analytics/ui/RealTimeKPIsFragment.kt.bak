package com.edham.logistics.analytics.ui

import android.os.Bundle
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import androidx.compose.foundation.layout.*
import androidx.compose.foundation.lazy.LazyColumn
import androidx.compose.foundation.lazy.LazyRow
import androidx.compose.foundation.lazy.items
import androidx.compose.foundation.shape.RoundedCornerShape
import androidx.compose.material3.*
import androidx.compose.runtime.*
import androidx.compose.ui.Alignment
import androidx.compose.ui.Modifier
import androidx.compose.ui.draw.clip
import androidx.compose.ui.graphics.Color
import androidx.compose.ui.text.font.FontWeight
import androidx.compose.ui.text.style.TextAlign
import androidx.compose.ui.unit.dp
import androidx.compose.ui.unit.sp
import androidx.fragment.app.Fragment
import androidx.fragment.app.viewModels
import androidx.lifecycle.compose.collectAsStateWithLifecycle
import com.edham.logistics.analytics.AnalyticsEngineService
import com.edham.logistics.analytics.CurrentKPIs
import com.edham.logistics.ui.theme.*
import dagger.hilt.android.AndroidEntryPoint
import kotlinx.coroutines.launch
import javax.inject.Inject

/**
 * Real-Time KPIs Fragment - Live KPI dashboard with real-time updates
 * 
 * Features:
 * - Real-time KPI cards
 * - Live indicators
 * - Performance metrics
 * - Trend indicators
 * - Alert notifications
 * - Auto-refresh functionality
 */
@AndroidEntryPoint
class RealTimeKPIsFragment : Fragment() {
    
    @Inject
    lateinit var analyticsEngineService: AnalyticsEngineService
    
    private val viewModel: RealTimeKPIsViewModel by viewModels()
    
    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View {
        return ComposeView(requireContext()).apply {
            setContent {
                EdhamLogisticsTheme {
                    RealTimeKPIsScreen(
                        viewModel = viewModel,
                        analyticsEngineService = analyticsEngineService
                    )
                }
            }
        }
    }
    
    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        
        // Initialize analytics engine
        lifecycleScope.launch {
            analyticsEngineService.initialize()
        }
        
        // Start real-time KPI updates
        viewModel.startRealTimeUpdates()
    }
    
    override fun onDestroyView() {
        super.onDestroyView()
        viewModel.stopRealTimeUpdates()
    }
}

@Composable
fun RealTimeKPIsScreen(
    viewModel: RealTimeKPIsViewModel,
    analyticsEngineService: AnalyticsEngineService
) {
    val currentKPIs by viewModel.currentKPIs.collectAsStateWithLifecycle()
    val isLoading by viewModel.isLoading.collectAsStateWithLifecycle()
    val errorMessage by viewModel.errorMessage.collectAsStateWithLifecycle()
    
    LaunchedEffect(Unit) {
        viewModel.loadCurrentKPIs()
    }
    
    Column(
        modifier = Modifier
            .fillMaxSize()
            .padding(16.dp),
        verticalArrangement = Arrangement.spacedBy(16.dp)
    ) {
        // Header
        Row(
            modifier = Modifier.fillMaxWidth(),
            horizontalArrangement = Arrangement.SpaceBetween,
            verticalAlignment = Alignment.CenterVertically
        ) {
            Text(
                text = "Real-Time KPIs",
                style = MaterialTheme.typography.headlineMedium,
                color = EdhamOrange,
                fontWeight = FontWeight.Bold
            )
            
            // Refresh indicator
            if (isLoading) {
                CircularProgressIndicator(
                    modifier = Modifier.size(24.dp),
                    color = EdhamOrange,
                    strokeWidth = 2.dp
                )
            } else {
                IconButton(
                    onClick = { viewModel.refreshKPIs() }
                ) {
                    Icon(
                        painter = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_rotate),
                        contentDescription = "Refresh",
                        tint = EdhamOrange
                    )
                }
            }
        }
        
        // Error message
        errorMessage?.let { error ->
            Card(
                modifier = Modifier.fillMaxWidth(),
                colors = CardDefaults.cardColors(
                    containerColor = ErrorRed.copy(alpha = 0.1f)
                ),
                elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
            ) {
                Text(
                    text = error,
                    modifier = Modifier.padding(16.dp),
                    color = ErrorRed,
                    style = MaterialTheme.typography.bodyMedium
                )
            }
        }
        
        // KPI Cards Grid
        LazyColumn(
            modifier = Modifier.fillMaxWidth(),
            verticalArrangement = Arrangement.spacedBy(16.dp)
        ) {
            // Shipments KPIs
            item {
                KPIsSection(
                    title = "Shipments",
                    kpis = listOf(
                        KPIData(
                            title = "Active Shipments",
                            value = currentKPIs.activeShipments.toString(),
                            change = calculateChange(currentKPIs.activeShipments, 0),
                            icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_send),
                            color = EdhamOrange
                        ),
                        KPIData(
                            title = "On-Time Delivery Rate",
                            value = "${String.format("%.1f", currentKPIs.onTimeDeliveryRate)}%",
                            change = calculateChange(currentKPIs.onTimeDeliveryRate, 0f),
                            icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_recent_history),
                            color = SuccessGreen
                        )
                    )
                )
            }
            
            // Fleet KPIs
            item {
                KPIsSection(
                    title = "Fleet",
                    kpis = listOf(
                        KPIData(
                            title = "Total Vehicles",
                            value = currentKPIs.totalVehicles.toString(),
                            change = calculateChange(currentKPIs.totalVehicles, 0),
                            icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_camera),
                            color = IceBlue
                        ),
                        KPIData(
                            title = "Active Drivers",
                            value = currentKPIs.activeDrivers.toString(),
                            change = calculateChange(currentKPIs.activeDrivers, 0),
                            icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_myplaces),
                            color = IceBlue
                        ),
                        KPIData(
                            title = "Fuel Efficiency",
                            value = "${String.format("%.1f", currentKPIs.fuelEfficiency)} km/L",
                            change = calculateChange(currentKPIs.fuelEfficiency, 0f),
                            icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_save),
                            color = WarningYellow
                        )
                    )
                )
            }
            
            // Financial KPIs
            item {
                KPIsSection(
                    title = "Financial",
                    kpis = listOf(
                        KPIData(
                            title = "Today's Revenue",
                            value = "SAR ${String.format("%,.2f", currentKPIs.todayRevenue)}",
                            change = calculateChange(currentKPIs.todayRevenue, 0.0),
                            icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_more),
                            color = SuccessGreen
                        ),
                        KPIData(
                            title = "Today's Expenses",
                            value = "SAR ${String.format("%,.2f", currentKPIs.todayExpenses)}",
                            change = calculateChange(currentKPIs.todayExpenses, 0.0),
                            icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_info_details),
                            color = ErrorRed
                        ),
                        KPIData(
                            title = "Net Profit",
                            value = "SAR ${String.format("%,.2f", currentKPIs.netProfit)}",
                            change = calculateChange(currentKPIs.netProfit, 0.0),
                            icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_preferences),
                            color = if (currentKPIs.netProfit >= 0) SuccessGreen else ErrorRed
                        )
                    )
                )
            }
            
            // Operations KPIs
            item {
                KPIsSection(
                    title = "Operations",
                    kpis = listOf(
                        KPIData(
                            title = "Average Temperature",
                            value = "${String.format("%.1f", currentKPIs.averageTemperature)}°C",
                            change = calculateChange(currentKPIs.averageTemperature, 0f),
                            icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_view),
                            color = IceBlue
                        ),
                        KPIData(
                            title = "Active Alerts",
                            value = currentKPIs.activeAlerts.toString(),
                            change = calculateChange(currentKPIs.activeAlerts, 0),
                            icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_help),
                            color = if (currentKPIs.activeAlerts > 0) ErrorRed else SuccessGreen
                        ),
                        KPIData(
                            title = "System Uptime",
                            value = "${String.format("%.1f", currentKPIs.systemUptime)}%",
                            change = calculateChange(currentKPIs.systemUptime, 0.0),
                            icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_manage),
                            color = SuccessGreen
                        )
                    )
                )
            }
            
            // Last Updated
            item {
                Card(
                    modifier = Modifier.fillMaxWidth(),
                    colors = CardDefaults.cardColors(
                        containerColor = MaterialTheme.colorScheme.surfaceVariant
                    ),
                    elevation = CardDefaults.cardElevation(defaultElevation = 1.dp)
                ) {
                    Row(
                        modifier = Modifier
                            .fillMaxWidth()
                            .padding(16.dp),
                        horizontalArrangement = Arrangement.SpaceBetween,
                        verticalAlignment = Alignment.CenterVertically
                    ) {
                        Text(
                            text = "Last Updated",
                            style = MaterialTheme.typography.bodyMedium,
                            color = MaterialTheme.colorScheme.onSurfaceVariant
                        )
                        
                        Text(
                            text = formatDateTime(currentKPIs.lastUpdated),
                            style = MaterialTheme.typography.bodyMedium,
                            fontWeight = FontWeight.Medium,
                            color = MaterialTheme.colorScheme.onSurfaceVariant
                        )
                    }
                }
            }
        }
    }
}

@Composable
fun KPIsSection(
    title: String,
    kpis: List<KPIData>
) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.surface
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Text(
                text = title,
                style = MaterialTheme.typography.titleMedium,
                color = EdhamOrange,
                fontWeight = FontWeight.Bold
            )
            
            Spacer(modifier = Modifier.height(16.dp))
            
            LazyRow(
                horizontalArrangement = Arrangement.spacedBy(16.dp)
            ) {
                items(kpis) { kpi ->
                    KPICard(kpi = kpi)
                }
            }
        }
    }
}

@Composable
fun KPICard(kpi: KPIData) {
    Card(
        modifier = Modifier
            .width(200.dp)
            .height(120.dp),
        colors = CardDefaults.cardColors(
            containerColor = kpi.color.copy(alpha = 0.1f)
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 1.dp)
    ) {
        Column(
            modifier = Modifier
                .fillMaxSize()
                .padding(12.dp),
            verticalArrangement = Arrangement.SpaceBetween
        ) {
            Row(
                verticalAlignment = Alignment.CenterVertically
            ) {
                Icon(
                    painter = kpi.icon,
                    contentDescription = null,
                    tint = kpi.color,
                    modifier = Modifier.size(24.dp)
                )
                
                Spacer(modifier = Modifier.width(8.dp))
                
                Text(
                    text = kpi.title,
                    style = MaterialTheme.typography.bodySmall,
                    color = MaterialTheme.colorScheme.onSurface.copy(alpha = 0.7f),
                    maxLines = 1
                )
            }
            
            Column {
                Text(
                    text = kpi.value,
                    style = MaterialTheme.typography.titleLarge,
                    color = kpi.color,
                    fontWeight = FontWeight.Bold,
                    maxLines = 1
                )
                
                Spacer(modifier = Modifier.height(4.dp))
                
                // Change indicator
                if (kpi.change != 0.0) {
                    Row(
                        verticalAlignment = Alignment.CenterVertically
                    ) {
                        Icon(
                            painter = androidx.compose.ui.res.painterResource(
                                id = if (kpi.change > 0) android.R.drawable.arrow_up_float 
                                else android.R.drawable.arrow_down_float
                            ),
                            contentDescription = null,
                            tint = if (kpi.change > 0) SuccessGreen else ErrorRed,
                            modifier = Modifier.size(16.dp)
                        )
                        
                        Spacer(modifier = Modifier.width(4.dp))
                        
                        Text(
                            text = "${String.format("%.1f", kotlin.math.abs(kpi.change))}%",
                            style = MaterialTheme.typography.bodySmall,
                            color = if (kpi.change > 0) SuccessGreen else ErrorRed,
                            fontWeight = FontWeight.Medium
                        )
                    }
                }
            }
        }
    }
}

// Data classes
data class KPIData(
    val title: String,
    val value: String,
    val change: Double,
    val icon: androidx.compose.ui.graphics.painter.Painter,
    val color: Color
)

// Helper functions
private fun calculateChange(current: Int, previous: Int): Double {
    return if (previous == 0) 0.0 else ((current - previous).toDouble() / previous) * 100
}

private fun calculateChange(current: Float, previous: Float): Double {
    return if (previous == 0f) 0.0 else ((current - previous).toDouble() / previous) * 100
}

private fun calculateChange(current: Double, previous: Double): Double {
    return if (previous == 0.0) 0.0 else ((current - previous) / previous) * 100
}

private fun formatDateTime(date: Date): String {
    val format = java.text.SimpleDateFormat("MMM dd, HH:mm", Locale.getDefault())
    return format.format(date)
}
