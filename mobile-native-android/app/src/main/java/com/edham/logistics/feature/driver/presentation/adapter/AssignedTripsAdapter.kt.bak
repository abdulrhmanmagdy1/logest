package com.edham.logistics.feature.driver.presentation.adapter

import android.view.LayoutInflater
import android.view.ViewGroup
import androidx.recyclerview.widget.DiffUtil
import androidx.recyclerview.widget.ListAdapter
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.databinding.ItemAssignedTripBinding
import com.edham.logistics.feature.driver.domain.model.DriverTrip
import javax.inject.Inject

class AssignedTripsAdapter @Inject constructor(
    private val onTripAction: (DriverTrip, String) -> Unit
) : ListAdapter<DriverTrip, AssignedTripsAdapter.AssignedTripViewHolder>(AssignedTripDiffCallback()) {

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): AssignedTripViewHolder {
        val binding = ItemAssignedTripBinding.inflate(
            LayoutInflater.from(parent.context),
            parent,
            false
        )
        return AssignedTripViewHolder(binding)
    }

    override fun onBindViewHolder(holder: AssignedTripViewHolder, position: Int) {
        holder.bind(getItem(position))
    }

    inner class AssignedTripViewHolder(
        private val binding: ItemAssignedTripBinding
    ) : RecyclerView.ViewHolder(binding.root) {

        fun bind(trip: DriverTrip) {
            binding.apply {
                textTrackingNumber.text = trip.trackingNumber
                textCustomerName.text = trip.customerName
                textCustomerPhone.text = trip.customerPhone
                textPickupLocation.text = trip.pickupLocation.address
                textDeliveryLocation.text = trip.deliveryLocation.address
                textCargoType.text = formatCargoType(trip.cargoType)
                textWeight.text = "${trip.weight} كجم"
                textPrice.text = formatPrice(trip.price)
                textStatus.text = formatTripStatus(trip.status)
                
                // Set status color
                textStatus.setTextColor(getTripStatusColor(trip.status))
                
                // Show action buttons based on status
                when (trip.status) {
                    com.edham.logistics.feature.driver.domain.model.TripStatus.ASSIGNED -> {
                        buttonAccept.visible()
                        buttonReject.visible()
                        buttonStart.gone()
                        buttonNavigation.gone()
                    }
                    com.edham.logistics.feature.driver.domain.model.TripStatus.ACCEPTED -> {
                        buttonAccept.gone()
                        buttonReject.gone()
                        buttonStart.visible()
                        buttonNavigation.gone()
                    }
                    com.edham.logistics.feature.driver.domain.model.TripStatus.STARTED,
                    com.edham.logistics.feature.driver.domain.model.TripStatus.IN_TRANSIT -> {
                        buttonAccept.gone()
                        buttonReject.gone()
                        buttonStart.gone()
                        buttonNavigation.visible()
                    }
                    else -> {
                        buttonAccept.gone()
                        buttonReject.gone()
                        buttonStart.gone()
                        buttonNavigation.gone()
                    }
                }
                
                // Set click listeners
                buttonAccept.setOnClickListener {
                    onTripAction(trip, "accept")
                }
                
                buttonReject.setOnClickListener {
                    onTripAction(trip, "reject")
                }
                
                buttonStart.setOnClickListener {
                    onTripAction(trip, "start")
                }
                
                buttonNavigation.setOnClickListener {
                    onTripAction(trip, "navigation")
                }
                
                root.setOnClickListener {
                    onTripAction(trip, "details")
                }
                
                // Show special instructions if available
                if (trip.specialInstructions?.isNotBlank() == true) {
                    textSpecialInstructions.text = trip.specialInstructions
                    textSpecialInstructions.visible()
                } else {
                    textSpecialInstructions.gone()
                }
                
                // Show priority badge
                textPriority.text = formatPriority(trip.priority)
                textPriority.setBackgroundColor(getPriorityColor(trip.priority))
            }
        }
        
        private fun formatCargoType(cargoType: String): String {
            return when (cargoType) {
                "general" -> "بضائع عامة"
                "refrigerated" -> "بضائع مبردة"
                "fragile" -> "بضائع قابلة للكسر"
                "heavy" -> "بضائع ثقيلة"
                "urgent" -> "بضائع عاجلة"
                "documents" -> "مستندات"
                "electronics" -> "إلكترونيات"
                "food" -> "مواد غذائية"
                "medical" -> "معدات طبية"
                "chemicals" -> "مواد كيميائية"
                "livestock" -> "مواشي"
                "vehicles" -> "مركبات"
                else -> cargoType
            }
        }
        
        private fun formatTripStatus(status: com.edham.logistics.feature.driver.domain.model.TripStatus): String {
            return when (status) {
                com.edham.logistics.feature.driver.domain.model.TripStatus.ASSIGNED -> "مخصص"
                com.edham.logistics.feature.driver.domain.model.TripStatus.ACCEPTED -> "مقبول"
                com.edham.logistics.feature.driver.domain.model.TripStatus.REJECTED -> "مرفوض"
                com.edham.logistics.feature.driver.domain.model.TripStatus.STARTED -> "بدأت"
                com.edham.logistics.feature.driver.domain.model.TripStatus.IN_TRANSIT -> "قيد النقل"
                com.edham.logistics.feature.driver.domain.model.TripStatus.ARRIVED -> "وصلت"
                com.edham.logistics.feature.driver.domain.model.TripStatus.DELIVERED -> "تم التسليم"
                com.edham.logistics.feature.driver.domain.model.TripStatus.CANCELLED -> "ملغية"
            }
        }
        
        private fun formatPriority(priority: String): String {
            return when (priority) {
                "normal" -> "عادي"
                "express" -> "سريع"
                "urgent" -> "عاجل"
                "economy" -> "اقتصادي"
                else -> priority
            }
        }
        
        private fun formatPrice(price: Double): String {
            return String.format("%.2f ريال", price)
        }
        
        private fun getTripStatusColor(status: com.edham.logistics.feature.driver.domain.model.TripStatus): Int {
            return when (status) {
                com.edham.logistics.feature.driver.domain.model.TripStatus.ASSIGNED -> android.graphics.Color.parseColor("#FF9800")
                com.edham.logistics.feature.driver.domain.model.TripStatus.ACCEPTED -> android.graphics.Color.parseColor("#2196F3")
                com.edham.logistics.feature.driver.domain.model.TripStatus.REJECTED -> android.graphics.Color.parseColor("#F44336")
                com.edham.logistics.feature.driver.domain.model.TripStatus.STARTED -> android.graphics.Color.parseColor("#4CAF50")
                com.edham.logistics.feature.driver.domain.model.TripStatus.IN_TRANSIT -> android.graphics.Color.parseColor("#2196F3")
                com.edham.logistics.feature.driver.domain.model.TripStatus.ARRIVED -> android.graphics.Color.parseColor("#9C27B0")
                com.edham.logistics.feature.driver.domain.model.TripStatus.DELIVERED -> android.graphics.Color.parseColor("#4CAF50")
                com.edham.logistics.feature.driver.domain.model.TripStatus.CANCELLED -> android.graphics.Color.parseColor("#F44336")
            }
        }
        
        private fun getPriorityColor(priority: String): Int {
            return when (priority) {
                "normal" -> android.graphics.Color.parseColor("#9E9E9E")
                "express" -> android.graphics.Color.parseColor("#2196F3")
                "urgent" -> android.graphics.Color.parseColor("#F44336")
                "economy" -> android.graphics.Color.parseColor("#4CAF50")
                else -> android.graphics.Color.parseColor("#9E9E9E")
            }
        }
    }

    private class AssignedTripDiffCallback : DiffUtil.ItemCallback<DriverTrip>() {
        override fun areItemsTheSame(oldItem: DriverTrip, newItem: DriverTrip): Boolean {
            return oldItem.id == newItem.id
        }

        override fun areContentsTheSame(oldItem: DriverTrip, newItem: DriverTrip): Boolean {
            return oldItem == newItem
        }
    }
}
