package com.edham.logistics.feature.coldchain.presentation.adapter

import android.view.LayoutInflater
import android.view.ViewGroup
import androidx.recyclerview.widget.DiffUtil
import androidx.recyclerview.widget.ListAdapter
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.databinding.ItemColdChainShipmentBinding
import com.edham.logistics.feature.coldchain.domain.model.ColdChainShipment
import javax.inject.Inject

class ColdChainShipmentsAdapter @Inject constructor(
    private val onShipmentAction: (ColdChainShipment, String) -> Unit
) : ListAdapter<ColdChainShipment, ColdChainShipmentsAdapter.ShipmentViewHolder>(ShipmentDiffCallback()) {

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): ShipmentViewHolder {
        val binding = ItemColdChainShipmentBinding.inflate(
            LayoutInflater.from(parent.context),
            parent,
            false
        )
        return ShipmentViewHolder(binding)
    }

    override fun onBindViewHolder(holder: ShipmentViewHolder, position: Int) {
        holder.bind(getItem(position))
    }

    inner class ShipmentViewHolder(
        private val binding: ItemColdChainShipmentBinding
    ) : RecyclerView.ViewHolder(binding.root) {

        fun bind(shipment: ColdChainShipment) {
            binding.apply {
                textShipmentId.text = shipment.id
                textCargoType.text = formatCargoType(shipment.cargoType)
                textCurrentTemperature.text = "${shipment.currentTemperature}°C"
                textCurrentHumidity.text = shipment.currentHumidity?.let { "${it}%" } ?: "N/A"
                textStatus.text = formatColdChainStatus(shipment.status)
                textComplianceRate.text = "${shipment.complianceRate.toInt()}%"
                textAlertCount.text = "${shipment.alertCount}"
                textLastUpdate.text = formatTimestamp(shipment.lastUpdate)
                
                // Set status color
                textStatus.setTextColor(getColdChainStatusColor(shipment.status))
                
                // Set temperature color based on status
                val temperatureColor = when (shipment.status) {
                    com.edham.logistics.feature.coldchain.domain.model.ColdChainStatus.NORMAL -> android.graphics.Color.parseColor("#4CAF50")
                    com.edham.logistics.feature.coldchain.domain.model.ColdChainStatus.WARNING -> android.graphics.Color.parseColor("#FF9800")
                    com.edham.logistics.feature.coldchain.domain.model.ColdChainStatus.CRITICAL -> android.graphics.Color.parseColor("#F44336")
                    else -> android.graphics.Color.parseColor("#9E9E9E")
                }
                textCurrentTemperature.setTextColor(temperatureColor)
                
                // Show sensor info
                textSensorModel.text = shipment.sensorInfo.model
                textSensorStatus.text = formatSensorStatus(shipment.sensorInfo.status)
                textSensorBattery.text = "${shipment.sensorInfo.batteryLevel.toInt()}%"
                
                // Show battery indicator
                progressBattery.progress = shipment.sensorInfo.batteryLevel.toInt()
                when {
                    shipment.sensorInfo.batteryLevel > 50 -> {
                        progressBattery.setIndicatorColor(android.graphics.Color.parseColor("#4CAF50"))
                    }
                    shipment.sensorInfo.batteryLevel > 20 -> {
                        progressBattery.setIndicatorColor(android.graphics.Color.parseColor("#FF9800"))
                    }
                    else -> {
                        progressBattery.setIndicatorColor(android.graphics.Color.parseColor("#F44336"))
                    }
                }
                
                // Show alert indicator
                if (shipment.alertCount > 0) {
                    layoutAlertIndicator.visible()
                    textAlertIndicator.text = "${shipment.alertCount}"
                    when (shipment.status) {
                        com.edham.logistics.feature.coldchain.domain.model.ColdChainStatus.WARNING -> {
                            layoutAlertIndicator.setBackgroundColor(android.graphics.Color.parseColor("#FF9800"))
                        }
                        com.edham.logistics.feature.coldchain.domain.model.ColdChainStatus.CRITICAL -> {
                            layoutAlertIndicator.setBackgroundColor(android.graphics.Color.parseColor("#F44336"))
                        }
                        else -> {
                            layoutAlertIndicator.setBackgroundColor(android.graphics.Color.parseColor("#2196F3"))
                        }
                    }
                } else {
                    layoutAlertIndicator.gone()
                }
                
                // Set click listeners
                root.setOnClickListener {
                    onShipmentAction(shipment, "select")
                }
                
                buttonDetails.setOnClickListener {
                    onShipmentAction(shipment, "details")
                }
                
                buttonAlerts.setOnClickListener {
                    onShipmentAction(shipment, "alerts")
                }
                
                buttonCalibrate.setOnClickListener {
                    onShipmentAction(shipment, "calibrate")
                }
                
                // Show/hide calibrate button based on sensor status
                buttonCalibrate.visibility = when (shipment.sensorInfo.status) {
                    com.edham.logistics.feature.coldchain.domain.model.SensorStatus.CALIBRATION_REQUIRED -> android.view.View.VISIBLE
                    else -> android.view.View.GONE
                }
            }
        }
        
        private fun formatCargoType(cargoType: com.edham.logistics.feature.coldchain.domain.model.CargoType): String {
            return when (cargoType) {
                com.edham.logistics.feature.coldchain.domain.model.CargoType.FOOD -> "مواد غذائية"
                com.edham.logistics.feature.coldchain.domain.model.CargoType.MEDICAL -> "مواد طبية"
                com.edham.logistics.feature.coldchain.domain.model.CargoType.FROZEN_GOODS -> "بضائع مجمدة"
                com.edham.logistics.feature.coldchain.domain.model.CargoType.PHARMACEUTICAL -> "أدوية"
                com.edham.logistics.feature.coldchain.domain.model.CargoType.DAIRY -> "منتجات ألبان"
                com.edham.logistics.feature.coldchain.domain.model.CargoType.MEAT -> "لحوم"
                com.edham.logistics.feature.coldchain.domain.model.CargoType.VEGETABLES -> "خضروات"
                com.edham.logistics.feature.coldchain.domain.model.CargoType.FRUITS -> "فواكه"
                else -> cargoType.name
            }
        }
        
        private fun formatColdChainStatus(status: com.edham.logistics.feature.coldchain.domain.model.ColdChainStatus): String {
            return when (status) {
                com.edham.logistics.feature.coldchain.domain.model.ColdChainStatus.NORMAL -> "طبيعي"
                com.edham.logistics.feature.coldchain.domain.model.ColdChainStatus.WARNING -> "تحذير"
                com.edham.logistics.feature.coldchain.domain.model.ColdChainStatus.CRITICAL -> "حرج"
                com.edham.logistics.feature.coldchain.domain.model.ColdChainStatus.OFFLINE -> "غير متصل"
                com.edham.logistics.feature.coldchain.domain.model.ColdChainStatus.MAINTENANCE -> "صيانة"
                com.edham.logistics.feature.coldchain.domain.model.ColdChainStatus.CALIBRATION_REQUIRED -> "تحتاج معايرة"
                com.edham.logistics.feature.coldchain.domain.model.ColdChainStatus.SENSOR_ERROR -> "خطأ في المستشعر"
            }
        }
        
        private fun formatSensorStatus(status: com.edham.logistics.feature.coldchain.domain.model.SensorStatus): String {
            return when (status) {
                com.edham.logistics.feature.coldchain.domain.model.SensorStatus.ONLINE -> "متصل"
                com.edham.logistics.feature.coldchain.domain.model.SensorStatus.OFFLINE -> "غير متصل"
                com.edham.logistics.feature.coldchain.domain.model.SensorStatus.LOW_BATTERY -> "بطارية منخفضة"
                com.edham.logistics.feature.coldchain.domain.model.SensorStatus.CALIBRATION_REQUIRED -> "تحتاج معايرة"
                com.edham.logistics.feature.coldchain.domain.model.SensorStatus.ERROR -> "خطأ"
                com.edham.logistics.feature.coldchain.domain.model.SensorStatus.MAINTENANCE -> "صيانة"
            }
        }
        
        private fun formatTimestamp(timestamp: Long): String {
            val now = System.currentTimeMillis()
            val diff = now - timestamp
            
            return when {
                diff < 60000 -> "الآن"
                diff < 3600000 -> "${diff / 60000} دقيقة"
                diff < 86400000 -> "${diff / 3600000} ساعة"
                else -> "${diff / 86400000} يوم"
            }
        }
        
        private fun getColdChainStatusColor(status: com.edham.logistics.feature.coldchain.domain.model.ColdChainStatus): Int {
            return when (status) {
                com.edham.logistics.feature.coldchain.domain.model.ColdChainStatus.NORMAL -> android.graphics.Color.parseColor("#4CAF50")
                com.edham.logistics.feature.coldchain.domain.model.ColdChainStatus.WARNING -> android.graphics.Color.parseColor("#FF9800")
                com.edham.logistics.feature.coldchain.domain.model.ColdChainStatus.CRITICAL -> android.graphics.Color.parseColor("#F44336")
                com.edham.logistics.feature.coldchain.domain.model.ColdChainStatus.OFFLINE -> android.graphics.Color.parseColor("#9E9E9E")
                com.edham.logistics.feature.coldchain.domain.model.ColdChainStatus.MAINTENANCE -> android.graphics.Color.parseColor("#2196F3")
                com.edham.logistics.feature.coldchain.domain.model.ColdChainStatus.CALIBRATION_REQUIRED -> android.graphics.Color.parseColor("#FF5722")
                com.edham.logistics.feature.coldchain.domain.model.ColdChainStatus.SENSOR_ERROR -> android.graphics.Color.parseColor("#F44336")
            }
        }
    }

    private class ShipmentDiffCallback : DiffUtil.ItemCallback<ColdChainShipment>() {
        override fun areItemsTheSame(oldItem: ColdChainShipment, newItem: ColdChainShipment): Boolean {
            return oldItem.id == newItem.id
        }

        override fun areContentsTheSame(oldItem: ColdChainShipment, newItem: ColdChainShipment): Boolean {
            return oldItem == newItem
        }
    }
}
