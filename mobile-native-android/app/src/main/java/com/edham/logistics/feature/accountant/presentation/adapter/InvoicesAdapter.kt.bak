package com.edham.logistics.feature.accountant.presentation.adapter

import android.view.LayoutInflater
import android.view.ViewGroup
import androidx.recyclerview.widget.DiffUtil
import androidx.recyclerview.widget.ListAdapter
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.databinding.ItemInvoiceBinding
import com.edham.logistics.feature.accountant.domain.model.Invoice
import javax.inject.Inject

class InvoicesAdapter @Inject constructor(
    private val onInvoiceAction: (Invoice, String) -> Unit
) : ListAdapter<Invoice, InvoicesAdapter.InvoiceViewHolder>(InvoiceDiffCallback()) {

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): InvoiceViewHolder {
        val binding = ItemInvoiceBinding.inflate(
            LayoutInflater.from(parent.context),
            parent,
            false
        )
        return InvoiceViewHolder(binding)
    }

    override fun onBindViewHolder(holder: InvoiceViewHolder, position: Int) {
        holder.bind(getItem(position))
    }

    inner class InvoiceViewHolder(
        private val binding: ItemInvoiceBinding
    ) : RecyclerView.ViewHolder(binding.root) {

        fun bind(invoice: Invoice) {
            binding.apply {
                textInvoiceNumber.text = invoice.invoiceNumber
                textCustomerName.text = invoice.customerName
                textCustomerPhone.text = invoice.customerPhone
                textTrackingNumber.text = invoice.trackingNumber
                textAmount.text = formatCurrency(invoice.totalAmount)
                textStatus.text = formatInvoiceStatus(invoice.status)
                textIssueDate.text = formatDate(invoice.issueDate)
                textDueDate.text = formatDate(invoice.dueDate)
                
                // Set status color
                textStatus.setTextColor(getInvoiceStatusColor(invoice.status))
                
                // Show tax amount if applicable
                if (invoice.taxAmount > 0) {
                    textTaxAmount.text = formatCurrency(invoice.taxAmount)
                    layoutTaxAmount.visible()
                } else {
                    layoutTaxAmount.gone()
                }
                
                // Show paid date if paid
                if (invoice.paidDate != null) {
                    textPaidDate.text = formatDate(invoice.paidDate)
                    layoutPaidDate.visible()
                } else {
                    layoutPaidDate.gone()
                }
                
                // Show payment method if paid
                if (invoice.paymentMethod != null) {
                    textPaymentMethod.text = formatPaymentMethod(invoice.paymentMethod)
                    layoutPaymentMethod.visible()
                } else {
                    layoutPaymentMethod.gone()
                }
                
                // Set click listeners
                buttonDetails.setOnClickListener {
                    onInvoiceAction(invoice, "details")
                }
                
                buttonEdit.setOnClickListener {
                    onInvoiceAction(invoice, "edit")
                }
                
                buttonPayment.setOnClickListener {
                    onInvoiceAction(invoice, "payment")
                }
                
                root.setOnClickListener {
                    onInvoiceAction(invoice, "details")
                }
                
                // Show/hide action buttons based on status
                buttonEdit.visibility = when (invoice.status) {
                    com.edham.logistics.feature.accountant.domain.model.InvoiceStatus.DRAFT,
                    com.edham.logistics.feature.accountant.domain.model.InvoiceStatus.ISSUED -> android.view.View.VISIBLE
                    else -> android.view.View.GONE
                }
                
                buttonPayment.visibility = when (invoice.status) {
                    com.edham.logistics.feature.accountant.domain.model.InvoiceStatus.ISSUED,
                    com.edham.logistics.feature.accountant.domain.model.InvoiceStatus.PARTIALLY_PAID,
                    com.edham.logistics.feature.accountant.domain.model.InvoiceStatus.OVERDUE -> android.view.View.VISIBLE
                    else -> android.view.View.GONE
                }
            }
        }
        
        private fun formatInvoiceStatus(status: com.edham.logistics.feature.accountant.domain.model.InvoiceStatus): String {
            return when (status) {
                com.edham.logistics.feature.accountant.domain.model.InvoiceStatus.DRAFT -> "مسودة"
                com.edham.logistics.feature.accountant.domain.model.InvoiceStatus.ISSUED -> "صادرة"
                com.edham.logistics.feature.accountant.domain.model.InvoiceStatus.PAID -> "مدفوعة"
                com.edham.logistics.feature.accountant.domain.model.InvoiceStatus.OVERDUE -> "متأخرة"
                com.edham.logistics.feature.accountant.domain.model.InvoiceStatus.CANCELLED -> "ملغية"
                com.edham.logistics.feature.accountant.domain.model.InvoiceStatus.PARTIALLY_PAID -> "مدفوعة جزئياً"
            }
        }
        
        private fun formatPaymentMethod(method: String): String {
            return when (method) {
                "CASH" -> "نقدي"
                "BANK_TRANSFER" -> "تحويل بنكي"
                "CREDIT_CARD" -> "بطاقة ائتمان"
                "CHECK" -> "شيك"
                "ONLINE_PAYMENT" -> "دفع إلكتروني"
                "MOBILE_MONEY" -> "محفظة محمولة"
                else -> method
            }
        }
        
        private fun formatCurrency(amount: Double): String {
            return String.format("%.2f ريال", amount)
        }
        
        private fun formatDate(date: String): String {
            return date.substring(0, 10).replace("-", "/")
        }
        
        private fun getInvoiceStatusColor(status: com.edham.logistics.feature.accountant.domain.model.InvoiceStatus): Int {
            return when (status) {
                com.edham.logistics.feature.accountant.domain.model.InvoiceStatus.DRAFT -> android.graphics.Color.parseColor("#9E9E9E")
                com.edham.logistics.feature.accountant.domain.model.InvoiceStatus.ISSUED -> android.graphics.Color.parseColor("#2196F3")
                com.edham.logistics.feature.accountant.domain.model.InvoiceStatus.PAID -> android.graphics.Color.parseColor("#4CAF50")
                com.edham.logistics.feature.accountant.domain.model.InvoiceStatus.OVERDUE -> android.graphics.Color.parseColor("#F44336")
                com.edham.logistics.feature.accountant.domain.model.InvoiceStatus.CANCELLED -> android.graphics.Color.parseColor("#FF5722")
                com.edham.logistics.feature.accountant.domain.model.InvoiceStatus.PARTIALLY_PAID -> android.graphics.Color.parseColor("#FF9800")
            }
        }
    }

    private class InvoiceDiffCallback : DiffUtil.ItemCallback<Invoice>() {
        override fun areItemsTheSame(oldItem: Invoice, newItem: Invoice): Boolean {
            return oldItem.id == newItem.id
        }

        override fun areContentsTheSame(oldItem: Invoice, newItem: Invoice): Boolean {
            return oldItem == newItem
        }
    }
}
