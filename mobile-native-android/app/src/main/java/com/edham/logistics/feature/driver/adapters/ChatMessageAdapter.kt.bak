package com.edham.logistics.feature.driver.adapters

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.ImageView
import android.widget.TextView
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.feature.driver.ChatMessage
import java.text.SimpleDateFormat
import java.util.*

class ChatMessageAdapter(
    private val messages: List<ChatMessage>
) : RecyclerView.Adapter<ChatMessageAdapter.ViewHolder>() {
    
    private val timeFormat = SimpleDateFormat("HH:mm", Locale.getDefault())
    private val dateFormat = SimpleDateFormat("MMM dd", Locale.getDefault())
    
    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): ViewHolder {
        val view = LayoutInflater.from(parent.context).inflate(R.layout.item_chat_message, parent, false)
        return ViewHolder(view)
    }
    
    override fun onBindViewHolder(holder: ViewHolder, position: Int) {
        holder.bind(messages[position])
    }
    
    override fun getItemCount(): Int = messages.size
    
    inner class ViewHolder(itemView: View) : RecyclerView.ViewHolder(itemView) {
        private val messageContainer: ViewGroup = itemView.findViewById(R.id.messageContainer)
        private val messageText: TextView = itemView.findViewById(R.id.messageText)
        private val senderName: TextView = itemView.findViewById(R.id.senderName)
        private val messageTime: TextView = itemView.findViewById(R.id.messageTime)
        private val messageStatus: TextView = itemView.findViewById(R.id.messageStatus)
        private val messageIcon: ImageView = itemView.findViewById(R.id.messageIcon)
        
        fun bind(message: ChatMessage) {
            // Set message text
            messageText.text = message.message
            
            // Set sender name
            senderName.text = if (message.isFromDriver) "You" else "Dispatcher"
            
            // Set time
            val calendar = Calendar.getInstance()
            calendar.timeInMillis = message.timestamp
            
            val today = Calendar.getInstance()
            val isToday = calendar.get(Calendar.DAY_OF_YEAR) == today.get(Calendar.DAY_OF_YEAR) &&
                    calendar.get(Calendar.YEAR) == today.get(Calendar.YEAR)
            
            messageTime.text = if (isToday) {
                timeFormat.format(calendar.time)
            } else {
                dateFormat.format(calendar.time)
            }
            
            // Set status
            when (message.status) {
                "SENDING" -> {
                    messageStatus.text = "Sending..."
                    messageStatus.visibility = View.VISIBLE
                }
                "SENT" -> {
                    messageStatus.text = "Sent"
                    messageStatus.visibility = View.VISIBLE
                }
                "RECEIVED" -> {
                    messageStatus.text = "Delivered"
                    messageStatus.visibility = View.VISIBLE
                }
                "READ" -> {
                    messageStatus.text = "Read"
                    messageStatus.visibility = View.VISIBLE
                }
                else -> {
                    messageStatus.visibility = View.GONE
                }
            }
            
            // Set message icon based on type
            when (message.messageType) {
                "TEXT" -> {
                    messageIcon.setImageResource(R.drawable.ic_message_text)
                    messageIcon.visibility = View.GONE
                }
                "FILE" -> {
                    messageIcon.setImageResource(R.drawable.ic_attachment)
                    messageIcon.visibility = View.VISIBLE
                }
                "VOICE" -> {
                    messageIcon.setImageResource(R.drawable.ic_voice)
                    messageIcon.visibility = View.VISIBLE
                }
                "IMAGE" -> {
                    messageIcon.setImageResource(R.drawable.ic_image)
                    messageIcon.visibility = View.VISIBLE
                }
                else -> {
                    messageIcon.visibility = View.GONE
                }
            }
            
            // Set message appearance based on sender
            if (message.isFromDriver) {
                // Driver message - align to right
                messageContainer.setBackgroundResource(R.drawable.bg_message_sent)
                messageText.setTextColor(itemView.context.getColor(R.color.text_on_primary))
                senderName.setTextColor(itemView.context.getColor(R.color.text_on_primary_secondary))
                messageTime.setTextColor(itemView.context.getColor(R.color.text_on_primary_secondary))
                messageStatus.setTextColor(itemView.context.getColor(R.color.text_on_primary_secondary))
                
                // Layout params for sent messages
                (messageContainer.layoutParams as ViewGroup.MarginLayoutParams).marginStart = 64.dp
                (messageContainer.layoutParams as ViewGroup.MarginLayoutParams).marginEnd = 8.dp
            } else {
                // Dispatcher message - align to left
                messageContainer.setBackgroundResource(R.drawable.bg_message_received)
                messageText.setTextColor(itemView.context.getColor(R.color.text_primary))
                senderName.setTextColor(itemView.context.getColor(R.color.text_secondary))
                messageTime.setTextColor(itemView.context.getColor(R.color.text_secondary))
                messageStatus.setTextColor(itemView.context.getColor(R.color.text_secondary))
                
                // Layout params for received messages
                (messageContainer.layoutParams as ViewGroup.MarginLayoutParams).marginStart = 8.dp
                (messageContainer.layoutParams as ViewGroup.MarginLayoutParams).marginEnd = 64.dp
            }
        }
    }
    
    // Extension for dp to pixels
    private val Int.dp: Int
        get() = (this * itemView.context.resources.displayMetrics.density).toInt()
}
