package com.edham.logistics.feature.admin.presentation.adapter

import android.view.LayoutInflater
import android.view.ViewGroup
import androidx.recyclerview.widget.DiffUtil
import androidx.recyclerview.widget.ListAdapter
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.databinding.ItemRecentUserBinding
import com.edham.logistics.feature.admin.domain.model.UserManagement
import com.edham.logistics.presentation.util.DateFormatter
import javax.inject.Inject

class RecentUsersAdapter @Inject constructor(
    private val dateFormatter: DateFormatter
) : ListAdapter<UserManagement, RecentUsersAdapter.RecentUserViewHolder>(RecentUserDiffCallback()) {

    private var onItemClickListener: ((UserManagement) -> Unit)? = null

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): RecentUserViewHolder {
        val binding = ItemRecentUserBinding.inflate(
            LayoutInflater.from(parent.context),
            parent,
            false
        )
        return RecentUserViewHolder(binding)
    }

    override fun onBindViewHolder(holder: RecentUserViewHolder, position: Int) {
        holder.bind(getItem(position))
    }

    inner class RecentUserViewHolder(
        private val binding: ItemRecentUserBinding
    ) : RecyclerView.ViewHolder(binding.root) {

        fun bind(user: UserManagement) {
            binding.apply {
                textUserName.text = user.name
                textUserEmail.text = user.email
                textUserRole.text = formatRole(user.role)
                textUserStatus.text = formatStatus(user.status)
                textLastLogin.text = user.lastLogin?.let { 
                    dateFormatter.formatRelativeTime(it) 
                } ?: "لم يسجل دخول بعد"
                
                // Set status color
                textUserStatus.setTextColor(getStatusColor(user.status))
                
                // Set role icon
                imageRoleIcon.setImageResource(getRoleIcon(user.role))
                
                // Set click listener
                root.setOnClickListener {
                    onItemClickListener?.invoke(user)
                }
            }
        }
        
        private fun formatRole(role: String): String {
            return when (role) {
                "admin" -> "مدير النظام"
                "supervisor" -> "مشرف العمليات"
                "driver" -> "سائق"
                "customer" -> "عميل"
                "accountant" -> "محاسب"
                "workshop" -> "فني ورشة"
                else -> role
            }
        }
        
        private fun formatStatus(status: String): String {
            return when (status) {
                "active" -> "نشط"
                "inactive" -> "غير نشط"
                "suspended" -> "موقوف"
                "pending" -> "في انتظار"
                "on_leave" -> "في إجازة"
                else -> status
            }
        }
        
        private fun getStatusColor(status: String): Int {
            return when (status) {
                "active" -> android.graphics.Color.parseColor("#4CAF50")
                "inactive" -> android.graphics.Color.parseColor("#9E9E9E")
                "suspended" -> android.graphics.Color.parseColor("#F44336")
                "pending" -> android.graphics.Color.parseColor("#FF9800")
                "on_leave" -> android.graphics.Color.parseColor("#2196F3")
                else -> android.graphics.Color.parseColor("#9E9E9E")
            }
        }
        
        private fun getRoleIcon(role: String): Int {
            return when (role) {
                "admin" -> com.edham.logistics.R.drawable.ic_admin
                "supervisor" -> com.edham.logistics.R.drawable.ic_supervisor
                "driver" -> com.edham.logistics.R.drawable.ic_driver
                "customer" -> com.edham.logistics.R.drawable.ic_customer
                "accountant" -> com.edham.logistics.R.drawable.ic_accountant
                "workshop" -> com.edham.logistics.R.drawable.ic_workshop
                else -> com.edham.logistics.R.drawable.ic_user_default
            }
        }
    }

    fun setOnItemClickListener(listener: (UserManagement) -> Unit) {
        onItemClickListener = listener
    }

    private class RecentUserDiffCallback : DiffUtil.ItemCallback<UserManagement>() {
        override fun areItemsTheSame(oldItem: UserManagement, newItem: UserManagement): Boolean {
            return oldItem.id == newItem.id
        }

        override fun areContentsTheSame(oldItem: UserManagement, newItem: UserManagement): Boolean {
            return oldItem == newItem
        }
    }
}
