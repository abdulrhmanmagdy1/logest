package com.edham.logistics.bugdetection

import timber.log.Timber

/**
 * REST API Controller for Bug Detection System
 * Provides endpoints for bug management, reporting, and analysis
 * Note: Spring annotations commented out for Android compatibility
 * Controller methods disabled - only data classes preserved for Android usage
 */

class BugDetectionController {
    // Spring REST controller methods disabled for Android compatibility
    // Data classes below are preserved for use in Android app
}

// Request/Response data classes
data class BugReportListRequest(
    val page: Int,
    val size: Int,
    val sortBy: String,
    val sortDirection: String,
    val severity: BugSeverity? = null,
    val type: BugType? = null,
    val status: BugStatus? = null
)

data class BugReportListResponse(
    val reports: List<BugReportResponse>,
    val pagination: PaginationInfo,
    val totalCount: Int
)

data class BugReportResponse(
    val id: String,
    val type: BugType,
    val severity: BugSeverity,
    val title: String,
    val description: String,
    val data: Map<String, Any>,
    val timestamp: Long,
    val status: BugStatus,
    val deviceInfo: DeviceInfo,
    val appInfo: AppInfo,
    val comments: List<BugCommentResponse>
)

data class BugCommentResponse(
    val id: String,
    val bugId: String,
    val author: String,
    val content: String,
    val timestamp: Long
)

data class BugStatisticsRequest(
    val startDate: Long,
    val endDate: Long
)

data class BugStatisticsResponse(
    val totalDetections: Long,
    val criticalBugs: Long,
    val performanceIssues: Long,
    val networkIssues: Long,
    val memoryIssues: Long,
    val openBugs: Int,
    val resolvedBugs: Int,
    val averageResolutionTime: Double,
    val bugTrend: List<BugTrendPoint>
)

data class BugTrendPoint(
    val date: String,
    val count: Int,
    val severity: BugSeverity
)

data class UpdateBugStatusRequest(
    val status: BugStatus,
    val comment: String? = null
)

data class AddBugCommentRequest(
    val content: String,
    val author: String
)

data class BugTrendsRequest(
    val days: Int,
    val type: BugType? = null
)

data class BugTrendsResponse(
    val trends: List<BugTrendPoint>,
    val summary: BugTrendsSummary
)

data class BugTrendsSummary(
    val totalBugs: Int,
    val criticalBugs: Int,
    val highBugs: Int,
    val mediumBugs: Int,
    val lowBugs: Int,
    val trendDirection: String // "increasing", "decreasing", "stable"
)

data class SeverityDistributionRequest(
    val days: Int
)

data class SeverityDistributionResponse(
    val distribution: Map<BugSeverity, Int>,
    val totalBugs: Int,
    val criticalPercentage: Double,
    val highPercentage: Double,
    val mediumPercentage: Double,
    val lowPercentage: Double
)

data class TypeDistributionRequest(
    val days: Int
)

data class TypeDistributionResponse(
    val distribution: Map<BugType, Int>,
    val totalBugs: Int,
    val mostCommonType: BugType,
    val typePercentages: Map<BugType, Double>
)

data class DeviceStatisticsResponse(
    val deviceDistribution: Map<String, Int>,
    val osVersionDistribution: Map<String, Int>,
    val appVersionDistribution: Map<String, Int>,
    val mostProblematicDevice: String,
    val mostProblematicOSVersion: String
)

data class ExportBugReportsRequest(
    val days: Int,
    val format: ExportFormat
)

data class ManualDetectionResponse(
    val detectionRun: Boolean,
    val newBugsFound: Int,
    val detectionTime: Long,
    val summary: String
)

data class DetectionRuleResponse(
    val id: String,
    val name: String,
    val type: String,
    val threshold: Double,
    val severity: BugSeverity,
    val enabled: Boolean,
    val createdAt: Long,
    val updatedAt: Long
)

data class AddDetectionRuleRequest(
    val name: String,
    val type: String,
    val threshold: Double,
    val severity: BugSeverity,
    val enabled: Boolean = true
)

data class UpdateDetectionRuleRequest(
    val name: String? = null,
    val threshold: Double? = null,
    val severity: BugSeverity? = null,
    val enabled: Boolean? = null
)

data class BugDetectionConfigurationResponse(
    val autoReportingEnabled: Boolean,
    val criticalBugAutoReport: Boolean,
    val detectionInterval: Long,
    val maxStoredReports: Int,
    val notificationSettings: NotificationSettings
)

data class NotificationSettings(
    val emailNotifications: Boolean,
    val slackNotifications: Boolean,
    val criticalOnly: Boolean,
    val notificationEmails: List<String>,
    val slackWebhook: String?
)

data class UpdateBugDetectionConfigurationRequest(
    val autoReportingEnabled: Boolean? = null,
    val criticalBugAutoReport: Boolean? = null,
    val detectionInterval: Long? = null,
    val maxStoredReports: Int? = null,
    val notificationSettings: NotificationSettings? = null
)

enum class ExportFormat {
    CSV, JSON, PDF
}
