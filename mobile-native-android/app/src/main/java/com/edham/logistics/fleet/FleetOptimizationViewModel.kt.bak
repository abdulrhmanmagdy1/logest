package com.edham.logistics.fleet

import androidx.lifecycle.*
import kotlinx.coroutines.flow.*
import kotlinx.coroutines.launch

/**
 * Fleet Optimization ViewModel - State management for fleet optimization
 */
class FleetOptimizationViewModel : ViewModel() {
    
    private val fleetOptimizationService = FleetOptimizationService(context = null) // Will be injected
    
    // State flows
    private val _fleetOptimizationData = MutableStateFlow<FleetOptimizationData?>(null)
    val fleetOptimizationData: StateFlow<FleetOptimizationData?> = _fleetOptimizationData.asStateFlow()
    
    private val _isLoading = MutableStateFlow(false)
    val isLoading: StateFlow<Boolean> = _isLoading.asStateFlow()
    
    private val _error = MutableStateFlow<String?>(null)
    val error: StateFlow<String?> = _error.asStateFlow()
    
    private val _assignmentResult = MutableStateFlow<VehicleAssignmentResult?>(null)
    val assignmentResult: StateFlow<VehicleAssignmentResult?> = _assignmentResult.asStateFlow()
    
    private val _maintenanceResult = MutableStateFlow<MaintenanceScheduleResult?>(null)
    val maintenanceResult: StateFlow<MaintenanceScheduleResult?> = _maintenanceResult.asStateFlow()
    
    init {
        refreshFleetData()
    }
    
    /**
     * Refresh fleet data
     */
    fun refreshFleetData() {
        viewModelScope.launch {
            try {
                _isLoading.value = true
                _error.value = null
                
                // Get comprehensive fleet optimization data
                fleetOptimizationService.getFleetOptimizationData().collect { data ->
                    _fleetOptimizationData.value = data
                }
                
            } catch (e: Exception) {
                _error.value = "Failed to refresh fleet data: ${e.message}"
            } finally {
                _isLoading.value = false
            }
        }
    }
    
    /**
     * Get vehicle utilization
     */
    fun getVehicleUtilization(): StateFlow<VehicleUtilizationAnalysis> {
        return fleetOptimizationService.getVehicleUtilization()
    }
    
    /**
     * Get idle vehicles
     */
    fun getIdleVehicles(): StateFlow<List<IdleVehicle>> {
        return fleetOptimizationService.getIdleVehicles()
    }
    
    /**
     * Get maintenance alerts
     */
    fun getMaintenanceAlerts(): StateFlow<List<MaintenanceAlert>> {
        return fleetOptimizationService.getMaintenanceAlerts()
    }
    
    /**
     * Get fleet health score
     */
    fun getFleetHealthScore(): StateFlow<FleetHealthScore> {
        return fleetOptimizationService.getFleetHealthScore()
    }
    
    /**
     * Assign vehicle to shipment
     */
    fun assignVehicle(shipmentId: String, vehicleId: String) {
        viewModelScope.launch {
            try {
                _isLoading.value = true
                _error.value = null
                
                val requirements = ShipmentRequirements(
                    weight = 500.0, // Default weight - should come from shipment
                    cargoType = "General", // Default type - should come from shipment
                    pickupLocation = Location(0.0, 0.0), // Default - should come from shipment
                    deliveryLocation = Location(0.0, 0.0), // Default - should come from shipment
                    priority = Priority.MEDIUM
                )
                
                val result = fleetOptimizationService.assignVehicleToShipment(shipmentId, requirements)
                _assignmentResult.value = result
                
                if (result.success) {
                    // Refresh fleet data after successful assignment
                    refreshFleetData()
                } else {
                    _error.value = result.message
                }
                
            } catch (e: Exception) {
                _error.value = "Failed to assign vehicle: ${e.message}"
            } finally {
                _isLoading.value = false
            }
        }
    }
    
    /**
     * Schedule maintenance
     */
    fun scheduleMaintenance(
        vehicleId: String,
        maintenanceType: MaintenanceType,
        scheduledDate: LocalDateTime
    ) {
        viewModelScope.launch {
            try {
                _isLoading.value = true
                _error.value = null
                
                val result = fleetOptimizationService.scheduleMaintenance(
                    vehicleId = vehicleId,
                    maintenanceType = maintenanceType,
                    scheduledDate = scheduledDate
                )
                _maintenanceResult.value = result
                
                if (result.success) {
                    // Refresh fleet data after successful scheduling
                    refreshFleetData()
                } else {
                    _error.value = result.message
                }
                
            } catch (e: Exception) {
                _error.value = "Failed to schedule maintenance: ${e.message}"
            } finally {
                _isLoading.value = false
            }
        }
    }
    
    /**
     * Clear error
     */
    fun clearError() {
        _error.value = null
    }
    
    /**
     * Clear assignment result
     */
    fun clearAssignmentResult() {
        _assignmentResult.value = null
    }
    
    /**
     * Clear maintenance result
     */
    fun clearMaintenanceResult() {
        _maintenanceResult.value = null
    }
    
    override fun onCleared() {
        super.onCleared()
        fleetOptimizationService.cleanup()
    }
}

/**
 * Factory for creating FleetOptimizationViewModel
 */
class FleetOptimizationViewModelFactory(
    private val fleetOptimizationService: FleetOptimizationService
) : ViewModelProvider.Factory {
    
    @Suppress("UNCHECKED_CAST")
    override fun <T : ViewModel> create(modelClass: Class<T>): T {
        if (modelClass.isAssignableFrom(FleetOptimizationViewModel::class.java)) {
            return FleetOptimizationViewModel() as T
        }
        throw IllegalArgumentException("Unknown ViewModel class")
    }
}
