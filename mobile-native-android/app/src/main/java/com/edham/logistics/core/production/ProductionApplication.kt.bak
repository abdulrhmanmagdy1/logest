package com.edham.logistics.core.production

import android.app.Application
import android.util.Log
import com.google.firebase.crashlytics.FirebaseCrashlytics
import com.google.firebase.ktx.Firebase
import dagger.hilt.android.HiltAndroidApp
import javax.inject.Inject

/**
 * Production Application Class
 * Handles production-specific initialization and configuration
 */
@HiltAndroidApp
class ProductionApplication : Application() {
    
    @Inject
    lateinit var productionConfig: ProductionConfig
    
    @Inject
    lateinit var crashReportingManager: CrashReportingManager
    
    @Inject
    lateinit var analyticsManager: AnalyticsManager
    
    @Inject
    lateinit var buildOptimizer: BuildOptimizer
    
    @Inject
    lateinit var debugCodeRemover: DebugCodeRemover
    
    @Inject
    lateinit var apiSecurityManager: ApiSecurityManager
    
    override fun onCreate() {
        super.onCreate()
        
        Log.i("ProductionApplication", "Initializing Edham Logistics Production App")
        
        try {
            // Initialize production configuration
            initializeProductionConfig()
            
            // Initialize crash reporting
            initializeCrashReporting()
            
            // Initialize analytics
            initializeAnalytics()
            
            // Initialize build optimizations
            initializeBuildOptimizations()
            
            // Remove debug code
            removeDebugCode()
            
            // Initialize API security
            initializeApiSecurity()
            
            // Validate production readiness
            validateProductionReadiness()
            
            Log.i("ProductionApplication", "Production app initialization completed successfully")
            
        } catch (e: Exception) {
            Log.e("ProductionApplication", "Failed to initialize production app", e)
            
            // Report initialization failure
            Firebase.crashlytics.recordException(e)
        }
    }
    
    /**
     * Initialize production configuration
     */
    private fun initializeProductionConfig() {
        try {
            productionConfig.initializeProductionConfig()
            Log.i("ProductionApplication", "Production configuration initialized")
        } catch (e: Exception) {
            Log.e("ProductionApplication", "Failed to initialize production config", e)
            throw e
        }
    }
    
    /**
     * Initialize crash reporting
     */
    private fun initializeCrashReporting() {
        try {
            crashReportingManager.initialize()
            Log.i("ProductionApplication", "Crash reporting initialized")
        } catch (e: Exception) {
            Log.e("ProductionApplication", "Failed to initialize crash reporting", e)
            // Don't throw - continue with app initialization
        }
    }
    
    /**
     * Initialize analytics
     */
    private fun initializeAnalytics() {
        try {
            analyticsManager.initialize()
            analyticsManager.trackAppOpen()
            Log.i("ProductionApplication", "Analytics initialized")
        } catch (e: Exception) {
            Log.e("ProductionApplication", "Failed to initialize analytics", e)
            // Don't throw - continue with app initialization
        }
    }
    
    /**
     * Initialize build optimizations
     */
    private fun initializeBuildOptimizations() {
        try {
            buildOptimizer.initializeBuildOptimizations()
            Log.i("ProductionApplication", "Build optimizations initialized")
        } catch (e: Exception) {
            Log.e("ProductionApplication", "Failed to initialize build optimizations", e)
            // Don't throw - continue with app initialization
        }
    }
    
    /**
     * Remove debug code
     */
    private fun removeDebugCode() {
        try {
            val success = debugCodeRemover.removeDebugCode()
            if (success) {
                Log.i("ProductionApplication", "Debug code removal completed")
            } else {
                Log.w("ProductionApplication", "Debug code removal had issues")
            }
        } catch (e: Exception) {
            Log.e("ProductionApplication", "Failed to remove debug code", e)
            // Don't throw - continue with app initialization
        }
    }
    
    /**
     * Initialize API security
     */
    private fun initializeApiSecurity() {
        try {
            apiSecurityManager.initializeApiSecurity()
            Log.i("ProductionApplication", "API security initialized")
        } catch (e: Exception) {
            Log.e("ProductionApplication", "Failed to initialize API security", e)
            // Don't throw - continue with app initialization
        }
    }
    
    /**
     * Validate production readiness
     */
    private fun validateProductionReadiness() {
        try {
            val issues = mutableListOf<String>()
            
            // Validate production configuration
            val configIssues = productionConfig.validateProductionConfig()
            issues.addAll(configIssues)
            
            // Validate debug code removal
            if (!debugCodeRemover.isProductionReady()) {
                issues.add("Debug code removal validation failed")
            }
            
            // Validate API security
            if (!apiSecurityManager.isApiSecure()) {
                issues.add("API security validation failed")
            }
            
            // Validate build optimization
            if (!buildOptimizer.isBuildOptimized()) {
                issues.add("Build optimization validation failed")
            }
            
            if (issues.isNotEmpty()) {
                Log.e("ProductionApplication", "Production readiness validation failed: ${issues.joinToString(", ")}")
                
                // Report production readiness issues
                Firebase.crashlytics.setCustomKey("production_issues", issues.joinToString(", "))
                
                // In production, we might want to throw or handle this differently
                if (productionConfig.isProductionMode()) {
                    Log.w("ProductionApplication", "App has production readiness issues but continuing")
                }
            } else {
                Log.i("ProductionApplication", "Production readiness validation passed")
            }
            
        } catch (e: Exception) {
            Log.e("ProductionApplication", "Failed to validate production readiness", e)
            // Don't throw - continue with app initialization
        }
    }
    
    /**
     * Get production status report
     */
    fun getProductionStatusReport(): Map<String, Any> {
        return mapOf(
            "productionConfig" to productionConfig.getBuildInfo(),
            "crashReporting" to mapOf(
                "enabled" to crashReportingManager.isCrashReportingEnabled()
            ),
            "analytics" to mapOf(
                "enabled" to analyticsManager.isAnalyticsEnabled()
            ),
            "buildOptimization" to buildOptimizer.getBuildPerformanceMetrics(),
            "debugCodeRemoval" to debugCodeRemover.generateDebugCodeRemovalSummary(),
            "apiSecurity" to apiSecurityManager.getApiSecurityReport(),
            "isProductionReady" to isProductionReady()
        )
    }
    
    /**
     * Check if app is production ready
     */
    fun isProductionReady(): Boolean {
        return productionConfig.isProductionMode() &&
               debugCodeRemover.isProductionReady() &&
               apiSecurityManager.isApiSecure() &&
               buildOptimizer.isBuildOptimized()
    }
    
    override fun onTerminate() {
        super.onTerminate()
        Log.i("ProductionApplication", "Production app terminated")
    }
    
    override fun onLowMemory() {
        super.onLowMemory()
        Log.w("ProductionApplication", "Low memory warning received")
        
        // Report low memory issue
        Firebase.crashlytics.setCustomKey("low_memory", "true")
    }
    
    override fun onTrimMemory(level: Int) {
        super.onTrimMemory(level)
        Log.w("ProductionApplication", "Memory trim level: $level")
        
        // Report memory trim level
        Firebase.crashlytics.setCustomKey("memory_trim_level", level.toString())
    }
}
