package com.edham.logistics

import android.os.Bundle
import android.os.Handler
import android.os.Looper
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.EditText
import androidx.recyclerview.widget.LinearLayoutManager
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.ui.base.BaseListFragment
import com.google.android.material.tabs.TabLayout

class LoadsFragment : BaseListFragment() {
    private lateinit var etSearch: EditText
    private lateinit var tabLayout: TabLayout
    private lateinit var rvLoads: RecyclerView
    private lateinit var loadAdapter: LoadAdapter

    override fun getLayoutId(): Int {
        return R.layout.fragment_loads
    }

    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)

        etSearch = view.findViewById(R.id.et_search)
        tabLayout = view.findViewById(R.id.tab_layout)
        rvLoads = view.findViewById(R.id.rv_loads)

        setupTabs()
        setupRecyclerView()
        setupSearch()
        
        // Load initial data
        loadData()
    }

    private fun setupTabs() {
        tabLayout.addTab(tabLayout.newTab().setText("All"))
        tabLayout.addTab(tabLayout.newTab().setText("Active"))
        tabLayout.addTab(tabLayout.newTab().setText("Delivered"))
        tabLayout.addTab(tabLayout.newTab().setText("Pending"))

        tabLayout.addOnTabSelectedListener(object : TabLayout.OnTabSelectedListener {
            override fun onTabSelected(tab: TabLayout.Tab?) {
                filterLoads(tab?.position ?: 0)
            }

            override fun onTabUnselected(tab: TabLayout.Tab?) {}

            override fun onTabReselected(tab: TabLayout.Tab?) {}
        })
    }

    private fun setupRecyclerView() {
        loadAdapter = LoadAdapter(emptyList())
        rvLoads.layoutManager = LinearLayoutManager(requireContext())
        rvLoads.adapter = loadAdapter
        
        // Add item animations
        rvLoads.itemAnimator = androidx.recyclerview.widget.DefaultItemAnimator()
    }

    private fun setupSearch() {
        etSearch.addTextChangedListener {
            filterLoads(tabLayout.selectedTabPosition, it.toString())
        }
    }

    private fun filterLoads(position: Int, query: String) {
        val allLoads = MockData.loads
        val filteredLoads = when (position) {
            0 -> allLoads // All
            1 -> allLoads.filter { it.status == "In Transit" || it.status == "Loading" } // Active
            2 -> allLoads.filter { it.status == "Delivered" } // Delivered
            3 -> allLoads.filter { it.status == "Pending" } // Pending
            else -> allLoads
        }
        
        // Apply search filter if search text exists
        val finalFiltered = if (query.isNotEmpty()) {
            filteredLoads.filter { 
                it.id.contains(query, ignoreCase = true) ||
                it.clientName.contains(query, ignoreCase = true)
            }
        } else {
            filteredLoads
        }
        
        loadAdapter.updateData(finalFiltered)
        checkEmptyState(finalFiltered.size)
    }

    private fun loadData() {
        showLoading()
        
        // Simulate network delay
        Handler(Looper.getMainLooper()).postDelayed({
            val loads = MockData.loads
            loadAdapter.updateData(loads)
            
            if (loads.isEmpty()) {
                showEmptyState()
            } else {
                showContent()
            }
            hideLoading()
        }, 1500)
    }

    override fun onRefresh() {
        loadData()
    }
}
