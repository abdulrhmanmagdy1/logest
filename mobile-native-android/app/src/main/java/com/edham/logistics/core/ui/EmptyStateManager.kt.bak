package com.edham.logistics.core.ui

import android.content.Context
import android.graphics.Color
import android.graphics.drawable.GradientDrawable
import android.view.View
import android.view.ViewGroup
import android.widget.ImageView
import android.widget.TextView
import androidx.constraintlayout.widget.ConstraintLayout
import androidx.core.content.ContextCompat
import androidx.core.view.isVisible
import kotlinx.coroutines.*
import java.util.concurrent.ConcurrentHashMap
import javax.inject.Inject
import javax.inject.Singleton

/**
 * Empty State Manager - Manages empty states for all screens
 * Provides consistent empty state patterns across the application
 */
@Singleton
class EmptyStateManager @Inject constructor(
    private val context: Context
) {

    private val emptyStateViews = ConcurrentHashMap<String, View>()
    private val coroutineScope = CoroutineScope(SupervisorJob() + Dispatchers.Main)
    
    // Default empty state configuration
    private var defaultConfig = EmptyStateConfig()
    
    /**
     * Initialize empty state manager
     */
    fun initialize(screenId: String, config: EmptyStateConfig = EmptyStateConfig()) {
        this.defaultConfig = config
    }

    /**
     * Show empty state for no data
     */
    fun showNoDataState(
        screenId: String,
        parentView: ViewGroup,
        title: String = "لا توجد بيانات",
        description: String = "لا توجد بيانات لعرضها حالياً",
        actionText: String? = "إعادة المحاولة",
        action: (() -> Unit)? = null
    ) {
        showEmptyState(
            screenId,
            parentView,
            EmptyType.NO_DATA,
            title,
            description,
            actionText,
            action
        )
    }

    /**
     * Show empty state for no results
     */
    fun showNoResultsState(
        screenId: String,
        parentView: ViewGroup,
        searchQuery: String? = null,
        actionText: String? = "مسح البحث",
        action: (() -> Unit)? = null
    ) {
        val title = if (searchQuery != null) {
            "لا توجد نتائج لـ \"$searchQuery\""
        } else {
            "لا توجد نتائج"
        }
        
        val description = if (searchQuery != null) {
            "لم يتم العثور على نتائج مطابقة لبحثك. جرب كلمات مختلفة."
        } else {
            "لم يتم العثور على نتائج. جرب تعديل الفلاتر."
        }
        
        showEmptyState(
            screenId,
            parentView,
            EmptyType.NO_RESULTS,
            title,
            description,
            actionText,
            action
        )
    }

    /**
     * Show empty state for network error
     */
    fun showNetworkErrorState(
        screenId: String,
        parentView: ViewGroup,
        actionText: String? = "إعادة المحاولة",
        action: (() -> Unit)? = null
    ) {
        showEmptyState(
            screenId,
            parentView,
            EmptyType.NETWORK_ERROR,
            "مشكلة في الاتصال",
            "تحقق من اتصالك بالإنترنت وحاول مرة أخرى.",
            actionText,
            action
        )
    }

    /**
     * Show empty state for server error
     */
    fun showServerErrorState(
        screenId: String,
        parentView: ViewGroup,
        actionText: String? = "إعادة المحاولة",
        action: (() -> Unit)? = null
    ) {
        showEmptyState(
            screenId,
            parentView,
            EmptyType.SERVER_ERROR,
            "خطأ في الخادم",
            "حدث خطأ في الخادم. يرجى المحاولة مرة أخرى لاحقاً.",
            actionText,
            action
        )
    }

    /**
     * Show empty state for loading error
     */
    fun showLoadingErrorState(
        screenId: String,
        parentView: ViewGroup,
        errorMessage: String? = null,
        actionText: String? = "إعادة المحاولة",
        action: (() -> Unit)? = null
    ) {
        val description = errorMessage ?: "حدث خطأ أثناء تحميل البيانات."
        
        showEmptyState(
            screenId,
            parentView,
            EmptyType.LOADING_ERROR,
            "خطأ في التحميل",
            description,
            actionText,
            action
        )
    }

    /**
     * Show custom empty state
     */
    fun showCustomEmptyState(
        screenId: String,
        parentView: ViewGroup,
        iconRes: Int? = null,
        title: String,
        description: String,
        actionText: String? = null,
        action: (() -> Unit)? = null
    ) {
        val emptyView = createCustomEmptyView(iconRes, title, description, actionText, action)
        showEmptyStateView(screenId, parentView, emptyView)
    }

    /**
     * Show empty state
     */
    private fun showEmptyState(
        screenId: String,
        parentView: ViewGroup,
        emptyType: EmptyType,
        title: String,
        description: String,
        actionText: String? = null,
        action: (() -> Unit)? = null
    ) {
        hideEmptyState(screenId) // Hide any existing empty state
        
        val emptyView = createEmptyView(emptyType, title, description, actionText, action)
        showEmptyStateView(screenId, parentView, emptyView)
    }

    /**
     * Show empty state view
     */
    private fun showEmptyStateView(screenId: String, parentView: ViewGroup, emptyView: View) {
        emptyStateViews[screenId] = emptyView
        
        // Add empty view to parent
        val layoutParams = ViewGroup.LayoutParams(
            ViewGroup.LayoutParams.MATCH_PARENT,
            ViewGroup.LayoutParams.MATCH_PARENT
        )
        parentView.addView(emptyView, layoutParams)
        
        // Animate in if enabled
        if (defaultConfig.enableAnimations) {
            animateInEmptyView(emptyView)
        }
    }

    /**
     * Hide empty state
     */
    fun hideEmptyState(screenId: String) {
        emptyStateViews[screenId]?.let { emptyView ->
            animateOutEmptyView(emptyView) {
                (emptyView.parent as? ViewGroup)?.removeView(emptyView)
            }
        }
        
        emptyStateViews.remove(screenId)
    }

    /**
     * Create empty view
     */
    private fun createEmptyView(
        emptyType: EmptyType,
        title: String,
        description: String,
        actionText: String? = null,
        action: (() -> Unit)? = null
    ): View {
        val iconRes = getIconForEmptyType(emptyType)
        val iconColor = getIconColorForEmptyType(emptyType)
        
        return createEmptyView(iconRes, iconColor, title, description, actionText, action)
    }

    /**
     * Create custom empty view
     */
    private fun createCustomEmptyView(
        iconRes: Int?,
        title: String,
        description: String,
        actionText: String? = null,
        action: (() -> Unit)? = null
    ): View {
        return createEmptyView(iconRes, null, title, description, actionText, action)
    }

    /**
     * Create empty view with components
     */
    private fun createEmptyView(
        iconRes: Int?,
        iconColor: Int?,
        title: String,
        description: String,
        actionText: String? = null,
        action: (() -> Unit)? = null
    ): View {
        val rootView = ConstraintLayout(context).apply {
            layoutParams = ViewGroup.LayoutParams(
                ViewGroup.LayoutParams.MATCH_PARENT,
                ViewGroup.LayoutParams.MATCH_PARENT
            )
            setPadding(32, 32, 32, 32)
            
            // Create background
            background = createEmptyBackground()
        }
        
        // Icon
        iconRes?.let { res ->
            val iconView = ImageView(context).apply {
                id = View.generateViewId()
                setImageResource(res)
                iconColor?.let { color ->
                    setColorFilter(color)
                }
                alpha = 0.7f
            }
            
            rootView.addView(iconView)
            
            // Constraint icon to top
            val iconLayoutParams = iconView.layoutParams as ConstraintLayout.LayoutParams
            iconLayoutParams.topToTop = ConstraintLayout.LayoutParams.PARENT_ID
            iconLayoutParams.startToStart = ConstraintLayout.LayoutParams.PARENT_ID
            iconLayoutParams.endToEnd = ConstraintLayout.LayoutParams.PARENT_ID
            iconLayoutParams.topMargin = 32
        } ?: run {
            // Create default icon view
            val defaultIconView = createDefaultIconView()
            rootView.addView(defaultIconView)
            
            val iconLayoutParams = defaultIconView.layoutParams as ConstraintLayout.LayoutParams
            iconLayoutParams.topToTop = ConstraintLayout.LayoutParams.PARENT_ID
            iconLayoutParams.startToStart = ConstraintLayout.LayoutParams.PARENT_ID
            iconLayoutParams.endToEnd = ConstraintLayout.LayoutParams.PARENT_ID
            iconLayoutParams.topMargin = 32
        }
        
        // Title
        val titleView = TextView(context).apply {
            id = View.generateViewId()
            text = title
            textSize = 18f
            setTextColor(Color.parseColor("#333333"))
            gravity = android.view.Gravity.CENTER
            setTypeface(null, android.graphics.Typeface.BOLD)
        }
        
        rootView.addView(titleView)
        
        // Description
        val descriptionView = TextView(context).apply {
            id = View.generateViewId()
            text = description
            textSize = 14f
            setTextColor(Color.parseColor("#666666"))
            gravity = android.view.Gravity.CENTER
            lineSpacingExtra = 4f
        }
        
        rootView.addView(descriptionView)
        
        // Action button
        actionText?.let { text ->
            val actionButton = createActionButton(text, action)
            rootView.addView(actionButton)
            
            // Constraint action button
            val actionLayoutParams = actionButton.layoutParams as ConstraintLayout.LayoutParams
            actionLayoutParams.topToBottom = descriptionView.id
            actionLayoutParams.startToStart = ConstraintLayout.LayoutParams.PARENT_ID
            actionLayoutParams.endToEnd = ConstraintLayout.LayoutParams.PARENT_ID
            actionLayoutParams.topMargin = 24
            
            // Constraint description to action button
            val descLayoutParams = descriptionView.layoutParams as ConstraintLayout.LayoutParams
            descLayoutParams.bottomToTop = actionButton.id
            descLayoutParams.startToStart = ConstraintLayout.LayoutParams.PARENT_ID
            descLayoutParams.endToEnd = ConstraintLayout.LayoutParams.PARENT_ID
            descLayoutParams.topToTop = ConstraintLayout.LayoutParams.PARENT_ID
            descLayoutParams.topMargin = 16
        }
        
        return rootView
    }

    /**
     * Create default icon view
     */
    private fun createDefaultIconView(): View {
        return View(context).apply {
            id = View.generateViewId()
            background = createDefaultIconDrawable()
            layoutParams = ConstraintLayout.LayoutParams(64, 64)
        }
    }

    /**
     * Create default icon drawable
     */
    private fun createDefaultIconDrawable(): GradientDrawable {
        return GradientDrawable().apply {
            setColor(Color.parseColor("#CCCCCC"))
            shape = GradientDrawable.OVAL
        }
    }

    /**
     * Create empty background
     */
    private fun createEmptyBackground(): GradientDrawable {
        return GradientDrawable().apply {
            setColor(Color.parseColor("#FFFFFF"))
            cornerRadius = 12f
        }
    }

    /**
     * Create action button
     */
    private fun createActionButton(text: String, action: (() -> Unit)?): View {
        val buttonView = TextView(context).apply {
            id = View.generateViewId()
            this.text = text
            textSize = 14f
            setTextColor(Color.WHITE)
            gravity = android.view.Gravity.CENTER
            setTypeface(null, android.graphics.Typeface.BOLD)
            background = createActionButtonBackground()
            setPadding(24, 12, 24, 12)
            isClickable = true
            isFocusable = true
            
            setOnClickListener {
                action?.invoke()
            }
        }
        
        return buttonView
    }

    /**
     * Create action button background
     */
    private fun createActionButtonBackground(): GradientDrawable {
        return GradientDrawable().apply {
            setColor(Color.parseColor("#2196F3"))
            cornerRadius = 6f
        }
    }

    /**
     * Get icon resource for empty type
     */
    private fun getIconForEmptyType(emptyType: EmptyType): Int? {
        return when (emptyType) {
            EmptyType.NO_DATA -> android.R.drawable.ic_menu_search
            EmptyType.NO_RESULTS -> android.R.drawable.ic_menu_search
            EmptyType.NETWORK_ERROR -> android.R.drawable.stat_notify_error
            EmptyType.SERVER_ERROR -> android.R.drawable.stat_notify_error
            EmptyType.LOADING_ERROR -> android.R.drawable.stat_notify_error
            else -> null
        }
    }

    /**
     * Get icon color for empty type
     */
    private fun getIconColorForEmptyType(emptyType: EmptyType): Int? {
        return when (emptyType) {
            EmptyType.NO_DATA -> Color.parseColor("#9E9E9E")
            EmptyType.NO_RESULTS -> Color.parseColor("#9E9E9E")
            EmptyType.NETWORK_ERROR -> Color.parseColor("#F44336")
            EmptyType.SERVER_ERROR -> Color.parseColor("#F44336")
            EmptyType.LOADING_ERROR -> Color.parseColor("#FF9800")
            else -> null
        }
    }

    /**
     * Animate in empty view
     */
    private fun animateInEmptyView(view: View) {
        view.alpha = 0f
        view.scaleX = 0.8f
        view.scaleY = 0.8f
        
        view.animate()
            .alpha(1f)
            .scaleX(1f)
            .scaleY(1f)
            .setDuration(defaultConfig.animationDuration)
            .setInterpolator(android.view.animation.DecelerateInterpolator())
            .start()
    }

    /**
     * Animate out empty view
     */
    private fun animateOutEmptyView(view: View, onComplete: () -> Unit) {
        view.animate()
            .alpha(0f)
            .scaleX(0.8f)
            .scaleY(0.8f)
            .setDuration(defaultConfig.animationDuration)
            .setInterpolator(android.view.animation.AccelerateInterpolator())
            .withEndAction {
                onComplete()
            }
            .start()
    }

    /**
     * Check if empty state is showing
     */
    fun isShowingEmptyState(screenId: String): Boolean {
        return emptyStateViews.containsKey(screenId)
    }

    /**
     * Update empty state configuration
     */
    fun updateConfig(config: EmptyStateConfig) {
        this.defaultConfig = config
    }

    /**
     * Create empty state for list
     */
    fun createListEmptyState(
        screenId: String,
        parentView: ViewGroup,
        itemType: String = "عنصر"
    ) {
        showEmptyState(
            screenId,
            parentView,
            EmptyType.NO_DATA,
            "لا توجد $itemType",
            "لا توجد عناصر لعرضها حالياً. اسحب للتحديث أو أضف عنصر جديد.",
            "إضافة عنصر",
            null // Action would be handled by the calling screen
        )
    }

    /**
     * Create empty state for search
     */
    fun createSearchEmptyState(
        screenId: String,
        parentView: ViewGroup,
        searchQuery: String
    ) {
        showNoResultsState(screenId, parentView, searchQuery, "مسح البحث") {
            // Clear search action would be handled by calling screen
        }
    }

    /**
     * Cleanup empty state manager
     */
    fun cleanup() {
        // Hide all empty states
        emptyStateViews.forEach { (screenId, _) ->
            hideEmptyState(screenId)
        }
        
        emptyStateViews.clear()
        coroutineScope.cancel()
    }

    /**
     * Cleanup specific screen
     */
    fun cleanup(screenId: String) {
        hideEmptyState(screenId)
    }
}

/**
 * Data classes and enums
 */
data class EmptyStateConfig(
    val enableAnimations: Boolean = true,
    val animationDuration: Long = 300,
    val showIcons: Boolean = true,
    val enableActions: Boolean = true,
    val backgroundColor: Int = Color.WHITE,
    val titleColor: Int = Color.parseColor("#333333"),
    val descriptionColor: Int = Color.parseColor("#666666")
)

enum class EmptyType {
    NO_DATA,
    NO_RESULTS,
    NETWORK_ERROR,
    SERVER_ERROR,
    LOADING_ERROR,
    CUSTOM
}
