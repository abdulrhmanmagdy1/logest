package com.edham.logistics.presentation.ui.dashboard

import android.os.Bundle
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import androidx.fragment.app.Fragment
import androidx.fragment.app.viewModels
import androidx.lifecycle.lifecycleScope
import androidx.recyclerview.widget.LinearLayoutManager
import com.edham.logistics.core.extensions.gone
import com.edham.logistics.core.extensions.visible
import com.edham.logistics.databinding.FragmentAdminDashboardBinding
import com.edham.logistics.presentation.adapter.ShipmentAdapter
import com.edham.logistics.presentation.ui.dashboard.AdminDashboardViewModel
import dagger.hilt.android.AndroidEntryPoint
import kotlinx.coroutines.launch
import javax.inject.Inject

@AndroidEntryPoint
class AdminDashboardFragment : Fragment() {

    private var _binding: FragmentAdminDashboardBinding? = null
    private val binding get() = _binding!!
    
    private val viewModel: AdminDashboardViewModel by viewModels()
    
    @Inject
    lateinit var shipmentAdapter: ShipmentAdapter

    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View {
        _binding = FragmentAdminDashboardBinding.inflate(inflater, container, false)
        return binding.root
    }

    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        setupRecyclerView()
        setupClickListeners()
        observeViewModel()
        setupFilters()
    }

    private fun setupRecyclerView() {
        binding.recyclerViewRecentShipments.apply {
            adapter = shipmentAdapter
            layoutManager = LinearLayoutManager(requireContext())
        }
        
        // Setup click listeners
        shipmentAdapter.setOnShipmentClick { shipment ->
            // Navigate to shipment details
            navigateToShipmentDetails(shipment.id)
        }
        
        shipmentAdapter.setOnTrackClick { shipment ->
            // Navigate to tracking
            navigateToTracking(shipment.id)
        }
    }

    private fun setupClickListeners() {
        binding.cardShipments.setOnClickListener {
            navigateToShipments()
        }
        
        binding.cardDrivers.setOnClickListener {
            navigateToDrivers()
        }
        
        binding.cardVehicles.setOnClickListener {
            navigateToVehicles()
        }
        
        binding.cardRevenue.setOnClickListener {
            navigateToInvoices()
        }
        
        binding.buttonRefresh.setOnClickListener {
            viewModel.refreshData()
        }
        
        binding.swipeRefreshLayout.setOnRefreshListener {
            viewModel.refreshData()
        }
    }

    private fun setupFilters() {
        binding.spinnerStatus.onItemSelectedListener = object : android.widget.AdapterView.OnItemSelectedListener {
            override fun onItemSelected(parent: android.widget.AdapterView<*>?, view: View?, position: Int, id: Long) {
                val status = when (position) {
                    0 -> "all"
                    1 -> "pending"
                    2 -> "in_transit"
                    3 -> "delivered"
                    else -> "all"
                }
                viewModel.filterShipmentsByStatus(status)
            }
            
            override fun onNothingSelected(parent: android.widget.AdapterView<*>?) {}
        }
    }

    private fun observeViewModel() {
        viewLifecycleOwner.lifecycleScope.launch {
            viewModel.uiState.collect { uiState ->
                when {
                    uiState.isLoading -> {
                        showLoading()
                    }
                    uiState.error != null -> {
                        showError(uiState.error)
                    }
                    else -> {
                        showContent(uiState)
                    }
                }
            }
        }
    }

    private fun showLoading() {
        binding.progressBar.visible()
        binding.contentLayout.gone()
        binding.layoutError.gone()
        binding.swipeRefreshLayout.isRefreshing = false
    }

    private fun showError(error: String?) {
        binding.progressBar.gone()
        binding.contentLayout.gone()
        binding.layoutError.visible()
        binding.textError.text = error ?: "حدث خطأ غير متوقع"
        binding.swipeRefreshLayout.isRefreshing = false
    }

    private fun showContent(uiState: AdminDashboardUiState) {
        binding.progressBar.gone()
        binding.contentLayout.visible()
        binding.layoutError.gone()
        binding.swipeRefreshLayout.isRefreshing = false
        
        // Update KPI cards
        binding.textTotalShipments.text = uiState.totalShipments.toString()
        binding.textActiveShipments.text = uiState.activeShipments.toString()
        binding.textTotalDrivers.text = uiState.totalDrivers.toString()
        binding.textActiveDrivers.text = uiState.activeDrivers.toString()
        binding.textTotalVehicles.text = uiState.totalVehicles.toString()
        binding.textAvailableVehicles.text = uiState.availableVehicles.toString()
        binding.textTotalRevenue.text = uiState.totalRevenue.formatCurrency()
        
        // Update recent shipments
        val recentShipments = uiState.filteredShipments.take(10)
        if (recentShipments.isEmpty()) {
            binding.layoutEmptyShipments.visible()
            binding.recyclerViewRecentShipments.gone()
        } else {
            binding.layoutEmptyShipments.gone()
            binding.recyclerViewRecentShipments.visible()
            shipmentAdapter.submitList(recentShipments)
        }
        
        // Setup map with fleet locations
        setupFleetMap(uiState.drivers, uiState.vehicles)
        
        // Setup charts
        setupCharts(uiState)
    }

    private fun setupFleetMap(drivers: List<com.edham.logistics.domain.model.Driver>, vehicles: List<com.edham.logistics.domain.model.Vehicle>) {
        // This would integrate with Google Maps
        // For now, we'll show a placeholder
        binding.textViewFleetStatus.text = "الأسطول النشط: ${drivers.count { it.isOnline }} سائق، ${vehicles.count { it.status == "available" }} مركبة"
    }

    private fun setupCharts(uiState: AdminDashboardUiState) {
        // This would integrate with MPAndroidChart
        // For now, we'll show summary statistics
        binding.textViewChartSummary.text = "إجمالي الإيرادات: ${uiState.totalRevenue.formatCurrency()}\n" +
                "متوسط الإيرادات للشحنة: ${(uiState.totalRevenue / uiState.totalShipments.coerceAtLeast(1)).formatCurrency()}"
    }

    private fun navigateToShipments() {
        // Navigate to shipments list
    }

    private fun navigateToDrivers() {
        // Navigate to drivers list
    }

    private fun navigateToVehicles() {
        // Navigate to vehicles list
    }

    private fun navigateToInvoices() {
        // Navigate to invoices list
    }

    private fun navigateToShipmentDetails(shipmentId: String) {
        // Navigate to shipment details
    }

    private fun navigateToTracking(shipmentId: String) {
        // Navigate to tracking
    }

    override fun onDestroyView() {
        super.onDestroyView()
        _binding = null
    }
}

// Extension function for formatting currency
private fun Double.formatCurrency(): String {
    return String.format("%.2f ريال", this)
}
