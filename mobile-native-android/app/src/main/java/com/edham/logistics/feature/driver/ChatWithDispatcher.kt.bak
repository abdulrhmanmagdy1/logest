package com.edham.logistics.feature.driver

import android.os.Bundle
import android.widget.Toast
import androidx.fragment.app.Fragment
import androidx.recyclerview.widget.LinearLayoutManager
import com.edham.logistics.R
import com.edham.logistics.databinding.FragmentChatWithDispatcherBinding
import com.edham.logistics.feature.driver.adapters.ChatMessageAdapter
import com.edham.logistics.utils.VoiceAlertManager
import timber.log.Timber
import java.util.*

class ChatWithDispatcherFragment : Fragment() {
    
    private var _binding: FragmentChatWithDispatcherBinding? = null
    private val binding get() = _binding!!
    
    private lateinit var voiceAlertManager: VoiceAlertManager
    private lateinit var chatAdapter: ChatMessageAdapter
    private var chatMessages = mutableListOf<ChatMessage>()
    private var currentDriverId: String = "driver_123"
    private var dispatcherId: String = "dispatcher_001"
    
    override fun onCreateView(
        inflater: android.view.LayoutInflater,
        container: android.view.ViewGroup?,
        savedInstanceState: Bundle?
    ): android.view.View {
        _binding = FragmentChatWithDispatcherBinding.inflate(inflater, container, false)
        return binding.root
    }
    
    override fun onViewCreated(view: android.view.View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        
        voiceAlertManager = VoiceAlertManager(requireContext())
        setupUI()
        setupRecyclerView()
        setupClickListeners()
        loadChatHistory()
        
        voiceAlertManager.speak("Chat with dispatcher opened")
    }
    
    private fun setupUI() {
        // Large touch targets for one-hand usage
        binding.btnSendMessage.minimumHeight = 72.dp
        binding.btnSendMessage.minimumWidth = 120.dp
        
        binding.btnAttachFile.minimumHeight = 64.dp
        binding.btnAttachFile.minimumWidth = 64.dp
        
        binding.btnVoiceMessage.minimumHeight = 64.dp
        binding.btnVoiceMessage.minimumWidth = 64.dp
        
        // Dark mode optimized colors
        binding.cardChatInput.setCardBackgroundColor(
            requireContext().getColor(R.color.dark_surface)
        )
        
        // High visibility status colors
        binding.viewConnectionStatus.setBackgroundColor(
            requireContext().getColor(R.color.status_active)
        )
    }
    
    private fun setupRecyclerView() {
        chatAdapter = ChatMessageAdapter(chatMessages)
        
        binding.recyclerViewMessages.apply {
            layoutManager = LinearLayoutManager(requireContext()).apply {
                stackFromEnd = true // Show latest messages at bottom
            }
            adapter = chatAdapter
        }
    }
    
    private fun setupClickListeners() {
        binding.btnSendMessage.setOnClickListener {
            sendMessage()
        }
        
        binding.btnAttachFile.setOnClickListener {
            attachFile()
        }
        
        binding.btnVoiceMessage.setOnClickListener {
            sendVoiceMessage()
        }
        
        // Send message on enter key
        binding.etMessage.setOnEditorActionListener { _, actionId, _ ->
            if (actionId == android.view.inputmethod.EditorInfo.IME_ACTION_SEND) {
                sendMessage()
                true
            } else {
                false
            }
        }
    }
    
    private fun sendMessage() {
        val messageText = binding.etMessage.text.toString().trim()
        
        if (messageText.isBlank()) {
            voiceAlertManager.speak("Please enter a message")
            return
        }
        
        // Create chat message
        val message = ChatMessage(
            id = UUID.randomUUID().toString(),
            senderId = currentDriverId,
            receiverId = dispatcherId,
            message = messageText,
            messageType = "TEXT",
            timestamp = System.currentTimeMillis(),
            status = "SENT",
            isFromDriver = true
        )
        
        // Add message to list
        addMessage(message)
        
        // Clear input field
        binding.etMessage.text.clear()
        
        // Send to server
        sendMessageToServer(message)
        
        // Voice feedback
        voiceAlertManager.speak("Message sent")
    }
    
    private fun attachFile() {
        // Open file picker for document/image attachment
        voiceAlertManager.speak("Attaching file")
        
        // Implementation would open file picker
        // For now, simulate file attachment
        val fileMessage = ChatMessage(
            id = UUID.randomUUID().toString(),
            senderId = currentDriverId,
            receiverId = dispatcherId,
            message = "document.pdf",
            messageType = "FILE",
            fileName = "delivery_document.pdf",
            timestamp = System.currentTimeMillis(),
            status = "SENT",
            isFromDriver = true
        )
        
        addMessage(fileMessage)
        sendMessageToServer(fileMessage)
    }
    
    private fun sendVoiceMessage() {
        // Start voice recording
        voiceAlertManager.speak("Recording voice message")
        
        // Implementation would start voice recording
        // For now, simulate voice message
        val voiceMessage = ChatMessage(
            id = UUID.randomUUID().toString(),
            senderId = currentDriverId,
            receiverId = dispatcherId,
            message = "voice_message.mp3",
            messageType = "VOICE",
            duration = 15, // seconds
            timestamp = System.currentTimeMillis(),
            status = "SENT",
            isFromDriver = true
        )
        
        addMessage(voiceMessage)
        sendMessageToServer(voiceMessage)
    }
    
    private fun addMessage(message: ChatMessage) {
        chatMessages.add(message)
        chatAdapter.notifyItemInserted(chatMessages.size - 1)
        
        // Scroll to bottom
        binding.recyclerViewMessages.scrollToPosition(chatMessages.size - 1)
    }
    
    private fun sendMessageToServer(message: ChatMessage) {
        // Update status to sending
        message.status = "SENDING"
        chatAdapter.notifyItemChanged(chatMessages.size - 1)
        
        // Simulate server send
        binding.root.postDelayed({
            message.status = "SENT"
            chatAdapter.notifyItemChanged(chatMessages.size - 1)
            
            // Simulate dispatcher response
            simulateDispatcherResponse(message)
        }, 1000)
    }
    
    private fun simulateDispatcherResponse(originalMessage: ChatMessage) {
        val responses = listOf(
            "Message received. I'll check on that.",
            "Thanks for the update. Keep me informed.",
            "Understood. I'll handle this situation.",
            "Got it. Stay safe and follow protocol.",
            "Acknowledged. I'm monitoring the situation."
        )
        
        val responseText = responses.random()
        
        val responseMessage = ChatMessage(
            id = UUID.randomUUID().toString(),
            senderId = dispatcherId,
            receiverId = currentDriverId,
            message = responseText,
            messageType = "TEXT",
            timestamp = System.currentTimeMillis(),
            status = "RECEIVED",
            isFromDriver = false
        )
        
        addMessage(responseMessage)
        
        // Voice notification for new message
        voiceAlertManager.speak("New message from dispatcher")
        
        // Vibrate for new message
        vibrateDevice()
    }
    
    private fun loadChatHistory() {
        // Load chat history from local database or API
        // For now, add some sample messages
        val sampleMessages = listOf(
            ChatMessage(
                id = UUID.randomUUID().toString(),
                senderId = dispatcherId,
                receiverId = currentDriverId,
                message = "Good morning! How is your route today?",
                messageType = "TEXT",
                timestamp = System.currentTimeMillis() - 3600000, // 1 hour ago
                status = "RECEIVED",
                isFromDriver = false
            ),
            ChatMessage(
                id = UUID.randomUUID().toString(),
                senderId = currentDriverId,
                receiverId = dispatcherId,
                message = "Good morning! Route is clear so far.",
                messageType = "TEXT",
                timestamp = System.currentTimeMillis() - 3000000, // 50 minutes ago
                status = "SENT",
                isFromDriver = true
            ),
            ChatMessage(
                id = UUID.randomUUID().toString(),
                senderId = dispatcherId,
                receiverId = currentDriverId,
                message = "Great! Let me know if you need any assistance.",
                messageType = "TEXT",
                timestamp = System.currentTimeMillis() - 2400000, // 40 minutes ago
                status = "RECEIVED",
                isFromDriver = false
            )
        )
        
        chatMessages.addAll(sampleMessages)
        chatAdapter.notifyDataSetChanged()
        
        // Scroll to bottom
        binding.recyclerViewMessages.scrollToPosition(chatMessages.size - 1)
    }
    
    private fun updateConnectionStatus(isConnected: Boolean) {
        val status = if (isConnected) "ONLINE" else "OFFLINE"
        binding.tvConnectionStatus.text = status
        
        val color = if (isConnected) {
            requireContext().getColor(R.color.status_active)
        } else {
            requireContext().getColor(R.color.status_offline)
        }
        
        binding.viewConnectionStatus.setBackgroundColor(color)
    }
    
    private fun vibrateDevice() {
        try {
            val vibrator = requireContext().getSystemService(android.content.Context.VIBRATOR_SERVICE) as android.os.Vibrator
            if (android.os.Build.VERSION.SDK_INT >= android.os.Build.VERSION_CODES.O) {
                vibrator.vibrate(android.os.VibrationEffect.createOneShot(200, android.os.VibrationEffect.DEFAULT_AMPLITUDE))
            } else {
                @Suppress("DEPRECATION")
                vibrator.vibrate(200)
            }
        } catch (e: Exception) {
            Timber.e(e, "Error vibrating device")
        }
    }
    
    private fun markMessageAsRead(messageId: String) {
        // Update message status to read
        val messageIndex = chatMessages.indexOfFirst { it.id == messageId }
        if (messageIndex != -1) {
            chatMessages[messageIndex].status = "READ"
            chatAdapter.notifyItemChanged(messageIndex)
        }
    }
    
    private fun deleteMessage(messageId: String) {
        val messageIndex = chatMessages.indexOfFirst { it.id == messageId }
        if (messageIndex != -1) {
            chatMessages.removeAt(messageIndex)
            chatAdapter.notifyItemRemoved(messageIndex)
        }
    }
    
    override fun onResume() {
        super.onResume()
        
        // Update connection status
        updateConnectionStatus(true)
        
        // Mark messages as read
        chatMessages.filter { !it.isFromDriver && it.status == "RECEIVED" }
            .forEach { message ->
                markMessageAsRead(message.id)
            }
    }
    
    override fun onPause() {
        super.onPause()
        
        // Update connection status
        updateConnectionStatus(false)
    }
    
    override fun onDestroyView() {
        super.onDestroyView()
        
        voiceAlertManager.cleanup()
        _binding = null
    }
    
    // Extension for dp to pixels
    private val Int.dp: Int
        get() = (this * resources.displayMetrics.density).toInt()
}

data class ChatMessage(
    val id: String,
    val senderId: String,
    val receiverId: String,
    val message: String,
    val messageType: String, // TEXT, FILE, VOICE, IMAGE
    val fileName: String? = null,
    val duration: Int? = null, // for voice messages in seconds
    val timestamp: Long,
    var status: String, // SENDING, SENT, RECEIVED, READ
    val isFromDriver: Boolean
)
