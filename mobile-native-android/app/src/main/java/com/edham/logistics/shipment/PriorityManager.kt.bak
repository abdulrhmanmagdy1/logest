    /**
     * Get monitoring status
     */
    fun isMonitoring(): Boolean = isMonitoring
}

/**
 * Data classes
 */
data class PriorityShipment(
    val shipment: ShipmentEntity,
    val slaThreshold: SLAThreshold,
    val slaStatus: SLAStatus,
    val priorityScore: Int,
    val riskLevel: RiskLevel
)

data class PriorityAnalytics(
    val totalPriorityShipments: Int,
    val priorityDistribution: Map<Priority, Int>,
    val slaComplianceRate: Float,
    val averageResponseTime: Double,
    val priorityEfficiency: Float,
    val criticalAlerts: Int,
    val overdueShipments: Int,
    val handledOnTime: Int,
    val requiresAttention: List<ShipmentEntity>
)

data class SLAThreshold(
    val pickupTime: Long,
    val deliveryTime: Long,
    val responseTime: Long,
    val notificationLevel: NotificationLevel
)

data class SLAStatus(
    val type: SLAType,
    val expectedTime: Long,
    val actualTime: Long,
    val isViolation: Boolean,
    val violationType: ViolationType?,
    val delayDuration: Long
)

data class SLAViolation(
    val shipmentId: Long,
    val shipmentIdString: String,
    val priority: Priority,
    val violationType: ViolationType,
    val expectedTime: Long,
    val actualTime: Long,
    val delayDuration: Long,
    val severity: ViolationSeverity,
    val createdAt: Date
)

/**
 * Enums
 */
enum class PriorityState {
    Idle,
    Starting,
    Monitoring,
    UpdatingPriority,
    PriorityUpdated,
    Stopped,
    Error
}

enum class Priority {
    CRITICAL,
    HIGH,
    NORMAL,
    LOW
}

enum class SLAType {
    PICKUP,
    DELIVERY,
    RESPONSE
}

enum class ViolationType {
    DELAYED_PICKUP,
    DELAYED_DELIVERY,
    DELAYED_RESPONSE
}

enum class ViolationSeverity {
    LOW,
    MEDIUM,
    HIGH,
    CRITICAL
}

enum class NotificationLevel {
    IMMEDIATE,
    HIGH,
    NORMAL,
    LOW
}

enum class RiskLevel {
    LOW,
    MEDIUM,
    HIGH,
    CRITICAL
}

data class PriorityAlert(
    val type: PriorityAlertType,
    val shipmentId: Long,
    val message: String,
    val severity: ViolationSeverity,
    val timestamp: Date
)

enum class PriorityAlertType {
    SLA_VIOLATION,
    CRITICAL_SHIPMENT_DELAYED,
    PRIORITY_ESCALATION,
    RESOURCE_SHORTAGE,
    AUTOMATED_ESCALATION
}
