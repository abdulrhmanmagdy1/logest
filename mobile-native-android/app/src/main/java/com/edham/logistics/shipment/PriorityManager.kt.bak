/**
 * Priority Manager - Advanced priority shipment management system
 * 
 * Features:
 * - Priority classification
 * - Priority-based routing
 * - Expedited handling
 * - Priority notifications
 * - Performance tracking
 * - SLA management
 */
@Singleton
class PriorityManager @Inject constructor(
    private val context: Context,
    private val database: EdhamDatabase,
    private val shipmentApi: ShipmentApi,
    private val liveTrackingManager: LiveTrackingManager,
    private val networkUtils: NetworkUtils
) {
    
    private val _priorityState = MutableStateFlow<PriorityState>(PriorityState.Idle)
    val priorityState: StateFlow<PriorityState> = _priorityState.asStateFlow()
    
    private val _priorityShipments = MutableStateFlow<List<PriorityShipment>>(emptyList())
    val priorityShipments: StateFlow<List<PriorityShipment>> = _priorityState.asStateFlow()
    
    private val _priorityAnalytics = MutableStateFlow<PriorityAnalytics?>(null)
    val priorityAnalytics: StateFlow<PriorityAnalytics?> = _priorityAnalytics.asStateFlow()
    
    private val _priorityAlerts = MutableStateFlow<List<PriorityAlert>>(emptyList())
    val priorityAlerts: StateFlow<List<PriorityAlert>> = _priorityAlerts.asStateFlow()
    
    private var isMonitoring = false
    private var slaThresholds: MutableMap<Priority, SLAThreshold> = mutableMapOf()
    
    companion object {
        private const val TAG = "PriorityManager"
        private const val PRIORITY_UPDATE_INTERVAL = 60000L // 1 minute
        private const val CRITICAL_RESPONSE_TIME = 300000L // 5 minutes
        private const val HIGH_RESPONSE_TIME = 900000L // 15 minutes
        private const val NORMAL_RESPONSE_TIME = 1800000L // 30 minutes
        private const val LOW_RESPONSE_TIME = 3600000L // 1 hour
    }
    
    init {
        initializeSLAThresholds()
    }
    
    /**
     * Initialize SLA thresholds
     */
    private fun initializeSLAThresholds() {
        slaThresholds[Priority.CRITICAL] = SLAThreshold(
            pickupTime = CRITICAL_RESPONSE_TIME,
            deliveryTime = CRITICAL_RESPONSE_TIME * 2,
            responseTime = CRITICAL_RESPONSE_TIME / 5,
            notificationLevel = NotificationLevel.IMMEDIATE
        )
        
        slaThresholds[Priority.HIGH] = SLAThreshold(
            pickupTime = HIGH_RESPONSE_TIME,
            deliveryTime = HIGH_RESPONSE_TIME * 2,
            responseTime = HIGH_RESPONSE_TIME / 5,
            notificationLevel = NotificationLevel.HIGH
        )
        
        slaThresholds[Priority.NORMAL] = SLAThreshold(
            pickupTime = NORMAL_RESPONSE_TIME,
            deliveryTime = NORMAL_RESPONSE_TIME * 2,
            responseTime = NORMAL_RESPONSE_TIME / 5,
            notificationLevel = NotificationLevel.NORMAL
        )
        
        slaThresholds[Priority.LOW] = SLAThreshold(
            pickupTime = LOW_RESPONSE_TIME,
            deliveryTime = LOW_RESPONSE_TIME * 2,
            responseTime = LOW_RESPONSE_TIME / 5,
            notificationLevel = NotificationLevel.LOW
        )
    }
    
    /**
     * Start priority monitoring
     */
    fun startMonitoring() {
        if (isMonitoring) return
        
        try {
            _priorityState.value = PriorityState.Starting
            isMonitoring = true
            
            // Load priority shipments
            loadPriorityShipments()
            
            // Start SLA monitoring
            startSLAMonitoring()
            
            _priorityState.value = PriorityState.Monitoring
            
        } catch (e: Exception) {
            _priorityState.value = PriorityState.Error("Failed to start monitoring: ${e.message}")
        }
    }
    
    /**
     * Stop priority monitoring
     */
    fun stopMonitoring() {
        isMonitoring = false
        _priorityState.value = PriorityState.Stopped
    }
    
    /**
     * Set shipment priority
     */
    suspend fun setShipmentPriority(
        shipmentId: Long,
        priority: Priority,
        reason: String,
        updatedBy: String
    ): Result<ShipmentEntity> {
        return withContext(Dispatchers.IO) {
            try {
                _priorityState.value = PriorityState.UpdatingPriority
                
                // Get shipment
                val shipment = database.shipmentDao().getShipmentById(shipmentId)
                    ?: throw Exception("Shipment not found")
                
                // Validate priority change
                validatePriorityChange(shipment.priority, priority)
                
                // Update shipment priority
                val updatedShipment = shipment.copy(
                    priority = priority,
                    updatedAt = Date(),
                    updatedBy = updatedBy
                )
                
                database.shipmentDao().updateShipment(updatedShipment)
                
                // Create priority change record
                createPriorityChangeRecord(shipmentId, shipment.priority, priority, reason, updatedBy)
                
                // Apply priority-based routing
                applyPriorityRouting(updatedShipment)
                
                // Send notifications
                sendPriorityNotifications(updatedShipment, reason)
                
                // Update priority shipments list
                loadPriorityShipments()
                
                _priorityState.value = PriorityState.PriorityUpdated
                Result.success(updatedShipment)
                
            } catch (e: Exception) {
                _priorityState.value = PriorityState.Error("Failed to update priority: ${e.message}")
                Result.failure(e)
            }
        }
    }
    
    /**
     * Get priority shipments
     */
    suspend fun getPriorityShipments(priority: Priority? = null): List<PriorityShipment> {
        return withContext(Dispatchers.IO) {
            val shipments = if (priority != null) {
                database.shipmentDao().getShipmentsByPriority(priority)
            } else {
                database.shipmentDao().getShipmentsByPriorityIn(listOf(Priority.CRITICAL, Priority.HIGH))
            }
            
            shipments.map { shipment ->
                val slaThreshold = slaThresholds[shipment.priority] ?: SLAThreshold()
                val slaStatus = calculateSLAStatus(shipment, slaThreshold)
                
                PriorityShipment(
                    shipment = shipment,
                    slaThreshold = slaThreshold,
                    slaStatus = slaStatus,
                    priorityScore = calculatePriorityScore(shipment),
                    riskLevel = calculateRiskLevel(shipment, slaStatus)
                )
            }
        }
    }
    
    /**
     * Get priority analytics
     */
    suspend fun getPriorityAnalytics(): PriorityAnalytics {
        return withContext(Dispatchers.IO) {
            val allShipments = database.shipmentDao().getAllShipments()
            val priorityShipments = allShipments.filter { it.priority != Priority.NORMAL }
            
            val priorityDistribution = calculatePriorityDistribution(allShipments)
            val slaComplianceRate = calculateSLAComplianceRate(priorityShipments)
            val averageResponseTime = calculateAverageResponseTime(priorityShipments)
            val priorityEfficiency = calculatePriorityEfficiency(priorityShipments)
            val criticalAlerts = priorityShipments.count { it.priority == Priority.CRITICAL }
            val overdueShipments = calculateOverdueShipments(priorityShipments)
            
            PriorityAnalytics(
                totalPriorityShipments = priorityShipments.size,
                priorityDistribution = priorityDistribution,
                slaComplianceRate = slaComplianceRate,
                averageResponseTime = averageResponseTime,
                priorityEfficiency = priorityEfficiency,
                criticalAlerts = criticalAlerts,
                overdueShipments = overdueShipments,
                handledOnTime = priorityShipments.count { isHandledOnTime(it) },
                requiresAttention = priorityShipments.filter { requiresAttention(it) }
            )
        }
    }
    
    /**
     * Check SLA compliance
     */
    suspend fun checkSLACompliance(): List<SLAViolation> {
        return withContext(Dispatchers.IO) {
            val violations = mutableListOf<SLAViolation>()
            val priorityShipments = database.shipmentDao().getShipmentsByPriorityIn(
                listOf(Priority.CRITICAL, Priority.HIGH)
            )
            
            priorityShipments.forEach { shipment ->
                val slaThreshold = slaThresholds[shipment.priority] ?: return@forEach
                val slaStatus = calculateSLAStatus(shipment, slaThreshold)
                
                if (slaStatus.isViolation) {
                    violations.add(
                        SLAViolation(
                            shipmentId = shipment.id,
                            shipmentIdString = shipment.shipmentId,
                            priority = shipment.priority,
                            violationType = slaStatus.violationType,
                            expectedTime = slaStatus.expectedTime,
                            actualTime = slaStatus.actualTime,
                            delayDuration = slaStatus.delayDuration,
                            severity = calculateViolationSeverity(shipment.priority, slaStatus),
                            createdAt = Date()
                        )
                    )
                }
            }
            
            violations
        }
    }
    
    /**
     * Expedite shipment
     */
    suspend fun expediteShipment(
        shipmentId: Long,
        expeditedBy: String,
        reason: String
    ): Result<ShipmentEntity> {
        return withContext(Dispatchers.IO) {
            try {
                val shipment = database.shipmentDao().getShipmentById(shipmentId)
                    ?: throw Exception("Shipment not found")
                
                // Increase priority if not already critical
                val newPriority = if (shipment.priority != Priority.CRITICAL) {
                    when (shipment.priority) {
                        Priority.LOW -> Priority.NORMAL
                        Priority.NORMAL -> Priority.HIGH
                        Priority.HIGH -> Priority.CRITICAL
                        Priority.CRITICAL -> Priority.CRITICAL
                    }
                } else {
                    shipment.priority
                }
                
                // Update shipment
                val updatedShipment = shipment.copy(
                    priority = newPriority,
                    updatedAt = Date(),
                    updatedBy = expeditedBy
                )
                
                database.shipmentDao().updateShipment(updatedShipment)
                
                // Apply expedited routing
                applyExpeditedRouting(updatedShipment)
                
                // Send expedited notifications
                sendExpeditedNotifications(updatedShipment, expeditedBy, reason)
                
                Result.success(updatedShipment)
                
            } catch (e: Exception) {
                Result.failure(e)
            }
        }
    }
    
    /**
     * Helper functions
     */
    private suspend fun loadPriorityShipments() {
        val priorityShipments = getPriorityShipments()
        _priorityShipments.value = priorityShipments
    }
    
    private fun startSLAMonitoring() {
        // Implementation would start periodic SLA monitoring
    }
    
