@Singleton
class GrantUserPermissionsUseCase @Inject constructor(
    private val userRepository: UserRepository
) {
    suspend operator fun invoke(userId: String, permissions: Set<Permission>, reason: String): Result<User> {
        return try {
            val result = userRepository.grantUserPermissions(userId, permissions, reason)
            
            // Log activity
            logUserActivity(
                userId = userId,
                action = ActivityAction.PERMISSION_GRANT,
                resource = "User",
                resourceId = userId,
                details = mapOf(
                    "permissions" to permissions.map { it.name },
                    "reason" to reason
                )
            )
            
            result
        } catch (e: Exception) {
            Result.Error(e)
        }
    }
    
    private suspend fun logUserActivity(
        userId: String,
        action: ActivityAction,
        resource: String?,
        resourceId: String?,
        details: Map<String, Any>
    ) {
        val activityLog = UserActivityLog(
            id = java.util.UUID.randomUUID().toString(),
            userId = userId,
            action = action,
            resource = resource,
            resourceId = resourceId,
            details = details,
            ipAddress = null,
            userAgent = null,
            deviceId = null,
            location = null,
            timestamp = System.currentTimeMillis(),
            sessionId = null,
            success = true,
            errorMessage = null
        )
        
        userRepository.logUserActivity(activityLog)
    }
}

