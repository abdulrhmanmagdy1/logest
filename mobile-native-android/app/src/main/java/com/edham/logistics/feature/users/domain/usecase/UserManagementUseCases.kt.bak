@Singleton
class ChangeUserRoleUseCase @Inject constructor(
    private val userRepository: UserRepository
) {
    suspend operator fun invoke(userId: String, newRole: UserRole, reason: String): Result<User> {
        return try {
            // Get user
            val userResult = userRepository.getUserById(userId)
            val user = when (userResult) {
                is Result.Success -> userResult.data
                is Result.Error -> throw userResult.exception
            }
            
            // Validate role change
            validateRoleChange(user, newRole)
            
            // Change role
            val updatedUser = userRepository.changeUserRole(userId, newRole, reason)
            
            // Log activity
            logUserActivity(
                userId = userId,
                action = ActivityAction.ROLE_CHANGE,
                resource = "User",
                resourceId = userId,
                details = mapOf(
                    "oldRole" to user.role.name,
                    "newRole" to newRole.name,
                    "reason" to reason
                )
            )
            
            // Terminate all sessions for security
            userRepository.terminateAllUserSessions(userId)
            
            Result.Success(updatedUser)
        } catch (e: Exception) {
            Result.Error(e)
        }
    }
    
    private fun validateRoleChange(user: User, newRole: UserRole) {
        // Prevent self-role change
        if (user.id == "current_user_id") { // Would get from context
            throw IllegalArgumentException("Cannot change your own role")
        }
        
        // Prevent role downgrade for certain conditions
        if (user.role.level > newRole.level) {
            // Additional validation logic
        }
    }
    
    private suspend fun logUserActivity(
        userId: String,
        action: ActivityAction,
        resource: String?,
        resourceId: String?,
        details: Map<String, Any>
    ) {
        val activityLog = UserActivityLog(
            id = java.util.UUID.randomUUID().toString(),
            userId = userId,
            action = action,
            resource = resource,
            resourceId = resourceId,
            details = details,
            ipAddress = null,
            userAgent = null,
            deviceId = null,
            location = null,
            timestamp = System.currentTimeMillis(),
            sessionId = null,
            success = true,
            errorMessage = null
        )
        
        userRepository.logUserActivity(activityLog)
    }
}

