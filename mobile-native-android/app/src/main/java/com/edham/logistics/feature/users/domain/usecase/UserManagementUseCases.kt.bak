/**
 * User management use cases for comprehensive user and role management
 */
@Singleton
class CreateUserUseCase @Inject constructor(
    private val userRepository: UserRepository
) {
    suspend operator fun invoke(request: CreateUserRequest): Result<User> {
        return try {
            // Validate request
            validateCreateRequest(request)
            
            // Create user
            val user = userRepository.createUser(request)
            
            // Log activity
            logUserActivity(
                userId = user.id,
                action = ActivityAction.CREATE,
                resource = "User",
                resourceId = user.id,
                details = mapOf(
                    "username" to request.username,
                    "email" to request.email,
                    "role" to request.role.name,
                    "createdBy" to "current_user"
                )
            )
            
            Result.Success(user)
        } catch (e: Exception) {
            Result.Error(e)
        }
    }
    
    private suspend fun validateCreateRequest(request: CreateUserRequest) {
        // Check if username exists
        val existingUsername = userRepository.getUserByUsername(request.username)
        if (existingUsername is Result.Success) {
            throw IllegalArgumentException("Username already exists")
        }
        
        // Check if email exists
        val existingEmail = userRepository.getUserByEmail(request.email)
        if (existingEmail is Result.Success) {
            throw IllegalArgumentException("Email already exists")
        }
        
        // Validate phone number if provided
        request.phoneNumber?.let { phone ->
            if (!isValidPhoneNumber(phone)) {
                throw IllegalArgumentException("Invalid phone number")
            }
        }
        
        // Validate password strength
        if (!isPasswordStrong(request.password)) {
            throw IllegalArgumentException("Password does not meet security requirements")
        }
    }
    
    private fun isValidPhoneNumber(phone: String): Boolean {
        return phone.matches(Regex("^[+]?[1-9][\\d]{0,15}$"))
    }
    
    private fun isPasswordStrong(password: String): Boolean {
        return password.length >= 8 &&
               password.any { it.isUpperCase() } &&
               password.any { it.isLowerCase() } &&
               password.any { it.isDigit() } &&
               password.any { !it.isLetterOrDigit() }
    }
    
    private suspend fun logUserActivity(
        userId: String,
        action: ActivityAction,
        resource: String?,
        resourceId: String?,
        details: Map<String, Any>
    ) {
        val activityLog = UserActivityLog(
            id = java.util.UUID.randomUUID().toString(),
            userId = userId,
            action = action,
            resource = resource,
            resourceId = resourceId,
            details = details,
            ipAddress = null,
            userAgent = null,
            deviceId = null,
            location = null,
            timestamp = System.currentTimeMillis(),
            sessionId = null,
            success = true,
            errorMessage = null
        )
        
        userRepository.logUserActivity(activityLog)
    }
}

@Singleton
class UpdateUserUseCase @Inject constructor(
    private val userRepository: UserRepository
) {
    suspend operator fun invoke(request: UpdateUserRequest): Result<User> {
        return try {
            // Validate request
            validateUpdateRequest(request)
            
            // Get existing user
            val existingUserResult = userRepository.getUserById(request.id)
            val existingUser = when (existingUserResult) {
                is Result.Success -> existingUserResult.data
                is Result.Error -> throw existingUserResult.exception
            }
            
            // Update user
            val updatedUser = userRepository.updateUser(request)
            
            // Log changes
            logUserChanges(existingUser, updatedUser)
            
            Result.Success(updatedUser)
        } catch (e: Exception) {
            Result.Error(e)
        }
    }
    
    private suspend fun validateUpdateRequest(request: UpdateUserRequest) {
        // Check if user exists
        val userResult = userRepository.getUserById(request.id)
        if (userResult is Result.Error) {
            throw IllegalArgumentException("User not found")
        }
        
        // Validate username if changed
        request.username?.let { username ->
            val existingUsername = userRepository.getUserByUsername(username)
            if (existingUsername is Result.Success && existingUsername.data.id != request.id) {
                throw IllegalArgumentException("Username already exists")
            }
        }
        
        // Validate email if changed
        request.email?.let { email ->
            val existingEmail = userRepository.getUserByEmail(email)
            if (existingEmail is Result.Success && existingEmail.data.id != request.id) {
                throw IllegalArgumentException("Email already exists")
            }
        }
        
        // Validate phone number if provided
        request.phoneNumber?.let { phone ->
            if (!isValidPhoneNumber(phone)) {
                throw IllegalArgumentException("Invalid phone number")
            }
        }
    }
    
    private suspend fun logUserChanges(oldUser: User, newUser: User) {
        val changes = mutableMapOf<String, Any>()
        
        if (oldUser.username != newUser.username) {
            changes["username"] = mapOf("old" to oldUser.username, "new" to newUser.username)
        }
        if (oldUser.email != newUser.email) {
            changes["email"] = mapOf("old" to oldUser.email, "new" to newUser.email)
        }
        if (oldUser.firstName != newUser.firstName) {
            changes["firstName"] = mapOf("old" to oldUser.firstName, "new" to newUser.firstName)
        }
        if (oldUser.lastName != newUser.lastName) {
            changes["lastName"] = mapOf("old" to oldUser.lastName, "new" to newUser.lastName)
        }
        if (oldUser.role != newUser.role) {
            changes["role"] = mapOf("old" to oldUser.role.name, "new" to newUser.role.name)
        }
        if (oldUser.status != newUser.status) {
            changes["status"] = mapOf("old" to oldUser.status.name, "new" to newUser.status.name)
        }
        if (oldUser.isActive != newUser.isActive) {
            changes["isActive"] = mapOf("old" to oldUser.isActive, "new" to newUser.isActive)
        }
        
        if (changes.isNotEmpty()) {
            logUserActivity(
                userId = newUser.id,
                action = ActivityAction.UPDATE,
                resource = "User",
                resourceId = newUser.id,
                details = changes
            )
        }
    }
    
    private suspend fun logUserActivity(
        userId: String,
        action: ActivityAction,
        resource: String?,
        resourceId: String?,
        details: Map<String, Any>
    ) {
        val activityLog = UserActivityLog(
            id = java.util.UUID.randomUUID().toString(),
            userId = userId,
            action = action,
            resource = resource,
            resourceId = resourceId,
            details = details,
            ipAddress = null,
            userAgent = null,
            deviceId = null,
            location = null,
            timestamp = System.currentTimeMillis(),
            sessionId = null,
            success = true,
            errorMessage = null
        )
        
        userRepository.logUserActivity(activityLog)
    }
}

@Singleton
class DisableUserUseCase @Inject constructor(
    private val userRepository: UserRepository
) {
    suspend operator fun invoke(userId: String, reason: String): Result<User> {
        return try {
            // Get user
            val userResult = userRepository.getUserById(userId)
            val user = when (userResult) {
                is Result.Success -> userResult.data
                is Result.Error -> throw userResult.exception
            }
            
            // Check if user can be disabled
            if (user.role == UserRole.ADMIN) {
                throw IllegalArgumentException("Cannot disable admin users")
            }
            
            // Disable user
            val disabledUser = userRepository.disableUser(userId, reason)
            
            // Log activity
            logUserActivity(
                userId = userId,
                action = ActivityAction.DISABLE,
                resource = "User",
                resourceId = userId,
                details = mapOf(
                    "reason" to reason,
                    "previousStatus" to user.status.name
                )
            )
            
            // Terminate all sessions
            userRepository.terminateAllUserSessions(userId)
            
            Result.Success(disabledUser)
        } catch (e: Exception) {
            Result.Error(e)
        }
    }
    
    private suspend fun logUserActivity(
        userId: String,
        action: ActivityAction,
        resource: String?,
        resourceId: String?,
        details: Map<String, Any>
    ) {
        val activityLog = UserActivityLog(
            id = java.util.UUID.randomUUID().toString(),
            userId = userId,
            action = action,
            resource = resource,
            resourceId = resourceId,
            details = details,
            ipAddress = null,
            userAgent = null,
            deviceId = null,
            location = null,
            timestamp = System.currentTimeMillis(),
            sessionId = null,
            success = true,
            errorMessage = null
        )
        
        userRepository.logUserActivity(activityLog)
    }
}

