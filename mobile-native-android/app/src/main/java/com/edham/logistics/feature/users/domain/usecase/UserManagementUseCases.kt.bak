@Singleton
class BulkUserOperationUseCase @Inject constructor(
    private val userRepository: UserRepository
) {
    suspend operator fun invoke(operation: BulkUserOperation): Result<BulkOperationResult> {
        return try {
            val results = mutableListOf<UserOperationResult>()
            val errors = mutableListOf<String>()
            var successCount = 0
            
            operation.userIds.forEach { userId ->
                try {
                    val result = performOperation(userId, operation)
                    results.add(result)
                    if (result.success) {
                        successCount++
                    } else {
                        errors.add("User $userId: ${result.error}")
                    }
                } catch (e: Exception) {
                    results.add(UserOperationResult(userId, false, e.message))
                    errors.add("User $userId: ${e.message}")
                }
            }
            
            val bulkResult = BulkOperationResult(
                operation = operation.operation,
                totalUsers = operation.userIds.size,
                successfulUsers = successCount,
                failedUsers = operation.userIds.size - successCount,
                results = results,
                errors = errors
            )
            
            // Log bulk operation
            logBulkOperation(operation, bulkResult)
            
            Result.Success(bulkResult)
        } catch (e: Exception) {
            Result.Error(e)
        }
    }
    
    private suspend fun performOperation(userId: String, operation: BulkUserOperation): UserOperationResult {
        return when (operation.operation) {
            BulkOperationType.ENABLE -> {
                val result = userRepository.enableUser(userId, "Bulk enable operation")
                UserOperationResult(userId, result is Result.Success, if (result is Result.Error) result.exception.message else null)
            }
            BulkOperationType.DISABLE -> {
                val result = userRepository.disableUser(userId, "Bulk disable operation")
                UserOperationResult(userId, result is Result.Success, if (result is Result.Error) result.exception.message else null)
            }
            BulkOperationType.SUSPEND -> {
                val result = userRepository.suspendUser(userId, "Bulk suspend operation")
                UserOperationResult(userId, result is Result.Success, if (result is Result.Error) result.exception.message else null)
            }
            BulkOperationType.UNSUSPEND -> {
                val result = userRepository.unsuspendUser(userId, "Bulk unsuspend operation")
                UserOperationResult(userId, result is Result.Success, if (result is Result.Error) result.exception.message else null)
            }
            BulkOperationType.LOCK -> {
                val result = userRepository.lockUser(userId, "Bulk lock operation")
                UserOperationResult(userId, result is Result.Success, if (result is Result.Error) result.exception.message else null)
            }
            BulkOperationType.UNLOCK -> {
                val result = userRepository.unlockUser(userId, "Bulk unlock operation")
                UserOperationResult(userId, result is Result.Success, if (result is Result.Error) result.exception.message else null)
            }
            BulkOperationType.DELETE -> {
                val result = userRepository.deleteUser(userId, "Bulk delete operation")
                UserOperationResult(userId, result is Result.Success, if (result is Result.Error) result.exception.message else null)
            }
            BulkOperationType.ROLE_CHANGE -> {
                val newRole = operation.parameters?.get("role") as? UserRole
                if (newRole != null) {
                    val result = userRepository.changeUserRole(userId, newRole, "Bulk role change operation")
                    UserOperationResult(userId, result is Result.Success, if (result is Result.Error) result.exception.message else null)
                } else {
                    UserOperationResult(userId, false, "Role not specified")
                }
            }
            BulkOperationType.PASSWORD_RESET -> {
                val result = userRepository.resetUserPassword(userId, "Bulk password reset")
                UserOperationResult(userId, result is Result.Success, if (result is Result.Error) result.exception.message else null)
            }
            BulkOperationType.EMAIL_VERIFY -> {
                val result = userRepository.verifyUserEmail(userId)
                UserOperationResult(userId, result is Result.Success, if (result is Result.Error) result.exception.message else null)
            }
            BulkOperationType.PHONE_VERIFY -> {
                val result = userRepository.verifyUserPhone(userId)
                UserOperationResult(userId, result is Result.Success, if (result is Result.Error) result.exception.message else null)
            }
            else -> {
                UserOperationResult(userId, false, "Unsupported operation")
            }
        }
    }
    
    private suspend fun logBulkOperation(operation: BulkUserOperation, result: BulkOperationResult) {
        val activityLog = UserActivityLog(
            id = java.util.UUID.randomUUID().toString(),
            userId = "system",
            action = ActivityAction.SYSTEM_ACCESS,
            resource = "BulkOperation",
            resourceId = null,
            details = mapOf(
                "operation" to operation.operation.name,
                "totalUsers" to operation.userIds.size,
                "successfulUsers" to result.successfulUsers,
                "failedUsers" to result.failedUsers
            ),
            ipAddress = null,
            userAgent = null,
            deviceId = null,
            location = null,
            timestamp = System.currentTimeMillis(),
            sessionId = null,
            success = result.failedUsers == 0,
            errorMessage = if (result.errors.isNotEmpty()) result.errors.joinToString("; ") else null
        )
        
        userRepository.logUserActivity(activityLog)
    }
}

