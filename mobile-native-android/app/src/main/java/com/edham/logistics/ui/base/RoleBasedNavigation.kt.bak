package com.edham.logistics.ui.base

import android.os.Bundle
import androidx.fragment.app.Fragment
import com.edham.logistics.*

enum class UserRole {
    ADMIN,
    DRIVER,
    ACCOUNTANT,
    SUPERVISOR,
    WORKSHOP,
    CUSTOMER
}

class RoleBasedNavigation {
    
    companion object {
        fun getNavigationItems(role: UserRole): List<NavigationItem> {
            return when (role) {
                UserRole.ADMIN -> getAdminNavigation()
                UserRole.DRIVER -> getDriverNavigation()
                UserRole.ACCOUNTANT -> getAccountantNavigation()
                UserRole.SUPERVISOR -> getSupervisorNavigation()
                UserRole.WORKSHOP -> getWorkshopNavigation()
                UserRole.CUSTOMER -> getCustomerNavigation()
            }
        }
        
        fun getDashboardFragment(role: UserRole): Fragment {
            return when (role) {
                UserRole.ADMIN -> AdminDashboardFragment()
                UserRole.DRIVER -> DriverDashboardFragment()
                UserRole.ACCOUNTANT -> AdminDashboardFragment() // Temporarily use admin dashboard
                UserRole.SUPERVISOR -> AdminDashboardFragment() // Temporarily use admin dashboard
                UserRole.WORKSHOP -> AdminDashboardFragment() // Temporarily use admin dashboard
                UserRole.CUSTOMER -> AdminDashboardFragment() // Temporarily use admin dashboard
            }
        }
        
        private fun getAdminNavigation(): List<NavigationItem> {
            return listOf(
                NavigationItem("لوحة التحكم", R.drawable.ic_logo_white, AdminDashboardFragment::class.java),
                NavigationItem("الشحنات", R.drawable.ic_logo_white, LoadsFragment::class.java),
                NavigationItem("الفواتير", R.drawable.ic_logo_white, InvoicesFragment::class.java),
                NavigationItem("الصيانة", R.drawable.ic_logo_white, MaintenanceFragment::class.java),
                NavigationItem("السائقين", R.drawable.ic_logo_white, DriversFragment::class.java),
                NavigationItem("مراقبة التبريد", R.drawable.ic_logo_white, ColdChainFragment::class.java),
                NavigationItem("الإشعارات", R.drawable.ic_logo_white, NotificationsFragment::class.java),
                NavigationItem("الملف الشخصي", R.drawable.ic_logo_white, ProfileFragment::class.java)
            )
        }
        
        private fun getDriverNavigation(): List<NavigationItem> {
            return listOf(
                NavigationItem("لوحة التحكم", R.drawable.ic_logo_white, DriverDashboardFragment::class.java),
                NavigationItem("رحلاتي", R.drawable.ic_logo_white, LoadsFragment::class.java),
                NavigationItem("التتبع", R.drawable.ic_logo_white, TrackingFragment::class.java),
                NavigationItem("الإشعارات", R.drawable.ic_logo_white, NotificationsFragment::class.java),
                NavigationItem("الملف الشخصي", R.drawable.ic_logo_white, ProfileFragment::class.java)
            )
        }
        
        private fun getAccountantNavigation(): List<NavigationItem> {
            return listOf(
                NavigationItem("لوحة التحكم", R.drawable.ic_logo_white, AdminDashboardFragment::class.java),
                NavigationItem("الفواتير", R.drawable.ic_logo_white, InvoicesFragment::class.java),
                NavigationItem("المدفوعات", R.drawable.ic_logo_white, InvoicesFragment::class.java),
                NavigationItem("التقارير", R.drawable.ic_logo_white, InvoicesFragment::class.java),
                NavigationItem("الملف الشخصي", R.drawable.ic_logo_white, ProfileFragment::class.java)
            )
        }
        
        private fun getSupervisorNavigation(): List<NavigationItem> {
            return listOf(
                NavigationItem("لوحة التحكم", R.drawable.ic_logo_white, AdminDashboardFragment::class.java),
                NavigationItem("الشحنات", R.drawable.ic_logo_white, LoadsFragment::class.java),
                NavigationItem("السائقين", R.drawable.ic_logo_white, DriversFragment::class.java),
                NavigationItem("التتبع", R.drawable.ic_logo_white, TrackingFragment::class.java),
                NavigationItem("الإشعارات", R.drawable.ic_logo_white, NotificationsFragment::class.java),
                NavigationItem("الملف الشخصي", R.drawable.ic_logo_white, ProfileFragment::class.java)
            )
        }
        
        private fun getWorkshopNavigation(): List<NavigationItem> {
            return listOf(
                NavigationItem("لوحة التحكم", R.drawable.ic_logo_white, AdminDashboardFragment::class.java),
                NavigationItem("الصيانة", R.drawable.ic_logo_white, MaintenanceFragment::class.java),
                NavigationItem("المركبات", R.drawable.ic_logo_white, DriversFragment::class.java),
                NavigationItem("قطع الغيار", R.drawable.ic_logo_white, MaintenanceFragment::class.java),
                NavigationItem("الملف الشخصي", R.drawable.ic_logo_white, ProfileFragment::class.java)
            )
        }
        
        private fun getCustomerNavigation(): List<NavigationItem> {
            return listOf(
                NavigationItem("الرئيسية", R.drawable.ic_logo_white, AdminDashboardFragment::class.java),
                NavigationItem("طلب شحنة", R.drawable.ic_logo_white, CreateShipmentFragment::class.java),
                NavigationItem("شحناتي", R.drawable.ic_logo_white, LoadsFragment::class.java),
                NavigationItem("التتبع", R.drawable.ic_logo_white, TrackingFragment::class.java),
                NavigationItem("الملف الشخصي", R.drawable.ic_logo_white, ProfileFragment::class.java)
            )
        }
    }
}

data class NavigationItem(
    val title: String,
    val icon: Int,
    val fragmentClass: Class<out Fragment>
)
