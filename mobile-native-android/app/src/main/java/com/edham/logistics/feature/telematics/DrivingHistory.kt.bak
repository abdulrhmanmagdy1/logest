    }
}

data class TrendAnalytics(
    val trend: Trend,
    val scoreChange: Double,
    val scoreChangePercentage: Double,
    val weeklyAverage: List<Double>
) {
    enum class Trend {
        IMPROVING,
        DECLINING,
        STABLE
    }
    
    companion object {
        fun createEmpty(): TrendAnalytics {
            return TrendAnalytics(
                trend = Trend.STABLE,
                scoreChange = 0.0,
                scoreChangePercentage = 0.0,
                weeklyAverage = emptyList()
            )
        }
    }
}

data class DrivingPatterns(
    val driverId: String,
    val timePatterns: TimePatterns,
    val routePatterns: RoutePatterns,
    val behaviorPatterns: BehaviorPatterns,
    val seasonalPatterns: SeasonalPatterns,
    val timeWindow: TimeWindow,
    val analyzedAt: LocalDateTime,
    val errorMessage: String? = null
) {
    companion object {
        fun createEmpty(driverId: String, timeWindow: TimeWindow): DrivingPatterns {
            return DrivingPatterns(
                driverId = driverId,
                timePatterns = TimePatterns.createEmpty(),
                routePatterns = RoutePatterns.createEmpty(),
                behaviorPatterns = BehaviorPatterns.createEmpty(),
                seasonalPatterns = SeasonalPatterns.createEmpty(),
                timeWindow = timeWindow,
                analyzedAt = LocalDateTime.now()
            )
        }
        
        fun createError(driverId: String, timeWindow: TimeWindow): DrivingPatterns {
            return DrivingPatterns(
                driverId = driverId,
                timePatterns = TimePatterns.createEmpty(),
                routePatterns = RoutePatterns.createEmpty(),
                behaviorPatterns = BehaviorPatterns.createEmpty(),
                seasonalPatterns = SeasonalPatterns.createEmpty(),
                timeWindow = timeWindow,
                analyzedAt = LocalDateTime.now(),
                errorMessage = "Error analyzing driving patterns"
            )
        }
    }
}

data class TimePatterns(
    val peakDrivingHour: Int,
    val peakDrivingDay: Int,
    val preferredDrivingTimes: List<String>
) {
    companion object {
        fun createEmpty(): TimePatterns {
            return TimePatterns(
                peakDrivingHour = 0,
                peakDrivingDay = 1,
                preferredDrivingTimes = emptyList()
            )
        }
    }
}

data class RoutePatterns(
    val mostFrequentRoutes: List<String>,
    val averageRouteLength: Double,
    val routeConsistency: Double
) {
    companion object {
        fun createEmpty(): RoutePatterns {
            return RoutePatterns(
                mostFrequentRoutes = emptyList(),
                averageRouteLength = 0.0,
                routeConsistency = 0.0
            )
        }
    }
}

data class BehaviorPatterns(
    val averageEventsPerTrip: Double,
    val mostCommonViolation: String,
    val riskLevel: RiskLevel
) {
    enum class RiskLevel {
        LOW,
        MEDIUM,
        HIGH,
        VERY_HIGH
    }
    
    companion object {
        fun createEmpty(): BehaviorPatterns {
            return BehaviorPatterns(
                averageEventsPerTrip = 0.0,
                mostCommonViolation = "None",
                riskLevel = RiskLevel.LOW
            )
        }
    }
}

data class SeasonalPatterns(
    val seasonalVariations: Map<String, Double>,
    val weatherImpact: Map<String, Double>,
    val holidayPatterns: Map<String, Int>
) {
    companion object {
        fun createEmpty(): SeasonalPatterns {
            return SeasonalPatterns(
                seasonalVariations = emptyMap(),
                weatherImpact = emptyMap(),
                holidayPatterns = emptyMap()
            )
        }
    }
}
