package com.edham.logistics.adapters

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.ImageView
import android.widget.TextView
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.domain.model.Shipment

class ShipmentManagementAdapter(
    private var shipments: List<Shipment>,
    private val onShipmentClick: (Shipment) -> Unit
) : RecyclerView.Adapter<ShipmentManagementAdapter.ShipmentViewHolder>() {

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): ShipmentViewHolder {
        val view = LayoutInflater.from(parent.context)
            .inflate(R.layout.item_shipment_management, parent, false)
        return ShipmentViewHolder(view)
    }

    override fun onBindViewHolder(holder: ShipmentViewHolder, position: Int) {
        holder.bind(shipments[position])
    }

    override fun getItemCount(): Int = shipments.size

    fun updateShipments(newShipments: List<Shipment>) {
        shipments = newShipments
        notifyDataSetChanged()
    }

    inner class ShipmentViewHolder(itemView: View) : RecyclerView.ViewHolder(itemView) {
        private val tvShipmentId: TextView = itemView.findViewById(R.id.tvShipmentId)
        private val tvOrigin: TextView = itemView.findViewById(R.id.tvOrigin)
        private val tvDestination: TextView = itemView.findViewById(R.id.tvDestination)
        private val tvStatus: TextView = itemView.findViewById(R.id.tvStatus)
        private val tvDriverName: TextView = itemView.findViewById(R.id.tvDriverName)
        private val tvVehicleNumber: TextView = itemView.findViewById(R.id.tvVehicleNumber)
        private val tvTime: TextView = itemView.findViewById(R.id.tvTime)
        private val ivStatusIcon: ImageView = itemView.findViewById(R.id.ivStatusIcon)

        fun bind(shipment: Shipment) {
            tvShipmentId.text = shipment.id
            tvOrigin.text = shipment.origin
            tvDestination.text = shipment.destination
            tvStatus.text = shipment.status
            tvDriverName.text = shipment.driverName
            tvVehicleNumber.text = shipment.vehicleNumber
            tvTime.text = shipment.time

            // Set status icon and color
            when (shipment.status) {
                "نشط" -> {
                    ivStatusIcon.setImageResource(R.drawable.circle_blue)
                    tvStatus.setTextColor(itemView.context.getColor(R.color.supervisor_info))
                }
                "قيد التوصيل" -> {
                    ivStatusIcon.setImageResource(R.drawable.circle_warning)
                    tvStatus.setTextColor(itemView.context.getColor(R.color.supervisor_warning))
                }
                "تم التسليم" -> {
                    ivStatusIcon.setImageResource(R.drawable.circle_green)
                    tvStatus.setTextColor(itemView.context.getColor(R.color.supervisor_success))
                }
                "متأخرة" -> {
                    ivStatusIcon.setImageResource(R.drawable.circle_red)
                    tvStatus.setTextColor(itemView.context.getColor(R.color.supervisor_error))
                }
                else -> {
                    ivStatusIcon.setImageResource(R.drawable.circle_grey)
                    tvStatus.setTextColor(itemView.context.getColor(R.color.text_secondary))
                }
            }

            itemView.setOnClickListener {
                onShipmentClick(shipment)
            }
        }
    }
}
