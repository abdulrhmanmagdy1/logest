package com.edham.logistics.feature.dispatch.adapters

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.ImageView
import android.widget.TextView
import androidx.recyclerview.widget.DiffUtil
import androidx.recyclerview.widget.ListAdapter
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.data.model.Driver
import com.edham.logistics.utils.GlideUtils

/**
 * Driver Card Adapter for dispatch board
 * Shows available drivers with drag support
 */
class DriverCardAdapter(
    private val onDriverAction: (Driver, String) -> Unit
) : ListAdapter<Driver, DriverCardAdapter.DriverViewHolder>(DriverDiffCallback()) {
    
    private var onDragListener: ((View, Driver) -> Unit)? = null
    
    fun setOnDragListener(listener: (View, Driver) -> Unit) {
        onDragListener = listener
    }
    
    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): DriverViewHolder {
        val view = LayoutInflater.from(parent.context)
            .inflate(R.layout.item_driver_card_dispatch, parent, false)
        return DriverViewHolder(view)
    }
    
    override fun onBindViewHolder(holder: DriverViewHolder, position: Int) {
        val driver = getItem(position)
        holder.bind(driver, onDragListener)
    }
    
    override fun getItemCount(): Int = currentList.size
    
    class DriverViewHolder(itemView: View) : RecyclerView.ViewHolder(itemView) {
        private val imageDriver: ImageView = itemView.findViewById(R.id.imageDriver)
        private val textDriverName: TextView = itemView.findViewById(R.id.textDriverName)
        private val textDriverStatus: TextView = itemView.findViewById(R.id.textDriverStatus)
        private val textVehicleInfo: TextView = itemView.findViewById(R.id.textVehicleInfo)
        private val textActiveShipments: TextView = itemView.findViewById(R.id.textActiveShipments)
        private val textRating: TextView = itemView.findViewById(R.id.textRating)
        private val textLocation: TextView = itemView.findViewById(R.id.textLocation)
        private val layoutActions: ViewGroup = itemView.findViewById(R.id.layoutActions)
        
        fun bind(driver: Driver, onDragListener: ((View, Driver) -> Unit)?) {
            // Set tag for drag identification
            itemView.tag = driver
            itemView.id = View.generateViewId()
            
            // Load driver image
            GlideUtils.loadDriverImage(imageDriver, driver.photoUrl)
            
            // Set driver info
            textDriverName.text = driver.name
            textVehicleInfo.text = "${driver.vehicle?.make} ${driver.vehicle?.model}"
            textRating.text = "⭐ %.1f".format(driver.rating ?: 0.0)
            
            // Set status with appropriate color
            val statusText = when (driver.status) {
                Driver.Status.AVAILABLE -> "متاح"
                Driver.Status.BUSY -> "مشغول"
                Driver.Status.OFF_DUTY -> "خارج الدوام"
                Driver.Status.BREAK -> "في استراحة"
                else -> "غير معروف"
            }
            
            val statusColor = when (driver.status) {
                Driver.Status.AVAILABLE -> R.color.driver_available
                Driver.Status.BUSY -> R.color.driver_busy
                Driver.Status.OFF_DUTY -> R.color.driver_off_duty
                Driver.Status.BREAK -> R.color.driver_break
                else -> R.color.gray_500
            }
            
            textDriverStatus.text = statusText
            textDriverStatus.setTextColor(itemView.context.getColor(statusColor))
            
            // Set active shipments count
            textActiveShipments.text = "${driver.activeShipments ?: 0}/${driver.maxConcurrentShipments}"
            
            // Set location
            textLocation.text = if (driver.currentLocation != null) {
                "📍 ${driver.currentLocation?.latitude}, ${driver.currentLocation?.longitude}"
            } else {
                "📍 غير متاح"
            }
            
            // Setup drag functionality
            itemView.setOnLongClickListener {
                onDragListener?.invoke(itemView, driver)
                true
            }
            
            // Setup action buttons
            setupActionButtons(driver)
        }
        
        private fun setupActionButtons(driver: Driver) {
            // Clear existing action buttons
            layoutActions.removeAllViews()
            
            // Add action buttons based on driver status
            when (driver.status) {
                Driver.Status.AVAILABLE -> {
                    addActionButton("تعيين شحنة", "ASSIGN_SHIPMENT")
                    addActionButton("تفاصيل", "VIEW_DETAILS")
                }
                
                Driver.Status.BUSY -> {
                    addActionButton("عرض المهام", "VIEW_TASKS")
                    addActionButton("موقع", "VIEW_LOCATION")
                }
                
                else -> {
                    addActionButton("تفاصيل", "VIEW_DETAILS")
                }
            }
        }
        
        private fun addActionButton(text: String, action: String) {
            val button = android.widget.Button(itemView.context).apply {
                setText(text)
                setTextColor(itemView.context.getColor(R.color.white))
                setBackgroundColor(itemView.context.getColor(R.color.primary))
                layoutParams = ViewGroup.LayoutParams(
                    ViewGroup.LayoutParams.WRAP_CONTENT,
                    ViewGroup.LayoutParams.WRAP_CONTENT
                ).apply {
                    setMargins(8, 0, 8, 0)
                }
                
                setOnClickListener {
                    // This would be handled by parent fragment
                    onDriverAction.invoke(getItem(bindingAdapterPosition), action)
                }
            }
            
            layoutActions.addView(button)
        }
    }
    
    private class DriverDiffCallback : DiffUtil.ItemCallback<Driver>() {
        override fun areItemsTheSame(oldItem: Driver, newItem: Driver): Boolean {
            return oldItem.id == newItem.id
        }
        
        override fun areContentsTheSame(oldItem: Driver, newItem: Driver): Boolean {
            return oldItem == newItem
        }
    }
}
