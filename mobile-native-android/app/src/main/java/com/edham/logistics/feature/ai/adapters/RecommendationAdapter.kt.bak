package com.edham.logistics.feature.ai.adapters

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.ImageView
import android.widget.TextView
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.feature.ai.FuelOptimization
import com.edham.logistics.feature.ai.DriverBehaviorAnalysis
import com.edham.logistics.feature.ai.ShipmentRiskAnalysis
import java.text.SimpleDateFormat
import java.util.*

class RecommendationAdapter(
    private val onRecommendationClick: (Any) -> Unit
) : RecyclerView.Adapter<RecommendationAdapter.ViewHolder>() {
    
    private var recommendations = mutableListOf<Any>()
    private val timeFormat = SimpleDateFormat("HH:mm", Locale.getDefault())
    
    fun updateRecommendations(newRecommendations: List<Any>) {
        recommendations.clear()
        recommendations.addAll(newRecommendations)
        notifyDataSetChanged()
    }
    
    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): ViewHolder {
        val view = LayoutInflater.from(parent.context).inflate(R.layout.item_recommendation, parent, false)
        return ViewHolder(view)
    }
    
    override fun onBindViewHolder(holder: ViewHolder, position: Int) {
        holder.bind(recommendations[position])
    }
    
    override fun getItemCount(): Int = recommendations.size
    
    inner class ViewHolder(itemView: View) : RecyclerView.ViewHolder(itemView) {
        private val recommendationIcon: ImageView = itemView.findViewById(R.id.recommendationIcon)
        private val recommendationType: TextView = itemView.findViewById(R.id.recommendationType)
        private val recommendationTitle: TextView = itemView.findViewById(R.id.recommendationTitle)
        private val recommendationValue: TextView = itemView.findViewById(R.id.recommendationValue)
        private val recommendationImpact: TextView = itemView.findViewById(R.id.recommendationImpact)
        private val recommendationTime: TextView = itemView.findViewById(R.id.recommendationTime)
        private val recommendationStatus: TextView = itemView.findViewById(R.id.recommendationStatus)
        private val typeIndicator: View = itemView.findViewById(R.id.typeIndicator)
        
        fun bind(recommendation: Any) {
            when (recommendation) {
                is FuelOptimization -> bindFuelOptimization(recommendation)
                is DriverBehaviorAnalysis -> bindDriverBehavior(recommendation)
                is ShipmentRiskAnalysis -> bindRiskAnalysis(recommendation)
            }
            
            // Set click listener
            itemView.setOnClickListener {
                onRecommendationClick(recommendation)
            }
        }
        
        private fun bindFuelOptimization(optimization: FuelOptimization) {
            val (iconRes, typeText, colorRes) = when {
                optimization.potentialSavings > 15.0 -> Triple(R.drawable.ic_fuel_high, "FUEL", R.color.recommendation_high)
                optimization.potentialSavings > 8.0 -> Triple(R.drawable.ic_fuel_medium, "FUEL", R.color.recommendation_medium)
                else -> Triple(R.drawable.ic_fuel_low, "FUEL", R.color.recommendation_low)
            }
            
            recommendationIcon.setImageResource(iconRes)
            recommendationIcon.setColorFilter(itemView.context.getColor(colorRes))
            recommendationType.text = typeText
            recommendationTitle.text = "Vehicle ${optimization.vehicleId}"
            recommendationValue.text = "${optimization.potentialSavings.toInt()}% savings"
            recommendationImpact.text = "Efficiency: ${optimization.currentEfficiency.toInt()}%"
            recommendationTime.text = timeFormat.format(Date(optimization.timestamp))
            recommendationStatus.text = if (optimization.fuelEfficiencyIssue) "Issue" else "Good"
            typeIndicator.setBackgroundColor(itemView.context.getColor(colorRes))
            
            // Set background color
            itemView.setBackgroundColor(itemView.context.getColor(R.color.recommendation_fuel_bg))
        }
        
        private fun bindDriverBehavior(analysis: DriverBehaviorAnalysis) {
            val (iconRes, typeText, colorRes) = when {
                analysis.riskScore > 0.7 -> Triple(R.drawable.ic_driver_high, "DRIVER", R.color.recommendation_high)
                analysis.riskScore > 0.4 -> Triple(R.drawable.ic_driver_medium, "DRIVER", R.color.recommendation_medium)
                else -> Triple(R.drawable.ic_driver_low, "DRIVER", R.color.recommendation_low)
            }
            
            recommendationIcon.setImageResource(iconRes)
            recommendationIcon.setColorFilter(itemView.context.getColor(colorRes))
            recommendationType.text = typeText
            recommendationTitle.text = "Driver ${analysis.driverId}"
            recommendationValue.text = "${(analysis.riskScore * 100).toInt()}% risk"
            recommendationImpact.text = "${analysis.improvementAreas.size} areas"
            recommendationTime.text = timeFormat.format(Date(analysis.timestamp))
            recommendationStatus.text = if (analysis.riskScore > 0.7) "High Risk" else "Normal"
            typeIndicator.setBackgroundColor(itemView.context.getColor(colorRes))
            
            // Set background color
            itemView.setBackgroundColor(itemView.context.getColor(R.color.recommendation_driver_bg))
        }
        
        private fun bindRiskAnalysis(analysis: ShipmentRiskAnalysis) {
            val (iconRes, typeText, colorRes) = when {
                analysis.overallRisk > 0.8 -> Triple(R.drawable.ic_risk_high, "RISK", R.color.recommendation_high)
                analysis.overallRisk > 0.5 -> Triple(R.drawable.ic_risk_medium, "RISK", R.color.recommendation_medium)
                else -> Triple(R.drawable.ic_risk_low, "RISK", R.color.recommendation_low)
            }
            
            recommendationIcon.setImageResource(iconRes)
            recommendationIcon.setColorFilter(itemView.context.getColor(colorRes))
            recommendationType.text = typeText
            recommendationTitle.text = "Shipment ${analysis.shipmentId}"
            recommendationValue.text = "${(analysis.overallRisk * 100).toInt()}% risk"
            recommendationImpact.text = "${analysis.mitigationStrategies.size} strategies"
            recommendationTime.text = timeFormat.format(Date(analysis.timestamp))
            recommendationStatus.text = if (analysis.overallRisk > 0.8) "Critical" else "Monitor"
            typeIndicator.setBackgroundColor(itemView.context.getColor(colorRes))
            
            // Set background color
            itemView.setBackgroundColor(itemView.context.getColor(R.color.recommendation_risk_bg))
        }
    }
}
