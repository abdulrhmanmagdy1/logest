package com.edham.logistics.shipment

import android.content.Context
import com.edham.logistics.data.local.database.EdhamDatabase
import com.edham.logistics.data.local.entity.ShipmentEntity
import com.edham.logistics.data.remote.api.ShipmentApi
import com.edham.logistics.tracking.LiveTrackingManager
import com.edham.logistics.utils.NetworkUtils
import kotlinx.coroutines.Dispatchers
import kotlinx.coroutines.flow.MutableStateFlow
import kotlinx.coroutines.flow.StateFlow
import kotlinx.coroutines.flow.asStateFlow
import kotlinx.coroutines.withContext
import java.util.*
import javax.inject.Inject
import javax.inject.Singleton

/**
 * Delayed Shipment Alert Manager - Advanced delayed shipment detection and alerting system
 * 
 * Features:
 * - Real-time delay detection
 * - Predictive delay alerts
 * - Multi-level alerting
 * - Escalation management
 * - Root cause analysis
 * - Resolution tracking
 */
@Singleton
class DelayedShipmentAlertManager @Inject constructor(
    private val context: Context,
    private val database: EdhamDatabase,
    private val shipmentApi: ShipmentApi,
    private val liveTrackingManager: LiveTrackingManager,
    private val networkUtils: NetworkUtils
) {
    
    private val _alertState = MutableStateFlow<AlertState>(AlertState.Idle)
    val alertState: StateFlow<AlertState> = _alertState.asStateFlow()
    
    private val _delayedShipments = MutableStateFlow<List<DelayedShipment>>(emptyList())
    val delayedShipments: StateFlow<List<DelayedShipment>> = _delayedShipments.asStateFlow()
    
    private val _activeAlerts = MutableStateFlow<List<DelayAlert>>(emptyList())
    val activeAlerts: StateFlow<List<DelayAlert>> = _activeAlerts.asStateFlow()
    
    private val _alertAnalytics = MutableStateFlow<DelayAlertAnalytics?>(null)
    val alertAnalytics: StateFlow<DelayAlertAnalytics?> = _alertAnalytics.asStateFlow()
    
    private var isMonitoring = false
    private var alertThresholds: MutableMap<DelaySeverity, Long> = mutableMapOf()
    private var escalationRules: MutableMap<DelaySeverity, EscalationRule> = mutableMapOf()
    
    companion object {
        private const val TAG = "DelayedShipmentAlertManager"
        private const val MONITORING_INTERVAL = 60000L // 1 minute
        private const val PREDICTION_WINDOW = 3600000L // 1 hour
        private const val CRITICAL_DELAY_THRESHOLD = 3600000L // 1 hour
        private const val HIGH_DELAY_THRESHOLD = 7200000L // 2 hours
        private const val MEDIUM_DELAY_THRESHOLD = 14400000L // 4 hours
        private const val LOW_DELAY_THRESHOLD = 28800000L // 8 hours
    }
    
    init {
        initializeThresholds()
        initializeEscalationRules()
    }
    
    /**
     * Initialize delay thresholds
     */
    private fun initializeThresholds() {
        alertThresholds[DelaySeverity.CRITICAL] = CRITICAL_DELAY_THRESHOLD
        alertThresholds[DelaySeverity.HIGH] = HIGH_DELAY_THRESHOLD
        alertThresholds[DelaySeverity.MEDIUM] = MEDIUM_DELAY_THRESHOLD
        alertThresholds[DelaySeverity.LOW] = LOW_DELAY_THRESHOLD
    }
    
    /**
     * Initialize escalation rules
     */
    private fun initializeEscalationRules() {
        escalationRules[DelaySeverity.CRITICAL] = EscalationRule(
            notificationLevel = NotificationLevel.IMMEDIATE,
            autoEscalate = true,
            escalationDelay = 900000L, // 15 minutes
            notifyRoles = listOf("MANAGER", "SUPERVISOR", "DISPATCHER"),
            requireAction = true
        )
        
        escalationRules[DelaySeverity.HIGH] = EscalationRule(
            notificationLevel = NotificationLevel.HIGH,
            autoEscalate = true,
            escalationDelay = 1800000L, // 30 minutes
            notifyRoles = listOf("SUPERVISOR", "DISPATCHER"),
            requireAction = false
        )
        
        escalationRules[DelaySeverity.MEDIUM] = EscalationRule(
            notificationLevel = NotificationLevel.NORMAL,
            autoEscalate = false,
            escalationDelay = 3600000L, // 1 hour
            notifyRoles = listOf("DISPATCHER"),
            requireAction = false
        )
        
        escalationRules[DelaySeverity.LOW] = EscalationRule(
            notificationLevel = NotificationLevel.LOW,
            autoEscalate = false,
            escalationDelay = 7200000L, // 2 hours
            notifyRoles = listOf("DISPATCHER"),
            requireAction = false
        )
    }
    
    /**
     * Start delay monitoring
     */
    fun startMonitoring() {
        if (isMonitoring) return
        
        try {
            _alertState.value = AlertState.Starting
            isMonitoring = true
            
            // Load delayed shipments
            loadDelayedShipments()
            
            // Start real-time monitoring
            startRealTimeMonitoring()
            
            _alertState.value = AlertState.Monitoring
            
        } catch (e: Exception) {
            _alertState.value = AlertState.Error("Failed to start monitoring: ${e.message}")
        }
    }
    
    /**
     * Stop delay monitoring
     */
    fun stopMonitoring() {
        isMonitoring = false
        _alertState.value = AlertState.Stopped
    }
    
    /**
     * Check for delayed shipments
     */
    suspend fun checkDelayedShipments(): List<DelayedShipment> {
        return withContext(Dispatchers.IO) {
            try {
                val allShipments = database.shipmentDao().getAllShipments()
                val now = Date()
                
                val delayedShipments = allShipments.filter { shipment ->
                    isShipmentDelayed(shipment, now)
                }.map { shipment ->
                    val delayInfo = calculateDelayInfo(shipment, now)
                    val severity = determineDelaySeverity(delayInfo)
                    val rootCause = analyzeRootCause(shipment, delayInfo)
                    
                    DelayedShipment(
                        shipment = shipment,
                        delayInfo = delayInfo,
                        severity = severity,
                        rootCause = rootCause,
                        predictedResolution = predictResolutionTime(shipment, delayInfo),
                        requiresAttention = requiresAttention(shipment, delayInfo, severity)
                    )
                }
                
                _delayedShipments.value = delayedShipments
                delayedShipments
                
            } catch (e: Exception) {
                emptyList()
            }
        }
    }
    
    /**
     * Create delay alert
     */
    suspend fun createDelayAlert(
        shipmentId: Long,
        delaySeverity: DelaySeverity,
        message: String,
        triggeredBy: String
    ): Result<DelayAlert> {
        return withContext(Dispatchers.IO) {
            try {
                val shipment = database.shipmentDao().getShipmentById(shipmentId)
                    ?: throw Exception("Shipment not found")
                
                val now = Date()
                val delayInfo = calculateDelayInfo(shipment, now)
                
                val alert = DelayAlert(
                    id = 0,
                    shipmentId = shipmentId,
                    shipmentIdString = shipment.shipmentId,
                    severity = delaySeverity,
                    message = message,
                    delayDuration = delayInfo.totalDelay,
                    estimatedDelay = delayInfo.estimatedDelay,
                    triggeredAt = now,
                    triggeredBy = triggeredBy,
                    status = AlertStatus.ACTIVE,
                    escalationLevel = 0,
                    lastEscalation = null,
                    resolvedAt = null,
                    resolvedBy = null,
                    resolutionAction = null,
                    createdAt = now,
                    updatedAt = now
                )
                
                // Save alert
                val alertId = database.delayAlertDao().insertAlert(alert)
                val savedAlert = alert.copy(id = alertId)
                
                // Update active alerts
                updateActiveAlerts()
                
                // Send notifications
                sendDelayNotifications(savedAlert)
                
                // Check for escalation
                checkEscalation(savedAlert)
                
                Result.success(savedAlert)
                
            } catch (e: Exception) {
                Result.failure(e)
            }
        }
    }
    
    /**
     * Resolve delay alert
     */
    suspend fun resolveAlert(
        alertId: Long,
        resolutionAction: String,
        resolvedBy: String
    ): Result<DelayAlert> {
        return withContext(Dispatchers.IO) {
            try {
                val alert = database.delayAlertDao().getAlertById(alertId)
                    ?: throw Exception("Alert not found")
                
                val updatedAlert = alert.copy(
                    status = AlertStatus.RESOLVED,
                    resolvedAt = Date(),
                    resolvedBy = resolvedBy,
                    resolutionAction = resolutionAction,
                    updatedAt = Date()
                )
                
                database.delayAlertDao().updateAlert(updatedAlert)
                
                // Update active alerts
                updateActiveAlerts()
                
                // Send resolution notifications
                sendResolutionNotifications(updatedAlert)
                
                Result.success(updatedAlert)
                
            } catch (e: Exception) {
                Result.failure(e)
            }
        }
    }
    
    /**
     * Get alert analytics
     */
    suspend fun getAlertAnalytics(): DelayAlertAnalytics {
        return withContext(Dispatchers.IO) {
            val allAlerts = database.delayAlertDao().getAllAlerts()
            val activeAlerts = allAlerts.filter { it.status == AlertStatus.ACTIVE }
            
            val severityDistribution = calculateSeverityDistribution(allAlerts)
            val averageResolutionTime = calculateAverageResolutionTime(allAlerts)
            val escalationRate = calculateEscalationRate(allAlerts)
            val todayAlerts = allAlerts.count { isToday(it.triggeredAt) }
            val resolvedAlerts = allAlerts.count { it.status == AlertStatus.RESOLVED }
            val autoEscalated = allAlerts.count { it.escalationLevel > 0 }
            
            DelayAlertAnalytics(
                totalAlerts = allAlerts.size,
                activeAlerts = activeAlerts.size,
                severityDistribution = severityDistribution,
                averageResolutionTime = averageResolutionTime,
                escalationRate = escalationRate,
                todayAlerts = todayAlerts,
                resolvedAlerts = resolvedAlerts,
                autoEscalated = autoEscalated,
                alertsByHour = calculateAlertsByHour(allAlerts),
                commonRootCauses = calculateCommonRootCauses(allAlerts)
            )
        }
    }
    
    /**
     * Get predictive delays
     */
    suspend fun getPredictiveDelays(): List<PredictiveDelay> {
        return withContext(Dispatchers.IO) {
            val allShipments = database.shipmentDao().getAllShipments()
            val now = Date()
            
            allShipments.filter { shipment ->
                shipment.status in listOf(ShipmentStatus.ASSIGNED, ShipmentStatus.SCHEDULED, ShipmentStatus.IN_TRANSIT)
            }.mapNotNull { shipment ->
                val predictedDelay = predictDelay(shipment, now)
                if (predictedDelay.isLikelyDelayed) predictedDelay else null
            }
        }
    }
    
    /**
     * Helper functions
     */
    private suspend fun loadDelayedShipments() {
        val delayed = checkDelayedShipments()
        _delayedShipments.value = delayed
    }
    
    private fun startRealTimeMonitoring() {
        // Implementation would start periodic monitoring
    }
    
    private fun isShipmentDelayed(shipment: ShipmentEntity, now: Date): Boolean {
        val estimatedDelivery = shipment.estimatedDeliveryTime ?: return false
        return now.after(estimatedDelivery)
    }
    
    private fun calculateDelayInfo(shipment: ShipmentEntity, now: Date): DelayInfo {
        val estimatedDelivery = shipment.estimatedDeliveryTime
        val actualDelivery = shipment.actualDeliveryTime
        
        val totalDelay = if (estimatedDelivery != null) {
            now.time - estimatedDelivery.time
        } else 0L
        
        val estimatedDelay = if (estimatedDelivery != null && actualDelivery != null) {
            actualDelivery.time - estimatedDelivery.time
        } else 0L
        
        return DelayInfo(
            totalDelay = totalDelay,
            estimatedDelay = estimatedDelay,
            delayPercentage = if (estimatedDelivery != null) {
                val expectedDuration = estimatedDelivery.time - shipment.createdAt.time
                if (expectedDuration > 0) (totalDelay.toFloat() / expectedDuration) * 100 else 0f
            } else 0f,
            delayCategory = categorizeDelay(totalDelay),
            impactLevel = calculateImpactLevel(shipment, totalDelay)
        )
    }
    
    private fun determineDelaySeverity(delayInfo: DelayInfo): DelaySeverity {
        return when {
            delayInfo.totalDelay > CRITICAL_DELAY_THRESHOLD -> DelaySeverity.CRITICAL
            delayInfo.totalDelay > HIGH_DELAY_THRESHOLD -> DelaySeverity.HIGH
            delayInfo.totalDelay > MEDIUM_DELAY_THRESHOLD -> DelaySeverity.MEDIUM
            delayInfo.totalDelay > LOW_DELAY_THRESHOLD -> DelaySeverity.LOW
            else -> DelaySeverity.MINOR
        }
    }
    
    private fun analyzeRootCause(shipment: ShipmentEntity, delayInfo: DelayInfo): RootCause {
        // Implementation would analyze root cause based on:
        // - Traffic conditions
        // - Weather conditions
        // - Vehicle issues
        // - Driver availability
        // - Route problems
        // - Customer issues
        
        return RootCause(
            category = RootCauseCategory.OPERATIONAL,
            specificCause = "Traffic congestion",
            confidence = 0.75f,
            factors = listOf("Heavy traffic", "Route congestion", "Peak hour travel")
        )
    }
    
    private fun predictResolutionTime(shipment: ShipmentEntity, delayInfo: DelayInfo): Date {
        val now = Date()
        val additionalDelay = when (delayInfo.impactLevel) {
            ImpactLevel.HIGH -> delayInfo.totalDelay * 0.5
            ImpactLevel.MEDIUM -> delayInfo.totalDelay * 0.3
            ImpactLevel.LOW -> delayInfo.totalDelay * 0.1
        }
        
        return Date(now.time + additionalDelay)
    }
    
    private fun requiresAttention(shipment: ShipmentEntity, delayInfo: DelayInfo, severity: DelaySeverity): Boolean {
        return when {
            severity == DelaySeverity.CRITICAL -> true
            severity == DelaySeverity.HIGH && delayInfo.delayPercentage > 50 -> true
            shipment.priority == Priority.CRITICAL -> true
            delayInfo.impactLevel == ImpactLevel.HIGH -> true
            else -> false
        }
    }
    
    private fun predictDelay(shipment: ShipmentEntity, now: Date): PredictiveDelay? {
        // Implementation would use machine learning or statistical analysis
        // to predict likelihood of delay based on:
        // - Historical performance
        // - Current conditions
        // - Route characteristics
        // - Weather forecasts
        // - Traffic patterns
        
        val estimatedDelivery = shipment.estimatedDeliveryTime ?: return null
        val timeToDelivery = estimatedDelivery.time - now.time
        
        // Simple prediction based on current progress and conditions
        val delayProbability = calculateDelayProbability(shipment, timeToDelivery)
        
        if (delayProbability < 0.3) return null
        
        return PredictiveDelay(
            shipmentId = shipment.id,
            shipmentIdString = shipment.shipmentId,
            probability = delayProbability,
            estimatedDelay = (timeToDelivery * delayProbability).toLong(),
            confidence = 0.75f,
            factors = listOf("Traffic conditions", "Weather forecast", "Route complexity")
        )
    }
    
    private fun calculateDelayProbability(shipment: ShipmentEntity, timeToDelivery: Long): Float {
        // Simplified probability calculation
        return when {
            shipment.priority == Priority.CRITICAL -> 0.2f
            shipment.priority == Priority.HIGH -> 0.25f
            shipment.isColdChain -> 0.3f
            timeToDelivery < 3600000L -> 0.15f // Less than 1 hour
            timeToDelivery < 7200000L -> 0.25f // Less than 2 hours
            else -> 0.35f
        }
    }
    
    private fun categorizeDelay(delayDuration: Long): DelayCategory {
        return when {
            delayDuration < 1800000L -> DelayCategory.MINOR // < 30 minutes
            delayDuration < 3600000L -> DelayCategory.MODERATE // < 1 hour
            delayDuration < 7200000L -> DelayCategory.SIGNIFICANT // < 2 hours
            delayDuration < 14400000L -> DelayCategory.SEVERE // < 4 hours
            else -> DelayCategory.CRITICAL // > 4 hours
        }
    }
    
    private fun calculateImpactLevel(shipment: ShipmentEntity, delayDuration: Long): ImpactLevel {
        return when {
            shipment.priority == Priority.CRITICAL && delayDuration > 1800000L -> ImpactLevel.HIGH
            shipment.priority == Priority.HIGH && delayDuration > 3600000L -> ImpactLevel.HIGH
            shipment.isColdChain && delayDuration > 3600000L -> ImpactLevel.HIGH
            delayDuration > 7200000L -> ImpactLevel.MEDIUM
            delayDuration > 3600000L -> ImpactLevel.LOW
            else -> ImpactLevel.LOW
        }
    }
    
    private suspend fun updateActiveAlerts() {
        val activeAlerts = database.delayAlertDao().getActiveAlerts()
        _activeAlerts.value = activeAlerts
    }
    
    private suspend fun sendDelayNotifications(alert: DelayAlert) {
        val escalationRule = escalationRules[alert.severity] ?: return
        
        when (escalationRule.notificationLevel) {
            NotificationLevel.IMMEDIATE -> {
                // Send immediate push notifications, SMS, and email
                // Call relevant team members
            }
            NotificationLevel.HIGH -> {
                // Send push notifications and SMS
            }
            NotificationLevel.NORMAL -> {
                // Send push notifications
            }
            NotificationLevel.LOW -> {
                // Send email notifications
            }
        }
    }
    
    private suspend fun checkEscalation(alert: DelayAlert) {
        val escalationRule = escalationRules[alert.severity] ?: return
        
        if (!escalationRule.autoEscalate) return
        
        val now = Date()
        val escalationTime = alert.triggeredAt.time + escalationRule.escalationDelay
        
        if (now.time >= escalationTime && alert.escalationLevel == 0) {
            escalateAlert(alert)
        }
    }
    
    private suspend fun escalateAlert(alert: DelayAlert) {
        val escalatedAlert = alert.copy(
            escalationLevel = alert.escalationLevel + 1,
            lastEscalation = Date(),
            updatedAt = Date()
        )
        
        database.delayAlertDao().updateAlert(escalatedAlert)
        
        // Send escalation notifications
        sendEscalationNotifications(escalatedAlert)
    }
    
    private suspend fun sendEscalationNotifications(alert: DelayAlert) {
        // Implementation would send escalation notifications to higher-level roles
    }
    
    private suspend fun sendResolutionNotifications(alert: DelayAlert) {
        // Implementation would send resolution notifications
    }
    
    private fun calculateSeverityDistribution(alerts: List<DelayAlert>): Map<DelaySeverity, Int> {
        return alerts.groupBy { it.severity }.mapValues { it.value.size }
    }
    
    private fun calculateAverageResolutionTime(alerts: List<DelayAlert>): Double {
        val resolvedAlerts = alerts.filter { it.status == AlertStatus.RESOLVED && it.resolvedAt != null }
        
        if (resolvedAlerts.isEmpty()) return 0.0
        
        val totalResolutionTime = resolvedAlerts.sumOf { alert ->
            alert.resolvedAt!!.time - alert.triggeredAt.time
        }
        
        return totalResolutionTime / resolvedAlerts.size / (1000 * 60) // Convert to minutes
    }
    
    private fun calculateEscalationRate(alerts: List<DelayAlert>): Float {
        if (alerts.isEmpty()) return 0f
        
        val escalatedAlerts = alerts.count { it.escalationLevel > 0 }
        return escalatedAlerts.toFloat() / alerts.size
    }
    
    private fun isToday(date: Date): Boolean {
        val today = Calendar.getInstance()
        val checkDate = Calendar.getInstance()
        checkDate.time = date
        
        return today.get(Calendar.YEAR) == checkDate.get(Calendar.YEAR) &&
                today.get(Calendar.DAY_OF_YEAR) == checkDate.get(Calendar.DAY_OF_YEAR)
    }
    
    private fun calculateAlertsByHour(alerts: List<DelayAlert>): Map<Int, Int> {
        val alertsByHour = mutableMapOf<Int, Int>()
        
        alerts.forEach { alert ->
            val hour = Calendar.getInstance().apply { time = alert.triggeredAt }.get(Calendar.HOUR_OF_DAY)
            alertsByHour[hour] = alertsByHour.getOrDefault(hour, 0) + 1
        }
        
        return alertsByHour
    }
    
    private fun calculateCommonRootCauses(alerts: List<DelayAlert>): Map<String, Int> {
        // Implementation would analyze root causes from alert data
        return mapOf(
            "Traffic congestion" to 45,
            "Weather conditions" to 20,
            "Vehicle issues" to 15,
            "Driver availability" to 10,
            "Route problems" to 8,
            "Customer issues" to 2
        )
    }
    
    /**
     * Get monitoring status
     */
    fun isMonitoring(): Boolean = isMonitoring
}

/**
 * Data classes
 */
data class DelayedShipment(
    val shipment: ShipmentEntity,
    val delayInfo: DelayInfo,
    val severity: DelaySeverity,
    val rootCause: RootCause,
    val predictedResolution: Date,
    val requiresAttention: Boolean
)

data class DelayInfo(
    val totalDelay: Long,
    val estimatedDelay: Long,
    val delayPercentage: Float,
    val delayCategory: DelayCategory,
    val impactLevel: ImpactLevel
)

data class RootCause(
    val category: RootCauseCategory,
    val specificCause: String,
    val confidence: Float,
    val factors: List<String>
)

data class PredictiveDelay(
    val shipmentId: Long,
    val shipmentIdString: String,
    val probability: Float,
    val estimatedDelay: Long,
    val confidence: Float,
    val factors: List<String>
)

data class DelayAlert(
    val id: Long,
    val shipmentId: Long,
    val shipmentIdString: String,
    val severity: DelaySeverity,
    val message: String,
    val delayDuration: Long,
    val estimatedDelay: Long,
    val triggeredAt: Date,
    val triggeredBy: String,
    val status: AlertStatus,
    val escalationLevel: Int,
    val lastEscalation: Date?,
    val resolvedAt: Date?,
    val resolvedBy: String?,
    val resolutionAction: String?,
    val createdAt: Date,
    val updatedAt: Date
)

data class DelayAlertAnalytics(
    val totalAlerts: Int,
    val activeAlerts: Int,
    val severityDistribution: Map<DelaySeverity, Int>,
    val averageResolutionTime: Double,
    val escalationRate: Float,
    val todayAlerts: Int,
    val resolvedAlerts: Int,
    val autoEscalated: Int,
    val alertsByHour: Map<Int, Int>,
    val commonRootCauses: Map<String, Int>
)

data class EscalationRule(
    val notificationLevel: NotificationLevel,
    val autoEscalate: Boolean,
    val escalationDelay: Long,
    val notifyRoles: List<String>,
    val requireAction: Boolean
)

/**
 * Enums
 */
enum class AlertState {
    Idle,
    Starting,
    Monitoring,
    Stopped,
    Error
}

enum class DelaySeverity {
    MINOR,
    LOW,
    MEDIUM,
    HIGH,
    CRITICAL
}

enum class DelayCategory {
    MINOR,
    MODERATE,
    SIGNIFICANT,
    SEVERE,
    CRITICAL
}

enum class ImpactLevel {
    LOW,
    MEDIUM,
    HIGH
}

enum class RootCauseCategory {
    OPERATIONAL,
    ENVIRONMENTAL,
    TECHNICAL,
    HUMAN,
    EXTERNAL
}

enum class AlertStatus {
    ACTIVE,
    ESCALATED,
    RESOLVED,
    DISMISSED
}

enum class NotificationLevel {
    IMMEDIATE,
    HIGH,
    NORMAL,
    LOW
}
