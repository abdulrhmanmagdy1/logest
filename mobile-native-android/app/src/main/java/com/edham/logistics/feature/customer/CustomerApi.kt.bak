package com.edham.logistics.feature.customer

import com.edham.logistics.data.local.entity.Shipment
import com.edham.logistics.data.local.entity.Customer
import retrofit2.Response
import retrofit2.http.*

interface CustomerApi {
    
    // Shipment Tracking
    @GET("api/v1/customer/shipments/{shipmentId}/tracking")
    suspend fun getShipmentTracking(@Path("shipmentId") shipmentId: String): Response<TrackingData>
    
    @GET("api/v1/customer/shipments/tracking/{trackingNumber}")
    suspend fun getShipmentByTrackingNumber(@Path("trackingNumber") trackingNumber: String): Response<Shipment>
    
    @GET("api/v1/customer/shipments/active")
    suspend fun getActiveShipments(@Query("customerId") customerId: String): Response<List<Shipment>>
    
    @GET("api/v1/customer/shipments/history")
    suspend fun getShipmentHistory(@Query("customerId") customerId: String): Response<List<Shipment>>
    
    @POST("api/v1/customer/shipments")
    suspend fun createShipment(@Body request: CreateShipmentRequest): Response<Shipment>
    
    @PUT("api/v1/customer/shipments/{shipmentId}")
    suspend fun updateShipment(@Path("shipmentId") shipmentId: String, @Body request: UpdateShipmentRequest): Response<Shipment>
    
    @DELETE("api/v1/customer/shipments/{shipmentId}")
    suspend fun cancelShipment(@Path("shipmentId") shipmentId: String): Response<Unit>
    
    // Notifications
    @GET("api/v1/customer/notifications")
    suspend fun getCustomerNotifications(@Query("customerId") customerId: String): Response<List<CustomerNotification>>
    
    @POST("api/v1/customer/notifications/{notificationId}/read")
    suspend fun markNotificationAsRead(@Path("notificationId") notificationId: String): Response<Unit>
    
    @POST("api/v1/customer/notifications/{notificationId}/dismiss")
    suspend fun dismissNotification(@Path("notificationId") notificationId: String): Response<Unit>
    
    // Digital Invoices
    @GET("api/v1/customer/invoices")
    suspend fun getCustomerInvoices(@Query("customerId") customerId: String): Response<List<DigitalInvoice>>
    
    @GET("api/v1/customer/invoices/{invoiceId}")
    suspend fun getInvoice(@Path("invoiceId") invoiceId: String): Response<DigitalInvoice>
    
    @POST("api/v1/customer/invoices/{invoiceId}/download")
    suspend fun downloadInvoice(@Path("invoiceId") invoiceId: String): Response<InvoiceDownloadResponse>
    
    @POST("api/v1/customer/invoices/{invoiceId}/pay")
    suspend fun payInvoice(@Path("invoiceId") invoiceId: String, @Body request: PaymentRequest): Response<PaymentResponse>
    
    // Ratings & Reviews
    @GET("api/v1/customer/reviews")
    suspend fun getCustomerReviews(@Query("customerId") customerId: String): Response<List<CustomerReview>>
    
    @POST("api/v1/customer/reviews")
    suspend fun submitReview(@Body review: CustomerReview): Response<CustomerReview>
    
    @PUT("api/v1/customer/reviews/{reviewId}")
    suspend fun updateReview(@Path("reviewId") reviewId: String, @Body review: CustomerReview): Response<CustomerReview>
    
    @DELETE("api/v1/customer/reviews/{reviewId}")
    suspend fun deleteReview(@Path("reviewId") reviewId: String): Response<Unit>
    
    // Customer Support Chat
    @GET("api/v1/customer/chat/messages")
    suspend fun getCustomerChatMessages(@Query("customerId") customerId: String): Response<List<ChatMessage>>
    
    @POST("api/v1/customer/chat/messages")
    suspend fun sendChatMessage(@Body message: ChatMessage): Response<ChatMessage>
    
    @PUT("api/v1/customer/chat/messages/{messageId}/read")
    suspend fun markMessageAsRead(@Path("messageId") messageId: String): Response<Unit>
    
    @POST("api/v1/customer/chat/status")
    suspend fun updateChatStatus(@Body request: ChatStatusRequest): Response<Unit>
    
    @GET("api/v1/customer/chat/agents")
    suspend fun getAvailableAgents(): Response<List<SupportAgent>>
    
    // Complaint System
    @GET("api/v1/customer/complaints")
    suspend fun getCustomerComplaints(@Query("customerId") customerId: String): Response<List<CustomerComplaint>>
    
    @POST("api/v1/customer/complaints")
    suspend fun submitComplaint(@Body complaint: CustomerComplaint): Response<CustomerComplaint>
    
    @GET("api/v1/customer/complaints/{complaintId}")
    suspend fun getComplaint(@Path("complaintId") complaintId: String): Response<CustomerComplaint>
    
    @PUT("api/v1/customer/complaints/{complaintId}")
    suspend fun updateComplaint(@Path("complaintId") complaintId: String, @Body request: UpdateComplaintRequest): Response<CustomerComplaint>
    
    @POST("api/v1/customer/complaints/{complaintId}/escalate")
    suspend fun escalateComplaint(@Path("complaintId") complaintId: String): Response<Unit>
    
    @POST("api/v1/customer/complaints/{complaintId}/close")
    suspend fun closeComplaint(@Path("complaintId") complaintId: String, @Body request: CloseComplaintRequest): Response<Unit>
    
    // Customer Profile
    @GET("api/v1/customer/profile")
    suspend fun getCustomerProfile(@Query("customerId") customerId: String): Response<Customer>
    
    @PUT("api/v1/customer/profile")
    suspend fun updateCustomerProfile(@Query("customerId") customerId: String, @Body profile: Customer): Response<Customer>
    
    @POST("api/v1/customer/profile/password")
    suspend fun changePassword(@Body request: ChangePasswordRequest): Response<Unit>
    
    @POST("api/v1/customer/profile/preferences")
    suspend fun updateNotificationPreferences(@Body preferences: NotificationPreferences): Response<Unit>
    
    // Address Book
    @GET("api/v1/customer/addresses")
    suspend fun getCustomerAddresses(@Query("customerId") customerId: String): Response<List<CustomerAddress>>
    
    @POST("api/v1/customer/addresses")
    suspend fun addAddress(@Body address: CustomerAddress): Response<CustomerAddress>
    
    @PUT("api/v1/customer/addresses/{addressId}")
    suspend fun updateAddress(@Path("addressId") addressId: String, @Body address: CustomerAddress): Response<CustomerAddress>
    
    @DELETE("api/v1/customer/addresses/{addressId}")
    suspend fun deleteAddress(@Path("addressId") addressId: String): Response<Unit>
    
    // Payment Methods
    @GET("api/v1/customer/payment-methods")
    suspend fun getPaymentMethods(@Query("customerId") customerId: String): Response<List<PaymentMethod>>
    
    @POST("api/v1/customer/payment-methods")
    suspend fun addPaymentMethod(@Body method: PaymentMethod): Response<PaymentMethod>
    
    @PUT("api/v1/customer/payment-methods/{methodId}")
    suspend fun updatePaymentMethod(@Path("methodId") methodId: String, @Body method: PaymentMethod): Response<PaymentMethod>
    
    @DELETE("api/v1/customer/payment-methods/{methodId}")
    suspend fun deletePaymentMethod(@Path("methodId") methodId: String): Response<Unit>
    
    // Analytics and Insights
    @GET("api/v1/customer/analytics/summary")
    suspend fun getCustomerAnalytics(@Query("customerId") customerId: String): Response<CustomerAnalytics>
    
    @GET("api/v1/customer/analytics/shipments")
    suspend fun getShipmentAnalytics(@Query("customerId") customerId: String, @Query("period") period: String): Response<ShipmentAnalytics>
    
    @GET("api/v1/customer/analytics/spending")
    suspend fun getSpendingAnalytics(@Query("customerId") customerId: String, @Query("period") period: String): Response<SpendingAnalytics>
}

// Request data classes
data class CreateShipmentRequest(
    val customerId: String,
    val originAddress: Address,
    val destinationAddress: Address,
    val packageDetails: PackageDetails,
    val serviceType: String,
    val priority: String,
    val specialInstructions: String?,
    val estimatedValue: Double,
    val insuranceRequired: Boolean,
    val pickupDate: Long?,
    val deliveryDate: Long?
)

data class UpdateShipmentRequest(
    val specialInstructions: String?,
    val pickupDate: Long?,
    val deliveryDate: Long?,
    val priority: String?
)

data class PaymentRequest(
    val paymentMethodId: String,
    val amount: Double,
    val currency: String
)

data class ChatStatusRequest(
    val customerId: String,
    val status: String
)

data class UpdateComplaintRequest(
    val description: String?,
    val priority: ComplaintPriority?
)

data class CloseComplaintRequest(
    val resolution: String,
    val satisfactionRating: Float?
)

data class ChangePasswordRequest(
    val currentPassword: String,
    val newPassword: String
)

data class NotificationPreferences(
    val emailNotifications: Boolean,
    val smsNotifications: Boolean,
    val pushNotifications: Boolean,
    val shipmentUpdates: Boolean,
    val promotions: Boolean,
    val payments: Boolean
)

// Response data classes
data class InvoiceDownloadResponse(
    val downloadUrl: String,
    val expiresAt: Long,
    val fileSize: Long
)

data class PaymentResponse(
    val paymentId: String,
    val status: String,
    val transactionId: String?,
    val timestamp: Long
)

data class SupportAgent(
    val id: String,
    val name: String,
    val avatar: String,
    val status: String,
    val rating: Float,
    val languages: List<String>
)

data class CustomerAddress(
    val id: String,
    val customerId: String,
    val type: AddressType,
    val name: String,
    val company: String?,
    val address: String,
    val city: String,
    val state: String,
    val zipCode: String,
    val country: String,
    val phone: String,
    val isDefault: Boolean,
    val coordinates: Coordinates?
)

data class PaymentMethod(
    val id: String,
    val customerId: String,
    val type: PaymentType,
    val provider: String,
    val lastFour: String,
    val expiryMonth: Int?,
    val expiryYear: Int?,
    val isDefault: Boolean,
    val isExpired: Boolean
)

data class CustomerAnalytics(
    val totalShipments: Int,
    val activeShipments: Int,
    val completedShipments: Int,
    val totalSpent: Double,
    val averageDeliveryTime: Double,
    val onTimeDeliveryRate: Double,
    val customerRating: Float,
    val favoriteRoutes: List<RouteAnalytics>,
    val recentActivity: List<ActivityItem>
)

data class ShipmentAnalytics(
    val period: String,
    val totalShipments: Int,
    val deliveredShipments: Int,
    val delayedShipments: Int,
    val cancelledShipments: Int,
    val averageDeliveryTime: Double,
    val totalDistance: Double,
    val totalCost: Double,
    val serviceTypeBreakdown: Map<String, Int>,
    val dailyBreakdown: List<DailyAnalytics>
)

data class SpendingAnalytics(
    val period: String,
    val totalSpent: Double,
    val averagePerShipment: Double,
    val costBreakdown: Map<String, Double>,
    val monthlyTrend: List<MonthlySpending>,
    val savings: Double
)

// Supporting data classes
data class Address(
    val street: String,
    val city: String,
    val state: String,
    val zipCode: String,
    val country: String,
    val coordinates: Coordinates?
)

data class PackageDetails(
    val weight: Double,
    val dimensions: PackageDimensions,
    val description: String,
    val category: String,
    val fragile: Boolean,
    val hazardous: Boolean
)

data class PackageDimensions(
    val length: Double,
    val width: Double,
    val height: Double,
    val unit: String
)

data class Coordinates(
    val latitude: Double,
    val longitude: Double
)

data class RouteAnalytics(
    val origin: String,
    val destination: String,
    val shipmentCount: Int,
    val averageCost: Double,
    val averageTime: Double
)

data class ActivityItem(
    val type: String,
    val description: String,
    val timestamp: Long,
    val shipmentId: String?
)

data class DailyAnalytics(
    val date: String,
    val shipments: Int,
    val delivered: Int,
    val delayed: Int,
    val cost: Double
)

data class MonthlySpending(
    val month: String,
    val amount: Double,
    val shipments: Int,
    val averageCost: Double
)

// Enums
enum class AddressType {
    HOME, WORK, PICKUP, DELIVERY, BILLING
}

enum class PaymentType {
    CREDIT_CARD, DEBIT_CARD, BANK_TRANSFER, DIGITAL_WALLET, CASH_ON_DELIVERY
}
