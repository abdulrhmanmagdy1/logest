package com.edham.logistics.feature.coldchain.adapters

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.ImageView
import android.widget.TextView
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.feature.coldchain.AlertSeverity
import com.edham.logistics.feature.coldchain.AlertType
import com.edham.logistics.feature.coldchain.ColdChainAlert
import java.text.SimpleDateFormat
import java.util.*

class AlertAdapter(
    private val onAlertClick: (ColdChainAlert) -> Unit
) : RecyclerView.Adapter<AlertAdapter.ViewHolder>() {
    
    private var alerts = mutableListOf<ColdChainAlert>()
    private val timeFormat = SimpleDateFormat("HH:mm:ss", Locale.getDefault())
    
    fun updateAlerts(newAlerts: List<ColdChainAlert>) {
        alerts.clear()
        alerts.addAll(newAlerts.sortedByDescending { it.timestamp })
        notifyDataSetChanged()
    }
    
    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): ViewHolder {
        val view = LayoutInflater.from(parent.context).inflate(R.layout.item_cold_chain_alert, parent, false)
        return ViewHolder(view)
    }
    
    override fun onBindViewHolder(holder: ViewHolder, position: Int) {
        holder.bind(alerts[position])
    }
    
    override fun getItemCount(): Int = alerts.size
    
    inner class ViewHolder(itemView: View) : RecyclerView.ViewHolder(itemView) {
        private val alertIcon: ImageView = itemView.findViewById(R.id.alertIcon)
        private val alertTitle: TextView = itemView.findViewById(R.id.alertTitle)
        private val alertMessage: TextView = itemView.findViewById(R.id.alertMessage)
        private val alertTime: TextView = itemView.findViewById(R.id.alertTime)
        private val alertSeverity: TextView = itemView.findViewById(R.id.alertSeverity)
        private val alertStatus: TextView = itemView.findViewById(R.id.alertStatus)
        private val acknowledgeButton: View = itemView.findViewById(R.id.btnAcknowledge)
        private val resolveButton: View = itemView.findViewById(R.id.btnResolve)
        
        fun bind(alert: ColdChainAlert) {
            // Set alert icon and color based on type
            val (iconRes, colorRes) = when (alert.type) {
                AlertType.TEMPERATURE_LOW, AlertType.TEMPERATURE_LOW_WARNING -> {
                    Pair(R.drawable.ic_temperature_low, R.color.alert_cold)
                }
                AlertType.TEMPERATURE_HIGH, AlertType.TEMPERATURE_HIGH_WARNING -> {
                    Pair(R.drawable.ic_temperature_high, R.color.alert_hot)
                }
                AlertType.HUMIDITY_LOW, AlertType.HUMIDITY_HIGH -> {
                    Pair(R.drawable.ic_humidity, R.color.alert_humidity)
                }
                AlertType.SENSOR_BATTERY_LOW -> {
                    Pair(R.drawable.ic_battery_low, R.color.alert_battery)
                }
                AlertType.SENSOR_DISCONNECTED -> {
                    Pair(R.drawable.ic_sensor_offline, R.color.alert_offline)
                }
                AlertType.SENSOR_STALE_DATA -> {
                    Pair(R.drawable.ic_data_stale, R.color.alert_stale)
                }
                AlertType.COOLING_FAILURE -> {
                    Pair(R.drawable.ic_cooling_failure, R.color.alert_critical)
                }
            }
            
            alertIcon.setImageResource(iconRes)
            alertIcon.setColorFilter(itemView.context.getColor(colorRes))
            
            // Set alert title and message
            alertTitle.text = getAlertTitle(alert.type)
            alertMessage.text = getAlertMessage(alert)
            
            // Set time
            alertTime.text = timeFormat.format(Date(alert.timestamp))
            
            // Set severity badge
            alertSeverity.text = alert.severity.name
            val severityColor = when (alert.severity) {
                AlertSeverity.INFO -> itemView.context.getColor(R.color.severity_info)
                AlertSeverity.WARNING -> itemView.context.getColor(R.color.severity_warning)
                AlertSeverity.CRITICAL -> itemView.context.getColor(R.color.severity_critical)
            }
            alertSeverity.setTextColor(severityColor)
            alertSeverity.setBackgroundColor(severityColor.copy(alpha = 0.2f))
            
            // Set status
            when {
                alert.resolved -> {
                    alertStatus.text = "RESOLVED"
                    alertStatus.setTextColor(itemView.context.getColor(R.color.status_completed))
                    acknowledgeButton.visibility = View.GONE
                    resolveButton.visibility = View.GONE
                }
                alert.acknowledged -> {
                    alertStatus.text = "ACKNOWLEDGED"
                    alertStatus.setTextColor(itemView.context.getColor(R.color.status_warning))
                    acknowledgeButton.visibility = View.GONE
                    resolveButton.visibility = View.VISIBLE
                }
                else -> {
                    alertStatus.text = "ACTIVE"
                    alertStatus.setTextColor(itemView.context.getColor(R.color.status_active))
                    acknowledgeButton.visibility = View.VISIBLE
                    resolveButton.visibility = View.VISIBLE
                }
            }
            
            // Set click listeners
            itemView.setOnClickListener {
                onAlertClick(alert)
            }
            
            acknowledgeButton.setOnClickListener {
                onAlertClick(alert)
            }
            
            resolveButton.setOnClickListener {
                onAlertClick(alert)
            }
            
            // Set background based on severity
            val backgroundColor = when (alert.severity) {
                AlertSeverity.CRITICAL -> itemView.context.getColor(R.color.alert_critical_bg)
                AlertSeverity.WARNING -> itemView.context.getColor(R.color.alert_warning_bg)
                AlertSeverity.INFO -> itemView.context.getColor(R.color.alert_info_bg)
            }
            
            itemView.setBackgroundColor(backgroundColor)
        }
        
        private fun getAlertTitle(type: AlertType): String {
            return when (type) {
                AlertType.TEMPERATURE_LOW -> "Temperature Too Low"
                AlertType.TEMPERATURE_HIGH -> "Temperature Too High"
                AlertType.TEMPERATURE_LOW_WARNING -> "Temperature Low Warning"
                AlertType.TEMPERATURE_HIGH_WARNING -> "Temperature High Warning"
                AlertType.HUMIDITY_LOW -> "Humidity Too Low"
                AlertType.HUMIDITY_HIGH -> "Humidity Too High"
                AlertType.SENSOR_BATTERY_LOW -> "Sensor Battery Low"
                AlertType.SENSOR_DISCONNECTED -> "Sensor Disconnected"
                AlertType.SENSOR_STALE_DATA -> "Stale Sensor Data"
                AlertType.COOLING_FAILURE -> "Cooling System Failure"
            }
        }
        
        private fun getAlertMessage(alert: ColdChainAlert): String {
            return when (alert.type) {
                AlertType.TEMPERATURE_LOW, AlertType.TEMPERATURE_LOW_WARNING -> {
                    "Temperature: ${String.format("%.1f°C", alert.value)} (Threshold: ${String.format("%.1f°C", alert.threshold)})"
                }
                AlertType.TEMPERATURE_HIGH, AlertType.TEMPERATURE_HIGH_WARNING -> {
                    "Temperature: ${String.format("%.1f°C", alert.value)} (Threshold: ${String.format("%.1f°C", alert.threshold)})"
                }
                AlertType.HUMIDITY_LOW -> {
                    "Humidity: ${String.format("%.1f%%", alert.value)} (Threshold: ${String.format("%.1f%%", alert.threshold)})"
                }
                AlertType.HUMIDITY_HIGH -> {
                    "Humidity: ${String.format("%.1f%%", alert.value)} (Threshold: ${String.format("%.1f%%", alert.threshold)})"
                }
                AlertType.SENSOR_BATTERY_LOW -> {
                    "Battery: ${String.format("%.1f%%", alert.value)} (Threshold: ${String.format("%.1f%%", alert.threshold)})"
                }
                AlertType.SENSOR_DISCONNECTED -> {
                    "Sensor ${alert.sensorId} is disconnected"
                }
                AlertType.SENSOR_STALE_DATA -> {
                    "Last data: ${String.format("%.0f sec", alert.value)} ago (Threshold: ${String.format("%.0f sec", alert.threshold)})"
                }
                AlertType.COOLING_FAILURE -> {
                    "Cooling system failure detected"
                }
            }
        }
    }
}
