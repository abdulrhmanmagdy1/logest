package com.edham.logistics.adapters

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.ImageView
import android.widget.TextView
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.domain.model.Task

class TaskManagementAdapter(
    private var tasks: List<Task>,
    private val onTaskClick: (Task) -> Unit
) : RecyclerView.Adapter<TaskManagementAdapter.TaskViewHolder>() {

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): TaskViewHolder {
        val view = LayoutInflater.from(parent.context)
            .inflate(R.layout.item_task_management, parent, false)
        return TaskViewHolder(view)
    }

    override fun onBindViewHolder(holder: TaskViewHolder, position: Int) {
        holder.bind(tasks[position])
    }

    override fun getItemCount(): Int = tasks.size

    fun updateTasks(newTasks: List<Task>) {
        tasks = newTasks
        notifyDataSetChanged()
    }

    inner class TaskViewHolder(itemView: View) : RecyclerView.ViewHolder(itemView) {
        private val tvTaskTitle: TextView = itemView.findViewById(R.id.tvTaskTitle)
        private val tvAssignedTo: TextView = itemView.findViewById(R.id.tvAssignedTo)
        private val tvStatus: TextView = itemView.findViewById(R.id.tvStatus)
        private val tvPriority: TextView = itemView.findViewById(R.id.tvPriority)
        private val tvTime: TextView = itemView.findViewById(R.id.tvTime)
        private val ivStatusIcon: ImageView = itemView.findViewById(R.id.ivStatusIcon)

        fun bind(task: Task) {
            tvTaskTitle.text = task.title
            tvAssignedTo.text = task.assignedTo
            tvStatus.text = task.status
            tvPriority.text = task.priority
            tvTime.text = task.time

            // Set status icon and color
            when (task.status) {
                "مكتمل" -> {
                    ivStatusIcon.setImageResource(R.drawable.circle_green)
                    tvStatus.setTextColor(itemView.context.getColor(R.color.supervisor_success))
                }
                "قيد التنفيذ" -> {
                    ivStatusIcon.setImageResource(R.drawable.circle_blue)
                    tvStatus.setTextColor(itemView.context.getColor(R.color.supervisor_info))
                }
                "معلق" -> {
                    ivStatusIcon.setImageResource(R.drawable.circle_warning)
                    tvStatus.setTextColor(itemView.context.getColor(R.color.supervisor_warning))
                }
                "متأخر" -> {
                    ivStatusIcon.setImageResource(R.drawable.circle_red)
                    tvStatus.setTextColor(itemView.context.getColor(R.color.supervisor_error))
                }
                else -> {
                    ivStatusIcon.setImageResource(R.drawable.circle_grey)
                    tvStatus.setTextColor(itemView.context.getColor(R.color.text_secondary))
                }
            }

            // Set priority color
            when (task.priority) {
                "عالي" -> {
                    tvPriority.setTextColor(itemView.context.getColor(R.color.supervisor_error))
                    tvPriority.setBackgroundColor(itemView.context.getColor(R.color.supervisor_error_transparent))
                }
                "متوسط" -> {
                    tvPriority.setTextColor(itemView.context.getColor(R.color.supervisor_warning))
                    tvPriority.setBackgroundColor(itemView.context.getColor(R.color.supervisor_warning_transparent))
                }
                "عادي" -> {
                    tvPriority.setTextColor(itemView.context.getColor(R.color.supervisor_info))
                    tvPriority.setBackgroundColor(itemView.context.getColor(R.color.supervisor_info_transparent))
                }
                else -> {
                    tvPriority.setTextColor(itemView.context.getColor(R.color.text_secondary))
                    tvPriority.setBackgroundColor(itemView.context.getColor(R.color.text_secondary_transparent))
                }
            }

            itemView.setOnClickListener {
                onTaskClick(task)
            }
        }
    }
}
