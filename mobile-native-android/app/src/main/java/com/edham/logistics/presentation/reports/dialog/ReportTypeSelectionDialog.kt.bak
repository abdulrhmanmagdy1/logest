package com.edham.logistics.presentation.reports.dialog

import android.app.Dialog
import android.os.Bundle
import androidx.fragment.app.DialogFragment
import com.edham.logistics.R
import com.edham.logistics.presentation.reports.ReportType
import com.google.android.material.dialog.MaterialAlertDialogBuilder

/**
 * Report Type Selection Dialog - Dialog for selecting report type
 * Provides options for different types of business intelligence reports
 */
class ReportTypeSelectionDialog(
    private val onReportTypeSelected: (ReportType) -> Unit
) : DialogFragment() {

    override fun onCreateDialog(savedInstanceState: Bundle?): Dialog {
        val reportTypes = arrayOf(
            "Revenue Report",
            "Shipment Performance",
            "Driver Performance", 
            "Customer Behavior"
        )

        return MaterialAlertDialogBuilder(requireContext())
            .setTitle("Select Report Type")
            .setItems(reportTypes) { _, which ->
                val reportType = when (which) {
                    0 -> ReportType.REVENUE
                    1 -> ReportType.SHIPMENT
                    2 -> ReportType.DRIVER
                    3 -> ReportType.CUSTOMER
                    else -> ReportType.REVENUE
                }
                onReportTypeSelected(reportType)
            }
            .setNegativeButton("Cancel", null)
            .create()
    }
}
