package com.edham.logistics

import android.os.Bundle
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.TextView
import androidx.fragment.app.Fragment
import androidx.recyclerview.widget.LinearLayoutManager
import androidx.recyclerview.widget.RecyclerView
import com.github.mikephil.charting.charts.LineChart
import com.github.mikephil.charting.charts.BarChart
import com.github.mikephil.charting.charts.PieChart
import com.github.mikephil.charting.data.*
import com.github.mikephil.charting.formatter.PercentFormatter

class AdvancedAnalyticsFragment : Fragment() {
    private lateinit var revenueChart: LineChart
    private lateinit var performanceChart: BarChart
    private lateinit var statusPieChart: PieChart
    private lateinit var tvTotalRevenue: TextView
    private lateinit var tvGrowthRate: TextView
    private lateinit var tvEfficiencyScore: TextView
    private lateinit var tvActiveFleet: TextView
    private lateinit var rvTopDrivers: RecyclerView
    private lateinit var rvRecentAlerts: RecyclerView

    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View? {
        return inflater.inflate(R.layout.fragment_advanced_analytics, container, false)
    }

    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)

        // Initialize charts
        revenueChart = view.findViewById(R.id.revenue_chart)
        performanceChart = view.findViewById(R.id.performance_chart)
        statusPieChart = view.findViewById(R.id.status_pie_chart)

        // Initialize text views
        tvTotalRevenue = view.findViewById(R.id.tv_total_revenue)
        tvGrowthRate = view.findViewById(R.id.tv_growth_rate)
        tvEfficiencyScore = view.findViewById(R.id.tv_efficiency_score)
        tvActiveFleet = view.findViewById(R.id.tv_active_fleet)

        // Initialize recycler views
        rvTopDrivers = view.findViewById(R.id.rv_top_drivers)
        rvRecentAlerts = view.findViewById(R.id.rv_recent_alerts)

        // Set Arabic titles
        view.findViewById<TextView>(R.id.tv_analytics_title).text = "التحليلات المتقدمة"
        view.findViewById<TextView>(R.id.tv_revenue_trends_title).text = "اتجاهات الإيرادات"
        view.findViewById<TextView>(R.id.tv_performance_title).text = "أداء الأسطول"
        view.findViewById<TextView>(R.id.tv_status_distribution_title).text = "توزيع الحالات"
        view.findViewById<TextView>(R.id.tv_top_drivers_title).text = "أفضل السائقين"
        view.findViewById<TextView>(R.id.tv_recent_alerts_title).text = "التنبيهات الحديثة"

        // Setup data
        setupRevenueChart()
        setupPerformanceChart()
        setupStatusPieChart()
        setupMetrics()
        setupTopDrivers()
        setupRecentAlerts()
    }

    private fun setupRevenueChart() {
        val entries = mutableListOf<Entry>()
        val revenueData = listOf(
            "يناير" to 120000f,
            "فبراير" to 135000f,
            "مارس" to 142000f,
            "أبريل" to 158000f,
            "مايو" to 165000f,
            "يونيو" to 172000f
        )

        revenueData.forEachIndexed { index, (month, revenue) ->
            entries.add(Entry(index.toFloat(), revenue))
        }

        val dataSet = LineDataSet(entries, "الإيرادات الشهرية").apply {
            color = resources.getColor(android.R.color.holo_orange_dark)
            setCircleColor(resources.getColor(android.R.color.holo_orange_light))
            lineWidth = 3f
            circleRadius = 5f
            setDrawFilled(true)
            fillColor = resources.getColor(android.R.color.holo_orange_light)
        }

        val lineData = LineData(dataSet)
        revenueChart.apply {
            data = lineData
            description.isEnabled = false
            legend.isEnabled = true
            axisRight.isEnabled = false
            xAxis.isEnabled = true
            axisLeft.isEnabled = true
            invalidate()
        }
    }

    private fun setupPerformanceChart() {
        val entries = mutableListOf<BarEntry>()
        val performanceData = listOf(
            "TRK-001" to 95f,
            "TRK-002" to 88f,
            "TRK-003" to 92f,
            "TRK-004" to 78f,
            "TRK-005" to 85f
        )

        performanceData.forEachIndexed { index, (vehicle, performance) ->
            entries.add(BarEntry(index.toFloat(), performance))
        }

        val dataSet = BarDataSet(entries, "كفاءة المركبة").apply {
            colors = listOf(
                resources.getColor(android.R.color.holo_green_dark),
                resources.getColor(android.R.color.holo_blue_dark),
                resources.getColor(android.R.color.holo_orange_dark),
                resources.getColor(android.R.color.holo_red_dark),
                resources.getColor(android.R.color.holo_purple)
            )
        }

        val barData = BarData(dataSet)
        performanceChart.apply {
            data = barData
            description.isEnabled = false
            legend.isEnabled = true
            axisRight.isEnabled = false
            invalidate()
        }
    }

    private fun setupStatusPieChart() {
        val entries = listOf(
            PieEntry(45f, "مكتمل"),
            PieEntry(30f, "في الطريق"),
            PieEntry(15f, "تحميل"),
            PieEntry(10f, "معلق")
        )

        val dataSet = PieDataSet(entries, "حالة الشحنات").apply {
            colors = listOf(
                resources.getColor(android.R.color.holo_green_dark),
                resources.getColor(android.R.color.holo_blue_dark),
                resources.getColor(android.R.color.holo_orange_dark),
                resources.getColor(android.R.color.holo_red_dark)
            )
            valueFormatter = PercentFormatter()
            valueTextSize = 12f
        }

        val pieData = PieData(dataSet)
        statusPieChart.apply {
            data = pieData
            description.isEnabled = false
            legend.isEnabled = true
            setUsePercentValues(true)
            invalidate()
        }
    }

    private fun setupMetrics() {
        tvTotalRevenue.text = "892,000 ريال"
        tvGrowthRate.text = "+15.3%"
        tvEfficiencyScore.text = "94.2%"
        tvActiveFleet.text = "24/28"
    }

    private fun setupTopDrivers() {
        rvTopDrivers.layoutManager = LinearLayoutManager(requireContext())
    }

    private fun setupRecentAlerts() {
        rvRecentAlerts.layoutManager = LinearLayoutManager(requireContext())
    }
}
