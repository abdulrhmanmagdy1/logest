    private suspend fun loadMaintenanceTypes() {
        // Load maintenance types from API or local storage
    }
    
    private fun validateMaintenanceExpenseRequest(request: MaintenanceExpenseRequest) {
        if (request.vehicleId.isBlank()) throw Exception("Vehicle ID is required")
        if (request.maintenanceType == null) throw Exception("Maintenance type is required")
        if (request.description.isBlank()) throw Exception("Description is required")
        if (request.date == null) throw Exception("Maintenance date is required")
        
        val totalCost = (request.laborCost ?: 0f) + (request.partsCost ?: 0f)
        if (totalCost <= 0) throw Exception("Total cost must be positive")
        if (totalCost > MAX_MAINTENANCE_COST) throw Exception("Total cost exceeds maximum limit")
    }
    
    private fun validateMaintenanceExpense(maintenanceExpense: MaintenanceExpense) {
        if (maintenanceExpense.vehicleId.isBlank()) throw Exception("Vehicle ID is required")
        if (maintenanceExpense.maintenanceType == null) throw Exception("Maintenance type is required")
        if (maintenanceExpense.description.isBlank()) throw Exception("Description is required")
        if (maintenanceExpense.date == null) throw Exception("Maintenance date is required")
        if (maintenanceExpense.totalCost <= 0) throw Exception("Total cost must be positive")
        if (maintenanceExpense.totalCost > MAX_MAINTENANCE_COST) throw Exception("Total cost exceeds maximum limit")
    }
    
    private fun shouldAutoApprove(request: MaintenanceExpenseRequest): Boolean {
        // Auto-approve if cost is below threshold and type allows it
        val totalCost = (request.laborCost ?: 0f) + (request.partsCost ?: 0f)
        return totalCost <= 1000f && request.maintenanceType in listOf(
            MaintenanceType.OIL_CHANGE,
            MaintenanceType.TIRE_ROTATION,
            MaintenanceType.BATTERY_REPLACEMENT
        )
    }
    
    private suspend fun processAutoApproval(maintenanceExpense: MaintenanceExpense) {
        try {
            val approvedMaintenanceExpense = maintenanceExpense.copy(
                status = MaintenanceExpenseStatus.APPROVED,
                approvedBy = "SYSTEM",
                approvalNotes = "Auto-approved",
                approvedAt = Date(),
                updatedAt = Date()
            )
            
            // Update in database
            database.maintenanceExpenseDao().updateMaintenanceExpense(approvedMaintenanceExpense.toEntity())
            
            // Update in list
            updateMaintenanceExpenseInList(approvedMaintenanceExpense)
            
            // Update stats
            updateMaintenanceExpenseStats()
            
        } catch (e: Exception) {
            // Handle error
        }
    }
    
    private suspend fun submitForApproval(maintenanceExpense: MaintenanceExpense) {
        try {
            // Send notification to approvers
            // This would integrate with notification system
        } catch (e: Exception) {
            // Handle error
        }
    }
    
    private suspend fun updateVehicleMaintenanceInfo(vehicle: Vehicle, maintenanceExpense: MaintenanceExpense) {
        try {
            val updatedVehicle = vehicle.copy(
                lastMaintenanceDate = maintenanceExpense.date,
                lastMaintenanceOdometer = maintenanceExpense.odometerReading,
                lastMaintenanceCost = maintenanceExpense.totalCost,
                updatedAt = Date()
            )
            
            vehicleApi.updateVehicle(updatedVehicle)
        } catch (e: Exception) {
            // Handle error
        }
    }
    
    private fun addToMaintenanceExpenses(maintenanceExpense: MaintenanceExpense) {
        val currentMaintenanceExpenses = _maintenanceExpenses.value.toMutableList()
        currentMaintenanceExpenses.add(0, maintenanceExpense) // Add to beginning
        
        // Keep only last 100 maintenance expenses in cache
        if (currentMaintenanceExpenses.size > 100) {
            currentMaintenanceExpenses.removeAt(currentMaintenanceExpenses.size - 1)
        }
        
        _maintenanceExpenses.value = currentMaintenanceExpenses
    }
    
    private fun updateMaintenanceExpenseInList(maintenanceExpense: MaintenanceExpense) {
        val currentMaintenanceExpenses = _maintenanceExpenses.value.toMutableList()
        val index = currentMaintenanceExpenses.indexOfFirst { it.id == maintenanceExpense.id }
        
        if (index != -1) {
            currentMaintenanceExpenses[index] = maintenanceExpense
            _maintenanceExpenses.value = currentMaintenanceExpenses
        }
    }
    
    private suspend fun updateMaintenanceExpenseStats() {
        try {
            val maintenanceExpenses = _maintenanceExpenses.value
            val stats = MaintenanceExpenseStats(
                totalExpenses = maintenanceExpenses.size,
                pendingExpenses = maintenanceExpenses.count { it.status == MaintenanceExpenseStatus.PENDING },
                approvedExpenses = maintenanceExpenses.count { it.status == MaintenanceExpenseStatus.APPROVED },
                rejectedExpenses = maintenanceExpenses.count { it.status == MaintenanceExpenseStatus.REJECTED },
                totalCost = maintenanceExpenses.sumOf { it.totalCost.toDouble() }.toFloat(),
                averageCost = if (maintenanceExpenses.isNotEmpty()) maintenanceExpenses.map { it.totalCost }.average().toFloat() else 0f,
                maintenanceTypeStats = maintenanceExpenses.groupBy { it.maintenanceType }.mapValues { it.value.size }
            )
            
            _maintenanceExpenseStats.value = stats
            
        } catch (e: Exception) {
            // Handle error
        }
    }
    
    private fun calculateMonthlyMaintenanceStats(maintenanceExpenses: List<MaintenanceExpense>): Map<String, MonthlyMaintenanceStats> {
        return maintenanceExpenses.groupBy { 
            val calendar = Calendar.getInstance()
            calendar.time = it.date
            "${calendar.get(Calendar.YEAR)}-${String.format("%02d", calendar.get(Calendar.MONTH) + 1)}"
        }.mapValues { (_, monthExpenses) ->
            MonthlyMaintenanceStats(
                expenseCount = monthExpenses.size,
                totalCost = monthExpenses.sumOf { it.totalCost.toDouble() }.toFloat(),
                averageCost = if (monthExpenses.isNotEmpty()) monthExpenses.map { it.totalCost }.average().toFloat() else 0f,
                approvedExpenses = monthExpenses.count { it.status == MaintenanceExpenseStatus.APPROVED }
            )
        }
    }
    
    private fun calculateCostTrend(maintenanceExpenses: List<MaintenanceExpense>): List<CostTrendPoint> {
        return maintenanceExpenses
            .sortedBy { it.date }
            .map { expense ->
                CostTrendPoint(
                    date = expense.date,
                    maintenanceType = expense.maintenanceType,
                    cost = expense.totalCost
                )
            }
    }
    
    private fun calculatePredictiveMaintenance(maintenanceExpenses: List<MaintenanceExpense>): PredictiveMaintenance {
        val typeFrequency = maintenanceExpenses.groupBy { it.maintenanceType }
            .mapValues { (_, expenses) ->
                val intervals = expenses.sortedBy { it.date }.zipWithNext { a, b ->
                    (b.date.time - a.date.time) / (1000 * 60 * 60 * 24f) // days
                }
                if (intervals.isNotEmpty()) intervals.average().toFloat() else 0f
            }
        
        return PredictiveMaintenance(
            maintenanceTypeFrequency = typeFrequency,
            averageInterval = typeFrequency.values.average().toFloat(),
            nextPredictiveMaintenance = calculateNextPredictiveMaintenance(maintenanceExpenses, typeFrequency)
        )
    }
    
    private fun calculateNextMaintenanceDate(vehicle: Vehicle, maintenanceExpenses: List<MaintenanceExpense>): Date? {
        val lastMaintenance = maintenanceExpenses.maxByOrNull { it.date } ?: return null
        val calendar = Calendar.getInstance()
        calendar.time = lastMaintenance.date
        calendar.add(Calendar.DAY_OF_MONTH, 90) // Next maintenance in 90 days
        return calendar.time
    }
    
    private fun calculateMaintenanceEfficiency(vehicle: Vehicle, maintenanceExpenses: List<MaintenanceExpense>): MaintenanceEfficiency {
        val totalCost = maintenanceExpenses.sumOf { it.totalCost.toDouble() }.toFloat()
        val daysSinceFirstMaintenance = if (maintenanceExpenses.isNotEmpty()) {
            ((Date().time - maintenanceExpenses.minByOrNull { it.date }!!.date.time) / (1000 * 60 * 60 * 24f))
        } else 0f
        
        return MaintenanceEfficiency(
            costPerDay = if (daysSinceFirstMaintenance > 0) totalCost / daysSinceFirstMaintenance else 0f,
            maintenanceFrequency = if (daysSinceFirstMaintenance > 0) maintenanceExpenses.size / (daysSinceFirstMaintenance / 30f) else 0f,
            efficiencyRating = calculateEfficiencyRating(totalCost, daysSinceFirstMaintenance, maintenanceExpenses.size)
        )
    }
    
    private fun calculateEfficiencyRating(totalCost: Float, days: Float, count: Int): EfficiencyRating {
        val costPerDay = if (days > 0) totalCost / days else 0f
        return when {
            costPerDay <= 10f -> EfficiencyRating.EXCELLENT
            costPerDay <= 20f -> EfficiencyRating.GOOD
            costPerDay <= 30f -> EfficiencyRating.AVERAGE
            costPerDay <= 50f -> EfficiencyRating.POOR
            else -> EfficiencyRating.VERY_POOR
        }
    }
    
    private fun calculateEstimatedMaintenanceCost(maintenanceType: MaintenanceType, vehicle: Vehicle): Float {
        return when (maintenanceType) {
            MaintenanceType.OIL_CHANGE -> 150f
            MaintenanceType.TIRE_ROTATION -> 100f
            MaintenanceType.TIRE_REPLACEMENT -> 800f
            MaintenanceType.BATTERY_REPLACEMENT -> 300f
            MaintenanceType.BRAKE_SERVICE -> 400f
            MaintenanceType.PREVENTIVE -> 500f
            MaintenanceType.MAJOR -> 2000f
            MaintenanceType.MINOR -> 300f
            MaintenanceType.EMERGENCY -> 1500f
        }
    }
    
    private fun calculateNextPredictiveMaintenance(
        maintenanceExpenses: List<MaintenanceExpense>,
        typeFrequency: Map<MaintenanceType, Float>
    ): NextPredictiveMaintenance? {
        val mostFrequentType = typeFrequency.maxByOrNull { it.value }?.key ?: return null
        val lastMaintenanceOfType = maintenanceExpenses
            .filter { it.maintenanceType == mostFrequentType }
            .maxByOrNull { it.date } ?: return null
        
        val calendar = Calendar.getInstance()
        calendar.time = lastMaintenanceOfType.date
        calendar.add(Calendar.DAY_OF_MONTH, typeFrequency[mostFrequentType]?.toInt() ?: 90)
        
        return NextPredictiveMaintenance(
            maintenanceType = mostFrequentType,
            predictedDate = calendar.time,
            confidence = 0.8f,
            estimatedCost = calculateEstimatedMaintenanceCost(mostFrequentType, Vehicle())
        )
    }
    
    /**
     * Get initialization status
     */
    fun isInitialized(): Boolean = isInitialized
}

/**
 * Data classes
 */
data class MaintenanceExpenseRequest(
    val vehicleId: String,
    val maintenanceType: MaintenanceType,
    val description: String,
    val date: Date,
    val odometerReading: Float? = null,
    val workshopId: String? = null,
    val laborCost: Float? = null,
    val partsCost: Float? = null,
    val currency: String? = null,
    val parts: List<Part> = emptyList(),
    val receiptUrl: String? = null,
    val metadata: Map<String, String> = emptyMap()
)

data class MaintenanceExpense(
    val id: String = "",
    val vehicleId: String,
    val maintenanceType: MaintenanceType,
    val description: String,
    val date: Date,
    val odometerReading: Float? = null,
    val workshopId: String? = null,
    val workshopName: String? = null,
    val laborCost: Float? = null,
    val partsCost: Float? = null,
    val totalCost: Float,
    val currency: String,
    val parts: List<Part> = emptyList(),
    val receiptUrl: String? = null,
    val status: MaintenanceExpenseStatus,
    val approvedBy: String? = null,
    val approvalNotes: String? = null,
    val rejectedBy: String? = null,
    val rejectionReason: String? = null,
    val approvedAt: Date? = null,
    val rejectedAt: Date? = null,
    val metadata: Map<String, String> = emptyMap(),
    val createdAt: Date = Date(),
    val updatedAt: Date = Date()
)

data class MaintenanceExpenseAnalytics(
    val totalExpenses: Int,
    val totalCost: Float,
    val approvedExpenses: Int,
    val pendingExpenses: Int,
    val rejectedExpenses: Int,
    val averageCost: Float,
    val maintenanceTypeStats: Map<MaintenanceType, Int>,
    val vehicleStats: Map<String, Int>,
    val workshopStats: Map<String, Int>,
    val monthlyStats: Map<String, MonthlyMaintenanceStats>,
    val costTrend: List<CostTrendPoint>,
    val predictiveMaintenance: PredictiveMaintenance
)

data class MaintenanceExpenseStats(
    val totalExpenses: Int = 0,
    val pendingExpenses: Int = 0,
    val approvedExpenses: Int = 0,
    val rejectedExpenses: Int = 0,
    val totalCost: Float = 0f,
    val averageCost: Float = 0f,
    val maintenanceTypeStats: Map<MaintenanceType, Int> = emptyMap()
)

data class VehicleMaintenanceHistory(
    val vehicleId: String,
    val totalMaintenanceCost: Float,
    val maintenanceCount: Int,
    val averageCost: Float,
    val lastMaintenanceDate: Date?,
    val nextMaintenanceDate: Date?,
    val maintenanceTypeStats: Map<MaintenanceType, Int>,
    val costTrend: List<CostTrendPoint>,
    val maintenanceEfficiency: MaintenanceEfficiency
)

data class MaintenanceRecommendation(
    val type: MaintenanceType,
    val priority: RecommendationPriority,
    val description: String,
    val estimatedCost: Float,
    val dueDate: Date,
    val vehicleId: String
)

data class MonthlyMaintenanceStats(
    val expenseCount: Int,
    val totalCost: Float,
    val averageCost: Float,
    val approvedExpenses: Int
)

data class CostTrendPoint(
    val date: Date,
    val maintenanceType: MaintenanceType,
    val cost: Float
)

data class PredictiveMaintenance(
    val maintenanceTypeFrequency: Map<MaintenanceType, Float>,
    val averageInterval: Float,
    val nextPredictiveMaintenance: NextPredictiveMaintenance?
)

data class NextPredictiveMaintenance(
    val maintenanceType: MaintenanceType,
    val predictedDate: Date,
    val confidence: Float,
    val estimatedCost: Float
)

data class MaintenanceEfficiency(
    val costPerDay: Float,
    val maintenanceFrequency: Float,
    val efficiencyRating: EfficiencyRating
)

data class Part(
    val id: String = UUID.randomUUID().toString(),
    val name: String,
    val quantity: Int,
    val unitPrice: Float,
    val totalPrice: Float = quantity * unitPrice,
    val partNumber: String? = null,
    val manufacturer: String? = null
)

/**
 * Enums
 */
enum class MaintenanceExpenseState {
    Idle,
    Initializing,
    Ready,
    Processing,
    Error
}

enum class MaintenanceType {
    OIL_CHANGE,
    TIRE_ROTATION,
    TIRE_REPLACEMENT,
    BATTERY_REPLACEMENT,
    BRAKE_SERVICE,
    PREVENTIVE,
    MAJOR,
    MINOR,
    EMERGENCY
}

enum class MaintenanceExpenseStatus {
    PENDING,
    APPROVED,
    REJECTED,
    CANCELLED
}

enum class RecommendationPriority {
    LOW,
    MEDIUM,
    HIGH,
    CRITICAL
}

enum class EfficiencyRating {
    EXCELLENT,
    GOOD,
    AVERAGE,
    POOR,
    VERY_POOR
}
