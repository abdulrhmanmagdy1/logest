package com.edham.logistics.finance.expense

import android.content.Context
import com.edham.logistics.data.local.database.EdhamDatabase
import com.edham.logistics.data.remote.api.MaintenanceExpenseApi
import com.edham.logistics.data.remote.api.VehicleApi
import com.edham.logistics.data.remote.api.WorkshopApi
import com.edham.logistics.utils.NetworkUtils
import com.edham.logistics.utils.SecurityUtils
import kotlinx.coroutines.Dispatchers
import kotlinx.coroutines.flow.MutableStateFlow
import kotlinx.coroutines.flow.StateFlow
import kotlinx.coroutines.flow.asStateFlow
import kotlinx.coroutines.withContext
import java.util.*
import javax.inject.Inject
import javax.inject.Singleton

/**
 * Maintenance Expense Service - Manages maintenance expense tracking and analysis
 * 
 * Features:
 * - Maintenance expense creation and management
 * - Maintenance type categorization
 * - Maintenance scheduling and tracking
 * - Workshop management
 * - Parts inventory integration
 * - Maintenance cost analysis
 * - Maintenance history tracking
 * - Predictive maintenance analytics
 */
@Singleton
class MaintenanceExpenseService @Inject constructor(
    private val context: Context,
    private val database: EdhamDatabase,
    private val maintenanceExpenseApi: MaintenanceExpenseApi,
    private val vehicleApi: VehicleApi,
    private val workshopApi: WorkshopApi,
    private val networkUtils: NetworkUtils,
    private val securityUtils: SecurityUtils
) {
    
    private val _maintenanceExpenseState = MutableStateFlow<MaintenanceExpenseState>(MaintenanceExpenseState.Idle)
    val maintenanceExpenseState: StateFlow<MaintenanceExpenseState> = _maintenanceExpenseState.asStateFlow()
    
    private val _maintenanceExpenses = MutableStateFlow<List<MaintenanceExpense>>(emptyList())
    val maintenanceExpenses: StateFlow<List<MaintenanceExpense>> = _maintenanceExpenses.asStateFlow()
    
    private val _maintenanceExpenseStats = MutableStateFlow<MaintenanceExpenseStats>(MaintenanceExpenseStats())
    val maintenanceExpenseStats: StateFlow<MaintenanceExpenseStats> = _maintenanceExpenseStats.asStateFlow()
    
    private var isInitialized = false
    
    companion object {
        private const val TAG = "MaintenanceExpenseService"
        private const val DEFAULT_CURRENCY = "SAR"
        private const val MAINTENANCE_COST_UPDATE_INTERVAL_MS = 24 * 60 * 60 * 1000L // 24 hours
        private const val PREVENTIVE_MAINTENANCE_INTERVAL_KM = 10000f // km
        private const val MAX_MAINTENANCE_COST = 50000f
    }
    
    /**
     * Initialize maintenance expense service
     */
    suspend fun initialize(): Result<Boolean> {
        return withContext(Dispatchers.IO) {
            try {
                _maintenanceExpenseState.value = MaintenanceExpenseState.Initializing
                
                // Load maintenance expense configuration
                loadMaintenanceExpenseConfiguration()
                
                // Load recent maintenance expenses
                loadRecentMaintenanceExpenses()
                
                // Load maintenance types
                loadMaintenanceTypes()
                
                isInitialized = true
                _maintenanceExpenseState.value = MaintenanceExpenseState.Ready
                Result.success(true)
                
            } catch (e: Exception) {
                _maintenanceExpenseState.value = MaintenanceExpenseState.Error("Failed to initialize maintenance expense service: ${e.message}")
                Result.failure(e)
            }
        }
    }
    
    /**
     * Create maintenance expense
     */
    suspend fun createMaintenanceExpense(
        maintenanceExpenseRequest: MaintenanceExpenseRequest
    ): Result<MaintenanceExpense> {
        return withContext(Dispatchers.IO) {
            try {
                if (!isInitialized) {
                    throw Exception("Maintenance expense service not initialized")
                }
                
                _maintenanceExpenseState.value = MaintenanceExpenseState.Processing
                
                // Validate maintenance expense request
                validateMaintenanceExpenseRequest(maintenanceExpenseRequest)
                
                // Get vehicle information
                val vehicle = vehicleApi.getVehicleById(maintenanceExpenseRequest.vehicleId)
                    ?: throw Exception("Vehicle not found")
                
                // Get workshop information
                val workshop = maintenanceExpenseRequest.workshopId?.let { workshopId ->
                    workshopApi.getWorkshopById(workshopId)
                }
                
                // Create maintenance expense
                val maintenanceExpense = MaintenanceExpense(
                    id = UUID.randomUUID().toString(),
                    vehicleId = maintenanceExpenseRequest.vehicleId,
                    maintenanceType = maintenanceExpenseRequest.maintenanceType,
                    description = maintenanceExpenseRequest.description,
                    date = maintenanceExpenseRequest.date,
                    odometerReading = maintenanceExpenseRequest.odometerReading,
                    workshopId = maintenanceExpenseRequest.workshopId,
                    workshopName = workshop?.name,
                    laborCost = maintenanceExpenseRequest.laborCost,
                    partsCost = maintenanceExpenseRequest.partsCost,
                    totalCost = (maintenanceExpenseRequest.laborCost ?: 0f) + (maintenanceExpenseRequest.partsCost ?: 0f),
                    currency = maintenanceExpenseRequest.currency ?: DEFAULT_CURRENCY,
                    parts = maintenanceExpenseRequest.parts,
                    receiptUrl = maintenanceExpenseRequest.receiptUrl,
                    status = MaintenanceExpenseStatus.PENDING,
                    metadata = maintenanceExpenseRequest.metadata,
                    createdAt = Date(),
                    updatedAt = Date()
                )
                
                // Save to database
                val savedMaintenanceExpense = database.maintenanceExpenseDao().insertMaintenanceExpense(maintenanceExpense.toEntity())
                    .let { id -> maintenanceExpense.copy(id = id.toString()) }
                
                // Add to maintenance expenses list
                addToMaintenanceExpenses(savedMaintenanceExpense)
                
                // Update vehicle maintenance information
                updateVehicleMaintenanceInfo(vehicle, savedMaintenanceExpense)
                
                // Check for auto-approval
                if (shouldAutoApprove(maintenanceExpenseRequest)) {
                    processAutoApproval(savedMaintenanceExpense)
                } else {
                    // Submit for approval
                    submitForApproval(savedMaintenanceExpense)
                }
                
                // Update stats
                updateMaintenanceExpenseStats()
                
                _maintenanceExpenseState.value = MaintenanceExpenseState.Ready
                Result.success(savedMaintenanceExpense)
                
            } catch (e: Exception) {
                _maintenanceExpenseState.value = MaintenanceExpenseState.Error("Maintenance expense creation failed: ${e.message}")
                Result.failure(e)
            }
        }
    }
    
    /**
     * Update maintenance expense
     */
    suspend fun updateMaintenanceExpense(
        maintenanceExpense: MaintenanceExpense
    ): Result<MaintenanceExpense> {
        return withContext(Dispatchers.IO) {
            try {
                if (!isInitialized) {
                    throw Exception("Maintenance expense service not initialized")
                }
                
                _maintenanceExpenseState.value = MaintenanceExpenseState.Processing
                
                // Validate maintenance expense
                validateMaintenanceExpense(maintenanceExpense)
                
                // Recalculate total cost
                val updatedMaintenanceExpense = maintenanceExpense.copy(
                    totalCost = (maintenanceExpense.laborCost ?: 0f) + (maintenanceExpense.partsCost ?: 0f),
                    updatedAt = Date()
                )
                
                // Update in database
                database.maintenanceExpenseDao().updateMaintenanceExpense(updatedMaintenanceExpense.toEntity())
                
                // Update in list
                updateMaintenanceExpenseInList(updatedMaintenanceExpense)
                
                // Update stats
                updateMaintenanceExpenseStats()
                
                _maintenanceExpenseState.value = MaintenanceExpenseState.Ready
                Result.success(updatedMaintenanceExpense)
                
            } catch (e: Exception) {
                _maintenanceExpenseState.value = MaintenanceExpenseState.Error("Maintenance expense update failed: ${e.message}")
                Result.failure(e)
            }
        }
    }
    
    /**
     * Process maintenance approval
     */
    suspend fun processMaintenanceApproval(
        maintenanceExpenseId: String,
        approved: Boolean,
        approverId: String,
        notes: String? = null
    ): Result<MaintenanceExpense> {
        return withContext(Dispatchers.IO) {
            try {
                val maintenanceExpense = _maintenanceExpenses.value.find { it.id == maintenanceExpenseId }
                    ?: throw Exception("Maintenance expense not found")
                
                if (maintenanceExpense.status != MaintenanceExpenseStatus.PENDING) {
                    throw Exception("Maintenance expense is not pending approval")
                }
                
                _maintenanceExpenseState.value = MaintenanceExpenseState.Processing
                
                val updatedMaintenanceExpense = if (approved) {
                    maintenanceExpense.copy(
                        status = MaintenanceExpenseStatus.APPROVED,
                        approvedBy = approverId,
                        approvalNotes = notes,
                        approvedAt = Date(),
                        updatedAt = Date()
                    )
                } else {
                    maintenanceExpense.copy(
                        status = MaintenanceExpenseStatus.REJECTED,
                        rejectedBy = approverId,
                        rejectionReason = notes,
                        rejectedAt = Date(),
                        updatedAt = Date()
                    )
                }
                
                // Update in database
                database.maintenanceExpenseDao().updateMaintenanceExpense(updatedMaintenanceExpense.toEntity())
                
                // Update in list
                updateMaintenanceExpenseInList(updatedMaintenanceExpense)
                
                // Update stats
                updateMaintenanceExpenseStats()
                
                _maintenanceExpenseState.value = MaintenanceExpenseState.Ready
                Result.success(updatedMaintenanceExpense)
                
            } catch (e: Exception) {
                _maintenanceExpenseState.value = MaintenanceExpenseState.Error("Maintenance approval processing failed: ${e.message}")
                Result.failure(e)
            }
        }
    }
    
    /**
     * Get maintenance expense by ID
     */
    suspend fun getMaintenanceExpense(maintenanceExpenseId: String): MaintenanceExpense? {
        return withContext(Dispatchers.IO) {
            try {
                // Try cache first
                _maintenanceExpenses.value.find { it.id == maintenanceExpenseId }
                    ?: database.maintenanceExpenseDao().getMaintenanceExpenseById(maintenanceExpenseId.toLong())?.toDomainModel()
            } catch (e: Exception) {
                null
            }
        }
    }
    
    /**
     * Get maintenance expense history
     */
    suspend fun getMaintenanceExpenseHistory(
        vehicleId: String? = null,
        dateRange: DateRange = DateRange.last30Days(),
        maintenanceType: MaintenanceType? = null
    ): Result<List<MaintenanceExpense>> {
        return withContext(Dispatchers.IO) {
            try {
                val maintenanceExpenses = database.maintenanceExpenseDao().getMaintenanceExpenseHistory(
                    vehicleId = vehicleId?.toLong(),
                    startDate = dateRange.startDate,
                    endDate = dateRange.endDate,
                    maintenanceType = maintenanceType
                ).map { it.toDomainModel() }
                
                Result.success(maintenanceExpenses)
                
            } catch (e: Exception) {
                Result.failure(e)
            }
        }
    }
    
    /**
     * Get maintenance expense analytics
     */
    suspend fun getMaintenanceExpenseAnalytics(
        dateRange: DateRange = DateRange.last30Days()
    ): Result<MaintenanceExpenseAnalytics> {
        return withContext(Dispatchers.IO) {
            try {
                val maintenanceExpenses = getMaintenanceExpenseHistory(null, dateRange).getOrThrow()
                
                val analytics = MaintenanceExpenseAnalytics(
                    totalExpenses = maintenanceExpenses.size,
                    totalCost = maintenanceExpenses.sumOf { it.totalCost.toDouble() }.toFloat(),
                    approvedExpenses = maintenanceExpenses.count { it.status == MaintenanceExpenseStatus.APPROVED },
                    pendingExpenses = maintenanceExpenses.count { it.status == MaintenanceExpenseStatus.PENDING },
                    rejectedExpenses = maintenanceExpenses.count { it.status == MaintenanceExpenseStatus.REJECTED },
                    averageCost = if (maintenanceExpenses.isNotEmpty()) maintenanceExpenses.map { it.totalCost }.average().toFloat() else 0f,
                    maintenanceTypeStats = maintenanceExpenses.groupBy { it.maintenanceType }.mapValues { it.value.size },
                    vehicleStats = maintenanceExpenses.groupBy { it.vehicleId }.mapValues { it.value.size },
                    workshopStats = maintenanceExpenses.groupBy { it.workshopId }.mapValues { it.value.size },
                    monthlyStats = calculateMonthlyMaintenanceStats(maintenanceExpenses),
                    costTrend = calculateCostTrend(maintenanceExpenses),
                    predictiveMaintenance = calculatePredictiveMaintenance(maintenanceExpenses)
                )
                
                Result.success(analytics)
                
            } catch (e: Exception) {
                Result.failure(e)
            }
        }
    }
    
    /**
     * Get vehicle maintenance history
     */
    suspend fun getVehicleMaintenanceHistory(
        vehicleId: String,
        dateRange: DateRange = DateRange.last90Days()
    ): Result<VehicleMaintenanceHistory> {
        return withContext(Dispatchers.IO) {
            try {
                val maintenanceExpenses = getMaintenanceExpenseHistory(vehicleId, dateRange).getOrThrow()
                val vehicle = vehicleApi.getVehicleById(vehicleId) ?: throw Exception("Vehicle not found")
                
                val history = VehicleMaintenanceHistory(
                    vehicleId = vehicleId,
                    totalMaintenanceCost = maintenanceExpenses.sumOf { it.totalCost.toDouble() }.toFloat(),
                    maintenanceCount = maintenanceExpenses.size,
                    averageCost = if (maintenanceExpenses.isNotEmpty()) maintenanceExpenses.map { it.totalCost }.average().toFloat() else 0f,
                    lastMaintenanceDate = maintenanceExpenses.maxOfOrNull { it.date },
                    nextMaintenanceDate = calculateNextMaintenanceDate(vehicle, maintenanceExpenses),
                    maintenanceTypeStats = maintenanceExpenses.groupBy { it.maintenanceType }.mapValues { it.value.size },
                    costTrend = calculateCostTrend(maintenanceExpenses),
                    maintenanceEfficiency = calculateMaintenanceEfficiency(vehicle, maintenanceExpenses)
                )
                
                Result.success(history)
                
            } catch (e: Exception) {
                Result.failure(e)
            }
        }
    }
    
    /**
     * Get maintenance recommendations
     */
    suspend fun getMaintenanceRecommendations(
        vehicleId: String
    ): Result<List<MaintenanceRecommendation>> {
        return withContext(Dispatchers.IO) {
            try {
                val vehicle = vehicleApi.getVehicleById(vehicleId) ?: throw Exception("Vehicle not found")
                val maintenanceExpenses = getMaintenanceExpenseHistory(vehicleId, DateRange.last90Days()).getOrThrow()
                
                val recommendations = mutableListOf<MaintenanceRecommendation>()
                
                // Check for preventive maintenance
                val lastMaintenance = maintenanceExpenses.maxByOrNull { it.date }
                val currentOdometer = vehicle.currentOdometer ?: 0f
                
                if (lastMaintenance != null && lastMaintenance.odometerReading != null) {
                    val kmSinceLastMaintenance = currentOdometer - lastMaintenance.odometerReading
                    if (kmSinceLastMaintenance >= PREVENTIVE_MAINTENANCE_INTERVAL_KM) {
                        recommendations.add(
                            MaintenanceRecommendation(
                                type = MaintenanceType.PREVENTIVE,
                                priority = RecommendationPriority.HIGH,
                                description = "Preventive maintenance recommended based on mileage",
                                estimatedCost = calculateEstimatedMaintenanceCost(MaintenanceType.PREVENTIVE, vehicle),
                                dueDate = Date(),
                                vehicleId = vehicleId
                            )
                        )
                    }
                }
                
                // Check for oil change
                val oilChangeExpenses = maintenanceExpenses.filter { it.maintenanceType == MaintenanceType.OIL_CHANGE }
                val lastOilChange = oilChangeExpenses.maxByOrNull { it.date }
                
                if (lastOilChange != null && lastOilChange.odometerReading != null) {
                    val kmSinceLastOilChange = currentOdometer - lastOilChange.odometerReading
                    if (kmSinceLastOilChange >= 5000f) { // Oil change every 5000km
                        recommendations.add(
                            MaintenanceRecommendation(
                                type = MaintenanceType.OIL_CHANGE,
                                priority = RecommendationPriority.MEDIUM,
                                description = "Oil change recommended based on mileage",
                                estimatedCost = calculateEstimatedMaintenanceCost(MaintenanceType.OIL_CHANGE, vehicle),
                                dueDate = Date(),
                                vehicleId = vehicleId
                            )
                        )
                    }
                }
                
                // Check for tire replacement
                val tireExpenses = maintenanceExpenses.filter { it.maintenanceType == MaintenanceType.TIRE_REPLACEMENT }
                val lastTireReplacement = tireExpenses.maxByOrNull { it.date }
                
                if (lastTireReplacement != null) {
                    val monthsSinceLastTireReplacement = ((Date().time - lastTireReplacement.date.time) / (1000 * 60 * 60 * 24 * 30f)).toInt()
                    if (monthsSinceLastTireReplacement >= 24) { // Replace tires every 2 years
                        recommendations.add(
                            MaintenanceRecommendation(
                                type = MaintenanceType.TIRE_REPLACEMENT,
                                priority = RecommendationPriority.LOW,
                                description = "Tire replacement recommended based on time",
                                estimatedCost = calculateEstimatedMaintenanceCost(MaintenanceType.TIRE_REPLACEMENT, vehicle),
                                dueDate = Date(),
                                vehicleId = vehicleId
                            )
                        )
                    }
                }
                
                Result.success(recommendations)
                
            } catch (e: Exception) {
                Result.failure(e)
            }
        }
    }
    
