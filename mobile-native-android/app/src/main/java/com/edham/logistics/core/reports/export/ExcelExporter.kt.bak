    private fun createPaymentMethodsSheet(sheet: Sheet, paymentMethods: List<PaymentMethodAnalysis>) {
        val headerStyle = createHeaderStyle(sheet.workbook)
        val dataStyle = createDataStyle(sheet.workbook)
        val currencyStyle = createCurrencyStyle(sheet.workbook)
        val percentageStyle = createPercentageStyle(sheet.workbook)
        
        var rowIndex = 0
        
        // Headers
        createHeaderCell(sheet, rowIndex, 0, "Payment Method", headerStyle)
        createHeaderCell(sheet, rowIndex, 1, "Transactions", headerStyle)
        createHeaderCell(sheet, rowIndex, 2, "Total Amount", headerStyle)
        createHeaderCell(sheet, rowIndex, 3, "Average Amount", headerStyle)
        createHeaderCell(sheet, rowIndex, 4, "Percentage", headerStyle)
        rowIndex++
        
        // Data
        paymentMethods.forEach { payment ->
            createDataCell(sheet, rowIndex, 0, payment.paymentMethod, dataStyle)
            createDataCell(sheet, rowIndex, 1, payment.transactionCount, dataStyle)
            createDataCell(sheet, rowIndex, 2, payment.totalAmount, currencyStyle)
            createDataCell(sheet, rowIndex, 3, payment.averageAmount, currencyStyle)
            createDataCell(sheet, rowIndex, 4, payment.percentage, percentageStyle)
            rowIndex++
        }
        
        // Auto-size columns
        for (i in 0..4) {
            sheet.autoSizeColumn(i)
        }
    }

    // Shipment Performance Sheet Creation Methods
    
    private fun createShipmentSummarySheet(sheet: Sheet, report: ShipmentPerformanceReport) {
        val headerStyle = createHeaderStyle(sheet.workbook)
        val dataStyle = createDataStyle(sheet.workbook)
        val percentageStyle = createPercentageStyle(sheet.workbook)
        
        var rowIndex = 0
        
        // Title
        createTitleCell(sheet, rowIndex, 0, report.title, 5)
        rowIndex += 2
        
        // Report Info
        createLabelCell(sheet, rowIndex, 0, "Generated:", dataStyle)
        createDataCell(sheet, rowIndex, 1, dateTimeFormat.format(Date(report.generatedAt)), dataStyle)
        rowIndex++
        
        createLabelCell(sheet, rowIndex, 0, "Period:", dataStyle)
        createDataCell(sheet, rowIndex, 1, "${dateFormat.format(Date(report.startDate))} - ${dateFormat.format(Date(report.endDate))}", dataStyle)
        rowIndex += 2
        
        // Executive Summary
        createHeaderCell(sheet, rowIndex, 0, "Executive Summary", headerStyle)
        rowIndex++
        
        val summaryData = listOf(
            "Total Shipments" to report.totalShipments.toDouble(),
            "Delivered Shipments" to report.deliveredShipments.toDouble(),
            "Delayed Shipments" to report.delayedShipments.toDouble(),
            "Cancelled Shipments" to report.cancelledShipments.toDouble(),
            "On-Time Delivery Rate" to report.onTimeDeliveryRate,
            "Average Delivery Time (Hours)" to (report.averageDeliveryTime / (1000 * 60 * 60))
        )
        
        summaryData.forEach { (label, value) ->
            createLabelCell(sheet, rowIndex, 0, label, dataStyle)
            when (label) {
                "On-Time Delivery Rate" -> {
                    createDataCell(sheet, rowIndex, 1, value, percentageStyle)
                }
                else -> {
                    createDataCell(sheet, rowIndex, 1, value, dataStyle)
                }
            }
            rowIndex++
        }
        
        // Auto-size columns
        for (i in 0..4) {
            sheet.autoSizeColumn(i)
        }
    }

