        rowIndex++
        
        val teamData = listOf(
            "Total Drivers" to report.teamStatistics.totalDrivers.toDouble(),
            "Average On-Time Rate" to report.teamStatistics.averageOnTimeDeliveryRate,
            "Average Satisfaction" to report.teamStatistics.averageCustomerSatisfaction,
            "Total Revenue Generated" to report.teamStatistics.totalRevenueGenerated
        )
        
        teamData.forEach { (label, value) ->
            createLabelCell(sheet, rowIndex, 0, label, dataStyle)
            when (label) {
                "Average On-Time Rate" -> {
                    createDataCell(sheet, rowIndex, 1, value, percentageStyle)
                }
                "Total Revenue Generated" -> {
                    createDataCell(sheet, rowIndex, 1, value, currencyStyle)
                }
                else -> {
                    createDataCell(sheet, rowIndex, 1, value, dataStyle)
                }
            }
            rowIndex++
        }
        
        // Auto-size columns
        for (i in 0..4) {
            sheet.autoSizeColumn(i)
        }
    }

    private fun createAllDriversSheet(sheet: Sheet, driverPerformances: List<DriverPerformance>) {
        val headerStyle = createHeaderStyle(sheet.workbook)
        val dataStyle = createDataStyle(sheet.workbook)
        val currencyStyle = createCurrencyStyle(sheet.workbook)
        val percentageStyle = createPercentageStyle(sheet.workbook)
        
        var rowIndex = 0
        
        // Headers
        createHeaderCell(sheet, rowIndex, 0, "Driver Name", headerStyle)
        createHeaderCell(sheet, rowIndex, 1, "Total Shipments", headerStyle)
        createHeaderCell(sheet, rowIndex, 2, "Delivered", headerStyle)
        createHeaderCell(sheet, rowIndex, 3, "Delayed", headerStyle)
        createHeaderCell(sheet, rowIndex, 4, "On-Time Rate", headerStyle)
        createHeaderCell(sheet, rowIndex, 5, "Revenue", headerStyle)
        createHeaderCell(sheet, rowIndex, 6, "Satisfaction", headerStyle)
        createHeaderCell(sheet, rowIndex, 7, "Rating", headerStyle)
        rowIndex++
        
        // Data
        driverPerformances.forEach { driver ->
            createDataCell(sheet, rowIndex, 0, driver.driverName, dataStyle)
            createDataCell(sheet, rowIndex, 1, driver.totalShipments, dataStyle)
            createDataCell(sheet, rowIndex, 2, driver.deliveredShipments, dataStyle)
            createDataCell(sheet, rowIndex, 3, driver.delayedShipments, dataStyle)
            createDataCell(sheet, rowIndex, 4, driver.onTimeDeliveryRate, percentageStyle)
            createDataCell(sheet, rowIndex, 5, driver.revenueGenerated, currencyStyle)
            createDataCell(sheet, rowIndex, 6, driver.customerSatisfaction, dataStyle)
            createDataCell(sheet, rowIndex, 7, driver.rating, dataStyle)
            rowIndex++
        }
        
        // Auto-size columns
        for (i in 0..7) {
            sheet.autoSizeColumn(i)
        }
    }

    private fun createTopPerformersSheet(sheet: Sheet, topPerformers: List<DriverPerformance>) {
        val headerStyle = createHeaderStyle(sheet.workbook)
        val dataStyle = createDataStyle(sheet.workbook)
        val currencyStyle = createCurrencyStyle(sheet.workbook)
        val percentageStyle = createPercentageStyle(sheet.workbook)
        
        var rowIndex = 0
        
        // Headers
        createHeaderCell(sheet, rowIndex, 0, "Rank", headerStyle)
        createHeaderCell(sheet, rowIndex, 1, "Driver Name", headerStyle)
        createHeaderCell(sheet, rowIndex, 2, "Total Shipments", headerStyle)
        createHeaderCell(sheet, rowIndex, 3, "On-Time Rate", headerStyle)
        createHeaderCell(sheet, rowIndex, 4, "Revenue", headerStyle)
        createHeaderCell(sheet, rowIndex, 5, "Rating", headerStyle)
        rowIndex++
        
        // Data
        topPerformers.forEachIndexed { index, driver ->
            createDataCell(sheet, rowIndex, 0, index + 1, dataStyle)
            createDataCell(sheet, rowIndex, 1, driver.driverName, dataStyle)
            createDataCell(sheet, rowIndex, 2, driver.totalShipments, dataStyle)
            createDataCell(sheet, rowIndex, 3, driver.onTimeDeliveryRate, percentageStyle)
            createDataCell(sheet, rowIndex, 4, driver.revenueGenerated, currencyStyle)
            createDataCell(sheet, rowIndex, 5, driver.rating, dataStyle)
            rowIndex++
        }
        
        // Auto-size columns
        for (i in 0..5) {
            sheet.autoSizeColumn(i)
        }
    }

    // Customer Behavior Sheet Creation Methods
    
    private fun createCustomerSummarySheet(sheet: Sheet, report: CustomerBehaviorReport) {
        val headerStyle = createHeaderStyle(sheet.workbook)
        val dataStyle = createDataStyle(sheet.workbook)
        val currencyStyle = createCurrencyStyle(sheet.workbook)
        val percentageStyle = createPercentageStyle(sheet.workbook)
        
        var rowIndex = 0
        
        // Title
        createTitleCell(sheet, rowIndex, 0, report.title, 5)
        rowIndex += 2
        
        // Report Info
        createLabelCell(sheet, rowIndex, 0, "Generated:", dataStyle)
        createDataCell(sheet, rowIndex, 1, dateTimeFormat.format(Date(report.generatedAt)), dataStyle)
        rowIndex++
        
        createLabelCell(sheet, rowIndex, 0, "Period:", dataStyle)
        createDataCell(sheet, rowIndex, 1, "${dateFormat.format(Date(report.startDate))} - ${dateFormat.format(Date(report.endDate))}", dataStyle)
        rowIndex += 2
        
        // Market Segmentation
        createHeaderCell(sheet, rowIndex, 0, "Market Segmentation", headerStyle)
        rowIndex++
        
        report.marketSegmentation.segments.forEach { segment ->
            createLabelCell(sheet, rowIndex, 0, segment.name, dataStyle)
            createDataCell(sheet, rowIndex, 1, segment.customerCount, dataStyle)
            rowIndex++
        }
        
        rowIndex++
        
        // Customer Lifetime Value
        createHeaderCell(sheet, rowIndex, 0, "Customer Lifetime Value", headerStyle)
        rowIndex++
        
        val clvData = listOf(
            "Average CLV" to report.customerLifetimeValue.averageLifetimeValue,
            "Total CLV" to report.customerLifetimeValue.totalLifetimeValue,
            "Average Customer Lifetime (Months)" to report.customerLifetimeValue.averageCustomerLifetime
        )
        
        clvData.forEach { (label, value) ->
            createLabelCell(sheet, rowIndex, 0, label, dataStyle)
            when (label) {
                "Average CLV", "Total CLV" -> {
                    createDataCell(sheet, rowIndex, 1, value, currencyStyle)
                }
                else -> {
                    createDataCell(sheet, rowIndex, 1, value, dataStyle)
                }
            }
            rowIndex++
        }
        
        // Auto-size columns
        for (i in 0..4) {
            sheet.autoSizeColumn(i)
        }
    }

    private fun createCustomerInsightsSheet(sheet: Sheet, customerInsights: List<CustomerInsight>) {
        val headerStyle = createHeaderStyle(sheet.workbook)
        val dataStyle = createDataStyle(sheet.workbook)
        val currencyStyle = createCurrencyStyle(sheet.workbook)
        
        var rowIndex = 0
        
        // Headers
        createHeaderCell(sheet, rowIndex, 0, "Customer Name", headerStyle)
        createHeaderCell(sheet, rowIndex, 1, "Total Shipments", headerStyle)
        createHeaderCell(sheet, rowIndex, 2, "Total Revenue", headerStyle)
        createHeaderCell(sheet, rowIndex, 3, "Average Order Value", headerStyle)
        createHeaderCell(sheet, rowIndex, 4, "Loyalty Score", headerStyle)
        createHeaderCell(sheet, rowIndex, 5, "Risk Level", headerStyle)
        createHeaderCell(sheet, rowIndex, 6, "Growth Potential", headerStyle)
        rowIndex++
        
        // Data
        customerInsights.forEach { customer ->
            createDataCell(sheet, rowIndex, 0, customer.customerName, dataStyle)
            createDataCell(sheet, rowIndex, 1, customer.totalShipments, dataStyle)
            createDataCell(sheet, rowIndex, 2, customer.totalRevenue, currencyStyle)
            createDataCell(sheet, rowIndex, 3, customer.averageOrderValue, currencyStyle)
            createDataCell(sheet, rowIndex, 4, customer.loyaltyScore, dataStyle)
            createDataCell(sheet, rowIndex, 5, customer.riskLevel.toString(), dataStyle)
            createDataCell(sheet, rowIndex, 6, customer.growthPotential, dataStyle)
            rowIndex++
        }
        
        // Auto-size columns
        for (i in 0..6) {
            sheet.autoSizeColumn(i)
        }
    }

    private fun createTopCustomersSheet(sheet: Sheet, topCustomers: List<CustomerInsight>) {
        val headerStyle = createHeaderStyle(sheet.workbook)
        val dataStyle = createDataStyle(sheet.workbook)
        val currencyStyle = createCurrencyStyle(sheet.workbook)
        
        var rowIndex = 0
        
        // Headers
        createHeaderCell(sheet, rowIndex, 0, "Rank", headerStyle)
        createHeaderCell(sheet, rowIndex, 1, "Customer Name", headerStyle)
        createHeaderCell(sheet, rowIndex, 2, "Total Shipments", headerStyle)
        createHeaderCell(sheet, rowIndex, 3, "Total Revenue", headerStyle)
        createHeaderCell(sheet, rowIndex, 4, "Loyalty Score", headerStyle)
        rowIndex++
        
        // Data
        topCustomers.forEachIndexed { index, customer ->
            createDataCell(sheet, rowIndex, 0, index + 1, dataStyle)
            createDataCell(sheet, rowIndex, 1, customer.customerName, dataStyle)
            createDataCell(sheet, rowIndex, 2, customer.totalShipments, dataStyle)
            createDataCell(sheet, rowIndex, 3, customer.totalRevenue, currencyStyle)
            createDataCell(sheet, rowIndex, 4, customer.loyaltyScore, dataStyle)
            rowIndex++
        }
        
        // Auto-size columns
        for (i in 0..4) {
            sheet.autoSizeColumn(i)
        }
    }

    private fun createAtRiskCustomersSheet(sheet: Sheet, atRiskCustomers: List<CustomerInsight>) {
        val headerStyle = createHeaderStyle(sheet.workbook)
        val dataStyle = createDataStyle(sheet.workbook)
        val currencyStyle = createCurrencyStyle(sheet.workbook)
        
        var rowIndex = 0
        
        // Headers
        createHeaderCell(sheet, rowIndex, 0, "Customer Name", headerStyle)
        createHeaderCell(sheet, rowIndex, 1, "Total Shipments", headerStyle)
        createHeaderCell(sheet, rowIndex, 2, "Total Revenue", headerStyle)
        createHeaderCell(sheet, rowIndex, 3, "Risk Level", headerStyle)
        createHeaderCell(sheet, rowIndex, 4, "Growth Potential", headerStyle)
        rowIndex++
        
        // Data
        atRiskCustomers.forEach { customer ->
            createDataCell(sheet, rowIndex, 0, customer.customerName, dataStyle)
            createDataCell(sheet, rowIndex, 1, customer.totalShipments, dataStyle)
            createDataCell(sheet, rowIndex, 2, customer.totalRevenue, currencyStyle)
            createDataCell(sheet, rowIndex, 3, customer.riskLevel.toString(), dataStyle)
            createDataCell(sheet, rowIndex, 4, customer.growthPotential, dataStyle)
            rowIndex++
        }
        
        // Auto-size columns
        for (i in 0..4) {
            sheet.autoSizeColumn(i)
        }
    }

    // Cell Creation Helper Methods
    
    private fun createTitleCell(sheet: Sheet, row: Int, col: Int, value: String, colspan: Int) {
        val rowObj = sheet.getRow(row) ?: sheet.createRow(row)
        val cell = rowObj.createCell(col)
        cell.setCellValue(value)
        
        val style = sheet.workbook.createCellStyle()
        style.setFont(sheet.workbook.createFont().apply {
            fontHeightInPoints = 16.toShort()
            bold = true
        })
        style.setAlignment(HorizontalAlignment.CENTER)
        cell.cellStyle = style
        
        if (colspan > 1) {
            sheet.addMergedRegion(CellRangeAddress(row, row, col, col + colspan - 1))
        }
    }

    private fun createHeaderCell(sheet: Sheet, row: Int, col: Int, value: String, style: CellStyle) {
        val rowObj = sheet.getRow(row) ?: sheet.createRow(row)
        val cell = rowObj.createCell(col)
        cell.setCellValue(value)
        cell.cellStyle = style
    }

    private fun createLabelCell(sheet: Sheet, row: Int, col: Int, value: String, style: CellStyle) {
        val rowObj = sheet.getRow(row) ?: sheet.createRow(row)
        val cell = rowObj.createCell(col)
        cell.setCellValue(value)
        cell.cellStyle = style
    }

    private fun createDataCell(sheet: Sheet, row: Int, col: Int, value: String, style: CellStyle) {
        val rowObj = sheet.getRow(row) ?: sheet.createRow(row)
        val cell = rowObj.createCell(col)
        cell.setCellValue(value)
        cell.cellStyle = style
    }

    private fun createDataCell(sheet: Sheet, row: Int, col: Int, value: Double, style: CellStyle) {
        val rowObj = sheet.getRow(row) ?: sheet.createRow(row)
        val cell = rowObj.createCell(col)
        cell.setCellValue(value)
        cell.cellStyle = style
    }

    private fun createDataCell(sheet: Sheet, row: Int, col: Int, value: Int, style: CellStyle) {
        val rowObj = sheet.getRow(row) ?: sheet.createRow(row)
        val cell = rowObj.createCell(col)
        cell.setCellValue(value.toDouble())
        cell.cellStyle = style
    }

    // Style Creation Methods
    
    private fun createHeaderStyle(workbook: Workbook): CellStyle {
        return workbook.createCellStyle().apply {
            font = workbook.createFont().apply {
                fontHeightInPoints = 12.toShort()
                bold = true
                color = IndexedColors.WHITE.index
            }
            fillForegroundColor = IndexedColors.DARK_BLUE.index
            fillPattern = FillPatternType.SOLID_FOREGROUND
            alignment = HorizontalAlignment.CENTER
            verticalAlignment = VerticalAlignment.CENTER
            setBorder(BorderStyle.THIN, IndexedColors.BLACK.index, BorderStyle.THIN, IndexedColors.BLACK.index, BorderStyle.THIN, IndexedColors.BLACK.index, BorderStyle.THIN, IndexedColors.BLACK.index)
        }
    }

    private fun createDataStyle(workbook: Workbook): CellStyle {
        return workbook.createCellStyle().apply {
            font = workbook.createFont().apply {
                fontHeightInPoints = 11.toShort()
            }
            alignment = HorizontalAlignment.LEFT
            verticalAlignment = VerticalAlignment.CENTER
            setBorder(BorderStyle.THIN, IndexedColors.GREY_25_PERCENT.index, BorderStyle.THIN, IndexedColors.GREY_25_PERCENT.index, BorderStyle.THIN, IndexedColors.GREY_25_PERCENT.index, BorderStyle.THIN, IndexedColors.GREY_25_PERCENT.index)
        }
    }

    private fun createCurrencyStyle(workbook: Workbook): CellStyle {
        return workbook.createCellStyle().apply {
            font = workbook.createFont().apply {
                fontHeightInPoints = 11.toShort()
            }
            alignment = HorizontalAlignment.RIGHT
            verticalAlignment = VerticalAlignment.CENTER
            dataFormat = workbook.createDataFormat().getFormat("#,##0.00 \"SAR\"")
            setBorder(BorderStyle.THIN, IndexedColors.GREY_25_PERCENT.index, BorderStyle.THIN, IndexedColors.GREY_25_PERCENT.index, BorderStyle.THIN, IndexedColors.GREY_25_PERCENT.index, BorderStyle.THIN, IndexedColors.GREY_25_PERCENT.index)
        }
    }

    private fun createPercentageStyle(workbook: Workbook): CellStyle {
        return workbook.createCellStyle().apply {
            font = workbook.createFont().apply {
                fontHeightInPoints = 11.toShort()
            }
            alignment = HorizontalAlignment.RIGHT
            verticalAlignment = VerticalAlignment.CENTER
            dataFormat = workbook.createDataFormat().getFormat("0.0%")
            setBorder(BorderStyle.THIN, IndexedColors.GREY_25_PERCENT.index, BorderStyle.THIN, IndexedColors.GREY_25_PERCENT.index, BorderStyle.THIN, IndexedColors.GREY_25_PERCENT.index, BorderStyle.THIN, IndexedColors.GREY_25_PERCENT.index)
        }
    }

    /**
     * Create Excel file
     */
    private fun createExcelFile(fileName: String): File {
        val downloadsDir = File(context.getExternalFilesDir(null), "Reports")
        if (!downloadsDir.exists()) {
            downloadsDir.mkdirs()
        }
        
        val timestamp = SimpleDateFormat("yyyyMMdd_HHmmss", Locale.getDefault()).format(Date())
        val finalFileName = "${fileName}_$timestamp.xlsx"
        
        return File(downloadsDir, finalFileName)
    }
}
