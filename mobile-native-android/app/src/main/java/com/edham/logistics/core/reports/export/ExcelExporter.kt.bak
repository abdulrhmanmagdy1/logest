package com.edham.logistics.core.reports.export

import android.content.Context
import com.edham.logistics.core.reports.data.*
import kotlinx.coroutines.Dispatchers
import kotlinx.coroutines.withContext
import org.apache.poi.ss.usermodel.*
import org.apache.poi.ss.util.CellRangeAddress
import org.apache.poi.xssf.usermodel.XSSFWorkbook
import java.io.File
import java.io.FileOutputStream
import java.text.SimpleDateFormat
import java.util.*

/**
 * Excel Exporter - Handles export of reports to Excel format
 * Provides professional Excel generation with multiple sheets and formatting
 */
class ExcelExporter(private val context: Context) {

    private val dateFormat = SimpleDateFormat("yyyy-MM-dd", Locale.getDefault())
    private val dateTimeFormat = SimpleDateFormat("yyyy-MM-dd HH:mm:ss", Locale.getDefault())

    /**
     * Export revenue report to Excel
     */
    suspend fun exportRevenueReport(report: RevenueReport, fileName: String): String = withContext(Dispatchers.IO) {
        val workbook = XSSFWorkbook()
        
        try {
            // Create main sheet
            val mainSheet = workbook.createSheet("Revenue Summary")
            createRevenueSummarySheet(mainSheet, report)
            
            // Create detailed sheets
            if (report.revenueByPeriod.isNotEmpty()) {
                val periodSheet = workbook.createSheet("Revenue by Period")
                createRevenueByPeriodSheet(periodSheet, report.revenueByPeriod)
            }
            
            if (report.revenueByCustomer.isNotEmpty()) {
                val customerSheet = workbook.createSheet("Revenue by Customer")
                createRevenueByCustomerSheet(customerSheet, report.revenueByCustomer)
            }
            
            if (report.revenueByServiceType.isNotEmpty()) {
                val serviceSheet = workbook.createSheet("Revenue by Service")
                createRevenueByServiceSheet(serviceSheet, report.revenueByServiceType)
            }
            
            if (report.paymentMethods.isNotEmpty()) {
                val paymentSheet = workbook.createSheet("Payment Methods")
                createPaymentMethodsSheet(paymentSheet, report.paymentMethods)
            }
            
            // Save file
            val file = createExcelFile(fileName)
            val fileOutputStream = FileOutputStream(file)
            workbook.write(fileOutputStream)
            workbook.close()
            fileOutputStream.close()
            
            file.absolutePath
            
        } catch (e: Exception) {
            workbook.close()
            throw Exception("Failed to generate Excel: ${e.message}", e)
        }
    }

    /**
     * Export shipment performance report to Excel
     */
    suspend fun exportShipmentReport(report: ShipmentPerformanceReport, fileName: String): String = withContext(Dispatchers.IO) {
        val workbook = XSSFWorkbook()
        
        try {
            // Create main sheet
            val mainSheet = workbook.createSheet("Shipment Performance")
            createShipmentSummarySheet(mainSheet, report)
            
            // Create detailed sheets
            if (report.performanceByRoute.isNotEmpty()) {
                val routeSheet = workbook.createSheet("Performance by Route")
                createPerformanceByRouteSheet(routeSheet, report.performanceByRoute)
            }
            
            if (report.performanceByDriver.isNotEmpty()) {
                val driverSheet = workbook.createSheet("Performance by Driver")
                createPerformanceByDriverSheet(driverSheet, report.performanceByDriver)
            }
            
            if (report.performanceByVehicleType.isNotEmpty()) {
                val vehicleSheet = workbook.createSheet("Performance by Vehicle")
                createPerformanceByVehicleSheet(vehicleSheet, report.performanceByVehicleType)
            }
            
            if (report.geographicPerformance.isNotEmpty()) {
                val geoSheet = workbook.createSheet("Geographic Performance")
                createGeographicPerformanceSheet(geoSheet, report.geographicPerformance)
            }
            
            // Save file
            val file = createExcelFile(fileName)
            val fileOutputStream = FileOutputStream(file)
            workbook.write(fileOutputStream)
            workbook.close()
            fileOutputStream.close()
            
            file.absolutePath
            
        } catch (e: Exception) {
            workbook.close()
            throw Exception("Failed to generate Excel: ${e.message}", e)
        }
    }

    /**
     * Export driver performance report to Excel
     */
    suspend fun exportDriverReport(report: DriverPerformanceReport, fileName: String): String = withContext(Dispatchers.IO) {
        val workbook = XSSFWorkbook()
        
        try {
            // Create main sheet
            val mainSheet = workbook.createSheet("Driver Performance")
            createDriverSummarySheet(mainSheet, report)
            
            // Create detailed sheet
            val detailSheet = workbook.createSheet("All Drivers")
            createAllDriversSheet(detailSheet, report.driverPerformances)
            
            // Create top performers sheet
            val topSheet = workbook.createSheet("Top Performers")
            createTopPerformersSheet(topSheet, report.topPerformers)
            
            // Save file
            val file = createExcelFile(fileName)
            val fileOutputStream = FileOutputStream(file)
            workbook.write(fileOutputStream)
            workbook.close()
            fileOutputStream.close()
            
            file.absolutePath
            
        } catch (e: Exception) {
            workbook.close()
            throw Exception("Failed to generate Excel: ${e.message}", e)
        }
    }

    /**
     * Export customer behavior report to Excel
     */
    suspend fun exportCustomerReport(report: CustomerBehaviorReport, fileName: String): String = withContext(Dispatchers.IO) {
        val workbook = XSSFWorkbook()
        
        try {
            // Create main sheet
            val mainSheet = workbook.createSheet("Customer Behavior")
            createCustomerSummarySheet(mainSheet, report)
            
            // Create customer insights sheet
            val insightsSheet = workbook.createSheet("Customer Insights")
            createCustomerInsightsSheet(insightsSheet, report.customerInsights)
            
            // Create top customers sheet
            val topSheet = workbook.createSheet("Top Customers")
            createTopCustomersSheet(topSheet, report.topCustomers)
            
            // Create at risk customers sheet
            val riskSheet = workbook.createSheet("At Risk Customers")
            createAtRiskCustomersSheet(riskSheet, report.atRiskCustomers)
            
            // Save file
            val file = createExcelFile(fileName)
            val fileOutputStream = FileOutputStream(file)
            workbook.write(fileOutputStream)
            workbook.close()
            fileOutputStream.close()
            
            file.absolutePath
            
        } catch (e: Exception) {
            workbook.close()
            throw Exception("Failed to generate Excel: ${e.message}", e)
        }
    }

    // Revenue Report Sheet Creation Methods
    
    private fun createRevenueSummarySheet(sheet: Sheet, report: RevenueReport) {
        val headerStyle = createHeaderStyle(sheet.workbook)
        val dataStyle = createDataStyle(sheet.workbook)
        val currencyStyle = createCurrencyStyle(sheet.workbook)
        val percentageStyle = createPercentageStyle(sheet.workbook)
        
        var rowIndex = 0
        
        // Title
        createTitleCell(sheet, rowIndex, 0, report.title, 5)
        rowIndex += 2
        
        // Report Info
        createLabelCell(sheet, rowIndex, 0, "Generated:", dataStyle)
        createDataCell(sheet, rowIndex, 1, dateTimeFormat.format(Date(report.generatedAt)), dataStyle)
        rowIndex++
        
        createLabelCell(sheet, rowIndex, 0, "Period:", dataStyle)
        createDataCell(sheet, rowIndex, 1, "${dateFormat.format(Date(report.startDate))} - ${dateFormat.format(Date(report.endDate))}", dataStyle)
        rowIndex += 2
        
        // Executive Summary
        createHeaderCell(sheet, rowIndex, 0, "Executive Summary", headerStyle)
        rowIndex++
        
        val summaryData = listOf(
            "Total Revenue" to report.totalRevenue,
            "Total Invoices" to report.totalInvoices.toDouble(),
            "Paid Invoices" to report.paidInvoices.toDouble(),
            "Unpaid Invoices" to report.unpaidInvoices.toDouble(),
            "Average Invoice Value" to report.averageInvoiceValue,
            "Revenue Growth" to report.revenueGrowth
        )
        
        summaryData.forEach { (label, value) ->
            createLabelCell(sheet, rowIndex, 0, label, dataStyle)
            when (label) {
                "Total Revenue", "Average Invoice Value" -> {
                    createDataCell(sheet, rowIndex, 1, value, currencyStyle)
                }
                "Revenue Growth" -> {
                    createDataCell(sheet, rowIndex, 1, value, percentageStyle)
                }
                else -> {
                    createDataCell(sheet, rowIndex, 1, value.toInt(), dataStyle)
                }
            }
            rowIndex++
        }
        
        // Auto-size columns
        for (i in 0..4) {
            sheet.autoSizeColumn(i)
        }
    }

    private fun createRevenueByPeriodSheet(sheet: Sheet, revenueByPeriod: List<RevenueByPeriod>) {
        val headerStyle = createHeaderStyle(sheet.workbook)
        val dataStyle = createDataStyle(sheet.workbook)
        val currencyStyle = createCurrencyStyle(sheet.workbook)
        
        var rowIndex = 0
        
        // Headers
        createHeaderCell(sheet, rowIndex, 0, "Period", headerStyle)
        createHeaderCell(sheet, rowIndex, 1, "Revenue", headerStyle)
        createHeaderCell(sheet, rowIndex, 2, "Transactions", headerStyle)
        rowIndex++
        
        // Data
        revenueByPeriod.forEach { period ->
            createDataCell(sheet, rowIndex, 0, period.period, dataStyle)
            createDataCell(sheet, rowIndex, 1, period.revenue, currencyStyle)
            createDataCell(sheet, rowIndex, 2, period.transactionCount, dataStyle)
            rowIndex++
        }
        
        // Auto-size columns
        for (i in 0..2) {
            sheet.autoSizeColumn(i)
        }
    }

