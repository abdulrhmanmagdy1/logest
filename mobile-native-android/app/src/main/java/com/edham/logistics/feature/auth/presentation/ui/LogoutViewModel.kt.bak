package com.edham.logistics.feature.auth.presentation.ui

import androidx.lifecycle.viewModelScope
import com.edham.logistics.core.utils.Result
import com.edham.logistics.feature.auth.domain.usecase.LogoutUseCase
import com.edham.logistics.feature.auth.domain.usecase.SessionManagerUseCase
import com.edham.logistics.presentation.ui.base.BaseViewModel
import dagger.hilt.android.lifecycle.HiltViewModel
import kotlinx.coroutines.flow.MutableStateFlow
import kotlinx.coroutines.flow.StateFlow
import kotlinx.coroutines.flow.asStateFlow
import kotlinx.coroutines.launch
import javax.inject.Inject

@HiltViewModel
class LogoutViewModel @Inject constructor(
    private val logoutUseCase: LogoutUseCase,
    private val sessionManagerUseCase: SessionManagerUseCase
) : BaseViewModel<LogoutViewModel.LogoutUiState>() {

    private val _uiState = MutableStateFlow(LogoutUiState())
    val uiState: StateFlow<LogoutUiState> = _uiState.asStateFlow()

    override fun createInitialState(): LogoutUiState = LogoutUiState()

    init {
        checkCurrentUser()
    }

    private fun checkCurrentUser() {
        viewModelScope.launch {
            when (val result = sessionManagerUseCase()) {
                is Result.Success -> {
                    updateUiState {
                        copy(
                            currentUser = result.data,
                            isLoggedIn = result.data != null
                        )
                    }
                }
                is Result.Error -> {
                    updateUiState {
                        copy(
                            error = result.exception.message
                        )
                    }
                }
            }
        }
    }

    fun logout() {
        viewModelScope.launch {
            updateUiState { copy(isLoggingOut = true, error = null) }
            
            when (val result = logoutUseCase()) {
                is Result.Success -> {
                    updateUiState {
                        copy(
                            isLoggingOut = false,
                            isLoggedIn = false,
                            currentUser = null,
                            logoutSuccess = true
                        )
                    }
                }
                is Result.Error -> {
                    updateUiState {
                        copy(
                            isLoggingOut = false,
                            error = result.exception.message
                        )
                    }
                }
            }
        }
    }

    fun clearError() {
        updateUiState { copy(error = null) }
    }

    fun onLogoutHandled() {
        updateUiState { copy(logoutSuccess = false) }
    }

    data class LogoutUiState(
        val currentUser: com.edham.logistics.feature.auth.domain.model.User? = null,
        val isLoggedIn: Boolean = false,
        val isLoggingOut: Boolean = false,
        val logoutSuccess: Boolean = false,
        val error: String? = null
    ) : com.edham.logistics.presentation.ui.base.UiState {
        override fun copyLoading(isLoading: Boolean): UiState = copy(isLoggingOut = isLoading)
        override fun copyError(error: String?): UiState = copy(error = error)
        override fun copySuccess(message: String?): UiState = this // Logout doesn't use success messages
    }
}
