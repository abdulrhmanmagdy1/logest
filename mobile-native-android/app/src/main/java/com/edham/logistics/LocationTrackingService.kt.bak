package com.edham.logistics

import android.Manifest
import android.annotation.SuppressLint
import android.app.Service
import android.content.Context
import android.content.Intent
import android.content.pm.PackageManager
import android.location.Location
import android.location.LocationListener
import android.location.LocationManager
import android.os.Bundle
import android.os.IBinder
import android.os.Looper
import androidx.core.app.ActivityCompat
import com.google.android.gms.location.*
import kotlinx.coroutines.*
import java.util.concurrent.TimeUnit

class LocationTrackingService : Service() {
    
    private lateinit var fusedLocationClient: FusedLocationProviderClient
    private lateinit var locationCallback: LocationCallback
    private val scope = CoroutineScope(Dispatchers.Main + SupervisorJob())
    
    companion object {
        private const val LOCATION_UPDATE_INTERVAL = 30_000L // 30 seconds
        private const val FASTEST_LOCATION_INTERVAL = 15_000L // 15 seconds
        private const val LOCATION_ACCURACY_THRESHOLD = 100f // 100 meters
        
        fun startLocationTracking(context: Context) {
            val intent = Intent(context, LocationTrackingService::class.java)
            if (android.os.Build.VERSION.SDK_INT >= android.os.Build.VERSION_CODES.O) {
                context.startForegroundService(intent)
            } else {
                context.startService(intent)
            }
        }
        
        fun stopLocationTracking(context: Context) {
            val intent = Intent(context, LocationTrackingService::class.java)
            context.stopService(intent)
        }
    }
    
    override fun onCreate() {
        super.onCreate()
        fusedLocationClient = LocationServices.getFusedLocationProviderClient(this)
        setupLocationCallback()
    }
    
    override fun onStartCommand(intent: Intent?, flags: Int, startId: Int): Int {
        startLocationUpdates()
        return START_STICKY
    }
    
    override fun onBind(intent: Intent?): IBinder? = null
    
    private fun setupLocationCallback() {
        locationCallback = object : LocationCallback() {
            override fun onLocationResult(locationResult: LocationResult) {
                locationResult.lastLocation?.let { location ->
                    handleLocationUpdate(location)
                }
            }
            
            override fun onLocationAvailability(availability: LocationAvailability) {
                if (!availability.isLocationAvailable) {
                    // Handle location unavailable
                    handleLocationUnavailable()
                }
            }
        }
    }
    
    @SuppressLint("MissingPermission")
    private fun startLocationUpdates() {
        if (hasLocationPermission()) {
            val locationRequest = LocationRequest.Builder(
                Priority.PRIORITY_HIGH_ACCURACY,
                LOCATION_UPDATE_INTERVAL
            ).apply {
                setWaitForAccurateLocation(false)
                setMinUpdateIntervalMillis(FASTEST_LOCATION_INTERVAL)
                setMaxUpdateDelayMillis(TimeUnit.MINUTES.toMillis(2))
            }.build()
            
            fusedLocationClient.requestLocationUpdates(
                locationRequest,
                locationCallback,
                Looper.getMainLooper()
            )
        } else {
            // Handle missing permissions
            stopSelf()
        }
    }
    
    private fun hasLocationPermission(): Boolean {
        return ActivityCompat.checkSelfPermission(
            this,
            Manifest.permission.ACCESS_FINE_LOCATION
        ) == PackageManager.PERMISSION_GRANTED &&
        ActivityCompat.checkSelfPermission(
            this,
            Manifest.permission.ACCESS_COARSE_LOCATION
        ) == PackageManager.PERMISSION_GRANTED
    }
    
    private fun handleLocationUpdate(location: Location) {
        scope.launch {
            try {
                // Validate location accuracy
                if (location.accuracy > LOCATION_ACCURACY_THRESHOLD) {
                    return@launch // Skip inaccurate locations
                }
                
                // Update driver location in backend
                updateDriverLocation(location)
                
                // Check for geofence events
                checkGeofenceEvents(location)
                
                // Log location for analytics
                logLocationData(location)
                
            } catch (e: Exception) {
                // Handle location update errors
            }
        }
    }
    
    private suspend fun updateDriverLocation(location: Location) {
        // Simulate API call to update driver location
        delay(100) // Simulate network delay
        
        // In real app, send location to backend
        // Example: apiService.updateDriverLocation(driverId, location.latitude, location.longitude)
    }
    
    private suspend fun checkGeofenceEvents(location: Location) {
        // Check if driver entered/exited important locations
        MockData.loads.forEach { load ->
            if (load.status == "In Transit") {
                // Check proximity to pickup/delivery locations
                val pickupLocation = getLocationForAddress(load.from)
                val deliveryLocation = getLocationForAddress(load.to)
                
                pickupLocation?.let {
                    if (isNearLocation(location, it, 500f)) {
                        // Driver is near pickup location
                        handleNearPickupLocation(load.id)
                    }
                }
                
                deliveryLocation?.let {
                    if (isNearLocation(location, it, 500f)) {
                        // Driver is near delivery location
                        handleNearDeliveryLocation(load.id)
                    }
                }
            }
        }
    }
    
    private fun getLocationForAddress(address: String): Location? {
        // Simple geocoding simulation
        // In real app, use Geocoding API
        val locations = mapOf(
            "Riyadh" to Location("").apply {
                latitude = 24.7136
                longitude = 46.6753
            },
            "Jeddah" to Location("").apply {
                latitude = 21.3891
                longitude = 39.8579
            },
            "Dammam" to Location("").apply {
                latitude = 26.4262
                longitude = 50.0888
            },
            "Medina" to Location("").apply {
                latitude = 24.4584
                longitude = 39.6142
            }
        )
        
        return locations[address]
    }
    
    private fun isNearLocation(currentLocation: Location, targetLocation: Location, radius: Float): Boolean {
        val distance = currentLocation.distanceTo(targetLocation)
        return distance <= radius
    }
    
    private suspend fun handleNearPickupLocation(loadId: String) {
        // Send notification to supervisor
        val notificationsService = SmartNotificationsService(this)
        notificationsService.sendLoadAssigned(loadId, "قرب نقطة التحميل")
    }
    
    private suspend fun handleNearDeliveryLocation(loadId: String) {
        // Send notification to customer and supervisor
        val notificationsService = SmartNotificationsService(this)
        notificationsService.sendTripCompleted(loadId, "قرب نقطة التسليم")
    }
    
    private suspend fun logLocationData(location: Location) {
        // Log location for analytics and route optimization
        // In real app, send to analytics service
        delay(50) // Simulate logging delay
    }
    
    private fun handleLocationUnavailable() {
        // Handle cases where location is unavailable
        // Could switch to cell tower location or notify user
    }
    
    private fun stopLocationUpdates() {
        fusedLocationClient.removeLocationUpdates(locationCallback)
    }
    
    override fun onDestroy() {
        super.onDestroy()
        stopLocationUpdates()
        scope.cancel()
    }
}
