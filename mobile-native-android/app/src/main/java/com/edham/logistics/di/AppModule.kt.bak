package com.edham.logistics.di

import android.content.Context
import androidx.room.Room
import com.edham.logistics.data.local.database.EdhamDatabase
import com.edham.logistics.security.AuthManager
import com.edham.logistics.security.CertificatePinning
import com.google.gson.Gson
import com.google.gson.GsonBuilder
import dagger.Module
import dagger.Provides
import dagger.hilt.InstallIn
import dagger.hilt.android.qualifiers.ApplicationContext
import dagger.hilt.components.SingletonComponent
import javax.inject.Singleton

/**
 * Dependency Injection Module using Hilt
 * يوفر جميع الاعتماديات المطلوبة للتطبيق
 */
@Module
@InstallIn(SingletonComponent::class)
object AppModule {
    
    /**
     * Database Configuration
     */
    @Provides
    @Singleton
    fun provideEdhamDatabase(@ApplicationContext context: Context): EdhamDatabase {
        return Room.databaseBuilder(
            context,
            EdhamDatabase::class.java,
            "edham_database"
        )
            .fallbackToDestructiveMigration()
            .build()
    }
    
    /**
     * Network Configuration
     */
    @Provides
    @Singleton
    fun provideGson(): Gson {
        return GsonBuilder()
            .setLenient()
            .setDateFormat("yyyy-MM-dd'T'HH:mm:ss.SSS'Z'")
            .create()
    }
    
    /**
     * Security Configuration
     */
    @Provides
    @Singleton
    fun provideAuthManager(@ApplicationContext context: Context): AuthManager {
        return AuthManager.getInstance(context)
    }
    
    @Provides
    @Singleton
    fun provideCertificatePinning(@ApplicationContext context: Context): CertificatePinning {
        return CertificatePinning.getInstance(context)
    }
}
