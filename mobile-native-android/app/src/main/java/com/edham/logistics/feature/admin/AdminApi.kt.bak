package com.edham.logistics.feature.admin

import com.edham.logistics.data.local.entity.User
import com.edham.logistics.data.local.entity.Role
import com.edham.logistics.data.local.entity.Permission
import com.edham.logistics.data.local.entity.ActivityLog
import com.edham.logistics.data.local.entity.SystemSetting
import retrofit2.Response
import retrofit2.http.*

interface AdminApi {
    
    // User Management
    @GET("api/v1/admin/users")
    suspend fun getAllUsers(): List<User>
    
    @GET("api/v1/admin/users/{userId}")
    suspend fun getUser(@Path("userId") userId: String): Response<User>
    
    @POST("api/v1/admin/users")
    suspend fun createUser(@Body user: User): Response<User>
    
    @PUT("api/v1/admin/users/{userId}")
    suspend fun updateUser(
        @Path("userId") userId: String,
        @Body user: User
    ): Response<User>
    
    @DELETE("api/v1/admin/users/{userId}")
    suspend fun deleteUser(@Path("userId") userId: String): Response<Unit>
    
    @POST("api/v1/admin/users/{userId}/activate")
    suspend fun activateUser(@Path("userId") userId: String): Response<Unit>
    
    @POST("api/v1/admin/users/{userId}/deactivate")
    suspend fun deactivateUser(@Path("userId") userId: String): Response<Unit>
    
    @GET("api/v1/admin/users/search")
    suspend fun searchUsers(@Query("query") query: String): List<User>
    
    // Role Management
    @GET("api/v1/admin/roles")
    suspend fun getAllRoles(): List<Role>
    
    @GET("api/v1/admin/roles/{roleId}")
    suspend fun getRole(@Path("roleId") roleId: String): Response<Role>
    
    @POST("api/v1/admin/roles")
    suspend fun createRole(@Body role: Role): Response<Role>
    
    @PUT("api/v1/admin/roles/{roleId}")
    suspend fun updateRole(
        @Path("roleId") roleId: String,
        @Body role: Role
    ): Response<Role>
    
    @DELETE("api/v1/admin/roles/{roleId}")
    suspend fun deleteRole(@Path("roleId") roleId: String): Response<Unit>
    
    @GET("api/v1/admin/roles/{roleId}/users")
    suspend fun getUsersByRole(@Path("roleId") roleId: String): List<User>
    
    // Permission Management
    @GET("api/v1/admin/permissions")
    suspend fun getAllPermissions(): List<Permission>
    
    @GET("api/v1/admin/permissions/{permissionId}")
    suspend fun getPermission(@Path("permissionId") permissionId: String): Response<Permission>
    
    @POST("api/v1/admin/permissions")
    suspend fun createPermission(@Body permission: Permission): Response<Permission>
    
    @PUT("api/v1/admin/permissions/{permissionId}")
    suspend fun updatePermission(
        @Path("permissionId") permissionId: String,
        @Body permission: Permission
    ): Response<Permission>
    
    @DELETE("api/v1/admin/permissions/{permissionId}")
    suspend fun deletePermission(@Path("permissionId") permissionId: String): Response<Unit>
    
    @GET("api/v1/admin/permissions/hierarchy")
    suspend fun getPermissionHierarchy(): PermissionHierarchyResponse
    
    @POST("api/v1/admin/permissions/matrix")
    suspend fun getPermissionsMatrix(): PermissionsMatrixResponse
    
    // System Settings
    @GET("api/v1/admin/settings")
    suspend fun getSystemSettings(): List<SystemSetting>
    
    @GET("api/v1/admin/settings/{key}")
    suspend fun getSetting(@Path("key") key: String): Response<SystemSetting>
    
    @PUT("api/v1/admin/settings/{key}")
    suspend fun updateSetting(
        @Path("key") key: String,
        @Body setting: SystemSetting
    ): Response<SystemSetting>
    
    @POST("api/v1/admin/settings/batch")
    suspend fun updateSettingsBatch(@Body settings: List<SystemSetting>): Response<Unit>
    
    // Activity Logs
    @GET("api/v1/admin/activity-logs")
    suspend fun getActivityLogs(
        @Query("startDate") startDate: Long?,
        @Query("endDate") endDate: Long?,
        @Query("userId") userId: String?,
        @Query("action") action: String?,
        @Query("resourceType") resourceType: String?,
        @Query("limit") limit: Int?
    ): List<ActivityLog>
    
    @POST("api/v1/admin/activity-logs/sync")
    suspend fun syncActivityLogs(@Body logs: List<ActivityLog>): Response<Unit>
    
    @GET("api/v1/admin/activity-logs/export")
    suspend fun exportActivityLogs(
        @Query("format") format: String,
        @Query("startDate") startDate: Long?,
        @Query("endDate") endDate: Long?
    ): Response<ExportResponse>
    
    // System Overview
    @GET("api/v1/admin/system/overview")
    suspend fun getSystemOverview(): SystemOverviewResponse
    
    @GET("api/v1/admin/system/kpi")
    suspend fun getKPIMetrics(): KPIMetricsResponse
    
    @GET("api/v1/admin/system/health")
    suspend fun getSystemHealth(): SystemHealthResponse
    
    @GET("api/v1/admin/system/performance")
    suspend fun getSystemPerformance(): SystemPerformanceResponse
    
    // Analytics
    @GET("api/v1/admin/analytics/users")
    suspend fun getUserAnalytics(@Query("period") period: String): UserAnalyticsResponse
    
    @GET("api/v1/admin/analytics/roles")
    suspend fun getRoleAnalytics(): RoleAnalyticsResponse
    
    @GET("api/v1/admin/analytics/activities")
    suspend fun getActivityAnalytics(@Query("period") period: String): ActivityAnalyticsResponse
    
    @GET("api/v1/admin/analytics/performance")
    suspend fun getPerformanceAnalytics(@Query("period") period: String): PerformanceAnalyticsResponse
    
    @GET("api/v1/admin/analytics/dashboard")
    suspend fun getDashboardAnalytics(): DashboardAnalyticsResponse
    
    // Fleet Overview
    @GET("api/v1/admin/fleet/overview")
    suspend fun getFleetOverview(): FleetOverviewResponse
    
    @GET("api/v1/admin/fleet/drivers")
    suspend fun getDriversOverview(): DriversOverviewResponse
    
    @GET("api/v1/admin/fleet/vehicles")
    suspend fun getVehiclesOverview(): VehiclesOverviewResponse
    
    @GET("api/v1/admin/fleet/utilization")
    suspend fun getFleetUtilization(@Query("period") period: String): FleetUtilizationResponse
    
    // Shipment Overview
    @GET("api/v1/admin/shipments/overview")
    suspend fun getShipmentsOverview(): ShipmentsOverviewResponse
    
    @GET("api/v1/admin/shipments/analytics")
    suspend fun getShipmentAnalytics(@Query("period") period: String): ShipmentAnalyticsResponse
    
    @GET("api/v1/admin/shipments/performance")
    suspend fun getShipmentPerformance(@Query("period") period: String): ShipmentPerformanceResponse
    
    // Finance Overview
    @GET("api/v1/admin/finance/overview")
    suspend fun getFinanceOverview(): FinanceOverviewResponse
    
    @GET("api/v1/admin/finance/revenue")
    suspend fun getRevenueAnalytics(@Query("period") period: String): RevenueAnalyticsResponse
    
    @GET("api/v1/admin/finance/expenses")
    suspend fun getExpenseAnalytics(@Query("period") period: String): ExpenseAnalyticsResponse
    
    @GET("api/v1/admin/finance/profitability")
    suspend fun getProfitabilityAnalytics(@Query("period") period: String): ProfitabilityAnalyticsResponse
    
    // Driver Monitoring
    @GET("api/v1/admin/drivers/monitoring")
    suspend fun getDriverMonitoring(): DriverMonitoringResponse
    
    @GET("api/v1/admin/drivers/performance")
    suspend fun getDriverPerformance(@Query("period") period: String): DriverPerformanceResponse
    
    @GET("api/v1/admin/drivers/activity")
    suspend fun getDriverActivity(@Query("driverId") driverId: String, @Query("period") period: String): DriverActivityResponse
    
    // Monitoring Services
    @GET("api/v1/admin/monitoring/metrics")
    suspend fun getMonitoringMetrics(): MonitoringMetricsResponse
    
    @GET("api/v1/admin/monitoring/alerts")
    suspend fun getMonitoringAlerts(): MonitoringAlertsResponse
    
    @POST("api/v1/admin/monitoring/alerts/{alertId}/acknowledge")
    suspend fun acknowledgeAlert(@Path("alertId") alertId: String): Response<Unit>
    
    // Notification Controls
    @GET("api/v1/admin/notifications/settings")
    suspend fun getNotificationSettings(): NotificationSettingsResponse
    
    @PUT("api/v1/admin/notifications/settings")
    suspend fun updateNotificationSettings(@Body settings: NotificationSettingsRequest): Response<Unit>
    
    @POST("api/v1/admin/notifications/test")
    suspend fun testNotification(@Body notification: TestNotificationRequest): Response<Unit>
    
    @GET("api/v1/admin/notifications/history")
    suspend fun getNotificationHistory(@Query("limit") limit: Int?): NotificationHistoryResponse
    
    // System Maintenance
    @POST("api/v1/admin/system/maintenance/cleanup")
    suspend fun performSystemCleanup(): Response<MaintenanceResponse>
    
    @POST("api/v1/admin/system/maintenance/backup")
    suspend fun createSystemBackup(): Response<BackupResponse>
    
    @POST("api/v1/admin/system/maintenance/restore")
    suspend fun restoreSystemBackup(@Body backupRequest: RestoreBackupRequest): Response<RestoreResponse>
    
    @GET("api/v1/admin/system/maintenance/status")
    suspend fun getMaintenanceStatus(): MaintenanceStatusResponse
}

// Response data classes
data class PermissionHierarchyResponse(
    val categories: Map<String, List<PermissionItem>>
)

data class PermissionsMatrixResponse(
    val roles: List<Role>,
    val permissions: List<Permission>,
    val matrix: Map<String, Map<String, Boolean>>
)

data class PermissionItem(
    val key: String,
    val name: String,
    val description: String
)

data class SystemOverviewResponse(
    val totalUsers: Int,
    val activeUsers: Int,
    val totalRoles: Int,
    val totalPermissions: Int,
    val activeDrivers: Int,
    val totalVehicles: Int,
    val activeShipments: Int,
    val systemUptime: Long,
    val lastSync: Long
)

data class KPIMetricsResponse(
    val userGrowthRate: Double,
    val driverUtilizationRate: Double,
    val vehicleUtilizationRate: Double,
    val shipmentCompletionRate: Double,
    val averageResponseTime: Long,
    val systemPerformance: Double,
    val errorRate: Double,
    val lastUpdated: Long
)

data class SystemHealthResponse(
    val status: String,
    val checks: List<HealthCheck>,
    val timestamp: Long
)

data class HealthCheck(
    val name: String,
    val status: String,
    val message: String,
    val responseTime: Long
)

data class SystemPerformanceResponse(
    val cpuUsage: Double,
    val memoryUsage: Double,
    val diskUsage: Double,
    val networkLatency: Long,
    val databasePerformance: DatabasePerformance,
    val apiPerformance: ApiPerformance
)

data class DatabasePerformance(
    val connectionPool: ConnectionPoolStats,
    val queryPerformance: QueryPerformanceStats
)

data class ConnectionPoolStats(
    val active: Int,
    val idle: Int,
    val total: Int,
    val max: Int
)

data class QueryPerformanceStats(
    val averageResponseTime: Long,
    val slowQueries: Int,
    val totalQueries: Long
)

data class ApiPerformance(
    val averageResponseTime: Long,
    val requestsPerSecond: Double,
    val errorRate: Double,
    val slowEndpoints: List<EndpointStats>
)

data class EndpointStats(
    val endpoint: String,
    val averageResponseTime: Long,
    val requestCount: Long,
    val errorCount: Long
)

data class UserAnalyticsResponse(
    val totalUsers: Int,
    val activeUsers: Int,
    val inactiveUsers: Int,
    val usersByRole: List<RoleUserCount>,
    val recentUsers: Int,
    val userGrowthRate: Double,
    val userActivity: UserActivityStats
)

data class UserActivityStats(
    val dailyActiveUsers: Int,
    val weeklyActiveUsers: Int,
    val monthlyActiveUsers: Int,
    val averageSessionDuration: Long
)

data class RoleUserCount(
    val roleId: String,
    val roleName: String,
    val userCount: Int
)

data class RoleAnalyticsResponse(
    val totalRoles: Int,
    val rolesWithUsers: Int,
    val averageUsersPerRole: Double,
    val mostUsedRole: String?,
    val roleDistribution: List<RoleDistribution>
)

data class RoleDistribution(
    val roleId: String,
    val roleName: String,
    val userCount: Int,
    val percentage: Double
)

data class ActivityAnalyticsResponse(
    val totalActivities: Int,
    val recentActivities: Int,
    val activitiesByAction: Map<String, Int>,
    val activitiesByUser: Map<String, Int>,
    val mostActiveUser: String?,
    val activityTrends: List<ActivityTrend>
)

data class ActivityTrend(
    val date: String,
    val count: Int
)

data class PerformanceAnalyticsResponse(
    val systemUptime: Long,
    val averageResponseTime: Long,
    val errorRate: Double,
    val databasePerformance: DatabasePerformance,
    val apiPerformance: ApiPerformance,
    val performanceTrends: List<PerformanceTrend>
)

data class PerformanceTrend(
    val timestamp: Long,
    val responseTime: Long,
    val errorRate: Double
)

data class DashboardAnalyticsResponse(
    val userAnalytics: UserAnalyticsResponse,
    val roleAnalytics: RoleAnalyticsResponse,
    val activityAnalytics: ActivityAnalyticsResponse,
    val performanceAnalytics: PerformanceAnalyticsResponse,
    val fleetOverview: FleetOverviewResponse,
    val shipmentOverview: ShipmentsOverviewResponse,
    val financeOverview: FinanceOverviewResponse
)

data class FleetOverviewResponse(
    val totalVehicles: Int,
    val activeVehicles: Int,
    val inactiveVehicles: Int,
    val vehiclesByStatus: Map<String, Int>,
    val vehiclesByType: Map<String, Int>,
    val fleetUtilization: Double
)

data class DriversOverviewResponse(
    val totalDrivers: Int,
    val activeDrivers: Int,
    val onDutyDrivers: Int,
    val offDutyDrivers: Int,
    val driversByStatus: Map<String, Int>,
    val driverPerformance: DriverPerformanceSummary
)

data class DriverPerformanceSummary(
    val averageRating: Double,
    val totalTrips: Int,
    val averageResponseTime: Long,
    val onTimeDeliveryRate: Double
)

data class VehiclesOverviewResponse(
    val totalVehicles: Int,
    val activeVehicles: Int,
    val maintenanceVehicles: Int,
    val outOfServiceVehicles: Int,
    val vehiclesByStatus: Map<String, Int>,
    val vehicleUtilization: Double
)

data class FleetUtilizationResponse(
    val overallUtilization: Double,
    val driverUtilization: Double,
    val vehicleUtilization: Double,
    val utilizationByVehicle: List<VehicleUtilization>,
    val utilizationTrends: List<UtilizationTrend>
)

data class VehicleUtilization(
    val vehicleId: String,
    val vehicleName: String,
    val utilizationRate: Double,
    val totalHours: Long,
    val activeHours: Long
)

data class UtilizationTrend(
    val date: String,
    val utilization: Double
)

data class ShipmentsOverviewResponse(
    val totalShipments: Int,
    val activeShipments: Int,
    val completedShipments: Int,
    val cancelledShipments: Int,
    val shipmentsByStatus: Map<String, Int>,
    val shipmentsByType: Map<String, Int>,
    val completionRate: Double
)

data class ShipmentAnalyticsResponse(
    val totalShipments: Int,
    val completedShipments: Int,
    val completionRate: Double,
    val averageDeliveryTime: Long,
    val shipmentsByStatus: Map<String, Int>,
    val shipmentsByType: Map<String, Int>,
    val shipmentTrends: List<ShipmentTrend>
)

data class ShipmentTrend(
    val date: String,
    val count: Int,
    val completionRate: Double
)

data class ShipmentPerformanceResponse(
    val averageDeliveryTime: Long,
    val onTimeDeliveryRate: Double,
    val customerSatisfactionScore: Double,
    val deliveryPerformance: List<DeliveryPerformance>
)

data class DeliveryPerformance(
    val period: String,
    val averageTime: Long,
    val onTimeRate: Double,
    val satisfactionScore: Double
)

data class FinanceOverviewResponse(
    val totalRevenue: Double,
    val totalExpenses: Double,
    val netProfit: Double,
    val profitMargin: Double,
    val revenueGrowth: Double,
    val expenseGrowth: Double,
    val financialPeriod: String
)

data class RevenueAnalyticsResponse(
    val totalRevenue: Double,
    val revenueByPeriod: List<RevenueByPeriod>,
    val revenueByService: List<RevenueByService>,
    val revenueGrowth: Double,
    val revenueTrends: List<RevenueTrend>
)

data class RevenueByPeriod(
    val period: String,
    val revenue: Double,
    val growth: Double
)

data class RevenueByService(
    val service: String,
    val revenue: Double,
    val percentage: Double
)

data class RevenueTrend(
    val date: String,
    val revenue: Double
)

data class ExpenseAnalyticsResponse(
    val totalExpenses: Double,
    val expensesByCategory: List<ExpenseByCategory>,
    val expensesByPeriod: List<ExpenseByPeriod>,
    val expenseGrowth: Double,
    val expenseTrends: List<ExpenseTrend>
)

data class ExpenseByCategory(
    val category: String,
    val amount: Double,
    val percentage: Double
)

data class ExpenseByPeriod(
    val period: String,
    val amount: Double,
    val growth: Double
)

data class ExpenseTrend(
    val date: String,
    val amount: Double
)

data class ProfitabilityAnalyticsResponse(
    val netProfit: Double,
    val profitMargin: Double,
    val profitabilityByPeriod: List<ProfitabilityByPeriod>,
    val profitabilityTrends: List<ProfitabilityTrend>,
    val profitFactors: List<ProfitFactor>
)

data class ProfitabilityByPeriod(
    val period: String,
    val revenue: Double,
    val expenses: Double,
    val profit: Double,
    val margin: Double
)

data class ProfitabilityTrend(
    val date: String,
    val profit: Double,
    val margin: Double
)

data class ProfitFactor(
    val factor: String,
    val impact: Double,
    val description: String
)

data class DriverMonitoringResponse(
    val totalDrivers: Int,
    val activeDrivers: Int,
    val onDutyDrivers: Int,
    val driverLocations: List<DriverLocation>,
    val driverStatuses: List<DriverStatus>,
    val performanceAlerts: List<DriverAlert>
)

data class DriverLocation(
    val driverId: String,
    val driverName: String,
    val latitude: Double,
    val longitude: Double,
    val lastUpdate: Long,
    val accuracy: Double
)

data class DriverStatus(
    val driverId: String,
    val driverName: String,
    val status: String,
    val currentShipment: String?,
    val lastUpdate: Long
)

data class DriverAlert(
    val driverId: String,
    val driverName: String,
    val alertType: String,
    val message: String,
    val severity: String,
    val timestamp: Long
)

data class DriverPerformanceResponse(
    val overallPerformance: DriverPerformanceSummary,
    val individualPerformance: List<IndividualDriverPerformance>,
    val performanceMetrics: List<PerformanceMetric>,
    val performanceTrends: List<PerformanceTrend>
)

data class IndividualDriverPerformance(
    val driverId: String,
    val driverName: String,
    val rating: Double,
    val totalTrips: Int,
    val completedTrips: Int,
    val averageResponseTime: Long,
    val onTimeDeliveryRate: Double,
    val customerSatisfaction: Double
)

data class PerformanceMetric(
    val metric: String,
    val value: Double,
    val target: Double,
    val performance: String
)

data class DriverActivityResponse(
    val driverId: String,
    val driverName: String,
    val activities: List<DriverActivity>,
    val activitySummary: DriverActivitySummary,
    val performanceMetrics: List<PerformanceMetric>
)

data class DriverActivity(
    val activity: String,
    val timestamp: Long,
    val details: String,
    val location: String?
)

data class DriverActivitySummary(
    val totalActivities: Int,
    val activitiesByType: Map<String, Int>,
    val averageResponseTime: Long,
    val workingHours: Long
)

data class MonitoringMetricsResponse(
    val systemMetrics: SystemMetrics,
    val applicationMetrics: ApplicationMetrics,
    val businessMetrics: BusinessMetrics,
    val alerts: List<MonitoringAlert>
)

data class SystemMetrics(
    val cpuUsage: Double,
    val memoryUsage: Double,
    val diskUsage: Double,
    val networkLatency: Long,
    val uptime: Long
)

data class ApplicationMetrics(
    val activeUsers: Int,
    val concurrentSessions: Int,
    val apiRequests: Int,
    val errorRate: Double,
    val averageResponseTime: Long
)

data class BusinessMetrics(
    val activeShipments: Int,
    val totalRevenue: Double,
    val driverUtilization: Double,
    val vehicleUtilization: Double,
    val customerSatisfaction: Double
)

data class MonitoringAlert(
    val id: String,
    val type: String,
    val severity: String,
    val message: String,
    val timestamp: Long,
    val acknowledged: Boolean,
    val acknowledgedBy: String?,
    val acknowledgedAt: Long?
)

data class MonitoringAlertsResponse(
    val alerts: List<MonitoringAlert>,
    val alertSummary: AlertSummary
)

data class AlertSummary(
    val totalAlerts: Int,
    val criticalAlerts: Int,
    val warningAlerts: Int,
    val infoAlerts: Int,
    val acknowledgedAlerts: Int
)

data class NotificationSettingsResponse(
    val emailNotifications: EmailNotificationSettings,
    val smsNotifications: SmsNotificationSettings,
    val pushNotifications: PushNotificationSettings,
    val alertSettings: AlertNotificationSettings
)

data class EmailNotificationSettings(
    val enabled: Boolean,
    val recipients: List<String>,
    val templates: Map<String, EmailTemplate>
)

data class EmailTemplate(
    val subject: String,
    val body: String,
    val enabled: Boolean
)

data class SmsNotificationSettings(
    val enabled: Boolean,
    val recipients: List<String>,
    val templates: Map<String, SmsTemplate>
)

data class SmsTemplate(
    val message: String,
    val enabled: Boolean
)

data class PushNotificationSettings(
    val enabled: Boolean,
    val platforms: List<String>,
    val settings: Map<String, PlatformSettings>
)

data class PlatformSettings(
    val enabled: Boolean,
    val apiKey: String,
    val settings: Map<String, String>
)

data class AlertNotificationSettings(
    val criticalAlerts: AlertChannelSettings,
    val warningAlerts: AlertChannelSettings,
    val infoAlerts: AlertChannelSettings
)

data class AlertChannelSettings(
    val email: Boolean,
    val sms: Boolean,
    val push: Boolean,
    val webhook: Boolean
)

data class NotificationSettingsRequest(
    val emailNotifications: EmailNotificationSettings,
    val smsNotifications: SmsNotificationSettings,
    val pushNotifications: PushNotificationSettings,
    val alertSettings: AlertNotificationSettings
)

data class TestNotificationRequest(
    val type: String,
    val message: String,
    val channels: List<String>
)

data class NotificationHistoryResponse(
    val notifications: List<NotificationHistory>,
    val summary: NotificationHistorySummary
)

data class NotificationHistory(
    val id: String,
    val type: String,
    val recipient: String,
    val channel: String,
    val message: String,
    val status: String,
    val timestamp: Long,
    val deliveredAt: Long?,
    val readAt: Long?
)

data class NotificationHistorySummary(
    val totalNotifications: Int,
    val deliveredNotifications: Int,
    val readNotifications: Int,
    val deliveryRate: Double,
    val readRate: Double
)

data class ExportResponse(
    val success: Boolean,
    val downloadUrl: String,
    val format: String,
    val size: Long,
    val expiresAt: Long
)

data class MaintenanceResponse(
    val success: Boolean,
    val message: String,
    val operations: List<MaintenanceOperation>
)

data class MaintenanceOperation(
    val operation: String,
    val status: String,
    val message: String,
    val duration: Long
)

data class BackupResponse(
    val success: Boolean,
    val backupId: String,
    val size: Long,
    val location: String,
    val createdAt: Long
)

data class RestoreBackupRequest(
    val backupId: String,
    val confirm: Boolean
)

data class RestoreResponse(
    val success: Boolean,
    val message: String,
    val restoredAt: Long
)

data class MaintenanceStatusResponse(
    val status: String,
    val lastMaintenance: Long,
    val nextMaintenance: Long,
    val operations: List<MaintenanceOperation>
)
