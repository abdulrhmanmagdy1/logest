package com.edham.logistics.feature.notifications.presentation.adapter

import android.view.LayoutInflater
import android.view.ViewGroup
import androidx.recyclerview.widget.DiffUtil
import androidx.recyclerview.widget.ListAdapter
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.databinding.ItemNotificationNewBinding
import com.edham.logistics.feature.notifications.domain.model.Notification
import com.edham.logistics.feature.notifications.domain.model.NotificationType
import com.edham.logistics.feature.notifications.domain.model.NotificationCategory
import javax.inject.Inject

class NotificationAdapter @Inject constructor(
    private val onNotificationAction: (Notification, String) -> Unit
) : ListAdapter<Notification, NotificationAdapter.NotificationViewHolder>(NotificationDiffCallback()) {

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): NotificationViewHolder {
        val binding = ItemNotificationNewBinding.inflate(
            LayoutInflater.from(parent.context),
            parent,
            false
        )
        return NotificationViewHolder(binding)
    }

    override fun onBindViewHolder(holder: NotificationViewHolder, position: Int) {
        holder.bind(getItem(position))
    }

    inner class NotificationViewHolder(
        private val binding: ItemNotificationNewBinding
    ) : RecyclerView.ViewHolder(binding.root) {

        fun bind(notification: Notification) {
            binding.apply {
                textTitle.text = notification.title
                textMessage.text = notification.message
                textTime.text = formatTimestamp(notification.timestamp)
                
                // Set icon based on notification type
                imageNotificationIcon.setImageResource(getNotificationIcon(notification.type))
                imageNotificationIcon.setColorFilter(getNotificationColor(notification.type))
                
                // Set background based on read status
                if (notification.isRead) {
                    root.setBackgroundColor(android.graphics.Color.TRANSPARENT)
                    textTitle.alpha = 0.7f
                    textMessage.alpha = 0.7f
                } else {
                    root.setBackgroundColor(android.graphics.Color.parseColor("#F5F5F5"))
                    textTitle.alpha = 1.0f
                    textMessage.alpha = 1.0f
                }
                
                // Show category badge
                textCategory.text = formatCategory(notification.category)
                textCategory.setBackgroundColor(getCategoryColor(notification.category))
                
                // Show priority indicator
                if (notification.priority == com.edham.logistics.feature.notifications.domain.model.NotificationPriority.URGENT) {
                    imagePriorityIndicator.visible()
                    imagePriorityIndicator.setImageResource(R.drawable.ic_urgent)
                } else {
                    imagePriorityIndicator.gone()
                }
                
                // Show image if available
                notification.imageUrl?.let { imageUrl ->
                    if (imageUrl.isNotEmpty()) {
                        imageNotificationImage.visible()
                        // In a real implementation, you would load this image using Glide or Coil
                        // For now, we'll use a placeholder
                        imageNotificationImage.setImageResource(R.drawable.ic_notification_image)
                    } else {
                        imageNotificationImage.gone()
                    }
                } ?: run {
                    imageNotificationImage.gone()
                }
                
                // Show action button if action URL is available
                notification.actionUrl?.let { actionUrl ->
                    if (actionUrl.isNotEmpty()) {
                        buttonAction.visible()
                        buttonAction.setOnClickListener {
                            onNotificationAction(notification, "view")
                        }
                    } else {
                        buttonAction.gone()
                    }
                } ?: run {
                    buttonAction.gone()
                }
                
                // Set click listeners
                root.setOnClickListener {
                    if (!notification.isRead) {
                        onNotificationAction(notification, "mark_read")
                    }
                    onNotificationAction(notification, "view")
                }
                
                buttonMarkRead.setOnClickListener {
                    if (!notification.isRead) {
                        onNotificationAction(notification, "mark_read")
                    }
                }
                
                buttonDelete.setOnClickListener {
                    onNotificationAction(notification, "delete")
                }
                
                // Update button states
                if (notification.isRead) {
                    buttonMarkRead.gone()
                } else {
                    buttonMarkRead.visible()
                }
            }
        }
        
        private fun getNotificationIcon(type: NotificationType): Int {
            return when (type) {
                NotificationType.SHIPMENT_CREATED,
                NotificationType.SHIPMENT_PICKED_UP,
                NotificationType.SHIPMENT_IN_TRANSIT,
                NotificationType.SHIPMENT_DELIVERED -> R.drawable.ic_shipment
                NotificationType.SHIPMENT_CANCELLED,
                NotificationType.SHIPMENT_DELAYED,
                NotificationType.SHIPMENT_STATUS_UPDATED -> R.drawable.ic_warning
                NotificationType.DRIVER_ASSIGNED,
                NotificationType.DRIVER_LOCATION_UPDATED,
                NotificationType.DRIVER_ARRIVED,
                NotificationType.DRIVER_DEPARTED,
                NotificationType.DRIVER_COMPLETED_TRIP,
                NotificationType.DRIVER_STATUS_CHANGED -> R.drawable.ic_driver
                NotificationType.TEMPERATURE_ALERT,
                NotificationType.TEMPERATURE_NORMAL,
                NotificationType.SENSOR_OFFLINE,
                NotificationType.SENSOR_BATTERY_LOW,
                NotificationType.SENSOR_CALIBRATION_REQUIRED -> R.drawable.ic_temperature
                NotificationType.PAYMENT_RECEIVED,
                NotificationType.PAYMENT_FAILED,
                NotificationType.PAYMENT_PENDING,
                NotificationType.PAYMENT_OVERDUE,
                NotificationType.INVOICE_GENERATED,
                NotificationType.INVOICE_OVERDUE -> R.drawable.ic_payment
                NotificationType.SYSTEM_MAINTENANCE,
                NotificationType.SYSTEM_UPDATE,
                NotificationType.SYSTEM_ALERT,
                NotificationType.SYSTEM_ERROR -> R.drawable.ic_system
                NotificationType.USER_LOGIN,
                NotificationType.USER_LOGOUT -> R.drawable.ic_user
                NotificationType.GENERAL_ANNOUNCEMENT,
                NotificationType.PROMOTION,
                NotificationType.REMINDER -> R.drawable.ic_notification
                NotificationType.WARNING,
                NotificationType.ERROR -> R.drawable.ic_error
            }
        }
        
        private fun getNotificationColor(type: NotificationType): Int {
            return when (type) {
                NotificationType.SHIPMENT_CREATED,
                NotificationType.SHIPMENT_PICKED_UP,
                NotificationType.SHIPMENT_IN_TRANSIT,
                NotificationType.SHIPMENT_DELIVERED -> android.graphics.Color.parseColor("#4CAF50")
                NotificationType.SHIPMENT_CANCELLED,
                NotificationType.SHIPMENT_DELAYED,
                NotificationType.SHIPMENT_STATUS_UPDATED -> android.graphics.Color.parseColor("#FF9800")
                NotificationType.DRIVER_ASSIGNED,
                NotificationType.DRIVER_LOCATION_UPDATED,
                NotificationType.DRIVER_ARRIVED,
                NotificationType.DRIVER_DEPARTED,
                NotificationType.DRIVER_COMPLETED_TRIP,
                NotificationType.DRIVER_STATUS_CHANGED -> android.graphics.Color.parseColor("#2196F3")
                NotificationType.TEMPERATURE_ALERT,
                NotificationType.SENSOR_OFFLINE,
                NotificationType.SENSOR_BATTERY_LOW,
                NotificationType.SENSOR_CALIBRATION_REQUIRED -> android.graphics.Color.parseColor("#F44336")
                NotificationType.TEMPERATURE_NORMAL -> android.graphics.Color.parseColor("#4CAF50")
                NotificationType.PAYMENT_RECEIVED -> android.graphics.Color.parseColor("#4CAF50")
                NotificationType.PAYMENT_FAILED,
                NotificationType.PAYMENT_PENDING,
                NotificationType.PAYMENT_OVERDUE,
                NotificationType.INVOICE_OVERDUE -> android.graphics.Color.parseColor("#F44336")
                NotificationType.INVOICE_GENERATED -> android.graphics.Color.parseColor("#2196F3")
                NotificationType.SYSTEM_MAINTENANCE,
                NotificationType.SYSTEM_UPDATE -> android.graphics.Color.parseColor("#FF9800")
                NotificationType.SYSTEM_ALERT,
                NotificationType.SYSTEM_ERROR -> android.graphics.Color.parseColor("#F44336")
                NotificationType.USER_LOGIN,
                NotificationType.USER_LOGOUT -> android.graphics.Color.parseColor("#9E9E9E")
                NotificationType.GENERAL_ANNOUNCEMENT -> android.graphics.Color.parseColor("#2196F3")
                NotificationType.PROMOTION -> android.graphics.Color.parseColor("#9C27B0")
                NotificationType.REMINDER -> android.graphics.Color.parseColor("#FF9800")
                NotificationType.WARNING -> android.graphics.Color.parseColor("#FF5722")
                NotificationType.ERROR -> android.graphics.Color.parseColor("#F44336")
            }
        }
        
        private fun formatCategory(category: NotificationCategory): String {
            return when (category) {
                NotificationCategory.SHIPMENT -> "شحنة"
                NotificationCategory.DRIVER -> "سائق"
                NotificationCategory.TEMPERATURE -> "حرارة"
                NotificationCategory.PAYMENT -> "دفع"
                NotificationCategory.SYSTEM -> "نظام"
                NotificationCategory.USER -> "مستخدم"
                NotificationCategory.MARKETING -> "تسويق"
                NotificationCategory.GENERAL -> "عام"
            }
        }
        
        private fun getCategoryColor(category: NotificationCategory): Int {
            return when (category) {
                NotificationCategory.SHIPMENT -> android.graphics.Color.parseColor("#4CAF50")
                NotificationCategory.DRIVER -> android.graphics.Color.parseColor("#2196F3")
                NotificationCategory.TEMPERATURE -> android.graphics.Color.parseColor("#FF5722")
                NotificationCategory.PAYMENT -> android.graphics.Color.parseColor("#9C27B0")
                NotificationCategory.SYSTEM -> android.graphics.Color.parseColor("#FF9800")
                NotificationCategory.USER -> android.graphics.Color.parseColor("#607D8B")
                NotificationCategory.MARKETING -> android.graphics.Color.parseColor("#9C27B0")
                NotificationCategory.GENERAL -> android.graphics.Color.parseColor("#9E9E9E")
            }
        }
        
        private fun formatTimestamp(timestamp: Long): String {
            val now = System.currentTimeMillis()
            val diff = now - timestamp
            
            return when {
                diff < 60000 -> "الآن"
                diff < 3600000 -> "${diff / 60000} دقيقة"
                diff < 86400000 -> "${diff / 3600000} ساعة"
                diff < 604800000 -> "${diff / 86400000} يوم"
                else -> java.text.SimpleDateFormat("dd MMM", java.util.Locale.getDefault())
                    .format(java.util.Date(timestamp))
            }
        }
    }

    private class NotificationDiffCallback : DiffUtil.ItemCallback<Notification>() {
        override fun areItemsTheSame(oldItem: Notification, newItem: Notification): Boolean {
            return oldItem.id == newItem.id
        }

        override fun areContentsTheSame(oldItem: Notification, newItem: Notification): Boolean {
            return oldItem == newItem
        }
    }
}
