    /**
     * Check if user can perform action on screen
     */
    fun canPerformAction(userRole: UserRole, screenRoute: String, action: String): Boolean {
        return when (userRole) {
            UserRole.CLIENT -> {
                when (screenRoute) {
                    Screen.CreateShipment.route -> action in listOf("create", "save", "submit")
                    Screen.LiveTracking.route -> action in listOf("view", "track", "refresh")
                    Screen.Wallet.route -> action in listOf("view", "add_funds", "pay")
                    Screen.Profile.route -> action in listOf("view", "edit", "update")
                    else -> false
                }
            }
            UserRole.DRIVER -> {
                when (screenRoute) {
                    Screen.DriverTasks.route -> action in listOf("view", "update_status", "upload_proof")
                    Screen.DriverLocation.route -> action in listOf("view", "update", "track")
                    Screen.DriverEarnings.route -> action in listOf("view", "filter", "export")
                    Screen.DriverSchedule.route -> action in listOf("view", "accept", "decline")
                    else -> false
                }
            }
            UserRole.ADMIN -> {
                // Admin can perform all actions
                true
            }
            UserRole.ACCOUNTANT -> {
                when (screenRoute) {
                    Screen.InvoiceManagement.route -> action in listOf("view", "create", "update", "delete", "send")
                    Screen.PaymentManagement.route -> action in listOf("view", "process", "refund", "approve")
                    Screen.FinancialReports.route -> action in listOf("view", "generate", "export", "filter")
                    else -> false
                }
            }
            UserRole.WORKSHOP -> {
                when (screenRoute) {
                    Screen.VehicleManagement.route -> action in listOf("view", "update_status", "schedule_maintenance")
                    Screen.MaintenanceManagement.route -> action in listOf("view", "create", "update", "complete")
                    Screen.PartsInventory.route -> action in listOf("view", "add", "update", "delete")
                    else -> false
                }
            }
        }
    }

    /**
     * Get role-specific theme colors
     */
    fun getRoleThemeColors(userRole: UserRole): RoleThemeColors {
        return when (userRole) {
            UserRole.CLIENT -> RoleThemeColors(
                primary = "#3b82f6",
                secondary = "#60a5fa",
                accent = "#2563eb",
                background = "#0a0a0a"
            )
            UserRole.DRIVER -> RoleThemeColors(
                primary = "#10b981",
                secondary = "#34d399",
                accent = "#059669",
                background = "#0a0a0a"
            )
            UserRole.ADMIN -> RoleThemeColors(
                primary = "#dc2626",
                secondary = "#ef4444",
                accent = "#b91c1c",
                background = "#0a0a0a"
            )
            UserRole.ACCOUNTANT -> RoleThemeColors(
                primary = "#f59e0b",
                secondary = "#fbbf24",
                accent = "#d97706",
                background = "#0a0a0a"
            )
            UserRole.WORKSHOP -> RoleThemeColors(
                primary = "#ef4444",
                secondary = "#f87171",
                accent = "#dc2626",
                background = "#0a0a0a"
            )
        }
    }

    /**
     * Composable for role-based screen protection
     */
    @Composable
    fun RoleProtectedScreen(
        userRole: UserRole,
        screenRoute: String,
        onAccessDenied: @Composable () -> Unit = { AccessDeniedScreen() },
        content: @Composable () -> Unit
    ) {
        if (canAccessScreen(userRole, screenRoute)) {
            content()
        } else {
            onAccessDenied()
        }
    }

    /**
     * Composable for role-based action protection
     */
    @Composable
    fun RoleProtectedAction(
        userRole: UserRole,
        screenRoute: String,
        action: String,
        onAccessDenied: () -> Unit = {},
        content: @Composable () -> Unit
    ) {
        if (canPerformAction(userRole, screenRoute, action)) {
            content()
        } else {
            onAccessDenied()
        }
    }

    /**
     * State holder for role-based access
     */
    @Stable
    class RoleAccessState(
        initialRole: UserRole
    ) {
        private val _userRole = MutableStateFlow(initialRole)
        val userRole: StateFlow<UserRole> = _userRole

        private val _accessibleScreens = MutableStateFlow(getAccessibleScreens(initialRole))
        val accessibleScreens: StateFlow<List<Screen>> = _accessibleScreens

        private val _navigationItems = MutableStateFlow(getBottomNavigationItems(initialRole))
        val navigationItems: StateFlow<List<NavigationItem>> = _navigationItems

        private val _drawerItems = MutableStateFlow(getDrawerNavigationItems(initialRole))
        val drawerItems: StateFlow<List<NavigationItem>> = _drawerItems

        private val _themeColors = MutableStateFlow(getRoleThemeColors(initialRole))
        val themeColors: StateFlow<RoleThemeColors> = _themeColors

        fun updateRole(newRole: UserRole) {
            _userRole.value = newRole
            _accessibleScreens.value = getAccessibleScreens(newRole)
            _navigationItems.value = getBottomNavigationItems(newRole)
            _drawerItems.value = getDrawerNavigationItems(newRole)
            _themeColors.value = getRoleThemeColors(newRole)
        }

        fun canAccessScreen(screenRoute: String): Boolean {
            return canAccessScreen(_userRole.value, screenRoute)
        }

        fun canPerformAction(screenRoute: String, action: String): Boolean {
            return canPerformAction(_userRole.value, screenRoute, action)
        }
    }
}

/**
 * Data class for navigation items
 */
data class NavigationItem(
    val title: String,
    val icon: String,
    val route: String
)

/**
 * Data class for role theme colors
 */
data class RoleThemeColors(
    val primary: String,
    val secondary: String,
    val accent: String,
    val background: String
)
