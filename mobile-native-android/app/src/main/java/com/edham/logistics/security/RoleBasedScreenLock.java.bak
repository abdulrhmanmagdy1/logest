package com.edham.logistics.security

import androidx.compose.runtime.*
import androidx.navigation.NavController
import com.edham.logistics.model.UserRole
import com.edham.logistics.navigation.Screen
import kotlinx.coroutines.flow.MutableStateFlow
import kotlinx.coroutines.flow.StateFlow

/**
 * Role-Based Screen Lock for Android
 * Prevents unauthorized access to screens based on user roles
 */
object RoleBasedScreenLock {

    // Define screen permissions
    private val screenPermissions = mapOf(
        // Client screens
        Screen.Home.route to setOf(UserRole.CLIENT, UserRole.ADMIN),
        Screen.CreateShipment.route to setOf(UserRole.CLIENT, UserRole.ADMIN),
        Screen.LiveTracking.route to setOf(UserRole.CLIENT, UserRole.DRIVER, UserRole.ADMIN),
        Screen.Wallet.route to setOf(UserRole.CLIENT, UserRole.ADMIN),
        Screen.Profile.route to setOf(UserRole.CLIENT, UserRole.DRIVER, UserRole.ADMIN),
        Screen.Settings.route to setOf(UserRole.CLIENT, UserRole.DRIVER, UserRole.ADMIN),
        
        // Driver screens
        Screen.DriverDashboard.route to setOf(UserRole.DRIVER, UserRole.ADMIN),
        Screen.DriverTasks.route to setOf(UserRole.DRIVER, UserRole.ADMIN),
        Screen.DriverLocation.route to setOf(UserRole.DRIVER, UserRole.ADMIN),
        Screen.DriverEarnings.route to setOf(UserRole.DRIVER, UserRole.ADMIN),
        Screen.DriverSchedule.route to setOf(UserRole.DRIVER, UserRole.ADMIN),
        
        // Admin screens
        Screen.AdminDashboard.route to setOf(UserRole.ADMIN),
        Screen.UserManagement.route to setOf(UserRole.ADMIN),
        Screen.RoleManagement.route to setOf(UserRole.ADMIN),
        Screen.PermissionManagement.route to setOf(UserRole.ADMIN),
        Screen.SystemSettings.route to setOf(UserRole.ADMIN),
        
        // Accountant screens
        Screen.AccountantDashboard.route to setOf(UserRole.ACCOUNTANT, UserRole.ADMIN),
        Screen.InvoiceManagement.route to setOf(UserRole.ACCOUNTANT, UserRole.ADMIN),
        Screen.PaymentManagement.route to setOf(UserRole.ACCOUNTANT, UserRole.ADMIN),
        Screen.FinancialReports.route to setOf(UserRole.ACCOUNTANT, UserRole.ADMIN),
        Screen.TaxReports.route to setOf(UserRole.ACCOUNTANT, UserRole.ADMIN),
        
        // Workshop screens
        Screen.WorkshopDashboard.route to setOf(UserRole.WORKSHOP, UserRole.ADMIN),
        Screen.VehicleManagement.route to setOf(UserRole.WORKSHOP, UserRole.ADMIN),
        Screen.MaintenanceManagement.route to setOf(UserRole.WORKSHOP, UserRole.ADMIN),
        Screen.PartsInventory.route to setOf(UserRole.WORKSHOP, UserRole.ADMIN),
        Screen.FleetHealth.route to setOf(UserRole.WORKSHOP, UserRole.ADMIN)
    )

    // Define navigation items per role
    private val roleNavigationItems = mapOf(
        UserRole.CLIENT to listOf(
            Screen.Home,
            Screen.CreateShipment,
            Screen.LiveTracking,
            Screen.Wallet,
            Screen.Profile,
            Screen.Settings
        ),
        UserRole.DRIVER to listOf(
            Screen.DriverDashboard,
            Screen.DriverTasks,
            Screen.DriverLocation,
            Screen.DriverEarnings,
            Screen.DriverSchedule,
            Screen.Profile,
            Screen.Settings
        ),
        UserRole.ADMIN to listOf(
            Screen.AdminDashboard,
            Screen.UserManagement,
            Screen.RoleManagement,
            Screen.PermissionManagement,
            Screen.SystemSettings,
            Screen.VehicleManagement,
            Screen.InvoiceManagement,
            Screen.FinancialReports
        ),
        UserRole.ACCOUNTANT to listOf(
            Screen.AccountantDashboard,
            Screen.InvoiceManagement,
            Screen.PaymentManagement,
            Screen.FinancialReports,
            Screen.TaxReports,
            Screen.Profile,
            Screen.Settings
        ),
        UserRole.WORKSHOP to listOf(
            Screen.WorkshopDashboard,
            Screen.VehicleManagement,
            Screen.MaintenanceManagement,
            Screen.PartsInventory,
            Screen.FleetHealth,
            Screen.Profile,
            Screen.Settings
        )
    )

    // Define UI components per role
    private val roleUIComponents = mapOf(
        UserRole.CLIENT to listOf(
            "ShipmentList", "CreateShipment", "TrackShipment",
            "Profile", "Wallet", "Notifications"
        ),
        UserRole.DRIVER to listOf(
            "TaskList", "LocationTracker", "ShipmentStatus",
            "Earnings", "Schedule", "Profile"
        ),
        UserRole.ADMIN to listOf(
            "UserManagement", "RoleManagement", "PermissionManagement",
            "SystemConfiguration", "Reports", "Dashboard"
        ),
        UserRole.ACCOUNTANT to listOf(
            "InvoiceManagement", "PaymentManagement", "FinancialReports",
            "TaxReports", "Analytics", "Dashboard"
        ),
        UserRole.WORKSHOP to listOf(
            "VehicleManagement", "MaintenanceManagement", "PartsInventory",
            "FleetHealth", "Schedule", "Dashboard"
        )
    )

    /**
     * Check if user can access screen
     */
    fun canAccessScreen(userRole: UserRole, screenRoute: String): Boolean {
        val allowedRoles = screenPermissions[screenRoute] ?: return false
        return userRole in allowedRoles
    }

    /**
     * Get accessible screens for user role
     */
    fun getAccessibleScreens(userRole: UserRole): List<Screen> {
        return roleNavigationItems[userRole] ?: emptyList()
    }

    /**
     * Get accessible UI components for user role
     */
    fun getAccessibleUIComponents(userRole: UserRole): List<String> {
        return roleUIComponents[userRole] ?: emptyList()
    }

    /**
     * Navigate to screen with permission check
     */
    fun navigateWithPermissionCheck(
        navController: NavController,
        userRole: UserRole,
        screenRoute: String,
        onAccessDenied: () -> Unit = {}
    ) {
        if (canAccessScreen(userRole, screenRoute)) {
            navController.navigate(screenRoute)
        } else {
            onAccessDenied()
        }
    }

