package com.edham.logistics.feature.driver.data.repository

import com.edham.logistics.core.utils.Result
import com.edham.logistics.feature.driver.domain.model.*
import com.edham.logistics.feature.driver.domain.repository.DriverRepository
import com.edham.logistics.feature.driver.data.remote.api.DriverApiService
import com.edham.logistics.feature.driver.data.remote.dto.DriverDashboardDto
import com.edham.logistics.feature.driver.data.remote.mapper.DriverMapper
import kotlinx.coroutines.flow.Flow
import kotlinx.coroutines.flow.flow
import kotlinx.coroutines.flow.catch
import kotlinx.coroutines.flow.flowOf
import java.io.IOException
import javax.inject.Inject
import javax.inject.Singleton

@Singleton
class DriverRepositoryImpl @Inject constructor(
    private val driverApiService: DriverApiService,
    private val driverMapper: DriverMapper
) : DriverRepository {

    override suspend fun getDriverProfile(driverId: String): Result<DriverProfile> {
        return try {
            val response = driverApiService.getDriverProfile(driverId)
            if (response.isSuccessful) {
                response.body()?.let { profileDto ->
                    Result.Success(driverMapper.mapToDomainProfile(profileDto))
                } ?: Result.Error(IOException("Empty response"))
            } else {
                Result.Error(IOException("Failed to fetch driver profile: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun updateDriverProfile(profile: DriverProfile): Result<DriverProfile> {
        return try {
            val profileDto = driverMapper.mapToDtoProfile(profile)
            val response = driverApiService.updateDriverProfile(profile.id, profileDto)
            if (response.isSuccessful) {
                response.body()?.let { updatedProfileDto ->
                    Result.Success(driverMapper.mapToDomainProfile(updatedProfileDto))
                } ?: Result.Error(IOException("Empty response"))
            } else {
                Result.Error(IOException("Failed to update driver profile: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun getDriverShipments(driverId: String, page: Int, pageSize: Int): Result<List<ShipmentSummary>> {
        return try {
            val response = driverApiService.getDriverShipments(driverId, page, pageSize)
            if (response.isSuccessful) {
                response.body()?.let { shipmentsDto ->
                    val shipments = shipmentsDto.map { driverMapper.mapToDomainShipmentSummary(it) }
                    Result.Success(shipments)
                } ?: Result.Error(IOException("Empty response"))
            } else {
                Result.Error(IOException("Failed to fetch driver shipments: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun updateShipmentStatus(shipmentId: String, status: String): Result<Unit> {
        return try {
            val response = driverApiService.updateShipmentStatus(shipmentId, status)
            if (response.isSuccessful) {
                Result.Success(Unit)
            } else {
                Result.Error(IOException("Failed to update shipment status: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun updateDriverLocation(location: DriverLocation): Result<Unit> {
        return try {
            val locationDto = driverMapper.mapToDtoLocation(location)
            val response = driverApiService.updateDriverLocation(location.driverId, locationDto)
            if (response.isSuccessful) {
                Result.Success(Unit)
            } else {
                Result.Error(IOException("Failed to update driver location: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun startTrip(shipmentId: String): Result<Unit> {
        return try {
            val response = driverApiService.startTrip(shipmentId)
            if (response.isSuccessful) {
                Result.Success(Unit)
            } else {
                Result.Error(IOException("Failed to start trip: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun completeTrip(shipmentId: String, deliveryPhotos: List<String>): Result<Unit> {
        return try {
            val response = driverApiService.completeTrip(shipmentId, deliveryPhotos)
            if (response.isSuccessful) {
                Result.Success(Unit)
            } else {
                Result.Error(IOException("Failed to complete trip: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun cancelTrip(shipmentId: String, reason: String): Result<Unit> {
        return try {
            val response = driverApiService.cancelTrip(shipmentId, reason)
            if (response.isSuccessful) {
                Result.Success(Unit)
            } else {
                Result.Error(IOException("Failed to cancel trip: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun reportIssue(shipmentId: String, issue: String, photos: List<String>): Result<Unit> {
        return try {
            val response = driverApiService.reportIssue(shipmentId, issue, photos)
            if (response.isSuccessful) {
                Result.Success(Unit)
            } else {
                Result.Error(IOException("Failed to report issue: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun getDriverDashboard(driverId: String): Flow<Result<DriverDashboardData>> = flow {
        emit(Result.Loading)
        try {
            val response = driverApiService.getDriverDashboard(driverId)
            if (response.isSuccessful) {
                response.body()?.let { dashboardDto ->
                    val dashboardData = driverMapper.mapToDomainDashboard(dashboardDto)
                    emit(Result.Success(dashboardData))
                } ?: emit(Result.Error(IOException("Empty response")))
            } else {
                emit(Result.Error(IOException("Failed to fetch dashboard: ${response.code()}")))
            }
        } catch (e: Exception) {
            emit(Result.Error(e))
        }
    }.catch { e ->
        emit(Result.Error(e))
    }

    override suspend fun performTripAction(request: TripActionRequest): Result<Unit> {
        return try {
            val actionDto = driverMapper.mapToDtoTripAction(request)
            val response = driverApiService.performTripAction(actionDto)
            if (response.isSuccessful) {
                Result.Success(Unit)
            } else {
                Result.Error(IOException("Failed to perform trip action: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun updateTripStatus(request: TripUpdateRequest): Result<Unit> {
        return try {
            val statusDto = driverMapper.mapToDtoTripUpdate(request)
            val response = driverApiService.updateTripStatus(statusDto)
            if (response.isSuccessful) {
                Result.Success(Unit)
            } else {
                Result.Error(IOException("Failed to update trip status: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun uploadDeliveryProof(tripId: String, request: DeliveryProofRequest): Result<Unit> {
        return try {
            val proofDto = driverMapper.mapToDtoDeliveryProof(request)
            val response = driverApiService.uploadDeliveryProof(tripId, proofDto)
            if (response.isSuccessful) {
                Result.Success(Unit)
            } else {
                Result.Error(IOException("Failed to upload delivery proof: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override fun observeDriverProfile(driverId: String): Flow<DriverProfile> {
        return flowOf() // In real implementation, this would observe from local database
    }

    override fun observeDriverShipments(driverId: String): Flow<List<ShipmentSummary>> {
        return flowOf() // In real implementation, this would observe from local database
    }

    override fun observeDriverLocation(driverId: String): Flow<DriverLocation?> {
        return flowOf() // In real implementation, this would observe from local database
    }
}
