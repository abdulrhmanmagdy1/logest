package com.edham.logistics.feature.accountant.domain.model

data class Invoice(
    val id: String,
    val invoiceNumber: String,
    val customerId: String,
    val customerName: String,
    val customerEmail: String,
    val customerPhone: String,
    val customerAddress: String,
    val shipmentId: String? = null,
    val shipmentNumber: String? = null,
    val issueDate: String,
    val dueDate: String,
    val status: String,
    val subtotal: Double,
    val taxAmount: Double,
    val taxRate: Double = 15.0, // VAT rate
    val discountAmount: Double = 0.0,
    val totalAmount: Double,
    val paidAmount: Double = 0.0,
    val balanceAmount: Double,
    val currency: String = "SAR",
    val items: List<InvoiceItem>,
    val payments: List<Payment> = emptyList(),
    val notes: String? = null,
    val terms: String? = null,
    val createdBy: String,
    val createdAt: String,
    val updatedAt: String,
    val sentAt: String? = null,
    val paidAt: String? = null,
    val overdueDays: Int? = null,
    val canBeCancelled: Boolean = false,
    val canBeModified: Boolean = false,
    val attachments: List<String> = emptyList()
)

data class InvoiceItem(
    val id: String,
    val description: String,
    val quantity: Int,
    val unitPrice: Double,
    val totalPrice: Double,
    val itemType: String, // "shipment", "service", "penalty", "discount"
    val shipmentId: String? = null,
    val serviceCode: String? = null,
    val taxable: Boolean = true
)

data class Payment(
    val id: String,
    val invoiceId: String,
    val amount: Double,
    val paymentMethod: String,
    val paymentDate: String,
    val transactionId: String? = null,
    val status: String,
    val gateway: String? = null,
    val gatewayResponse: Map<String, Any> = emptyMap(),
    val processedBy: String,
    val notes: String? = null,
    val createdAt: String,
    val updatedAt: String,
    val refundAmount: Double = 0.0,
    val refunds: List<Refund> = emptyList()
)

data class Refund(
    val id: String,
    val paymentId: String,
    val amount: Double,
    val reason: String,
    val status: String,
    val processedBy: String,
    val processedAt: String,
    val notes: String? = null,
    val gatewayRefundId: String? = null
)

data class FinancialReport(
    val id: String,
    val reportType: String,
    val title: String,
    val description: String,
    val generatedAt: String,
    val generatedBy: String,
    val period: ReportPeriod,
    val summary: FinancialSummary,
    val details: List<FinancialDetail>,
    val charts: List<ChartData> = emptyList(),
    val fileUrl: String? = null,
    val fileSize: Long? = null,
    val format: String = "PDF"
)

data class ReportPeriod(
    val startDate: String,
    val endDate: String,
    val type: String // "daily", "weekly", "monthly", "quarterly", "yearly", "custom"
)

data class FinancialSummary(
    val totalRevenue: Double,
    val totalExpenses: Double,
    val netProfit: Double,
    val totalInvoices: Int,
    val paidInvoices: Int,
    val unpaidInvoices: Int,
    val overdueInvoices: Int,
    val totalPayments: Double,
    val averageInvoiceValue: Double,
    val totalTaxCollected: Double,
    val totalDiscountsGiven: Double,
    val customerCount: Int,
    val newCustomers: Int,
    val topCustomers: List<CustomerRevenue>
)

data class FinancialDetail(
    val category: String,
    val amount: Double,
    val percentage: Double,
    val count: Int,
    val trend: String, // "up", "down", "stable"
    val changePercentage: Double
)

data class CustomerRevenue(
    val customerId: String,
    val customerName: String,
    val totalRevenue: Double,
    val invoiceCount: Int,
    val averageInvoiceValue: Double,
    val lastInvoiceDate: String,
    val status: String
)

data class ChartData(
    val type: String, // "line", "bar", "pie", "doughnut"
    val title: String,
    val labels: List<String>,
    val datasets: List<ChartDataset>
)

data class ChartDataset(
    val label: String,
    val data: List<Double>,
    val backgroundColor: List<String>? = null,
    val borderColor: String? = null,
    val borderWidth: Int = 1
)

enum class InvoiceStatus(val value: String, val displayName: String) {
    DRAFT("draft", "مسودة"),
    SENT("sent", "مرسلة"),
    VIEWED("viewed", "تمت معاينتها"),
    PARTIALLY_PAID("partially_paid", "مدفوعة جزئياً"),
    PAID("paid", "مدفوعة بالكامل"),
    OVERDUE("overdue", "متأخرة"),
    CANCELLED("cancelled", "ملغية"),
    REFUNDED("refunded", "مستردة")
}

enum class PaymentStatus(val value: String, val displayName: String) {
    PENDING("pending", "في انتظار"),
    PROCESSING("processing", "قيد المعالجة"),
    COMPLETED("completed", "مكتملة"),
    FAILED("failed", "فشلت"),
    CANCELLED("cancelled", "ملغية"),
    REFUNDED("refunded", "مستردة")
}

enum class PaymentMethod(val value: String, val displayName: String) {
    CASH("cash", "نقدي"),
    BANK_TRANSFER("bank_transfer", "تحويل بنكي"),
    CREDIT_CARD("credit_card", "بطاقة ائتمان"),
    DEBIT_CARD("debit_card", "بطاقة خصم مباشر"),
    APPLE_PAY("apple_pay", "Apple Pay"),
    GOOGLE_PAY("google_pay", "Google Pay"),
    PAYPAL("paypal", "PayPal"),
    CHECK("check", "شيك")
}

enum class ReportType(val value: String, val displayName: String) {
    INVOICE_SUMMARY("invoice_summary", "ملخص الفواتير"),
    REVENUE_REPORT("revenue_report", "تقرير الإيرادات"),
    EXPENSE_REPORT("expense_report", "تقرير المصروفات"),
    PROFIT_LOSS("profit_loss", "تقرير الأرباح والخسائر"),
    TAX_REPORT("tax_report", "تقرير الضرائب"),
    CUSTOMER_STATEMENT("customer_statement", "كشف العميل"),
    AGING_REPORT("aging_report", "تقرير الشيخوكة"),
    PAYMENT_REPORT("payment_report", "تقرير المدفوعات"),
    SALES_REPORT("sales_report", "تقرير المبيعات")
}
