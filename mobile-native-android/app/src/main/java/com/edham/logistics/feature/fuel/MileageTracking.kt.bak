        val monday: Double,
        val tuesday: Double,
        val wednesday: Double,
        val thursday: Double,
        val friday: Double,
        val saturday: Double,
        val sunday: Double
    )
    
    data class MonthlyPattern(
        val january: Double,
        val february: Double,
        val march: Double,
        val april: Double,
        val may: Double,
        val june: Double,
        val july: Double,
        val august: Double,
        val september: Double,
