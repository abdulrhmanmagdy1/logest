    )
    
    // Enums
    enum class MileageRecordingType {
        MANUAL, AUTOMATIC, TRIP_START, TRIP_END, TRIP_UPDATE, CHECKPOINT
    }
    
    enum class ServiceType {
        REGULAR, OIL_CHANGE, TIRE_ROTATION, BRAKE_SERVICE, MAJOR_SERVICE, INSPECTION
    }
    
    enum class AnomalySeverity {
        LOW, MEDIUM, HIGH, CRITICAL
    }
    
    enum class TrendDirection {
        INCREASING, DECREASING, STABLE
    }
    
    enum class TimeWindow(val duration: java.time.Duration) {
        LAST_7_DAYS(java.time.Duration.ofDays(7)),
        LAST_30_DAYS(java.time.Duration.ofDays(30)),
        LAST_90_DAYS(java.time.Duration.ofDays(90)),
        LAST_YEAR(java.time.Duration.ofDays(365))
    }
    
    enum class RecommendationType {
        MAINTENANCE, OPTIMIZATION, MONITORING, ALERT
    }
    
    enum class Priority {
        LOW, MEDIUM, HIGH, CRITICAL
    }
    
    enum class MaintenanceUrgency {
        SCHEDULED, SOON, URGENT, OVERDUE
    }
    
