    private fun formatTime(date: java.util.Date): String {
        val hours = date.hours
        val minutes = date.minutes
        return String.format("%02d:%02d", hours, minutes)
    }

    companion object {
        private const val TAG = "LiveTrackingFragment"
        const val ARG_VEHICLE_ID = "vehicle_id"
        const val ARG_ROUTE_ID = "route_id"
        
        fun newInstance(vehicleId: String, routeId: String): LiveTrackingFragment {
            return LiveTrackingFragment().apply {
                arguments = Bundle().apply {
                    putString(ARG_VEHICLE_ID, vehicleId)
                    putString(ARG_ROUTE_ID, routeId)
                }
            }
        }
    }
}

/**
 * Tracking UI state
 */
sealed class TrackingUIState {
    object Initializing : TrackingUIState()
    object MapReady : TrackingUIState()
    object StartingTracking : TrackingUIState()
    object TrackingActive : TrackingUIState()
    object TrackingPaused : TrackingUIState()
    object TrackingStopped : TrackingUIState()
    object MapMoving : TrackingUIState()
    object MapIdle : TrackingUIState()
    object Refreshing : TrackingUIState()
    data class Error(val message: String) : TrackingUIState()
}
