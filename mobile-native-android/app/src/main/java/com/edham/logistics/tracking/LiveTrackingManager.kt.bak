    /**
     * Stop live tracking
     */
    fun stopTracking() {
        try {
            // Stop location updates
            stopLocationUpdates()
            
            // Stop monitoring systems
            stopMonitoringSystems()
            
            // Save final route data
            saveRouteData()
            
            // Update state
            _trackingState.value = TrackingState.Stopped
            isTracking = false
            
        } catch (e: Exception) {
            _trackingState.value = TrackingState.Error(e.message ?: "Failed to stop tracking")
        }
    }
    
    /**
     * Pause tracking
     */
    fun pauseTracking() {
        if (isTracking) {
            stopLocationUpdates()
            _trackingState.value = TrackingState.Paused
        }
    }
    
    /**
     * Resume tracking
     */
    fun resumeTracking() {
        if (_trackingState.value is TrackingState.Paused) {
            startLocationUpdates()
            _trackingState.value = TrackingState.Active
        }
    }
    
