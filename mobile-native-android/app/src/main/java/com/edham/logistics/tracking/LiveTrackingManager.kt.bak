/**
 * Tracking state
 */
sealed class TrackingState {
    object Stopped : TrackingState()
    object Starting : TrackingState()
    object Active : TrackingState()
    object Paused : TrackingState()
    data class Error(val message: String) : TrackingState()
}

/**
 * Route progress
 */
data class RouteProgress(
    val percentage: Float,
    val distanceRemaining: Double,
    val timeRemaining: Long,
    val eta: Date,
    val currentLeg: Int,
    val totalLegs: Int,
    val nextStop: String?
)

/**
 * Tracking statistics
 */
data class TrackingStats(
    val duration: Long,
    val distance: Double,
    val averageSpeed: Double,
    val maxSpeed: Double,
    val fuelConsumed: Double,
    val averageTemperature: Float,
    val alertsCount: Int,
    val batteryLevel: Int,
    val networkType: String
)

/**
 * Tracking alerts
 */
sealed class TrackingAlert {
    data class Error(val message: String) : TrackingAlert()
    object RouteCompleted : TrackingAlert()
    data class GeofenceEntered(val name: String) : TrackingAlert()
    data class GeofenceExited(val name: String) : TrackingAlert()
    data class GeofenceDwell(val name: String) : TrackingAlert()
    data class SpeedLimitExceeded(val speed: Float, val limit: Float) : TrackingAlert()
    data class LowBattery(val level: Int) : TrackingAlert()
    data class HighTemperature(val temperature: Float) : TrackingAlert()
    data class LowFuel(val level: Float) : TrackingAlert()
    object NetworkLost : TrackingAlert()
    object NetworkRestored : TrackingAlert()
}

/**
 * Tracking summary
 */
data class TrackingSummary(
    val state: TrackingState,
    val currentLocation: Location?,
    val routeProgress: RouteProgress?,
    val stats: TrackingStats?,
    val alerts: List<TrackingAlert>
)
