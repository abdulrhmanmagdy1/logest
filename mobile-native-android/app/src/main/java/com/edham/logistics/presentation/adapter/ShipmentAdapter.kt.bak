package com.edham.logistics.presentation.adapter

import android.view.LayoutInflater
import android.view.ViewGroup
import androidx.recyclerview.widget.DiffUtil
import androidx.recyclerview.widget.ListAdapter
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.databinding.ItemShipmentBinding
import com.edham.logistics.domain.model.Shipment
import com.edham.logistics.domain.model.ShipmentStatus
import com.edham.logistics.presentation.util.DateFormatter
import com.edham.logistics.presentation.util.ShipmentStatusFormatter
import javax.inject.Inject

class ShipmentAdapter @Inject constructor(
    private val dateFormatter: DateFormatter,
    private val statusFormatter: ShipmentStatusFormatter
) : ListAdapter<Shipment, ShipmentAdapter.ShipmentViewHolder>(ShipmentDiffCallback()) {

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): ShipmentViewHolder {
        val binding = ItemShipmentBinding.inflate(
            LayoutInflater.from(parent.context),
            parent,
            false
        )
        return ShipmentViewHolder(binding)
    }

    override fun onBindViewHolder(holder: ShipmentViewHolder, position: Int) {
        holder.bind(getItem(position))
    }

    inner class ShipmentViewHolder(
        private val binding: ItemShipmentBinding
    ) : RecyclerView.ViewHolder(binding.root) {

        fun bind(shipment: Shipment) {
            binding.apply {
                textTrackingNumber.text = shipment.trackingNumber
                textClientName.text = shipment.clientName
                textPickupAddress.text = shipment.pickupAddress
                textDeliveryAddress.text = shipment.deliveryAddress
                textWeight.text = "${shipment.weight} كجم"
                textPrice.text = shipment.price.formatCurrency()
                textStatus.text = statusFormatter.getStatusDisplayName(shipment.status)
                
                // Set status color
                textStatus.setTextColor(statusFormatter.getStatusColor(shipment.status))
                
                // Set cargo type
                textCargoType.text = statusFormatter.getCargoTypeDisplayName(shipment.cargoType)
                
                // Set temperature if available
                shipment.temperature?.let { temp ->
                    textTemperature.text = "${temp}°C"
                    textTemperature.visible()
                } ?: run {
                    textTemperature.gone()
                }
                
                // Set status icon
                imageStatus.setImageResource(statusFormatter.getStatusIcon(shipment.status))
                
                // Set click listeners
                root.setOnClickListener {
                    // Handle item click
                    onShipmentClick?.invoke(shipment)
                }
                
                buttonTrack.setOnClickListener {
                    // Handle track button click
                    onTrackClick?.invoke(shipment)
                }
            }
        }
    }

    private var onShipmentClick: ((Shipment) -> Unit)? = null
    private var onTrackClick: ((Shipment) -> Unit)? = null

    fun setOnShipmentClick(listener: (Shipment) -> Unit) {
        onShipmentClick = listener
    }

    fun setOnTrackClick(listener: (Shipment) -> Unit) {
        onTrackClick = listener
    }

    private class ShipmentDiffCallback : DiffUtil.ItemCallback<Shipment>() {
        override fun areItemsTheSame(oldItem: Shipment, newItem: Shipment): Boolean {
            return oldItem.id == newItem.id
        }

        override fun areContentsTheSame(oldItem: Shipment, newItem: Shipment): Boolean {
            return oldItem == newItem
        }
    }
}
