package com.edham.logistics.presentation.ui.shipment

import android.os.Bundle
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import androidx.fragment.app.Fragment
import androidx.fragment.app.viewModels
import androidx.lifecycle.lifecycleScope
import androidx.recyclerview.widget.LinearLayoutManager
import com.edham.logistics.core.extensions.gone
import com.edham.logistics.core.extensions.visible
import com.edham.logistics.databinding.FragmentShipmentListBinding
import com.edham.logistics.presentation.adapter.ShipmentAdapter
import com.edham.logistics.presentation.ui.shipment.ShipmentListViewModel
import dagger.hilt.android.AndroidEntryPoint
import kotlinx.coroutines.launch
import javax.inject.Inject

@AndroidEntryPoint
class ShipmentListFragment : Fragment() {

    private var _binding: FragmentShipmentListBinding? = null
    private val binding get() = _binding!!
    
    private val viewModel: ShipmentListViewModel by viewModels()
    
    @Inject
    lateinit var shipmentAdapter: ShipmentAdapter

    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View {
        _binding = FragmentShipmentListBinding.inflate(inflater, container, false)
        return binding.root
    }

    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        setupRecyclerView()
        observeViewModel()
        setupListeners()
    }

    private fun setupRecyclerView() {
        binding.recyclerViewShipments.apply {
            adapter = shipmentAdapter
            layoutManager = LinearLayoutManager(requireContext())
        }
    }

    private fun observeViewModel() {
        viewLifecycleOwner.lifecycleScope.launch {
            viewModel.uiState.collect { uiState ->
                when {
                    uiState.isLoading -> {
                        showLoading()
                    }
                    uiState.isUpdating -> {
                        showUpdating()
                    }
                    uiState.error != null -> {
                        showError(uiState.error)
                    }
                    uiState.successMessage != null -> {
                        showSuccess(uiState.successMessage)
                    }
                    else -> {
                        showContent(uiState.shipments)
                    }
                }
            }
        }
    }

    private fun setupListeners() {
        binding.swipeRefreshLayout.setOnRefreshListener {
            viewModel.refreshShipments()
        }
        
        binding.buttonRetry.setOnClickListener {
            viewModel.refreshShipments()
        }
        
        binding.textError.setOnClickListener {
            viewModel.refreshShipments()
        }
    }

    private fun showLoading() {
        binding.progressBar.visible()
        binding.recyclerViewShipments.gone()
        binding.layoutError.gone()
        binding.swipeRefreshLayout.isRefreshing = false
    }

    private fun showUpdating() {
        binding.swipeRefreshLayout.isRefreshing = true
    }

    private fun showError(error: String?) {
        binding.progressBar.gone()
        binding.recyclerViewShipments.gone()
        binding.layoutError.visible()
        binding.textError.text = error ?: "حدث خطأ غير متوقع"
        binding.swipeRefreshLayout.isRefreshing = false
    }

    private fun showSuccess(message: String?) {
        binding.swipeRefreshLayout.isRefreshing = false
        // Could show a snackbar or toast
        message?.let {
            // showSnackbar(it)
        }
    }

    private fun showContent(shipments: List<com.edham.logistics.domain.model.Shipment>) {
        binding.progressBar.gone()
        binding.layoutError.gone()
        binding.recyclerViewShipments.visible()
        binding.swipeRefreshLayout.isRefreshing = false
        
        if (shipments.isEmpty()) {
            binding.layoutEmpty.visible()
        } else {
            binding.layoutEmpty.gone()
            shipmentAdapter.submitList(shipments)
        }
    }

    override fun onDestroyView() {
        super.onDestroyView()
        _binding = null
    }
}
