package com.edham.logistics.feature.warehouse

import com.edham.logistics.data.local.entity.InventoryItem
import com.edham.logistics.data.local.entity.StockMovement
import com.edham.logistics.data.local.entity.WarehouseZone
import com.edham.logistics.data.local.entity.Shelf
import retrofit2.Response
import retrofit2.http.*

interface WarehouseApi {
    
    @GET("api/v1/warehouse/{warehouseId}/inventory")
    suspend fun getInventory(@Path("warehouseId") warehouseId: String): List<InventoryItem>
    
    @GET("api/v1/warehouse/{warehouseId}/zones")
    suspend fun getWarehouseZones(@Path("warehouseId") warehouseId: String): List<WarehouseZone>
    
    @GET("api/v1/warehouse/{warehouseId}/shelves")
    suspend fun getWarehouseShelves(@Path("warehouseId") warehouseId: String): List<Shelf>
    
    @POST("api/v1/warehouse/{warehouseId}/receive")
    suspend fun receiveShipment(
        @Path("warehouseId") warehouseId: String,
        @Body shipment: ReceivedShipmentRequest
    ): Response<ReceiveShipmentResponse>
    
    @POST("api/v1/warehouse/{warehouseId}/dispatch")
    suspend fun dispatchItems(
        @Path("warehouseId") warehouseId: String,
        @Body dispatchRequest: DispatchRequest
    ): Response<DispatchResponse>
    
    @POST("api/v1/warehouse/{warehouseId}/transfer")
    suspend fun transferInventory(
        @Path("warehouseId") warehouseId: String,
        @Body transferRequest: TransferRequest
    ): Response<TransferResponse>
    
    @POST("api/v1/warehouse/{warehouseId}/damage")
    suspend fun reportDamagedGoods(
        @Path("warehouseId") warehouseId: String,
        @Body damageRequest: DamageRequest
    ): Response<DamageResponse>
    
    @POST("api/v1/warehouse/{warehouseId}/audit")
    suspend fun performAudit(
        @Path("warehouseId") warehouseId: String,
        @Body auditRequest: AuditRequest
    ): Response<AuditResponse>
    
    @GET("api/v1/warehouse/{warehouseId}/analytics")
    suspend fun getWarehouseAnalytics(@Path("warehouseId") warehouseId: String): WarehouseAnalyticsResponse
    
    @GET("api/v1/warehouse/{warehouseId}/movements")
    suspend fun getStockMovements(
        @Path("warehouseId") warehouseId: String,
        @Query("startDate") startDate: Long?,
        @Query("endDate") endDate: Long?,
        @Query("movementType") movementType: String?
    ): List<StockMovement>
    
    @POST("api/v1/warehouse/{warehouseId}/movements/sync")
    suspend fun syncStockMovements(@Body movements: List<StockMovement>): Response<Unit>
    
    @GET("api/v1/warehouse/{warehouseId}/updates")
    suspend fun getInventoryUpdates(@Query("since") since: Long): List<InventoryUpdate>
    
    @GET("api/v1/warehouse/{warehouseId}/search")
    suspend fun searchInventory(
        @Path("warehouseId") warehouseId: String,
        @Query("query") query: String
    ): List<InventoryItem>
    
    @POST("api/v1/warehouse/{warehouseId}/filter")
    suspend fun filterInventory(
        @Path("warehouseId") warehouseId: String,
        @Body filters: InventoryFiltersRequest
    ): List<InventoryItem>
    
    @POST("api/v1/warehouse/{warehouseId}/items")
    suspend fun createInventoryItem(
        @Path("warehouseId") warehouseId: String,
        @Body item: InventoryItem
    ): Response<InventoryItem>
    
    @PUT("api/v1/warehouse/{warehouseId}/items/{itemId}")
    suspend fun updateInventoryItem(
        @Path("warehouseId") warehouseId: String,
        @Path("itemId") itemId: String,
        @Body item: InventoryItem
    ): Response<InventoryItem>
    
    @DELETE("api/v1/warehouse/{warehouseId}/items/{itemId}")
    suspend fun deleteInventoryItem(
        @Path("warehouseId") warehouseId: String,
        @Path("itemId") itemId: String
    ): Response<Unit>
    
    @POST("api/v1/warehouse/{warehouseId}/zones")
    suspend fun createWarehouseZone(
        @Path("warehouseId") warehouseId: String,
        @Body zone: WarehouseZone
    ): Response<WarehouseZone>
    
    @PUT("api/v1/warehouse/{warehouseId}/zones/{zoneId}")
    suspend fun updateWarehouseZone(
        @Path("warehouseId") warehouseId: String,
        @Path("zoneId") zoneId: String,
        @Body zone: WarehouseZone
    ): Response<WarehouseZone>
    
    @POST("api/v1/warehouse/{warehouseId}/shelves")
    suspend fun createWarehouseShelf(
        @Path("warehouseId") warehouseId: String,
        @Body shelf: Shelf
    ): Response<Shelf>
    
    @PUT("api/v1/warehouse/{warehouseId}/shelves/{shelfId}")
    suspend fun updateWarehouseShelf(
        @Path("warehouseId") warehouseId: String,
        @Path("shelfId") shelfId: String,
        @Body shelf: Shelf
    ): Response<Shelf>
    
    @GET("api/v1/warehouse/{warehouseId}/reports/inventory")
    suspend fun generateInventoryReport(
        @Path("warehouseId") warehouseId: String,
        @Query("format") format: String,
        @Query("startDate") startDate: Long?,
        @Query("endDate") endDate: Long?
    ): Response<ReportResponse>
}

// Request/Response data classes
data class ReceivedShipmentRequest(
    val shipmentId: String,
    val items: List<ReceivedItemRequest>
)

data class ReceivedItemRequest(
    val sku: String,
    val quantity: Int,
    val targetLocation: String
)

data class ReceiveShipmentResponse(
    val success: Boolean,
    val receivedItems: List<InventoryItem>,
    val errors: List<String>
)

data class DispatchRequest(
    val items: List<DispatchItemRequest>
)

data class DispatchItemRequest(
    val sku: String,
    val quantity: Int,
    val destination: String
)

data class DispatchResponse(
    val success: Boolean,
    val dispatchedItems: List<InventoryItem>,
    val errors: List<String>
)

data class TransferRequest(
    val itemId: String,
    val quantity: Int,
    val fromLocation: String,
    val toLocation: String
)

data class TransferResponse(
    val success: Boolean,
    val message: String
)

data class DamageRequest(
    val itemId: String,
    val quantity: Int,
    val damageType: String,
    val notes: String
)

data class DamageResponse(
    val success: Boolean,
    val message: String
)

data class AuditRequest(
    val auditItems: List<AuditItemRequest>
)

data class AuditItemRequest(
    val sku: String,
    val actualQuantity: Int
)

data class AuditResponse(
    val success: Boolean,
    val discrepancies: List<InventoryDiscrepancy>,
    val adjustments: Int
)

data class WarehouseAnalyticsResponse(
    val totalItems: Int,
    val totalQuantity: Int,
    val lowStockItems: Int,
    val outOfStockItems: Int,
    val totalValue: Double,
    val zoneDistribution: List<ZoneAnalytics>,
    val movementsByType: Map<String, Int>,
    val lastUpdated: Long
)

data class InventoryUpdate(
    val itemId: String,
    val newQuantity: Int,
    val timestamp: Long,
    val movementType: String
)

data class InventoryFiltersRequest(
    val category: String?,
    val zoneId: String?,
    val stockLevel: String?,
    val minPrice: Double?,
    val maxPrice: Double?
)

data class ReportResponse(
    val success: Boolean,
    val reportUrl: String,
    val format: String
)
