package com.edham.logistics.auth

import android.os.Bundle
import android.text.Editable
import android.text.TextWatcher
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import androidx.fragment.app.Fragment
import androidx.fragment.app.viewModels
import androidx.lifecycle.lifecycleScope
import androidx.navigation.fragment.findNavController
import com.edham.logistics.R
import com.edham.logistics.databinding.FragmentForgotPasswordBinding
import com.edham.logistics.utils.NetworkUtils
import com.edham.logistics.utils.ValidationUtils
import dagger.hilt.android.AndroidEntryPoint
import kotlinx.coroutines.delay
import kotlinx.coroutines.launch
import javax.inject.Inject

/**
 * Forgot Password Fragment - Handles password reset functionality
 * 
 * Features:
 * - Email input for password reset
 * - Send reset link functionality
 * - Success message display
 * - Navigation back to login
 * - Arabic RTL support
 */
@AndroidEntryPoint
class ForgotPasswordFragment : Fragment() {

    private var _binding: FragmentForgotPasswordBinding? = null
    private val binding get() = _binding!!

    @Inject
    lateinit var authenticationManager: AuthenticationManager

    @Inject
    lateinit var networkUtils: NetworkUtils

    @Inject
    lateinit var validationUtils: ValidationUtils

    private val viewModel: ForgotPasswordViewModel by viewModels()

    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View {
        _binding = FragmentForgotPasswordBinding.inflate(inflater, container, false)
        return binding.root
    }

    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        
        setupUI()
        setupObservers()
        setupClickListeners()
        setupTextWatchers()
    }

    override fun onDestroyView() {
        super.onDestroyView()
        _binding = null
    }

    private fun setupUI() {
        // Configure text direction for RTL support
        if (isRTL()) {
            binding.emailEditText.textDirection = View.TEXT_DIRECTION_RTL
        }
        
        // Initially disable send button
        updateSendButtonState()
    }

    private fun setupObservers() {
        // Observe forgot password result
        viewModel.forgotPasswordResult.observe(viewLifecycleOwner) { result ->
            result.onSuccess { resetToken ->
                showLoading(false)
                showSuccessMessage(resetToken)
            }.onFailure { exception ->
                showLoading(false)
                showError(exception.message ?: "Failed to send reset link")
            }
        }
    }

    private fun setupClickListeners() {
        binding.sendResetButton.setOnClickListener {
            sendResetLink()
        }

        binding.backToLoginText.setOnClickListener {
            navigateToLogin()
        }

        binding.contactSupportText.setOnClickListener {
            contactSupport()
        }

        binding.okButton.setOnClickListener {
            navigateToLogin()
        }
    }

    private fun setupTextWatchers() {
        binding.emailEditText.addTextChangedListener { text ->
            clearError(binding.emailInputLayout)
            updateSendButtonState()
        }
    }

    private fun sendResetLink() {
        val email = binding.emailEditText.text.toString().trim()

        // Validate email
        if (!validationUtils.isValidEmail(email)) {
            binding.emailInputLayout.error = getString(R.string.invalid_email)
            return
        }

        if (!networkUtils.isNetworkAvailable()) {
            showError("No internet connection")
            return
        }

        viewLifecycleOwner.lifecycleScope.launch {
            showLoading(true)
            val result = authenticationManager.forgotPassword(email)
            result.onSuccess { resetToken ->
                showLoading(false)
                showSuccessMessage(resetToken)
            }.onFailure { exception ->
                showLoading(false)
                showError(exception.message ?: "Failed to send reset link")
            }
        }
    }

    private fun updateSendButtonState() {
        val email = binding.emailEditText.text.toString().trim()
        val isValid = validationUtils.isValidEmail(email) && networkUtils.isNetworkAvailable()
        
        binding.sendResetButton.isEnabled = isValid
    }

    private fun showLoading(show: Boolean) {
        binding.progressOverlay.visibility = if (show) View.VISIBLE else View.GONE
        binding.sendResetButton.isEnabled = !show
    }

    private fun showError(message: String) {
        binding.emailInputLayout.error = message
    }

    private fun clearError(inputLayout: com.google.android.material.textfield.TextInputLayout) {
        inputLayout.error = null
        inputLayout.isErrorEnabled = false
    }

    private fun showSuccessMessage(resetToken: String) {
        // Update success message with email
        val email = binding.emailEditText.text.toString().trim()
        binding.successDescription.text = getString(R.string.reset_link_sent_description, email)
        
        // Show success overlay
        binding.successMessage.visibility = View.VISIBLE
        
        // Hide form
        binding.emailInputLayout.visibility = View.GONE
        binding.sendResetButton.visibility = View.GONE
        binding.backToLoginText.visibility = View.GONE
    }

    private fun navigateToLogin() {
        findNavController().navigate(R.id.action_forgotPasswordFragment_to_loginFragment)
    }

    private fun contactSupport() {
        // Open email app
        val emailIntent = android.content.Intent(android.content.Intent.ACTION_SENDTO).apply {
            data = "mailto:support@edhamlogistics.com"
            putExtra(android.content.Intent.EXTRA_SUBJECT, "Password Reset Issue")
            putExtra(android.content.Intent.EXTRA_TEXT, "I'm having trouble with password reset.")
        }
        startActivity(emailIntent)
    }

    private fun isRTL(): Boolean {
        return resources.configuration.layoutDirection == View.LAYOUT_DIRECTION_RTL
    }

    companion object {
        private const val TAG = "ForgotPasswordFragment"
    }
}
