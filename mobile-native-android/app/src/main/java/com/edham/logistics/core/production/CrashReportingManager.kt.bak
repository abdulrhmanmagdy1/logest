package com.edham.logistics.core.production

import android.content.Context
import android.util.Log
import com.google.firebase.crashlytics.FirebaseCrashlytics
import com.google.firebase.crashlytics.ktx.crashlytics
import com.google.firebase.ktx.Firebase
import dagger.hilt.android.qualifiers.ApplicationContext
import javax.inject.Inject
import javax.inject.Singleton

/**
 * Crash Reporting Manager
 * Handles Firebase Crashlytics integration for production crash reporting
 */
@Singleton
class CrashReportingManager @Inject constructor(
    @ApplicationContext private val context: Context,
    private val productionConfig: ProductionConfig
) {
    
    private val crashlytics: FirebaseCrashlytics by lazy {
        Firebase.crashlytics
    }
    
    companion object {
        private const val TAG = "CrashReportingManager"
        
        // Custom keys for crash reporting
        const val KEY_USER_ROLE = "user_role"
        const val KEY_USER_ID = "user_id"
        const val KEY_BUILD_TYPE = "build_type"
        const val KEY_APP_VERSION = "app_version"
        const val KEY_DEVICE_MODEL = "device_model"
        const val KEY_ANDROID_VERSION = "android_version"
        const val KEY_MEMORY_AVAILABLE = "memory_available"
        const val KEY_DISK_SPACE_AVAILABLE = "disk_space_available"
    }
    
    /**
     * Initialize crash reporting
     */
    fun initialize() {
        if (productionConfig.isProductionMode()) {
            setupCrashlytics()
            setDefaultKeys()
            Log.i(TAG, "Crash reporting initialized")
        } else {
            Log.d(TAG, "Crash reporting disabled in non-production mode")
        }
    }
    
    /**
     * Setup Firebase Crashlytics
     */
    private fun setupCrashlytics() {
        try {
            // Enable crashlytics
            crashlytics.setCrashlyticsCollectionEnabled(true)
            
            // Set custom user identifier
            crashlytics.setUserId("anonymous")
            
            Log.i(TAG, "Firebase Crashlytics setup completed")
        } catch (e: Exception) {
            Log.e(TAG, "Failed to setup Firebase Crashlytics", e)
        }
    }
    
    /**
     * Set default keys for crash reporting
     */
    private fun setDefaultKeys() {
        try {
            // Build information
            crashlytics.setCustomKey(KEY_BUILD_TYPE, productionConfig.getBuildInfo()["buildType"] ?: "unknown")
            crashlytics.setCustomKey(KEY_APP_VERSION, productionConfig.getBuildInfo()["versionName"] ?: "unknown")
            
            // Device information
            val deviceInfo = getDeviceInfo()
            crashlytics.setCustomKey(KEY_DEVICE_MODEL, deviceInfo["model"] ?: "unknown")
            crashlytics.setCustomKey(KEY_ANDROID_VERSION, deviceInfo["androidVersion"] ?: "unknown")
            
            // System information
            val systemInfo = getSystemInfo()
            crashlytics.setCustomKey(KEY_MEMORY_AVAILABLE, systemInfo["memoryAvailable"] ?: "unknown")
            crashlytics.setCustomKey(KEY_DISK_SPACE_AVAILABLE, systemInfo["diskSpaceAvailable"] ?: "unknown")
            
        } catch (e: Exception) {
            Log.e(TAG, "Failed to set default keys", e)
        }
    }
    
    /**
     * Set user information for crash reporting
     */
    fun setUser(userId: String, userRole: String) {
        if (productionConfig.isProductionMode()) {
            try {
                crashlytics.setUserId(userId)
                crashlytics.setCustomKey(KEY_USER_ROLE, userRole)
                crashlytics.setCustomKey(KEY_USER_ID, userId)
                Log.d(TAG, "User information set for crash reporting")
            } catch (e: Exception) {
                Log.e(TAG, "Failed to set user information", e)
            }
        }
    }
    
    /**
     * Clear user information
     */
    fun clearUser() {
        if (productionConfig.isProductionMode()) {
            try {
                crashlytics.setUserId("anonymous")
                crashlytics.setCustomKey(KEY_USER_ROLE, "anonymous")
                crashlytics.setCustomKey(KEY_USER_ID, "anonymous")
                Log.d(TAG, "User information cleared")
            } catch (e: Exception) {
                Log.e(TAG, "Failed to clear user information", e)
            }
        }
    }
    
    /**
     * Log custom exception
     */
    fun logException(throwable: Throwable, context: String? = null) {
        if (productionConfig.isProductionMode()) {
            try {
                if (context != null) {
                    crashlytics.setCustomKey("error_context", context)
                }
                crashlytics.recordException(throwable)
                Log.d(TAG, "Exception logged: ${throwable.message}")
            } catch (e: Exception) {
                Log.e(TAG, "Failed to log exception", e)
            }
        }
    }
    
    /**
     * Log custom message
     */
    fun logMessage(message: String, level: String = "INFO") {
        if (productionConfig.isProductionMode()) {
            try {
                crashlytics.log("$level: $message")
                Log.d(TAG, "Message logged: $message")
            } catch (e: Exception) {
                Log.e(TAG, "Failed to log message", e)
            }
        }
    }
    
    /**
     * Set custom key
     */
    fun setCustomKey(key: String, value: String) {
        if (productionConfig.isProductionMode()) {
            try {
                crashlytics.setCustomKey(key, value)
                Log.d(TAG, "Custom key set: $key = $value")
            } catch (e: Exception) {
                Log.e(TAG, "Failed to set custom key", e)
            }
        }
    }
    
    /**
     * Add breadcrumb for user journey tracking
     */
    fun addBreadcrumb(message: String, category: String = "user_action") {
        if (productionConfig.isProductionMode()) {
            try {
                crashlytics.log("Breadcrumb: [$category] $message")
                Log.d(TAG, "Breadcrumb added: $message")
            } catch (e: Exception) {
                Log.e(TAG, "Failed to add breadcrumb", e)
            }
        }
    }
    
    /**
     * Record non-fatal exception
     */
    fun recordNonFatalException(throwable: Throwable, context: Map<String, String> = emptyMap()) {
        if (productionConfig.isProductionMode()) {
            try {
                // Set context information
                context.forEach { (key, value) ->
                    crashlytics.setCustomKey("context_$key", value)
                }
                
                crashlytics.recordException(throwable)
                Log.d(TAG, "Non-fatal exception recorded: ${throwable.message}")
            } catch (e: Exception) {
                Log.e(TAG, "Failed to record non-fatal exception", e)
            }
        }
    }
    
    /**
     * Get device information
     */
    private fun getDeviceInfo(): Map<String, String> {
        return mapOf(
            "model" to android.os.Build.MODEL,
            "manufacturer" to android.os.Build.MANUFACTURER,
            "androidVersion" to android.os.Build.VERSION.RELEASE,
            "sdkVersion" to android.os.Build.VERSION.SDK_INT.toString()
        )
    }
    
    /**
     * Get system information
     */
    private fun getSystemInfo(): Map<String, String> {
        val runtime = Runtime.getRuntime()
        val maxMemory = runtime.maxMemory() / (1024 * 1024) // MB
        val availableMemory = (runtime.totalMemory() - runtime.freeMemory()) / (1024 * 1024) // MB
        
        return mapOf(
            "memoryAvailable" to "${availableMemory}MB",
            "memoryMax" to "${maxMemory}MB",
            "diskSpaceAvailable" to getAvailableDiskSpace()
        )
    }
    
    /**
     * Get available disk space
     */
    private fun getAvailableDiskSpace(): String {
        return try {
            val stat = android.os.StatFs(context.filesDir.path)
            val availableBytes = stat.availableBlocksLong * stat.blockSizeLong
            val availableMB = availableBytes / (1024 * 1024)
            "${availableMB}MB"
        } catch (e: Exception) {
            "unknown"
        }
    }
    
    /**
     * Test crash reporting
     */
    fun testCrashReporting() {
        if (!productionConfig.isProductionMode()) {
            try {
                // Test exception
                throw RuntimeException("Test crash for debugging")
            } catch (e: Exception) {
                recordNonFatalException(e, mapOf("test" to "true"))
            }
        }
    }
    
    /**
     * Enable/disable crash reporting
     */
    fun setCrashReportingEnabled(enabled: Boolean) {
        try {
            crashlytics.setCrashlyticsCollectionEnabled(enabled)
            Log.i(TAG, "Crash reporting ${if (enabled) "enabled" else "disabled"}")
        } catch (e: Exception) {
            Log.e(TAG, "Failed to set crash reporting enabled", e)
        }
    }
    
    /**
     * Check if crash reporting is enabled
     */
    fun isCrashReportingEnabled(): Boolean {
        return try {
            crashlytics.isCrashlyticsCollectionEnabled
        } catch (e: Exception) {
            Log.e(TAG, "Failed to check crash reporting status", e)
            false
        }
    }
}
