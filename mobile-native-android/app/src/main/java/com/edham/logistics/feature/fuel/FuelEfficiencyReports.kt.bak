    data class OptimizationOpportunity(
        val area: OptimizationArea,
        val description: String,
        val potentialSavings: Double,
        val implementationCost: Double,
        val roi: Double
    )
    
    enum class RecommendationCategory {
        DRIVING_BEHAVIOR, VEHICLE_MAINTENANCE, ROUTE_OPTIMIZATION, FUEL_MANAGEMENT
    }
    
    enum class Priority {
        LOW, MEDIUM, HIGH, CRITICAL
    }
    
    enum class ImplementationEffort {
        LOW, MEDIUM, HIGH
    }
    
    enum class CoachingType {
        EFFICIENCY, SAFETY, COST_SAVINGS, BEHAVIOR_IMPROVEMENT
    }
    
    enum class OptimizationArea {
        ROUTE_PLANNING, VEHICLE_UTILIZATION, DRIVER_TRAINING, MAINTENANCE_SCHEDULE
    }
    
    // Additional stub methods for completeness
    private fun generateEfficiencyTrendAnalysis(vehicleId: String, timeWindow: TimeWindow): TrendAnalysis {
        return TrendAnalysis(
            trend = EfficiencyTrend.IMPROVING,
            changePercentage = 5.2,
            trendDirection = TrendDirection.UP,
            significantEvents = emptyList()
        )
    }
    
    private fun generateVehicleComparisons(vehicleId: String, metrics: VehicleEfficiencyMetrics): List<VehicleComparison> {
        return emptyList()
    }
    
    private fun generateEfficiencyRecommendations(
        vehicleId: String, 
        metrics: VehicleEfficiencyMetrics, 
        data: VehicleEfficiencyData
    ): List<EfficiencyRecommendation> {
        return emptyList()
    }
    
    private fun calculateCostAnalysis(data: VehicleEfficiencyData, metrics: VehicleEfficiencyMetrics): CostAnalysis {
        val totalCost = data.totalFuelConsumed * FUEL_PRICE_PER_LITER
        return CostAnalysis(
            totalFuelCost = totalCost,
            costPerKm = metrics.fuelCostPerKm,
            monthlySavings = 0.0,
            annualSavings = 0.0,
            costBreakdown = CostBreakdown(
                fuelCost = totalCost,
                maintenanceCost = 0.0,
                otherCosts = 0.0
            )
        )
    }
    
    data class CostBreakdown(
        val fuelCost: Double,
        val maintenanceCost: Double,
        val otherCosts: Double
    )
    
