    // Enums
    enum class ReportType {
        COMPREHENSIVE, PERFORMANCE, FLEET_ANALYSIS, ROUTE_ANALYSIS, COST_ANALYSIS
    }
    
    enum class TimeWindow(val duration: java.time.Duration) {
        LAST_7_DAYS(java.time.Duration.ofDays(7)),
        LAST_30_DAYS(java.time.Duration.ofDays(30)),
        LAST_90_DAYS(java.time.Duration.ofDays(90)),
        LAST_YEAR(java.time.Duration.ofDays(365))
    }
    
    enum class ReportStatus {
        GENERATED, PROCESSING, FAILED, ARCHIVED
    }
    
    enum class EfficiencyTrend {
        IMPROVING, DECLINING, STABLE
    }
    
    enum class EfficiencyRating {
        EXCELLENT, GOOD, AVERAGE, POOR, VERY_POOR
    }
    
    enum class TrendDirection {
        UP, DOWN, STABLE
    }
    
    enum class CongestionLevel {
        LOW, MEDIUM, HIGH, SEVERE
    }
    
    // Additional data classes for recommendations, predictions, etc.
    data class EfficiencyRecommendation(
        val category: RecommendationCategory,
        val title: String,
        val description: String,
        val potentialSavings: Double,
        val priority: Priority,
