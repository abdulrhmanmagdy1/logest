package com.edham.logistics.feature.driver

import android.app.Activity
import android.content.Intent
import android.graphics.Bitmap
import android.os.Bundle
import android.provider.MediaStore
import android.widget.Toast
import androidx.activity.result.contract.ActivityResultContracts
import androidx.fragment.app.Fragment
import com.edham.logistics.R
import com.edham.logistics.databinding.FragmentIncidentReportingBinding
import com.edham.logistics.utils.VoiceAlertManager
import com.edham.logistics.utils.GPSOptimizer
import timber.log.Timber
import java.io.ByteArrayOutputStream
import java.util.*

class IncidentReportingFragment : Fragment() {
    
    private var _binding: FragmentIncidentReportingBinding? = null
    private val binding get() = _binding!!
    
    private lateinit var voiceAlertManager: VoiceAlertManager
    private lateinit var gpsOptimizer: GPSOptimizer
    private var incidentPhotos = mutableListOf<Bitmap>()
    private var currentLocation: android.location.Location? = null
    
    private val cameraLauncher = registerForActivityResult(
        ActivityResultContracts.StartActivityForResult()
    ) { result ->
        if (result.resultCode == Activity.RESULT_OK) {
            result.data?.extras?.get("data")?.let { bitmap ->
                incidentPhotos.add(bitmap as Bitmap)
                updatePhotosUI()
                voiceAlertManager.speak("Photo captured successfully")
            }
        }
    }
    
    override fun onCreateView(
        inflater: android.view.LayoutInflater,
        container: android.view.ViewGroup?,
        savedInstanceState: Bundle?
    ): android.view.View {
        _binding = FragmentIncidentReportingBinding.inflate(inflater, container, false)
        return binding.root
    }
    
    override fun onViewCreated(view: android.view.View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        
        voiceAlertManager = VoiceAlertManager(requireContext())
        gpsOptimizer = GPSOptimizer(requireContext())
        
        setupUI()
        setupClickListeners()
        getCurrentLocation()
        
        voiceAlertManager.speak("Incident reporting screen opened")
    }
    
    private fun setupUI() {
        // Large touch targets for one-hand usage
        binding.btnCapturePhoto.minimumHeight = 72.dp
        binding.btnCapturePhoto.minimumWidth = 120.dp
        
        binding.btnReportIncident.minimumHeight = 88.dp
        binding.btnReportIncident.minimumWidth = 160.dp
        
        binding.btnCancel.minimumHeight = 72.dp
        binding.btnCancel.minimumWidth = 120.dp
        
        // Dark mode optimized colors
        binding.cardIncidentDetails.setCardBackgroundColor(
            requireContext().getColor(R.color.dark_surface)
        )
        
        // High visibility status colors
        binding.viewStatusIndicator.setBackgroundColor(
            requireContext().getColor(R.color.status_idle)
        )
        
        // Setup incident type spinner
        val incidentTypes = arrayOf(
            "Accident",
            "Breakdown", 
            "Traffic Jam",
            "Weather Conditions",
            "Road Hazard",
            "Vehicle Damage",
            "Theft",
            "Medical Emergency",
            "Other"
        )
        
        // Setup severity spinner
        val severityLevels = arrayOf("Low", "Medium", "High", "Critical")
    }
    
    private fun setupClickListeners() {
        binding.btnCapturePhoto.setOnClickListener {
            captureIncidentPhoto()
        }
        
        binding.btnReportIncident.setOnClickListener {
            reportIncident()
        }
        
        binding.btnCancel.setOnClickListener {
            requireActivity().onBackPressed()
        }
        
        binding.btnGetCurrentLocation.setOnClickListener {
            getCurrentLocation()
        }
    }
    
    private fun captureIncidentPhoto() {
        val cameraIntent = Intent(MediaStore.ACTION_IMAGE_CAPTURE)
        cameraLauncher.launch(cameraIntent)
    }
    
    private fun getCurrentLocation() {
        currentLocation = gpsOptimizer.getCurrentLocation()
        
        currentLocation?.let { location ->
            binding.tvCurrentLocation.text = String.format(
                "Lat: %.6f, Lng: %.6f",
                location.latitude,
                location.longitude
            )
            voiceAlertManager.speak("Location updated")
        } ?: run {
            binding.tvCurrentLocation.text = "Location not available"
            voiceAlertManager.speak("Location not available")
        }
    }
    
    private fun reportIncident() {
        val incidentType = binding.spinnerIncidentType.selectedItem?.toString()
        val severity = binding.spinnerSeverity.selectedItem?.toString()
        val description = binding.etDescription.text.toString()
        
        // Validate inputs
        if (incidentType == null) {
            Toast.makeText(requireContext(), "Please select incident type", Toast.LENGTH_SHORT).show()
            voiceAlertManager.speak("Please select incident type")
            return
        }
        
        if (severity == null) {
            Toast.makeText(requireContext(), "Please select severity level", Toast.LENGTH_SHORT).show()
            voiceAlertManager.speak("Please select severity level")
            return
        }
        
        if (description.isBlank()) {
            binding.etDescription.error = "Description required"
            voiceAlertManager.speak("Please enter incident description")
            return
        }
        
        if (currentLocation == null) {
            Toast.makeText(requireContext(), "Location required for incident report", Toast.LENGTH_SHORT).show()
            voiceAlertManager.speak("Location required for incident report")
            return
        }
        
        // Create incident report
        val incidentReport = IncidentReport(
            id = UUID.randomUUID().toString(),
            type = incidentType,
            severity = severity,
            description = description,
            location = currentLocation!!,
            photos = incidentPhotos,
            timestamp = System.currentTimeMillis(),
            driverId = getCurrentDriverId(),
            status = "REPORTED"
        )
        
        // Process incident report
        processIncidentReport(incidentReport)
    }
    
    private fun processIncidentReport(incident: IncidentReport) {
        // Show loading state
        binding.progressBar.visibility = android.view.View.VISIBLE
        binding.btnReportIncident.isEnabled = false
        
        // Update status
        updateStatus("PROCESSING")
        
        // Process incident report (API call or local storage)
        // This would typically involve:
        // 1. Save incident report to local database
        // 2. Upload photos to server
        // 3. Send incident alert to dispatcher
        // 4. Update trip status if affected
        
        // Simulate processing
        binding.root.postDelayed({
            binding.progressBar.visibility = android.view.View.GONE
            binding.btnReportIncident.isEnabled = true
            
            updateStatus("REPORTED")
            voiceAlertManager.speak("Incident reported successfully")
            Toast.makeText(requireContext(), "Incident reported successfully", Toast.LENGTH_LONG).show()
            
            // Show incident ID
            binding.tvIncidentId.text = "Incident ID: ${incident.id}"
            
            // Navigate back after delay
            binding.root.postDelayed({
                requireActivity().onBackPressed()
            }, 2000)
        }, 2000)
    }
    
    private fun updatePhotosUI() {
        binding.tvPhotoCount.text = "${incidentPhotos.size} photos captured"
        
        if (incidentPhotos.isNotEmpty()) {
            binding.btnCapturePhoto.text = "Add Photo (${incidentPhotos.size})"
            binding.btnCapturePhoto.setBackgroundColor(
                requireContext().getColor(R.color.status_active)
            )
        }
    }
    
    private fun updateStatus(status: String) {
        binding.tvStatus.text = status
        
        val color = when (status) {
            "PROCESSING" -> requireContext().getColor(R.color.status_active)
            "REPORTED" -> requireContext().getColor(R.color.status_completed)
            "ERROR" -> requireContext().getColor(R.color.status_error)
            else -> requireContext().getColor(R.color.status_idle)
        }
        
        binding.viewStatusIndicator.setBackgroundColor(color)
    }
    
    private fun getCurrentDriverId(): String {
        // Get current driver ID from preferences or authentication
        // For now, return a placeholder
        return "driver_123"
    }
    
    private fun compressBitmap(bitmap: Bitmap): ByteArray {
        val stream = ByteArrayOutputStream()
        bitmap.compress(Bitmap.CompressFormat.JPEG, 70, stream)
        return stream.toByteArray()
    }
    
    override fun onResume() {
        super.onResume()
        
        // Start location updates
        gpsOptimizer.startLocationUpdates()
    }
    
    override fun onPause() {
        super.onPause()
        
        // Stop location updates to save battery
        gpsOptimizer.stopLocationUpdates()
    }
    
    override fun onDestroyView() {
        super.onDestroyView()
        
        // Clean up resources
        gpsOptimizer.cleanup()
        voiceAlertManager.cleanup()
        _binding = null
    }
    
    // Extension for dp to pixels
    private val Int.dp: Int
        get() = (this * resources.displayMetrics.density).toInt()
}

data class IncidentReport(
    val id: String,
    val type: String,
    val severity: String,
    val description: String,
    val location: android.location.Location,
    val photos: List<Bitmap>,
    val timestamp: Long,
    val driverId: String,
    val status: String
)
