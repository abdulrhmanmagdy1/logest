package com.edham.logistics

import android.app.Notification
import android.app.NotificationChannel
import android.app.NotificationManager
import android.app.PendingIntent
import android.content.Context
import android.content.Intent
import android.os.Build
import androidx.core.app.NotificationCompat
import androidx.core.app.NotificationManagerCompat
import kotlinx.coroutines.*

class SmartNotificationsService(private val context: Context) {
    private val notificationManager = NotificationManagerCompat.from(context)
    private val scope = CoroutineScope(Dispatchers.Main + SupervisorJob())
    
    companion object {
        private const val CHANNEL_ID = "edham_logistics"
        private const val CHANNEL_NAME = "إدهام اللوجستية"
        private const val CHANNEL_DESCRIPTION = "إشعارات نظام إدهام اللوجستي"
        
        // Notification types
        const val TYPE_TEMPERATURE_ALERT = "temperature_alert"
        const val TYPE_LOAD_ASSIGNED = "load_assigned"
        const val TYPE_TRIP_COMPLETED = "trip_completed"
        const val TYPE_MAINTENANCE_DUE = "maintenance_due"
        const val TYPE_INVOICE_OVERDUE = "invoice_overdue"
        const val TYPE_EMERGENCY = "emergency"
        const val TYPE_SYSTEM_UPDATE = "system_update"
    }
    
    init {
        createNotificationChannel()
    }
    
    private fun createNotificationChannel() {
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            val channel = NotificationChannel(
                CHANNEL_ID,
                CHANNEL_NAME,
                NotificationManager.IMPORTANCE_HIGH
            ).apply {
                description = CHANNEL_DESCRIPTION
                enableLights(true)
                enableVibration(true)
                setShowBadge(true)
            }
            
            val manager = context.getSystemService(Context.NOTIFICATION_SERVICE) as NotificationManager
            manager.createNotificationChannel(channel)
        }
    }
    
    fun sendTemperatureAlert(loadId: String, temperature: String, status: String) {
        val title = "تنبيه درجة الحرارة"
        val message = "الشحنة $loadId: درجة الحرارة $temperature ($status)"
        
        val intent = Intent(context, MainActivity::class.java).apply {
            flags = Intent.FLAG_ACTIVITY_NEW_TASK or Intent.FLAG_ACTIVITY_CLEAR_TASK
            putExtra("notification_type", TYPE_TEMPERATURE_ALERT)
            putExtra("load_id", loadId)
        }
        
        sendNotification(
            id = loadId.hashCode(),
            title = title,
            message = message,
            intent = intent,
            priority = NotificationCompat.PRIORITY_HIGH,
            category = NotificationCompat.CATEGORY_ALARM
        )
    }
    
    fun sendLoadAssigned(loadId: String, driverName: String) {
        val title = "شحنة جديدة مخصصة"
        val message = "تم تخصيص الشحنة $loadId للسائق $driverName"
        
        val intent = Intent(context, MainActivity::class.java).apply {
            flags = Intent.FLAG_ACTIVITY_NEW_TASK or Intent.FLAG_ACTIVITY_CLEAR_TASK
            putExtra("notification_type", TYPE_LOAD_ASSIGNED)
            putExtra("load_id", loadId)
        }
        
        sendNotification(
            id = loadId.hashCode(),
            title = title,
            message = message,
            intent = intent,
            priority = NotificationCompat.PRIORITY_DEFAULT
        )
    }
    
    fun sendTripCompleted(loadId: String, driverName: String) {
        val title = "تم إنجاز الرحلة"
        val message = "أكمل السائق $driverName الرحلة $loadId بنجاح"
        
        val intent = Intent(context, MainActivity::class.java).apply {
            flags = Intent.FLAG_ACTIVITY_NEW_TASK or Intent.FLAG_ACTIVITY_CLEAR_TASK
            putExtra("notification_type", TYPE_TRIP_COMPLETED)
            putExtra("load_id", loadId)
        }
        
        sendNotification(
            id = loadId.hashCode(),
            title = title,
            message = message,
            intent = intent,
            priority = NotificationCompat.PRIORITY_DEFAULT
        )
    }
    
    fun sendMaintenanceDue(vehicleId: String, vehicleName: String, nextService: String) {
        val title = "صيانة مستحقة"
        val message = "المركبة $vehicleName تحتاج للصيانة في $nextService"
        
        val intent = Intent(context, MainActivity::class.java).apply {
            flags = Intent.FLAG_ACTIVITY_NEW_TASK or Intent.FLAG_ACTIVITY_CLEAR_TASK
            putExtra("notification_type", TYPE_MAINTENANCE_DUE)
            putExtra("vehicle_id", vehicleId)
        }
        
        sendNotification(
            id = vehicleId.hashCode(),
            title = title,
            message = message,
            intent = intent,
            priority = NotificationCompat.PRIORITY_DEFAULT
        )
    }
    
    fun sendInvoiceOverdue(invoiceId: String, clientName: String, daysOverdue: Int) {
        val title = "فاتورة متأخرة"
        val message = "فاتورة $invoiceId للعميل $clientName متأخرة $daysOverdue أيام"
        
        val intent = Intent(context, MainActivity::class.java).apply {
            flags = Intent.FLAG_ACTIVITY_NEW_TASK or Intent.FLAG_ACTIVITY_CLEAR_TASK
            putExtra("notification_type", TYPE_INVOICE_OVERDUE)
            putExtra("invoice_id", invoiceId)
        }
        
        sendNotification(
            id = invoiceId.hashCode(),
            title = title,
            message = message,
            intent = intent,
            priority = NotificationCompat.PRIORITY_HIGH
        )
    }
    
    fun sendEmergencyAlert(message: String, location: String? = null) {
        val title = "تنبيه طارئ"
        val fullMessage = if (location != null) {
            "$message - الموقع: $location"
        } else {
            message
        }
        
        val intent = Intent(context, MainActivity::class.java).apply {
            flags = Intent.FLAG_ACTIVITY_NEW_TASK or Intent.FLAG_ACTIVITY_CLEAR_TASK
            putExtra("notification_type", TYPE_EMERGENCY)
            putExtra("emergency_message", message)
            putExtra("location", location)
        }
        
        sendNotification(
            id = System.currentTimeMillis().toInt(),
            title = title,
            message = fullMessage,
            intent = intent,
            priority = NotificationCompat.PRIORITY_MAX,
            category = NotificationCompat.CATEGORY_ALARM,
            autoCancel = false
        )
    }
    
    fun sendSystemUpdate(updateMessage: String) {
        val title = "تحديث النظام"
        val message = updateMessage
        
        val intent = Intent(context, MainActivity::class.java).apply {
            flags = Intent.FLAG_ACTIVITY_NEW_TASK or Intent.FLAG_ACTIVITY_CLEAR_TASK
            putExtra("notification_type", TYPE_SYSTEM_UPDATE)
        }
        
        sendNotification(
            id = System.currentTimeMillis().toInt(),
            title = title,
            message = message,
            intent = intent,
            priority = NotificationCompat.PRIORITY_DEFAULT
        )
    }
    
    private fun sendNotification(
        id: Int,
        title: String,
        message: String,
        intent: Intent,
        priority: Int = NotificationCompat.PRIORITY_DEFAULT,
        category: String? = null,
        autoCancel: Boolean = true
    ) {
        val pendingIntent = PendingIntent.getActivity(
            context,
            id,
            intent,
            if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.M) {
                PendingIntent.FLAG_UPDATE_CURRENT or PendingIntent.FLAG_IMMUTABLE
            } else {
                PendingIntent.FLAG_UPDATE_CURRENT
            }
        )
        
        val notificationBuilder = NotificationCompat.Builder(context, CHANNEL_ID)
            .setSmallIcon(R.drawable.ic_logo_white)
            .setContentTitle(title)
            .setContentText(message)
            .setPriority(priority)
            .setContentIntent(pendingIntent)
            .setAutoCancel(autoCancel)
            .setStyle(NotificationCompat.BigTextStyle().bigText(message))
        
        category?.let { notificationBuilder.setCategory(it) }
        
        try {
            notificationManager.notify(id, notificationBuilder.build())
        } catch (e: SecurityException) {
            // Handle permission denied
        }
    }
    
    fun cancelNotification(id: Int) {
        notificationManager.cancel(id)
    }
    
    fun cancelAllNotifications() {
        notificationManager.cancelAll()
    }
    
    // Smart notification scheduling
    fun scheduleSmartNotifications() {
        scope.launch {
            while (isActive) {
                try {
                    // Check for temperature alerts
                    checkTemperatureAlerts()
                    
                    // Check for maintenance due
                    checkMaintenanceDue()
                    
                    // Check for overdue invoices
                    checkOverdueInvoices()
                    
                    // Wait for 5 minutes before next check
                    delay(5 * 60 * 1000L)
                } catch (e: Exception) {
                    // Handle errors
                    delay(60 * 1000L) // Wait 1 minute on error
                }
            }
        }
    }
    
    private suspend fun checkTemperatureAlerts() {
        MockData.loads.forEach { load ->
            if (load.temperature != null && load.status == "In Transit") {
                val temp = load.temperature.replace("°C", "").replace("-", "").toFloatOrNull()
                if (temp != null && temp > 15) { // Alert if temperature is too high
                    withContext(Dispatchers.Main) {
                        sendTemperatureAlert(load.id, load.temperature, "Warning")
                    }
                }
            }
        }
    }
    
    private suspend fun checkMaintenanceDue() {
        MockData.maintenanceRecords.forEach { record ->
            if (record.status == "Scheduled") {
                // Check if maintenance is due within 3 days
                val nextServiceDate = record.nextService
                // In real app, parse date and check if within 3 days
                withContext(Dispatchers.Main) {
                    sendMaintenanceDue(record.vehicleId, record.vehicleName, nextServiceDate)
                }
            }
        }
    }
    
    private suspend fun checkOverdueInvoices() {
        MockData.invoices.forEach { invoice ->
            if (invoice.status == "Overdue") {
                withContext(Dispatchers.Main) {
                    sendInvoiceOverdue(invoice.id, invoice.clientName, 5)
                }
            }
        }
    }
    
    fun stopSmartNotifications() {
        scope.cancel()
    }
}
