package com.edham.logistics.feature.customer

import android.os.Bundle
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import androidx.fragment.app.Fragment
import androidx.lifecycle.Observer
import androidx.recyclerview.widget.LinearLayoutManager
import com.edham.logistics.R
import com.edham.logistics.databinding.FragmentCustomerDashboardBinding
import com.edham.logistics.feature.customer.adapters.ActiveShipmentAdapter
import com.edham.logistics.feature.customer.adapters.NotificationAdapter
import com.edham.logistics.utils.VoiceAlertManager
import timber.log.Timber
import java.text.SimpleDateFormat
import java.util.*

class CustomerDashboardFragment : Fragment() {
    
    private var _binding: FragmentCustomerDashboardBinding? = null
    private val binding get() = _binding!!
    
    private lateinit var customerService: CustomerExperienceService
    private lateinit var voiceAlertManager: VoiceAlertManager
    private lateinit var activeShipmentAdapter: ActiveShipmentAdapter
    private lateinit var notificationAdapter: NotificationAdapter
    
    private val dateFormat = SimpleDateFormat("MMM dd, yyyy", Locale.getDefault())
    private val timeFormat = SimpleDateFormat("HH:mm", Locale.getDefault())
    
    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View {
        _binding = FragmentCustomerDashboardBinding.inflate(inflater, container, false)
        return binding.root
    }
    
    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        
        // Initialize services
        customerService = CustomerExperienceService(
            requireContext(),
            // api instance,
            // database instance
        )
        
        voiceAlertManager = VoiceAlertManager(requireContext())
        
        setupUI()
        setupRecyclerViews()
        setupClickListeners()
        setupObservers()
        
        // Initialize customer experience
        initializeCustomerExperience()
    }
    
    private fun setupUI() {
        // Large touch targets for one-hand usage
        binding.btnTrackShipment.minimumHeight = 72.dp
        binding.btnTrackShipment.minimumWidth = 120.dp
        
        binding.btnNewShipment.minimumHeight = 72.dp
        binding.btnNewShipment.minimumWidth = 120.dp
        
        binding.btnViewHistory.minimumHeight = 72.dp
        binding.btnViewHistory.minimumWidth = 120.dp
        
        binding.btnSupport.minimumHeight = 72.dp
        binding.btnSupport.minimumWidth = 120.dp
        
        // Clean minimal design
        binding.cardActiveShipments.setCardBackgroundColor(
            requireContext().getColor(R.color.customer_surface)
        )
        
        binding.cardNotifications.setCardBackgroundColor(
            requireContext().getColor(R.color.customer_surface)
        )
        
        binding.cardQuickActions.setCardBackgroundColor(
            requireContext().getColor(R.color.customer_surface)
        )
        
        // High visibility status colors
        updateUIStatus()
    }
    
    private fun setupRecyclerViews() {
        // Setup active shipments RecyclerView
        activeShipmentAdapter = ActiveShipmentAdapter { shipment ->
            onShipmentClicked(shipment)
        }
        
        binding.recyclerViewActiveShipments.apply {
            layoutManager = LinearLayoutManager(requireContext())
            adapter = activeShipmentAdapter
        }
        
        // Setup notifications RecyclerView
        notificationAdapter = NotificationAdapter { notification ->
            onNotificationClicked(notification)
        }
        
        binding.recyclerViewNotifications.apply {
            layoutManager = LinearLayoutManager(requireContext())
            adapter = notificationAdapter
        }
    }
    
    private fun setupClickListeners() {
        binding.btnTrackShipment.setOnClickListener {
            openTrackingScreen()
        }
        
        binding.btnNewShipment.setOnClickListener {
            openNewShipmentScreen()
        }
        
        binding.btnViewHistory.setOnClickListener {
            openHistoryScreen()
        }
        
        binding.btnSupport.setOnClickListener {
            openSupportScreen()
        }
        
        binding.etTrackingNumber.setOnEditorActionListener { _, actionId, _ ->
            if (actionId == android.view.inputmethod.EditorInfo.IME_ACTION_SEARCH) {
                trackShipment()
                true
            } else {
                false
            }
        }
        
        binding.btnSearchTracking.setOnClickListener {
            trackShipment()
        }
        
        binding.btnViewAllShipments.setOnClickListener {
            viewAllShipments()
        }
        
        binding.btnViewAllNotifications.setOnClickListener {
            viewAllNotifications()
        }
        
        binding.btnViewInvoices.setOnClickListener {
            openInvoicesScreen()
        }
        
        binding.btnViewReviews.setOnClickListener {
            openReviewsScreen()
        }
    }
    
    private fun setupObservers() {
        // Observe active shipments
        customerService.activeShipments.observe(viewLifecycleOwner, Observer { shipments ->
            updateActiveShipmentsUI(shipments)
        })
        
        // Observe notifications
        customerService.notifications.observe(viewLifecycleOwner, Observer { notifications ->
            updateNotificationsUI(notifications)
        })
        
        // Observe tracking data
        customerService.trackingData.observe(viewLifecycleOwner, Observer { trackingData ->
            updateTrackingUI(trackingData)
        })
    }
    
    private fun initializeCustomerExperience() {
        voiceAlertManager.speak("Welcome to Edham Logistics")
        
        // Initialize customer experience service
        binding.root.post {
            customerService.initializeCustomerExperience("customer_123") // Placeholder
        }
    }
    
    private fun updateUIStatus() {
        // Update connection status
        binding.viewConnectionStatus.setBackgroundColor(
            requireContext().getColor(R.color.status_active)
        )
        binding.tvConnectionStatus.text = "Connected"
        
        // Update last sync time
        binding.tvLastSync.text = timeFormat.format(Date())
    }
    
    private fun updateActiveShipmentsUI(shipments: List<com.edham.logistics.data.local.entity.Shipment>) {
        // Update shipment count
        binding.tvActiveShipmentsCount.text = shipments.size.toString()
        
        // Update RecyclerView
        activeShipmentAdapter.updateShipments(shipments.take(3)) // Show only 3 most recent
        
        // Update empty state
        if (shipments.isEmpty()) {
            binding.recyclerViewActiveShipments.visibility = View.GONE
            binding.tvNoActiveShipments.visibility = View.VISIBLE
        } else {
            binding.recyclerViewActiveShipments.visibility = View.VISIBLE
            binding.tvNoActiveShipments.visibility = View.GONE
        }
        
        // Update quick actions visibility
        binding.btnTrackShipment.visibility = if (shipments.isNotEmpty()) View.VISIBLE else View.GONE
    }
    
    private fun updateNotificationsUI(notifications: List<CustomerNotification>) {
        // Unread count
        val unreadCount = notifications.count { !it.isRead }
        binding.tvUnreadCount.text = unreadCount.toString()
        
        // Update RecyclerView
        notificationAdapter.updateNotifications(notifications.take(5)) // Show only 5 most recent
        
        // Update empty state
        if (notifications.isEmpty()) {
            binding.recyclerViewNotifications.visibility = View.GONE
            binding.tvNoNotifications.visibility = View.VISIBLE
        } else {
            binding.recyclerViewNotifications.visibility = View.VISIBLE
            binding.tvNoNotifications.visibility = View.GONE
        }
        
        // Update notification badge
        if (unreadCount > 0) {
            binding.viewNotificationBadge.visibility = View.VISIBLE
            binding.tvNotificationBadge.text = unreadCount.toString()
        } else {
            binding.viewNotificationBadge.visibility = View.GONE
        }
    }
    
    private fun updateTrackingUI(trackingData: Map<String, TrackingData>) {
        // Update tracking status for active shipments
        trackingData.forEach { (shipmentId, data) ->
            when (data.status) {
                "in_transit" -> updateShipmentStatus(shipmentId, "In Transit")
                "out_for_delivery" -> updateShipmentStatus(shipmentId, "Out for Delivery")
                "delivered" -> updateShipmentStatus(shipmentId, "Delivered")
                "delayed" -> updateShipmentStatus(shipmentId, "Delayed")
            }
        }
    }
    
    private fun updateShipmentStatus(shipmentId: String, status: String) {
        // Update UI for specific shipment
        // Implementation would update the specific shipment item in the adapter
        Timber.d("Shipment $shipmentId status updated to: $status")
    }
    
    private fun onShipmentClicked(shipment: com.edham.logistics.data.local.entity.Shipment) {
        voiceAlertManager.speak("Opening shipment tracking")
        
        // Navigate to shipment tracking screen
        val trackingFragment = ShipmentTrackingFragment.newInstance(shipment.id)
        parentFragmentManager.beginTransaction()
            .replace(R.id.fragment_container, trackingFragment)
            .addToBackStack(null)
            .commit()
    }
    
    private fun onNotificationClicked(notification: CustomerNotification) {
        voiceAlertManager.speak("Opening notification")
        
        // Mark as read
        markNotificationAsRead(notification.id)
        
        // Navigate based on notification type
        when (notification.type) {
            NotificationType.SHIPMENT_CREATED,
            NotificationType.SHIPMENT_PICKED_UP,
            NotificationType.SHIPMENT_IN_TRANSIT,
            NotificationType.SHIPMENT_OUT_FOR_DELIVERY,
            NotificationType.SHIPMENT_DELIVERED,
            NotificationType.DELAY_ALERT,
            NotificationType.ETA_UPDATE -> {
                if (notification.shipmentId != null) {
                    val trackingFragment = ShipmentTrackingFragment.newInstance(notification.shipmentId)
                    parentFragmentManager.beginTransaction()
                        .replace(R.id.fragment_container, trackingFragment)
                        .addToBackStack(null)
                        .commit()
                }
            }
            NotificationType.PAYMENT_DUE,
            NotificationType.PAYMENT_RECEIVED -> {
                openInvoicesScreen()
            }
            NotificationType.REVIEW_REQUEST -> {
                openReviewsScreen()
            }
            else -> {
                // Show notification details
                showNotificationDetails(notification)
            }
        }
    }
    
    private fun openTrackingScreen() {
        voiceAlertManager.speak("Opening shipment tracking")
        
        val trackingFragment = ShipmentTrackingFragment()
        parentFragmentManager.beginTransaction()
            .replace(R.id.fragment_container, trackingFragment)
            .addToBackStack(null)
            .commit()
    }
    
    private fun openNewShipmentScreen() {
        voiceAlertManager.speak("Creating new shipment")
        
        val newShipmentFragment = NewShipmentFragment()
        parentFragmentManager.beginTransaction()
            .replace(R.id.fragment_container, newShipmentFragment)
            .addToBackStack(null)
            .commit()
    }
    
    private fun openHistoryScreen() {
        voiceAlertManager.speak("Opening shipment history")
        
        val historyFragment = ShipmentHistoryFragment()
        parentFragmentManager.beginTransaction()
            .replace(R.id.fragment_container, historyFragment)
            .addToBackStack(null)
            .commit()
    }
    
    private fun openSupportScreen() {
        voiceAlertManager.speak("Opening customer support")
        
        val supportFragment = CustomerSupportFragment()
        parentFragmentManager.beginTransaction()
            .replace(R.id.fragment_container, supportFragment)
            .addToBackStack(null)
            .commit()
    }
    
    private fun openInvoicesScreen() {
        voiceAlertManager.speak("Opening invoices")
        
        val invoicesFragment = InvoicesFragment()
        parentFragmentManager.beginTransaction()
            .replace(R.id.fragment_container, invoicesFragment)
            .addToBackStack(null)
            .commit()
    }
    
    private fun openReviewsScreen() {
        voiceAlertManager.speak("Opening reviews")
        
        val reviewsFragment = ReviewsFragment()
        parentFragmentManager.beginTransaction()
            .replace(R.id.fragment_container, reviewsFragment)
            .addToBackStack(null)
            .commit()
    }
    
    private fun trackShipment() {
        val trackingNumber = binding.etTrackingNumber.text.toString().trim()
        
        if (trackingNumber.isBlank()) {
            binding.etTrackingNumber.error = "Enter tracking number"
            return
        }
        
        voiceAlertManager.speak("Tracking shipment")
        
        // Navigate to tracking screen with tracking number
        val trackingFragment = ShipmentTrackingFragment.newInstance(trackingNumber)
        parentFragmentManager.beginTransaction()
            .replace(R.id.fragment_container, trackingFragment)
            .addToBackStack(null)
            .commit()
        
        // Clear input
        binding.etTrackingNumber.text.clear()
    }
    
    private fun viewAllShipments() {
        voiceAlertManager.speak("Viewing all shipments")
        
        val allShipmentsFragment = AllShipmentsFragment()
        parentFragmentManager.beginTransaction()
            .replace(R.id.fragment_container, allShipmentsFragment)
            .addToBackStack(null)
            .commit()
    }
    
    private fun viewAllNotifications() {
        voiceAlertManager.speak("Viewing all notifications")
        
        val allNotificationsFragment = AllNotificationsFragment()
        parentFragmentManager.beginTransaction()
            .replace(R.id.fragment_container, allNotificationsFragment)
            .addToBackStack(null)
            .commit()
    }
    
    private fun markNotificationAsRead(notificationId: String) {
        // Mark notification as read in service
        // Implementation would call service method
        Timber.d("Marking notification as read: $notificationId")
    }
    
    private fun showNotificationDetails(notification: CustomerNotification) {
        val details = """
            Notification Details
            ===================
            Title: ${notification.title}
            Message: ${notification.message}
            Type: ${notification.type.name}
            Date: ${dateFormat.format(Date(notification.timestamp))}
        """.trimIndent()
        
        // Show details in dialog or toast
        Toast.makeText(requireContext(), details, Toast.LENGTH_LONG).show()
    }
    
    override fun onResume() {
        super.onResume()
        
        // Refresh data when fragment resumes
        customerService.initializeCustomerExperience("customer_123")
        updateUIStatus()
    }
    
    override fun onPause() {
        super.onPause()
        
        // Save current state
        // Implementation would save current filter and search state
    }
    
    override fun onDestroyView() {
        super.onDestroyView()
        
        // Cleanup resources
        customerService.cleanup()
        voiceAlertManager.cleanup()
        _binding = null
    }
    
    // Extension for dp to pixels
    private val Int.dp: Int
        get() = (this * resources.displayMetrics.density).toInt()
}
