package com.edham.logistics.ui.tasks

import android.os.Bundle
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.TextView
import androidx.fragment.app.Fragment
import androidx.recyclerview.widget.LinearLayoutManager
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.adapters.TaskManagementAdapter
import com.edham.logistics.domain.model.Task

class TasksFragment : Fragment() {

    private lateinit var rvTasks: RecyclerView
    private lateinit var tvTotalTasks: TextView
    private lateinit var tvPendingTasks: TextView
    private lateinit var tvCompletedTasks: TextView
    private lateinit var taskAdapter: TaskManagementAdapter

    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View? {
        return inflater.inflate(R.layout.fragment_tasks, container, false)
    }

    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        
        initViews(view)
        setupRecyclerView()
        loadTaskData()
    }

    private fun initViews(view: View) {
        rvTasks = view.findViewById(R.id.rvTasks)
        tvTotalTasks = view.findViewById(R.id.tvTotalTasks)
        tvPendingTasks = view.findViewById(R.id.tvPendingTasks)
        tvCompletedTasks = view.findViewById(R.id.tvCompletedTasks)
    }

    private fun setupRecyclerView() {
        taskAdapter = TaskManagementAdapter(getSampleTasks()) { task ->
            // Handle task click
            // TODO: Navigate to task details
        }
        
        rvTasks.apply {
            layoutManager = LinearLayoutManager(requireContext())
            adapter = taskAdapter
        }
    }

    private fun loadTaskData() {
        val tasks = getSampleTasks()
        val pendingCount = tasks.count { it.status == "معلق" || it.status == "قيد التنفيذ" }
        val completedCount = tasks.count { it.status == "مكتمل" }
        
        tvTotalTasks.text = tasks.size.toString()
        tvPendingTasks.text = pendingCount.toString()
        tvCompletedTasks.text = completedCount.toString()
        
        taskAdapter.updateTasks(tasks)
    }

    private fun getSampleTasks(): List<Task> {
        return listOf(
            Task("1", "توصيل شحنة #1234", "توصيل شحنة للعميل أحمد محمد", "قيد التنفيذ", "عالي", "أحمد محمد", "2024-05-12T14:00:00", "2024-05-12T08:00:00", "2024-05-12T08:00:00"),
            Task("2", "صيانة سيارة #5678", "صيانة دورية للسيارة", "معلق", "متوسط", "الورشة", "2024-05-12T16:00:00", "2024-05-12T09:00:00", "2024-05-12T09:00:00"),
            Task("3", "استلام بضاعة من الميناء", "استلام بضاعة من ميناء جدة", "مكتمل", "عالي", "محمد علي", "2024-05-12T10:00:00", "2024-05-12T07:00:00", "2024-05-12T07:00:00"),
            Task("4", "تسليم شحنة #1235", "تسليم شحنة للعميل عبدالله", "معلق", "عادي", "عبدالله سالم", "2024-05-12T18:00:00", "2024-05-12T10:00:00", "2024-05-12T10:00:00"),
            Task("5", "فحص دوري للأسطول", "فحص دوري لجميع السيارات", "قيد التنفيذ", "متوسط", "سالم خالد", "2024-05-12T15:30:00", "2024-05-12T11:00:00", "2024-05-12T11:00:00")
        )
    }
}
