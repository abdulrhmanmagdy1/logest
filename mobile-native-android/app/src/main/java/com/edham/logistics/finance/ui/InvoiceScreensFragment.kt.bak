    }
}

/**
 * Data classes for invoice screens
 */
data class InvoiceItem(
    val id: String,
    val invoiceNumber: String,
    val customerName: String,
    val amount: Float,
    val date: String,
    val status: InvoiceStatus,
    val dueDate: String
)

data class InvoiceDetail(
    val id: String,
    val invoiceNumber: String,
    val customer: CustomerInfo,
    val items: List<InvoiceItemDetail>,
    val totals: InvoiceTotals,
    val status: InvoiceStatus,
    val date: String,
    val dueDate: String,
    val notes: String
)

data class InvoiceItemDetail(
    val description: String,
    val quantity: Int,
    val unitPrice: Float,
    val total: Float
)

data class InvoiceTotals(
    val subtotal: Float,
    val tax: Float,
    val total: Float
)

data class CustomerInfo(
    val id: String,
    val name: String,
    val address: String,
    val email: String,
    val phone: String
)

data class InvoiceRequest(
    val customerId: String,
    val items: List<InvoiceItemRequest>,
    val notes: String,
    val dueDate: String
)

data class InvoiceItemRequest(
    val description: String,
    val quantity: Int,
    val unitPrice: Float,
    val total: Float
)

data class InvoiceFilters(
    val status: InvoiceStatus? = null,
    val customerId: String? = null,
    val dateFrom: String? = null,
    val dateTo: String? = null,
    val minAmount: Float? = null,
    val maxAmount: Float? = null
)

enum class InvoiceStatus {
    DRAFT,
    SENT,
    PARTIALLY_PAID,
    PAID,
    OVERDUE,
    CANCELLED
}
