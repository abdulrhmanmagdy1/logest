    @Composable
    private fun InvoiceActionsSection(
        invoice: InvoiceDetail,
        onEdit: () -> Unit,
        onGeneratePDF: () -> Unit,
        onSendInvoice: () -> Unit
    ) {
        Row(
            modifier = Modifier.fillMaxWidth(),
            horizontalArrangement = Arrangement.spacedBy(8.dp)
        ) {
            OutlinedButton(
                onClick = onEdit,
                modifier = Modifier.weight(1f)
            ) {
                Text("Edit")
            }
            
            Button(
                onClick = onGeneratePDF,
                modifier = Modifier.weight(1f)
            ) {
                Text("Generate PDF")
            }
            
            Button(
                onClick = onSendInvoice,
                modifier = Modifier.weight(1f)
            ) {
                Text("Send")
            }
        }
    }
    
    // Additional helper composables would go here...
    @Composable
    private fun CreateInvoiceHeader(
        title: String,
        subtitle: String,
        onCancel: () -> Unit
    ) {
        // Implementation for create invoice header
    }
    
    @Composable
    private fun EditInvoiceHeader(
        title: String,
        subtitle: String,
        onCancel: () -> Unit,
        onDelete: () -> Unit
    ) {
        // Implementation for edit invoice header
    }
    
    @Composable
    private fun CustomerSelectionSection(
        selectedCustomer: String,
        onCustomerSelected: (String) -> Unit
    ) {
        // Implementation for customer selection
    }
    
    @Composable
    private fun InvoiceItemsEditor(
        items: List<InvoiceItemRequest>,
        onItemsChanged: (List<InvoiceItemRequest>) -> Unit
    ) {
        // Implementation for invoice items editor
    }
    
    @Composable
    private fun InvoiceNotesSection(
        notes: String,
        onNotesChanged: (String) -> Unit
    ) {
        // Implementation for invoice notes
    }
    
    @Composable
    private fun CreateInvoiceActions(
        onSave: (InvoiceRequest) -> Unit,
        onSaveDraft: (InvoiceRequest) -> Unit,
        invoiceRequest: InvoiceRequest
    ) {
