package com.edham.logistics.finance.ui

import android.os.Bundle
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import androidx.compose.foundation.background
import androidx.compose.foundation.layout.*
import androidx.compose.foundation.lazy.LazyColumn
import androidx.compose.foundation.lazy.items
import androidx.compose.foundation.shape.RoundedCornerShape
import androidx.compose.foundation.text.KeyboardOptions
import androidx.compose.material.icons.Icons
import androidx.compose.material.icons.filled.*
import androidx.compose.material3.*
import androidx.compose.runtime.*
import androidx.compose.ui.Alignment
import androidx.compose.ui.Modifier
import androidx.compose.ui.draw.clip
import androidx.compose.ui.graphics.Color
import androidx.compose.ui.text.font.FontWeight
import androidx.compose.ui.text.input.KeyboardType
import androidx.compose.ui.text.style.TextAlign
import androidx.compose.ui.unit.dp
import androidx.compose.ui.unit.sp
import androidx.fragment.app.Fragment
import androidx.fragment.app.viewModels
import androidx.lifecycle.compose.collectAsStateWithLifecycle
import com.edham.logistics.finance.invoice.InvoiceService
import com.edham.logistics.ui.theme.EdhamLogisticsTheme
import dagger.hilt.android.AndroidEntryPoint
import javax.inject.Inject

/**
 * Invoice Screens Fragment - Comprehensive invoice management interface
 * 
 * Features:
 * - Invoice list and details
 * - Invoice creation and editing
 * - Invoice status tracking
 * - Payment status management
 * - PDF generation and sharing
 * - Invoice search and filtering
 * - Customer invoice history
 */
@AndroidEntryPoint
class InvoiceScreensFragment : Fragment() {
    
    @Inject
    lateinit var invoiceService: InvoiceService
    
    private val viewModel: InvoiceScreensViewModel by viewModels()
    
    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View {
        return ComposeView(requireContext()).apply {
            setContent {
                EdhamLogisticsTheme {
                    InvoiceScreensContent()
                }
            }
        }
    }
    
    @Composable
    private fun InvoiceScreensContent() {
        val uiState by viewModel.uiState.collectAsStateWithLifecycle()
        
        when (uiState) {
            is InvoiceScreensUiState.InvoiceList -> {
                InvoiceListScreen(
                    invoices = uiState.invoices,
                    onInvoiceClick = viewModel::selectInvoice,
                    onCreateInvoice = viewModel::navigateToCreateInvoice,
                    onSearch = viewModel::updateSearchQuery,
                    onFilter = viewModel::updateFilters
                )
            }
            
            is InvoiceScreensUiState.InvoiceDetails -> {
                InvoiceDetailsScreen(
                    invoice = uiState.invoice,
                    onBack = viewModel::navigateBack,
                    onEdit = viewModel::editInvoice,
                    onGeneratePDF = viewModel::generatePDF,
                    onSendInvoice = viewModel::sendInvoice,
                    onMarkPaid = viewModel::markAsPaid
                )
            }
            
            is InvoiceScreensUiState.CreateInvoice -> {
                CreateInvoiceScreen(
                    invoiceRequest = uiState.invoiceRequest,
                    onSave = viewModel::saveInvoice,
                    onCancel = viewModel::navigateBack,
                    onSaveDraft = viewModel::saveDraft
                )
            }
            
            is InvoiceScreensUiState.EditInvoice -> {
                EditInvoiceScreen(
                    invoice = uiState.invoice,
                    onUpdate = viewModel::updateInvoice,
                    onCancel = viewModel::navigateBack,
                    onDelete = viewModel::deleteInvoice
                )
            }
            
            is InvoiceScreensUiState.Loading -> {
                Box(
                    modifier = Modifier.fillMaxSize(),
                    contentAlignment = Alignment.Center
                ) {
                    CircularProgressIndicator(
                        modifier = Modifier.size(48.dp),
                        color = MaterialTheme.colorScheme.primary
                    )
                }
            }
            
            is InvoiceScreensUiState.Error -> {
                Box(
                    modifier = Modifier.fillMaxSize(),
                    contentAlignment = Alignment.Center
                ) {
                    Column(
                        horizontalAlignment = Alignment.CenterHorizontally,
                        verticalArrangement = Arrangement.spacedBy(16.dp)
                    ) {
                        Icon(
                            imageVector = Icons.Default.Error,
                            contentDescription = "Error",
                            modifier = Modifier.size(64.dp),
                            tint = MaterialTheme.colorScheme.error
                        )
                        
                        Text(
                            text = uiState.message,
                            style = MaterialTheme.typography.headlineSmall,
                            color = MaterialTheme.colorScheme.error,
                            textAlign = TextAlign.Center
                        )
                        
                        Button(
                            onClick = { viewModel.retry() }
                        ) {
                            Text("Retry")
                        }
                    }
                }
            }
        }
    }
    
    @Composable
    private fun InvoiceListScreen(
        invoices: List<InvoiceItem>,
        onInvoiceClick: (InvoiceItem) -> Unit,
        onCreateInvoice: () -> Unit,
        onSearch: (String) -> Unit,
        onFilter: (InvoiceFilters) -> Unit
    ) {
        Column(
            modifier = Modifier
                .fillMaxSize()
                .background(MaterialTheme.colorScheme.background)
                .padding(16.dp)
        ) {
            HeaderSection(
                title = "Invoices",
                subtitle = "Manage your invoices"
            )
            
            Spacer(modifier = Modifier.height(16.dp))
            
            SearchAndFilterSection(
                onSearch = onSearch,
                onFilter = onFilter
            )
            
            Spacer(modifier = Modifier.height(16.dp))
            
            InvoiceList(
                invoices = invoices,
                onInvoiceClick = onInvoiceClick
            )
            
            Spacer(modifier = Modifier.height(16.dp))
            
            FloatingActionButton(
                onClick = onCreateInvoice,
                modifier = Modifier.align(Alignment.End)
            ) {
                Icon(
                    imageVector = Icons.Default.Add,
                    contentDescription = "Create Invoice"
                )
            }
        }
    }
    
    @Composable
    private fun InvoiceDetailsScreen(
        invoice: InvoiceDetail,
        onBack: () -> Unit,
        onEdit: () -> Unit,
        onGeneratePDF: () -> Unit,
        onSendInvoice: () -> Unit,
        onMarkPaid: () -> Unit
    ) {
        LazyColumn(
            modifier = Modifier
                .fillMaxSize()
                .background(MaterialTheme.colorScheme.background)
                .padding(16.dp)
        ) {
            item {
                InvoiceHeader(
                    invoice = invoice,
                    onBack = onBack
                )
            }
            
            item {
                Spacer(modifier = Modifier.height(16.dp))
            }
            
            item {
                InvoiceStatusSection(
                    invoice = invoice,
                    onMarkPaid = onMarkPaid
                )
            }
            
            item {
                Spacer(modifier = Modifier.height(16.dp))
            }
            
            item {
                InvoiceCustomerSection(
                    customer = invoice.customer
                )
            }
            
            item {
                Spacer(modifier = Modifier.height(16.dp))
            }
            
            item {
                InvoiceItemsSection(
                    items = invoice.items
                )
            }
            
            item {
                Spacer(modifier = Modifier.height(16.dp))
            }
            
            item {
                InvoiceTotalsSection(
                    totals = invoice.totals
                )
            }
            
            item {
                Spacer(modifier = Modifier.height(16.dp))
            }
            
            item {
                InvoiceActionsSection(
                    invoice = invoice,
                    onEdit = onEdit,
                    onGeneratePDF = onGeneratePDF,
                    onSendInvoice = onSendInvoice
                )
            }
        }
    }
    
    @Composable
    private fun CreateInvoiceScreen(
        invoiceRequest: InvoiceRequest,
        onSave: (InvoiceRequest) -> Unit,
        onCancel: () -> Unit,
        onSaveDraft: (InvoiceRequest) -> Unit
    ) {
        LazyColumn(
            modifier = Modifier
                .fillMaxSize()
                .background(MaterialTheme.colorScheme.background)
                .padding(16.dp)
        ) {
            item {
                CreateInvoiceHeader(
                    title = "Create Invoice",
                    subtitle = "Fill in invoice details",
                    onCancel = onCancel
                )
            }
            
            item {
                Spacer(modifier = Modifier.height(16.dp))
            }
            
            item {
                CustomerSelectionSection(
                    selectedCustomer = invoiceRequest.customerId,
                    onCustomerSelected = { customerId ->
                        onSave(invoiceRequest.copy(customerId = customerId))
                    }
                )
            }
            
            item {
                Spacer(modifier = Modifier.height(16.dp))
            }
            
            item {
                InvoiceItemsEditor(
                    items = invoiceRequest.items,
                    onItemsChanged = { items ->
                        onSave(invoiceRequest.copy(items = items))
                    }
                )
            }
            
            item {
                Spacer(modifier = Modifier.height(16.dp))
            }
            
            item {
                InvoiceNotesSection(
                    notes = invoiceRequest.notes,
                    onNotesChanged = { notes ->
                        onSave(invoiceRequest.copy(notes = notes))
                    }
                )
            }
            
            item {
                Spacer(modifier = Modifier.height(16.dp))
            }
            
            item {
                CreateInvoiceActions(
                    onSave = onSave,
                    onSaveDraft = onSaveDraft,
                    invoiceRequest = invoiceRequest
                )
            }
        }
    }
    
    @Composable
    private fun EditInvoiceScreen(
        invoice: InvoiceDetail,
        onUpdate: (InvoiceDetail) -> Unit,
        onCancel: () -> Unit,
        onDelete: () -> Unit
    ) {
        LazyColumn(
            modifier = Modifier
                .fillMaxSize()
                .background(MaterialTheme.colorScheme.background)
                .padding(16.dp)
        ) {
            item {
                EditInvoiceHeader(
                    title = "Edit Invoice",
                    subtitle = "Update invoice details",
                    onCancel = onCancel,
                    onDelete = onDelete
                )
            }
            
            item {
                Spacer(modifier = Modifier.height(16.dp))
            }
            
            item {
                CustomerSelectionSection(
                    selectedCustomer = invoice.customer.id,
                    onCustomerSelected = { customerId ->
                        // Update customer in invoice
                    }
                )
            }
            
            item {
                Spacer(modifier = Modifier.height(16.dp))
            }
            
            item {
                InvoiceItemsEditor(
                    items = invoice.items.map { InvoiceItemRequest(
                        description = it.description,
                        quantity = it.quantity,
                        unitPrice = it.unitPrice,
                        total = it.total
                    ) },
                    onItemsChanged = { items ->
                        // Update items in invoice
                    }
                )
            }
            
            item {
                Spacer(modifier = Modifier.height(16.dp))
            }
            
            item {
                InvoiceNotesSection(
                    notes = invoice.notes,
                    onNotesChanged = { notes ->
                        onUpdate(invoice.copy(notes = notes))
                    }
                )
            }
            
            item {
                Spacer(modifier = Modifier.height(16.dp))
            }
            
            item {
                EditInvoiceActions(
                    onUpdate = onUpdate,
                    invoice = invoice
                )
            }
        }
    }
    
    @Composable
    private fun HeaderSection(
        title: String,
        subtitle: String
    ) {
        Column(
            modifier = Modifier.fillMaxWidth(),
            horizontalAlignment = Alignment.Start
        ) {
            Text(
                text = title,
                style = MaterialTheme.typography.headlineMedium.copy(
                    fontWeight = FontWeight.Bold
                ),
                color = MaterialTheme.colorScheme.onBackground
            )
            
            Spacer(modifier = Modifier.height(4.dp))
            
            Text(
                text = subtitle,
                style = MaterialTheme.typography.bodyMedium,
                color = MaterialTheme.colorScheme.onSurfaceVariant
            )
        }
    }
    
    @Composable
    private fun SearchAndFilterSection(
        onSearch: (String) -> Unit,
        onFilter: (InvoiceFilters) -> Unit
    ) {
        Row(
            modifier = Modifier.fillMaxWidth(),
            horizontalArrangement = Arrangement.spacedBy(8.dp)
        ) {
            OutlinedTextField(
                value = "",
                onValueChange = onSearch,
                modifier = Modifier.weight(1f),
                placeholder = {
                    Text("Search invoices...")
                },
                leadingIcon = {
                    Icon(
                        imageVector = Icons.Default.Search,
                        contentDescription = "Search"
                    )
                }
            )
            
            IconButton(
                onClick = { /* Show filter dialog */ }
            ) {
                Icon(
                    imageVector = Icons.Default.FilterList,
                    contentDescription = "Filter"
                )
            }
        }
    }
    
    @Composable
    private fun InvoiceList(
        invoices: List<InvoiceItem>,
        onInvoiceClick: (InvoiceItem) -> Unit
    ) {
        LazyColumn(
            verticalArrangement = Arrangement.spacedBy(8.dp)
        ) {
            items(invoices) { invoice ->
                InvoiceCard(
                    invoice = invoice,
                    onClick = { onInvoiceClick(invoice) }
                )
            }
        }
    }
    
    @Composable
    private fun InvoiceCard(
        invoice: InvoiceItem,
        onClick: () -> Unit
    ) {
        Card(
            modifier = Modifier.fillMaxWidth(),
            onClick = onClick,
            colors = CardDefaults.cardColors(
                containerColor = MaterialTheme.colorScheme.surface
            ),
            elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
        ) {
            Column(
                modifier = Modifier
                    .fillMaxWidth()
                    .padding(16.dp)
            ) {
                Row(
                    modifier = Modifier.fillMaxWidth(),
                    horizontalArrangement = Arrangement.SpaceBetween,
                    verticalAlignment = Alignment.CenterVertically
                ) {
                    Column(
                        modifier = Modifier.weight(1f)
                    ) {
                        Text(
                            text = "Invoice #${invoice.invoiceNumber}",
                            style = MaterialTheme.typography.bodyLarge.copy(
                                fontWeight = FontWeight.Bold
                            ),
                            color = MaterialTheme.colorScheme.onSurface
                        )
                        
                        Spacer(modifier = Modifier.height(4.dp))
                        
                        Text(
                            text = invoice.customerName,
                            style = MaterialTheme.typography.bodyMedium,
                            color = MaterialTheme.colorScheme.onSurfaceVariant
                        )
                        
                        Spacer(modifier = Modifier.height(4.dp))
                        
                        Text(
                            text = invoice.date,
                            style = MaterialTheme.typography.bodySmall,
                            color = MaterialTheme.colorScheme.onSurfaceVariant
                        )
                    }
                    
                    Column(
                        horizontalAlignment = Alignment.End
                    ) {
                        Text(
                            text = "SAR ${String.format("%.2f", invoice.amount)}",
                            style = MaterialTheme.typography.titleMedium.copy(
                                fontWeight = FontWeight.Bold
                            ),
                            color = MaterialTheme.colorScheme.primary
                        )
                        
                        Spacer(modifier = Modifier.height(4.dp))
                        
                        InvoiceStatusChip(status = invoice.status)
                    }
                }
            }
        }
    }
    
    @Composable
    private fun InvoiceStatusChip(status: InvoiceStatus) {
        val (color, backgroundColor) = when (status) {
            InvoiceStatus.DRAFT -> MaterialTheme.colorScheme.onSurface to MaterialTheme.colorScheme.surfaceVariant
            InvoiceStatus.SENT -> MaterialTheme.colorScheme.primary to MaterialTheme.colorScheme.primaryContainer
            InvoiceStatus.PARTIALLY_PAID -> MaterialTheme.colorScheme.tertiary to MaterialTheme.colorScheme.tertiaryContainer
            InvoiceStatus.PAID -> MaterialTheme.colorScheme.primary to MaterialTheme.colorScheme.primaryContainer
            InvoiceStatus.OVERDUE -> MaterialTheme.colorScheme.error to MaterialTheme.colorScheme.errorContainer
            InvoiceStatus.CANCELLED -> MaterialTheme.colorScheme.onSurface to MaterialTheme.colorScheme.surfaceVariant
        }
        
        Surface(
            modifier = Modifier.clip(RoundedCornerShape(12.dp)),
            color = backgroundColor
        ) {
            Text(
                text = status.name.replace("_", " "),
                modifier = Modifier.padding(horizontal = 8.dp, vertical = 4.dp),
                style = MaterialTheme.typography.bodySmall,
                color = color
            )
        }
    }
    
    // Additional composables for invoice details, creation, and editing
    // These would include more detailed UI components for each screen
    
    @Composable
    private fun InvoiceHeader(
        invoice: InvoiceDetail,
        onBack: () -> Unit
    ) {
        Row(
            modifier = Modifier.fillMaxWidth(),
            horizontalArrangement = Arrangement.SpaceBetween,
            verticalAlignment = Alignment.CenterVertically
        ) {
            IconButton(onClick = onBack) {
                Icon(
                    imageVector = Icons.Default.ArrowBack,
                    contentDescription = "Back"
                )
            }
            
            Text(
                text = "Invoice #${invoice.invoiceNumber}",
                style = MaterialTheme.typography.titleLarge.copy(
                    fontWeight = FontWeight.Bold
                ),
                color = MaterialTheme.colorScheme.onSurface
            )
            
            IconButton(
                onClick = { /* More options */ }
            ) {
                Icon(
                    imageVector = Icons.Default.MoreVert,
                    contentDescription = "More"
                )
            }
        }
    }
    
    @Composable
    private fun InvoiceStatusSection(
        invoice: InvoiceDetail,
        onMarkPaid: () -> Unit
    ) {
        Card(
            modifier = Modifier.fillMaxWidth(),
            colors = CardDefaults.cardColors(
                containerColor = when (invoice.status) {
                    InvoiceStatus.PAID -> MaterialTheme.colorScheme.primaryContainer
                    InvoiceStatus.OVERDUE -> MaterialTheme.colorScheme.errorContainer
                    else -> MaterialTheme.colorScheme.surfaceVariant
                }
            )
        ) {
            Row(
                modifier = Modifier
                    .fillMaxWidth()
                    .padding(16.dp),
                horizontalArrangement = Arrangement.SpaceBetween,
                verticalAlignment = Alignment.CenterVertically
            ) {
                Column {
                    Text(
                        text = "Status",
                        style = MaterialTheme.typography.bodySmall,
                        color = MaterialTheme.colorScheme.onSurfaceVariant
                    )
                    
                    Text(
                        text = invoice.status.name.replace("_", " "),
                        style = MaterialTheme.typography.titleMedium.copy(
                            fontWeight = FontWeight.Bold
                        ),
                        color = when (invoice.status) {
                            InvoiceStatus.PAID -> MaterialTheme.colorScheme.onPrimaryContainer
                            InvoiceStatus.OVERDUE -> MaterialTheme.colorScheme.onErrorContainer
                            else -> MaterialTheme.colorScheme.onSurfaceVariant
                        }
                    )
                }
                
                if (invoice.status == InvoiceStatus.SENT || invoice.status == InvoiceStatus.PARTIALLY_PAID) {
                    Button(
                        onClick = onMarkPaid
                    ) {
                        Text("Mark as Paid")
                    }
                }
            }
        }
    }
    
    @Composable
    private fun InvoiceCustomerSection(
        customer: CustomerInfo
    ) {
        Card(
            modifier = Modifier.fillMaxWidth(),
            colors = CardDefaults.cardColors(
                containerColor = MaterialTheme.colorScheme.surface
            )
        ) {
            Column(
                modifier = Modifier
                    .fillMaxWidth()
                    .padding(16.dp)
            ) {
                Text(
                    text = "Bill To",
                    style = MaterialTheme.typography.titleMedium.copy(
                        fontWeight = FontWeight.Bold
                    ),
                    color = MaterialTheme.colorScheme.onSurface
                )
                
                Spacer(modifier = Modifier.height(12.dp))
                
                Text(
                    text = customer.name,
                    style = MaterialTheme.typography.bodyLarge,
                    color = MaterialTheme.colorScheme.onSurface
                )
                
                if (customer.address.isNotEmpty()) {
                    Text(
                        text = customer.address,
                        style = MaterialTheme.typography.bodyMedium,
                        color = MaterialTheme.colorScheme.onSurfaceVariant
                    )
                }
                
                if (customer.email.isNotEmpty()) {
                    Text(
                        text = customer.email,
                        style = MaterialTheme.typography.bodyMedium,
                        color = MaterialTheme.colorScheme.onSurfaceVariant
                    )
                }
                
                if (customer.phone.isNotEmpty()) {
                    Text(
                        text = customer.phone,
                        style = MaterialTheme.typography.bodyMedium,
                        color = MaterialTheme.colorScheme.onSurfaceVariant
                    )
                }
            }
        }
    }
    
    @Composable
    private fun InvoiceItemsSection(
        items: List<InvoiceItemDetail>
    ) {
        Card(
            modifier = Modifier.fillMaxWidth(),
            colors = CardDefaults.cardColors(
                containerColor = MaterialTheme.colorScheme.surface
            )
        ) {
            Column(
                modifier = Modifier
                    .fillMaxWidth()
                    .padding(16.dp)
            ) {
                Text(
                    text = "Items",
                    style = MaterialTheme.typography.titleMedium.copy(
                        fontWeight = FontWeight.Bold
                    ),
                    color = MaterialTheme.colorScheme.onSurface
                )
                
                Spacer(modifier = Modifier.height(12.dp))
                
                // Table header
                Row(
                    modifier = Modifier.fillMaxWidth(),
                    horizontalArrangement = Arrangement.SpaceBetween
                ) {
                    Text(
                        text = "Description",
                        modifier = Modifier.weight(2f),
                        style = MaterialTheme.typography.bodySmall.copy(
                            fontWeight = FontWeight.Bold
                        ),
                        color = MaterialTheme.colorScheme.onSurfaceVariant
                    )
                    
                    Text(
                        text = "Qty",
                        modifier = Modifier.weight(0.5f),
                        style = MaterialTheme.typography.bodySmall.copy(
                            fontWeight = FontWeight.Bold
                        ),
                        color = MaterialTheme.colorScheme.onSurfaceVariant
                    )
                    
                    Text(
                        text = "Price",
                        modifier = Modifier.weight(1f),
                        style = MaterialTheme.typography.bodySmall.copy(
                            fontWeight = FontWeight.Bold
                        ),
                        color = MaterialTheme.colorScheme.onSurfaceVariant
                    )
                    
                    Text(
                        text = "Total",
                        modifier = Modifier.weight(1f),
                        style = MaterialTheme.typography.bodySmall.copy(
                            fontWeight = FontWeight.Bold
                        ),
                        color = MaterialTheme.colorScheme.onSurfaceVariant
                    )
                }
                
                Spacer(modifier = Modifier.height(8.dp))
                
                Divider(color = MaterialTheme.colorScheme.surfaceVariant)
                
                Spacer(modifier = Modifier.height(8.dp))
                
                // Items
                items.forEach { item ->
                    Row(
                        modifier = Modifier
                            .fillMaxWidth()
                            .padding(vertical = 4.dp),
                        horizontalArrangement = Arrangement.SpaceBetween
                    ) {
                        Text(
                            text = item.description,
                            modifier = Modifier.weight(2f),
                            style = MaterialTheme.typography.bodyMedium,
                            color = MaterialTheme.colorScheme.onSurface
                        )
                        
                        Text(
                            text = item.quantity.toString(),
                            modifier = Modifier.weight(0.5f),
                            style = MaterialTheme.typography.bodyMedium,
                            color = MaterialTheme.colorScheme.onSurface
                        )
                        
                        Text(
                            text = "SAR ${String.format("%.2f", item.unitPrice)}",
                            modifier = Modifier.weight(1f),
                            style = MaterialTheme.typography.bodyMedium,
                            color = MaterialTheme.colorScheme.onSurface
                        )
                        
                        Text(
                            text = "SAR ${String.format("%.2f", item.total)}",
                            modifier = Modifier.weight(1f),
                            style = MaterialTheme.typography.bodyMedium.copy(
                                fontWeight = FontWeight.Bold
                            ),
                            color = MaterialTheme.colorScheme.onSurface
                        )
                    }
                }
            }
        }
    }
    
