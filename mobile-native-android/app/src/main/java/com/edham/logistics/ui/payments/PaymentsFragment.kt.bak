package com.edham.logistics.ui.payments

import android.os.Bundle
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.TextView
import androidx.fragment.app.Fragment
import androidx.recyclerview.widget.LinearLayoutManager
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.adapters.PaymentManagementAdapter
import com.edham.logistics.domain.model.Payment

class PaymentsFragment : Fragment() {

    private lateinit var rvPayments: RecyclerView
    private lateinit var tvTotalPayments: TextView
    private lateinit var tvPendingPayments: TextView
    private lateinit var tvCompletedPayments: TextView
    private lateinit var paymentAdapter: PaymentManagementAdapter

    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View? {
        return inflater.inflate(R.layout.fragment_payments, container, false)
    }

    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        
        initViews(view)
        setupRecyclerView()
        loadPaymentData()
    }

    private fun initViews(view: View) {
        rvPayments = view.findViewById(R.id.rvPayments)
        tvTotalPayments = view.findViewById(R.id.tvTotalPayments)
        tvPendingPayments = view.findViewById(R.id.tvPendingPayments)
        tvCompletedPayments = view.findViewById(R.id.tvCompletedPayments)
    }

    private fun setupRecyclerView() {
        paymentAdapter = PaymentManagementAdapter(getSamplePayments()) { payment ->
            // Handle payment click
            // TODO: Navigate to payment details
        }
        
        rvPayments.apply {
            layoutManager = LinearLayoutManager(requireContext())
            adapter = paymentAdapter
        }
    }

    private fun loadPaymentData() {
        val payments = getSamplePayments()
        val pendingCount = payments.count { it.status == "معلق" || it.status == "قيد المراجعة" }
        val completedCount = payments.count { it.status == "مكتمل" || it.status == "مدفوع" }
        val totalAmount = payments.filter { it.status == "مكتمل" || it.status == "مدفوع" }.sumOf { it.amount }
        
        tvTotalPayments.text = payments.size.toString()
        tvPendingPayments.text = pendingCount.toString()
        tvCompletedPayments.text = String.format("%.2f ريال", totalAmount)
        
        paymentAdapter.updatePayments(payments)
    }

    private fun getSamplePayments(): List<Payment> {
        return listOf(
            Payment("1", "EDH123456", 150.0, "SAR", "بطاقة ائتمان", "completed", null, "2024-05-12T14:30:00", "2024-05-12T14:30:00", "2024-05-12T14:30:00"),
            Payment("2", "EDH123457", 85.50, "SAR", "تحويل بنكي", "pending", null, "2024-05-12T13:45:00", "2024-05-12T13:45:00", "2024-05-12T13:45:00"),
            Payment("3", "EDH123458", 220.0, "SAR", "محفظة إلكترونية", "pending", null, "2024-05-12T12:15:00", "2024-05-12T12:15:00", "2024-05-12T12:15:00"),
            Payment("4", "EDH123459", 95.25, "SAR", "نقدي", "completed", null, "2024-05-12T11:30:00", "2024-05-12T11:30:00", "2024-05-12T11:30:00"),
            Payment("5", "EDH123460", 175.75, "SAR", "بطاقة ائتمان", "completed", null, "2024-05-12T10:20:00", "2024-05-12T10:20:00", "2024-05-12T10:20:00")
        )
    }
}
