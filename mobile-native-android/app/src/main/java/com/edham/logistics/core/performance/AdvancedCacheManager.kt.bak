package com.edham.logistics.core.performance

import android.content.Context
import kotlinx.coroutines.*
import kotlinx.coroutines.flow.*
import java.util.concurrent.*
import java.util.concurrent.atomic.AtomicLong
import javax.inject.Inject
import javax.inject.Singleton

/**
 * Advanced Cache Manager - Multi-tier caching with LRU, memory, disk caching and intelligent eviction
 */
@Singleton
class AdvancedCacheManager @Inject constructor(
    private val context: Context
) {

    private val coroutineScope = CoroutineScope(SupervisorJob() + Dispatchers.IO)
    private var config: CacheConfig = CacheConfig()
    
    // Memory cache
    private val memoryCache = ConcurrentHashMap<String, CacheEntry>()
    private val memoryMaxSize = AtomicLong(50 * 1024 * 1024) // 50MB default
    private val memoryCurrentSize = AtomicLong(0)
    
    // Disk cache
    private lateinit var diskCache: DiskLruCache
    
    // Cache statistics
    private val hits = AtomicLong(0)
    private val misses = AtomicLong(0)
    private val puts = AtomicLong(0)
    private val evictions = AtomicLong(0)
    
    // Cleanup scheduler
    private val cleanupScheduler = ScheduledThreadPoolExecutor(1)
    
    init {
        initializeDiskCache()
        startCleanupScheduler()
    }

    /**
     * Configure the cache manager
     */
    fun configure(config: CacheConfig) {
        this.config = config
        this.memoryMaxSize.set(config.maxSize)
        
        // Reinitialize disk cache if needed
        if (config.maxSize > 0) {
            initializeDiskCache()
        }
    }

    /**
     * Get value from cache
     */
    fun <T> get(key: String): T? {
        val startTime = System.currentTimeMillis()
        
        try {
            // Try memory cache first
            val memoryEntry = memoryCache[key]
            if (memoryEntry != null && !memoryEntry.isExpired()) {
                hits.incrementAndGet()
                return memoryEntry.value as T
            }
            
            // Try disk cache
            if (config.maxSize > 0) {
                val diskEntry = diskCache.get(key)
                if (diskEntry != null) {
                    val value = deserializeValue<T>(diskEntry.data)
                    
                    // Promote to memory cache
                    putInMemory(key, value, diskEntry.ttl)
                    hits.incrementAndGet()
                    return value
                }
            }
            
            misses.incrementAndGet()
            return null
        } catch (e: Exception) {
            // Log error and return null
            return null
        }
    }

    /**
     * Put value in cache
     */
    fun <T> put(key: String, value: T, cachePolicy: CachePolicy = CachePolicy.DEFAULT) {
        try {
            val ttl = calculateTTL(cachePolicy)
            val serializedValue = serializeValue(value)
            val entrySize = calculateSize(serializedValue)
            
            // Put in memory cache
            putInMemory(key, value, ttl)
            
            // Put in disk cache if size is appropriate
            if (config.maxSize > 0 && shouldCacheInDisk(entrySize, cachePolicy)) {
                putInDisk(key, serializedValue, ttl)
            }
            
            puts.incrementAndGet()
        } catch (e: Exception) {
            // Log error but don't fail
        }
    }

    /**
     * Remove value from cache
     */
    fun remove(key: String) {
        memoryCache.remove(key)
        if (config.maxSize > 0) {
            diskCache.remove(key)
        }
    }

    /**
     * Clear all cache
     */
    fun clear() {
        memoryCache.clear()
        memoryCurrentSize.set(0)
        if (config.maxSize > 0) {
            diskCache.delete()
        }
    }

    /**
     * Get cache statistics
     */
    fun getStatistics(): CacheStatistics {
        val totalRequests = hits.get() + misses.get()
        return CacheStatistics(
            hits = hits.get(),
            misses = misses.get(),
            puts = puts.get(),
            evictions = evictions.get(),
            hitRate = if (totalRequests > 0) hits.get().toFloat() / totalRequests else 0f,
            memorySize = memoryCurrentSize.get(),
            memoryMaxSize = memoryMaxSize.get(),
            memoryEntries = memoryCache.size,
            diskSize = if (config.maxSize > 0) diskCache.size() else 0,
            diskEntries = if (config.maxSize > 0) diskCache.getEntryCount() else 0
        )
    }

    /**
     * Preload data into cache
     */
    suspend fun preload(
        items: List<CacheItem>,
        batchSize: Int = 10,
        delayBetweenBatches: Long = 100
    ) {
        items.chunked(batchSize).forEachIndexed { index, batch ->
            batch.forEach { item ->
                put(item.key, item.value, item.policy)
            }
            
            if (index < items.size / batchSize - 1) {
                delay(delayBetweenBatches)
            }
        }
    }

    /**
     * Warm up cache with frequently accessed data
     */
    suspend fun warmUp(warmUpTasks: List<WarmUpTask>) {
        warmUpTasks.forEach { task ->
            try {
                val value = task.loader()
                put(task.key, value, CachePolicy.AGGRESSIVE)
            } catch (e: Exception) {
                // Log error but continue with other tasks
            }
        }
    }

    /**
     * Cleanup expired entries
     */
    fun cleanup() {
        val currentTime = System.currentTimeMillis()
        
        // Cleanup memory cache
        val expiredMemoryEntries = memoryCache.filter { (_, entry) ->
            entry.isExpired(currentTime)
        }
        
        expiredMemoryEntries.forEach { (key, _) ->
            memoryCache.remove(key)
        }
        
        // Cleanup disk cache
        if (config.maxSize > 0) {
            diskCache.cleanupExpired()
        }
    }

    /**
     * Optimize cache based on usage patterns
     */
    fun optimize() {
        val stats = getStatistics()
        
        // Adjust cache size based on hit rate
        if (stats.hitRate < 0.5 && memoryCurrentSize.get() > memoryMaxSize.get() * 0.8) {
            // Low hit rate and high memory usage - reduce cache size
            evictLeastRecentlyUsed(memoryMaxSize.get() / 2)
        } else if (stats.hitRate > 0.8 && memoryCurrentSize.get() < memoryMaxSize.get() * 0.5) {
            // High hit rate and low memory usage - can potentially increase cache size
            // This would require reconfiguring the cache
        }
    }

    /**
     * Export cache data
     */
    suspend fun export(): List<CacheExportItem> {
        val exportItems = mutableListOf<CacheExportItem>()
        
        memoryCache.forEach { (key, entry) ->
            exportItems.add(
                CacheExportItem(
                    key = key,
                    value = entry.value,
                    timestamp = entry.timestamp,
                    ttl = entry.ttl,
                    location = CacheLocation.MEMORY
                )
            )
        }
        
        if (config.maxSize > 0) {
            diskCache.getAll().forEach { (key, snapshot) ->
                exportItems.add(
                    CacheExportItem(
                        key = key,
                        value = deserializeValue<Any>(snapshot.data),
                        timestamp = snapshot.timestamp,
                        ttl = snapshot.ttl,
                        location = CacheLocation.DISK
                    )
                )
            }
        }
        
        return exportItems
    }

    /**
     * Import cache data
     */
    suspend fun import(items: List<CacheExportItem>) {
        items.forEach { item ->
            put(item.key, item.value, CachePolicy.DEFAULT)
        }
    }

    /**
     * Cleanup resources
     */
    fun cleanupResources() {
        coroutineScope.cancel()
        cleanupScheduler.shutdown()
        clear()
        if (config.maxSize > 0) {
            diskCache.close()
        }
    }

    /**
     * Initialize disk cache
     */
    private fun initializeDiskCache() {
        try {
            val cacheDir = File(context.cacheDir, "disk_cache")
            diskCache = DiskLruCache.open(
                cacheDir,
                config.maxSize,
                1, // app version
                1  // value count
            )
        } catch (e: Exception) {
            // Disk cache initialization failed, continue with memory cache only
        }
    }

    /**
     * Start cleanup scheduler
     */
    private fun startCleanupScheduler() {
        cleanupScheduler.scheduleAtFixedRate({
            cleanup()
        }, 1, 1, TimeUnit.HOURS) // Cleanup every hour
    }

    /**
     * Put value in memory cache
     */
    private fun <T> putInMemory(key: String, value: T, ttl: Long) {
        val entry = CacheEntry(value, System.currentTimeMillis(), ttl)
        val entrySize = calculateSize(value)
        
        // Evict if necessary
        while (memoryCurrentSize.get() + entrySize > memoryMaxSize.get()) {
            evictLeastRecentlyUsed(entrySize)
        }
        
        memoryCache[key] = entry
        memoryCurrentSize.addAndGet(entrySize)
    }

    /**
     * Put value in disk cache
     */
    private fun putInDisk(key: String, value: ByteArray, ttl: Long) {
        try {
            val editor = diskCache.edit(key)
            editor.set(0, value)
            editor.setTTL(ttl)
            editor.commit()
        } catch (e: Exception) {
            // Log error
        }
    }

    /**
     * Evict least recently used entries
     */
    private fun evictLeastRecentlyUsed(requiredSize: Long) {
        val sortedEntries = memoryCache.entries.sortedBy { it.value.lastAccessTime }
        var freedSize = 0L
        
        for ((key, entry) in sortedEntries) {
            if (freedSize >= requiredSize) break
            
            memoryCache.remove(key)
            val entrySize = calculateSize(entry.value)
            memoryCurrentSize.addAndGet(-entrySize)
            freedSize += entrySize
            evictions.incrementAndGet()
        }
    }

    /**
     * Calculate TTL based on cache policy
     */
    private fun calculateTTL(policy: CachePolicy): Long {
        return when (policy) {
            CachePolicy.NO_CACHE -> 0
            CachePolicy.CONSERVATIVE -> config.ttlMs / 2
            CachePolicy.DEFAULT -> config.ttlMs
            CachePolicy.AGGRESSIVE -> config.ttlMs * 2
        }
    }

    /**
     * Check if item should be cached in disk
     */
    private fun shouldCacheInDisk(size: Long, policy: CachePolicy): Boolean {
        return size < config.maxSize / 10 && policy != CachePolicy.NO_CACHE
    }

    /**
     * Calculate size of cached item
     */
    private fun calculateSize(value: Any): Long {
        // Simple size calculation - in real implementation, use more sophisticated methods
        return when (value) {
            is String -> value.length.toLong()
            is ByteArray -> value.size.toLong()
            is Collection<*> -> value.size.toLong() * 8 // Assume 8 bytes per item
            else -> 64 // Default size for unknown objects
        }
    }

    /**
     * Serialize value to byte array
     */
    private fun serializeValue(value: Any): ByteArray {
        // Simple serialization - in real implementation, use proper serialization
        return when (value) {
            is String -> value.toByteArray()
            is ByteArray -> value
            else -> value.toString().toByteArray()
        }
    }

    /**
     * Deserialize value from byte array
     */
    private fun <T> deserializeValue(data: ByteArray): T {
        // Simple deserialization - in real implementation, use proper deserialization
        @Suppress("UNCHECKED_CAST")
        return String(data) as T
    }
}

/**
 * Cache entry data class
 */
data class CacheEntry(
    val value: Any,
    val timestamp: Long,
    val ttl: Long,
    var lastAccessTime: Long = System.currentTimeMillis()
) {
    fun isExpired(currentTime: Long = System.currentTimeMillis()): Boolean {
        return ttl > 0 && (timestamp + ttl) < currentTime
    }
}

