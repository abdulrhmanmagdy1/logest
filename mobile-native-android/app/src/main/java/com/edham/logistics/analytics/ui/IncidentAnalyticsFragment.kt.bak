                    SafetyMetric(
                        title = "Incident Rate per 1000km",
                        value = String.format("%.2f", analytics.incidentRatePerThousandKm),
                        subtitle = "Incidents per distance",
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_directions),
                        color = if (analytics.incidentRatePerThousandKm <= 1) SuccessGreen else WarningYellow
                    )
                }
            }
        }
    }
}

