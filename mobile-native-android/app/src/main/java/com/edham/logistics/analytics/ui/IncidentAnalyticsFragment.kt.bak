import kotlinx.coroutines.launch
import javax.inject.Inject

/**
 * Incident Analytics Fragment - Comprehensive incident analysis and insights
 * 
 * Features:
 * - Incident overview and statistics
 * - Incident type analysis
 * - Severity distribution
 * - Response time metrics
 * - Incident trends and patterns
 * - Safety performance indicators
 * - Risk assessment analytics
 * - Interactive charts
 */
@AndroidEntryPoint
class IncidentAnalyticsFragment : Fragment() {
    
    @Inject
    lateinit var analyticsEngineService: AnalyticsEngineService
    
    private val viewModel: IncidentAnalyticsViewModel by viewModels()
    
    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View {
        return ComposeView(requireContext()).apply {
            setContent {
                EdhamLogisticsTheme {
                    IncidentAnalyticsScreen(
                        viewModel = viewModel,
                        analyticsEngineService = analyticsEngineService
                    )
                }
            }
        }
    }
    
    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        
        // Initialize analytics engine
        lifecycleScope.launch {
            analyticsEngineService.initialize()
        }
        
        // Load incident analytics
        viewModel.loadIncidentAnalytics()
    }
}

@Composable
fun IncidentAnalyticsScreen(
    viewModel: IncidentAnalyticsViewModel,
    analyticsEngineService: AnalyticsEngineService
) {
    val incidentAnalytics by viewModel.incidentAnalytics.collectAsStateWithLifecycle()
    val isLoading by viewModel.isLoading.collectAsStateWithLifecycle()
    val errorMessage by viewModel.errorMessage.collectAsStateWithLifecycle()
    val selectedTimeRange by viewModel.selectedTimeRange.collectAsStateWithLifecycle()
    
    LaunchedEffect(selectedTimeRange) {
        viewModel.loadIncidentAnalytics()
    }
    
    Column(
        modifier = Modifier
            .fillMaxSize()
            .padding(16.dp),
        verticalArrangement = Arrangement.spacedBy(16.dp)
    ) {
        // Header with time range selector
        IncidentAnalyticsHeader(
            selectedTimeRange = selectedTimeRange,
            onTimeRangeChanged = viewModel::setTimeRange,
            onRefresh = viewModel::refreshAnalytics,
            isLoading = isLoading
        )
        
        // Error message
        errorMessage?.let { error ->
            Card(
                modifier = Modifier.fillMaxWidth(),
                colors = CardDefaults.cardColors(
                    containerColor = ErrorRed.copy(alpha = 0.1f)
                ),
                elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
            ) {
                Text(
                    text = error,
                    modifier = Modifier.padding(16.dp),
                    color = ErrorRed,
                    style = MaterialTheme.typography.bodyMedium
                )
            }
        }
        
        // Incident Analytics Content
        incidentAnalytics?.let { analytics ->
            // Incident Overview
            IncidentOverviewSection(analytics = analytics)
            
            // Incident Type Analysis
            IncidentTypeSection(analytics = analytics)
            
            // Severity Distribution
            SeverityDistributionSection(analytics = analytics)
            
            // Response Time Metrics
            ResponseTimeSection(analytics = analytics)
            
            // Incident Trends
            IncidentTrendsSection(analytics = analytics)
            
            // Safety Performance
            SafetyPerformanceSection(analytics = analytics)
            
            // Risk Assessment
            RiskAssessmentSection(analytics = analytics)
        }
        
        // Loading indicator
        if (isLoading) {
            Box(
                modifier = Modifier.fillMaxWidth(),
                contentAlignment = Alignment.Center
            ) {
                CircularProgressIndicator(
                    color = EdhamOrange,
                    strokeWidth = 3.dp
                )
            }
        }
    }
}

@Composable
fun IncidentAnalyticsHeader(
    selectedTimeRange: TimeRange,
    onTimeRangeChanged: (TimeRange) -> Unit,
    onRefresh: () -> Unit,
    isLoading: Boolean
) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.surface
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Row(
                modifier = Modifier.fillMaxWidth(),
                horizontalArrangement = Arrangement.SpaceBetween,
                verticalAlignment = Alignment.CenterVertically
            ) {
                Text(
                    text = "Incident Analytics",
                    style = MaterialTheme.typography.headlineMedium,
                    color = EdhamOrange,
                    fontWeight = FontWeight.Bold
                )
                
                Row {
                    // Time range selector
                    TimeRangeSelector(
                        selectedTimeRange = selectedTimeRange,
                        onTimeRangeChanged = onTimeRangeChanged
                    )
                    
                    Spacer(modifier = Modifier.width(8.dp))
                    
                    // Refresh button
                    IconButton(
                        onClick = onRefresh,
                        enabled = !isLoading
                    ) {
                        Icon(
                            painter = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_rotate),
                            contentDescription = "Refresh",
                            tint = EdhamOrange
                        )
                    }
                }
            }
        }
    }
}

@Composable
fun IncidentOverviewSection(analytics: IncidentAnalytics) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.surface
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Text(
                text = "Incident Overview",
                style = MaterialTheme.typography.titleMedium,
                color = EdhamOrange,
                fontWeight = FontWeight.Bold
            )
            
            Spacer(modifier = Modifier.height(16.dp))
            
            LazyColumn(
                verticalArrangement = Arrangement.spacedBy(12.dp)
            ) {
                item {
                    OverviewMetric(
                        title = "Total Incidents",
                        value = analytics.totalIncidents.toString(),
                        subtitle = "In selected period",
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_warning),
                        color = ErrorRed,
                        change = analytics.incidentsChange
                    )
                }
                
                item {
                    OverviewMetric(
                        title = "Critical Incidents",
                        value = analytics.criticalIncidents.toString(),
                        subtitle = "High severity incidents",
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_help),
                        color = ErrorRed,
                        change = analytics.criticalIncidentsChange
                    )
                }
                
                item {
                    OverviewMetric(
                        title = "Average Response Time",
                        value = "${String.format("%.1f", analytics.averageResponseTime)} minutes",
                        subtitle = "Time to respond",
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_recent_history),
                        color = if (analytics.averageResponseTime <= 15) SuccessGreen else WarningYellow,
                        change = analytics.responseTimeChange
                    )
                }
                
                item {
                    OverviewMetric(
                        title = "Resolution Rate",
                        value = "${String.format("%.1f", analytics.resolutionRate)}%",
                        subtitle = "Successfully resolved",
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_star),
                        color = if (analytics.resolutionRate >= 90) SuccessGreen else WarningYellow,
                        change = analytics.resolutionRateChange
                    )
                }
            }
        }
    }
}

