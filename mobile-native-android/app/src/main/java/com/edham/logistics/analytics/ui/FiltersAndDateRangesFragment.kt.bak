@Composable
fun AdvancedFiltersSection(
    advancedFilters: AdvancedFilters,
    onAdvancedFilterChanged: (AdvancedFilters) -> Unit
) {
    var expanded by remember { mutableStateOf(false) }
    
    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.surface
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Row(
                modifier = Modifier.fillMaxWidth(),
                horizontalArrangement = Arrangement.SpaceBetween,
                verticalAlignment = Alignment.CenterVertically
            ) {
                Text(
                    text = "Advanced Filters",
                    style = MaterialTheme.typography.titleMedium,
                    color = EdhamOrange,
                    fontWeight = FontWeight.Bold
                )
                
                IconButton(
                    onClick = { expanded = !expanded }
                ) {
                    Icon(
                        painter = androidx.compose.ui.res.painterResource(
                            id = if (expanded) android.R.drawable.ic_menu_more 
                            else android.R.drawable.ic_menu_less
                        ),
                        contentDescription = if (expanded) "Collapse" else "Expand",
                        tint = EdhamOrange
                    )
                }
            }
            
            if (expanded) {
                Spacer(modifier = Modifier.height(16.dp))
                
                LazyColumn(
                    verticalArrangement = Arrangement.spacedBy(12.dp)
                ) {
                    item {
                        Row(
                            modifier = Modifier.fillMaxWidth(),
                            horizontalArrangement = Arrangement.SpaceBetween,
                            verticalAlignment = Alignment.CenterVertically
                        ) {
                            Text(
                                text = "Minimum Revenue",
                                style = MaterialTheme.typography.bodyMedium,
                                color = MaterialTheme.colorScheme.onSurface
                            )
                            
                            OutlinedTextField(
                                value = advancedFilters.minRevenue,
                                onValueChange = { 
                                    onAdvancedFilterChanged(advancedFilters.copy(minRevenue = it))
                                },
                                modifier = Modifier.width(120.dp),
                                singleLine = true
                            )
                        }
                    }
                    
                    item {
                        Row(
                            modifier = Modifier.fillMaxWidth(),
                            horizontalArrangement = Arrangement.SpaceBetween,
                            verticalAlignment = Alignment.CenterVertically
                        ) {
                            Text(
                                text = "Maximum Revenue",
                                style = MaterialTheme.typography.bodyMedium,
                                color = MaterialTheme.colorScheme.onSurface
                            )
                            
                            OutlinedTextField(
                                value = advancedFilters.maxRevenue,
                                onValueChange = { 
                                    onAdvancedFilterChanged(advancedFilters.copy(maxRevenue = it))
                                },
                                modifier = Modifier.width(120.dp),
                                singleLine = true
                            )
                        }
                    }
                    
                    item {
                        Row(
                            modifier = Modifier.fillMaxWidth(),
                            horizontalArrangement = Arrangement.SpaceBetween,
                            verticalAlignment = Alignment.CenterVertically
                        ) {
                            Text(
                                text = "Minimum Distance",
                                style = MaterialTheme.typography.bodyMedium,
                                color = MaterialTheme.colorScheme.onSurface
                            )
                            
                            OutlinedTextField(
                                value = advancedFilters.minDistance,
                                onValueChange = { 
                                    onAdvancedFilterChanged(advancedFilters.copy(minDistance = it))
                                },
                                modifier = Modifier.width(120.dp),
                                singleLine = true
                            )
                        }
                    }
                    
                    item {
                        Row(
                            modifier = Modifier.fillMaxWidth(),
                            verticalAlignment = Alignment.CenterVertically
                        ) {
                            Checkbox(
                                checked = advancedFilters.includeIncomplete,
                                onCheckedChange = { 
                                    onAdvancedFilterChanged(advancedFilters.copy(includeIncomplete = it))
                                },
                                colors = CheckboxDefaults.colors(
                                    checkedColor = EdhamOrange
                                )
                            )
                            
                            Spacer(modifier = Modifier.width(12.dp))
                            
                            Text(
                                text = "Include incomplete shipments",
                                style = MaterialTheme.typography.bodyMedium,
                                color = MaterialTheme.colorScheme.onSurface
                            )
                        }
                    }
                    
                    item {
                        Row(
                            modifier = Modifier.fillMaxWidth(),
                            verticalAlignment = Alignment.CenterVertically
                        ) {
                            Checkbox(
                                checked = advancedFilters.includeCancelled,
                                onCheckedChange = { 
                                    onAdvancedFilterChanged(advancedFilters.copy(includeCancelled = it))
                                },
                                colors = CheckboxDefaults.colors(
                                    checkedColor = EdhamOrange
                                )
                            )
                            
                            Spacer(modifier = Modifier.width(12.dp))
                            
                            Text(
                                text = "Include cancelled shipments",
                                style = MaterialTheme.typography.bodyMedium,
                                color = MaterialTheme.colorScheme.onSurface
                            )
                        }
                    }
                }
            }
        }
    }
}

@Composable
fun SavedPresetsSection(
    presets: List<FilterPreset>,
    onPresetSelected: (FilterPreset) -> Unit,
    onPresetDeleted: (String) -> Unit
) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.surface
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Text(
                text = "Saved Presets",
                style = MaterialTheme.typography.titleMedium,
                color = EdhamOrange,
                fontWeight = FontWeight.Bold
            )
            
            Spacer(modifier = Modifier.height(16.dp))
            
            LazyColumn(
                verticalArrangement = Arrangement.spacedBy(8.dp)
            ) {
                items(presets) { preset ->
                    Row(
                        modifier = Modifier
                            .fillMaxWidth()
                            .clip(RoundedCornerShape(8.dp))
                            .background(MaterialTheme.colorScheme.surfaceVariant)
                            .clickable { onPresetSelected(preset) }
                            .padding(12.dp),
                        horizontalArrangement = Arrangement.SpaceBetween,
                        verticalAlignment = Alignment.CenterVertically
                    ) {
                        Column(modifier = Modifier.weight(1f)) {
                            Text(
                                text = preset.name,
                                style = MaterialTheme.typography.bodyMedium,
                                color = MaterialTheme.colorScheme.onSurface,
                                fontWeight = FontWeight.Medium
                            )
                            
                            Text(
                                text = "${preset.filterCount} filters",
                                style = MaterialTheme.typography.bodySmall,
                                color = MaterialTheme.colorScheme.onSurface.copy(alpha = 0.7f)
                            )
                        }
                        
                        IconButton(
                            onClick = { onPresetDeleted(preset.id) }
                        ) {
                            Icon(
                                painter = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_delete),
                                contentDescription = "Delete",
                                tint = ErrorRed,
                                modifier = Modifier.size(20.dp)
                            )
                        }
                    }
                }
            }
        }
    }
}

@Composable
fun FilterHistorySection(
    history: List<FilterHistoryItem>,
    onHistoryItemSelected: (FilterHistoryItem) -> Unit
) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.surface
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Text(
                text = "Recent Filters",
                style = MaterialTheme.typography.titleMedium,
                color = EdhamOrange,
                fontWeight = FontWeight.Bold
            )
            
            Spacer(modifier = Modifier.height(16.dp))
            
            LazyColumn(
                verticalArrangement = Arrangement.spacedBy(8.dp)
            ) {
                items(history.take(5)) { item ->
                    Row(
                        modifier = Modifier
                            .fillMaxWidth()
                            .clickable { onHistoryItemSelected(item) }
                            .padding(8.dp),
                        horizontalArrangement = Arrangement.SpaceBetween,
                        verticalAlignment = Alignment.CenterVertically
                    ) {
                        Column(modifier = Modifier.weight(1f)) {
                            Text(
                                text = item.name,
                                style = MaterialTheme.typography.bodyMedium,
                                color = MaterialTheme.colorScheme.onSurface
                            )
                            
                            Text(
                                text = item.appliedAt,
                                style = MaterialTheme.typography.bodySmall,
                                color = MaterialTheme.colorScheme.onSurface.copy(alpha = 0.7f)
                            )
                        }
                        
                        Icon(
                            painter = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_recent_history),
                            contentDescription = "Load",
                            tint = EdhamOrange,
                            modifier = Modifier.size(20.dp)
                        )
                    }
                }
            }
        }
    }
}

// Data classes and enums
enum class TimeRange(val displayName: String) {
    LAST_HOUR("Last Hour"),
    LAST_24_HOURS("Last 24 Hours"),
    LAST_7_DAYS("Last 7 Days"),
    LAST_30_DAYS("Last 30 Days"),
    LAST_3_MONTHS("Last 3 Months"),
    LAST_6_MONTHS("Last 6 Months"),
    LAST_YEAR("Last Year"),
    CUSTOM("Custom Range")
}

data class CustomDateRange(
    val startDate: String,
    val endDate: String
)

data class QuickFilter(
    val id: String,
    val name: String
)

data class CategoryFilter(
    val id: String,
    val name: String,
    val count: Int
)

data class StatusFilter(
    val id: String,
    val name: String,
    val color: Color
)

data class LocationFilter(
    val id: String,
    val name: String,
    val count: Int
)

data class DriverFilter(
    val id: String,
    val name: String,
    val completedDeliveries: Int
)

data class VehicleFilter(
    val id: String,
    val name: String,
    val type: String,
    val totalDistance: Int
)

data class AdvancedFilters(
    val minRevenue: String,
    val maxRevenue: String,
    val minDistance: String,
    val includeIncomplete: Boolean,
    val includeCancelled: Boolean
)

data class FilterPreset(
    val id: String,
    val name: String,
    val filterCount: Int
)

data class FilterHistoryItem(
    val id: String,
    val name: String,
    val appliedAt: String
)

data class FilterState(
    val selectedTimeRange: TimeRange,
    val customDateRange: CustomDateRange,
    val quickFilters: List<QuickFilter>,
    val selectedQuickFilters: Set<String>,
    val categoryFilters: List<CategoryFilter>,
    val selectedCategories: Set<String>,
    val statusFilters: List<StatusFilter>,
    val selectedStatuses: Set<String>,
    val locationFilters: List<LocationFilter>,
    val selectedLocations: Set<String>,
    val driverFilters: List<DriverFilter>,
    val selectedDrivers: Set<String>,
    val vehicleFilters: List<VehicleFilter>,
    val selectedVehicles: Set<String>,
    val advancedFilters: AdvancedFilters,
    val savedPresets: List<FilterPreset>,
    val filterHistory: List<FilterHistoryItem>
)
