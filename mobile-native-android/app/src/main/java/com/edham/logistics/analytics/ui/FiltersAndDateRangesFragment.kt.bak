import javax.inject.Inject

/**
 * Filters & Date Ranges Fragment - Comprehensive filtering and date range selection
 * 
 * Features:
 * - Date range picker with presets
 * - Custom date range selection
 * - Multiple filter categories
 * - Advanced filtering options
 * - Filter combinations
 * - Save filter presets
 * - Quick filter shortcuts
 * - Filter history
 */
@AndroidEntryPoint
class FiltersAndDateRangesFragment : Fragment() {
    
    @Inject
    lateinit var analyticsEngineService: AnalyticsEngineService
    
    private val viewModel: FiltersAndDateRangesViewModel by viewModels()
    
    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View {
        return ComposeView(requireContext()).apply {
            setContent {
                EdhamLogisticsTheme {
                    FiltersAndDateRangesScreen(
                        viewModel = viewModel,
                        analyticsEngineService = analyticsEngineService
                    )
                }
            }
        }
    }
    
    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        
        // Initialize analytics engine
        lifecycleScope.launch {
            analyticsEngineService.initialize()
        }
        
        // Load filter data
        viewModel.loadFilterData()
    }
}

@Composable
fun FiltersAndDateRangesScreen(
    viewModel: FiltersAndDateRangesViewModel,
    analyticsEngineService: AnalyticsEngineService
) {
    val filterState by viewModel.filterState.collectAsStateWithLifecycle()
    val isLoading by viewModel.isLoading.collectAsStateWithLifecycle()
    val errorMessage by viewModel.errorMessage.collectAsStateWithLifecycle()
    
    Column(
        modifier = Modifier
            .fillMaxSize()
            .padding(16.dp),
        verticalArrangement = Arrangement.spacedBy(16.dp)
    ) {
        // Header
        FiltersHeader(
            onApplyFilters = viewModel::applyFilters,
            onResetFilters = viewModel::resetFilters,
            onSavePreset = viewModel::saveFilterPreset,
            isLoading = isLoading
        )
        
        // Error message
        errorMessage?.let { error ->
            Card(
                modifier = Modifier.fillMaxWidth(),
                colors = CardDefaults.cardColors(
                    containerColor = ErrorRed.copy(alpha = 0.1f)
                ),
                elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
            ) {
                Text(
                    text = error,
                    modifier = Modifier.padding(16.dp),
                    color = ErrorRed,
                    style = MaterialTheme.typography.bodyMedium
                )
            }
        }
        
        // Filters Content
        LazyColumn(
            verticalArrangement = Arrangement.spacedBy(16.dp)
        ) {
            // Date Range Selection
            item {
                DateRangeSection(
                    selectedTimeRange = filterState.selectedTimeRange,
                    customDateRange = filterState.customDateRange,
                    onTimeRangeChanged = viewModel::setTimeRange,
                    onCustomDateRangeChanged = viewModel::setCustomDateRange
                )
            }
            
            // Quick Filters
            item {
                QuickFiltersSection(
                    quickFilters = filterState.quickFilters,
                    selectedQuickFilters = filterState.selectedQuickFilters,
                    onQuickFilterToggle = viewModel::toggleQuickFilter
                )
            }
            
            // Category Filters
            item {
                CategoryFiltersSection(
                    categoryFilters = filterState.categoryFilters,
                    selectedCategories = filterState.selectedCategories,
                    onCategoryToggle = viewModel::toggleCategory
                )
            }
            
            // Status Filters
            item {
                StatusFiltersSection(
                    statusFilters = filterState.statusFilters,
                    selectedStatuses = filterState.selectedStatuses,
                    onStatusToggle = viewModel::toggleStatus
                )
            }
            
            // Location Filters
            item {
                LocationFiltersSection(
                    locationFilters = filterState.locationFilters,
                    selectedLocations = filterState.selectedLocations,
                    onLocationToggle = viewModel::toggleLocation
                )
            }
            
            // Driver Filters
            item {
                DriverFiltersSection(
                    driverFilters = filterState.driverFilters,
                    selectedDrivers = filterState.selectedDrivers,
                    onDriverToggle = viewModel::toggleDriver
                )
            }
            
            // Vehicle Filters
            item {
                VehicleFiltersSection(
                    vehicleFilters = filterState.vehicleFilters,
                    selectedVehicles = filterState.selectedVehicles,
                    onVehicleToggle = viewModel::toggleVehicle
                )
            }
            
            // Advanced Filters
            item {
                AdvancedFiltersSection(
                    advancedFilters = filterState.advancedFilters,
                    onAdvancedFilterChanged = viewModel::updateAdvancedFilter
                )
            }
            
            // Saved Presets
            item {
                SavedPresetsSection(
                    presets = filterState.savedPresets,
                    onPresetSelected = viewModel::loadPreset,
                    onPresetDeleted = viewModel::deletePreset
                )
            }
            
            // Filter History
            item {
                FilterHistorySection(
                    history = filterState.filterHistory,
                    onHistoryItemSelected = viewModel::loadFromHistory
                )
            }
        }
    }
}

@Composable
fun FiltersHeader(
    onApplyFilters: () -> Unit,
    onResetFilters: () -> Unit,
    onSavePreset: () -> Unit,
    isLoading: Boolean
) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.surface
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Text(
                text = "Filters & Date Ranges",
                style = MaterialTheme.typography.headlineMedium,
                color = EdhamOrange,
                fontWeight = FontWeight.Bold
            )
            
            Spacer(modifier = Modifier.height(16.dp))
            
            Row(
                modifier = Modifier.fillMaxWidth(),
                horizontalArrangement = Arrangement.spacedBy(8.dp)
            ) {
                Button(
                    onClick = onApplyFilters,
                    enabled = !isLoading,
                    modifier = Modifier.weight(1f),
                    colors = ButtonDefaults.buttonColors(
                        containerColor = EdhamOrange
                    )
                ) {
                    if (isLoading) {
                        CircularProgressIndicator(
                            modifier = Modifier.size(20.dp),
                            color = Color.White,
                            strokeWidth = 2.dp
                        )
                    } else {
                        Text("Apply Filters")
                    }
                }
                
                OutlinedButton(
                    onClick = onResetFilters,
                    modifier = Modifier.weight(1f),
                    colors = ButtonDefaults.outlinedButtonColors(
                        contentColor = IceBlue,
                        borderColor = IceBlue
                    )
                ) {
                    Text("Reset")
                }
                
                OutlinedButton(
                    onClick = onSavePreset,
                    colors = ButtonDefaults.outlinedButtonColors(
                        contentColor = SuccessGreen,
                        borderColor = SuccessGreen
                    )
                ) {
                    Text("Save")
                }
            }
        }
    }
}

@Composable
fun DateRangeSection(
    selectedTimeRange: TimeRange,
    customDateRange: CustomDateRange,
    onTimeRangeChanged: (TimeRange) -> Unit,
    onCustomDateRangeChanged: (CustomDateRange) -> Unit
) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.surface
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Text(
                text = "Date Range",
                style = MaterialTheme.typography.titleMedium,
                color = EdhamOrange,
                fontWeight = FontWeight.Bold
            )
            
            Spacer(modifier = Modifier.height(16.dp))
            
            // Preset time ranges
            LazyRow(
                horizontalArrangement = Arrangement.spacedBy(8.dp)
            ) {
                items(TimeRange.values()) { timeRange ->
                    FilterChip(
                        selected = selectedTimeRange == timeRange,
                        onClick = { onTimeRangeChanged(timeRange) },
                        label = {
                            Text(
                                text = timeRange.displayName,
                                style = MaterialTheme.typography.bodyMedium
                            )
                        },
                        colors = FilterChipDefaults.filterChipColors(
                            selectedContainerColor = EdhamOrange,
                            selectedLabelColor = Color.White
                        )
                    )
                }
            }
            
            Spacer(modifier = Modifier.height(16.dp))
            
            // Custom date range
            if (selectedTimeRange == TimeRange.CUSTOM) {
                Row(
                    modifier = Modifier.fillMaxWidth(),
                    horizontalArrangement = Arrangement.spacedBy(8.dp)
                ) {
                    OutlinedButton(
                        onClick = { /* Show date picker for start date */ },
                        modifier = Modifier.weight(1f)
                    ) {
                        Column {
                            Text("Start Date")
                            Text(
                                text = customDateRange.startDate,
                                style = MaterialTheme.typography.bodySmall
                            )
                        }
                    }
                    
                    OutlinedButton(
                        onClick = { /* Show date picker for end date */ },
                        modifier = Modifier.weight(1f)
                    ) {
                        Column {
                            Text("End Date")
                            Text(
                                text = customDateRange.endDate,
                                style = MaterialTheme.typography.bodySmall
                            )
                        }
                    }
                }
            }
        }
    }
}

@Composable
fun QuickFiltersSection(
    quickFilters: List<QuickFilter>,
    selectedQuickFilters: Set<String>,
    onQuickFilterToggle: (String) -> Unit
) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.surface
        ),
