@Composable
fun LocationFiltersSection(
    locationFilters: List<LocationFilter>,
    selectedLocations: Set<String>,
    onLocationToggle: (String) -> Unit
) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.surface
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Text(
                text = "Locations",
                style = MaterialTheme.typography.titleMedium,
                color = EdhamOrange,
                fontWeight = FontWeight.Bold
            )
            
            Spacer(modifier = Modifier.height(16.dp))
            
            LazyColumn(
                verticalArrangement = Arrangement.spacedBy(8.dp)
            ) {
                items(locationFilters.take(5)) { filter ->
                    Row(
                        modifier = Modifier.fillMaxWidth(),
                        verticalAlignment = Alignment.CenterVertically
                    ) {
                        Checkbox(
                            checked = selectedLocations.contains(filter.id),
                            onCheckedChange = { onLocationToggle(filter.id) },
                            colors = CheckboxDefaults.colors(
                                checkedColor = EdhamOrange
                            )
                        )
                        
                        Spacer(modifier = Modifier.width(12.dp))
                        
                        Column(modifier = Modifier.weight(1f)) {
                            Text(
                                text = filter.name,
                                style = MaterialTheme.typography.bodyMedium,
                                color = MaterialTheme.colorScheme.onSurface
                            )
                            
                            Text(
                                text = "${filter.count} shipments",
                                style = MaterialTheme.typography.bodySmall,
                                color = MaterialTheme.colorScheme.onSurface.copy(alpha = 0.7f)
                            )
                        }
                    }
                }
            }
            
            if (locationFilters.size > 5) {
                TextButton(
                    onClick = { /* Show all locations */ },
                    modifier = Modifier.fillMaxWidth()
                ) {
                    Text(
                        text = "Show all ${locationFilters.size} locations",
                        color = EdhamOrange
                    )
                }
            }
        }
    }
}

