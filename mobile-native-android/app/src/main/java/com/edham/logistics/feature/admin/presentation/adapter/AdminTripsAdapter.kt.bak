package com.edham.logistics.feature.admin.presentation.adapter

import android.view.LayoutInflater
import android.view.ViewGroup
import androidx.recyclerview.widget.DiffUtil
import androidx.recyclerview.widget.ListAdapter
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.databinding.ItemAdminTripBinding
import com.edham.logistics.feature.admin.domain.model.AdminTrip
import javax.inject.Inject

class AdminTripsAdapter @Inject constructor(
    private val onTripAction: (AdminTrip, String) -> Unit
) : ListAdapter<AdminTrip, AdminTripsAdapter.AdminTripViewHolder>(AdminTripDiffCallback()) {

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): AdminTripViewHolder {
        val binding = ItemAdminTripBinding.inflate(
            LayoutInflater.from(parent.context),
            parent,
            false
        )
        return AdminTripViewHolder(binding)
    }

    override fun onBindViewHolder(holder: AdminTripViewHolder, position: Int) {
        holder.bind(getItem(position))
    }

    inner class AdminTripViewHolder(
        private val binding: ItemAdminTripBinding
    ) : RecyclerView.ViewHolder(binding.root) {

        fun bind(trip: AdminTrip) {
            binding.apply {
                textTrackingNumber.text = trip.trackingNumber
                textDriverName.text = trip.driver.name
                textDriverPhone.text = trip.driver.phone
                textCurrentLocation.text = trip.currentLocation?.address ?: "غير متوفر"
                textEstimatedArrival.text = formatDateTime(trip.estimatedArrival)
                textDistance.text = "${String.format("%.1f", trip.distance)} كم"
                textDuration.text = "${trip.duration} دقيقة"
                textStatus.text = formatTripStatus(trip.status)
                
                // Set status color
                textStatus.setTextColor(getTripStatusColor(trip.status))
                
                // Show progress bar
                progressBar.progress = (trip.progress * 100).toInt()
                textProgress.text = "${String.format("%.0f", trip.progress * 100)}%"
                
                // Set click listeners
                buttonTrack.setOnClickListener {
                    onTripAction(trip, "track")
                }
                
                buttonCall.setOnClickListener {
                    onTripAction(trip, "call")
                }
                
                root.setOnClickListener {
                    onTripAction(trip, "details")
                }
                
                // Show vehicle info
                textVehicleInfo.text = "${trip.driver.vehicle.type} - ${trip.driver.vehicle.licensePlate}"
                
                // Show fuel level if available
                trip.driver.vehicle.fuelLevel?.let { fuel ->
                    textFuelLevel.text = "${String.format("%.0f", fuel)}%"
                    layoutFuelLevel.visible()
                } ?: run {
                    layoutFuelLevel.gone()
                }
                
                // Show temperature if available
                trip.driver.vehicle.temperature?.let { temp ->
                    textTemperature.text = "${String.format("%.1f", temp)}°C"
                    layoutTemperature.visible()
                } ?: run {
                    layoutTemperature.gone()
                }
            }
        }
        
        private fun formatTripStatus(status: com.edham.logistics.feature.admin.domain.model.TripStatus): String {
            return when (status) {
                com.edham.logistics.feature.admin.domain.model.TripStatus.ASSIGNED -> "مخصص"
                com.edham.logistics.feature.admin.domain.model.TripStatus.STARTED -> "بدأت"
                com.edham.logistics.feature.admin.domain.model.TripStatus.IN_TRANSIT -> "قيد النقل"
                com.edham.logistics.feature.admin.domain.model.TripStatus.ARRIVED -> "وصلت"
                com.edham.logistics.feature.admin.domain.model.TripStatus.COMPLETED -> "مكتملة"
                com.edham.logistics.feature.admin.domain.model.TripStatus.CANCELLED -> "ملغية"
            }
        }
        
        private fun formatDateTime(dateTime: String): String {
            // In real app, we would format date time properly
            return dateTime.substring(0, 16).replace("T", " ")
        }
        
        private fun getTripStatusColor(status: com.edham.logistics.feature.admin.domain.model.TripStatus): Int {
            return when (status) {
                com.edham.logistics.feature.admin.domain.model.TripStatus.ASSIGNED -> android.graphics.Color.parseColor("#FF9800")
                com.edham.logistics.feature.admin.domain.model.TripStatus.STARTED -> android.graphics.Color.parseColor("#4CAF50")
                com.edham.logistics.feature.admin.domain.model.TripStatus.IN_TRANSIT -> android.graphics.Color.parseColor("#2196F3")
                com.edham.logistics.feature.admin.domain.model.TripStatus.ARRIVED -> android.graphics.Color.parseColor("#9C27B0")
                com.edham.logistics.feature.admin.domain.model.TripStatus.COMPLETED -> android.graphics.Color.parseColor("#4CAF50")
                com.edham.logistics.feature.admin.domain.model.TripStatus.CANCELLED -> android.graphics.Color.parseColor("#F44336")
            }
        }
    }

    private class AdminTripDiffCallback : DiffUtil.ItemCallback<AdminTrip>() {
        override fun areItemsTheSame(oldItem: AdminTrip, newItem: AdminTrip): Boolean {
            return oldItem.id == newItem.id
        }

        override fun areContentsTheSame(oldItem: AdminTrip, newItem: AdminTrip): Boolean {
            return oldItem == newItem
        }
    }
}
