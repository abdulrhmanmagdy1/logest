package com.edham.logistics.feature.activitylogs.domain.usecase

import com.edham.logistics.core.utils.Result
import com.edham.logistics.feature.activitylogs.domain.model.*
import com.edham.logistics.feature.activitylogs.domain.repository.ActivityLogRepository
import kotlinx.coroutines.flow.Flow
import javax.inject.Inject
import javax.inject.Singleton

/**
 * Activity logging use cases for comprehensive activity tracking
 */
@Singleton
class LogActivityUseCase @Inject constructor(
    private val activityLogRepository: ActivityLogRepository
) {
    suspend operator fun invoke(
        userId: String,
        userRole: UserRole,
        userName: String,
        userEmail: String,
        action: ActivityAction,
        entityType: EntityType,
        entityId: String? = null,
        entityName: String? = null,
        description: String,
        details: Map<String, Any> = emptyMap(),
        ipAddress: String? = null,
        userAgent: String? = null,
        deviceId: String? = null,
        location: String? = null,
        sessionId: String? = null,
        success: Boolean = true,
        errorMessage: String? = null,
        severity: LogSeverity = LogSeverity.INFO,
        source: LogSource = LogSource.MOBILE,
        metadata: ActivityLogMetadata? = null
    ): Result<ActivityLog> {
        return try {
            val activityLog = ActivityLog(
                id = java.util.UUID.randomUUID().toString(),
                userId = userId,
                userRole = userRole,
                userName = userName,
                userEmail = userEmail,
                action = action,
                actionType = getActionType(action),
                entityType = entityType,
                entityId = entityId,
                entityName = entityName,
                description = description,
                details = details,
                ipAddress = ipAddress,
                userAgent = userAgent,
                deviceId = deviceId,
                location = location,
                sessionId = sessionId,
                timestamp = System.currentTimeMillis(),
                success = success,
                errorMessage = errorMessage,
                severity = if (!success) LogSeverity.ERROR else severity,
                category = action.category,
                source = source,
                metadata = metadata ?: ActivityLogMetadata(
                    requestId = null,
                    correlationId = null,
                    traceId = null,
                    duration = null,
                    memoryUsage = null,
                    cpuUsage = null,
                    networkLatency = null,
                    databaseQueryTime = null,
                    cacheHitRate = null,
                    errorCode = null,
                    errorStack = null,
                    userAgentParsed = parseUserAgent(userAgent),
                    geoLocation = parseLocation(location),
                    deviceInfo = parseDeviceInfo(deviceId),
                    sessionInfo = parseSessionInfo(sessionId),
                    performanceMetrics = null
                )
            )
            
            activityLogRepository.logActivity(activityLog)
        } catch (e: Exception) {
            Result.Error(e)
        }
    }
    
    private fun getActionType(action: ActivityAction): ActionType {
        return when (action) {
            ActivityAction.LOGIN, ActivityAction.LOGOUT, ActivityAction.FAILED_LOGIN,
            ActivityAction.PASSWORD_CHANGE, ActivityAction.PASSWORD_RESET,
            ActivityAction.TWO_FACTOR_ENABLE, ActivityAction.TWO_FACTOR_DISABLE -> {
                ActionType.AUTHENTICATION
            }
            ActivityAction.USER_CREATE, ActivityAction.USER_UPDATE, ActivityAction.USER_DELETE,
            ActivityAction.USER_ENABLE, ActivityAction.USER_DISABLE, ActivityAction.USER_SUSPEND,
            ActivityAction.USER_UNSUSPEND, ActivityAction.USER_LOCK, ActivityAction.UNLOCK,
            ActivityAction.ROLE_CHANGE -> {
                ActionType.USER_MANAGEMENT
            }
            ActivityAction.SHIPMENT_CREATE, ActivityAction.SHIPMENT_UPDATE, ActivityAction.SHIPMENT_DELETE,
            ActivityAction.SHIPMENT_CANCEL, ActivityAction.SHIPMENT_PICKUP, ActivityAction.SHIPMENT_DELIVER,
            ActivityAction.SHIPMENT_RETURN, ActivityAction.SHIPMENT_STATUS_UPDATE,
            ActivityAction.SHIPMENT_ROUTE_UPDATE, ActivityAction.SHIPMENT_LOCATION_UPDATE -> {
                ActionType.CREATE
            }
            ActivityAction.INVOICE_CREATE, ActivityAction.INVOICE_UPDATE, ActivityAction.INVOICE_DELETE,
            ActivityAction.INVOICE_SEND, ActivityAction.INVOICE_PAID, ActivityAction.INVOICE_CANCEL -> {
                ActionType.CREATE
            }
            ActivityAction.PAYMENT_PROCESS, ActivityAction.PAYMENT_REFUND, ActivityAction.PAYMENT_FAILED -> {
                ActionType.CREATE
            }
            ActivityAction.SYSTEM_CONFIG_UPDATE, ActivityAction.SYSTEM_BACKUP, ActivityAction.SYSTEM_RESTORE,
            ActivityAction.SYSTEM_MAINTENANCE, ActivityAction.SYSTEM_UPGRADE -> {
                ActionType.SYSTEM
            }
            ActivityAction.SECURITY_ALERT, ActivityAction.SECURITY_VIOLATION, ActivityAction.SUSPICIOUS_ACTIVITY,
            ActivityAction.UNAUTHORIZED_ACCESS, ActivityAction.DATA_BREACH -> {
                ActionType.SECURITY
            }
            ActivityAction.DATA_EXPORT, ActivityAction.DATA_IMPORT, ActivityAction.DATA_DELETE,
            ActivityAction.DATA_BACKUP, ActivityAction.DATA_RESTORE -> {
                ActionType.DATA
            }
            ActivityAction.NOTIFICATION_SEND, ActivityAction.NOTIFICATION_READ, ActivityAction.NOTIFICATION_DELETE -> {
                ActionType.NOTIFICATION
            }
            ActivityAction.REPORT_GENERATE, ActivityAction.REPORT_VIEW, ActivityAction.REPORT_EXPORT,
            ActivityAction.REPORT_DELETE -> {
                ActionType.REPORT
            }
            ActivityAction.API_CALL, ActivityAction.API_ERROR, ActivityAction.API_RATE_LIMIT -> {
                ActionType.API
            }
            ActivityAction.FILE_UPLOAD, ActivityAction.FILE_DOWNLOAD -> {
                ActionType.CREATE
            }
            ActivityAction.SEARCH, ActivityAction.FILTER, ActivityAction.SORT -> {
                ActionType.READ
            }
            ActivityAction.VIEW, ActivityAction.READ -> {
                ActionType.READ
            }
            ActivityAction.EDIT, ActivityAction.UPDATE -> {
                ActionType.UPDATE
            }
            ActivityAction.DELETE -> {
                ActionType.DELETE
            }
            else -> ActionType.OTHER
        }
    }
    
    private fun parseUserAgent(userAgent: String?): UserAgentInfo? {
        return try {
            if (userAgent == null) return null
            
            // Simple user agent parsing - in production, use a proper library
            val isMobile = userAgent.contains("Mobile", ignoreCase = true)
            val isTablet = userAgent.contains("Tablet", ignoreCase = true)
            val isDesktop = !isMobile && !isTablet
            
            UserAgentInfo(
                browser = extractBrowser(userAgent),
                browserVersion = extractBrowserVersion(userAgent),
                os = extractOS(userAgent),
                osVersion = extractOSVersion(userAgent),
                device = extractDevice(userAgent),
                isMobile = isMobile,
                isTablet = isTablet,
                isDesktop = isDesktop
            )
        } catch (e: Exception) {
            null
        }
    }
    
    private fun extractBrowser(userAgent: String): String? {
        return when {
            userAgent.contains("Chrome", ignoreCase = true) -> "Chrome"
            userAgent.contains("Firefox", ignoreCase = true) -> "Firefox"
            userAgent.contains("Safari", ignoreCase = true) -> "Safari"
            userAgent.contains("Edge", ignoreCase = true) -> "Edge"
            userAgent.contains("Opera", ignoreCase = true) -> "Opera"
            else -> null
        }
    }
    
    private fun extractBrowserVersion(userAgent: String): String? {
        return try {
            val browser = extractBrowser(userAgent)
            if (browser != null) {
                val pattern = "$browser[\\s/]([\\d.]+)".toRegex()
                val match = pattern.find(userAgent)
                match?.groupValues?.get(1)
            } else null
        } catch (e: Exception) {
            null
        }
    }
    
    private fun extractOS(userAgent: String): String? {
        return when {
            userAgent.contains("Windows", ignoreCase = true) -> "Windows"
            userAgent.contains("Mac", ignoreCase = true) -> "macOS"
            userAgent.contains("Linux", ignoreCase = true) -> "Linux"
            userAgent.contains("Android", ignoreCase = true) -> "Android"
            userAgent.contains("iOS", ignoreCase = true) -> "iOS"
            else -> null
        }
    }
    
    private fun extractOSVersion(userAgent: String): String? {
        return try {
            val os = extractOS(userAgent)
            if (os != null) {
                val pattern = "$os[\\s/]([\\d._]+)".toRegex()
                val match = pattern.find(userAgent)
                match?.groupValues?.get(1)?.replace("_", ".")
            } else null
        } catch (e: Exception) {
            null
        }
    }
    
    private fun extractDevice(userAgent: String): String? {
        return try {
            // Simple device extraction
            when {
                userAgent.contains("iPhone", ignoreCase = true) -> "iPhone"
                userAgent.contains("iPad", ignoreCase = true) -> "iPad"
                userAgent.contains("Android", ignoreCase = true) -> "Android Device"
                userAgent.contains("Windows", ignoreCase = true) -> "Windows PC"
                userAgent.contains("Mac", ignoreCase = true) -> "Mac"
                else -> null
            }
        } catch (e: Exception) {
            null
        }
    }
    
    private fun parseLocation(location: String?): GeoLocation? {
        return try {
            if (location == null) return null
            
            // Simple location parsing - in production, use a proper geocoding service
            GeoLocation(
                country = null,
                region = null,
                city = location,
                latitude = null,
                longitude = null,
                accuracy = null,
                timezone = null
            )
        } catch (e: Exception) {
            null
        }
    }
    
    private fun parseDeviceInfo(deviceId: String?): DeviceInfo? {
        return try {
            if (deviceId == null) return null
            
            DeviceInfo(
                deviceId = deviceId,
                deviceType = null,
                deviceModel = null,
                deviceBrand = null,
                osVersion = null,
                appVersion = null,
                screenSize = null,
                isRooted = null,
                isEmulator = null
            )
        } catch (e: Exception) {
            null
        }
    }
    
    private fun parseSessionInfo(sessionId: String?): SessionInfo? {
        return try {
            if (sessionId == null) return null
            
            SessionInfo(
                sessionId = sessionId,
                sessionStartTime = null,
                sessionDuration = null,
                sessionActivityCount = null,
                lastActivityTime = null,
                isNewSession = null
            )
        } catch (e: Exception) {
            null
        }
    }
}

@Singleton
class GetActivityLogsUseCase @Inject constructor(
    private val activityLogRepository: ActivityLogRepository
) {
    suspend operator fun invoke(
        filters: ActivityLogFilters = ActivityLogFilters()
    ): Result<List<ActivityLog>> {
        return activityLogRepository.getActivityLogs(filters)
    }
}

