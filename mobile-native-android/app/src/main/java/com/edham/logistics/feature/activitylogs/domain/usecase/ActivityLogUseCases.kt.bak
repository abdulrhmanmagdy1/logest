// Convenience use cases for common logging scenarios

@Singleton
class LogLoginUseCase @Inject constructor(
    private val logActivityUseCase: LogActivityUseCase
) {
    suspend operator fun invoke(
        userId: String,
        userRole: UserRole,
        userName: String,
        userEmail: String,
        success: Boolean,
        ipAddress: String?,
        userAgent: String?,
        deviceId: String?,
        location: String?,
        sessionId: String?,
        errorMessage: String? = null
    ): Result<ActivityLog> {
        return logActivityUseCase(
            userId = userId,
            userRole = userRole,
            userName = userName,
            userEmail = userEmail,
            action = if (success) ActivityAction.LOGIN else ActivityAction.FAILED_LOGIN,
            entityType = EntityType.USER,
            entityId = userId,
            entityName = userName,
            description = if (success) "User logged in successfully" else "User login failed",
            details = mapOf(
                "success" to success,
                "sessionId" to sessionId
            ),
            ipAddress = ipAddress,
            userAgent = userAgent,
            deviceId = deviceId,
            location = location,
            sessionId = sessionId,
            success = success,
            errorMessage = errorMessage,
            severity = if (success) LogSeverity.INFO else LogSeverity.WARNING,
            source = LogSource.MOBILE
        )
    }
}

@Singleton
class LogLogoutUseCase @Inject constructor(
    private val logActivityUseCase: LogActivityUseCase
) {
    suspend operator fun invoke(
        userId: String,
        userRole: UserRole,
        userName: String,
        userEmail: String,
        sessionId: String?,
        ipAddress: String?,
        userAgent: String?,
        deviceId: String?,
        location: String?
    ): Result<ActivityLog> {
        return logActivityUseCase(
            userId = userId,
            userRole = userRole,
            userName = userName,
            userEmail = userEmail,
            action = ActivityAction.LOGOUT,
            entityType = EntityType.USER,
            entityId = userId,
            entityName = userName,
            description = "User logged out",
            details = mapOf(
                "sessionId" to sessionId
            ),
            ipAddress = ipAddress,
            userAgent = userAgent,
            deviceId = deviceId,
            location = location,
            sessionId = sessionId,
            success = true,
            severity = LogSeverity.INFO,
            source = LogSource.MOBILE
        )
    }
}

@Singleton
class LogShipmentCreationUseCase @Inject constructor(
    private val logActivityUseCase: LogActivityUseCase
) {
    suspend operator fun invoke(
        userId: String,
        userRole: UserRole,
        userName: String,
        userEmail: String,
        shipmentId: String,
        shipmentName: String,
        details: Map<String, Any> = emptyMap(),
        ipAddress: String?,
        userAgent: String?,
        deviceId: String?,
        location: String?,
        sessionId: String?
    ): Result<ActivityLog> {
        return logActivityUseCase(
            userId = userId,
            userRole = userRole,
            userName = userName,
            userEmail = userEmail,
            action = ActivityAction.SHIPMENT_CREATE,
            entityType = EntityType.SHIPMENT,
            entityId = shipmentId,
            entityName = shipmentName,
            description = "Shipment created",
            details = details,
            ipAddress = ipAddress,
            userAgent = userAgent,
            deviceId = deviceId,
            location = location,
            sessionId = sessionId,
            success = true,
            severity = LogSeverity.INFO,
            source = LogSource.MOBILE
        )
    }
}

@Singleton
class LogShipmentStatusUpdateUseCase @Inject constructor(
    private val logActivityUseCase: LogActivityUseCase
) {
    suspend operator fun invoke(
        userId: String,
        userRole: UserRole,
        userName: String,
        userEmail: String,
        shipmentId: String,
        shipmentName: String,
        oldStatus: String,
        newStatus: String,
        details: Map<String, Any> = emptyMap(),
        ipAddress: String?,
        userAgent: String?,
        deviceId: String?,
        location: String?,
        sessionId: String?
    ): Result<ActivityLog> {
        return logActivityUseCase(
            userId = userId,
            userRole = userRole,
            userName = userName,
            userEmail = userEmail,
            action = ActivityAction.SHIPMENT_STATUS_UPDATE,
            entityType = EntityType.SHIPMENT,
            entityId = shipmentId,
            entityName = shipmentName,
            description = "Shipment status updated",
            details = details + mapOf(
                "oldStatus" to oldStatus,
                "newStatus" to newStatus
            ),
            ipAddress = ipAddress,
            userAgent = userAgent,
            deviceId = deviceId,
            location = location,
            sessionId = sessionId,
            success = true,
            severity = LogSeverity.INFO,
            source = LogSource.MOBILE
        )
    }
}

@Singleton
class LogPaymentUseCase @Inject constructor(
    private val logActivityUseCase: LogActivityUseCase
) {
    suspend operator fun invoke(
        userId: String,
        userRole: UserRole,
        userName: String,
        userEmail: String,
        paymentId: String,
        paymentAmount: Double,
        paymentMethod: String,
        success: Boolean,
        details: Map<String, Any> = emptyMap(),
        ipAddress: String?,
        userAgent: String?,
        deviceId: String?,
        location: String?,
        sessionId: String?,
        errorMessage: String? = null
    ): Result<ActivityLog> {
        val action = if (success) ActivityAction.PAYMENT_PROCESS else ActivityAction.PAYMENT_FAILED
        
        return logActivityUseCase(
            userId = userId,
            userRole = userRole,
            userName = userName,
            userEmail = userEmail,
            action = action,
            entityType = EntityType.PAYMENT,
            entityId = paymentId,
            entityName = "Payment: $paymentAmount",
            description = if (success) "Payment processed successfully" else "Payment failed",
            details = details + mapOf(
                "amount" to paymentAmount,
                "method" to paymentMethod,
                "success" to success
            ),
            ipAddress = ipAddress,
            userAgent = userAgent,
            deviceId = deviceId,
            location = location,
            sessionId = sessionId,
            success = success,
            errorMessage = errorMessage,
            severity = if (success) LogSeverity.INFO else LogSeverity.ERROR,
            source = LogSource.MOBILE
        )
    }
}
