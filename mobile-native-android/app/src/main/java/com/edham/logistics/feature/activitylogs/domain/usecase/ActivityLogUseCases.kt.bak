}

@Singleton
class SearchActivityLogsUseCase @Inject constructor(
    private val activityLogRepository: ActivityLogRepository
) {
    suspend operator fun invoke(
        query: String,
        filters: ActivityLogFilters = ActivityLogFilters()
    ): Result<List<ActivityLog>> {
        val searchFilters = filters.copy(searchQuery = query)
        return activityLogRepository.getActivityLogs(searchFilters)
    }
}

