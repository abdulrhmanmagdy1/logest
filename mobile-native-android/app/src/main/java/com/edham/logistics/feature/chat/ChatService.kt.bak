package com.edham.logistics.feature.chat

import android.content.Context
import androidx.lifecycle.LiveData
import androidx.lifecycle.MutableLiveData
import com.edham.logistics.data.local.database.ChatDatabase
import com.edham.logistics.data.remote.api.ChatApi
import kotlinx.coroutines.*
import kotlinx.coroutines.flow.MutableSharedFlow
import kotlinx.coroutines.flow.SharedFlow
import kotlinx.coroutines.flow.asSharedFlow
import timber.log.Timber
import java.util.*
import java.util.concurrent.ConcurrentHashMap

/**
 * Chat & Communication Service
 * Complete real-time communication system with WebSocket, media sharing, and group conversations
 */
class ChatService(
    private val context: Context,
    private val api: ChatApi,
    private val database: ChatDatabase
) {
    
    private val serviceScope = CoroutineScope(Dispatchers.IO + SupervisorJob())
    
    // LiveData for real-time chat data
    private val _messages = MutableLiveData<List<ChatMessage>>()
    val messages: LiveData<List<ChatMessage>> = _messages
    
    private val _conversations = MutableLiveData<List<Conversation>>()
    val conversations: LiveData<List<Conversation>> = _conversations
    
    private val _onlineUsers = MutableLiveData<Set<String>>()
    val onlineUsers: LiveData<Set<String>> = _onlineUsers
    
    private val _typingUsers = MutableLiveData<Map<String, TypingIndicator>>()
    val typingUsers: LiveData<Map<String, TypingIndicator>> = _typingUsers
    
    private val _unreadCounts = MutableLiveData<Map<String, Int>>()
    val unreadCounts: LiveData<Map<String, Int>> = _unreadCounts
    
    // WebSocket events
    private val _messageEvents = MutableSharedFlow<MessageEvent>()
    val messageEvents: SharedFlow<MessageEvent> = _messageEvents.asSharedFlow()
    
    private val _typingEvents = MutableSharedFlow<TypingEvent>()
    val typingEvents: SharedFlow<TypingEvent> = _typingEvents.asSharedFlow()
    
    private val _readReceiptEvents = MutableSharedFlow<ReadReceiptEvent>()
    val readReceiptEvents: SharedFlow<ReadReceiptEvent> = _readReceiptEvents.asSharedFlow()
    
    // In-memory caches
    private val messageCache = ConcurrentHashMap<String, MutableList<ChatMessage>>()
    private val conversationCache = ConcurrentHashMap<String, Conversation>()
    private val typingCache = ConcurrentHashMap<String, TypingIndicator>()
    private val onlineUserCache = ConcurrentHashMap<String, Long>()
    
    companion object {
        private const val MESSAGE_CACHE_SIZE = 1000
        private const val TYPING_TIMEOUT = 5000L // 5 seconds
        private const val ONLINE_TIMEOUT = 300000L // 5 minutes
        private const val WEBSOCKET_RECONNECT_DELAY = 5000L
        private const val MAX_FILE_SIZE = 10 * 1024 * 1024 // 10MB
    }
    
    /**
     * Initialize chat service
     */
    suspend fun initializeChat(userId: String, userRole: UserRole) {
        try {
            // Load conversations
            loadConversations(userId, userRole)
            
            // Connect to WebSocket
            connectWebSocket(userId, userRole)
            
            // Start cleanup tasks
            startCleanupTasks()
            
            Timber.d("Chat service initialized for user: $userId, role: $userRole")
            
        } catch (e: Exception) {
            Timber.e(e, "Error initializing chat service")
        }
    }
    
    /**
     * Load conversations from database
     */
    private suspend fun loadConversations(userId: String, userRole: UserRole) {
        try {
            val conversations = when (userRole) {
                UserRole.DRIVER -> database.conversationDao().getDriverConversations(userId)
                UserRole.DISPATCHER -> database.conversationDao().getDispatcherConversations(userId)
                UserRole.ADMIN -> database.conversationDao().getAllConversations()
                else -> emptyList()
            }
            
            // Cache conversations
            conversations.forEach { conversation ->
                conversationCache[conversation.id] = conversation
                messageCache[conversation.id] = mutableListOf()
            }
            
            _conversations.postValue(conversations)
            
            // Load messages for each conversation
            conversations.forEach { conversation ->
                loadMessages(conversation.id)
            }
            
            Timber.d("Loaded ${conversations.size} conversations")
            
        } catch (e: Exception) {
            Timber.e(e, "Error loading conversations")
        }
    }
    
    /**
     * Load messages for a conversation
     */
    private suspend fun loadMessages(conversationId: String) {
        try {
            val messages = database.messageDao().getConversationMessages(conversationId)
            messageCache[conversationId]?.addAll(messages)
            
            // Update LiveData if this is the active conversation
            _messages.value?.let { currentMessages ->
                if (currentMessages.isNotEmpty() && currentMessages.first().conversationId == conversationId) {
                    _messages.postValue(messages)
                }
            }
            
            Timber.d("Loaded ${messages.size} messages for conversation: $conversationId")
            
        } catch (e: Exception) {
            Timber.e(e, "Error loading messages for conversation: $conversationId")
        }
    }
    
    /**
     * Connect to WebSocket for real-time messaging
     */
    private suspend fun connectWebSocket(userId: String, userRole: UserRole) {
        try {
            // Connect to WebSocket
            val webSocketUrl = "${api.getWebSocketBaseUrl()}/chat/$userId"
            
            // Implementation would connect to WebSocket
            // For now, simulate connection
            serviceScope.launch {
                while (true) {
                    try {
                        // Simulate receiving messages
                        delay(10000) // Check every 10 seconds
                        
                        // Clean up offline users
                        cleanupOfflineUsers()
                        
                    } catch (e: Exception) {
                        Timber.e(e, "WebSocket connection error")
                        delay(WEBSOCKET_RECONNECT_DELAY)
                    }
                }
            }
            
            Timber.d("WebSocket connected for user: $userId")
            
        } catch (e: Exception) {
            Timber.e(e, "Error connecting to WebSocket")
        }
    }
    
    /**
     * Send text message
     */
    suspend fun sendMessage(
        conversationId: String,
        text: String,
        senderId: String,
        senderRole: UserRole,
        messageType: MessageType = MessageType.TEXT
    ): Boolean {
        try {
            val message = ChatMessage(
                id = UUID.randomUUID().toString(),
                conversationId = conversationId,
                senderId = senderId,
                senderRole = senderRole,
                content = text,
                messageType = messageType,
                timestamp = System.currentTimeMillis(),
                isRead = false,
                isDelivered = false
            )
            
            // Send to API
            val response = api.sendMessage(message)
            
            if (response.isSuccessful) {
                // Save to database
                database.messageDao().insertMessage(message)
                
                // Add to cache
                messageCache.getOrPut(conversationId) { mutableListOf() }.add(message)
                
                // Update LiveData
                updateMessagesLiveData(conversationId)
                
                // Emit event
                _messageEvents.emit(MessageEvent.MessageSent(message))
                
                Timber.d("Message sent successfully: ${message.id}")
                return true
            }
            
        } catch (e: Exception) {
            Timber.e(e, "Error sending message")
        }
        
        return false
    }
    
    /**
     * Send voice note
     */
    suspend fun sendVoiceNote(
        conversationId: String,
        audioFile: String,
        duration: Long,
        senderId: String,
        senderRole: UserRole
    ): Boolean {
        try {
            // Upload audio file
            val uploadResponse = api.uploadMedia(audioFile)
            
            if (uploadResponse.isSuccessful) {
                val mediaUrl = uploadResponse.body()?.url ?: return false
                
                val message = ChatMessage(
                    id = UUID.randomUUID().toString(),
                    conversationId = conversationId,
                    senderId = senderId,
                    senderRole = senderRole,
                    content = mediaUrl,
                    messageType = MessageType.VOICE_NOTE,
                    timestamp = System.currentTimeMillis(),
                    isRead = false,
                    isDelivered = false,
                    metadata = MessageMetadata(
                        duration = duration,
                        fileSize = java.io.File(audioFile).length()
                    )
                )
                
                // Send message
                return sendMessage(conversationId, mediaUrl, senderId, senderRole, MessageType.VOICE_NOTE)
            }
            
        } catch (e: Exception) {
            Timber.e(e, "Error sending voice note")
        }
        
        return false
    }
    
    /**
     * Send image/file
     */
    suspend fun sendFile(
        conversationId: String,
        filePath: String,
        fileName: String,
        senderId: String,
        senderRole: UserRole
    ): Boolean {
        try {
            val file = java.io.File(filePath)
            
            // Check file size
            if (file.length() > MAX_FILE_SIZE) {
                Timber.e("File size exceeds limit: ${file.length()}")
                return false
            }
            
            // Upload file
            val uploadResponse = api.uploadMedia(filePath)
            
            if (uploadResponse.isSuccessful) {
                val mediaUrl = uploadResponse.body()?.url ?: return false
                
                val messageType = when {
                    fileName.lowercase().endsWith(".jpg") ||
                    fileName.lowercase().endsWith(".png") ||
                    fileName.lowercase().endsWith(".gif") -> MessageType.IMAGE
                    fileName.lowercase().endsWith(".mp4") ||
                    fileName.lowercase().endsWith(".mov") -> MessageType.VIDEO
                    else -> MessageType.FILE
                }
                
                val message = ChatMessage(
                    id = UUID.randomUUID().toString(),
                    conversationId = conversationId,
                    senderId = senderId,
                    senderRole = senderRole,
                    content = mediaUrl,
                    messageType = messageType,
                    timestamp = System.currentTimeMillis(),
                    isRead = false,
                    isDelivered = false,
                    metadata = MessageMetadata(
                        fileName = fileName,
                        fileSize = file.length()
                    )
                )
                
                // Send message
                return sendMessage(conversationId, mediaUrl, senderId, senderRole, messageType)
            }
            
        } catch (e: Exception) {
            Timber.e(e, "Error sending file")
        }
        
        return false
    }
    
    /**
     * Share location
     */
    suspend fun shareLocation(
        conversationId: String,
        latitude: Double,
        longitude: Double,
        address: String,
        senderId: String,
        senderRole: UserRole
    ): Boolean {
        try {
            val locationData = LocationData(
                latitude = latitude,
                longitude = longitude,
                address = address,
                timestamp = System.currentTimeMillis()
            )
            
            val message = ChatMessage(
                id = UUID.randomUUID().toString(),
                conversationId = conversationId,
                senderId = senderId,
                senderRole = senderRole,
                content = "📍 Shared Location: $address",
                messageType = MessageType.LOCATION,
                timestamp = System.currentTimeMillis(),
                isRead = false,
                isDelivered = false,
                metadata = MessageMetadata(locationData = locationData)
            )
            
            return sendMessage(conversationId, message.content, senderId, senderRole, MessageType.LOCATION)
            
        } catch (e: Exception) {
            Timber.e(e, "Error sharing location")
        }
        
        return false
    }
    
    /**
     * Send emergency broadcast
     */
    suspend fun sendEmergencyBroadcast(
        message: String,
        priority: EmergencyPriority,
        senderId: String,
        senderRole: UserRole,
        targetRoles: List<UserRole> = listOf(UserRole.DRIVER, UserRole.DISPATCHER, UserRole.ADMIN)
    ): Boolean {
        try {
            val emergencyMessage = EmergencyMessage(
                id = UUID.randomUUID().toString(),
                senderId = senderId,
                senderRole = senderRole,
                message = message,
                priority = priority,
                targetRoles = targetRoles,
                timestamp = System.currentTimeMillis(),
                isRead = false
            )
            
            val response = api.sendEmergencyBroadcast(emergencyMessage)
            
            if (response.isSuccessful) {
                // Save to database
                database.emergencyMessageDao().insertEmergencyMessage(emergencyMessage)
                
                // Emit event
                _messageEvents.emit(MessageEvent.EmergencyBroadcast(emergencyMessage))
                
                Timber.d("Emergency broadcast sent: ${emergencyMessage.id}")
                return true
            }
            
        } catch (e: Exception) {
            Timber.e(e, "Error sending emergency broadcast")
        }
        
        return false
    }
    
    /**
     * Create group conversation
     */
    suspend fun createGroupConversation(
        name: String,
        description: String,
        participantIds: List<String>,
        creatorId: String,
        creatorRole: UserRole
    ): String? {
        try {
            val conversation = Conversation(
                id = UUID.randomUUID().toString(),
                name = name,
                description = description,
                type = ConversationType.GROUP,
                participantIds = participantIds,
                creatorId = creatorId,
                creatorRole = creatorRole,
                createdAt = System.currentTimeMillis(),
                lastMessageAt = System.currentTimeMillis(),
                unreadCount = 0
            )
            
            val response = api.createConversation(conversation)
            
            if (response.isSuccessful) {
                val createdConversation = response.body()
                if (createdConversation != null) {
                    // Save to database
                    database.conversationDao().insertConversation(createdConversation)
                    
                    // Cache conversation
                    conversationCache[createdConversation.id] = createdConversation
                    messageCache[createdConversation.id] = mutableListOf()
                    
                    // Update LiveData
                    val currentConversations = _conversations.value?.toMutableList() ?: mutableListOf()
                    currentConversations.add(0, createdConversation)
                    _conversations.postValue(currentConversations)
                    
                    Timber.d("Group conversation created: ${createdConversation.id}")
                    return createdConversation.id
                }
            }
            
        } catch (e: Exception) {
            Timber.e(e, "Error creating group conversation")
        }
        
        return null
    }
    
    /**
     * Send typing indicator
     */
    suspend fun sendTypingIndicator(
        conversationId: String,
        userId: String,
        isTyping: Boolean
    ) {
        try {
            val typingIndicator = TypingIndicator(
                userId = userId,
                conversationId = conversationId,
                isTyping = isTyping,
                timestamp = System.currentTimeMillis()
            )
            
            // Send to API
            api.sendTypingIndicator(typingIndicator)
            
            // Update local cache
            if (isTyping) {
                typingCache[userId] = typingIndicator
            } else {
                typingCache.remove(userId)
            }
            
            // Update LiveData
            _typingUsers.postValue(typingCache.toMap())
            
            // Emit event
            _typingEvents.emit(TypingEvent.TypingChanged(typingIndicator))
            
        } catch (e: Exception) {
            Timber.e(e, "Error sending typing indicator")
        }
    }
    
    /**
     * Mark messages as read
     */
    suspend fun markMessagesAsRead(
        conversationId: String,
        messageIds: List<String>,
        readerId: String
    ) {
        try {
            messageIds.forEach { messageId ->
                val readReceipt = ReadReceipt(
                    id = UUID.randomUUID().toString(),
                    messageId = messageId,
                    readerId = readerId,
                    readAt = System.currentTimeMillis()
                )
                
                // Send to API
                api.sendReadReceipt(readReceipt)
                
                // Save to database
                database.readReceiptDao().insertReadReceipt(readReceipt)
                
                // Update message in cache
                messageCache[conversationId]?.find { it.id == messageId }?.isRead = true
                
                // Emit event
                _readReceiptEvents.emit(ReadReceiptEvent.MessageRead(readReceipt))
            }
            
            // Update unread count
            updateUnreadCount(conversationId)
            
            Timber.d("Marked ${messageIds.size} messages as read")
            
        } catch (e: Exception) {
            Timber.e(e, "Error marking messages as read")
        }
    }
    
    /**
     * Update unread count for conversation
     */
    private suspend fun updateUnreadCount(conversationId: String) {
        try {
            val messages = messageCache[conversationId] ?: return
            val unreadCount = messages.count { !it.isRead }
            
            // Update conversation
            conversationCache[conversationId]?.unreadCount = unreadCount
            database.conversationDao().updateUnreadCount(conversationId, unreadCount)
            
            // Update unread counts LiveData
            val currentCounts = _unreadCounts.value?.toMutableMap() ?: mutableMapOf()
            currentCounts[conversationId] = unreadCount
            _unreadCounts.postValue(currentCounts)
            
        } catch (e: Exception) {
            Timber.e(e, "Error updating unread count")
        }
    }
    
    /**
     * Get messages for conversation with pagination
     */
    suspend fun getMessages(
        conversationId: String,
        limit: Int = 50,
        offset: Int = 0
    ): List<ChatMessage> {
        return try {
            val cachedMessages = messageCache[conversationId] ?: emptyList()
            
            if (offset == 0 && cachedMessages.size <= limit) {
                cachedMessages
            } else {
                // Load from database for pagination
                database.messageDao().getMessagesPaginated(conversationId, limit, offset)
            }
            
        } catch (e: Exception) {
            Timber.e(e, "Error getting messages")
            emptyList()
        }
    }
    
    /**
     * Search messages
     */
    suspend fun searchMessages(
        conversationId: String,
        query: String
    ): List<ChatMessage> {
        return try {
            database.messageDao().searchMessages(conversationId, "%$query%")
        } catch (e: Exception) {
            Timber.e(e, "Error searching messages")
            emptyList()
        }
    }
    
    /**
     * Update online users
     */
    private fun updateOnlineUsers(userId: String) {
        onlineUserCache[userId] = System.currentTimeMillis()
        _onlineUsers.postValue(onlineUserCache.keys.toSet())
    }
    
    /**
     * Clean up offline users
     */
    private fun cleanupOfflineUsers() {
        val currentTime = System.currentTimeMillis()
        val offlineUsers = onlineUserCache.filter { (_, lastSeen) ->
            currentTime - lastSeen > ONLINE_TIMEOUT
        }.keys
        
        offlineUsers.forEach { userId ->
            onlineUserCache.remove(userId)
        }
        
        if (offlineUsers.isNotEmpty()) {
            _onlineUsers.postValue(onlineUserCache.keys.toSet())
            Timber.d("Removed ${offlineUsers.size} offline users")
        }
    }
    
    /**
     * Clean up expired typing indicators
     */
    private fun cleanupTypingIndicators() {
        val currentTime = System.currentTimeMillis()
        val expiredTyping = typingCache.filter { (_, indicator) ->
            currentTime - indicator.timestamp > TYPING_TIMEOUT
        }.keys
        
        expiredTyping.forEach { userId ->
            typingCache.remove(userId)
        }
        
        if (expiredTyping.isNotEmpty()) {
            _typingUsers.postValue(typingCache.toMap())
            Timber.d("Cleaned up ${expiredTyping.size} expired typing indicators")
        }
    }
    
    /**
     * Update messages LiveData
     */
    private fun updateMessagesLiveData(conversationId: String) {
        val messages = messageCache[conversationId] ?: return
        _messages.postValue(messages)
    }
    
    /**
     * Start cleanup tasks
     */
    private fun startCleanupTasks() {
        serviceScope.launch {
            while (true) {
                try {
                    delay(30000) // Every 30 seconds
                    
                    // Clean up offline users
                    cleanupOfflineUsers()
                    
                    // Clean up expired typing indicators
                    cleanupTypingIndicators()
                    
                    // Clean up old messages
                    cleanupOldMessages()
                    
                } catch (e: Exception) {
                    Timber.e(e, "Error in cleanup task")
                }
            }
        }
    }
    
    /**
     * Clean up old messages
     */
    private suspend fun cleanupOldMessages() {
        try {
            messageCache.values.forEach { messages ->
                if (messages.size > MESSAGE_CACHE_SIZE) {
                    val messagesToRemove = messages.drop(MESSAGE_CACHE_SIZE)
                    messagesToRemove.forEach { message ->
                        database.messageDao().deleteMessage(message.id)
                    }
                    messages.removeAll(messagesToRemove)
                }
            }
            
        } catch (e: Exception) {
            Timber.e(e, "Error cleaning up old messages")
        }
    }
    
    /**
     * Get conversation by ID
     */
    fun getConversation(conversationId: String): Conversation? {
        return conversationCache[conversationId]
    }
    
    /**
     * Get unread count for conversation
     */
    fun getUnreadCount(conversationId: String): Int {
        return _unreadCounts.value?.get(conversationId) ?: 0
    }
    
    /**
     * Get total unread count
     */
    fun getTotalUnreadCount(): Int {
        return _unreadCounts.value?.values?.sum() ?: 0
    }
    
    /**
     * Cleanup resources
     */
    fun cleanup() {
        serviceScope.cancel()
        
        // Clear caches
        messageCache.clear()
        conversationCache.clear()
        typingCache.clear()
        onlineUserCache.clear()
        
        Timber.d("Chat service cleaned up")
    }
}

// Data classes
data class ChatMessage(
    val id: String,
    val conversationId: String,
    val senderId: String,
    val senderRole: UserRole,
    val content: String,
    val messageType: MessageType,
    val timestamp: Long,
    var isRead: Boolean = false,
    var isDelivered: Boolean = false,
    val metadata: MessageMetadata? = null
)

data class Conversation(
    val id: String,
    val name: String,
    val description: String,
    val type: ConversationType,
    val participantIds: List<String>,
    val creatorId: String,
    val creatorRole: UserRole,
    val createdAt: Long,
    var lastMessageAt: Long,
    var unreadCount: Int,
    val lastMessage: String? = null,
    val isActive: Boolean = true
)

data class TypingIndicator(
    val userId: String,
    val conversationId: String,
    val isTyping: Boolean,
    val timestamp: Long
)

data class ReadReceipt(
    val id: String,
    val messageId: String,
    val readerId: String,
    val readAt: Long
)

data class EmergencyMessage(
    val id: String,
    val senderId: String,
    val senderRole: UserRole,
    val message: String,
    val priority: EmergencyPriority,
    val targetRoles: List<UserRole>,
    val timestamp: Long,
    var isRead: Boolean = false
)

data class MessageMetadata(
    val fileName: String? = null,
    val fileSize: Long? = null,
    val duration: Long? = null,
    val locationData: LocationData? = null
)

data class LocationData(
    val latitude: Double,
    val longitude: Double,
    val address: String,
    val timestamp: Long
)

// Enums
enum class MessageType {
    TEXT, IMAGE, VIDEO, FILE, VOICE_NOTE, LOCATION, SYSTEM
}

enum class ConversationType {
    DIRECT, GROUP, BROADCAST
}

enum class UserRole {
    DRIVER, DISPATCHER, ADMIN, CUSTOMER, WORKSHOP, ACCOUNTANT
}

enum class EmergencyPriority {
    LOW, MEDIUM, HIGH, CRITICAL
}

// Events
sealed class MessageEvent {
    data class MessageSent(val message: ChatMessage) : MessageEvent()
    data class MessageReceived(val message: ChatMessage) : MessageEvent()
    data class MessageDelivered(val messageId: String) : MessageEvent()
    data class EmergencyBroadcast(val emergencyMessage: EmergencyMessage) : MessageEvent()
}

sealed class TypingEvent {
    data class TypingChanged(val indicator: TypingIndicator) : TypingEvent()
    data class TypingStopped(val userId: String) : TypingEvent()
}

sealed class ReadReceiptEvent {
    data class MessageRead(val receipt: ReadReceipt) : ReadReceiptEvent()
    data class AllMessagesRead(val conversationId: String, val userId: String) : ReadReceiptEvent()
}
