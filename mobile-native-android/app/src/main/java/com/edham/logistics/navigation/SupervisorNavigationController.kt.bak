package com.edham.logistics.navigation

import android.content.Context
import android.content.Intent
import androidx.fragment.app.Fragment
import androidx.navigation.NavController
import androidx.navigation.fragment.NavHostFragment
import com.edham.logistics.R
import com.edham.logistics.ui.drivers.DriversFragment
import com.edham.logistics.ui.shipments.ShipmentsFragment
import com.edham.logistics.ui.tasks.TasksFragment
import com.edham.logistics.ui.notifications.NotificationCenterFragment
import com.edham.logistics.ui.reports.ReportsFragment
import com.edham.logistics.ui.settings.SettingsFragment
import com.edham.logistics.ui.inventory.InventoryFragment
import com.edham.logistics.ui.payments.PaymentsFragment
import com.edham.logistics.ui.support.CustomerSupportFragment
import com.edham.logistics.ui.security.SecurityFragment

class SupervisorNavigationController(
    private val context: Context,
    private val navController: NavController
) {

    fun navigateToMenuItem(menuItemId: String) {
        when (menuItemId) {
            "dashboard" -> {
                // Already on dashboard
                navController.popBackStack(R.id.supervisorDashboardEnhancedFragment, false)
            }
            "drivers" -> {
                navigateToFragment(DriversFragment())
            }
            "shipments" -> {
                navigateToFragment(ShipmentsFragment())
            }
            "tasks" -> {
                navigateToFragment(TasksFragment())
            }
            "notifications" -> {
                navigateToFragment(NotificationCenterFragment())
            }
            "reports" -> {
                navigateToFragment(ReportsFragment())
            }
            "settings" -> {
                navigateToFragment(SettingsFragment())
            }
            "inventory" -> {
                navigateToFragment(InventoryFragment())
            }
            "payments" -> {
                navigateToFragment(PaymentsFragment())
            }
            "support" -> {
                navigateToFragment(CustomerSupportFragment())
            }
            "security" -> {
                navigateToFragment(SecurityFragment())
            }
        }
    }

    private fun navigateToFragment(fragment: Fragment) {
        val activity = context as? androidx.fragment.app.FragmentActivity
        val transaction = activity?.supportFragmentManager?.beginTransaction()
        
        transaction?.apply {
            replace(R.id.fragment_container, fragment)
            addToBackStack(null)
            commit()
        }
    }

    fun navigateToAddDriver() {
        // Navigate to add driver screen
        val intent = Intent(context, AddDriverActivity::class.java)
        context.startActivity(intent)
    }

    fun navigateToNewShipment() {
        // Navigate to new shipment screen
        val intent = Intent(context, NewShipmentActivity::class.java)
        context.startActivity(intent)
    }

    fun navigateToQuickReport() {
        // Navigate to quick report screen
        val intent = Intent(context, QuickReportActivity::class.java)
        context.startActivity(intent)
    }

    fun navigateToNotifications() {
        navigateToMenuItem("notifications")
    }

    fun navigateToDriverDetails(driverId: String) {
        val intent = Intent(context, DriverDetailsActivity::class.java).apply {
            putExtra("driverId", driverId)
        }
        context.startActivity(intent)
    }

    fun navigateToShipmentDetails(shipmentId: String) {
        val intent = Intent(context, ShipmentDetailsActivity::class.java).apply {
            putExtra("shipmentId", shipmentId)
        }
        context.startActivity(intent)
    }

    fun navigateToTaskDetails(taskId: String) {
        val intent = Intent(context, TaskDetailsActivity::class.java).apply {
            putExtra("taskId", taskId)
        }
        context.startActivity(intent)
    }

    fun navigateToReportDetails(reportId: String) {
        val intent = Intent(context, ReportDetailsActivity::class.java).apply {
            putExtra("reportId", reportId)
        }
        context.startActivity(intent)
    }

    fun navigateToDriverTracking(driverId: String) {
        val intent = Intent(context, DriverTrackingActivity::class.java).apply {
            putExtra("driverId", driverId)
        }
        context.startActivity(intent)
    }

    fun navigateToShipmentTracking(shipmentId: String) {
        val intent = Intent(context, ShipmentTrackingActivity::class.java).apply {
            putExtra("shipmentId", shipmentId)
        }
        context.startActivity(intent)
    }

    fun navigateToFleetManagement() {
        val intent = Intent(context, FleetManagementActivity::class.java)
        context.startActivity(intent)
    }

    fun navigateToDispatchBoard() {
        val intent = Intent(context, DispatchBoardActivity::class.java)
        context.startActivity(intent)
    }

    fun navigateToLiveTracking() {
        val intent = Intent(context, LiveTrackingActivity::class.java)
        context.startActivity(intent)
    }

    fun navigateToAnalytics() {
        val intent = Intent(context, AnalyticsActivity::class.java)
        context.startActivity(intent)
    }

    fun navigateToUserManagement() {
        val intent = Intent(context, UserManagementActivity::class.java)
        context.startActivity(intent)
    }

    fun navigateToSystemConfiguration() {
        val intent = Intent(context, SystemConfigurationActivity::class.java)
        context.startActivity(intent)
    }

    fun navigateToBackupAndRestore() {
        val intent = Intent(context, BackupRestoreActivity::class.java)
        context.startActivity(intent)
    }

    fun navigateToAuditLogs() {
        val intent = Intent(context, AuditLogsActivity::class.java)
        context.startActivity(intent)
    }

    fun navigateToSystemMonitoring() {
        val intent = Intent(context, SystemMonitoringActivity::class.java)
        context.startActivity(intent)
    }

    fun navigateToHelpAndSupport() {
        val intent = Intent(context, HelpAndSupportActivity::class.java)
        context.startActivity(intent)
    }

    fun navigateToAbout() {
        val intent = Intent(context, AboutActivity::class.java)
        context.startActivity(intent)
    }

    fun logout() {
        // Clear user session and navigate to login
        val intent = Intent(context, LoginActivity::class.java).apply {
            flags = Intent.FLAG_ACTIVITY_NEW_TASK or Intent.FLAG_ACTIVITY_CLEAR_TASK
        }
        context.startActivity(intent)
    }

    fun getCurrentFragment(): Fragment? {
        return navController.currentDestination?.let { destination ->
            when (destination.id) {
                R.id.supervisorDashboardEnhancedFragment -> null // Current fragment
                R.id.driversFragment -> null
                R.id.shipmentsFragment -> null
                R.id.tasksFragment -> null
                R.id.notificationCenterFragment -> null
                R.id.reportsFragment -> null
                R.id.settingsFragment -> null
                else -> null
            }
        }
    }

    fun canGoBack(): Boolean {
        return navController.previousBackStackEntry != null
    }

    fun goBack() {
        if (canGoBack()) {
            navController.popBackStack()
        }
    }

    fun clearBackStack() {
        navController.popBackStack(R.id.supervisorDashboardEnhancedFragment, false)
    }
}
