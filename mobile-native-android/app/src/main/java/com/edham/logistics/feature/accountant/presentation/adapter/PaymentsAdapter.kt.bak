package com.edham.logistics.feature.accountant.presentation.adapter

import android.view.LayoutInflater
import android.view.ViewGroup
import androidx.recyclerview.widget.DiffUtil
import androidx.recyclerview.widget.ListAdapter
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.databinding.ItemPaymentBinding
import com.edham.logistics.feature.accountant.domain.model.Payment
import javax.inject.Inject

class PaymentsAdapter @Inject constructor(
    private val onPaymentAction: (Payment, String) -> Unit
) : ListAdapter<Payment, PaymentsAdapter.PaymentViewHolder>(PaymentDiffCallback()) {

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): PaymentViewHolder {
        val binding = ItemPaymentBinding.inflate(
            LayoutInflater.from(parent.context),
            parent,
            false
        )
        return PaymentViewHolder(binding)
    }

    override fun onBindViewHolder(holder: PaymentViewHolder, position: Int) {
        holder.bind(getItem(position))
    }

    inner class PaymentViewHolder(
        private val binding: ItemPaymentBinding
    ) : RecyclerView.ViewHolder(binding.root) {

        fun bind(payment: Payment) {
            binding.apply {
                textPaymentId.text = payment.id
                textInvoiceNumber.text = payment.invoiceNumber
                textCustomerName.text = payment.customerName
                textCustomerPhone.text = payment.customerPhone
                textAmount.text = formatCurrency(payment.amount)
                textStatus.text = formatPaymentStatus(payment.status)
                textPaymentDate.text = formatDate(payment.paymentDate)
                textPaymentMethod.text = formatPaymentMethod(payment.paymentMethod.name)
                
                // Set status color
                textStatus.setTextColor(getPaymentStatusColor(payment.status))
                
                // Show transaction ID if available
                if (payment.transactionId != null) {
                    textTransactionId.text = payment.transactionId
                    layoutTransactionId.visible()
                } else {
                    layoutTransactionId.gone()
                }
                
                // Show processed by info
                textProcessedBy.text = "بواسطة: ${payment.processedBy}"
                
                // Set click listeners
                buttonDetails.setOnClickListener {
                    onPaymentAction(payment, "details")
                }
                
                buttonRefund.setOnClickListener {
                    onPaymentAction(payment, "refund")
                }
                
                buttonInvoice.setOnClickListener {
                    onPaymentAction(payment, "invoice")
                }
                
                root.setOnClickListener {
                    onPaymentAction(payment, "details")
                }
                
                // Show/hide action buttons based on status
                buttonRefund.visibility = when (payment.status) {
                    com.edham.logistics.feature.accountant.domain.model.PaymentStatus.COMPLETED -> android.view.View.VISIBLE
                    else -> android.view.View.GONE
                }
            }
        }
        
        private fun formatPaymentStatus(status: com.edham.logistics.feature.accountant.domain.model.PaymentStatus): String {
            return when (status) {
                com.edham.logistics.feature.accountant.domain.model.PaymentStatus.PENDING -> "في انتظار"
                com.edham.logistics.feature.accountant.domain.model.PaymentStatus.COMPLETED -> "مكتمل"
                com.edham.logistics.feature.accountant.domain.model.PaymentStatus.FAILED -> "فشل"
                com.edham.logistics.feature.accountant.domain.model.PaymentStatus.CANCELLED -> "ملغي"
                com.edham.logistics.feature.accountant.domain.model.PaymentStatus.REFUNDED -> "مسترد"
            }
        }
        
        private fun formatPaymentMethod(method: String): String {
            return when (method) {
                "CASH" -> "نقدي"
                "BANK_TRANSFER" -> "تحويل بنكي"
                "CREDIT_CARD" -> "بطاقة ائتمان"
                "CHECK" -> "شيك"
                "ONLINE_PAYMENT" -> "دفع إلكتروني"
                "MOBILE_MONEY" -> "محفظة محمولة"
                else -> method
            }
        }
        
        private fun formatCurrency(amount: Double): String {
            return String.format("%.2f ريال", amount)
        }
        
        private fun formatDate(date: String): String {
            return date.substring(0, 10).replace("-", "/")
        }
        
        private fun getPaymentStatusColor(status: com.edham.logistics.feature.accountant.domain.model.PaymentStatus): Int {
            return when (status) {
                com.edham.logistics.feature.accountant.domain.model.PaymentStatus.PENDING -> android.graphics.Color.parseColor("#FF9800")
                com.edham.logistics.feature.accountant.domain.model.PaymentStatus.COMPLETED -> android.graphics.Color.parseColor("#4CAF50")
                com.edham.logistics.feature.accountant.domain.model.PaymentStatus.FAILED -> android.graphics.Color.parseColor("#F44336")
                com.edham.logistics.feature.accountant.domain.model.PaymentStatus.CANCELLED -> android.graphics.Color.parseColor("#9E9E9E")
                com.edham.logistics.feature.accountant.domain.model.PaymentStatus.REFUNDED -> android.graphics.Color.parseColor("#2196F3")
            }
        }
    }

    private class PaymentDiffCallback : DiffUtil.ItemCallback<Payment>() {
        override fun areItemsTheSame(oldItem: Payment, newItem: Payment): Boolean {
            return oldItem.id == newItem.id
        }

        override fun areContentsTheSame(oldItem: Payment, newItem: Payment): Boolean {
            return oldItem == newItem
        }
    }
}
