    /**
     * Initialize rule processors
     */
    private fun initializeRuleProcessors() {
        // Time-based rule processor
        ruleProcessors["TIME_BASED"] = TimeBasedRuleProcessor()
        
        // Event-based rule processor
        ruleProcessors["EVENT_BASED"] = EventBasedRuleProcessor()
        
        // Condition-based rule processor
        ruleProcessors["CONDITION_BASED"] = ConditionBasedRuleProcessor()
        
        // Location-based rule processor
        ruleProcessors["LOCATION_BASED"] = LocationBasedRuleProcessor()
        
        // Priority-based rule processor
        ruleProcessors["PRIORITY_BASED"] = PriorityBasedRuleProcessor()
        
        // Delay-based rule processor
        ruleProcessors["DELAY_BASED"] = DelayBasedRuleProcessor()
        
        // Temperature-based rule processor
        ruleProcessors["TEMPERATURE_BASED"] = TemperatureBasedRuleProcessor()
    }
    
    /**
     * Start automation system
     */
    fun startAutomation() {
        if (isRunning) return
        
        try {
            _automationState.value = AutomationState.Starting
            isRunning = true
            
            // Start rule processors
            ruleProcessors.values.forEach { processor ->
                processor.start()
            }
            
            // Start scheduled tasks
            startScheduledTasks()
            
            // Start monitoring
            startMonitoring()
            
            _automationState.value = AutomationState.Running
            
        } catch (e: Exception) {
            _automationState.value = AutomationState.Error("Failed to start automation: ${e.message}")
        }
    }
    
    /**
     * Stop automation system
     */
    fun stopAutomation() {
        if (!isRunning) return
        
        try {
            isRunning = false
            
            // Stop rule processors
            ruleProcessors.values.forEach { processor ->
                processor.stop()
            }
            
            // Stop scheduled tasks
            stopScheduledTasks()
            
            // Stop monitoring
            stopMonitoring()
            
            _automationState.value = AutomationState.Stopped
            
        } catch (e: Exception) {
            _automationState.value = AutomationState.Error("Failed to stop automation: ${e.message}")
        }
    }
    
