    }
    
    /**
     * Execute automation rule
     */
    suspend fun executeRule(ruleId: Long, context: AutomationContext): Result<Unit> {
        return withContext(Dispatchers.IO) {
            try {
                _automationState.value = AutomationState.ExecutingRule
                
                // Get rule
                // val ruleEntity = database.automationRuleDao().getRuleById(ruleId)
                //     ?: throw Exception("Rule not found")
                
                // val rule = convertToAutomationRule(ruleEntity)
                
                // Check if rule is active
                if (!rule.isActive) {
                    throw Exception("Rule is not active")
                }
                
                // Create execution record
                // val execution = AutomationExecutionEntity(
                //     id = 0,
                //     ruleId = ruleId,
                    ruleName = rule.name,
                    executionTime = Date(),
                    context = serializeContext(context),
                    status = ExecutionStatus.RUNNING,
                    result = null,
                    error = null,
                    duration = 0L,
                    createdAt = Date()
                )
                
                // val executionId = database.automationExecutionDao().insertExecution(execution)
                // val savedExecution = execution.copy(id = executionId)
                
                // Execute rule
                val startTime = System.currentTimeMillis()
                val result = executeRuleActions(rule, context)
                val endTime = System.currentTimeMillis()
                
                // Update execution record
                val updatedExecution = savedExecution.copy(
                    status = if (result.isSuccess) ExecutionStatus.SUCCESS else ExecutionStatus.FAILED,
                    result = result.getOrNull()?.toString(),
                    error = if (result.isFailure) result.exceptionOrNull()?.message else null,
                    duration = endTime - startTime
                )
                
                // database.automationExecutionDao().updateExecution(updatedExecution)
                
                // Update rule execution count
                // val updatedRule = ruleEntity.copy(
                //     executionCount = ruleEntity.executionCount + 1,
                //     lastExecuted = Date(),
                //     updatedAt = Date()
                // )
                // database.automationRuleDao().updateRule(updatedRule)
                
                // Update execution history
                // updateExecutionHistory()
                
                _automationState.value = AutomationState.RuleExecuted
                Result.success(Unit)
                
            } catch (e: Exception) {
                _automationState.value = AutomationState.Error("Failed to execute rule: ${e.message}")
                Result.failure(e)
            }
        }
    }
    
    /**
     * Get automation analytics
     */
    suspend fun getAutomationAnalytics(): AutomationAnalytics {
        return withContext(Dispatchers.IO) {
            val allRules = database.automationRuleDao().getAllRules()
            val allExecutions = database.automationExecutionDao().getAllExecutions()
            
            val totalRules = allRules.size
            val activeRules = allRules.count { it.isActive }
            val totalExecutions = allExecutions.size
            val successfulExecutions = allExecutions.count { it.status == ExecutionStatus.SUCCESS }
            val failedExecutions = allExecutions.count { it.status == ExecutionStatus.FAILED }
            val averageExecutionTime = calculateAverageExecutionTime(allExecutions)
            val ruleTypeDistribution = calculateRuleTypeDistribution(allRules)
            val mostExecutedRules = calculateMostExecutedRules(allRules)
            val executionTrends = calculateExecutionTrends(allExecutions)
            
            AutomationAnalytics(
                totalRules = totalRules,
                activeRules = activeRules,
                totalExecutions = totalExecutions,
                successRate = if (totalExecutions > 0) successfulExecutions.toFloat() / totalExecutions else 1f,
                averageExecutionTime = averageExecutionTime,
                ruleTypeDistribution = ruleTypeDistribution,
                mostExecutedRules = mostExecutedRules,
                executionTrends = executionTrends,
                automationEfficiency = calculateAutomationEfficiency(allExecutions)
            )
        }
    }
    
    /**
     * Helper functions
     */
    private fun loadAutomationRules() {
        val rules = database.automationRuleDao().getAllRules()
            .filter { it.isActive }
            .map { convertToAutomationRule(it) }
        
        _activeRules.value = rules
        
        // Register rules with processors
        rules.forEach { rule ->
            registerRuleWithProcessor(rule)
        }
    }
    
    private fun registerRuleWithProcessor(rule: AutomationRule) {
        val processor = ruleProcessors[rule.ruleType]
        processor?.registerRule(rule)
    }
    
    private fun validateRule(rule: CreateAutomationRuleRequest) {
        // Validate rule name
        if (rule.name.isBlank()) {
            throw Exception("Rule name is required")
        }
        
        // Validate rule type
        if (!ruleProcessors.containsKey(rule.ruleType)) {
            throw Exception("Invalid rule type: ${rule.ruleType}")
        }
        
        // Validate trigger conditions
        if (rule.triggerConditions.isEmpty()) {
            throw Exception("At least one trigger condition is required")
        }
        
        // Validate actions
        if (rule.actions.isEmpty()) {
            throw Exception("At least one action is required")
        }
    }
    
    private suspend fun executeRuleActions(rule: AutomationRule, context: AutomationContext): Result<Any> {
        return try {
            for (action in rule.actions) {
                when (action.type) {
                    ActionType.UPDATE_STATUS -> executeUpdateStatus(action, context)
                    ActionType.SEND_NOTIFICATION -> executeSendNotification(action, context)
                    ActionType.ASSIGN_DRIVER -> executeAssignDriver(action, context)
                    ActionType.ASSIGN_VEHICLE -> executeAssignVehicle(action, context)
                    ActionType.ESCALATE_PRIORITY -> executeEscalatePriority(action, context)
                    ActionType.CREATE_ALERT -> executeCreateAlert(action, context)
                    ActionType.SCHEDULE_PICKUP -> executeSchedulePickup(action, context)
                    ActionType.OPTIMIZE_ROUTE -> executeOptimizeRoute(action, context)
                    ActionType.GENERATE_REPORT -> executeGenerateReport(action, context)
                    ActionType.TRACK_SHIPMENT -> executeTrackShipment(action, context)
                    ActionType.CANCEL_SHIPMENT -> executeCancelShipment(action, context)
                    ActionType.DELAY_SHIPMENT -> executeDelayShipment(action, context)
                    ActionType.COMPLETE_SHIPMENT -> executeCompleteShipment(action, context)
                }
            }
            
            Result.success("Rule executed successfully")
            
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    private suspend fun executeUpdateStatus(action: AutomationAction, context: AutomationContext) {
        val shipmentId = context.shipmentId
        val newStatus = action.parameters["status"] as? String
            ?: throw Exception("Status parameter is required")
        
        val status = ShipmentStatus.valueOf(newStatus)
        val reason = action.parameters["reason"] as? String ?: "Automated status update"
        
        // Update shipment status
        val shipment = database.shipmentDao().getShipmentById(shipmentId)
            ?: throw Exception("Shipment not found")
        
        val updatedShipment = shipment.copy(
            status = status,
            updatedAt = Date(),
            updatedBy = "automation"
        )
        
        database.shipmentDao().updateShipment(updatedShipment)
    }
    
