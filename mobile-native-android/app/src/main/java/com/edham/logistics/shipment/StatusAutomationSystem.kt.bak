    private val _automationState = MutableStateFlow<AutomationState>(AutomationState.Idle)
    val automationState: StateFlow<AutomationState> = _automationState.asStateFlow()
    
    private val _activeRules = MutableStateFlow<List<AutomationRule>>(emptyList())
    val activeRules: StateFlow<List<AutomationRule>> = _activeRules.asStateFlow()
    
    private val _executionHistory = MutableStateFlow<List<AutomationExecutionEntity>>(emptyList())
    val executionHistory: StateFlow<List<AutomationExecutionEntity>> = _executionHistory.asStateFlow()
    
