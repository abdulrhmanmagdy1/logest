/**
 * Data classes
 */
data class AutomationRule(
    val id: Long,
    val name: String,
    val description: String,
    val ruleType: String,
    val triggerConditions: List<TriggerCondition>,
    val actions: List<AutomationAction>,
    val isActive: Boolean,
    val priority: Int,
    val executionCount: Int,
    val lastExecuted: Date?,
    val createdAt: Date,
    val updatedAt: Date
)

data class CreateAutomationRuleRequest(
    val name: String,
    val description: String,
    val ruleType: String,
    val triggerConditions: List<TriggerCondition>,
    val actions: List<AutomationAction>,
    val isActive: Boolean = true,
    val priority: Int = 0,
    val createdBy: String
)

data class TriggerCondition(
    val type: String,
    val parameters: Map<String, Any>,
    val operator: String,
    val value: Any
)

data class AutomationAction(
    val type: ActionType,
    val parameters: Map<String, Any>,
    val description: String
)

data class AutomationContext(
    val shipmentId: Long,
    val currentStatus: ShipmentStatus,
    val priority: Priority,
    val metadata: Map<String, Any> = emptyMap()
)

data class AutomationAnalytics(
    val totalRules: Int,
    val activeRules: Int,
    val totalExecutions: Int,
    val successRate: Float,
    val averageExecutionTime: Double,
    val ruleTypeDistribution: Map<String, Int>,
    val mostExecutedRules: List<AutomationRule>,
    val executionTrends: Map<String, Int>,
    val automationEfficiency: Float
)

data class ScheduledTask(
    val id: String,
    val name: String,
    val schedule: String,
    val ruleId: Long,
    val isActive: Boolean,
    val lastRun: Date?,
    val nextRun: Date?
)

/**
 * Enums
 */
enum class AutomationState {
    Idle,
    Starting,
    Running,
    CreatingRule,
    RuleCreated,
    ExecutingRule,
    RuleExecuted,
    Stopped,
    Error
}

enum class ActionType {
    UPDATE_STATUS,
    SEND_NOTIFICATION,
    ASSIGN_DRIVER,
    ASSIGN_VEHICLE,
    ESCALATE_PRIORITY,
    CREATE_ALERT,
    SCHEDULE_PICKUP,
    OPTIMIZE_ROUTE,
    GENERATE_REPORT,
    TRACK_SHIPMENT,
    CANCEL_SHIPMENT,
    DELAY_SHIPMENT,
    COMPLETE_SHIPMENT
}

enum class ExecutionStatus {
    RUNNING,
    SUCCESS,
    FAILED,
    TIMEOUT
}

/**
 * Rule Processor Interface
 */
interface RuleProcessor {
    fun start()
    fun stop()
    fun registerRule(rule: AutomationRule)
    fun unregisterRule(ruleId: Long)
}

/**
 * Rule Processor Implementations
 */
