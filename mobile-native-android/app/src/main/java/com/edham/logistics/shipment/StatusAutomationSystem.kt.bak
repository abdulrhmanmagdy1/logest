    private fun calculateAverageExecutionTime(executions: List<AutomationExecutionEntity>): Double {
        if (executions.isEmpty()) return 0.0
        
        val totalTime = executions.sumOf { it.duration }
        return totalTime.toDouble() / executions.size
    }
    
