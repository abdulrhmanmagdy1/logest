    val automationAnalytics: StateFlow<AutomationAnalytics?> = _automationAnalytics.asStateFlow()
    
    private var isRunning = false
    private var ruleProcessors: MutableMap<String, RuleProcessor> = mutableMapOf()
    private var scheduledTasks: MutableMap<String, ScheduledTask> = mutableMapOf()
    
