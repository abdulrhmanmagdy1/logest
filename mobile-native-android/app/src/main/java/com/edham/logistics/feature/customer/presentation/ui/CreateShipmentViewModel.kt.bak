package com.edham.logistics.feature.customer.presentation.ui

import androidx.lifecycle.viewModelScope
import com.edham.logistics.core.utils.Result
import com.edham.logistics.feature.customer.domain.usecase.CreateShipmentUseCase
import com.edham.logistics.feature.customer.domain.model.ShipmentCreationRequest
import com.edham.logistics.feature.customer.domain.model.CargoType
import com.edham.logistics.feature.customer.domain.model.ShipmentPriority
import com.edham.logistics.presentation.ui.base.BaseViewModel
import dagger.hilt.android.lifecycle.HiltViewModel
import kotlinx.coroutines.flow.MutableStateFlow
import kotlinx.coroutines.flow.StateFlow
import kotlinx.coroutines.flow.asStateFlow
import kotlinx.coroutines.launch
import javax.inject.Inject

@HiltViewModel
class CreateShipmentViewModel @Inject constructor(
    private val createShipmentUseCase: CreateShipmentUseCase
) : BaseViewModel<CreateShipmentViewModel.CreateShipmentUiState>() {

    private val _uiState = MutableStateFlow(CreateShipmentUiState())
    val uiState: StateFlow<CreateShipmentUiState> = _uiState.asStateFlow()

    override fun createInitialState(): CreateShipmentUiState = CreateShipmentUiState()

    init {
        loadCargoTypes()
        loadPriorities()
    }

    private fun loadCargoTypes() {
        val cargoTypes = listOf(
            CargoType("general", "بضائع عامة", "general", false, 1000.0, 2.0, 1.5),
            CargoType("refrigerated", "بضائع مبردة", "refrigerated", true, 800.0, 3.0, 2.0),
            CargoType("fragile", "بضائع قابلة للكسر", "fragile", false, 500.0, 4.0, 3.0),
            CargoType("heavy", "بضائع ثقيلة", "heavy", false, 2000.0, 1.5, 1.0),
            CargoType("urgent", "بضائع عاجلة", "urgent", false, 750.0, 2.5, 2.0),
            CargoType("documents", "مستندات", "documents", false, 200.0, 1.0, 0.8),
            CargoType("electronics", "إلكترونيات", "electronics", false, 600.0, 3.5, 2.5),
            CargoType("food", "مواد غذائية", "food", true, 700.0, 2.8, 2.2),
            CargoType("medical", "معدات طبية", "medical", false, 1200.0, 2.2, 1.8),
            CargoType("chemicals", "مواد كيميائية", "chemicals", false, 1500.0, 2.0, 1.5),
            CargoType("livestock", "مواشي", "livestock", false, 1800.0, 1.8, 1.2),
            CargoType("vehicles", "مركبات", "vehicles", false, 2500.0, 1.2, 0.8)
        )
        
        updateUiState { copy(cargoTypes = cargoTypes) }
    }

    private fun loadPriorities() {
        val priorities = listOf(
            ShipmentPriority("normal", "عادي", "normal", 1.0, "2-3 أيام", "ic_priority_normal"),
            ShipmentPriority("express", "سريع", "express", 1.5, "1-2 يوم", "ic_priority_express"),
            ShipmentPriority("urgent", "عاجل", "urgent", 2.0, "24 ساعة", "ic_priority_urgent"),
            ShipmentPriority("economy", "اقتصادي", "economy", 0.8, "4-5 أيام", "ic_priority_economy")
        )
        
        updateUiState { copy(priorities = priorities) }
    }

    fun updatePickupAddress(address: String, latitude: Double, longitude: Double) {
        updateUiState { 
            copy(
                pickupAddress = address,
                pickupLatitude = latitude,
                pickupLongitude = longitude
            ) 
        }
    }

    fun updateDeliveryAddress(address: String, latitude: Double, longitude: Double) {
        updateUiState { 
            copy(
                deliveryAddress = address,
                deliveryLatitude = latitude,
                deliveryLongitude = longitude
            ) 
        }
    }

    fun updateCargoType(cargoType: CargoType) {
        updateUiState { 
            copy(
                selectedCargoType = cargoType,
                temperature = if (cargoType.requiresTemperature) 4.0 else null
            ) 
        }
    }

    fun updateWeight(weight: String) {
        val weightValue = weight.toDoubleOrNull() ?: 0.0
        updateUiState { copy(weight = weightValue) }
    }

    fun updateNotes(notes: String) {
        updateUiState { copy(notes = notes) }
    }

    fun updatePriority(priority: ShipmentPriority) {
        updateUiState { copy(selectedPriority = priority) }
    }

    fun updateTemperature(temperature: String) {
        val tempValue = temperature.toDoubleOrNull()
        updateUiState { copy(temperature = tempValue) }
    }

    fun updateInsuranceValue(value: String) {
        val insuranceValue = value.toDoubleOrNull() ?: 0.0
        updateUiState { copy(insuranceValue = insuranceValue) }
    }

    fun createShipment() {
        val currentState = uiState.value
        
        if (!isValidShipmentData(currentState)) {
            updateUiState { copy(error = "يرجى ملء جميع الحقول المطلوبة") }
            return
        }

        val request = ShipmentCreationRequest(
            customerId = "customer_123", // In real app, get from session
            pickupAddress = currentState.pickupAddress,
            pickupLatitude = currentState.pickupLatitude,
            pickupLongitude = currentState.pickupLongitude,
            deliveryAddress = currentState.deliveryAddress,
            deliveryLatitude = currentState.deliveryLatitude,
            deliveryLongitude = currentState.deliveryLongitude,
            cargoType = currentState.selectedCargoType?.id ?: "",
            weight = currentState.weight,
            notes = currentState.notes,
            temperature = currentState.temperature,
            priority = currentState.selectedPriority?.id ?: "normal",
            insuranceValue = currentState.insuranceValue
        )

        viewModelScope.launch {
            updateUiState { copy(isCreating = true, error = null) }
            
            when (val result = createShipmentUseCase(request)) {
                is Result.Success -> {
                    updateUiState {
                        copy(
                            isCreating = false,
                            createdShipment = result.data,
                            error = null
                        )
                    }
                }
                is Result.Error -> {
                    updateUiState {
                        copy(
                            isCreating = false,
                            error = result.exception.message ?: "فشل إنشاء الشحنة"
                        )
                    }
                }
                is Result.Loading -> {
                    updateUiState { copy(isCreating = true) }
                }
            }
        }
    }

    private fun isValidShipmentData(state: CreateShipmentUiState): Boolean {
        return state.pickupAddress.isNotBlank() &&
                state.deliveryAddress.isNotBlank() &&
                state.selectedCargoType != null &&
                state.weight > 0 &&
                state.pickupLatitude != 0.0 &&
                state.pickupLongitude != 0.0 &&
                state.deliveryLatitude != 0.0 &&
                state.deliveryLongitude != 0.0
    }

    fun clearError() {
        updateUiState { copy(error = null) }
    }

    fun onShipmentCreatedHandled() {
        updateUiState { copy(createdShipment = null) }
    }

    fun resetForm() {
        updateUiState { 
            copy(
                pickupAddress = "",
                pickupLatitude = 0.0,
                pickupLongitude = 0.0,
                deliveryAddress = "",
                deliveryLatitude = 0.0,
                deliveryLongitude = 0.0,
                selectedCargoType = null,
                weight = 0.0,
                notes = "",
                temperature = null,
                selectedPriority = null,
                insuranceValue = 0.0,
                error = null
            ) 
        }
    }

    data class CreateShipmentUiState(
        val pickupAddress: String = "",
        val pickupLatitude: Double = 0.0,
        val pickupLongitude: Double = 0.0,
        val deliveryAddress: String = "",
        val deliveryLatitude: Double = 0.0,
        val deliveryLongitude: Double = 0.0,
        val selectedCargoType: CargoType? = null,
        val cargoTypes: List<CargoType> = emptyList(),
        val weight: Double = 0.0,
        val notes: String = "",
        val temperature: Double? = null,
        val selectedPriority: ShipmentPriority? = null,
        val priorities: List<ShipmentPriority> = emptyList(),
        val insuranceValue: Double = 0.0,
        val isCreating: Boolean = false,
        val createdShipment: com.edham.logistics.feature.customer.domain.model.CustomerShipment? = null,
        val error: String? = null
    ) : com.edham.logistics.presentation.ui.base.UiState {
        override fun copyLoading(isLoading: Boolean): UiState = copy(isCreating = isLoading)
        override fun copyError(error: String?): UiState = copy(error = error)
        override fun copySuccess(message: String?): UiState = this // Create shipment doesn't use success messages
    }
}
