package com.edham.logistics.feature.tracking.presentation.adapter

import android.view.LayoutInflater
import android.view.ViewGroup
import androidx.recyclerview.widget.DiffUtil
import androidx.recyclerview.widget.ListAdapter
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.databinding.ItemVehicleTrackingBinding
import com.edham.logistics.feature.tracking.domain.model.VehicleTracking
import javax.inject.Inject

class VehiclesAdapter @Inject constructor(
    private val onVehicleAction: (VehicleTracking, String) -> Unit
) : ListAdapter<VehicleTracking, VehiclesAdapter.VehicleViewHolder>(VehicleDiffCallback()) {

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): VehicleViewHolder {
        val binding = ItemVehicleTrackingBinding.inflate(
            LayoutInflater.from(parent.context),
            parent,
            false
        )
        return VehicleViewHolder(binding)
    }

    override fun onBindViewHolder(holder: VehicleViewHolder, position: Int) {
        holder.bind(getItem(position))
    }

    inner class VehicleViewHolder(
        private val binding: ItemVehicleTrackingBinding
    ) : RecyclerView.ViewHolder(binding.root) {

        fun bind(vehicle: VehicleTracking) {
            binding.apply {
                textVehicleLicensePlate.text = vehicle.vehicleLicensePlate
                textDriverName.text = vehicle.driverName
                textVehicleType.text = formatVehicleType(vehicle.vehicleType)
                textStatus.text = formatVehicleStatus(vehicle.status)
                textSpeed.text = "${vehicle.speed.toInt()} كم/س"
                textLastUpdate.text = formatTimestamp(vehicle.lastUpdate)
                
                // Set status color
                textStatus.setTextColor(getVehicleStatusColor(vehicle.status))
                
                // Show battery level if available
                vehicle.batteryLevel?.let { battery ->
                    textBatteryLevel.text = "${battery.toInt()}%"
                    progressBattery.progress = battery.toInt()
                    layoutBattery.visible()
                } ?: run {
                    layoutBattery.gone()
                }
                
                // Show fuel level if available
                vehicle.fuelLevel?.let { fuel ->
                    textFuelLevel.text = "${fuel.toInt()}%"
                    progressFuel.progress = fuel.toInt()
                    layoutFuel.visible()
                } ?: run {
                    layoutFuel.gone()
                }
                
                // Show current shipment if available
                vehicle.currentShipmentNumber?.let { shipmentNumber ->
                    textCurrentShipment.text = shipmentNumber
                    layoutCurrentShipment.visible()
                } ?: run {
                    layoutCurrentShipment.gone()
                }
                
                // Show online/offline status
                if (vehicle.isOnline) {
                    imageOnlineStatus.setImageResource(R.drawable.ic_online)
                    textOnlineStatus.text = "متصل"
                    textOnlineStatus.setTextColor(android.graphics.Color.parseColor("#4CAF50"))
                } else {
                    imageOnlineStatus.setImageResource(R.drawable.ic_offline)
                    textOnlineStatus.text = "غير متصل"
                    textOnlineStatus.setTextColor(android.graphics.Color.parseColor("#F44336"))
                }
                
                // Set click listeners
                root.setOnClickListener {
                    onVehicleAction(vehicle, "select")
                }
                
                buttonCenter.setOnClickListener {
                    onVehicleAction(vehicle, "center")
                }
                
                buttonDetails.setOnClickListener {
                    onVehicleAction(vehicle, "details")
                }
                
                vehicle.currentShipmentId?.let { shipmentId ->
                    buttonTrack.visible()
                    buttonTrack.setOnClickListener {
                        onVehicleAction(vehicle, "track")
                    }
                } ?: run {
                    buttonTrack.gone()
                }
            }
        }
        
        private fun formatVehicleType(type: String): String {
            return when (type) {
                "truck" -> "شاحنة"
                "van" -> "فان"
                "pickup" -> "بيك أب"
                "motorcycle" -> "دراجة نارية"
                "car" -> "سيارة"
                "trailer" -> "مقطورة"
                else -> type
            }
        }
        
        private fun formatVehicleStatus(status: com.edham.logistics.feature.tracking.domain.model.VehicleStatus): String {
            return when (status) {
                com.edham.logistics.feature.tracking.domain.model.VehicleStatus.IDLE -> "خامل"
                com.edham.logistics.feature.tracking.domain.model.VehicleStatus.MOVING -> "متحرك"
                com.edham.logistics.feature.tracking.domain.model.VehicleStatus.STOPPED -> "متوقف"
                com.edham.logistics.feature.tracking.domain.model.VehicleStatus.OFFLINE -> "غير متصل"
                com.edham.logistics.feature.tracking.domain.model.VehicleStatus.MAINTENANCE -> "صيانة"
                com.edham.logistics.feature.tracking.domain.model.VehicleStatus.BREAKDOWN -> "عطل"
            }
        }
        
        private fun formatTimestamp(timestamp: Long): String {
            val now = System.currentTimeMillis()
            val diff = now - timestamp
            
            return when {
                diff < 60000 -> "الآن"
                diff < 3600000 -> "${diff / 60000} دقيقة"
                diff < 86400000 -> "${diff / 3600000} ساعة"
                else -> "${diff / 86400000} يوم"
            }
        }
        
        private fun getVehicleStatusColor(status: com.edham.logistics.feature.tracking.domain.model.VehicleStatus): Int {
            return when (status) {
                com.edham.logistics.feature.tracking.domain.model.VehicleStatus.IDLE -> android.graphics.Color.parseColor("#FF9800")
                com.edham.logistics.feature.tracking.domain.model.VehicleStatus.MOVING -> android.graphics.Color.parseColor("#4CAF50")
                com.edham.logistics.feature.tracking.domain.model.VehicleStatus.STOPPED -> android.graphics.Color.parseColor("#F44336")
                com.edham.logistics.feature.tracking.domain.model.VehicleStatus.OFFLINE -> android.graphics.Color.parseColor("#9E9E9E")
                com.edham.logistics.feature.tracking.domain.model.VehicleStatus.MAINTENANCE -> android.graphics.Color.parseColor("#2196F3")
                com.edham.logistics.feature.tracking.domain.model.VehicleStatus.BREAKDOWN -> android.graphics.Color.parseColor("#FF5722")
            }
        }
    }

    private class VehicleDiffCallback : DiffUtil.ItemCallback<VehicleTracking>() {
        override fun areItemsTheSame(oldItem: VehicleTracking, newItem: VehicleTracking): Boolean {
            return oldItem.id == newItem.id
        }

        override fun areContentsTheSame(oldItem: VehicleTracking, newItem: VehicleTracking): Boolean {
            return oldItem == newItem
        }
    }
}
