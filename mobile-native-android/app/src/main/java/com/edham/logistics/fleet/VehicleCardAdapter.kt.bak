package com.edham.logistics.fleet

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import androidx.core.content.ContextCompat
import androidx.recyclerview.widget.DiffUtil
import androidx.recyclerview.widget.ListAdapter
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.databinding.ItemVehicleCardBinding
import com.edham.logistics.fleet.models.VehicleCard
import com.edham.logistics.utils.AnimUtils

/**
 * Vehicle Card Adapter - RecyclerView adapter for interactive vehicle cards
 * 
 * Features:
 * - Rich vehicle information display
 * - Real-time status updates
 * - Interactive metrics
 * - Alert notifications
 * - Quick actions
 * - Smooth animations
 */
class VehicleCardAdapter(
    private val onItemClick: (VehicleCard) -> Unit,
    private val onTrackClick: (VehicleCard) -> Unit,
    private val onDetailsClick: (VehicleCard) -> Unit,
    private val onAlertAction: (VehicleCard, String) -> Unit
) : ListAdapter<VehicleCard, VehicleCardAdapter.ViewHolder>(VehicleCardDiffCallback()) {

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): ViewHolder {
        val binding = ItemVehicleCardBinding.inflate(
            LayoutInflater.from(parent.context),
            parent,
            false
        )
        return ViewHolder(binding)
    }

    override fun onBindViewHolder(holder: ViewHolder, position: Int) {
        holder.bind(getItem(position))
    }

    inner class ViewHolder(
        private val binding: ItemVehicleCardBinding
    ) : RecyclerView.ViewHolder(binding.root) {

        fun bind(vehicle: VehicleCard) {
            // Set vehicle basic information
            binding.tvVehicleId.text = vehicle.vehicleId
            binding.tvVehicleDetails.text = vehicle.vehicleDetails
            binding.tvDriverName.text = "السائق: ${vehicle.driverName}"
            binding.tvStatusBadge.text = vehicle.status.displayName

            // Update status indicator and badge
            updateStatusIndicator(vehicle.status)
            updateStatusBadge(vehicle.status)

            // Update vehicle image
            updateVehicleImage(vehicle.vehicleType, vehicle.vehicleImage)

            // Update metrics
            binding.tvFuelLevel.text = "${vehicle.fuelLevel}%"
            binding.tvMileage.text = formatMileage(vehicle.mileage)
            binding.tvSpeed.text = vehicle.currentSpeed.toString()
            binding.tvHealthScore.text = "${vehicle.healthScore}%"

            // Update progress bars
            binding.progressFuel.progress = vehicle.fuelLevel
            binding.progressHealth.progress = vehicle.healthScore
            binding.tvFuelPercentage.text = "${vehicle.fuelLevel}%"
            binding.tvHealthPercentage.text = "${vehicle.healthScore}%"

            // Update colors based on values
            updateFuelColors(vehicle.fuelLevel)
            updateHealthColors(vehicle.healthScore)
            updateSpeedColor(vehicle.currentSpeed)

            // Show/hide alert section
            if (vehicle.alerts.isNotEmpty()) {
                binding.llAlertSection.visibility = View.VISIBLE
                binding.tvAlertMessage.text = vehicle.alerts.first().message
                updateAlertSection(vehicle.alerts.first().severity)
            } else {
                binding.llAlertSection.visibility = View.GONE
            }

            // Set click listeners
            setupClickListeners(vehicle)

            // Animate appearance
            animateAppearance()
        }

        private fun updateStatusIndicator(status: VehicleStatus) {
            val colorRes = when (status) {
                VehicleStatus.ACTIVE -> R.color.green
                VehicleStatus.IDLE -> R.color.yellow
                VehicleStatus.MAINTENANCE -> R.color.orange
                VehicleStatus.OFFLINE -> R.color.red
                VehicleStatus.OUT_OF_SERVICE -> R.color.red
                else -> R.color.white_60
            }

            binding.viewStatusIndicator.setBackgroundColor(
                ContextCompat.getColor(binding.root.context, colorRes)
            )
        }

        private fun updateStatusBadge(status: VehicleStatus) {
            val (backgroundRes, textColor) = when (status) {
                VehicleStatus.ACTIVE -> {
                    R.drawable.bg_status_active_badge to R.color.white
                }
                VehicleStatus.IDLE -> {
                    R.drawable.bg_status_idle_badge to R.color.black
                }
                VehicleStatus.MAINTENANCE -> {
                    R.drawable.bg_status_maintenance_badge to R.color.white
                }
                VehicleStatus.OFFLINE -> {
                    R.drawable.bg_status_offline_badge to R.color.white
                }
                VehicleStatus.OUT_OF_SERVICE -> {
                    R.drawable.bg_status_out_of_service_badge to R.color.white
                }
                else -> {
                    R.drawable.bg_status_default_badge to R.color.white
                }
            }

            binding.tvStatusBadge.setBackgroundResource(backgroundRes)
            binding.tvStatusBadge.setTextColor(
                ContextCompat.getColor(binding.root.context, textColor)
            )
        }

        private fun updateVehicleImage(vehicleType: VehicleType, imageUrl: String?) {
            if (imageUrl != null && imageUrl.isNotEmpty()) {
                // Load image from URL using image loading library
                // For now, use placeholder based on type
                updateVehicleImageByType(vehicleType)
            } else {
                updateVehicleImageByType(vehicleType)
            }
        }

        private fun updateVehicleImageByType(vehicleType: VehicleType) {
            val iconRes = when (vehicleType) {
                VehicleType.TRUCK -> R.drawable.ic_truck
                VehicleType.VAN -> R.drawable.ic_van
                VehicleType.CAR -> R.drawable.ic_car
                VehicleType.MOTORCYCLE -> R.drawable.ic_motorcycle
                VehicleType.BUS -> R.drawable.ic_bus
                else -> R.drawable.ic_truck
            }

            binding.ivVehicleImage.setImageResource(iconRes)
        }

        private fun updateFuelColors(fuelLevel: Int) {
            val colorRes = when {
                fuelLevel >= 50 -> R.color.green
                fuelLevel >= 25 -> R.color.yellow
                fuelLevel >= 10 -> R.color.orange
                else -> R.color.red
            }

            val color = ContextCompat.getColor(binding.root.context, colorRes)
            binding.tvFuelLevel.setTextColor(color)
            binding.progressFuel.progressTintList = ContextCompat.getColorStateList(binding.root.context, colorRes)
        }

        private fun updateHealthColors(healthScore: Int) {
            val colorRes = when {
                healthScore >= 80 -> R.color.green
                healthScore >= 60 -> R.color.yellow
                healthScore >= 40 -> R.color.orange
                else -> R.color.red
            }

            val color = ContextCompat.getColor(binding.root.context, colorRes)
            binding.tvHealthScore.setTextColor(color)
            binding.progressHealth.progressTintList = ContextCompat.getColorStateList(binding.root.context, colorRes)
        }

        private fun updateSpeedColor(speed: Int) {
            val colorRes = when {
                speed <= 60 -> R.color.green
                speed <= 80 -> R.color.yellow
                speed <= 100 -> R.color.orange
                else -> R.color.red
            }

            binding.tvSpeed.setTextColor(ContextCompat.getColor(binding.root.context, colorRes))
        }

        private fun updateAlertSection(severity: AlertSeverity) {
            val (backgroundRes, textColor, iconTint) = when (severity) {
                AlertSeverity.CRITICAL -> {
                    Triple(R.drawable.bg_alert_critical, R.color.white, R.color.red)
                }
                AlertSeverity.HIGH -> {
                    Triple(R.drawable.bg_alert_high, R.color.white, R.color.orange)
                }
                AlertSeverity.MEDIUM -> {
                    Triple(R.drawable.bg_alert_medium, R.color.black, R.color.yellow)
                }
                AlertSeverity.LOW -> {
                    Triple(R.drawable.bg_alert_low, R.color.white, R.color.green)
                }
            }

            binding.llAlertSection.setBackgroundResource(backgroundRes)
            binding.tvAlertMessage.setTextColor(
                ContextCompat.getColor(binding.root.context, textColor)
            )
            binding.btnAlertAction.setColorFilter(
                ContextCompat.getColor(binding.root.context, iconTint)
            )
        }

        private fun setupClickListeners(vehicle: VehicleCard) {
            // Card click
            binding.root.setOnClickListener {
                onItemClick(vehicle)
                AnimUtils.scaleAnimation(it, 0.95f, 1.0f, 100)
            }

            // Track button
            binding.btnTrack.setOnClickListener {
                onTrackClick(vehicle)
                AnimUtils.scaleAnimation(it, 0.9f, 1.0f, 100)
            }

            // Details button
            binding.btnDetails.setOnClickListener {
                onDetailsClick(vehicle)
                AnimUtils.scaleAnimation(it, 0.9f, 1.0f, 100)
            }

            // Alert action button
            binding.btnAlertAction.setOnClickListener {
                if (vehicle.alerts.isNotEmpty()) {
                    onAlertAction(vehicle, vehicle.alerts.first().id)
                }
                AnimUtils.scaleAnimation(it, 0.9f, 1.0f, 100)
            }
        }

        private fun animateAppearance() {
            binding.root.alpha = 0f
            binding.root.translationY = 50f

            binding.root.animate()
                .alpha(1f)
                .translationY(0f)
                .setDuration(300)
                .setStartDelay(bindingAdapterPosition * 50L)
                .start()
        }

        private fun formatMileage(mileage: Float): String {
            return when {
                mileage >= 1000f -> "${(mileage / 1000).formatDecimal()}K"
                else -> mileage.toInt().toString()
            }
        }

        private fun Float.formatDecimal(): String {
            return String.format("%.1f", this)
        }
    }

    private class VehicleCardDiffCallback : DiffUtil.ItemCallback<VehicleCard>() {
        override fun areItemsTheSame(
            oldItem: VehicleCard,
            newItem: VehicleCard
        ): Boolean {
            return oldItem.vehicleId == newItem.vehicleId
        }

        override fun areContentsTheSame(
            oldItem: VehicleCard,
            newItem: VehicleCard
        ): Boolean {
            return oldItem == newItem
        }
    }
}

/**
 * Data classes for Vehicle Card
 */
data class VehicleCard(
    val vehicleId: String,
    val vehicleDetails: String,
    val driverName: String,
    val status: VehicleStatus,
    val vehicleType: VehicleType,
    val vehicleImage: String? = null,
    val fuelLevel: Int,
    val mileage: Float,
    val currentSpeed: Int,
    val healthScore: Int,
    val alerts: List<VehicleAlert> = emptyList(),
    val lastUpdated: Long = System.currentTimeMillis()
)

data class VehicleAlert(
    val id: String,
    val message: String,
    val severity: AlertSeverity,
    val timestamp: Long
)

enum class VehicleStatus(val displayName: String) {
    ACTIVE("نشط"),
    IDLE("متوقف"),
    MAINTENANCE("صيانة"),
    OFFLINE("غير متصل"),
    OUT_OF_SERVICE("خارج الخدمة")
}

enum class VehicleType {
    TRUCK,
    VAN,
    CAR,
    MOTORCYCLE,
    BUS
}

enum class AlertSeverity {
    CRITICAL,
    HIGH,
    MEDIUM,
    LOW
}
