package com.edham.logistics.feature.admin.domain.usecase

import com.edham.logistics.core.utils.Result
import com.edham.logistics.feature.admin.domain.model.RejectOrderRequest
import com.edham.logistics.feature.admin.domain.repository.AdminRepository
import javax.inject.Inject

class RejectOrderUseCase @Inject constructor(
    private val adminRepository: AdminRepository
) {
    
    suspend operator fun invoke(
        orderId: String,
        rejectedBy: String,
        reason: String,
        notes: String? = null
    ): Result<Unit> {
        val request = RejectOrderRequest(
            orderId = orderId,
            rejectedBy = rejectedBy,
            reason = reason,
            notes = notes
        )
        return adminRepository.rejectOrder(request)
    }
}
