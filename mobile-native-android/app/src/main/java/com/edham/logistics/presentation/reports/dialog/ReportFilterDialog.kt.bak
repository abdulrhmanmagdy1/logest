package com.edham.logistics.presentation.reports.dialog

import android.app.Dialog
import android.os.Bundle
import androidx.fragment.app.DialogFragment
import com.edham.logistics.R
import com.edham.logistics.presentation.reports.ReportFilters
import com.google.android.material.dialog.MaterialAlertDialogBuilder

/**
 * Report Filter Dialog - Dialog for configuring report filters
 * Provides comprehensive filtering options for report generation
 */
class ReportFilterDialog(
    private val currentFilters: ReportFilters,
    private val onFiltersApplied: (ReportFilters) -> Unit
) : DialogFragment() {

    override fun onCreateDialog(savedInstanceState: Bundle?): Dialog {
        val options = arrayOf(
            "Customer IDs (${currentFilters.customerIds.size} selected)",
            "Driver IDs (${currentFilters.driverIds.size} selected)",
            "Vehicle Types (${currentFilters.vehicleTypes.size} selected)",
            "Service Types (${currentFilters.serviceTypes.size} selected)",
            "Locations (${currentFilters.locations.size} selected)",
            "Status Filters (${currentFilters.statusFilters.size} selected)",
            "Amount Range",
            "Clear All Filters"
        )

        return MaterialAlertDialogBuilder(requireContext())
            .setTitle("Report Filters")
            .setItems(options) { _, which ->
                when (which) {
                    0 -> showCustomerFilterDialog()
                    1 -> showDriverFilterDialog()
                    2 -> showVehicleTypeFilterDialog()
                    3 -> showServiceTypeFilterDialog()
                    4 -> showLocationFilterDialog()
                    5 -> showStatusFilterDialog()
                    6 -> showAmountRangeDialog()
                    7 -> clearAllFilters()
                }
            }
            .setPositiveButton("Apply") { _, _ ->
                onFiltersApplied(currentFilters)
            }
            .setNegativeButton("Cancel", null)
            .create()
    }

    private fun showCustomerFilterDialog() {
        // Implementation for customer filter selection
        // This would show a multi-select dialog with available customers
    }

    private fun showDriverFilterDialog() {
        // Implementation for driver filter selection
        // This would show a multi-select dialog with available drivers
    }

    private fun showVehicleTypeFilterDialog() {
        val vehicleTypes = arrayOf("Truck", "Van", "Motorcycle", "Bicycle")
        val selectedIndices = currentFilters.vehicleTypes.mapNotNull { type ->
            vehicleTypes.indexOf(type).takeIf { it >= 0 }
        }.toIntArray()

        MaterialAlertDialogBuilder(requireContext())
            .setTitle("Select Vehicle Types")
            .setMultiChoiceItems(vehicleTypes, selectedIndices) { _, which, isChecked ->
                // Update selection
            }
            .setPositiveButton("OK", null)
            .setNegativeButton("Cancel", null)
            .show()
    }

    private fun showServiceTypeFilterDialog() {
        val serviceTypes = arrayOf("Standard", "Express", "Overnight", "International")
        val selectedIndices = currentFilters.serviceTypes.mapNotNull { type ->
            serviceTypes.indexOf(type).takeIf { it >= 0 }
        }.toIntArray()

        MaterialAlertDialogBuilder(requireContext())
            .setTitle("Select Service Types")
            .setMultiChoiceItems(serviceTypes, selectedIndices) { _, which, isChecked ->
                // Update selection
            }
            .setPositiveButton("OK", null)
            .setNegativeButton("Cancel", null)
            .show()
    }

    private fun showLocationFilterDialog() {
        // Implementation for location filter selection
        // This would show a multi-select dialog with available locations
    }

    private fun showStatusFilterDialog() {
        val statuses = arrayOf("Pending", "In Transit", "Delivered", "Cancelled")
        val selectedIndices = currentFilters.statusFilters.mapNotNull { status ->
            statuses.indexOf(status).takeIf { it >= 0 }
        }.toIntArray()

        MaterialAlertDialogBuilder(requireContext())
            .setTitle("Select Status Filters")
            .setMultiChoiceItems(statuses, selectedIndices) { _, which, isChecked ->
                // Update selection
            }
            .setPositiveButton("OK", null)
            .setNegativeButton("Cancel", null)
            .show()
    }

    private fun showAmountRangeDialog() {
        // Implementation for amount range filter
        // This would show a dialog with min/max amount inputs
    }

    private fun clearAllFilters() {
        // Implementation to clear all filters
        val clearedFilters = ReportFilters()
        onFiltersApplied(clearedFilters)
        dismiss()
    }
}
