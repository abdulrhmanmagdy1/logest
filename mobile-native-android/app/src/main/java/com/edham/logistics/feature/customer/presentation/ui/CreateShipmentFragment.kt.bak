package com.edham.logistics.feature.customer.presentation.ui

import android.os.Bundle
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import androidx.fragment.app.Fragment
import androidx.fragment.app.viewModels
import androidx.lifecycle.lifecycleScope
import androidx.navigation.fragment.findNavController
import com.edham.logistics.core.extensions.gone
import com.edham.logistics.core.extensions.visible
import com.edham.logistics.core.extensions.showSnackbar
import com.edham.logistics.databinding.FragmentCreateShipmentBinding
import com.edham.logistics.feature.customer.presentation.ui.CreateShipmentViewModel
import com.edham.logistics.feature.customer.presentation.adapter.CargoTypeAdapter
import com.edham.logistics.feature.customer.presentation.adapter.PriorityAdapter
import dagger.hilt.android.AndroidEntryPoint
import kotlinx.coroutines.launch
import javax.inject.Inject

@AndroidEntryPoint
class CreateShipmentFragment : Fragment() {

    private var _binding: FragmentCreateShipmentBinding? = null
    private val binding get() = _binding!!
    
    private val viewModel: CreateShipmentViewModel by viewModels()
    
    @Inject
    lateinit var cargoTypeAdapter: CargoTypeAdapter
    
    @Inject
    lateinit var priorityAdapter: PriorityAdapter

    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View {
        _binding = FragmentCreateShipmentBinding.inflate(inflater, container, false)
        return binding.root
    }

    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        setupAdapters()
        setupClickListeners()
        observeViewModel()
    }

    private fun setupAdapters() {
        // Cargo type adapter
        cargoTypeAdapter = CargoTypeAdapter { cargoType ->
            viewModel.updateCargoType(cargoType)
        }
        
        binding.recyclerViewCargoTypes.apply {
            adapter = cargoTypeAdapter
            layoutManager = androidx.recyclerview.widget.LinearLayoutManager(requireContext(), androidx.recyclerview.widget.LinearLayoutManager.HORIZONTAL, false)
        }
        
        // Priority adapter
        priorityAdapter = PriorityAdapter { priority ->
            viewModel.updatePriority(priority)
        }
        
        binding.recyclerViewPriorities.apply {
            adapter = priorityAdapter
            layoutManager = androidx.recyclerview.widget.LinearLayoutManager(requireContext(), androidx.recyclerview.widget.LinearLayoutManager.HORIZONTAL, false)
        }
    }

    private fun setupClickListeners() {
        binding.cardPickupLocation.setOnClickListener {
            selectPickupLocation()
        }
        
        binding.cardDeliveryLocation.setOnClickListener {
            selectDeliveryLocation()
        }
        
        binding.buttonCreateShipment.setOnClickListener {
            viewModel.createShipment()
        }
        
        binding.buttonReset.setOnClickListener {
            viewModel.resetForm()
        }
        
        binding.textViewPickupOnMap.setOnClickListener {
            selectPickupLocation()
        }
        
        binding.textViewDeliveryOnMap.setOnClickListener {
            selectDeliveryLocation()
        }
    }

    private fun observeViewModel() {
        viewLifecycleOwner.lifecycleScope.launch {
            viewModel.uiState.collect { uiState ->
                updateUI(uiState)
            }
        }
    }

    private fun updateUI(uiState: CreateShipmentViewModel.CreateShipmentUiState) {
        // Update cargo types
        cargoTypeAdapter.submitList(uiState.cargoTypes)
        cargoTypeAdapter.setSelectedItem(uiState.selectedCargoType)
        
        // Update priorities
        priorityAdapter.submitList(uiState.priorities)
        priorityAdapter.setSelectedItem(uiState.selectedPriority)
        
        // Update form fields
        binding.editTextPickupAddress.setText(uiState.pickupAddress)
        binding.editTextDeliveryAddress.setText(uiState.deliveryAddress)
        binding.editTextWeight.setText(if (uiState.weight > 0) uiState.weight.toString() else "")
        binding.editTextNotes.setText(uiState.notes)
        binding.editTextTemperature.setText(uiState.temperature?.toString() ?: "")
        binding.editTextInsuranceValue.setText(if (uiState.insuranceValue > 0) uiState.insuranceValue.toString() else "")
        
        // Update temperature field visibility
        if (uiState.selectedCargoType?.requiresTemperature == true) {
            binding.layoutTemperature.visible()
        } else {
            binding.layoutTemperature.gone()
        }
        
        // Handle loading state
        when {
            uiState.isCreating -> {
                showLoading()
            }
            uiState.error != null -> {
                showError(uiState.error)
            }
            else -> {
                showContent()
            }
        }
        
        // Handle shipment creation success
        uiState.createdShipment?.let { shipment ->
            showSnackbar("تم إنشاء الشحنة بنجاح")
            navigateToShipmentTracking(shipment.trackingNumber)
            viewModel.onShipmentCreatedHandled()
        }
    }

    private fun showLoading() {
        binding.progressBar.visible()
        binding.contentLayout.alpha = 0.5f
        binding.buttonCreateShipment.isEnabled = false
        binding.buttonReset.isEnabled = false
    }

    private fun showError(error: String?) {
        binding.progressBar.gone()
        binding.contentLayout.alpha = 1.0f
        binding.buttonCreateShipment.isEnabled = true
        binding.buttonReset.isEnabled = true
        
        error?.let {
            showSnackbar(it)
        }
    }

    private fun showContent() {
        binding.progressBar.gone()
        binding.contentLayout.alpha = 1.0f
        binding.buttonCreateShipment.isEnabled = true
        binding.buttonReset.isEnabled = true
    }

    private fun selectPickupLocation() {
        // In a real app, this would open Google Maps
        // For now, we'll set mock coordinates
        viewModel.updatePickupAddress("الرياض، شارع الملك، بناية 123", 24.7136, 46.6753)
        showSnackbar("تم تحديد موقع الاستلام")
    }

    private fun selectDeliveryLocation() {
        // In a real app, this would open Google Maps
        // For now, we'll set mock coordinates
        viewModel.updateDeliveryAddress("جدة، شارع الملك، بناية 456", 21.4225, 39.8262)
        showSnackbar("تم تحديد موقع التسليم")
    }

    private fun navigateToShipmentTracking(trackingNumber: String) {
        val action = CreateShipmentFragmentDirections
            .actionCreateShipmentFragmentToTrackingFragment(trackingNumber)
        findNavController().navigate(action)
    }

    override fun onDestroyView() {
        super.onDestroyView()
        _binding = null
    }
}
