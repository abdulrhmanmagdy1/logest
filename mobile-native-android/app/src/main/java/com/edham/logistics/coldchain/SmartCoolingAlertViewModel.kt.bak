package com.edham.logistics.coldchain

import androidx.lifecycle.ViewModel
import androidx.lifecycle.viewModelScope
import kotlinx.coroutines.flow.*
import kotlinx.coroutines.launch

/**
 * ViewModel for Smart Cooling Alert System
 */
class SmartCoolingAlertViewModel : ViewModel() {
    
    private val smartCoolingAlertService = SmartCoolingAlertService()
    
    // StateFlows for UI
    private val _isLoading = MutableStateFlow(false)
    val isLoading: StateFlow<Boolean> = _isLoading.asStateFlow()
    
    private val _error = MutableStateFlow<String?>(null)
    val error: StateFlow<String?> = _error.asStateFlow()
    
    // Expose service flows
    val activeAlerts: StateFlow<List<SmartCoolingAlertService.SmartCoolingAlert>> = 
        smartCoolingAlertService.activeAlerts
    
    val alertStatistics: StateFlow<SmartCoolingAlertService.AlertStatistics> = 
        smartCoolingAlertService.alertStatistics
    
    val failurePredictions: StateFlow<Map<String, SmartCoolingAlertService.CoolingFailurePrediction>> = 
        smartCoolingAlertService.failurePredictions
    
    val temperatureHistory: StateFlow<Map<String, List<SmartCoolingAlertService.TemperatureReading>>> = 
        smartCoolingAlertService.temperatureHistory
    
    /**
     * Process new temperature reading
     */
    fun processTemperatureReading(
        shipmentId: String,
        temperature: Double,
        productType: String,
        sensorId: String = "SENSOR_DEFAULT",
        batteryLevel: Double = 100.0,
        location: String = "Unknown"
    ) {
        viewModelScope.launch {
            try {
                _isLoading.value = true
                _error.value = null
                
                smartCoolingAlertService.processTemperatureReading(
                    shipmentId, temperature, productType, sensorId, batteryLevel, location
                )
                
            } catch (e: Exception) {
                _error.value = "فشل في معالجة قراءة درجة الحرارة: ${e.message}"
            } finally {
                _isLoading.value = false
            }
        }
    }
    
    /**
     * Acknowledge alert
     */
    fun acknowledgeAlert(alertId: String, userId: String) {
        viewModelScope.launch {
            try {
                _isLoading.value = true
                _error.value = null
                
                smartCoolingAlertService.acknowledgeAlert(alertId, userId)
                
            } catch (e: Exception) {
                _error.value = "فشل في الاعتراف بالتنبيه: ${e.message}"
            } finally {
                _isLoading.value = false
            }
        }
    }
    
    /**
     * Get alert by ID
     */
    fun getAlert(alertId: String): SmartCoolingAlertService.SmartCoolingAlert? {
        return smartCoolingAlertService.getAlert(alertId)
    }
    
    /**
     * Get failure prediction for shipment
     */
    fun getFailurePrediction(shipmentId: String): SmartCoolingAlertService.CoolingFailurePrediction? {
        return smartCoolingAlertService.getFailurePrediction(shipmentId)
    }
    
    /**
     * Get temperature history for shipment
     */
    fun getTemperatureHistory(shipmentId: String, hours: Int = 24): List<SmartCoolingAlertService.TemperatureReading> {
        return smartCoolingAlertService.getTemperatureHistory(shipmentId, hours)
    }
    
    /**
     * Get temperature chart data
     */
    fun getTemperatureChartData(shipmentId: String, hours: Int = 24) = 
        smartCoolingAlertService.getTemperatureChartData(shipmentId, hours)
    
    /**
     * Get temperature threshold lines
     */
    fun getThresholdLines(productType: String) = 
        smartCoolingAlertService.getThresholdLines(productType)
    
    /**
     * Refresh all data
     */
    fun refreshData() {
        viewModelScope.launch {
            try {
                _isLoading.value = true
                _error.value = null
                
                // Data is automatically updated through StateFlows
                // This can be used to trigger manual refresh if needed
                
            } catch (e: Exception) {
                _error.value = "فشل في تحديث البيانات: ${e.message}"
            } finally {
                _isLoading.value = false
            }
        }
    }
    
    /**
     * Clear error
     */
    fun clearError() {
        _error.value = null
    }
    
    /**
     * Clear all data (for testing)
     */
    fun clearAllData() {
        viewModelScope.launch {
            smartCoolingAlertService.clearAllData()
        }
    }
    
    /**
     * Get alert level information
     */
    fun getAlertLevelInfo(): Map<String, Map<String, Any>> {
        return mapOf(
            "WARNING" to mapOf(
                "name" to "تحذير",
                "severity" to 1,
                "color" to "#F59E0B",
                "escalationMinutes" to 30,
                "description" to "درجة الحرارة أعلى من المعتاد ولكن لا تزال في نطاق آمن نسبياً"
            ),
            "CRITICAL" to mapOf(
                "name" to "حرج",
                "severity" to 2,
                "color" to "#EF4444",
                "escalationMinutes" to 15,
                "description" to "درجة الحرارة خطرة وتتطلب اتخاذ إجراء فوري"
            ),
            "EMERGENCY" to mapOf(
                "name" to "طوارئ",
                "severity" to 3,
                "color" to "#DC2626",
                "escalationMinutes" to 5,
                "description" to "درجة الحرارة في مستوى الطوارئ وتتطلب استجابة فورية"
            )
        )
    }
    
    /**
     * Get risk level information
     */
    fun getRiskLevelInfo(): Map<String, Map<String, Any>> {
        return mapOf(
            "LOW" to mapOf(
                "name" to "منخفض",
                "scoreRange" to "0.0 - 0.29",
                "color" to "#10B981",
                "description" to "مخاطر منخفضة، الوضع طبيعي"
            ),
            "MEDIUM" to mapOf(
                "name" to "متوسط",
                "scoreRange" to "0.30 - 0.59",
                "color" to "#F59E0B",
                "description" to "مخاطر متوسطة، يجب المراقبة"
            ),
            "HIGH" to mapOf(
                "name" to "مرتفع",
                "scoreRange" to "0.60 - 0.79",
                "color" to "#EF4444",
                "description" to "مخاطر مرتفعة، يجب اتخاذ إجراءات وقائية"
            ),
            "CRITICAL" to mapOf(
                "name" to "حرج",
                "scoreRange" to "0.80 - 1.00",
                "color" to "#DC2626",
                "description" to "مخاطر حرجة، يتطلب استجابة فورية"
            )
        )
    }
    
    /**
     * Get system health status
     */
    fun getSystemHealth(): Map<String, Any> {
        val statistics = alertStatistics.value
        
        val healthStatus = when {
            statistics.emergencyAlerts > 0 -> "CRITICAL"
            statistics.criticalAlerts > 0 -> "WARNING"
            statistics.totalActiveAlerts > 0 -> "NORMAL"
            else -> "HEALTHY"
        }
        
        return mapOf(
            "status" to healthStatus,
            "totalActiveAlerts" to statistics.totalActiveAlerts,
            "highPriorityAlerts" to (statistics.criticalAlerts + statistics.emergencyAlerts),
            "acknowledgmentRate" to if (statistics.totalActiveAlerts > 0) {
                statistics.acknowledgedAlerts.toDouble() / statistics.totalActiveAlerts
            } else 0.0,
            "lastUpdated" to System.currentTimeMillis()
        )
    }
    
    /**
     * Get dashboard summary
     */
    fun getDashboardSummary(): Map<String, Any> {
        val statistics = alertStatistics.value
        val alerts = activeAlerts.value
        
        // Recent alerts (last 10)
        val recentAlerts = alerts.sortedByDescending { it.createdAt }.take(10)
        
        // Critical alerts requiring immediate attention
        val criticalAlerts = alerts.filter { !it.acknowledged && 
            (it.level == SmartCoolingAlertService.AlertLevel.CRITICAL || 
             it.level == SmartCoolingAlertService.AlertLevel.EMERGENCY) }
        
        return mapOf(
            "statistics" to statistics,
            "recentAlerts" to recentAlerts,
            "criticalAlerts" to criticalAlerts,
            "totalActiveAlerts" to alerts.size,
            "unacknowledgedAlerts" to alerts.count { !it.acknowledged && !it.autoResolved },
            "lastUpdated" to System.currentTimeMillis()
        )
    }
    
    override fun onCleared() {
        super.onCleared()
        // Clean up resources if needed
    }
}
