package com.edham.logistics.finance.export

import android.content.Context
import android.graphics.Bitmap
import android.graphics.BitmapFactory
import android.graphics.Canvas
import android.graphics.Color
import android.graphics.Paint
import android.graphics.Typeface
import android.graphics.pdf.PdfDocument
import com.edham.logistics.data.local.database.EdhamDatabase
import com.edham.logistics.data.remote.api.PDFExportApi
import com.edham.logistics.utils.NetworkUtils
import com.edham.logistics.utils.SecurityUtils
import kotlinx.coroutines.Dispatchers
import kotlinx.coroutines.flow.MutableStateFlow
import kotlinx.coroutines.flow.StateFlow
import kotlinx.coroutines.flow.asStateFlow
import kotlinx.coroutines.withContext
import java.io.File
import java.io.FileOutputStream
import java.util.*
import javax.inject.Inject
import javax.inject.Singleton

/**
 * PDF Export Service - Comprehensive PDF generation and export functionality
 * 
 * Features:
 * - Invoice PDF generation
 * - Financial reports PDF export
 * - Transaction history PDF
 * - Custom template support
 * - Batch PDF generation
 * - PDF sharing and printing
 * - PDF compression and optimization
 */
@Singleton
class PDFExportService @Inject constructor(
    private val context: Context,
    private val database: EdhamDatabase,
    private val pdfExportApi: PDFExportApi,
    private val networkUtils: NetworkUtils,
    private val securityUtils: SecurityUtils
) {
    
    private val _pdfExportState = MutableStateFlow<PDFExportState>(PDFExportState.Idle)
    val pdfExportState: StateFlow<PDFExportState> = _pdfExportState.asStateFlow()
    
    private val _exportedPDFs = MutableStateFlow<List<ExportedPDF>>(emptyList())
    val exportedPDFs: StateFlow<List<ExportedPDF>> = _exportedPDFs.asStateFlow()
    
    private var isInitialized = false
    
    companion object {
        private const val TAG = "PDFExportService"
        private const val PDF_CACHE_SIZE = 50
        private const val PDF_QUALITY = 90
        private const val PAGE_WIDTH = 595 // A4 width in points
        private const val PAGE_HEIGHT = 842 // A4 height in points
        private const val MARGIN = 50
        private const val FONT_SIZE_TITLE = 18f
        private const val FONT_SIZE_HEADER = 14f
        private const val FONT_SIZE_BODY = 12f
        private const val FONT_SIZE_SMALL = 10f
    }
    
    /**
     * Initialize PDF export service
     */
    suspend fun initialize(): Result<Boolean> {
        return withContext(Dispatchers.IO) {
            try {
                _pdfExportState.value = PDFExportState.Initializing
                
                // Create PDF export directory
                createPDFExportDirectory()
                
                // Load recent exported PDFs
                loadRecentExportedPDFs()
                
                // Initialize PDF templates
                initializePDFTemplates()
                
                isInitialized = true
                _pdfExportState.value = PDFExportState.Ready
                Result.success(true)
                
            } catch (e: Exception) {
                _pdfExportState.value = PDFExportState.Error("Failed to initialize PDF export service: ${e.message}")
                Result.failure(e)
            }
        }
    }
    
    /**
     * Export invoice to PDF
     */
    suspend fun exportInvoiceToPDF(
        invoiceId: String,
        template: PDFTemplate = PDFTemplate.STANDARD,
        options: PDFExportOptions? = null
    ): Result<ExportedPDF> {
        return withContext(Dispatchers.IO) {
            try {
                if (!isInitialized) {
                    throw Exception("PDF export service not initialized")
                }
                
                _pdfExportState.value = PDFExportState.Exporting
                
                // Get invoice data
                val invoice = database.invoiceDao().getInvoiceById(invoiceId.toLong())
                    ?.toDomainModel() ?: throw Exception("Invoice not found")
                
                // Generate PDF file
                val fileName = "invoice_${invoice.invoiceNumber}_${Date().time}.pdf"
                val filePath = generateInvoicePDF(invoice, template, options, fileName)
                
                // Create exported PDF record
                val exportedPDF = ExportedPDF(
                    id = UUID.randomUUID().toString(),
                    fileName = fileName,
                    filePath = filePath,
                    type = PDFType.INVOICE,
                    entityId = invoiceId,
                    template = template,
                    options = options ?: PDFExportOptions(),
                    fileSize = File(filePath).length(),
                    createdAt = Date(),
                    metadata = mapOf(
                        "invoice_number" to invoice.invoiceNumber,
                        "customer_id" to invoice.customerId,
                        "amount" to invoice.totalAmount.toString()
                    )
                )
                
                // Save to database
                val savedPDF = database.exportedPDFDao().insertExportedPDF(exportedPDF.toEntity())
                    .let { id -> exportedPDF.copy(id = id.toString()) }
                
                // Add to exported PDFs list
                addToExportedPDFs(savedPDF)
                
                _pdfExportState.value = PDFExportState.Ready
                Result.success(savedPDF)
                
            } catch (e: Exception) {
                _pdfExportState.value = PDFExportState.Error("Invoice PDF export failed: ${e.message}")
                Result.failure(e)
            }
        }
    }
    
    /**
     * Export financial report to PDF
     */
    suspend fun exportFinancialReportToPDF(
        reportType: FinancialReportType,
        dateRange: DateRange,
        template: PDFTemplate = PDFTemplate.STANDARD,
        options: PDFExportOptions? = null
    ): Result<ExportedPDF> {
        return withContext(Dispatchers.IO) {
            try {
                if (!isInitialized) {
                    throw Exception("PDF export service not initialized")
                }
                
                _pdfExportState.value = PDFExportState.Exporting
                
                // Get financial report data
                val reportData = getFinancialReportData(reportType, dateRange)
                
                // Generate PDF file
                val fileName = "${reportType.name.lowercase()}_report_${Date().time}.pdf"
                val filePath = generateFinancialReportPDF(reportData, template, options, fileName)
                
                // Create exported PDF record
                val exportedPDF = ExportedPDF(
                    id = UUID.randomUUID().toString(),
                    fileName = fileName,
                    filePath = filePath,
                    type = PDFType.FINANCIAL_REPORT,
                    entityId = reportType.name,
                    template = template,
                    options = options ?: PDFExportOptions(),
                    fileSize = File(filePath).length(),
                    createdAt = Date(),
                    metadata = mapOf(
                        "report_type" to reportType.name,
                        "date_range" to "${dateRange.startDate} to ${dateRange.endDate}",
                        "generated_at" to Date().toString()
                    )
                )
                
                // Save to database
                val savedPDF = database.exportedPDFDao().insertExportedPDF(exportedPDF.toEntity())
                    .let { id -> exportedPDF.copy(id = id.toString()) }
                
                // Add to exported PDFs list
                addToExportedPDFs(savedPDF)
                
                _pdfExportState.value = PDFExportState.Ready
                Result.success(savedPDF)
                
            } catch (e: Exception) {
                _pdfExportState.value = PDFExportState.Error("Financial report PDF export failed: ${e.message}")
                Result.failure(e)
            }
        }
    }
    
    /**
     * Export transaction history to PDF
     */
    suspend fun exportTransactionHistoryToPDF(
        filters: TransactionFilters,
        template: PDFTemplate = PDFTemplate.STANDARD,
        options: PDFExportOptions? = null
    ): Result<ExportedPDF> {
        return withContext(Dispatchers.IO) {
            try {
                if (!isInitialized) {
                    throw Exception("PDF export service not initialized")
                }
                
                _pdfExportState.value = PDFExportState.Exporting
                
                // Get transaction data
                val transactions = getTransactionData(filters)
                
                // Generate PDF file
                val fileName = "transaction_history_${Date().time}.pdf"
                val filePath = generateTransactionHistoryPDF(transactions, template, options, fileName)
                
                // Create exported PDF record
                val exportedPDF = ExportedPDF(
                    id = UUID.randomUUID().toString(),
                    fileName = fileName,
                    filePath = filePath,
                    type = PDFType.TRANSACTION_HISTORY,
                    entityId = "transaction_history",
                    template = template,
                    options = options ?: PDFExportOptions(),
                    fileSize = File(filePath).length(),
                    createdAt = Date(),
                    metadata = mapOf(
                        "transaction_count" to transactions.size.toString(),
                        "filters" to filters.toString(),
                        "generated_at" to Date().toString()
                    )
                )
                
                // Save to database
                val savedPDF = database.exportedPDFDao().insertExportedPDF(exportedPDF.toEntity())
                    .let { id -> exportedPDF.copy(id = id.toString()) }
                
                // Add to exported PDFs list
                addToExportedPDFs(savedPDF)
                
                _pdfExportState.value = PDFExportState.Ready
                Result.success(savedPDF)
                
            } catch (e: Exception) {
                _pdfExportState.value = PDFExportState.Error("Transaction history PDF export failed: ${e.message}")
                Result.failure(e)
            }
        }
    }
    
    /**
     * Batch export PDFs
     */
    suspend fun batchExportPDFs(
        exportRequests: List<PDFExportRequest>
    ): Result<List<ExportedPDF>> {
        return withContext(Dispatchers.IO) {
            try {
                if (!isInitialized) {
                    throw Exception("PDF export service not initialized")
                }
                
                _pdfExportState.value = PDFExportState.Exporting
                
                val exportedPDFs = mutableListOf<ExportedPDF>()
                
                exportRequests.forEach { request ->
                    when (request.type) {
                        PDFType.INVOICE -> {
                            val result = exportInvoiceToPDF(request.entityId, request.template, request.options)
                            if (result.isSuccess) {
                                exportedPDFs.add(result.getOrThrow())
                            }
                        }
                        PDFType.FINANCIAL_REPORT -> {
                            val result = exportFinancialReportToPDF(
                                FinancialReportType.valueOf(request.entityId),
                                request.dateRange ?: DateRange.last30Days(),
                                request.template,
                                request.options
                            )
                            if (result.isSuccess) {
                                exportedPDFs.add(result.getOrThrow())
                            }
                        }
                        PDFType.TRANSACTION_HISTORY -> {
                            val result = exportTransactionHistoryToPDF(
                                TransactionFilters(),
                                request.template,
                                request.options
                            )
                            if (result.isSuccess) {
                                exportedPDFs.add(result.getOrThrow())
                            }
                        }
                    }
                }
                
                _pdfExportState.value = PDFExportState.Ready
                Result.success(exportedPDFs)
                
            } catch (e: Exception) {
                _pdfExportState.value = PDFExportState.Error("Batch PDF export failed: ${e.message}")
                Result.failure(e)
            }
        }
    }
    
    /**
     * Share PDF
     */
    suspend fun sharePDF(
        pdfId: String,
        shareMethod: ShareMethod = ShareMethod.EMAIL
    ): Result<Boolean> {
        return withContext(Dispatchers.IO) {
            try {
                val pdf = getExportedPDF(pdfId)
                    ?: throw Exception("PDF not found")
                
                _pdfExportState.value = PDFExportState.Sharing
                
                val success = when (shareMethod) {
                    ShareMethod.EMAIL -> sharePDFViaEmail(pdf)
                    ShareMethod.WHATSAPP -> sharePDFViaWhatsApp(pdf)
                    ShareMethod.DRIVE -> sharePDFViaDrive(pdf)
                    ShareMethod.OTHER -> sharePDFViaOther(pdf)
                }
                
                _pdfExportState.value = PDFExportState.Ready
                Result.success(success)
                
            } catch (e: Exception) {
                _pdfExportState.value = PDFExportState.Error("PDF sharing failed: ${e.message}")
                Result.failure(e)
            }
        }
    }
    
    /**
     * Get exported PDF by ID
     */
    suspend fun getExportedPDF(pdfId: String): ExportedPDF? {
        return withContext(Dispatchers.IO) {
            try {
                // Try cache first
                _exportedPDFs.value.find { it.id == pdfId }
                    ?: database.exportedPDFDao().getExportedPDFById(pdfId.toLong())?.toDomainModel()
            } catch (e: Exception) {
                null
            }
        }
    }
    
    /**
     * Get exported PDFs history
     */
    suspend fun getExportedPDFsHistory(
        type: PDFType? = null,
        dateRange: DateRange? = null,
        page: Int = 0,
        pageSize: Int = 50
    ): Result<PDFHistoryResult> {
        return withContext(Dispatchers.IO) {
            try {
                val pdfs = database.exportedPDFDao().getExportedPDFsHistory(
                    type = type,
                    startDate = dateRange?.startDate,
                    endDate = dateRange?.endDate,
                    limit = pageSize,
                    offset = page * pageSize
                ).map { it.toDomainModel() }
                
                val totalCount = database.exportedPDFDao().getExportedPDFsHistoryCount(
                    type = type,
                    startDate = dateRange?.startDate,
                    endDate = dateRange?.endDate
                )
                
                Result.success(
                    PDFHistoryResult(
                        pdfs = pdfs,
                        totalCount = totalCount,
                        page = page,
                        pageSize = pageSize,
                        totalPages = (totalCount + pageSize - 1) / pageSize
                    )
                )
                
            } catch (e: Exception) {
                Result.failure(e)
            }
        }
    }
    
    /**
     * Delete exported PDF
     */
    suspend fun deleteExportedPDF(pdfId: String): Result<Boolean> {
        return withContext(Dispatchers.IO) {
            try {
                val pdf = getExportedPDF(pdfId)
                    ?: throw Exception("PDF not found")
                
                // Delete file
                File(pdf.filePath).delete()
                
                // Delete from database
                database.exportedPDFDao().deleteExportedPDF(pdfId.toLong())
                
                // Remove from cache
                removeFromExportedPDFs(pdfId)
                
                Result.success(true)
                
            } catch (e: Exception) {
                Result.failure(e)
            }
        }
    }
    
    /**
     * Helper functions
     */
    private suspend fun createPDFExportDirectory() {
        val pdfDir = File("${context.getExternalFilesDir(null)}/pdfs")
        if (!pdfDir.exists()) {
            pdfDir.mkdirs()
        }
    }
    
    private suspend fun loadRecentExportedPDFs() {
        try {
            val pdfs = database.exportedPDFDao().getRecentExportedPDFs(PDF_CACHE_SIZE)
                .map { it.toDomainModel() }
            
            _exportedPDFs.value = pdfs
            
        } catch (e: Exception) {
            // Handle error
        }
    }
    
    private suspend fun initializePDFTemplates() {
        // Initialize PDF templates
    }
    
    private suspend fun generateInvoicePDF(
        invoice: Invoice,
        template: PDFTemplate,
        options: PDFExportOptions?,
        fileName: String
    ): String {
        val filePath = "${context.getExternalFilesDir(null)}/pdfs/$fileName"
        
        val pdfDocument = PdfDocument()
        val pageInfo = PdfDocument.PageInfo.Builder(PAGE_WIDTH, PAGE_HEIGHT, 1).create()
        val page = pdfDocument.startPage(pageInfo)
        val canvas = page.canvas
        val paint = Paint()
        
        var yPosition = MARGIN.toFloat()
        
        // Draw header
        paint.textSize = FONT_SIZE_TITLE
        paint.typeface = Typeface.DEFAULT_BOLD
        canvas.drawText("INVOICE", MARGIN.toFloat(), yPosition, paint)
        yPosition += FONT_SIZE_TITLE + 20
        
        // Draw invoice number and date
        paint.textSize = FONT_SIZE_BODY
        paint.typeface = Typeface.DEFAULT
        canvas.drawText("Invoice Number: ${invoice.invoiceNumber}", MARGIN.toFloat(), yPosition, paint)
        yPosition += FONT_SIZE_BODY + 10
        
        canvas.drawText("Date: ${invoice.issueDate}", MARGIN.toFloat(), yPosition, paint)
        yPosition += FONT_SIZE_BODY + 20
        
        // Draw customer info
        paint.textSize = FONT_SIZE_HEADER
        paint.typeface = Typeface.DEFAULT_BOLD
        canvas.drawText("Bill To:", MARGIN.toFloat(), yPosition, paint)
        yPosition += FONT_SIZE_HEADER + 10
        
        paint.textSize = FONT_SIZE_BODY
        paint.typeface = Typeface.DEFAULT
        canvas.drawText(invoice.customerName, MARGIN.toFloat(), yPosition, paint)
        yPosition += FONT_SIZE_BODY + 10
        
        canvas.drawText(invoice.customerAddress, MARGIN.toFloat(), yPosition, paint)
        yPosition += FONT_SIZE_BODY + 20
        
        // Draw items table
        drawItemsTable(canvas, paint, invoice.items, yPosition)
        
        // Draw totals
        yPosition = PAGE_HEIGHT - 200f
        drawTotals(canvas, paint, invoice, yPosition)
        
        // Draw footer
        yPosition = PAGE_HEIGHT - 50f
        drawFooter(canvas, paint, template, yPosition)
        
        pdfDocument.finishPage(page)
        pdfDocument.close()
        
        return filePath
    }
    
    private suspend fun generateFinancialReportPDF(
        reportData: FinancialReportData,
        template: PDFTemplate,
        options: PDFExportOptions?,
        fileName: String
    ): String {
        val filePath = "${context.getExternalFilesDir(null)}/pdfs/$fileName"
        
        val pdfDocument = PdfDocument()
        val pageInfo = PdfDocument.PageInfo.Builder(PAGE_WIDTH, PAGE_HEIGHT, 1).create()
        val page = pdfDocument.startPage(pageInfo)
        val canvas = page.canvas
        val paint = Paint()
        
        var yPosition = MARGIN.toFloat()
        
        // Draw report title
        paint.textSize = FONT_SIZE_TITLE
        paint.typeface = Typeface.DEFAULT_BOLD
        canvas.drawText(reportData.title, MARGIN.toFloat(), yPosition, paint)
        yPosition += FONT_SIZE_TITLE + 20
        
        // Draw report period
        paint.textSize = FONT_SIZE_BODY
        paint.typeface = Typeface.DEFAULT
        canvas.drawText("Period: ${reportData.period}", MARGIN.toFloat(), yPosition, paint)
        yPosition += FONT_SIZE_BODY + 20
        
        // Draw report content
        drawFinancialReportContent(canvas, paint, reportData, yPosition)
        
        pdfDocument.finishPage(page)
        pdfDocument.close()
        
        return filePath
    }
    
    private suspend fun generateTransactionHistoryPDF(
        transactions: List<Transaction>,
        template: PDFTemplate,
        options: PDFExportOptions?,
        fileName: String
    ): String {
        val filePath = "${context.getExternalFilesDir(null)}/pdfs/$fileName"
        
        val pdfDocument = PdfDocument()
        val pageInfo = PdfDocument.PageInfo.Builder(PAGE_WIDTH, PAGE_HEIGHT, 1).create()
        val page = pdfDocument.startPage(pageInfo)
        val canvas = page.canvas
        val paint = Paint()
        
        var yPosition = MARGIN.toFloat()
        
        // Draw title
        paint.textSize = FONT_SIZE_TITLE
        paint.typeface = Typeface.DEFAULT_BOLD
        canvas.drawText("Transaction History", MARGIN.toFloat(), yPosition, paint)
        yPosition += FONT_SIZE_TITLE + 20
        
        // Draw transactions table
        drawTransactionsTable(canvas, paint, transactions, yPosition)
        
        pdfDocument.finishPage(page)
        pdfDocument.close()
        
        return filePath
    }
    
    private fun drawItemsTable(canvas: Canvas, paint: Paint, items: List<InvoiceItem>, startY: Float) {
        var yPosition = startY
        
        // Table headers
        paint.textSize = FONT_SIZE_HEADER
        paint.typeface = Typeface.DEFAULT_BOLD
        canvas.drawText("Description", MARGIN.toFloat(), yPosition, paint)
        canvas.drawText("Quantity", 250f, yPosition, paint)
        canvas.drawText("Price", 350f, yPosition, paint)
        canvas.drawText("Total", 450f, yPosition, paint)
        
        yPosition += FONT_SIZE_HEADER + 10
        
        // Table rows
        paint.textSize = FONT_SIZE_BODY
        paint.typeface = Typeface.DEFAULT
        items.forEach { item ->
            canvas.drawText(item.description, MARGIN.toFloat(), yPosition, paint)
            canvas.drawText(item.quantity.toString(), 250f, yPosition, paint)
            canvas.drawText("SAR ${String.format("%.2f", item.unitPrice)}", 350f, yPosition, paint)
            canvas.drawText("SAR ${String.format("%.2f", item.total)}", 450f, yPosition, paint)
            yPosition += FONT_SIZE_BODY + 5
        }
    }
    
    private fun drawTotals(canvas: Canvas, paint: Paint, invoice: Invoice, startY: Float) {
        var yPosition = startY
        
        paint.textSize = FONT_SIZE_BODY
        paint.typeface = Typeface.DEFAULT
        
        canvas.drawText("Subtotal: SAR ${String.format("%.2f", invoice.subtotal)}", 350f, yPosition, paint)
        yPosition += FONT_SIZE_BODY + 10
        
        canvas.drawText("Tax (15%): SAR ${String.format("%.2f", invoice.tax)}", 350f, yPosition, paint)
        yPosition += FONT_SIZE_BODY + 10
        
        paint.textSize = FONT_SIZE_HEADER
        paint.typeface = Typeface.DEFAULT_BOLD
        canvas.drawText("Total: SAR ${String.format("%.2f", invoice.total)}", 350f, yPosition, paint)
    }
    
    private fun drawFooter(canvas: Canvas, paint: Paint, template: PDFTemplate, startY: Float) {
        paint.textSize = FONT_SIZE_SMALL
        paint.typeface = Typeface.DEFAULT
        
        when (template) {
            PDFTemplate.STANDARD -> {
                canvas.drawText("Thank you for your business!", MARGIN.toFloat(), startY, paint)
            }
            PDFTemplate.DETAILED -> {
                canvas.drawText("Terms and conditions apply. Payment due within 30 days.", MARGIN.toFloat(), startY, paint)
            }
            PDFTemplate.MINIMAL -> {
                canvas.drawText("Generated by Edham Logistics", MARGIN.toFloat(), startY, paint)
            }
        }
    }
    
    private fun drawFinancialReportContent(canvas: Canvas, paint: Paint, reportData: FinancialReportData, startY: Float) {
        // Implementation for drawing financial report content
    }
    
    private fun drawTransactionsTable(canvas: Canvas, paint: Paint, transactions: List<Transaction>, startY: Float) {
        var yPosition = startY
        
        // Table headers
        paint.textSize = FONT_SIZE_HEADER
        paint.typeface = Typeface.DEFAULT_BOLD
        canvas.drawText("Date", MARGIN.toFloat(), yPosition, paint)
        canvas.drawText("Description", 100f, yPosition, paint)
        canvas.drawText("Amount", 350f, yPosition, paint)
        canvas.drawText("Type", 450f, yPosition, paint)
        
        yPosition += FONT_SIZE_HEADER + 10
        
        // Table rows
        paint.textSize = FONT_SIZE_BODY
        paint.typeface = Typeface.DEFAULT
        transactions.take(20).forEach { transaction -> // Limit to 20 transactions per page
            canvas.drawText(transaction.date, MARGIN.toFloat(), yPosition, paint)
            canvas.drawText(transaction.description, 100f, yPosition, paint)
            canvas.drawText("SAR ${String.format("%.2f", transaction.amount)}", 350f, yPosition, paint)
            canvas.drawText(transaction.type, 450f, yPosition, paint)
            yPosition += FONT_SIZE_BODY + 5
        }
    }
    
    private suspend fun getFinancialReportData(reportType: FinancialReportType, dateRange: DateRange): FinancialReportData {
        // Get financial report data based on type and date range
        return when (reportType) {
            FinancialReportType.INCOME_STATEMENT -> {
                FinancialReportData(
                    title = "Income Statement",
                    period = "${dateRange.startDate} to ${dateRange.endDate}",
                    data = emptyMap()
                )
            }
            FinancialReportType.BALANCE_SHEET -> {
                FinancialReportData(
                    title = "Balance Sheet",
                    period = "${dateRange.startDate} to ${dateRange.endDate}",
                    data = emptyMap()
                )
            }
            FinancialReportType.CASH_FLOW -> {
                FinancialReportData(
                    title = "Cash Flow Statement",
                    period = "${dateRange.startDate} to ${dateRange.endDate}",
                    data = emptyMap()
                )
            }
        }
    }
    
