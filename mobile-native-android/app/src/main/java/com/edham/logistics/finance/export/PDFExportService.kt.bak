    private fun addToExportedPDFs(pdf: ExportedPDF) {
        val currentPDFs = _exportedPDFs.value.toMutableList()
        currentPDFs.add(0, pdf) // Add to beginning
        
        // Keep only last PDF_CACHE_SIZE PDFs in cache
        if (currentPDFs.size > PDF_CACHE_SIZE) {
            currentPDFs.removeAt(currentPDFs.size - 1)
        }
        
        _exportedPDFs.value = currentPDFs
    }
    
    private fun removeFromExportedPDFs(pdfId: String) {
        val currentPDFs = _exportedPDFs.value.toMutableList()
        currentPDFs.removeAll { it.id == pdfId }
        _exportedPDFs.value = currentPDFs
    }
    
    /**
     * Get initialization status
     */
    fun isInitialized(): Boolean = isInitialized
}

/**
 * Data classes
 */
data class ExportedPDF(
    val id: String = "",
    val fileName: String,
    val filePath: String,
    val type: PDFType,
    val entityId: String,
    val template: PDFTemplate,
    val options: PDFExportOptions,
    val fileSize: Long,
    val createdAt: Date,
    val metadata: Map<String, String> = emptyMap()
)

data class PDFExportRequest(
    val type: PDFType,
    val entityId: String,
    val template: PDFTemplate = PDFTemplate.STANDARD,
    val options: PDFExportOptions? = null,
    val dateRange: DateRange? = null
)

data class PDFExportOptions(
    val includeWatermark: Boolean = false,
    val watermarkText: String = "",
    val includePageNumbers: Boolean = true,
    val includeHeader: Boolean = true,
    val includeFooter: Boolean = true,
    val compression: Boolean = true,
    val password: String? = null
)

data class PDFHistoryResult(
    val pdfs: List<ExportedPDF>,
    val totalCount: Int,
    val page: Int,
    val pageSize: Int,
    val totalPages: Int
)

data class FinancialReportData(
    val title: String,
    val period: String,
    val data: Map<String, Any>
)

data class Transaction(
    val date: String,
    val description: String,
    val amount: Float,
    val type: String
)

data class TransactionFilters(
    val dateFrom: Date? = null,
    val dateTo: Date? = null,
    val type: String? = null,
    val minAmount: Float? = null,
    val maxAmount: Float? = null
)

data class DateRange(
    val startDate: Date,
    val endDate: Date
) {
    companion object {
        fun last30Days(): DateRange {
            val calendar = Calendar.getInstance()
            val endDate = calendar.time
            calendar.add(Calendar.DAY_OF_MONTH, -30)
            val startDate = calendar.time
            return DateRange(startDate, endDate)
        }
        
        fun last7Days(): DateRange {
            val calendar = Calendar.getInstance()
            val endDate = calendar.time
            calendar.add(Calendar.DAY_OF_MONTH, -7)
            val startDate = calendar.time
            return DateRange(startDate, endDate)
        }
        
        fun today(): DateRange {
            val calendar = Calendar.getInstance()
            calendar.set(Calendar.HOUR_OF_DAY, 0)
            calendar.set(Calendar.MINUTE, 0)
            calendar.set(Calendar.SECOND, 0)
            calendar.set(Calendar.MILLISECOND, 0)
            val startDate = calendar.time
            
            calendar.add(Calendar.DAY_OF_MONTH, 1)
            val endDate = calendar.time
            
            return DateRange(startDate, endDate)
        }
    }
}

