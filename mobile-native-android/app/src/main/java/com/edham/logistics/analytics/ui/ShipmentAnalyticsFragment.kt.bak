import com.edham.logistics.ui.theme.*
import dagger.hilt.android.AndroidEntryPoint
import kotlinx.coroutines.launch
import javax.inject.Inject

/**
 * Shipment Analytics Fragment - Comprehensive shipment analytics and insights
 * 
 * Features:
 * - Shipment overview statistics
 * - Delivery performance metrics
 * - Route analytics
 * - Customer insights
 * - Revenue analysis per shipment
 * - Interactive charts
 * - Filtering and date ranges
 */
@AndroidEntryPoint
class ShipmentAnalyticsFragment : Fragment() {
    
    @Inject
    lateinit var analyticsEngineService: AnalyticsEngineService
    
    private val viewModel: ShipmentAnalyticsViewModel by viewModels()
    
    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View {
        return ComposeView(requireContext()).apply {
            setContent {
                EdhamLogisticsTheme {
                    ShipmentAnalyticsScreen(
                        viewModel = viewModel,
                        analyticsEngineService = analyticsEngineService
                    )
                }
            }
        }
    }
    
    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        
        // Initialize analytics engine
        lifecycleScope.launch {
            analyticsEngineService.initialize()
        }
        
        // Load shipment analytics
        viewModel.loadShipmentAnalytics()
    }
}

@Composable
fun ShipmentAnalyticsScreen(
    viewModel: ShipmentAnalyticsViewModel,
    analyticsEngineService: AnalyticsEngineService
) {
    val shipmentAnalytics by viewModel.shipmentAnalytics.collectAsStateWithLifecycle()
    val isLoading by viewModel.isLoading.collectAsStateWithLifecycle()
    val errorMessage by viewModel.errorMessage.collectAsStateWithLifecycle()
    val selectedTimeRange by viewModel.selectedTimeRange.collectAsStateWithLifecycle()
    
    LaunchedEffect(selectedTimeRange) {
        viewModel.loadShipmentAnalytics()
    }
    
    Column(
        modifier = Modifier
            .fillMaxSize()
            .padding(16.dp),
        verticalArrangement = Arrangement.spacedBy(16.dp)
    ) {
        // Header with time range selector
        ShipmentAnalyticsHeader(
            selectedTimeRange = selectedTimeRange,
            onTimeRangeChanged = viewModel::setTimeRange,
            onRefresh = viewModel::refreshAnalytics,
            isLoading = isLoading
        )
        
        // Error message
        errorMessage?.let { error ->
            Card(
                modifier = Modifier.fillMaxWidth(),
                colors = CardDefaults.cardColors(
                    containerColor = ErrorRed.copy(alpha = 0.1f)
                ),
                elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
            ) {
                Text(
                    text = error,
                    modifier = Modifier.padding(16.dp),
                    color = ErrorRed,
                    style = MaterialTheme.typography.bodyMedium
                )
            }
        }
        
        // Shipment Analytics Content
        shipmentAnalytics?.let { analytics ->
            // Shipment Overview
            ShipmentOverviewSection(analytics = analytics)
            
            // Delivery Performance
            DeliveryPerformanceSection(analytics = analytics)
            
            // Route Analytics
            RouteAnalyticsSection(analytics = analytics)
            
            // Customer Insights
            CustomerInsightsSection(analytics = analytics)
            
            // Revenue Analysis
            ShipmentRevenueSection(analytics = analytics)
            
            // Top Routes
            TopRoutesSection(analytics = analytics)
            
            // Shipment Status Breakdown
            ShipmentStatusBreakdownSection(analytics = analytics)
        }
        
        // Loading indicator
        if (isLoading) {
            Box(
                modifier = Modifier.fillMaxWidth(),
                contentAlignment = Alignment.Center
            ) {
                CircularProgressIndicator(
                    color = EdhamOrange,
                    strokeWidth = 3.dp
                )
            }
        }
    }
}

@Composable
fun ShipmentAnalyticsHeader(
    selectedTimeRange: TimeRange,
    onTimeRangeChanged: (TimeRange) -> Unit,
    onRefresh: () -> Unit,
    isLoading: Boolean
) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.surface
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Row(
                modifier = Modifier.fillMaxWidth(),
                horizontalArrangement = Arrangement.SpaceBetween,
                verticalAlignment = Alignment.CenterVertically
            ) {
                Text(
                    text = "Shipment Analytics",
                    style = MaterialTheme.typography.headlineMedium,
                    color = EdhamOrange,
                    fontWeight = FontWeight.Bold
                )
                
                Row {
                    // Time range selector
                    TimeRangeSelector(
                        selectedTimeRange = selectedTimeRange,
                        onTimeRangeChanged = onTimeRangeChanged
                    )
                    
                    Spacer(modifier = Modifier.width(8.dp))
                    
                    // Refresh button
                    IconButton(
                        onClick = onRefresh,
                        enabled = !isLoading
                    ) {
                        Icon(
                            painter = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_rotate),
                            contentDescription = "Refresh",
                            tint = EdhamOrange
                        )
                    }
                }
            }
        }
    }
}

@Composable
fun ShipmentOverviewSection(analytics: ShipmentAnalytics) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.surface
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Text(
                text = "Shipment Overview",
                style = MaterialTheme.typography.titleMedium,
                color = EdhamOrange,
                fontWeight = FontWeight.Bold
            )
            
            Spacer(modifier = Modifier.height(16.dp))
            
            LazyColumn(
                verticalArrangement = Arrangement.spacedBy(12.dp)
            ) {
                item {
                    OverviewMetric(
                        title = "Total Shipments",
                        value = analytics.totalShipments.toString(),
                        subtitle = "In selected period",
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_send),
                        color = EdhamOrange,
                        change = analytics.totalShipmentsChange
                    )
                }
                
                item {
                    OverviewMetric(
                        title = "Completed Shipments",
                        value = analytics.completedShipments.toString(),
                        subtitle = "Successfully delivered",
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_save),
                        color = SuccessGreen,
                        change = analytics.completedShipmentsChange
                    )
                }
                
                item {
                    OverviewMetric(
                        title = "Average Delivery Time",
                        value = "${analytics.averageDeliveryTime} hours",
                        subtitle = "From pickup to delivery",
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_recent_history),
                        color = IceBlue,
                        change = analytics.deliveryTimeChange
                    )
                }
                
                item {
                    OverviewMetric(
                        title = "Success Rate",
                        value = "${String.format("%.1f", analytics.successRate)}%",
                        subtitle = "Delivery success percentage",
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_preferences),
                        color = if (analytics.successRate >= 95) SuccessGreen else WarningYellow,
                        change = analytics.successRateChange
                    )
                }
            }
        }
    }
}

@Composable
fun DeliveryPerformanceSection(analytics: ShipmentAnalytics) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.surface
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Text(
                text = "Delivery Performance",
                style = MaterialTheme.typography.titleMedium,
                color = EdhamOrange,
                fontWeight = FontWeight.Bold
            )
            
            Spacer(modifier = Modifier.height(16.dp))
            
            // Performance chart placeholder
            Box(
                modifier = Modifier
                    .fillMaxWidth()
                    .height(200.dp)
                    .clip(RoundedCornerShape(8.dp))
                    .background(MaterialTheme.colorScheme.surfaceVariant),
                contentAlignment = Alignment.Center
            ) {
                Column(
                    horizontalAlignment = Alignment.CenterHorizontally
                ) {
                    Icon(
                        painter = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_gallery),
                        contentDescription = "Chart",
                        tint = MaterialTheme.colorScheme.onSurfaceVariant,
                        modifier = Modifier.size(48.dp)
                    )
                    
                    Spacer(modifier = Modifier.height(8.dp))
                    
                    Text(
                        text = "Delivery Performance Chart",
                        style = MaterialTheme.typography.bodyMedium,
                        color = MaterialTheme.colorScheme.onSurfaceVariant
                    )
                    
                    Text(
                        text = "Interactive chart coming soon",
                        style = MaterialTheme.typography.bodySmall,
                        color = MaterialTheme.colorScheme.onSurfaceVariant.copy(alpha = 0.7f)
                    )
                }
            }
            
            Spacer(modifier = Modifier.height(16.dp))
            
            // Performance metrics
            LazyColumn(
                verticalArrangement = Arrangement.spacedBy(8.dp)
            ) {
                item {
                    PerformanceMetric(
                        title = "On-Time Delivery Rate",
                        value = "${String.format("%.1f", analytics.onTimeDeliveryRate)}%",
                        target = 95f,
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_recent_history),
                        color = if (analytics.onTimeDeliveryRate >= 95) SuccessGreen else WarningYellow
                    )
                }
                
                item {
                    PerformanceMetric(
                        title = "Average Route Efficiency",
                        value = "${String.format("%.1f", analytics.averageRouteEfficiency)}%",
                        target = 85f,
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_directions),
                        color = if (analytics.averageRouteEfficiency >= 85) SuccessGreen else WarningYellow
                    )
                }
                
                item {
                    PerformanceMetric(
                        title = "Customer Satisfaction",
                        value = "${String.format("%.1f", analytics.customerSatisfactionScore)}",
                        target = 4.5f,
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_star),
                        color = if (analytics.customerSatisfactionScore >= 4.5) SuccessGreen else WarningYellow
                    )
                }
            }
        }
    }
}

@Composable
fun PerformanceMetric(
    title: String,
    value: String,
    target: Float,
    icon: androidx.compose.ui.graphics.painter.Painter,
    color: Color
) {
    Row(
        modifier = Modifier.fillMaxWidth(),
        verticalAlignment = Alignment.CenterVertically
    ) {
        Card(
            modifier = Modifier.size(40.dp),
            colors = CardDefaults.cardColors(
                containerColor = color.copy(alpha = 0.1f)
            ),
            elevation = CardDefaults.cardElevation(defaultElevation = 1.dp)
        ) {
            Box(
                modifier = Modifier.fillMaxSize(),
                contentAlignment = Alignment.Center
            ) {
                Icon(
                    painter = icon,
                    contentDescription = null,
                    tint = color,
                    modifier = Modifier.size(20.dp)
                )
            }
        }
        
        Spacer(modifier = Modifier.width(12.dp))
        
        Column(modifier = Modifier.weight(1f)) {
            Text(
                text = title,
                style = MaterialTheme.typography.bodyMedium,
                color = MaterialTheme.colorScheme.onSurface
            )
            
            Row(
                verticalAlignment = Alignment.CenterVertically
            ) {
                Text(
                    text = value,
                    style = MaterialTheme.typography.titleMedium,
                    color = color,
                    fontWeight = FontWeight.Bold
                )
                
                Spacer(modifier = Modifier.width(8.dp))
                
                Text(
                    text = "(Target: $target)",
                    style = MaterialTheme.typography.bodySmall,
                    color = MaterialTheme.colorScheme.onSurface.copy(alpha = 0.7f)
                )
            }
        }
        
        // Status indicator
        Card(
            colors = CardDefaults.cardColors(
                containerColor = color
            ),
            shape = RoundedCornerShape(12.dp)
        ) {
            Text(
                text = if (color == SuccessGreen) "On Track" else "Needs Attention",
                modifier = Modifier.padding(horizontal = 12.dp, vertical = 4.dp),
                style = MaterialTheme.typography.bodySmall,
                color = Color.White,
                fontWeight = FontWeight.Medium
            )
        }
    }
}

