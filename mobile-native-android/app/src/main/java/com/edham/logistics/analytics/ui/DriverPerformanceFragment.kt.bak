@Composable
fun DriverRankingItem(
    driver: DriverPerformanceData,
    onDriverSelected: (String) -> Unit
) {
    Row(
        modifier = Modifier
            .fillMaxWidth()
            .clickable { onDriverSelected(driver.driverId) }
            .padding(vertical = 8.dp),
        horizontalArrangement = Arrangement.SpaceBetween,
        verticalAlignment = Alignment.CenterVertically
    ) {
        Row(
            verticalAlignment = Alignment.CenterVertically
        ) {
            // Rank
            Text(
                text = "#${driver.rank}",
                style = MaterialTheme.typography.bodyLarge,
                color = EdhamOrange,
                fontWeight = FontWeight.Bold,
                modifier = Modifier.width(40.dp)
            )
            
            Spacer(modifier = Modifier.width(12.dp))
            
            Column {
                Text(
                    text = driver.driverName,
                    style = MaterialTheme.typography.bodyMedium,
                    color = MaterialTheme.colorScheme.onSurface,
                    fontWeight = FontWeight.Medium
                )
                
                Text(
                    text = "${driver.totalDeliveries} deliveries",
                    style = MaterialTheme.typography.bodySmall,
                    color = MaterialTheme.colorScheme.onSurface.copy(alpha = 0.7f)
                )
            }
        }
        
        Row(
            verticalAlignment = Alignment.CenterVertically
        ) {
            Text(
                text = String.format("%.1f", driver.performanceScore),
                style = MaterialTheme.typography.bodyLarge,
                color = EdhamOrange,
                fontWeight = FontWeight.Bold
            )
            
            Spacer(modifier = Modifier.width(8.dp))
            
            // Performance indicator
            Card(
                colors = CardDefaults.cardColors(
                    containerColor = when {
                        driver.performanceScore >= 90 -> SuccessGreen
                        driver.performanceScore >= 75 -> EdhamOrange
                        driver.performanceScore >= 60 -> WarningYellow
                        else -> ErrorRed
                    }
                ),
                shape = RoundedCornerShape(8.dp)
            ) {
                Text(
                    text = when {
                        driver.performanceScore >= 90 -> "Excellent"
                        driver.performanceScore >= 75 -> "Good"
                        driver.performanceScore >= 60 -> "Average"
                        else -> "Poor"
                    },
                    modifier = Modifier.padding(horizontal = 8.dp, vertical = 4.dp),
                    style = MaterialTheme.typography.bodySmall,
                    color = Color.White,
                    fontWeight = FontWeight.Medium
                )
            }
        }
    }
}

