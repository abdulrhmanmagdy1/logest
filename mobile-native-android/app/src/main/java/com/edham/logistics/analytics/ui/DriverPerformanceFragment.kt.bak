import javax.inject.Inject

/**
 * Driver Performance Fragment - Comprehensive driver performance analytics
 * 
 * Features:
 * - Driver performance overview
 * - Performance metrics and KPIs
 * - Driver rankings and leaderboards
 * - Performance trends
 * - Individual driver details
 * - Performance comparisons
 * - Interactive charts
 */
@AndroidEntryPoint
class DriverPerformanceFragment : Fragment() {
    
    @Inject
    lateinit var analyticsEngineService: AnalyticsEngineService
    
    private val viewModel: DriverPerformanceViewModel by viewModels()
    
    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View {
        return ComposeView(requireContext()).apply {
            setContent {
                EdhamLogisticsTheme {
                    DriverPerformanceScreen(
                        viewModel = viewModel,
                        analyticsEngineService = analyticsEngineService
                    )
                }
            }
        }
    }
    
    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        
        // Initialize analytics engine
        lifecycleScope.launch {
            analyticsEngineService.initialize()
        }
        
        // Load driver performance analytics
        viewModel.loadDriverPerformanceAnalytics()
    }
}

@Composable
fun DriverPerformanceScreen(
    viewModel: DriverPerformanceViewModel,
    analyticsEngineService: AnalyticsEngineService
) {
    val driverAnalytics by viewModel.driverAnalytics.collectAsStateWithLifecycle()
    val isLoading by viewModel.isLoading.collectAsStateWithLifecycle()
    val errorMessage by viewModel.errorMessage.collectAsStateWithLifecycle()
    val selectedTimeRange by viewModel.selectedTimeRange.collectAsStateWithLifecycle()
    val selectedDriver by viewModel.selectedDriver.collectAsStateWithLifecycle()
    
    LaunchedEffect(selectedTimeRange) {
        viewModel.loadDriverPerformanceAnalytics()
    }
    
    Column(
        modifier = Modifier
            .fillMaxSize()
            .padding(16.dp),
        verticalArrangement = Arrangement.spacedBy(16.dp)
    ) {
        // Header with time range selector
        DriverPerformanceHeader(
            selectedTimeRange = selectedTimeRange,
            onTimeRangeChanged = viewModel::setTimeRange,
            onRefresh = viewModel::refreshAnalytics,
            isLoading = isLoading
        )
        
        // Error message
        errorMessage?.let { error ->
            Card(
                modifier = Modifier.fillMaxWidth(),
                colors = CardDefaults.cardColors(
                    containerColor = ErrorRed.copy(alpha = 0.1f)
                ),
                elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
            ) {
                Text(
                    text = error,
                    modifier = Modifier.padding(16.dp),
                    color = ErrorRed,
                    style = MaterialTheme.typography.bodyMedium
                )
            }
        }
        
        // Driver Analytics Content
        driverAnalytics?.let { analytics ->
            // Performance Overview
            PerformanceOverviewSection(analytics = analytics)
            
            // Top Performers
            TopPerformersSection(analytics = analytics, onDriverSelected = viewModel::selectDriver)
            
            // Performance Metrics
            PerformanceMetricsSection(analytics = analytics)
            
            // Driver Rankings
            DriverRankingsSection(analytics = analytics, onDriverSelected = viewModel::selectDriver)
            
            // Performance Trends
            PerformanceTrendsSection(analytics = analytics)
            
            // Selected Driver Details
            selectedDriver?.let { driver ->
                SelectedDriverDetailsSection(
                    driver = driver,
                    analytics = analytics
                )
            }
        }
        
        // Loading indicator
        if (isLoading) {
            Box(
                modifier = Modifier.fillMaxWidth(),
                contentAlignment = Alignment.Center
            ) {
                CircularProgressIndicator(
                    color = EdhamOrange,
                    strokeWidth = 3.dp
                )
            }
        }
    }
}

@Composable
fun DriverPerformanceHeader(
    selectedTimeRange: TimeRange,
    onTimeRangeChanged: (TimeRange) -> Unit,
    onRefresh: () -> Unit,
    isLoading: Boolean
) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.surface
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Row(
                modifier = Modifier.fillMaxWidth(),
                horizontalArrangement = Arrangement.SpaceBetween,
                verticalAlignment = Alignment.CenterVertically
            ) {
                Text(
                    text = "Driver Performance Analytics",
                    style = MaterialTheme.typography.headlineMedium,
                    color = EdhamOrange,
                    fontWeight = FontWeight.Bold
                )
                
                Row {
                    // Time range selector
                    TimeRangeSelector(
                        selectedTimeRange = selectedTimeRange,
                        onTimeRangeChanged = onTimeRangeChanged
                    )
                    
                    Spacer(modifier = Modifier.width(8.dp))
                    
                    // Refresh button
                    IconButton(
                        onClick = onRefresh,
                        enabled = !isLoading
                    ) {
                        Icon(
                            painter = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_rotate),
                            contentDescription = "Refresh",
                            tint = EdhamOrange
                        )
                    }
                }
            }
        }
    }
}

@Composable
fun PerformanceOverviewSection(analytics: DriverPerformanceAnalytics) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.surface
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Text(
                text = "Performance Overview",
                style = MaterialTheme.typography.titleMedium,
                color = EdhamOrange,
                fontWeight = FontWeight.Bold
            )
            
            Spacer(modifier = Modifier.height(16.dp))
            
            LazyColumn(
                verticalArrangement = Arrangement.spacedBy(12.dp)
            ) {
                item {
                    OverviewMetric(
                        title = "Total Active Drivers",
                        value = analytics.totalActiveDrivers.toString(),
                        subtitle = "Currently active",
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_myplaces),
                        color = EdhamOrange,
                        change = analytics.activeDriversChange
                    )
                }
                
                item {
                    OverviewMetric(
                        title = "Average Performance Score",
                        value = String.format("%.1f", analytics.averagePerformanceScore),
                        subtitle = "Out of 100",
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_star),
                        color = if (analytics.averagePerformanceScore >= 80) SuccessGreen else WarningYellow,
                        change = analytics.averageScoreChange
                    )
                }
                
                item {
                    OverviewMetric(
                        title = "On-Time Delivery Rate",
                        value = "${String.format("%.1f", analytics.averageOnTimeDeliveryRate)}%",
                        subtitle = "Fleet average",
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_recent_history),
                        color = if (analytics.averageOnTimeDeliveryRate >= 90) SuccessGreen else WarningYellow,
                        change = analytics.onTimeDeliveryChange
                    )
                }
                
                item {
                    OverviewMetric(
                        title = "Average Daily Deliveries",
                        value = String.format("%.1f", analytics.averageDailyDeliveries),
                        subtitle = "Per driver",
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_agenda),
                        color = IceBlue,
                        change = analytics.dailyDeliveriesChange
                    )
                }
            }
        }
    }
}

@Composable
fun TopPerformersSection(
    analytics: DriverPerformanceAnalytics,
