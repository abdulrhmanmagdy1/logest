@Composable
fun SelectedDriverDetailsSection(
    driver: String,
    analytics: DriverPerformanceAnalytics
) {
    // Find driver details from analytics
    val driverDetails = analytics.driverRankings.find { it.driverId == driver }
    
    driverDetails?.let { details ->
        Card(
            modifier = Modifier.fillMaxWidth(),
            colors = CardDefaults.cardColors(
                containerColor = EdhamOrange.copy(alpha = 0.1f)
            ),
            elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
        ) {
            Column(
                modifier = Modifier.padding(16.dp)
            ) {
                Row(
                    modifier = Modifier.fillMaxWidth(),
                    horizontalArrangement = Arrangement.SpaceBetween,
                    verticalAlignment = Alignment.CenterVertically
                ) {
                    Text(
                        text = "Selected Driver",
                        style = MaterialTheme.typography.titleMedium,
                        color = EdhamOrange,
                        fontWeight = FontWeight.Bold
                    )
                    
                    IconButton(
                        onClick = { /* Clear selection */ }
                    ) {
                        Icon(
                            painter = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_close_clear_cancel),
                            contentDescription = "Clear",
                            tint = EdhamOrange
                        )
                    }
                }
                
                Spacer(modifier = Modifier.height(16.dp))
                
                LazyColumn(
                    verticalArrangement = Arrangement.spacedBy(12.dp)
                ) {
                    item {
                        DriverDetailMetric(
                            title = "Driver Name",
                            value = details.driverName
                        )
                    }
                    
                    item {
                        DriverDetailMetric(
                            title = "Performance Score",
                            value = String.format("%.1f", details.performanceScore)
                        )
                    }
                    
                    item {
                        DriverDetailMetric(
                            title = "Total Deliveries",
                            value = details.totalDeliveries.toString()
                        )
                    }
                    
                    item {
                        DriverDetailMetric(
                            title = "On-Time Rate",
                            value = "${String.format("%.1f", details.onTimeDeliveryRate)}%"
                        )
                    }
                    
                    item {
                        DriverDetailMetric(
                            title = "Customer Rating",
                            value = String.format("%.1f", details.customerRating)
                        )
                    }
                    
                    item {
                        DriverDetailMetric(
                            title = "Safety Score",
                            value = String.format("%.1f", details.safetyScore)
                        )
                    }
                }
            }
        }
    }
}

@Composable
fun DriverDetailMetric(
    title: String,
    value: String
) {
    Row(
        modifier = Modifier.fillMaxWidth(),
        horizontalArrangement = Arrangement.SpaceBetween,
        verticalAlignment = Alignment.CenterVertically
    ) {
        Text(
            text = title,
            style = MaterialTheme.typography.bodyMedium,
            color = MaterialTheme.colorScheme.onSurface.copy(alpha = 0.7f)
        )
        
        Text(
            text = value,
            style = MaterialTheme.typography.bodyLarge,
            color = EdhamOrange,
            fontWeight = FontWeight.Bold
        )
    }
}

// Data classes
data class DriverPerformanceData(
    val driverId: String,
    val driverName: String,
    val rank: Int,
    val performanceScore: Float,
    val totalDeliveries: Int,
    val onTimeDeliveryRate: Float,
    val customerRating: Float,
    val safetyScore: Float,
    val vehicleType: String
)
