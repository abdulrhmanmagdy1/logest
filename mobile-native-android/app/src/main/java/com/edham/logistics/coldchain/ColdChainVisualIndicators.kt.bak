/**
 * Cold-chain visual indicators component
 * Provides visual temperature status with safe/warning/critical indicators
 */
@Composable
fun ColdChainVisualIndicators(
    temperature: Double?,
    status: ColdChainMonitoringService.TemperatureStatus,
    minTemperature: Double,
    maxTemperature: Double,
    criticalMinTemperature: Double,
    criticalMaxTemperature: Double,
    unit: String = "°C",
    modifier: Modifier = Modifier
) {
    val statusColor = getStatusColor(status)
    val statusIcon = getStatusIcon(status)
    val statusMessage = getStatusMessage(status, temperature, minTemperature, maxTemperature)
    
    Column(
        modifier = modifier
            .fillMaxWidth()
            .background(
                Brush.verticalGradient(
                    colors = listOf(
                        Color(0xFF1A1A1A),
                        Color(0xFF0A0A0A)
                    )
                )
            )
            .padding(16.dp),
        horizontalAlignment = Alignment.CenterHorizontally
    ) {
        // Temperature display with animation
        AnimatedTemperatureDisplay(
            temperature = temperature,
            statusColor = statusColor,
            statusIcon = statusIcon,
            unit = unit
        )
        
        Spacer(modifier = Modifier.height(16.dp))
        
        // Status message
        Text(
            text = statusMessage,
            fontSize = 16.sp,
            fontWeight = FontWeight.Medium,
            color = Color.White,
            textAlign = TextAlign.Center
        )
        
        Spacer(modifier = Modifier.height(16.dp))
        
        // Temperature gauge
        TemperatureGauge(
            temperature = temperature ?: 0.0,
            minTemperature = minTemperature,
            maxTemperature = maxTemperature,
            criticalMinTemperature = criticalMinTemperature,
            criticalMaxTemperature = criticalMaxTemperature,
            statusColor = statusColor
        )
        
        Spacer(modifier = Modifier.height(16.dp))
        
        // Threshold indicators
        ThresholdIndicators(
            minTemperature = minTemperature,
            maxTemperature = maxTemperature,
            criticalMinTemperature = criticalMinTemperature,
            criticalMaxTemperature = criticalMaxTemperature,
            unit = unit
        )
    }
}

/**
 * Animated temperature display
 */
@Composable
private fun AnimatedTemperatureDisplay(
    temperature: Double?,
    statusColor: Color,
    statusIcon: ImageVector,
    unit: String
) {
    val animatedTemperature by animateFloatAsState(
        targetValue = temperature?.toFloat() ?: 0f,
        animationSpec = tween(duration = 1000, easing = EaseInOutCubic)
    )
    
    Row(
        verticalAlignment = Alignment.CenterVertically,
        horizontalArrangement = Arrangement.Center
    ) {
        // Status icon with animation
        Icon(
            imageVector = statusIcon,
            contentDescription = "Temperature Status",
            tint = statusColor,
            modifier = Modifier.size(32.dp)
        )
        
        Spacer(modifier = Modifier.width(12.dp))
        
        // Temperature text
        Text(
            text = if (temperature != null) {
                String.format("%.1f%s", animatedTemperature, unit)
            } else {
                "--$unit"
            },
            fontSize = 32.sp,
            fontWeight = FontWeight.Bold,
            color = statusColor,
            textAlign = TextAlign.Center
        )
    }
}

/**
 * Temperature gauge component
 */
@Composable
private fun TemperatureGauge(
    temperature: Double,
    minTemperature: Double,
    maxTemperature: Double,
    criticalMinTemperature: Double,
    criticalMaxTemperature: Double,
    statusColor: Color
) {
    val gaugeHeight = 200.dp
    val gaugeWidth = 40.dp
    
    Box(
        modifier = Modifier
            .height(gaugeHeight)
            .width(gaugeWidth),
        contentAlignment = Alignment.Center
    ) {
        Canvas(modifier = Modifier.fillMaxSize()) {
            drawTemperatureGauge(
                temperature = temperature,
                minTemperature = minTemperature,
                maxTemperature = maxTemperature,
                criticalMinTemperature = criticalMinTemperature,
                criticalMaxTemperature = criticalMaxTemperature,
                statusColor = statusColor,
                size = Size(width.toFloat(), height.toFloat())
            )
        }
    }
}

/**
 * Draw temperature gauge on canvas
 */
private fun DrawScope.drawTemperatureGauge(
    temperature: Double,
    minTemperature: Double,
    maxTemperature: Double,
    criticalMinTemperature: Double,
    criticalMaxTemperature: Double,
    statusColor: Color,
    size: Size
) {
    val centerX = size.width / 2
    val gaugeHeight = size.height - 40f // Leave space for labels
    val gaugeTop = 20f
    
    // Calculate temperature position
    val tempRange = maxTemperature - minTemperature
    val tempPosition = if (tempRange > 0) {
        ((temperature - minTemperature) / tempRange).coerceIn(0.0, 1.0)
    } else {
        0.5
    }
    
    val indicatorY = gaugeTop + (gaugeHeight * (1 - tempPosition.toFloat()))
    
    // Draw gauge background
    drawRoundRect(
        color = Color.White.copy(alpha = 0.1f),
        topLeft = Offset(centerX - 15f, gaugeTop),
        size = Size(30f, gaugeHeight),
        cornerRadius = androidx.compose.ui.geometry.CornerRadius(15f)
    )
    
    // Draw safe zone
    val safeZoneTop = gaugeTop + (gaugeHeight * (1 - ((maxTemperature - minTemperature) / tempRange).toFloat()))
    val safeZoneBottom = gaugeTop + (gaugeHeight * (1 - ((criticalMinTemperature - minTemperature) / tempRange).toFloat()))
    
    drawRoundRect(
        color = Color(0xFF10B981).copy(alpha = 0.3f),
        topLeft = Offset(centerX - 15f, safeZoneTop),
        size = Size(30f, safeZoneBottom - safeZoneTop),
        cornerRadius = androidx.compose.ui.geometry.CornerRadius(15f)
    )
    
    // Draw critical zones
    val criticalTopZone = gaugeTop
    val criticalTopZoneBottom = gaugeTop + (gaugeHeight * (1 - ((criticalMinTemperature - minTemperature) / tempRange).toFloat()))
    
    drawRoundRect(
        color = Color(0xFFEF4444).copy(alpha = 0.3f),
        topLeft = Offset(centerX - 15f, criticalTopZone),
        size = Size(30f, criticalTopZoneBottom - criticalTopZone),
        cornerRadius = androidx.compose.ui.geometry.CornerRadius(15f)
    )
    
    val criticalBottomZone = gaugeTop + (gaugeHeight * (1 - ((criticalMaxTemperature - minTemperature) / tempRange).toFloat()))
    val criticalBottomZoneBottom = gaugeTop + gaugeHeight
    
    drawRoundRect(
        color = Color(0xFFEF4444).copy(alpha = 0.3f),
        topLeft = Offset(centerX - 15f, criticalBottomZone),
        size = Size(30f, criticalBottomZoneBottom - criticalBottomZone),
        cornerRadius = androidx.compose.ui.geometry.CornerRadius(15f)
    )
    
    // Draw temperature indicator
    drawCircle(
        color = statusColor,
        radius = 12f,
        center = Offset(centerX, indicatorY)
    )
    
    // Draw indicator glow effect
    drawCircle(
        color = statusColor.copy(alpha = 0.3f),
        radius = 20f,
        center = Offset(centerX, indicatorY)
    )
    
    // Draw temperature labels
    val labelColor = Color.White.copy(alpha = 0.7f)
    
    // Max temperature label
    drawContext {
        val textPainter = androidx.compose.ui.graphics.painter.TextPainter()
        textPainter.text = "%.0f°".format(maxTemperature)
        textPainter.style = androidx.compose.ui.graphics.painter.PaintStyle().apply {
            color = labelColor
            fontSize = 12.sp.toPx()
        }
        
        textPainter.align = androidx.compose.ui.graphics.painter.TextPainter.Align.Center
        textPainter.layout(size.width, Float.POSITIVE_INFINITY)
        textPainter.paint(
            drawContext.canvas,
            Offset(centerX, gaugeTop - 10f)
        )
    }
    
    // Min temperature label
    drawContext {
        val textPainter = androidx.compose.ui.graphics.painter.TextPainter()
        textPainter.text = "%.0f°".format(minTemperature)
        textPainter.style = androidx.compose.ui.graphics.painter.PaintStyle().apply {
            color = labelColor
            fontSize = 12.sp.toPx()
        }
        
        textPainter.align = androidx.compose.ui.graphics.painter.TextPainter.Align.Center
        textPainter.layout(size.width, Float.POSITIVE_INFINITY)
        textPainter.paint(
            drawContext.canvas,
            Offset(centerX, gaugeTop + gaugeHeight + 20f)
        )
    }
}

/**
 * Threshold indicators component
 */
@Composable
private fun ThresholdIndicators(
    minTemperature: Double,
    maxTemperature: Double,
    criticalMinTemperature: Double,
    criticalMaxTemperature: Double,
    unit: String
) {
    Column(
        modifier = Modifier.fillMaxWidth(),
        horizontalAlignment = Alignment.CenterHorizontally
    ) {
        // Safe range indicator
        Row(
            verticalAlignment = Alignment.CenterVertically,
            horizontalArrangement = Arrangement.spacedBy(8.dp)
        ) {
            Box(
                modifier = Modifier
                    .size(12.dp)
                    .background(
                        Color(0xFF10B981),
                        shape = androidx.compose.foundation.shape.CircleShape
                    )
            )
            
            Text(
                text = "Safe: %.1f%s - %.1f%s".format(minTemperature, unit, maxTemperature, unit),
                fontSize = 14.sp,
                color = Color(0xFF10B981),
                fontWeight = FontWeight.Medium
            )
        }
        
        Spacer(modifier = Modifier.height(8.dp))
        
        // Critical range indicators
        Row(
            verticalAlignment = Alignment.CenterVertically,
            horizontalArrangement = Arrangement.spacedBy(8.dp)
        ) {
            Box(
                modifier = Modifier
                    .size(12.dp)
                    .background(
                        Color(0xFFEF4444),
                        shape = androidx.compose.foundation.shape.CircleShape
                    )
            )
            
            Text(
                text = "Critical: < %.1f%s or > %.1f%s".format(criticalMinTemperature, unit, criticalMaxTemperature, unit),
                fontSize = 14.sp,
                color = Color(0xFFEF4444),
                fontWeight = FontWeight.Medium
            )
        }
    }
}

/**
 * Compact temperature indicator for lists
 */
@Composable
fun CompactTemperatureIndicator(
    temperature: Double?,
    status: ColdChainMonitoringService.TemperatureStatus,
    modifier: Modifier = Modifier
) {
    val statusColor = getStatusColor(status)
    val statusIcon = getStatusIcon(status)
    
    Row(
        modifier = modifier
            .clip(RoundedCornerShape(8.dp))
            .background(statusColor.copy(alpha = 0.1f))
            .padding(horizontal = 8.dp, vertical = 4.dp),
        verticalAlignment = Alignment.CenterVertically,
        horizontalArrangement = Arrangement.spacedBy(4.dp)
    ) {
        Icon(
            imageVector = statusIcon,
            contentDescription = "Temperature Status",
            tint = statusColor,
            modifier = Modifier.size(16.dp)
        )
        
        Text(
            text = if (temperature != null) {
                "%.1f°C".format(temperature)
            } else {
                "--°C"
            },
            fontSize = 14.sp,
            fontWeight = FontWeight.Medium,
            color = statusColor
        )
    }
}

/**
 * Temperature trend indicator
 */
@Composable
fun TemperatureTrendIndicator(
    readings: List<Double>,
    modifier: Modifier = Modifier
) {
    if (readings.size < 2) return
    
    val trend = calculateTrend(readings.takeLast(10))
    val trendColor = getTrendColor(trend)
    val trendIcon = getTrendIcon(trend)
    
    Row(
        modifier = modifier,
        verticalAlignment = Alignment.CenterVertically,
        horizontalArrangement = Arrangement.spacedBy(4.dp)
    ) {
        Icon(
            imageVector = trendIcon,
            contentDescription = "Temperature Trend",
            tint = trendColor,
            modifier = Modifier.size(16.dp)
        )
        
        Text(
            text = getTrendText(trend),
            fontSize = 12.sp,
            color = trendColor,
            fontWeight = FontWeight.Medium
        )
    }
}

/**
 * Temperature history chart
 */
@Composable
fun TemperatureHistoryChart(
    readings: List<Pair<Double, Long>>,
    modifier: Modifier = Modifier
) {
    Canvas(modifier = modifier.fillMaxSize().height(120.dp)) {
        drawTemperatureChart(readings, size)
    }
}

/**
 * Draw temperature history chart
 */
private fun DrawScope.drawTemperatureChart(readings: List<Pair<Double, Long>>, size: Size) {
    if (readings.size < 2) return
    
    val padding = 16f
    val chartWidth = size.width - (padding * 2)
    val chartHeight = size.height - (padding * 2)
    
    // Find min and max values
    val temperatures = readings.map { it.first }
    val minTemp = temperatures.minOrNull() ?: 0.0
    val maxTemp = temperatures.maxOrNull() ?: 0.0
    val tempRange = maxTemp - minTemp
    
    if (tempRange == 0.0) return
    
    // Draw grid lines
    val gridColor = Color.White.copy(alpha = 0.1f)
    for (i in 0..4) {
        val y = padding + (chartHeight * i / 4)
        drawLine(
            start = Offset(padding, y),
            end = Offset(size.width - padding, y),
            color = gridColor,
            strokeWidth = 1f
        )
    }
    
    // Draw temperature line
    val path = Path()
    readings.forEachIndexed { index, (temp, timestamp) ->
        val x = padding + (chartWidth * index / (readings.size - 1))
        val y = padding + chartHeight - (chartHeight * ((temp - minTemp) / tempRange).toFloat())
        
        if (index == 0) {
            path.moveTo(x, y)
        } else {
            path.lineTo(x, y)
        }
    }
    
    drawPath(
        path = path,
        color = Color(0xFF3B82F6),
        style = androidx.compose.ui.graphics.drawscope.DrawStyle().apply {
            strokeWidth = 2f
        }
    )
    
    // Draw data points
    readings.forEachIndexed { index, (temp, timestamp) ->
        val x = padding + (chartWidth * index / (readings.size - 1))
        val y = padding + chartHeight - (chartHeight * ((temp - minTemp) / tempRange).toFloat())
        
        drawCircle(
            color = Color(0xFF3B82F6),
            radius = 4f,
            center = Offset(x, y)
        )
        
        drawCircle(
            color = Color.White,
            radius = 2f,
            center = Offset(x, y)
        )
    }
}

// Helper functions
private fun getStatusColor(status: ColdChainMonitoringService.TemperatureStatus): Color {
    return when (status) {
        ColdChainMonitoringService.TemperatureStatus.SAFE -> Color(0xFF10B981)
        ColdChainMonitoringService.TemperatureStatus.WARNING -> Color(0xFFF59E0B)
        ColdChainMonitoringService.TemperatureStatus.CRITICAL -> Color(0xFFEF4444)
        ColdChainMonitoringService.TemperatureStatus.NO_DATA -> Color(0xFF9CA3AF)
    }
}

private fun getStatusIcon(status: ColdChainMonitoringService.TemperatureStatus): ImageVector {
    return when (status) {
        ColdChainMonitoringService.TemperatureStatus.SAFE -> Icons.Default.CheckCircle
        ColdChainMonitoringService.TemperatureStatus.WARNING -> Icons.Default.Warning
        ColdChainMonitoringService.TemperatureStatus.CRITICAL -> Icons.Default.Error
        ColdChainMonitoringService.TemperatureStatus.NO_DATA -> Icons.Default.Thermostat
    }
}

private fun getStatusMessage(status: ColdChainMonitoringService.TemperatureStatus, temperature: Double?, minTemp: Double, maxTemp: Double): String {
    return when (status) {
        ColdChainMonitoringService.TemperatureStatus.SAFE -> {
            if (temperature != null) {
                "Temperature is safe: %.1f°C".format(temperature)
            } else {
                "Temperature status unknown"
            }
        }
        ColdChainMonitoringService.TemperatureStatus.WARNING -> {
            if (temperature != null) {
                "Warning: %.1f°C outside safe range (%.1f°C - %.1f°C)".format(temperature, minTemp, maxTemp)
            } else {
                "Temperature warning"
            }
        }
        ColdChainMonitoringService.TemperatureStatus.CRITICAL -> {
            if (temperature != null) {
                "Critical: %.1f°C requires immediate attention!".format(temperature)
            } else {
                "Critical temperature alert"
            }
        }
        ColdChainMonitoringService.TemperatureStatus.NO_DATA -> "No temperature data available"
    }
}

private fun calculateTrend(readings: List<Double>): Double {
    if (readings.size < 2) return 0.0
    
    val firstHalf = readings.take(readings.size / 2).average()
    val secondHalf = readings.drop(readings.size / 2).average()
    
    return secondHalf - firstHalf
}

private fun getTrendColor(trend: Double): Color {
    return when {
        trend > 0.5 -> Color(0xFFEF4444) // Rising rapidly
        trend > 0.1 -> Color(0xFFF59E0B) // Rising
        trend < -0.5 -> Color(0xFF3B82F6) // Falling rapidly
        trend < -0.1 -> Color(0xFF10B981) // Falling
        else -> Color(0xFF9CA3AF) // Stable
    }
}

private fun getTrendIcon(trend: Double): ImageVector {
    return when {
        trend > 0.1 -> Icons.Default.TrendingUp
        trend < -0.1 -> Icons.Default.TrendingDown
        else -> Icons.Default.TrendingFlat
    }
}

private fun getTrendText(trend: Double): String {
    return when {
        trend > 0.5 -> "Rising rapidly"
        trend > 0.1 -> "Rising"
        trend < -0.5 -> "Falling rapidly"
        trend < -0.1 -> "Falling"
        else -> "Stable"
    }
}
