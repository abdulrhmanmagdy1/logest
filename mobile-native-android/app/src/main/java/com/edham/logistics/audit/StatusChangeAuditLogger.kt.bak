    /**
     * Log system status change
     */
    fun logSystemStatusChange(
        userId: String,
        componentId: String,
        componentName: String,
        oldStatus: String,
        newStatus: String,
        reason: String? = null,
        impactLevel: String? = null
    ) {
        logStatusChange(
            userId = userId,
            entityType = "SYSTEM",
            entityId = componentId,
            entityIdentifier = componentName,
            oldStatus = oldStatus,
            newStatus = newStatus,
            reason = reason,
            additionalData = mapOf(
                "componentName" to componentName,
                "impactLevel" to impactLevel
            ).filterValues { it != null }
        )
    }
    
    /**
     * Log batch status changes
     */
    fun logBatchStatusChanges(
        userId: String,
        statusChanges: List<StatusChangeBatch>
    ) {
        statusChanges.forEach { change ->
            logStatusChange(
                userId = userId,
                entityType = change.entityType,
                entityId = change.entityId,
                entityIdentifier = change.entityIdentifier,
                oldStatus = change.oldStatus,
                newStatus = change.newStatus,
                reason = change.reason,
                additionalData = change.additionalData
            )
        }
        
        // Also log the batch operation
        auditSystem?.logOperation(
            userId = userId,
            entityType = "BATCH_STATUS_CHANGE",
            entityId = "batch_${System.currentTimeMillis()}",
            operation = AuditOperation.UPDATE,
            description = "Batch status changes: ${statusChanges.size} entities updated",
            beforeData = mapOf(
                "batchSize" to statusChanges.size,
                "changes" to statusChanges.map { 
                    "${it.entityIdentifier}: ${it.oldStatus} → ${it.newStatus}" 
                }
            ),
            afterData = mapOf(
                "batchCompleted" to true,
                "batchTimestamp" to System.currentTimeMillis()
            ),
            metadata = mapOf(
                "batchSize" to statusChanges.size,
                "entityTypes" to statusChanges.map { it.entityType }.distinct(),
                "batchTimestamp" to System.currentTimeMillis(),
                "batchBy" to userId
            )
        )
    }
    
    /**
     * Log status change reversal
     */
    fun logStatusChangeReversal(
        userId: String,
        entityType: String,
        entityId: String,
        entityIdentifier: String,
        originalStatus: String,
        reversedStatus: String,
        reversalReason: String,
        originalChangeId: String? = null
    ) {
        auditSystem?.logOperation(
            userId = userId,
            entityType = "${entityType}_STATUS_REVERSAL",
            entityId = entityId,
            operation = AuditOperation.UPDATE,
            description = "$entityType status reversal: $entityIdentifier from $reversedStatus back to $originalStatus",
            beforeData = mapOf(
                "status" to reversedStatus,
                "originalStatus" to originalStatus,
                "reversalReason" to reversalReason
            ),
            afterData = mapOf(
                "status" to originalStatus,
                "reversedAt" to System.currentTimeMillis()
            ),
            metadata = mapOf(
                "entityType" to entityType,
                "entityId" to entityId,
                "entityIdentifier" to entityIdentifier,
                "originalStatus" to originalStatus,
                "reversedStatus" to reversedStatus,
                "reversalReason" to reversalReason,
                "originalChangeId" to originalChangeId,
                "reversalTimestamp" to System.currentTimeMillis(),
                "reversedBy" to userId
            )
        )
    }
    
    /**
     * Log status change approval
     */
    fun logStatusChangeApproval(
        userId: String,
        approverUserId: String,
        entityType: String,
        entityId: String,
        entityIdentifier: String,
        status: String,
        approvalType: String,
        comments: String? = null
    ) {
        auditSystem?.logOperation(
            userId = approverUserId,
            entityType = "${entityType}_STATUS_APPROVAL",
            entityId = entityId,
            operation = AuditOperation.UPDATE,
            description = "$entityType status change approved: $entityIdentifier - $status",
            beforeData = mapOf(
                "status" to status,
                "approvalRequired" to true
            ),
            afterData = mapOf(
                "status" to status,
                "approved" to true,
                "approvedAt" to System.currentTimeMillis()
            ),
            metadata = mapOf(
                "entityType" to entityType,
                "entityId" to entityId,
                "entityIdentifier" to entityIdentifier,
                "status" to status,
                "approvalType" to approvalType,
                "requestedBy" to userId,
                "approvedBy" to approverUserId,
                "comments" to comments,
                "approvalTimestamp" to System.currentTimeMillis()
            )
        )
    }
    
    /**
     * Log status change rejection
     */
    fun logStatusChangeRejection(
        userId: String,
        approverUserId: String,
        entityType: String,
        entityId: String,
        entityIdentifier: String,
        requestedStatus: String,
        currentStatus: String,
        rejectionReason: String
    ) {
        auditSystem?.logOperation(
            userId = approverUserId,
            entityType = "${entityType}_STATUS_REJECTION",
            entityId = entityId,
            operation = AuditOperation.UPDATE,
            description = "$entityType status change rejected: $entityIdentifier - $requestedStatus",
            beforeData = mapOf(
                "requestedStatus" to requestedStatus,
                "currentStatus" to currentStatus,
                "rejectionRequired" to true
            ),
            afterData = mapOf(
                "currentStatus" to currentStatus,
                "rejected" to true,
                "rejectedAt" to System.currentTimeMillis()
            ),
            metadata = mapOf(
                "entityType" to entityType,
                "entityId" to entityId,
                "entityIdentifier" to entityIdentifier,
                "requestedStatus" to requestedStatus,
                "currentStatus" to currentStatus,
                "rejectionReason" to rejectionReason,
                "requestedBy" to userId,
                "rejectedBy" to approverUserId,
                "rejectionTimestamp" to System.currentTimeMillis()
            )
        )
    }
    
    /**
     * Get status change history for entity
     */
    fun getStatusChangeHistory(
        entityType: String,
        entityId: String,
        limit: Int = 50
    ): List<Map<String, Any>> {
        return runBlocking {
            auditSystem?.getEntityAuditHistory("${entityType}_STATUS", entityId, limit)?.map { log ->
                mapOf(
                    "id" to log.id,
                    "userId" to log.userId,
                    "operation" to log.operation.name,
                    "description" to log.description,
                    "timestamp" to log.timestamp,
                    "beforeData" to log.beforeData,
                    "afterData" to log.afterData,
                    "metadata" to log.metadata,
                    "ipAddress" to log.ipAddress
                )
            } ?: emptyList()
        }
    }
    
    /**
     * Get all status changes by user
     */
    fun getUserStatusChangeHistory(
        userId: String,
        limit: Int = 100
    ): List<Map<String, Any>> {
        return runBlocking {
            auditSystem?.getUserAuditHistory(userId, limit)?.filter { log ->
                log.operation == AuditOperation.STATUS_CHANGE ||
                log.entityType?.endsWith("_STATUS") == true
            }?.map { log ->
                mapOf(
                    "id" to log.id,
                    "entityType" to log.entityType,
                    "entityId" to log.entityId,
                    "operation" to log.operation.name,
                    "description" to log.description,
                    "timestamp" to log.timestamp,
                    "beforeData" to log.beforeData,
                    "afterData" to log.afterData,
                    "metadata" to log.metadata,
                    "ipAddress" to log.ipAddress
                )
            } ?: emptyList()
        }
    }
    
    /**
     * Get status change statistics
     */
    fun getStatusChangeStatistics(): Map<String, Any> {
        return runBlocking {
            val allStatusLogs = auditSystem?.getAuditLogs(
                limit = 10000
            )?.filter { log ->
                log.operation == AuditOperation.STATUS_CHANGE ||
                log.entityType?.endsWith("_STATUS") == true
            } ?: emptyList()
            
            val totalStatusChanges = allStatusLogs.size
            val changesByEntityType = allStatusLogs.groupBy { 
                it.entityType?.replace("_STATUS", "") ?: "UNKNOWN"
            }.mapValues { it.value.size }
            
            val changesByUser = allStatusLogs.groupBy { it.userId }.mapValues { it.value.size }
                .toList().sortedByDescending { it.second }.take(10)
            
            val recentChanges = allStatusLogs.filter { 
                System.currentTimeMillis() - it.timestamp < 24 * 60 * 60 * 1000L 
            }.size
            
            val statusTransitions = allStatusLogs.mapNotNull { log ->
                val oldStatus = log.beforeData?.get("status") as? String
                val newStatus = log.afterData?.get("status") as? String
                if (oldStatus != null && newStatus != null) {
                    "$oldStatus → $newStatus"
                } else null
            }.groupBy { it }.mapValues { it.value.size }
            
            mapOf(
                "totalStatusChanges" to totalStatusChanges,
                "changesByEntityType" to changesByEntityType,
                "changesByUser" to changesByUser,
                "recentChanges24h" to recentChanges,
                "statusTransitions" to statusTransitions
            )
        }
    }
    
    /**
     * Get status change trends
     */
    fun getStatusChangeTrends(days: Int = 30): Map<String, Any> {
        return runBlocking {
            val cutoffTime = System.currentTimeMillis() - (days * 24 * 60 * 60 * 1000L)
            val trendLogs = auditSystem?.getAuditLogs(
                startDate = cutoffTime,
                limit = 50000
            )?.filter { log ->
                log.operation == AuditOperation.STATUS_CHANGE ||
                log.entityType?.endsWith("_STATUS") == true
            } ?: emptyList()
            
            val dailyChanges = trendLogs.groupBy { log ->
                val date = java.util.Date(log.timestamp)
                java.text.SimpleDateFormat("yyyy-MM-dd", java.util.Locale.getDefault()).format(date)
            }.mapValues { it.value.size }
            
            val entityTypeTrends = trendLogs.groupBy { log ->
                log.entityType?.replace("_STATUS", "") ?: "UNKNOWN"
            }.mapValues { changes ->
                changes.groupBy { log ->
                    val date = java.util.Date(log.timestamp)
                    java.text.SimpleDateFormat("yyyy-MM-dd", java.util.Locale.getDefault()).format(date)
                }.mapValues { it.value.size }
            }
            
            mapOf(
                "dailyChanges" to dailyChanges,
                "entityTypeTrends" to entityTypeTrends,
                "totalPeriodChanges" to trendLogs.size,
                "averageDailyChanges" to if (days > 0) trendLogs.size.toDouble() / days else 0.0
            )
        }
    }
}

/**
 * Data class for batch status changes
 */
data class StatusChangeBatch(
    val entityType: String,
    val entityId: String,
    val entityIdentifier: String,
    val oldStatus: String,
    val newStatus: String,
    val reason: String? = null,
    val additionalData: Map<String, Any>? = null
)
