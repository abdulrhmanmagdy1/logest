package com.edham.logistics.audit

import kotlinx.coroutines.runBlocking

/**
 * Status Change Audit Logger - Specialized audit logging for status changes across all entities
 */
class StatusChangeAuditLogger private constructor() {
    
    companion object {
        @Volatile
        private var INSTANCE: StatusChangeAuditLogger? = null
        
        fun getInstance(): StatusChangeAuditLogger {
            return INSTANCE ?: synchronized(this) {
                INSTANCE ?: StatusChangeAuditLogger().also { INSTANCE = it }
            }
        }
    }
    
    private var auditSystem: AuditLogSystem? = null
    
    /**
     * Initialize with audit system
     */
    fun initialize(auditSystem: AuditLogSystem) {
        this.auditSystem = auditSystem
    }
    
    /**
     * Log general status change
     */
    fun logStatusChange(
        userId: String,
        entityType: String,
        entityId: String,
        entityIdentifier: String,
        oldStatus: String,
        newStatus: String,
        reason: String? = null,
        additionalData: Map<String, Any>? = null
    ) {
        auditSystem?.logStatusChange(
            userId = userId,
            entityType = entityType,
            entityId = entityId,
            oldStatus = oldStatus,
            newStatus = newStatus,
            reason = reason
        )
        
        // Also log detailed status change operation
        val description = buildString {
            append("$entityType status changed: $entityIdentifier")
            append(" from $oldStatus to $newStatus")
            if (reason != null) {
                append(" - Reason: $reason")
            }
        }
        
        auditSystem?.logOperation(
            userId = userId,
            entityType = "${entityType}_STATUS",
            entityId = entityId,
            operation = AuditOperation.STATUS_CHANGE,
            description = description,
            beforeData = mapOf(
                "status" to oldStatus,
                "entityType" to entityType,
                "entityIdentifier" to entityIdentifier
            ),
            afterData = mapOf(
                "status" to newStatus,
                "entityType" to entityType,
                "entityIdentifier" to entityIdentifier
            ),
            metadata = mapOf(
                "entityType" to entityType,
                "entityId" to entityId,
                "entityIdentifier" to entityIdentifier,
                "oldStatus" to oldStatus,
                "newStatus" to newStatus,
                "reason" to reason,
                "statusChangeTimestamp" to System.currentTimeMillis()
            ) + (additionalData ?: emptyMap())
        )
    }
    
    /**
     * Log shipment status change
     */
    fun logShipmentStatusChange(
        userId: String,
        shipmentId: String,
        trackingNumber: String,
        oldStatus: String,
        newStatus: String,
        reason: String? = null,
        location: String? = null,
        driverId: String? = null
    ) {
        logStatusChange(
            userId = userId,
            entityType = "SHIPMENT",
            entityId = shipmentId,
            entityIdentifier = trackingNumber,
            oldStatus = oldStatus,
            newStatus = newStatus,
            reason = reason,
            additionalData = mapOf(
                "trackingNumber" to trackingNumber,
                "location" to location,
                "driverId" to driverId
            ).filterValues { it != null }
        )
    }
    
    /**
     * Log user status change
     */
    fun logUserStatusChange(
        userId: String,
        targetUserId: String,
        userName: String,
        oldStatus: String,
        newStatus: String,
        reason: String? = null
    ) {
        logStatusChange(
            userId = userId,
            entityType = "USER",
            entityId = targetUserId,
            entityIdentifier = userName,
            oldStatus = oldStatus,
            newStatus = newStatus,
            reason = reason,
            additionalData = mapOf(
                "userName" to userName,
                "targetUserId" to targetUserId
            )
        )
    }
    
