    // Validation methods
    private suspend fun validateStripePayment(details: PaymentDetails): PaymentMethodValidation {
        // Stripe-specific validation logic
        return PaymentMethodValidation(
            isValid = true,
            errors = emptyList(),
            requirements = listOf("card_number", "expiry_date", "cvv")
        )
    }
    
    private suspend fun validatePayPalPayment(details: PaymentDetails): PaymentMethodValidation {
        // PayPal-specific validation logic
        return PaymentMethodValidation(
            isValid = true,
            errors = emptyList(),
            requirements = listOf("email", "password")
        )
    }
    
    private suspend fun validateMadaPayment(details: PaymentDetails): PaymentMethodValidation {
        // Mada-specific validation logic
        return PaymentMethodValidation(
            isValid = true,
            errors = emptyList(),
            requirements = listOf("card_number", "expiry_date", "cvv", "pin")
        )
    }
    
    private suspend fun validateBankTransferPayment(details: PaymentDetails): PaymentMethodValidation {
        // Bank transfer validation logic
        return PaymentMethodValidation(
            isValid = true,
            errors = emptyList(),
            requirements = listOf("account_number", "bank_name")
        )
    }
    
    private suspend fun validateMobileMoneyPayment(details: PaymentDetails): PaymentMethodValidation {
        // Mobile money validation logic
        return PaymentMethodValidation(
            isValid = true,
            errors = emptyList(),
            requirements = listOf("mobile_number", "provider")
        )
    }
    
    // Analytics methods
    private fun calculateDailyGatewayStats(transactions: List<PaymentTransaction>): Map<String, DailyGatewayStats> {
        return transactions.groupBy { 
            val calendar = Calendar.getInstance()
            calendar.time = it.createdAt
            "${calendar.get(Calendar.YEAR)}-${String.format("%02d", calendar.get(Calendar.MONTH) + 1)}-${String.format("%02d", calendar.get(Calendar.DAY_OF_MONTH))}"
        }.mapValues { (_, dayTransactions) ->
            DailyGatewayStats(
                transactionCount = dayTransactions.size,
                totalAmount = dayTransactions.sumOf { it.amount.toDouble() }.toFloat(),
                successfulTransactions = dayTransactions.count { it.status == PaymentStatus.COMPLETED }
            )
        }
    }
    
    private fun calculateErrorStats(transactions: List<PaymentTransaction>): Map<String, Int> {
        return transactions.filter { it.status == PaymentStatus.FAILED }
            .groupBy { it.errorMessage ?: "Unknown error" }
            .mapValues { it.value.size }
    }
    
    private suspend fun saveTransaction(request: PaymentGatewayRequest, response: PaymentGatewayResponse) {
        try {
            val transaction = PaymentTransaction(
                id = UUID.randomUUID().toString(),
                userId = request.userId,
                amount = request.amount,
                currency = request.currency,
                paymentMethod = request.paymentMethod,
                status = response.status,
                description = request.description,
                gatewayTransactionId = response.transactionId,
                gatewayResponse = response.gatewayResponse,
                createdAt = Date(),
                updatedAt = Date(),
                processedAt = response.processedAt
            )
            
            database.paymentTransactionDao().insertTransaction(transaction.toEntity())
        } catch (e: Exception) {
            // Handle error
        }
    }
    
    private suspend fun saveRefundTransaction(request: RefundRequest, response: PaymentGatewayResponse) {
        try {
            val refund = Refund(
                id = UUID.randomUUID().toString(),
                originalTransactionId = request.originalTransactionId,
                amount = request.amount,
                reason = request.reason,
                refundMethod = request.refundMethod,
                status = RefundStatus.COMPLETED,
                gatewayTransactionId = response.transactionId,
                gatewayResponse = response.gatewayResponse,
                createdAt = Date(),
                updatedAt = Date(),
                processedAt = response.processedAt
            )
            
            database.refundDao().insertRefund(refund.toEntity())
        } catch (e: Exception) {
            // Handle error
        }
    }
    
    private fun updateGatewayStats(gateway: PaymentGateway, success: Boolean) {
        val currentStats = _gatewayStats.value
        val updatedStats = currentStats.copy(
            totalTransactions = currentStats.totalTransactions + 1,
            successfulTransactions = if (success) currentStats.successfulTransactions + 1 else currentStats.successfulTransactions,
            failedTransactions = if (!success) currentStats.failedTransactions + 1 else currentStats.failedTransactions
        )
        
        _gatewayStats.value = updatedStats
    }
    
    /**
     * Get initialization status
     */
    fun isInitialized(): Boolean = isInitialized
}

/**
 * Data classes
 */
data class PaymentGatewayRequest(
    val userId: String,
    val amount: Float,
    val currency: String = "SAR",
    val paymentMethod: PaymentMethod,
    val description: String,
    val cardToken: String? = null,
    val cardNumber: String? = null,
    val expiryDate: String? = null,
    val cvv: String? = null,
    val mobileNumber: String? = null,
    val metadata: Map<String, String> = emptyMap()
)

data class PaymentGatewayResponse(
    val transactionId: String,
    val status: PaymentStatus,
    val amount: Float,
    val currency: String,
    val gateway: String,
    val gatewayResponse: Map<String, Any>,
    val processedAt: Date
)

data class PaymentGateway(
    val id: String,
    val name: String,
    val type: PaymentGatewayType,
    val isActive: Boolean,
    val supportedMethods: List<PaymentMethod>,
    val currencies: List<String>,
    val fees: PaymentFees,
    val configuration: Map<String, String>
)

data class PaymentFees(
    val percentageFee: Float,
    val fixedFee: Float,
    val currency: String
)

data class PaymentDetails(
    val paymentMethod: PaymentMethod,
    val cardNumber: String? = null,
    val expiryDate: String? = null,
    val cvv: String? = null,
    val mobileNumber: String? = null,
    val bankName: String? = null,
    val accountNumber: String? = null
)

data class PaymentMethodValidation(
    val isValid: Boolean,
    val errors: List<String>,
    val requirements: List<String>
)

data class GatewayAnalytics(
    val totalTransactions: Int,
    val successfulTransactions: Int,
    val failedTransactions: Int,
    val totalAmount: Float,
    val averageAmount: Float,
    val gatewayStats: Map<PaymentMethod, Int>,
    val currencyStats: Map<String, Float>,
    val dailyStats: Map<String, DailyGatewayStats>,
    val errorStats: Map<String, Int>
)

data class GatewayStats(
    val totalTransactions: Int = 0,
    val successfulTransactions: Int = 0,
    val failedTransactions: Int = 0,
    val successRate: Float = 0f
)

data class DailyGatewayStats(
    val transactionCount: Int,
    val totalAmount: Float,
    val successfulTransactions: Int
)

// Gateway-specific request data classes
data class StripePaymentRequest(
    val amount: Long,
    val currency: String,
    val cardToken: String,
    val description: String,
    val metadata: Map<String, String>
)

data class PayPalPaymentRequest(
    val amount: Float,
    val currency: String,
    val returnUrl: String,
    val cancelUrl: String,
    val description: String,
    val metadata: Map<String, String>
)

data class MadaPaymentRequest(
    val amount: Float,
    val currency: String,
    val cardNumber: String,
    val expiryDate: String,
    val cvv: String,
    val description: String,
    val metadata: Map<String, String>
)

data class RefundRequest(
    val originalTransactionId: String,
    val amount: Float,
    val reason: String,
    val refundMethod: PaymentMethod,
    val mobileNumber: String? = null
)

data class StripeRefundRequest(
    val paymentIntentId: String,
    val amount: Long,
    val reason: String
)

data class PayPalRefundRequest(
    val paymentId: String,
    val amount: Float,
    val reason: String
)

data class MadaRefundRequest(
    val transactionId: String,
    val amount: Float,
    val reason: String
)

/**
 * Enums
 */
enum class GatewayState {
    Idle,
    Initializing,
    Ready,
    Processing,
    Error
}

enum class PaymentGatewayType {
    STRIPE,
    PAYPAL,
    MADA,
    BANK_TRANSFER,
    MOBILE_MONEY
}
