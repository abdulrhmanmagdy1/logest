package com.edham.logistics.finance.gateway

import android.content.Context
import com.edham.logistics.data.local.database.EdhamDatabase
import com.edham.logistics.data.remote.api.PaymentGatewayApi
import com.edham.logistics.data.remote.api.stripe.StripeApi
import com.edham.logistics.data.remote.api.paypal.PayPalApi
import com.edham.logistics.data.remote.api.mada.MadaApi
import com.edham.logistics.utils.NetworkUtils
import com.edham.logistics.utils.SecurityUtils
import kotlinx.coroutines.Dispatchers
import kotlinx.coroutines.flow.MutableStateFlow
import kotlinx.coroutines.flow.StateFlow
import kotlinx.coroutines.flow.asStateFlow
import kotlinx.coroutines.withContext
import java.util.*
import javax.inject.Inject
import javax.inject.Singleton

/**
 * Payment Gateway Service - Manages payment processing through multiple gateways
 * 
 * Features:
 * - Multiple payment gateway support (Stripe, PayPal, Mada)
 * - Payment method validation
 * - Transaction processing and tracking
 * - Refund processing
 * - Payment security and encryption
 * - Currency conversion
 * - Error handling and retry logic
 * - Payment analytics
 */
@Singleton
class PaymentGatewayService @Inject constructor(
    private val context: Context,
    private val database: EdhamDatabase,
    private val paymentGatewayApi: PaymentGatewayApi,
    private val stripeApi: StripeApi,
    private val payPalApi: PayPalApi,
    private val madaApi: MadaApi,
    private val networkUtils: NetworkUtils,
    private val securityUtils: SecurityUtils
) {
    
    private val _gatewayState = MutableStateFlow<GatewayState>(GatewayState.Idle)
    val gatewayState: StateFlow<GatewayState> = _gatewayState.asStateFlow()
    
    private val _activeGateways = MutableStateFlow<List<PaymentGateway>>(emptyList())
    val activeGateways: StateFlow<List<PaymentGateway>> = _activeGateways.asStateFlow()
    
    private val _gatewayStats = MutableStateFlow<GatewayStats>(GatewayStats())
    val gatewayStats: StateFlow<GatewayStats> = _gatewayStats.asStateFlow()
    
    private var isInitialized = false
    
    companion object {
        private const val TAG = "PaymentGatewayService"
        private const val DEFAULT_CURRENCY = "SAR"
        private const val PAYMENT_TIMEOUT_MS = 30000L
        private const val MAX_RETRY_ATTEMPTS = 3
        private const val MIN_AMOUNT = 1f
        private const val MAX_AMOUNT = 50000f
    }
    
    /**
     * Initialize payment gateway service
     */
    suspend fun initialize(): Result<Boolean> {
        return withContext(Dispatchers.IO) {
            try {
                _gatewayState.value = GatewayState.Initializing
                
                // Load gateway configuration
                loadGatewayConfiguration()
                
                // Initialize payment gateways
                initializePaymentGateways()
                
                // Load active gateways
                loadActiveGateways()
                
                isInitialized = true
                _gatewayState.value = GatewayState.Ready
                Result.success(true)
                
            } catch (e: Exception) {
                _gatewayState.value = GatewayState.Error("Failed to initialize payment gateway service: ${e.message}")
                Result.failure(e)
            }
        }
    }
    
    /**
     * Process payment through appropriate gateway
     */
    suspend fun processPayment(
        paymentRequest: PaymentGatewayRequest
    ): Result<PaymentGatewayResponse> {
        return withContext(Dispatchers.IO) {
            try {
                if (!isInitialized) {
                    throw Exception("Payment gateway service not initialized")
                }
                
                _gatewayState.value = GatewayState.Processing
                
                // Validate payment request
                validatePaymentRequest(paymentRequest)
                
                // Select appropriate gateway
                val gateway = selectPaymentGateway(paymentRequest.paymentMethod)
                    ?: throw Exception("Payment gateway not available")
                
                // Process payment through selected gateway
                val result = when (gateway.type) {
                    PaymentGatewayType.STRIPE -> processStripePayment(paymentRequest)
                    PaymentGatewayType.PAYPAL -> processPayPalPayment(paymentRequest)
                    PaymentGatewayType.MADA -> processMadaPayment(paymentRequest)
                    PaymentGatewayType.BANK_TRANSFER -> processBankTransferPayment(paymentRequest)
                    PaymentGatewayType.MOBILE_MONEY -> processMobileMoneyPayment(paymentRequest)
                }
                
                if (result.isSuccess) {
                    val response = result.getOrThrow()
                    
                    // Save transaction
                    saveTransaction(paymentRequest, response)
                    
                    // Update stats
                    updateGatewayStats(gateway, true)
                    
                    _gatewayState.value = GatewayState.Ready
                    Result.success(response)
                } else {
                    updateGatewayStats(gateway, false)
                    throw result.exceptionOrNull() ?: Exception("Payment processing failed")
                }
                
            } catch (e: Exception) {
                _gatewayState.value = GatewayState.Error("Payment processing failed: ${e.message}")
                Result.failure(e)
            }
        }
    }
    
    /**
     * Process refund through appropriate gateway
     */
    suspend fun processRefund(
        refundRequest: RefundRequest,
        originalTransaction: PaymentTransaction
    ): Result<PaymentGatewayResponse> {
        return withContext(Dispatchers.IO) {
            try {
                if (!isInitialized) {
                    throw Exception("Payment gateway service not initialized")
                }
                
                _gatewayState.value = GatewayState.Processing
                
                // Validate refund request
                validateRefundRequest(refundRequest, originalTransaction)
                
                // Get original gateway
                val gateway = getGatewayByTransactionId(originalTransaction.gatewayTransactionId ?: "")
                    ?: throw Exception("Original payment gateway not found")
                
                // Process refund through original gateway
                val result = when (gateway.type) {
                    PaymentGatewayType.STRIPE -> processStripeRefund(refundRequest, originalTransaction)
                    PaymentGatewayType.PAYPAL -> processPayPalRefund(refundRequest, originalTransaction)
                    PaymentGatewayType.MADA -> processMadaRefund(refundRequest, originalTransaction)
                    PaymentGatewayType.BANK_TRANSFER -> processBankTransferRefund(refundRequest, originalTransaction)
                    PaymentGatewayType.MOBILE_MONEY -> processMobileMoneyRefund(refundRequest, originalTransaction)
                }
                
                if (result.isSuccess) {
                    val response = result.getOrThrow()
                    
                    // Save refund transaction
                    saveRefundTransaction(refundRequest, response)
                    
                    // Update stats
                    updateGatewayStats(gateway, true)
                    
                    _gatewayState.value = GatewayState.Ready
                    Result.success(response)
                } else {
                    updateGatewayStats(gateway, false)
                    throw result.exceptionOrNull() ?: Exception("Refund processing failed")
                }
                
            } catch (e: Exception) {
                _gatewayState.value = GatewayState.Error("Refund processing failed: ${e.message}")
                Result.failure(e)
            }
        }
    }
    
    /**
     * Validate payment method
     */
    suspend fun validatePaymentMethod(
        paymentMethod: PaymentMethod,
        paymentDetails: PaymentDetails
    ): Result<PaymentMethodValidation> {
        return withContext(Dispatchers.IO) {
            try {
                val gateway = selectPaymentGateway(paymentMethod)
                    ?: return@withContext Result.failure(Exception("Payment gateway not available"))
                
                val validation = when (gateway.type) {
                    PaymentGatewayType.STRIPE -> validateStripePayment(paymentDetails)
                    PaymentGatewayType.PAYPAL -> validatePayPalPayment(paymentDetails)
                    PaymentGatewayType.MADA -> validateMadaPayment(paymentDetails)
                    PaymentGatewayType.BANK_TRANSFER -> validateBankTransferPayment(paymentDetails)
                    PaymentGatewayType.MOBILE_MONEY -> validateMobileMoneyPayment(paymentDetails)
                }
                
                Result.success(validation)
                
            } catch (e: Exception) {
                Result.failure(e)
            }
        }
    }
    
    /**
     * Get supported payment methods
     */
    suspend fun getSupportedPaymentMethods(): Result<List<PaymentMethod>> {
        return withContext(Dispatchers.IO) {
            try {
                val gatewayMethods = _activeGateways.value.flatMap { gateway ->
                    when (gateway.type) {
                        PaymentGatewayType.STRIPE -> listOf(
                            PaymentMethod.CREDIT_CARD,
                            PaymentMethod.DEBIT_CARD
                        )
                        PaymentGatewayType.PAYPAL -> listOf(
                            PaymentMethod.PAYPAL
                        )
                        PaymentGatewayType.MADA -> listOf(
                            PaymentMethod.MADA
                        )
                        PaymentGatewayType.BANK_TRANSFER -> listOf(
                            PaymentMethod.BANK_TRANSFER
                        )
                        PaymentGatewayType.MOBILE_MONEY -> listOf(
                            PaymentMethod.MOBILE_MONEY
                        )
                    }
                }
                
                Result.success(gatewayMethods.distinct())
                
            } catch (e: Exception) {
                Result.failure(e)
            }
        }
    }
    
    /**
     * Get gateway analytics
     */
    suspend fun getGatewayAnalytics(
        dateRange: DateRange = DateRange.last30Days()
    ): Result<GatewayAnalytics> {
        return withContext(Dispatchers.IO) {
            try {
                val transactions = database.paymentTransactionDao().getTransactionsByDateRange(
                    dateRange.startDate,
                    dateRange.endDate
                ).map { it.toDomainModel() }
                
                val analytics = GatewayAnalytics(
                    totalTransactions = transactions.size,
                    successfulTransactions = transactions.count { it.status == PaymentStatus.COMPLETED },
                    failedTransactions = transactions.count { it.status == PaymentStatus.FAILED },
                    totalAmount = transactions.sumOf { it.amount.toDouble() }.toFloat(),
                    averageAmount = if (transactions.isNotEmpty()) transactions.map { it.amount }.average().toFloat() else 0f,
                    gatewayStats = transactions.groupBy { it.paymentMethod }
                        .mapValues { it.value.size },
                    currencyStats = transactions.groupBy { it.currency }
                        .mapValues { it.value.sumOf { it.amount.toDouble() }.toFloat() },
                    dailyStats = calculateDailyGatewayStats(transactions),
                    errorStats = calculateErrorStats(transactions)
                )
                
                Result.success(analytics)
                
            } catch (e: Exception) {
                Result.failure(e)
            }
        }
    }
    
    /**
     * Helper functions
     */
