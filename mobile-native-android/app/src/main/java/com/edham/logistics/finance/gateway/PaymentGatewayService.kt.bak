    private suspend fun loadActiveGateways() {
        // Load active gateways from database or API
    }
    
    private fun selectPaymentGateway(paymentMethod: PaymentMethod): PaymentGateway? {
        return _activeGateways.value.find { gateway ->
            gateway.isActive && gateway.supportedMethods.contains(paymentMethod)
        }
    }
    
    private fun getGatewayByTransactionId(transactionId: String): PaymentGateway? {
        // Extract gateway type from transaction ID or database
        return _activeGateways.value.firstOrNull()
    }
    
    private fun validatePaymentRequest(request: PaymentGatewayRequest) {
        if (request.amount < MIN_AMOUNT) throw Exception("Minimum amount is $MIN_AMOUNT")
        if (request.amount > MAX_AMOUNT) throw Exception("Maximum amount is $MAX_AMOUNT")
        if (request.currency.isBlank()) throw Exception("Currency cannot be empty")
        if (request.paymentMethod == null) throw Exception("Payment method is required")
    }
    
    private fun validateRefundRequest(request: RefundRequest, originalTransaction: PaymentTransaction) {
        if (request.amount <= 0) throw Exception("Refund amount must be positive")
        if (request.amount > originalTransaction.amount) throw Exception("Refund amount cannot exceed original amount")
        if (request.reason.isBlank()) throw Exception("Refund reason is required")
    }
    
    // Gateway-specific payment processing methods
    private suspend fun processStripePayment(request: PaymentGatewayRequest): Result<PaymentGatewayResponse> {
        return try {
            val stripeRequest = StripePaymentRequest(
                amount = (request.amount * 100).toLong(), // Convert to cents
                currency = request.currency,
                cardToken = request.cardToken,
                description = request.description,
                metadata = request.metadata
            )
            
            val response = stripeApi.createPayment(stripeRequest)
            if (response.success) {
                Result.success(PaymentGatewayResponse(
                    transactionId = response.data?.id ?: "",
                    status = PaymentStatus.COMPLETED,
                    amount = request.amount,
                    currency = request.currency,
                    gateway = "stripe",
                    gatewayResponse = response.data,
                    processedAt = Date()
                ))
            } else {
                Result.failure(Exception(response.message))
            }
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    private suspend fun processPayPalPayment(request: PaymentGatewayRequest): Result<PaymentGatewayResponse> {
        return try {
            val paypalRequest = PayPalPaymentRequest(
                amount = request.amount,
                currency = request.currency,
                returnUrl = "https://edham.com/payment/success",
                cancelUrl = "https://edham.com/payment/cancel",
                description = request.description,
                metadata = request.metadata
            )
            
            val response = payPalApi.createPayment(paypalRequest)
            if (response.success) {
                Result.success(PaymentGatewayResponse(
                    transactionId = response.data?.id ?: "",
                    status = PaymentStatus.PENDING,
                    amount = request.amount,
                    currency = request.currency,
                    gateway = "paypal",
                    gatewayResponse = response.data,
                    processedAt = Date()
                ))
            } else {
                Result.failure(Exception(response.message))
            }
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    private suspend fun processMadaPayment(request: PaymentGatewayRequest): Result<PaymentGatewayResponse> {
        return try {
            val madaRequest = MadaPaymentRequest(
                amount = request.amount,
                currency = request.currency,
                cardNumber = request.cardNumber,
                expiryDate = request.expiryDate,
                cvv = request.cvv,
                description = request.description,
                metadata = request.metadata
            )
            
            val response = madaApi.processPayment(madaRequest)
            if (response.success) {
                Result.success(PaymentGatewayResponse(
                    transactionId = response.data?.transactionId ?: "",
                    status = PaymentStatus.COMPLETED,
                    amount = request.amount,
                    currency = request.currency,
                    gateway = "mada",
                    gatewayResponse = response.data,
                    processedAt = Date()
                ))
            } else {
                Result.failure(Exception(response.message))
            }
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    private suspend fun processBankTransferPayment(request: PaymentGatewayRequest): Result<PaymentGatewayResponse> {
        return try {
            // Bank transfer processing would create a pending transaction
            Result.success(PaymentGatewayResponse(
                transactionId = UUID.randomUUID().toString(),
                status = PaymentStatus.PENDING,
                amount = request.amount,
                currency = request.currency,
                gateway = "bank_transfer",
                gatewayResponse = mapOf(
                    "bankAccount" to "SA1234567890123456",
                    "iban" to "SA0380000000601234567890",
                    "reference" to "EDHAM-${Date().time}"
                ),
                processedAt = Date()
            ))
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    private suspend fun processMobileMoneyPayment(request: PaymentGatewayRequest): Result<PaymentGatewayResponse> {
        return try {
            // Mobile money payment processing
            Result.success(PaymentGatewayResponse(
