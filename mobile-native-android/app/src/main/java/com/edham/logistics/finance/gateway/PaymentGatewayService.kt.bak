    // Gateway-specific refund processing methods
    private suspend fun processStripeRefund(request: RefundRequest, originalTransaction: PaymentTransaction): Result<PaymentGatewayResponse> {
        return try {
            val refundRequest = StripeRefundRequest(
                paymentIntentId = originalTransaction.gatewayTransactionId,
                amount = (request.amount * 100).toLong(),
                reason = request.reason
            )
            
            val response = stripeApi.createRefund(refundRequest)
            if (response.success) {
                Result.success(PaymentGatewayResponse(
                    transactionId = response.data?.id ?: "",
                    status = PaymentStatus.COMPLETED,
                    amount = request.amount,
                    currency = originalTransaction.currency,
                    gateway = "stripe",
                    gatewayResponse = response.data,
                    processedAt = Date()
                ))
            } else {
                Result.failure(Exception(response.message))
            }
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    private suspend fun processPayPalRefund(request: RefundRequest, originalTransaction: PaymentTransaction): Result<PaymentGatewayResponse> {
        return try {
            val refundRequest = PayPalRefundRequest(
                paymentId = originalTransaction.gatewayTransactionId,
                amount = request.amount,
                reason = request.reason
            )
            
            val response = payPalApi.createRefund(refundRequest)
            if (response.success) {
                Result.success(PaymentGatewayResponse(
                    transactionId = response.data?.id ?: "",
                    status = PaymentStatus.COMPLETED,
                    amount = request.amount,
                    currency = originalTransaction.currency,
                    gateway = "paypal",
                    gatewayResponse = response.data,
                    processedAt = Date()
                ))
            } else {
                Result.failure(Exception(response.message))
            }
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    private suspend fun processMadaRefund(request: RefundRequest, originalTransaction: PaymentTransaction): Result<PaymentGatewayResponse> {
