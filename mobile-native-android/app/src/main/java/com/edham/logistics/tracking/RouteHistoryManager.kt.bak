package com.edham.logistics.tracking

import android.content.Context
import android.location.Location
import com.edham.logistics.data.local.database.EdhamDatabase
import com.edham.logistics.data.local.entity.LocationUpdateEntity
import com.edham.logistics.data.local.entity.RouteEntity
import com.edham.logistics.data.local.entity.RouteHistoryEntity
import com.edham.logistics.data.remote.api.RouteHistoryApi
import com.edham.logistics.utils.NetworkUtils
import kotlinx.coroutines.Dispatchers
import kotlinx.coroutines.flow.MutableStateFlow
import kotlinx.coroutines.flow.StateFlow
import kotlinx.coroutines.flow.asStateFlow
import kotlinx.coroutines.withContext
import java.util.*
import javax.inject.Inject
import javax.inject.Singleton

/**
 * Route History Manager - Comprehensive route history tracking and analytics
 * 
 * Features:
 * - Complete route history storage
 * - Route replay functionality
 * - Performance analytics
 * - Route comparison
 * - Export capabilities
 * - Historical data analysis
 */
@Singleton
class RouteHistoryManager @Inject constructor(
    private val context: Context,
    private val database: EdhamDatabase,
    private val routeHistoryApi: RouteHistoryApi,
    private val networkUtils: NetworkUtils
) {
    
    private val _historyState = MutableStateFlow<HistoryState>(HistoryState.Initial)
    val historyState: StateFlow<HistoryState> = _historyState.asStateFlow()
    
    private val _routeHistory = MutableStateFlow<List<RouteHistoryEntity>>(emptyList())
    val routeHistory: StateFlow<List<RouteHistoryEntity>> = _routeHistory.asStateFlow()
    
    private val _currentRouteHistory = MutableStateFlow<RouteHistoryEntity?>(null)
    val currentRouteHistory: StateFlow<RouteHistoryEntity?> = _currentRouteHistory.asStateFlow()
    
    private val _historyAnalytics = MutableStateFlow<RouteHistoryAnalytics?>(null)
    val historyAnalytics: StateFlow<RouteHistoryAnalytics?> = _historyAnalytics.asStateFlow()
    
    private var currentRouteId: String? = null
    private var isRecording = false
    private var recordingStartTime: Long = 0L
    private var locationUpdates: MutableList<LocationUpdateEntity> = mutableListOf()
    
    companion object {
        private const val TAG = "RouteHistoryManager"
        private const val MAX_HISTORY_DAYS = 90
        private const val MAX_ROUTES_PER_DAY = 50
        private const val LOCATION_UPDATE_BATCH_SIZE = 100
    }
    
    /**
     * Start recording route history
     */
    fun startRecording(routeId: String) {
        if (isRecording) return
        
        try {
            _historyState.value = HistoryState.StartingRecording
            
            currentRouteId = routeId
            isRecording = true
            recordingStartTime = System.currentTimeMillis()
            locationUpdates.clear()
            
            // Create initial route history entry
            val routeHistory = RouteHistoryEntity(
                id = 0,
                routeId = routeId,
                startTime = Date(recordingStartTime),
                endTime = null,
                status = "RECORDING",
                totalDistance = 0.0,
                totalDuration = 0L,
                averageSpeed = 0.0,
                maxSpeed = 0.0,
                fuelConsumed = 0.0,
                locationUpdateCount = 0,
                events = emptyList(),
                metadata = createInitialMetadata()
            )
            
            _currentRouteHistory.value = routeHistory
            _historyState.value = HistoryState.Recording
            
        } catch (e: Exception) {
            _historyState.value = HistoryState.Error("Failed to start recording: ${e.message}")
        }
    }
    
    /**
     * Stop recording route history
     */
    suspend fun stopRecording(): RouteHistoryEntity? {
        if (!isRecording) return null
        
        return withContext(Dispatchers.IO) {
            try {
                _historyState.value = HistoryState.StoppingRecording
                
                val endTime = System.currentTimeMillis()
                val totalDuration = endTime - recordingStartTime
                
                // Calculate final metrics
                val metrics = calculateRouteMetrics(locationUpdates, totalDuration)
                
                // Update route history entry
                val routeHistory = _currentRouteHistory.value?.copy(
                    endTime = Date(endTime),
                    status = "COMPLETED",
                    totalDistance = metrics.totalDistance,
                    totalDuration = totalDuration,
                    averageSpeed = metrics.averageSpeed,
                    maxSpeed = metrics.maxSpeed,
                    fuelConsumed = metrics.fuelConsumed,
                    locationUpdateCount = locationUpdates.size,
                    events = extractEvents(locationUpdates).map { it.toString() },
                    metadata = createFinalMetadata(metrics)
                )
                
                // Save to database
                routeHistory?.let { history ->
                    database.routeHistoryDao().insertRouteHistory(history)
                    
                    // Save location updates
                    locationUpdates.forEach { update ->
                        update.routeHistoryId = history.id
                        database.locationUpdateDao().insertLocationUpdate(update)
                    }
                    
                    // Update current route history
                    _currentRouteHistory.value = history
                    
                    // Update analytics
                    updateAnalytics()
                }
                
                isRecording = false
                currentRouteId = null
                locationUpdates.clear()
                
                _historyState.value = HistoryState.RecordingStopped
                
                routeHistory
                
            } catch (e: Exception) {
                _historyState.value = HistoryState.Error("Failed to stop recording: ${e.message}")
                null
            }
        }
    }
    
    /**
     * Add location update to current recording
     */
    fun addLocationUpdate(location: Location, additionalData: Map<String, Any> = emptyMap()) {
        if (!isRecording) return
        
        try {
            val locationUpdate = LocationUpdateEntity(
                id = 0,
                routeHistoryId = 0, // Will be set when saving
                latitude = location.latitude,
                longitude = location.longitude,
                altitude = location.altitude,
                accuracy = location.accuracy,
                speed = location.speed,
                heading = location.bearing,
                timestamp = Date(location.time),
                batteryLevel = additionalData["batteryLevel"] as? Int ?: 0,
                networkType = additionalData["networkType"] as? String ?: "unknown",
                additionalData = serializeAdditionalData(additionalData)
            )
            
            locationUpdates.add(locationUpdate)
            
            // Batch save if needed
            if (locationUpdates.size >= LOCATION_UPDATE_BATCH_SIZE) {
                // lifecycleScope.launch {
                //     saveLocationUpdatesBatch()
                // }
            }
            
        } catch (e: Exception) {
            _historyState.value = HistoryState.Error("Failed to add location update: ${e.message}")
        }
    }
    
    /**
     * Get route history for specific date range
     */
    suspend fun getRouteHistory(
        startDate: Date,
        endDate: Date
    ): List<RouteHistoryEntity> {
        return withContext(Dispatchers.IO) {
            try {
                val history = database.routeHistoryDao().getHistoryByDateRange(startDate, endDate)
                _routeHistory.value = history
                history
            } catch (e: Exception) {
                _historyState.value = HistoryState.Error("Failed to get route history: ${e.message}")
                emptyList()
            }
        }
    }
    
    /**
     * Get route history for specific route
     */
    suspend fun getRouteHistoryForRoute(routeId: String): List<RouteHistoryEntity> {
        return withContext(Dispatchers.IO) {
            try {
                val history = database.routeHistoryDao().getHistoryByRoute(routeId)
                history
            } catch (e: Exception) {
                _historyState.value = HistoryState.Error("Failed to get route history: ${e.message}")
                emptyList()
            }
        }
    }
    
    /**
     * Replay route history
     */
    suspend fun replayRouteHistory(routeHistoryId: Long): RouteReplay {
        return withContext(Dispatchers.IO) {
            try {
                _historyState.value = HistoryState.LoadingReplay
                
                val routeHistory = database.routeHistoryDao().getHistoryById(routeHistoryId)
                val locationUpdates = database.locationUpdateDao().getUpdatesByHistory(routeHistoryId)
                
                val replay = RouteReplay(
                    routeHistory = routeHistory,
                    locationUpdates = locationUpdates,
                    currentIndex = 0,
                    isPlaying = false,
                    playbackSpeed = 1.0f
                )
                
                _historyState.value = HistoryState.ReplayReady
                replay
                
            } catch (e: Exception) {
                _historyState.value = HistoryState.Error("Failed to replay route: ${e.message}")
                RouteReplay()
            }
        }
    }
    
    /**
     * Compare two routes
     */
    suspend fun compareRoutes(routeId1: String, routeId2: String): RouteComparison {
        return withContext(Dispatchers.IO) {
            try {
                val history1 = database.routeHistoryDao().getLatestHistoryByRoute(routeId1)
                val history2 = database.routeHistoryDao().getLatestHistoryByRoute(routeId2)
                
                if (history1 != null && history2 != null) {
                    RouteComparison(
                        route1 = history1,
                        route2 = history2,
                        distanceDifference = history2.totalDistance - history1.totalDistance,
                        durationDifference = history2.totalDuration - history1.totalDuration,
                        speedDifference = history2.averageSpeed - history1.averageSpeed,
                        fuelDifference = history2.fuelConsumed - history1.fuelConsumed,
                        efficiencyComparison = calculateEfficiencyComparison(history1, history2)
                    )
                } else {
                    RouteComparison()
                }
                
            } catch (e: Exception) {
                _historyState.value = HistoryState.Error("Failed to compare routes: ${e.message}")
                RouteComparison()
            }
        }
    }
    
    /**
     * Export route history
     */
    suspend fun exportRouteHistory(
        format: ExportFormat,
        routeIds: List<String>? = null
    ): ExportResult {
        return withContext(Dispatchers.IO) {
            try {
                _historyState.value = HistoryState.Exporting
                
                val history = routeIds?.let { ids ->
                    database.routeHistoryDao().getHistoryByRoutes(ids)
                } ?: database.routeHistoryDao().getAllHistory()
                
                val exportData = when (format) {
                    ExportFormat.JSON -> exportToJson(history)
                    ExportFormat.CSV -> exportToCsv(history)
                    ExportFormat.GPX -> exportToGpx(history)
                    ExportFormat.KML -> exportToKml(history)
                }
                
                _historyState.value = HistoryState.ExportComplete
                ExportResult(
                    success = true,
                    data = exportData,
                    format = format,
                    recordCount = history.size
                )
                
            } catch (e: Exception) {
                _historyState.value = HistoryState.Error("Failed to export: ${e.message}")
                ExportResult(success = false, error = e.message)
            }
        }
    }
    
    /**
     * Clean up old history
     */
    suspend fun cleanupOldHistory(): CleanupResult {
        return withContext(Dispatchers.IO) {
            try {
                _historyState.value = HistoryState.CleaningUp
                
                val cutoffDate = Date(System.currentTimeMillis() - (MAX_HISTORY_DAYS * 24 * 60 * 60 * 1000L))
                val oldHistory = database.routeHistoryDao().getHistoryOlderThan(cutoffDate)
                
                var deletedCount = 0
                oldHistory.forEach { history ->
                    database.routeHistoryDao().deleteHistory(history.id)
                    database.locationUpdateDao().deleteUpdatesByHistory(history.id)
                    deletedCount++
                }
                
                _historyState.value = HistoryState.CleanupComplete
                CleanupResult(
                    success = true,
                    deletedCount = deletedCount,
                    cutoffDate = cutoffDate
                )
                
            } catch (e: Exception) {
                _historyState.value = HistoryState.Error("Failed to cleanup: ${e.message}")
                CleanupResult(success = false, error = e.message)
            }
        }
    }
    
    /**
     * Update analytics
     */
    private suspend fun updateAnalytics() {
        withContext(Dispatchers.IO) {
            try {
                val allHistory = database.routeHistoryDao().getAllHistory()
                val analytics = calculateAnalytics(allHistory)
                _historyAnalytics.value = analytics
            } catch (e: Exception) {
                _historyState.value = HistoryState.Error("Failed to update analytics: ${e.message}")
            }
        }
    }
    
    /**
     * Calculate route metrics
     */
    private fun calculateRouteMetrics(
        locationUpdates: List<LocationUpdateEntity>,
        totalDuration: Long
    ): RouteMetrics {
        var totalDistance = 0.0
        var maxSpeed = 0.0
        var totalSpeed = 0.0
        var speedCount = 0
        
        for (i in 0 until locationUpdates.size - 1) {
            val update1 = locationUpdates[i]
            val update2 = locationUpdates[i + 1]
            
            // Calculate distance
            val distance = calculateDistance(
                update1.latitude, update1.longitude,
                update2.latitude, update2.longitude
            )
            totalDistance += distance
            
            // Calculate speed
            if (update2.speed > 0) {
                totalSpeed += update2.speed
                speedCount++
                maxSpeed = maxOf(maxSpeed, update2.speed.toDouble())
            }
        }
        
        val averageSpeed = if (speedCount > 0) (totalSpeed / speedCount) * 3.6 else 0.0 // Convert to km/h
        val fuelConsumed = totalDistance * 0.08 / 1000 // Estimate fuel consumption
        
        return RouteMetrics(
            totalDistance = totalDistance,
            averageSpeed = averageSpeed,
            maxSpeed = maxSpeed * 3.6, // Convert to km/h
            fuelConsumed = fuelConsumed
        )
    }
    
    /**
     * Calculate distance between two points
     */
    private fun calculateDistance(lat1: Double, lon1: Double, lat2: Double, lon2: Double): Double {
        val results = FloatArray(1)
        Location.distanceBetween(lat1, lon1, lat2, lon2, results)
        return results[0].toDouble()
    }
    
    /**
     * Extract events from location updates
     */
    private fun extractEvents(locationUpdates: List<LocationUpdateEntity>): List<RouteEvent> {
        val events = mutableListOf<RouteEvent>()
        
        locationUpdates.forEachIndexed { index, update ->
            // Check for speed events
            if (update.speed > 25.0) { // Speed threshold
                events.add(
                    RouteEvent(
                        type = EventType.SPEED_EXCEEDED,
                        timestamp = update.timestamp.time,
                        location = Location("").apply {
                            latitude = update.latitude
                            longitude = update.longitude
                        },
                        data = mapOf("speed" to update.speed)
                    )
                )
            }
            
            // Check for battery events
            if (update.batteryLevel < 20) {
                events.add(
                    RouteEvent(
                        type = EventType.LOW_BATTERY,
                        timestamp = update.timestamp.time,
                        location = Location("").apply {
                            latitude = update.latitude
                            longitude = update.longitude
                        },
                        data = mapOf("batteryLevel" to update.batteryLevel)
                    )
                )
            }
        }
        
        return events
    }
    
    /**
     * Create initial metadata
     */
    private fun createInitialMetadata(): Map<String, Any> {
        return mapOf(
            "deviceInfo" to getDeviceInfo(),
            "appVersion" to getAppVersion(),
            "recordingStartTime" to recordingStartTime
        )
    }
    
    /**
     * Create final metadata
     */
    private fun createFinalMetadata(metrics: RouteMetrics): Map<String, Any> {
        return mapOf(
            "deviceInfo" to getDeviceInfo(),
            "appVersion" to getAppVersion(),
            "recordingStartTime" to recordingStartTime,
            "recordingEndTime" to System.currentTimeMillis(),
            "totalDistance" to metrics.totalDistance,
            "averageSpeed" to metrics.averageSpeed,
            "maxSpeed" to metrics.maxSpeed,
            "fuelConsumed" to metrics.fuelConsumed
        )
    }
    
    /**
     * Serialize additional data
     */
    private fun serializeAdditionalData(data: Map<String, Any>): String {
        // Implementation would serialize data to JSON string
        return "{}"
    }
    
    /**
     * Save location updates batch
     */
    private suspend fun saveLocationUpdatesBatch() {
        withContext(Dispatchers.IO) {
            try {
                database.locationUpdateDao().insertLocationUpdates(locationUpdates)
                locationUpdates.clear()
            } catch (e: Exception) {
                // Handle error
            }
        }
    }
    
    /**
     * Calculate efficiency comparison
     */
    private fun calculateEfficiencyComparison(history1: RouteHistoryEntity, history2: RouteHistoryEntity): EfficiencyComparison {
        val efficiency1 = if (history1.totalDistance > 0) history1.totalDistance / history1.fuelConsumed else 0.0
        val efficiency2 = if (history2.totalDistance > 0) history2.totalDistance / history2.fuelConsumed else 0.0
        
        return EfficiencyComparison(
            route1Efficiency = efficiency1,
            route2Efficiency = efficiency2,
            efficiencyDifference = efficiency2 - efficiency1,
            percentageImprovement = if (efficiency1 > 0) ((efficiency2 - efficiency1) / efficiency1 * 100) else 0.0
        )
    }
    
    /**
     * Export to JSON
     */
    private suspend fun exportToJson(history: List<RouteHistoryEntity>): String {
        // Implementation would export to JSON format
        return "{}"
    }
    
    /**
     * Export to CSV
     */
    private suspend fun exportToCsv(history: List<RouteHistoryEntity>): String {
        // Implementation would export to CSV format
        return ""
    }
    
    /**
     * Export to GPX
     */
    private suspend fun exportToGpx(history: List<RouteHistoryEntity>): String {
        // Implementation would export to GPX format
        return ""
    }
    
    /**
     * Export to KML
     */
    private suspend fun exportToKml(history: List<RouteHistoryEntity>): String {
        // Implementation would export to KML format
        return ""
    }
    
    /**
     * Calculate analytics
     */
    private suspend fun calculateAnalytics(history: List<RouteHistoryEntity>): RouteHistoryAnalytics {
        val totalRoutes = history.size
        val totalDistance = history.sumOf { it.totalDistance }
        val totalDuration = history.sumOf { it.totalDuration }
        val averageSpeed = if (totalRoutes > 0) history.map { it.averageSpeed }.average() else 0.0
        val totalFuel = history.sumOf { it.fuelConsumed }
        
        return RouteHistoryAnalytics(
            totalRoutes = totalRoutes,
            totalDistance = totalDistance,
            totalDuration = totalDuration,
            averageSpeed = averageSpeed,
            totalFuelConsumed = totalFuel,
            averageDistancePerRoute = if (totalRoutes > 0) totalDistance / totalRoutes else 0.0,
            averageDurationPerRoute = if (totalRoutes > 0) totalDuration / totalRoutes else 0L,
            mostActiveDay = findMostActiveDay(history),
            efficiencyMetrics = calculateEfficiencyMetrics(history)
        )
    }
    
    /**
     * Find most active day
     */
    private fun findMostActiveDay(history: List<RouteHistoryEntity>): String {
        // Implementation would find the day with most routes
        return "Monday" // Placeholder
    }
    
    /**
     * Calculate efficiency metrics
     */
    private fun calculateEfficiencyMetrics(history: List<RouteHistoryEntity>): EfficiencyMetrics {
        val averageFuelPerKm = if (history.isNotEmpty()) {
            history.sumOf { it.fuelConsumed } / history.sumOf { it.totalDistance }
        } else 0.0
        
        return EfficiencyMetrics(
            averageFuelPerKm = averageFuelPerKm,
            fuelCostPerKm = averageFuelPerKm * 1.5, // Assuming 1.5 per liter
            co2EmissionsPerKm = averageFuelPerKm * 2.31 // CO2 factor for diesel
        )
    }
    
    /**
     * Get device info
     */
    private fun getDeviceInfo(): Map<String, String> {
        return mapOf(
            "manufacturer" to android.os.Build.MANUFACTURER,
            "model" to android.os.Build.MODEL,
            "osVersion" to android.os.Build.VERSION.RELEASE
        )
    }
    
    /**
     * Get app version
     */
    private fun getAppVersion(): String {
        return try {
            val packageInfo = context.packageManager.getPackageInfo(context.packageName, 0)
            packageInfo.versionName ?: "1.0.0"
        } catch (e: Exception) {
            "1.0.0"
        }
    }
}

/**
 * Data classes
 */
data class RouteMetrics(
    val totalDistance: Double,
    val averageSpeed: Double,
    val maxSpeed: Double,
    val fuelConsumed: Double
)

data class RouteEvent(
    val type: EventType,
    val timestamp: Long,
    val location: Location,
    val data: Map<String, Any>
)

data class RouteReplay(
    val routeHistory: RouteHistoryEntity? = null,
    val locationUpdates: List<LocationUpdateEntity> = emptyList(),
    val currentIndex: Int = 0,
    val isPlaying: Boolean = false,
    val playbackSpeed: Float = 1.0f
)

data class RouteComparison(
    val route1: RouteHistoryEntity? = null,
    val route2: RouteHistoryEntity? = null,
    val distanceDifference: Double = 0.0,
    val durationDifference: Long = 0L,
    val speedDifference: Double = 0.0,
    val fuelDifference: Double = 0.0,
    val efficiencyComparison: EfficiencyComparison = EfficiencyComparison()
)

data class EfficiencyComparison(
    val route1Efficiency: Double = 0.0,
    val route2Efficiency: Double = 0.0,
    val efficiencyDifference: Double = 0.0,
    val percentageImprovement: Double = 0.0
)

data class ExportResult(
    val success: Boolean,
    val data: String = "",
    val format: ExportFormat = ExportFormat.JSON,
    val recordCount: Int = 0,
    val error: String? = null
)

data class CleanupResult(
    val success: Boolean,
    val deletedCount: Int = 0,
    val cutoffDate: Date? = null,
    val error: String? = null
)

data class RouteHistoryAnalytics(
    val totalRoutes: Int,
    val totalDistance: Double,
    val totalDuration: Long,
    val averageSpeed: Double,
    val totalFuelConsumed: Double,
    val averageDistancePerRoute: Double,
    val averageDurationPerRoute: Long,
    val mostActiveDay: String,
    val efficiencyMetrics: EfficiencyMetrics
)

data class EfficiencyMetrics(
    val averageFuelPerKm: Double,
    val fuelCostPerKm: Double,
    val co2EmissionsPerKm: Double
)

/**
 * Enums
 */
enum class RouteHistoryStatus {
    RECORDING,
    COMPLETED,
    FAILED,
    CANCELLED
}

enum class EventType {
    SPEED_EXCEEDED,
    LOW_BATTERY,
    GEOFENCE_ENTER,
    GEOFENCE_EXIT,
    ROUTE_DEVIATION,
    NETWORK_LOST,
    NETWORK_RESTORED
}

enum class ExportFormat {
    JSON,
    CSV,
    GPX,
    KML
}

/**
 * History state
 */
sealed class HistoryState {
    object Initial : HistoryState()
    object StartingRecording : HistoryState()
    object Recording : HistoryState()
    object StoppingRecording : HistoryState()
    object RecordingStopped : HistoryState()
    object LoadingReplay : HistoryState()
    object ReplayReady : HistoryState()
    object Exporting : HistoryState()
    object ExportComplete : HistoryState()
    object CleaningUp : HistoryState()
    object CleanupComplete : HistoryState()
    data class Error(val message: String) : HistoryState()
}
