package com.edham.logistics.feature.accountant.domain.usecase

import com.edham.logistics.core.utils.Result
import com.edham.logistics.feature.accountant.domain.model.Invoice
import com.edham.logistics.feature.accountant.domain.repository.AccountantRepository
import kotlinx.coroutines.flow.Flow
import javax.inject.Inject

class GetInvoicesUseCase @Inject constructor(
    private val accountantRepository: AccountantRepository
) {
    
    suspend operator fun invoke(
        page: Int = 1,
        pageSize: Int = 20,
        status: String? = null,
        customerId: String? = null,
        search: String? = null
    ): Flow<Result<List<Invoice>>> {
        return accountantRepository.getInvoices(page, pageSize, status, customerId, search)
    }
}
