package com.edham.logistics.feature.admin.presentation.ui

import androidx.lifecycle.viewModelScope
import com.edham.logistics.core.utils.Result
import com.edham.logistics.feature.admin.domain.usecase.*
import com.edham.logistics.feature.admin.domain.model.*
import com.edham.logistics.presentation.ui.base.BaseViewModel
import dagger.hilt.android.lifecycle.HiltViewModel
import kotlinx.coroutines.flow.MutableStateFlow
import kotlinx.coroutines.flow.StateFlow
import kotlinx.coroutines.flow.asStateFlow
import kotlinx.coroutines.launch
import javax.inject.Inject

@HiltViewModel
class AdminDashboardViewModel @Inject constructor(
    private val getAdminDashboardUseCase: GetAdminDashboardUseCase,
    private val assignDriverUseCase: AssignDriverUseCase,
    private val approveOrderUseCase: ApproveOrderUseCase,
    private val rejectOrderUseCase: RejectOrderUseCase,
    private val getAllShipmentsUseCase: GetAllShipmentsUseCase,
    private val getFleetTrackingUseCase: GetFleetTrackingUseCase,
    private val getTemperatureAlertsUseCase: GetTemperatureAlertsUseCase,
    private val manageUsersUseCase: ManageUsersUseCase
) : BaseViewModel<AdminDashboardViewModel.AdminDashboardUiState>() {

    private val _uiState = MutableStateFlow(AdminDashboardUiState())
    val uiState: StateFlow<AdminDashboardUiState> = _uiState.asStateFlow()

    override fun createInitialState(): AdminDashboardUiState = AdminDashboardUiState()

    fun initialize() {
        loadDashboard()
    }

    fun loadDashboard() {
        viewModelScope.launch {
            getAdminDashboardUseCase().collect { result ->
                when (result) {
                    is Result.Loading -> {
                        updateUiState { copy(isLoading = true, error = null) }
                    }
                    is Result.Success -> {
                        updateUiState {
                            copy(
                                isLoading = false,
                                dashboardData = result.data,
                                error = null
                            )
                        }
                    }
                    is Result.Error -> {
                        updateUiState {
                            copy(
                                isLoading = false,
                                error = result.exception.message ?: "فشل تحميل لوحة التحكم"
                            )
                        }
                    }
                }
            }
        }
    }

    fun loadAllShipments(
        page: Int = 1,
        pageSize: Int = 20,
        status: String? = null,
        search: String? = null
    ) {
        viewModelScope.launch {
            getAllShipmentsUseCase(page, pageSize, status, search).collect { result ->
                when (result) {
                    is Result.Success -> {
                        updateUiState { copy(
                            allShipments = result.data,
                            shipmentsLoading = false
                        )}
                    }
                    is Result.Error -> {
                        updateUiState { copy(
                            shipmentsLoading = false,
                            error = result.exception.message ?: "فشل تحميل الشحنات"
                        )}
                    }
                    is Result.Loading -> {
                        updateUiState { copy(shipmentsLoading = true) }
                    }
                }
            }
        }
    }

    fun loadFleetTracking() {
        viewModelScope.launch {
            getFleetTrackingUseCase().collect { result ->
                when (result) {
                    is Result.Success -> {
                        updateUiState { copy(
                            fleetTracking = result.data,
                            fleetLoading = false
                        )}
                    }
                    is Result.Error -> {
                        updateUiState { copy(
                            fleetLoading = false,
                            error = result.exception.message ?: "فشل تحميل تتبع الأسطول"
                        )}
                    }
                    is Result.Loading -> {
                        updateUiState { copy(fleetLoading = true) }
                    }
                }
            }
        }
    }

    fun loadTemperatureAlerts(
        alertLevel: String? = null,
        isResolved: Boolean? = null
    ) {
        viewModelScope.launch {
            getTemperatureAlertsUseCase(alertLevel, isResolved).collect { result ->
                when (result) {
                    is Result.Success -> {
                        updateUiState { copy(
                            temperatureAlerts = result.data,
                            alertsLoading = false
                        )}
                    }
                    is Result.Error -> {
                        updateUiState { copy(
                            alertsLoading = false,
                            error = result.exception.message ?: "فشل تحميل تنبيهات الحرارة"
                        )}
                    }
                    is Result.Loading -> {
                        updateUiState { copy(alertsLoading = true) }
                    }
                }
            }
        }
    }

    fun assignDriver(
        shipmentId: String,
        driverId: String,
        notes: String? = null
    ) {
        viewModelScope.launch {
            when (val result = assignDriverUseCase(shipmentId, driverId, notes)) {
                is Result.Success -> {
                    updateUiState { copy(
                        actionSuccess = "تم تعيين السائق بنجاح",
                        error = null
                    )}
                    loadDashboard() // Refresh data
                }
                is Result.Error -> {
                    updateUiState { copy(error = result.exception.message ?: "فشل تعيين السائق") }
                }
                is Result.Loading -> {
                    updateUiState { copy(isLoading = true) }
                }
            }
        }
    }

    fun approveOrder(
        orderId: String,
        approvedBy: String,
        notes: String? = null
    ) {
        viewModelScope.launch {
            when (val result = approveOrderUseCase(orderId, approvedBy, notes)) {
                is Result.Success -> {
                    updateUiState { copy(
                        actionSuccess = "تمت الموافقة على الطلب بنجاح",
                        error = null
                    )}
                    loadDashboard() // Refresh data
                }
                is Result.Error -> {
                    updateUiState { copy(error = result.exception.message ?: "فشل الموافقة على الطلب") }
                }
                is Result.Loading -> {
                    updateUiState { copy(isLoading = true) }
                }
            }
        }
    }

    fun rejectOrder(
        orderId: String,
        rejectedBy: String,
        reason: String,
        notes: String? = null
    ) {
        viewModelScope.launch {
            when (val result = rejectOrderUseCase(orderId, rejectedBy, reason, notes)) {
                is Result.Success -> {
                    updateUiState { copy(
                        actionSuccess = "تم رفض الطلب بنجاح",
                        error = null
                    )}
                    loadDashboard() // Refresh data
                }
                is Result.Error -> {
                    updateUiState { copy(error = result.exception.message ?: "فشل رفض الطلب") }
                }
                is Result.Loading -> {
                    updateUiState { copy(isLoading = true) }
                }
            }
        }
    }

    fun resolveTemperatureAlert(alertId: String) {
        viewModelScope.launch {
            // In real implementation, we would have a use case for this
            updateUiState { copy(
                actionSuccess = "تم حل تنبيه الحرارة",
                error = null
            )}
            loadTemperatureAlerts() // Refresh alerts
        }
    }

    fun clearError() {
        updateUiState { copy(error = null) }
    }

    fun clearSuccess() {
        updateUiState { copy(actionSuccess = null) }
    }

    fun refresh() {
        loadDashboard()
    }

    data class AdminDashboardUiState(
        val isLoading: Boolean = false,
        val shipmentsLoading: Boolean = false,
        val fleetLoading: Boolean = false,
        val alertsLoading: Boolean = false,
        val dashboardData: AdminDashboardData? = null,
        val allShipments: List<AdminShipment>? = null,
        val fleetTracking: List<AdminTrip>? = null,
        val temperatureAlerts: List<TemperatureAlert>? = null,
        val error: String? = null,
        val actionSuccess: String? = null
    ) : com.edham.logistics.presentation.ui.base.UiState {
        override fun copyLoading(isLoading: Boolean): UiState = copy(isLoading = isLoading)
        override fun copyError(error: String?): UiState = copy(error = error)
        override fun copySuccess(message: String?): UiState = copy(actionSuccess = message)
    }
}
