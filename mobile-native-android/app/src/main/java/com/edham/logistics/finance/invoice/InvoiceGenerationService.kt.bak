package com.edham.logistics.finance.invoice

import android.content.Context
import com.edham.logistics.data.local.database.EdhamDatabase
import com.edham.logistics.data.remote.api.InvoiceApi
import com.edham.logistics.data.remote.api.CustomerApi
import com.edham.logistics.data.remote.api.ShipmentApi
import com.edham.logistics.utils.NetworkUtils
import com.edham.logistics.utils.SecurityUtils
import kotlinx.coroutines.Dispatchers
import kotlinx.coroutines.flow.MutableStateFlow
import kotlinx.coroutines.flow.StateFlow
import kotlinx.coroutines.flow.asStateFlow
import kotlinx.coroutines.withContext
import java.util.*
import javax.inject.Inject
import javax.inject.Singleton

/**
 * Invoice Generation Service - Automated invoice generation for shipments
 * 
 * Features:
 * - Automatic invoice creation for shipments
 * - Professional invoice templates
 * - Tax calculations and compliance
 * - Multi-currency support
 * - Invoice numbering and tracking
 * - Email delivery integration
 * - Invoice preview and editing
 */
@Singleton
class InvoiceGenerationService @Inject constructor(
    private val context: Context,
    private val database: EdhamDatabase,
    private val invoiceApi: InvoiceApi,
    private val customerApi: CustomerApi,
    private val shipmentApi: ShipmentApi,
    private val networkUtils: NetworkUtils,
    private val securityUtils: SecurityUtils
) {
    
    private val _invoiceGenerationState = MutableStateFlow<InvoiceGenerationState>(InvoiceGenerationState.Idle)
    val invoiceGenerationState: StateFlow<InvoiceGenerationState> = _invoiceGenerationState.asStateFlow()
    
    private val _generatedInvoices = MutableStateFlow<List<GeneratedInvoice>>(emptyList())
    val generatedInvoices: StateFlow<List<GeneratedInvoice>> = _generatedInvoices.asStateFlow()
    
    private var isInitialized = false
    
    companion object {
        private const val TAG = "InvoiceGenerationService"
        private const val DEFAULT_CURRENCY = "SAR"
        private const val TAX_RATE = 0.15f // 15% VAT
        private const val INVOICE_CACHE_SIZE = 100
        private const val INVOICE_NUMBER_PREFIX = "INV-"
        private const val LATE_FEE_RATE = 0.02f // 2% late fee
        private const val LATE_FEE_DAYS = 30 // Days before late fee applies
    }
    
    /**
     * Initialize invoice generation service
     */
    suspend fun initialize(): Result<Boolean> {
        return withContext(Dispatchers.IO) {
            try {
                _invoiceGenerationState.value = InvoiceGenerationState.Initializing
                
                // Load invoice templates
                loadInvoiceTemplates()
                
                // Load recent generated invoices
                loadRecentGeneratedInvoices()
                
                // Initialize invoice numbering
                initializeInvoiceNumbering()
                
                isInitialized = true
                _invoiceGenerationState.value = InvoiceGenerationState.Ready
                Result.success(true)
                
            } catch (e: Exception) {
                _invoiceGenerationState.value = InvoiceGenerationState.Error("Failed to initialize invoice generation service: ${e.message}")
                Result.failure(e)
            }
        }
    }
    
    /**
     * Generate invoice for shipment
     */
    suspend fun generateInvoiceForShipment(
        shipmentId: String,
        template: InvoiceTemplate = InvoiceTemplate.STANDARD,
        customizations: InvoiceCustomizations? = null
    ): Result<GeneratedInvoice> {
        return withContext(Dispatchers.IO) {
            try {
                if (!isInitialized) {
                    throw Exception("Invoice generation service not initialized")
                }
                
                _invoiceGenerationState.value = InvoiceGenerationState.Generating
                
                // Get shipment details
                val shipment = shipmentApi.getShipmentById(shipmentId)
                    ?: throw Exception("Shipment not found")
                
                // Get customer details
                val customer = customerApi.getCustomerById(shipment.customerId)
                    ?: throw Exception("Customer not found")
                
                // Check if invoice already exists
                val existingInvoice = database.invoiceDao().getInvoiceByShipmentId(shipmentId)
                if (existingInvoice != null) {
                    throw Exception("Invoice already exists for this shipment")
                }
                
                // Generate invoice number
                val invoiceNumber = generateInvoiceNumber()
                
                // Calculate invoice items
                val invoiceItems = calculateInvoiceItems(shipment, customizations)
                
                // Calculate totals
                val totals = calculateInvoiceTotals(invoiceItems)
                
                // Create invoice
                val invoice = GeneratedInvoice(
                    id = UUID.randomUUID().toString(),
                    invoiceNumber = invoiceNumber,
                    shipmentId = shipmentId,
                    customerId = shipment.customerId,
                    customerInfo = CustomerInfo(
                        name = customer.name,
                        address = customer.address,
                        email = customer.email,
                        phone = customer.phone,
                        taxNumber = customer.taxNumber
                    ),
                    items = invoiceItems,
                    totals = totals,
                    currency = DEFAULT_CURRENCY,
                    status = InvoiceStatus.DRAFT,
                    issueDate = Date(),
                    dueDate = calculateDueDate(shipment.deliveryDate),
                    template = template,
                    customizations = customizations ?: InvoiceCustomizations(),
                    metadata = mapOf(
                        "generated_by" to "system",
                        "shipment_type" to shipment.type.toString(),
                        "generated_at" to Date().toString()
                    )
                )
                
                // Save invoice to database
                val savedInvoice = database.invoiceDao().insertInvoice(invoice.toEntity())
                    .let { id -> invoice.copy(id = id.toString()) }
                
                // Add to generated invoices list
                addToGeneratedInvoices(savedInvoice)
                
                _invoiceGenerationState.value = InvoiceGenerationState.Ready
                Result.success(savedInvoice)
                
            } catch (e: Exception) {
                _invoiceGenerationState.value = InvoiceGenerationState.Error("Invoice generation failed: ${e.message}")
                Result.failure(e)
            }
        }
    }
    
    /**
     * Generate batch invoices
     */
    suspend fun generateBatchInvoices(
        shipmentIds: List<String>,
        template: InvoiceTemplate = InvoiceTemplate.STANDARD,
        customizations: InvoiceCustomizations? = null
    ): Result<List<GeneratedInvoice>> {
        return withContext(Dispatchers.IO) {
            try {
                if (!isInitialized) {
                    throw Exception("Invoice generation service not initialized")
                }
                
                _invoiceGenerationState.value = InvoiceGenerationState.Generating
                
                val generatedInvoices = mutableListOf<GeneratedInvoice>()
                
                shipmentIds.forEach { shipmentId ->
                    val result = generateInvoiceForShipment(shipmentId, template, customizations)
                    if (result.isSuccess) {
                        generatedInvoices.add(result.getOrThrow())
                    }
                }
                
                _invoiceGenerationState.value = InvoiceGenerationState.Ready
                Result.success(generatedInvoices)
                
            } catch (e: Exception) {
                _invoiceGenerationState.value = InvoiceGenerationState.Error("Batch invoice generation failed: ${e.message}")
                Result.failure(e)
            }
        }
    }
    
    /**
     * Preview invoice
     */
    suspend fun previewInvoice(
        shipmentId: String,
        template: InvoiceTemplate = InvoiceTemplate.STANDARD,
        customizations: InvoiceCustomizations? = null
    ): Result<InvoicePreview> {
        return withContext(Dispatchers.IO) {
            try {
                // Get shipment details
                val shipment = shipmentApi.getShipmentById(shipmentId)
                    ?: throw Exception("Shipment not found")
                
                // Get customer details
                val customer = customerApi.getCustomerById(shipment.customerId)
                    ?: throw Exception("Customer not found")
                
                // Generate preview invoice (not saved)
                val invoiceNumber = "PREVIEW-${UUID.randomUUID().toString().substring(0, 8).uppercase()}"
                val invoiceItems = calculateInvoiceItems(shipment, customizations)
                val totals = calculateInvoiceTotals(invoiceItems)
                
                val preview = InvoicePreview(
                    invoiceNumber = invoiceNumber,
                    customerInfo = CustomerInfo(
                        name = customer.name,
                        address = customer.address,
                        email = customer.email,
                        phone = customer.phone,
                        taxNumber = customer.taxNumber
                    ),
                    items = invoiceItems,
                    totals = totals,
                    currency = DEFAULT_CURRENCY,
                    template = template,
                    customizations = customizations ?: InvoiceCustomizations(),
                    issueDate = Date(),
                    dueDate = calculateDueDate(shipment.deliveryDate)
                )
                
                Result.success(preview)
                
            } catch (e: Exception) {
                Result.failure(e)
            }
        }
    }
    
    /**
     * Send invoice via email
     */
    suspend fun sendInvoiceByEmail(
        invoiceId: String,
        recipientEmail: String? = null,
        message: String? = null
    ): Result<Boolean> {
        return withContext(Dispatchers.IO) {
            try {
                val invoice = getGeneratedInvoice(invoiceId)
                    ?: throw Exception("Invoice not found")
                
                _invoiceGenerationState.value = InvoiceGenerationState.Sending
                
                // Generate PDF
                val pdfPath = generateInvoicePDF(invoice)
                
                // Send email
                val success = invoiceApi.sendInvoiceEmail(
                    invoiceId = invoiceId,
                    recipientEmail = recipientEmail ?: invoice.customerInfo.email,
                    subject = "Invoice ${invoice.invoiceNumber}",
                    message = message ?: "Please find attached your invoice.",
                    attachmentPath = pdfPath
                )
                
                if (success) {
                    // Update invoice status
                    val updatedInvoice = invoice.copy(
                        status = InvoiceStatus.SENT,
                        sentAt = Date()
                    )
                    
                    database.invoiceDao().updateInvoice(updatedInvoice.toEntity())
                    updateGeneratedInvoiceInList(updatedInvoice)
                }
                
                _invoiceGenerationState.value = InvoiceGenerationState.Ready
                Result.success(success)
                
            } catch (e: Exception) {
                _invoiceGenerationState.value = InvoiceGenerationState.Error("Failed to send invoice: ${e.message}")
                Result.failure(e)
            }
        }
    }
    
    /**
     * Get generated invoice by ID
     */
    suspend fun getGeneratedInvoice(invoiceId: String): GeneratedInvoice? {
        return withContext(Dispatchers.IO) {
            try {
                // Try cache first
                _generatedInvoices.value.find { it.id == invoiceId }
                    ?: database.invoiceDao().getInvoiceById(invoiceId.toLong())?.toDomainModel()
            } catch (e: Exception) {
                null
            }
        }
    }
    
    /**
     * Get generated invoices history
     */
    suspend fun getGeneratedInvoicesHistory(
        customerId: String? = null,
        status: InvoiceStatus? = null,
        dateRange: DateRange? = null,
        page: Int = 0,
        pageSize: Int = 50
    ): Result<InvoiceHistoryResult> {
        return withContext(Dispatchers.IO) {
            try {
                val invoices = database.invoiceDao().getInvoicesHistory(
                    customerId = customerId,
                    status = status,
                    startDate = dateRange?.startDate,
                    endDate = dateRange?.endDate,
                    limit = pageSize,
                    offset = page * pageSize
                ).map { it.toDomainModel() }
                
                val totalCount = database.invoiceDao().getInvoicesHistoryCount(
                    customerId = customerId,
                    status = status,
                    startDate = dateRange?.startDate,
                    endDate = dateRange?.endDate
                )
                
                Result.success(
                    InvoiceHistoryResult(
                        invoices = invoices,
                        totalCount = totalCount,
                        page = page,
                        pageSize = pageSize,
                        totalPages = (totalCount + pageSize - 1) / pageSize
                    )
                )
                
            } catch (e: Exception) {
                Result.failure(e)
            }
        }
    }
    
    /**
     * Update invoice status
     */
    suspend fun updateInvoiceStatus(
        invoiceId: String,
        status: InvoiceStatus,
        notes: String? = null
    ): Result<GeneratedInvoice> {
        return withContext(Dispatchers.IO) {
            try {
                val invoice = getGeneratedInvoice(invoiceId)
                    ?: throw Exception("Invoice not found")
                
                _invoiceGenerationState.value = InvoiceGenerationState.Updating
                
                val updatedInvoice = invoice.copy(
                    status = status,
                    notes = notes,
                    updatedAt = Date()
                )
                
                // Update in database
                database.invoiceDao().updateInvoice(updatedInvoice.toEntity())
                
                // Update in list
                updateGeneratedInvoiceInList(updatedInvoice)
                
                _invoiceGenerationState.value = InvoiceGenerationState.Ready
                Result.success(updatedInvoice)
                
            } catch (e: Exception) {
                _invoiceGenerationState.value = InvoiceGenerationState.Error("Failed to update invoice status: ${e.message}")
                Result.failure(e)
            }
        }
    }
    
    /**
     * Helper functions
     */
    private suspend fun loadInvoiceTemplates() {
        // Load invoice templates from API or local storage
    }
    
    private suspend fun loadRecentGeneratedInvoices() {
        try {
            val invoices = database.invoiceDao().getRecentInvoices(INVOICE_CACHE_SIZE)
                .map { it.toDomainModel() }
            
            _generatedInvoices.value = invoices
            
        } catch (e: Exception) {
            // Handle error
        }
    }
    
    private suspend fun initializeInvoiceNumbering() {
        // Initialize invoice numbering system
    }
    
    private suspend fun generateInvoiceNumber(): String {
        // Generate unique invoice number
        val timestamp = Calendar.getInstance().timeInMillis
        val random = (1000..9999).random()
        return "$INVOICE_NUMBER_PREFIX${timestamp}-$random"
    }
    
    private suspend fun calculateInvoiceItems(
        shipment: Shipment,
        customizations: InvoiceCustomizations?
    ): List<InvoiceItem> {
        val items = mutableListOf<InvoiceItem>()
        
        // Base transportation fee
        items.add(
            InvoiceItem(
                description = "Transportation Services",
                quantity = 1,
                unitPrice = shipment.basePrice,
                total = shipment.basePrice,
                itemType = InvoiceItemType.TRANSPORTATION
            )
        )
        
        // Additional services
        shipment.additionalServices?.forEach { service ->
            items.add(
                InvoiceItem(
                    description = service.name,
                    quantity = service.quantity ?: 1,
                    unitPrice = service.price,
                    total = (service.quantity ?: 1) * service.price,
                    itemType = InvoiceItemType.ADDITIONAL_SERVICE
                )
            )
        }
        
        // Fuel surcharge (if applicable)
        if (shipment.fuelSurcharge > 0) {
            val fuelItem = InvoiceItem(
                description = "Fuel Surcharge",
                quantity = 1,
                unitPrice = shipment.fuelSurcharge,
                total = shipment.fuelSurcharge,
                itemType = InvoiceItemType.FUEL_SURCHARGE
            )
            items.add(fuelItem)
        }
        
        // Insurance (if applicable)
        if (shipment.insuranceAmount > 0) {
            val insuranceItem = InvoiceItem(
                description = "Insurance Coverage",
                quantity = 1,
                unitPrice = shipment.insuranceAmount,
                total = shipment.insuranceAmount,
                itemType = InvoiceItemType.INSURANCE
            )
            items.add(insuranceItem)
        }
        
        // Custom items
        customizations?.customItems?.forEach { customItem ->
            items.add(
                InvoiceItem(
                    description = customItem.description,
                    quantity = customItem.quantity,
                    unitPrice = customItem.unitPrice,
                    total = customItem.quantity * customItem.unitPrice,
                    itemType = InvoiceItemType.CUSTOM
                )
            )
        }
        
        return items
    }
    
    private fun calculateInvoiceTotals(items: List<InvoiceItem>): InvoiceTotals {
        val subtotal = items.sumOf { it.total.toDouble() }.toFloat()
        val taxAmount = subtotal * TAX_RATE
        val total = subtotal + taxAmount
        
        return InvoiceTotals(
            subtotal = subtotal,
            taxAmount = taxAmount,
            taxRate = TAX_RATE,
            total = total,
            currency = DEFAULT_CURRENCY
        )
    }
    
    private fun calculateDueDate(deliveryDate: Date): Date {
        val calendar = Calendar.getInstance()
        calendar.time = deliveryDate
        calendar.add(Calendar.DAY_OF_MONTH, LATE_FEE_DAYS)
        return calendar.time
    }
    
    private suspend fun generateInvoicePDF(invoice: GeneratedInvoice): String {
        // Generate PDF invoice
        val fileName = "invoice_${invoice.invoiceNumber}.pdf"
        val filePath = "${context.getExternalFilesDir(null)}/invoices/$fileName"
        
        // Use PDF generation library
        return filePath
    }
    
    private fun addToGeneratedInvoices(invoice: GeneratedInvoice) {
        val currentInvoices = _generatedInvoices.value.toMutableList()
        currentInvoices.add(0, invoice) // Add to beginning
        
        // Keep only last INVOICE_CACHE_SIZE invoices in cache
        if (currentInvoices.size > INVOICE_CACHE_SIZE) {
            currentInvoices.removeAt(currentInvoices.size - 1)
        }
        
        _generatedInvoices.value = currentInvoices
    }
    
    private fun updateGeneratedInvoiceInList(invoice: GeneratedInvoice) {
        val currentInvoices = _generatedInvoices.value.toMutableList()
        val index = currentInvoices.indexOfFirst { it.id == invoice.id }
        
        if (index != -1) {
            currentInvoices[index] = invoice
            _generatedInvoices.value = currentInvoices
        }
    }
    
    /**
     * Get initialization status
     */
    fun isInitialized(): Boolean = isInitialized
}

/**
 * Data classes
 */
data class GeneratedInvoice(
    val id: String = "",
    val invoiceNumber: String,
    val shipmentId: String,
    val customerId: String,
    val customerInfo: CustomerInfo,
    val items: List<InvoiceItem>,
    val totals: InvoiceTotals,
    val currency: String,
    val status: InvoiceStatus,
    val issueDate: Date,
    val dueDate: Date,
    val template: InvoiceTemplate,
    val customizations: InvoiceCustomizations,
    val sentAt: Date? = null,
    val paidAt: Date? = null,
    val notes: String? = null,
    val metadata: Map<String, String> = emptyMap(),
    val createdAt: Date = Date(),
    val updatedAt: Date = Date()
)

data class InvoicePreview(
    val invoiceNumber: String,
    val customerInfo: CustomerInfo,
    val items: List<InvoiceItem>,
    val totals: InvoiceTotals,
    val currency: String,
    val template: InvoiceTemplate,
    val customizations: InvoiceCustomizations,
    val issueDate: Date,
    val dueDate: Date
)

data class InvoiceItem(
    val description: String,
    val quantity: Int,
    val unitPrice: Float,
    val total: Float,
    val itemType: InvoiceItemType
)

data class InvoiceTotals(
    val subtotal: Float,
    val taxAmount: Float,
    val taxRate: Float,
    val total: Float,
    val currency: String
)

data class CustomerInfo(
    val name: String,
    val address: String,
    val email: String,
    val phone: String,
    val taxNumber: String?
)

data class InvoiceCustomizations(
    val includeLogo: Boolean = true,
    val includeTerms: Boolean = true,
    val customItems: List<CustomInvoiceItem> = emptyList(),
    val customNotes: String? = null,
    val customFooter: String? = null
)

data class CustomInvoiceItem(
    val description: String,
    val quantity: Int,
    val unitPrice: Float
)

data class InvoiceHistoryResult(
    val invoices: List<GeneratedInvoice>,
    val totalCount: Int,
    val page: Int,
    val pageSize: Int,
    val totalPages: Int
)

/**
 * Enums
 */
enum class InvoiceGenerationState {
    Idle,
    Initializing,
    Ready,
    Generating,
    Sending,
    Updating,
    Error
}

enum class InvoiceTemplate {
    STANDARD,
    DETAILED,
    MINIMAL,
    CUSTOM
}

enum class InvoiceStatus {
    DRAFT,
    SENT,
    PARTIALLY_PAID,
    PAID,
    OVERDUE,
    CANCELLED
}

enum class InvoiceItemType {
    TRANSPORTATION,
    ADDITIONAL_SERVICE,
    FUEL_SURCHARGE,
    INSURANCE,
    CUSTOM
}
