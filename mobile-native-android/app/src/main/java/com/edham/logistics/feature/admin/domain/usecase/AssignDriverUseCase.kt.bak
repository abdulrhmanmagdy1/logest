package com.edham.logistics.feature.admin.domain.usecase

import com.edham.logistics.core.utils.Result
import com.edham.logistics.feature.admin.domain.model.AssignDriverRequest
import com.edham.logistics.feature.admin.domain.repository.AdminRepository
import javax.inject.Inject

class AssignDriverUseCase @Inject constructor(
    private val adminRepository: AdminRepository
) {
    
    suspend operator fun invoke(
        shipmentId: String,
        driverId: String,
        notes: String? = null
    ): Result<Unit> {
        val request = AssignDriverRequest(
            shipmentId = shipmentId,
            driverId = driverId,
            notes = notes
        )
        return adminRepository.assignDriver(request)
    }
}
