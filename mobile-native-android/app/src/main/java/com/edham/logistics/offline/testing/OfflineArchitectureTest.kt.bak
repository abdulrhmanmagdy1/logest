    // Individual test implementations

    private suspend fun testDatabaseInitialization(): TestResult {
        return try {
            // Test database can be initialized
            val shipmentDao = offlineDatabase.shipmentDao()
            val driverDao = offlineDatabase.driverDao()
            
            // Verify tables exist
            val shipments = shipmentDao.getAllShipments().first()
            val drivers = driverDao.getAllDrivers().first()
            
            TestResult("Database Initialization", true, "Database initialized successfully", 100L)
        } catch (e: Exception) {
            TestResult("Database Initialization", false, "Failed to initialize database: ${e.message}", 0L)
        }
    }

    private suspend fun testDataPersistence(): TestResult {
        return try {
            val startTime = System.currentTimeMillis()
            
            // Create test shipment
            val testShipment = ShipmentEntity(
                id = "test_shipment_1",
                trackingNumber = "TEST001",
                customerId = "customer1",
                driverId = "driver1",
                origin = "Test Origin",
                destination = "Test Destination",
                status = "CREATED",
                priority = "NORMAL",
                weight = 100.0,
                dimensions = "10x10x10",
                specialInstructions = null,
                estimatedDelivery = System.currentTimeMillis() + 86400000,
                actualDelivery = null,
                createdAt = System.currentTimeMillis(),
                updatedAt = System.currentTimeMillis()
            )
            
            // Save to database
            offlineDatabase.shipmentDao().insertShipment(testShipment)
            
            // Retrieve and verify
            val retrieved = offlineDatabase.shipmentDao().getShipmentById(testShipment.id)
            
            val success = retrieved != null && retrieved.trackingNumber == testShipment.trackingNumber
            
            TestResult("Data Persistence", success, if (success) "Data persisted successfully" else "Data persistence failed", System.currentTimeMillis() - startTime)
        } catch (e: Exception) {
            TestResult("Data Persistence", false, "Data persistence error: ${e.message}", 0L)
        }
    }

    private suspend fun testDataRetrieval(): TestResult {
        return try {
            val startTime = System.currentTimeMillis()
            
            // Test retrieval methods
            val allShipments = offlineDatabase.shipmentDao().getAllShipments().first()
            val customerShipments = offlineDatabase.shipmentDao().getShipmentsByCustomer("customer1").first()
            
            val success = allShipments.isNotEmpty() && customerShipments.isNotEmpty()
            
            TestResult("Data Retrieval", success, if (success) "Data retrieved successfully" else "Data retrieval failed", System.currentTimeMillis() - startTime)
        } catch (e: Exception) {
            TestResult("Data Retrieval", false, "Data retrieval error: ${e.message}", 0L)
        }
    }

    private suspend fun testDataUpdates(): TestResult {
        return try {
            val startTime = System.currentTimeMillis()
            
            // Update test shipment
            val shipment = offlineDatabase.shipmentDao().getShipmentById("test_shipment_1")
            if (shipment != null) {
                val updatedShipment = shipment.copy(status = "IN_TRANSIT", updatedAt = System.currentTimeMillis())
                offlineDatabase.shipmentDao().updateShipment(updatedShipment)
                
                // Verify update
                val retrieved = offlineDatabase.shipmentDao().getShipmentById("test_shipment_1")
                val success = retrieved?.status == "IN_TRANSIT"
                
                TestResult("Data Updates", success, if (success) "Data updated successfully" else "Data update failed", System.currentTimeMillis() - startTime)
            } else {
                TestResult("Data Updates", false, "Test shipment not found", System.currentTimeMillis() - startTime)
            }
        } catch (e: Exception) {
            TestResult("Data Updates", false, "Data update error: ${e.message}", 0L)
        }
    }

    private suspend fun testDataDeletion(): TestResult {
        return try {
            val startTime = System.currentTimeMillis()
            
            // Delete test shipment
            offlineDatabase.shipmentDao().deleteShipmentById("test_shipment_1")
            
            // Verify deletion
            val retrieved = offlineDatabase.shipmentDao().getShipmentById("test_shipment_1")
            val success = retrieved == null
            
            TestResult("Data Deletion", success, if (success) "Data deleted successfully" else "Data deletion failed", System.currentTimeMillis() - startTime)
        } catch (e: Exception) {
            TestResult("Data Deletion", false, "Data deletion error: ${e.message}", 0L)
        }
    }

    private suspend fun testConcurrentAccess(): TestResult {
        return try {
            val startTime = System.currentTimeMillis()
            
            // Test concurrent database access
            val jobs = List(10) {
                testScope.async {
                    val shipment = ShipmentEntity(
                        id = "concurrent_test_$it",
                        trackingNumber = "CONCURRENT$it",
                        customerId = "customer1",
                        driverId = "driver1",
                        origin = "Test Origin",
                        destination = "Test Destination",
                        status = "CREATED",
                        priority = "NORMAL",
                        weight = 100.0,
                        dimensions = "10x10x10",
                        specialInstructions = null,
                        estimatedDelivery = System.currentTimeMillis() + 86400000,
                        actualDelivery = null,
                        createdAt = System.currentTimeMillis(),
                        updatedAt = System.currentTimeMillis()
                    )
                    
                    offlineDatabase.shipmentDao().insertShipment(shipment)
                    offlineDatabase.shipmentDao().getShipmentById(shipment.id)
                }
            }
            
            val results = jobs.awaitAll()
            val success = results.all { it != null }
            
            TestResult("Concurrent Access", success, if (success) "Concurrent access successful" else "Concurrent access failed", System.currentTimeMillis() - startTime)
        } catch (e: Exception) {
            TestResult("Concurrent Access", false, "Concurrent access error: ${e.message}", 0L)
        }
    }

