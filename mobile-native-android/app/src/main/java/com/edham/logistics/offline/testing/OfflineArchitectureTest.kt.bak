    private suspend fun testQueueOperations(): TestResult {
        return try {
            val startTime = System.currentTimeMillis()
            
            // Test queue enqueue/dequeue
            val operation = SyncOperation(
                id = "test_op_1",
                type = OperationType.CREATE_SHIPMENT,
                data = "test data",
                timestamp = System.currentTimeMillis()
            )
            
            val enqueueResult = syncQueue.enqueue(operation)
            val pendingOps = syncQueue.getPendingOperations()
            
            val success = enqueueResult.isSuccess && pendingOps.isNotEmpty()
            
            TestResult("Queue Operations", success, if (success) "Queue operations successful" else "Queue operations failed", System.currentTimeMillis() - startTime)
        } catch (e: Exception) {
