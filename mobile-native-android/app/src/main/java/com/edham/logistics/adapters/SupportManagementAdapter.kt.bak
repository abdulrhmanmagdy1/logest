package com.edham.logistics.adapters

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.ImageView
import android.widget.TextView
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.domain.model.SupportTicket

class SupportManagementAdapter(
    private var tickets: List<SupportTicket>,
    private val onTicketClick: (SupportTicket) -> Unit
) : RecyclerView.Adapter<SupportManagementAdapter.SupportViewHolder>() {

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): SupportViewHolder {
        val view = LayoutInflater.from(parent.context)
            .inflate(R.layout.item_support_management, parent, false)
        return SupportViewHolder(view)
    }

    override fun onBindViewHolder(holder: SupportViewHolder, position: Int) {
        holder.bind(tickets[position])
    }

    override fun getItemCount(): Int = tickets.size

    fun updateTickets(newTickets: List<SupportTicket>) {
        tickets = newTickets
        notifyDataSetChanged()
    }

    inner class SupportViewHolder(itemView: View) : RecyclerView.ViewHolder(itemView) {
        private val tvTicketTitle: TextView = itemView.findViewById(R.id.tvTicketTitle)
        private val tvDescription: TextView = itemView.findViewById(R.id.tvDescription)
        private val tvStatus: TextView = itemView.findViewById(R.id.tvStatus)
        private val tvPriority: TextView = itemView.findViewById(R.id.tvPriority)
        private val tvTime: TextView = itemView.findViewById(R.id.tvTime)
        private val tvCustomerName: TextView = itemView.findViewById(R.id.tvCustomerName)
        private val ivTicketIcon: ImageView = itemView.findViewById(R.id.ivTicketIcon)

        fun bind(ticket: SupportTicket) {
            tvTicketTitle.text = ticket.title
            tvDescription.text = ticket.description
            tvStatus.text = ticket.status
            tvPriority.text = ticket.priority
            tvTime.text = ticket.time
            tvCustomerName.text = ticket.customerName

            // Set ticket icon and color based on status
            when (ticket.status) {
                "مفتوح" -> {
                    ivTicketIcon.setImageResource(R.drawable.circle_blue)
                    ivTicketIcon.setColorFilter(itemView.context.getColor(R.color.supervisor_info))
                    tvStatus.setTextColor(itemView.context.getColor(R.color.supervisor_info))
                }
                "قيد المعالجة" -> {
                    ivTicketIcon.setImageResource(R.drawable.circle_warning)
                    ivTicketIcon.setColorFilter(itemView.context.getColor(R.color.supervisor_warning))
                    tvStatus.setTextColor(itemView.context.getColor(R.color.supervisor_warning))
                }
                "محلول", "مغلوق" -> {
                    ivTicketIcon.setImageResource(R.drawable.circle_green)
                    ivTicketIcon.setColorFilter(itemView.context.getColor(R.color.supervisor_success))
                    tvStatus.setTextColor(itemView.context.getColor(R.color.supervisor_success))
                }
                else -> {
                    ivTicketIcon.setImageResource(R.drawable.circle_grey)
                    ivTicketIcon.setColorFilter(itemView.context.getColor(R.color.text_secondary))
                    tvStatus.setTextColor(itemView.context.getColor(R.color.text_secondary))
                }
            }

            // Set priority color
            when (ticket.priority) {
                "عالي" -> {
                    tvPriority.setTextColor(itemView.context.getColor(R.color.supervisor_error))
                    tvPriority.setBackgroundColor(itemView.context.getColor(R.color.supervisor_error_transparent))
                }
                "متوسط" -> {
                    tvPriority.setTextColor(itemView.context.getColor(R.color.supervisor_warning))
                    tvPriority.setBackgroundColor(itemView.context.getColor(R.color.supervisor_warning_transparent))
                }
                "منخفض" -> {
                    tvPriority.setTextColor(itemView.context.getColor(R.color.supervisor_success))
                    tvPriority.setBackgroundColor(itemView.context.getColor(R.color.supervisor_success_transparent))
                }
                else -> {
                    tvPriority.setTextColor(itemView.context.getColor(R.color.text_secondary))
                    tvPriority.setBackgroundColor(itemView.context.getColor(R.color.text_secondary_transparent))
                }
            }

            itemView.setOnClickListener {
                onTicketClick(ticket)
            }
        }
    }
}
