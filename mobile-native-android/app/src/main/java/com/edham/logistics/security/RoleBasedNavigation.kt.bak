/**
 * Role-Based Navigation for Android
 * Provides dynamic navigation based on user roles
 */
@Composable
fun RoleBasedNavigation(
    userRole: UserRole,
    navController: NavHostController = rememberNavController(),
    startDestination: String = RoleBasedScreenLock.getAccessibleScreens(userRole).firstOrNull()?.route ?: Screen.Home.route
) {
    val drawerState = rememberDrawerState(initialValue = DrawerValue.Closed)
    val scope = rememberCoroutineScope()
    val currentRoute by navController.currentScreenAsState()

    // Get navigation items for user role
    val bottomNavItems = RoleBasedScreenLock.getBottomNavigationItems(userRole)
    val drawerItems = RoleBasedScreenLock.getDrawerNavigationItems(userRole)
    val themeColors = RoleBasedScreenLock.getRoleThemeColors(userRole)

    ModalNavigationDrawer(
        drawerState = drawerState,
        drawerContent = {
            DrawerContent(
                userRole = userRole,
                drawerItems = drawerItems,
                themeColors = themeColors,
                onNavigation = { route ->
                    scope.launch {
                        drawerState.close()
                        navController.navigate(route) {
                            popUpTo(navController.graph.startDestinationId) {
                                saveState = true
                            }
                            launchSingleTop = true
                            restoreState = true
                        }
                    }
                },
                onLogout = {
                    // Handle logout
                    scope.launch {
                        drawerState.close()
                        // Navigate to login screen
                        navController.navigate(Screen.Login.route) {
                            popUpTo(0) { inclusive = true }
                        }
                    }
                }
            )
        }
    ) {
        Scaffold(
            modifier = Modifier
                .fillMaxSize()
                .background(Color(0xFF0A0A0A)),
            bottomBar = {
                RoleBasedBottomNavigation(
                    currentRoute = currentRoute,
                    navItems = bottomNavItems,
                    themeColors = themeColors,
                    onNavigation = { route ->
                        navController.navigate(route) {
                            popUpTo(navController.graph.startDestinationId) {
                                saveState = true
                            }
                            launchSingleTop = true
                            restoreState = true
                        }
                    }
                )
            },
            floatingActionButton = {
                RoleBasedFloatingActionButton(
                    userRole = userRole,
                    themeColors = themeColors,
                    onAction = { action ->
                        when (action) {
                            "create_shipment" -> {
                                if (RoleBasedScreenLock.canAccessScreen(userRole, Screen.CreateShipment.route)) {
                                    navController.navigate(Screen.CreateShipment.route)
                                }
                            }
                            "track_shipment" -> {
                                if (RoleBasedScreenLock.canAccessScreen(userRole, Screen.LiveTracking.route)) {
                                    navController.navigate(Screen.LiveTracking.route)
                                }
                            }
                            "contact_support" -> {
                                // Open support screen or chat
                            }
                        }
                    }
                )
            }
        ) { paddingValues ->
            NavHost(
                navController = navController,
                startDestination = startDestination,
                modifier = Modifier.padding(paddingValues)
            ) {
                // Add role-protected screens
                addRoleProtectedScreens(userRole, navController)
            }
        }
    }
}

/**
 * Add role-protected screens to navigation
 */
private fun NavGraphBuilder.addRoleProtectedScreens(
    userRole: UserRole,
    navController: NavController
) {
    // Client screens
    if (RoleBasedScreenLock.canAccessScreen(userRole, Screen.Home.route)) {
        composable(Screen.Home.route) {
            RoleBasedScreenLock.RoleProtectedScreen(
                userRole = userRole,
                screenRoute = Screen.Home.route,
                onAccessDenied = { AccessDeniedScreen(onBackToHome = { navController.navigate(Screen.Home.route) }) }
            ) {
                // Home screen content
            }
        }
    }

    if (RoleBasedScreenLock.canAccessScreen(userRole, Screen.CreateShipment.route)) {
        composable(Screen.CreateShipment.route) {
            RoleBasedScreenLock.RoleProtectedScreen(
                userRole = userRole,
                screenRoute = Screen.CreateShipment.route,
                onAccessDenied = { AccessDeniedScreen(onBackToHome = { navController.navigate(Screen.Home.route) }) }
            ) {
                // Create shipment screen content
            }
        }
    }

    if (RoleBasedScreenLock.canAccessScreen(userRole, Screen.LiveTracking.route)) {
        composable(Screen.LiveTracking.route) {
            RoleBasedScreenLock.RoleProtectedScreen(
                userRole = userRole,
                screenRoute = Screen.LiveTracking.route,
                onAccessDenied = { AccessDeniedScreen(onBackToHome = { navController.navigate(Screen.Home.route) }) }
            ) {
                // Live tracking screen content
            }
        }
    }

    if (RoleBasedScreenLock.canAccessScreen(userRole, Screen.Wallet.route)) {
        composable(Screen.Wallet.route) {
            RoleBasedScreenLock.RoleProtectedScreen(
                userRole = userRole,
                screenRoute = Screen.Wallet.route,
                onAccessDenied = { AccessDeniedScreen(onBackToHome = { navController.navigate(Screen.Home.route) }) }
            ) {
                // Wallet screen content
            }
        }
    }

    // Driver screens
    if (RoleBasedScreenLock.canAccessScreen(userRole, Screen.DriverDashboard.route)) {
        composable(Screen.DriverDashboard.route) {
            RoleBasedScreenLock.RoleProtectedScreen(
                userRole = userRole,
                screenRoute = Screen.DriverDashboard.route,
                onAccessDenied = { AccessDeniedScreen(onBackToHome = { navController.navigate(Screen.Home.route) }) }
            ) {
                // Driver dashboard content
            }
        }
    }

    if (RoleBasedScreenLock.canAccessScreen(userRole, Screen.DriverTasks.route)) {
        composable(Screen.DriverTasks.route) {
            RoleBasedScreenLock.RoleProtectedScreen(
                userRole = userRole,
                screenRoute = Screen.DriverTasks.route,
                onAccessDenied = { AccessDeniedScreen(onBackToHome = { navController.navigate(Screen.Home.route) }) }
            ) {
                // Driver tasks content
            }
        }
    }

    if (RoleBasedScreenLock.canAccessScreen(userRole, Screen.DriverLocation.route)) {
        composable(Screen.DriverLocation.route) {
            RoleBasedScreenLock.RoleProtectedScreen(
                userRole = userRole,
                screenRoute = Screen.DriverLocation.route,
                onAccessDenied = { AccessDeniedScreen(onBackToHome = { navController.navigate(Screen.Home.route) }) }
            ) {
                // Driver location content
            }
        }
    }

    // Admin screens
    if (RoleBasedScreenLock.canAccessScreen(userRole, Screen.AdminDashboard.route)) {
        composable(Screen.AdminDashboard.route) {
            RoleBasedScreenLock.RoleProtectedScreen(
                userRole = userRole,
                screenRoute = Screen.AdminDashboard.route,
                onAccessDenied = { AccessDeniedScreen(onBackToHome = { navController.navigate(Screen.Home.route) }) }
            ) {
                // Admin dashboard content
            }
        }
    }

    if (RoleBasedScreenLock.canAccessScreen(userRole, Screen.UserManagement.route)) {
        composable(Screen.UserManagement.route) {
            RoleBasedScreenLock.RoleProtectedScreen(
                userRole = userRole,
                screenRoute = Screen.UserManagement.route,
                onAccessDenied = { AccessDeniedScreen(onBackToHome = { navController.navigate(Screen.Home.route) }) }
            ) {
                // User management content
            }
        }
    }

    if (RoleBasedScreenLock.canAccessScreen(userRole, Screen.RoleManagement.route)) {
        composable(Screen.RoleManagement.route) {
            RoleBasedScreenLock.RoleProtectedScreen(
                userRole = userRole,
                screenRoute = Screen.RoleManagement.route,
                onAccessDenied = { AccessDeniedScreen(onBackToHome = { navController.navigate(Screen.Home.route) }) }
            ) {
                // Role management content
            }
        }
    }

    // Accountant screens
    if (RoleBasedScreenLock.canAccessScreen(userRole, Screen.AccountantDashboard.route)) {
        composable(Screen.AccountantDashboard.route) {
            RoleBasedScreenLock.RoleProtectedScreen(
                userRole = userRole,
                screenRoute = Screen.AccountantDashboard.route,
                onAccessDenied = { AccessDeniedScreen(onBackToHome = { navController.navigate(Screen.Home.route) }) }
            ) {
                // Accountant dashboard content
            }
        }
    }

    if (RoleBasedScreenLock.canAccessScreen(userRole, Screen.InvoiceManagement.route)) {
        composable(Screen.InvoiceManagement.route) {
            RoleBasedScreenLock.RoleProtectedScreen(
                userRole = userRole,
                screenRoute = Screen.InvoiceManagement.route,
                onAccessDenied = { AccessDeniedScreen(onBackToHome = { navController.navigate(Screen.Home.route) }) }
            ) {
