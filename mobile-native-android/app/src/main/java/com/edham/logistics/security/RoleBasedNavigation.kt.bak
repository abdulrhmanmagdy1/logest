    }
}

/**
 * Role-based bottom navigation
 */
@Composable
private fun RoleBasedBottomNavigation(
    currentRoute: String,
    navItems: List<NavigationItem>,
    themeColors: RoleBasedScreenLock.RoleThemeColors,
    onNavigation: (String) -> Unit
) {
    NavigationBar(
        modifier = Modifier
            .fillMaxWidth()
            .background(
                Brush.verticalGradient(
                    colors = listOf(
                        Color(0xFF1A1A1A),
                        Color(0xFF0A0A0A)
                    )
                )
            ),
        containerColor = Color.Transparent
    ) {
        navItems.forEach { item ->
            val isSelected = currentRoute == item.route
            val iconColor = if (isSelected) {
                Color(android.graphics.Color.parseColor(themeColors.primary))
            } else {
                Color.White.copy(alpha = 0.6f)
            }

            NavigationBarItem(
                icon = {
                    Icon(
                        imageVector = getIconForRoute(item.icon),
                        contentDescription = item.title,
                        tint = iconColor,
                        modifier = Modifier.size(24.dp)
                    )
                },
                label = {
                    Text(
                        text = item.title,
                        color = iconColor,
                        fontSize = 12.sp,
                        fontWeight = if (isSelected) FontWeight.Bold else FontWeight.Normal
                    )
                },
                selected = isSelected,
                onClick = { onNavigation(item.route) },
                colors = NavigationBarItemDefaults.colors(
                    selectedIconColor = Color(android.graphics.Color.parseColor(themeColors.primary)),
                    selectedTextColor = Color(android.graphics.Color.parseColor(themeColors.primary)),
                    unselectedIconColor = Color.White.copy(alpha = 0.6f),
                    unselectedTextColor = Color.White.copy(alpha = 0.6f),
                    indicatorColor = Color.Transparent
                )
            )
        }
    }
}

/**
 * Role-based floating action button
 */
@Composable
private fun RoleBasedFloatingActionButton(
    userRole: UserRole,
    themeColors: RoleBasedScreenLock.RoleThemeColors,
    onAction: (String) -> Unit
) {
    val actions = when (userRole) {
        UserRole.CLIENT -> listOf("create_shipment", "track_shipment")
        UserRole.DRIVER -> listOf("update_location", "contact_support")
        UserRole.ADMIN -> listOf("create_user", "system_report")
        UserRole.ACCOUNTANT -> listOf("create_invoice", "generate_report")
        UserRole.WORKSHOP -> listOf("schedule_maintenance", "add_part")
    }

    FloatingActionButton(
        onClick = { onAction(actions.first()) },
        modifier = Modifier
            .padding(16.dp)
            .background(
                Brush.radialGradient(
                    colors = listOf(
                        Color(android.graphics.Color.parseColor(themeColors.primary)).copy(alpha = 0.8f),
                        Color(android.graphics.Color.parseColor(themeColors.accent)).copy(alpha = 0.6f)
                    )
                ),
                shape = RoundedCornerShape(16.dp)
            ),
        containerColor = Color.Transparent
    ) {
        Icon(
            imageVector = when (userRole) {
                UserRole.CLIENT -> Icons.Default.Add
                UserRole.DRIVER -> Icons.Default.LocationOn
                UserRole.ADMIN -> Icons.Default.AdminPanelSettings
                UserRole.ACCOUNTANT -> Icons.Default.Receipt
                UserRole.WORKSHOP -> Icons.Default.Build
            },
            contentDescription = "Quick Action",
            tint = Color.White,
            modifier = Modifier.size(24.dp)
        )
    }
}

/**
 * Drawer content for role-based navigation
 */
@Composable
private fun DrawerContent(
    userRole: UserRole,
    drawerItems: List<NavigationItem>,
    themeColors: RoleBasedScreenLock.RoleThemeColors,
    onNavigation: (String) -> Unit,
    onLogout: () -> Unit
) {
    Column(
        modifier = Modifier
            .fillMaxSize()
            .background(Color(0xFF1A1A1A))
            .padding(16.dp)
    ) {
        // User info header
        Row(
            modifier = Modifier
                .fillMaxWidth()
                .padding(vertical = 24.dp),
            verticalAlignment = Alignment.CenterVertically
        ) {
            Box(
                modifier = Modifier
                    .size(60.dp)
                    .background(
                        Brush.radialGradient(
                            colors = listOf(
                                Color(android.graphics.Color.parseColor(themeColors.primary)),
                                Color(android.graphics.Color.parseColor(themeColors.accent))
                            )
                        ),
                        shape = RoundedCornerShape(30.dp)
                    ),
                contentAlignment = Alignment.Center
            ) {
                Text(
                    text = userRole.name.first().toString(),
                    fontSize = 24.sp,
                    fontWeight = FontWeight.Bold,
                    color = Color.White
                )
            }

            Spacer(modifier = Modifier.width(16.dp))

            Column {
                Text(
                    text = userRole.name.replace("_", " "),
                    fontSize = 18.sp,
                    fontWeight = FontWeight.Bold,
                    color = Color.White
                )
                Text(
                    text = "Active User",
                    fontSize = 14.sp,
                    color = Color.White.copy(alpha = 0.7f)
                )
            }
        }

        Divider(
            modifier = Modifier.padding(vertical = 16.dp),
            color = Color.White.copy(alpha = 0.1f)
        )

        // Navigation items
        drawerItems.forEach { item ->
            NavigationDrawerItem(
                item = item,
                themeColors = themeColors,
                onClick = { onNavigation(item.route) }
            )
        }

        Spacer(modifier = Modifier.weight(1f))

        // Logout button
        OutlinedButton(
            onClick = onLogout,
            modifier = Modifier.fillMaxWidth(),
            border = ButtonDefaults.outlinedButtonBorder.copy(
                color = Color(android.graphics.Color.parseColor(themeColors.primary))
            ),
            colors = ButtonDefaults.outlinedButtonColors(
                contentColor = Color(android.graphics.Color.parseColor(themeColors.primary))
            )
        ) {
            Icon(
                imageVector = Icons.Default.Logout,
                contentDescription = "Logout",
                modifier = Modifier.size(20.dp)
            )
            Spacer(modifier = Modifier.width(8.dp))
            Text(
                text = "Logout",
                fontSize = 16.sp,
                fontWeight = FontWeight.Medium
            )
        }
    }
}

/**
 * Navigation drawer item
 */
@Composable
private fun NavigationDrawerItem(
    item: NavigationItem,
    themeColors: RoleBasedScreenLock.RoleThemeColors,
    onClick: () -> Unit
) {
    Row(
        modifier = Modifier
            .fillMaxWidth()
            .clip(RoundedCornerShape(12.dp))
            .background(
                Brush.horizontalGradient(
                    colors = listOf(
                        Color(android.graphics.Color.parseColor(themeColors.primary)).copy(alpha = 0.1f),
                        Color.Transparent
                    )
                )
            )
            .clickable { onClick() }
            .padding(horizontal = 16.dp, vertical = 12.dp),
        verticalAlignment = Alignment.CenterVertically
    ) {
        Icon(
            imageVector = getIconForRoute(item.icon),
            contentDescription = item.title,
            tint = Color(android.graphics.Color.parseColor(themeColors.primary)),
            modifier = Modifier.size(24.dp)
        )

        Spacer(modifier = Modifier.width(16.dp))

        Text(
            text = item.title,
            fontSize = 16.sp,
            fontWeight = FontWeight.Medium,
            color = Color.White
        )
    }

    Spacer(modifier = Modifier.height(8.dp))
}

/**
 * Get icon for route name
 */
private fun getIconForRoute(iconName: String): ImageVector {
    return when (iconName) {
        "home" -> Icons.Default.Home
        "dashboard" -> Icons.Default.Dashboard
        "package" -> Icons.Default.LocalShipping
        "track" -> Icons.Default.LocationOn
        "person" -> Icons.Default.Person
        "wallet" -> Icons.Default.AccountBalanceWallet
        "task" -> Icons.Default.Assignment
        "location" -> Icons.Default.LocationOn
        "earnings" -> Icons.Default.Paid
        "schedule" -> Icons.Default.Schedule
        "people" -> Icons.Default.People
        "security" -> Icons.Default.Security
        "settings" -> Icons.Default.Settings
        "receipt" -> Icons.Default.Receipt
        "payment" -> Icons.Default.Payment
        "analytics" -> Icons.Default.Analytics
        "vehicle" -> Icons.Default.DirectionsCar
        "maintenance" -> Icons.Default.Build
        "parts" -> Icons.Default.Inventory
        "health" -> Icons.Default.HealthAndSafety
        "lock" -> Icons.Default.Lock
        "admin" -> Icons.Default.AdminPanelSettings
        else -> Icons.Default.Home
    }
}

/**
 * Extension function to get current screen as state
 */
@Composable
private fun NavController.currentScreenAsState(): State<String> {
    val currentRoute = remember { mutableStateOf("") }
    
    DisposableEffect(this) {
        val listener = NavController.OnDestinationChangedListener { controller, destination, _ ->
            currentRoute.value = destination.route ?: ""
        }
        addOnDestinationChangedListener(listener)
        
        onDispose {
            removeOnDestinationChangedListener(listener)
        }
    }
    
    return currentRoute
}
