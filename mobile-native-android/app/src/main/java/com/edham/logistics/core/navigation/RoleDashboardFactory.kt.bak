package com.edham.logistics.core.navigation

import androidx.fragment.app.Fragment
import com.edham.logistics.AccountantDashboardFragment
import com.edham.logistics.AdminDashboardFragment
import com.edham.logistics.CustomerDashboardFragment
import com.edham.logistics.DriverDashboardFragment
import com.edham.logistics.SupervisorDashboardFragment
import com.edham.logistics.WorkshopDashboardFragment
import com.edham.logistics.core.model.UserRole

object RoleDashboardFactory {
    fun create(role: UserRole): Fragment {
        return when (role) {
            UserRole.ADMIN -> AdminDashboardFragment()
            UserRole.SUPERVISOR -> SupervisorDashboardFragment()
            UserRole.DRIVER -> DriverDashboardFragment()
            UserRole.CUSTOMER -> CustomerDashboardFragment()
            UserRole.ACCOUNTANT -> AccountantDashboardFragment()
            UserRole.WORKSHOP -> WorkshopDashboardFragment()
        }
    }
}
