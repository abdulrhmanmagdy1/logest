package com.edham.logistics.feature.driver

import android.app.Activity
import android.content.Intent
import android.graphics.Bitmap
import android.os.Bundle
import android.provider.MediaStore
import android.widget.Toast
import androidx.activity.result.contract.ActivityResultContracts
import androidx.fragment.app.Fragment
import com.edham.logistics.R
import com.edham.logistics.databinding.FragmentDeliveryConfirmationBinding
import com.edham.logistics.utils.VoiceAlertManager
import timber.log.Timber
import java.io.ByteArrayOutputStream
import java.util.*

class DeliveryConfirmationFragment : Fragment() {
    
    private var _binding: FragmentDeliveryConfirmationBinding? = null
    private val binding get() = _binding!!
    
    private lateinit var voiceAlertManager: VoiceAlertManager
    private var deliveryPhotos = mutableListOf<Bitmap>()
    private var currentShipmentId: String? = null
    private var customerSignature: Bitmap? = null
    
    private val cameraLauncher = registerForActivityResult(
        ActivityResultContracts.StartActivityForResult()
    ) { result ->
        if (result.resultCode == Activity.RESULT_OK) {
            result.data?.extras?.get("data")?.let { bitmap ->
                deliveryPhotos.add(bitmap as Bitmap)
                updatePhotosUI()
                voiceAlertManager.speak("Photo captured successfully")
            }
        }
    }
    
    private val signatureLauncher = registerForActivityResult(
        ActivityResultContracts.StartActivityForResult()
    ) { result ->
        if (result.resultCode == Activity.RESULT_OK) {
            // Handle signature capture
            voiceAlertManager.speak("Signature captured successfully")
        }
    }
    
    override fun onCreateView(
        inflater: android.view.LayoutInflater,
        container: android.view.ViewGroup?,
        savedInstanceState: Bundle?
    ): android.view.View {
        _binding = FragmentDeliveryConfirmationBinding.inflate(inflater, container, false)
        return binding.root
    }
    
    override fun onViewCreated(view: android.view.View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        
        voiceAlertManager = VoiceAlertManager(requireContext())
        setupUI()
        setupClickListeners()
        
        currentShipmentId = arguments?.getString("shipment_id")
        
        // Voice alert for delivery confirmation
        voiceAlertManager.speak("Please confirm delivery details and capture proof")
    }
    
    private fun setupUI() {
        // Large touch targets for one-hand usage
        binding.btnCapturePhoto.minimumHeight = 80.dp
        binding.btnCapturePhoto.minimumWidth = 120.dp
        
        binding.btnCaptureSignature.minimumHeight = 80.dp
        binding.btnCaptureSignature.minimumWidth = 120.dp
        
        binding.btnConfirmDelivery.minimumHeight = 88.dp
        binding.btnConfirmDelivery.minimumWidth = 160.dp
        
        binding.btnCancel.minimumHeight = 72.dp
        binding.btnCancel.minimumWidth = 120.dp
        
        // Dark mode optimized colors
        binding.cardDeliveryDetails.setCardBackgroundColor(
            requireContext().getColor(R.color.dark_surface)
        )
        
        // High visibility status colors
        binding.viewStatusIndicator.setBackgroundColor(
            requireContext().getColor(R.color.status_pending)
        )
    }
    
    private fun setupClickListeners() {
        binding.btnCapturePhoto.setOnClickListener {
            captureDeliveryPhoto()
        }
        
        binding.btnCaptureSignature.setOnClickListener {
            captureCustomerSignature()
        }
        
        binding.btnConfirmDelivery.setOnClickListener {
            confirmDelivery()
        }
        
        binding.btnCancel.setOnClickListener {
            requireActivity().onBackPressed()
        }
        
        binding.btnAddNote.setOnClickListener {
            addDeliveryNote()
        }
    }
    
    private fun captureDeliveryPhoto() {
        val cameraIntent = Intent(MediaStore.ACTION_IMAGE_CAPTURE)
        cameraLauncher.launch(cameraIntent)
    }
    
    private fun captureCustomerSignature() {
        // Launch signature capture activity
        val signatureIntent = Intent(requireContext(), SignatureCaptureActivity::class.java)
        signatureLauncher.launch(signatureIntent)
    }
    
    private fun confirmDelivery() {
        if (deliveryPhotos.isEmpty()) {
            Toast.makeText(requireContext(), "Please capture at least one photo", Toast.LENGTH_SHORT).show()
            voiceAlertManager.speak("Please capture delivery photos")
            return
        }
        
        if (customerSignature == null) {
            Toast.makeText(requireContext(), "Please capture customer signature", Toast.LENGTH_SHORT).show()
            voiceAlertManager.speak("Please capture customer signature")
            return
        }
        
        // Validate delivery confirmation
        val confirmationData = DeliveryConfirmationData(
            shipmentId = currentShipmentId ?: "",
            photos = deliveryPhotos,
            signature = customerSignature,
            notes = binding.etDeliveryNotes.text.toString(),
            timestamp = System.currentTimeMillis(),
            location = getCurrentLocation()
        )
        
        // Process delivery confirmation
        processDeliveryConfirmation(confirmationData)
    }
    
    private fun addDeliveryNote() {
        // Show dialog for adding notes
        voiceAlertManager.speak("Adding delivery notes")
    }
    
    private fun processDeliveryConfirmation(data: DeliveryConfirmationData) {
        // Show loading state
        binding.progressBar.visibility = android.view.View.VISIBLE
        binding.btnConfirmDelivery.isEnabled = false
        
        // Process confirmation (API call or local storage)
        // This would typically involve:
        // 1. Upload photos to server
        // 2. Upload signature
        // 3. Update shipment status
        // 4. Send confirmation to customer
        
        // Simulate processing
        binding.root.postDelayed({
            binding.progressBar.visibility = android.view.View.GONE
            binding.btnConfirmDelivery.isEnabled = true
            
            voiceAlertManager.speak("Delivery confirmed successfully")
            Toast.makeText(requireContext(), "Delivery confirmed successfully", Toast.LENGTH_LONG).show()
            
            // Navigate back or to next screen
            requireActivity().onBackPressed()
        }, 2000)
    }
    
    private fun updatePhotosUI() {
        binding.tvPhotoCount.text = "${deliveryPhotos.size} photos captured"
        
        if (deliveryPhotos.isNotEmpty()) {
            binding.btnCapturePhoto.text = "Add Photo (${deliveryPhotos.size})"
            binding.btnCapturePhoto.setBackgroundColor(
                requireContext().getColor(R.color.status_active)
            )
        }
    }
    
    private fun getCurrentLocation(): String {
        // Get current location for delivery confirmation
        return "Lat: 0.0, Lng: 0.0" // Placeholder
    }
    
    private fun compressBitmap(bitmap: Bitmap): ByteArray {
        val stream = ByteArrayOutputStream()
        bitmap.compress(Bitmap.CompressFormat.JPEG, 70, stream)
        return stream.toByteArray()
    }
    
    override fun onDestroyView() {
        super.onDestroyView()
        voiceAlertManager.cleanup()
        _binding = null
    }
    
    // Extension for dp to pixels
    private val Int.dp: Int
        get() = (this * resources.displayMetrics.density).toInt()
}

data class DeliveryConfirmationData(
    val shipmentId: String,
    val photos: List<Bitmap>,
    val signature: Bitmap?,
    val notes: String,
    val timestamp: Long,
    val location: String
)
