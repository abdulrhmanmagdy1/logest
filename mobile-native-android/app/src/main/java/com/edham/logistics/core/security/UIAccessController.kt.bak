package com.edham.logistics.core.security

import android.view.View
import android.widget.Button
import android.widget.ImageView
import android.widget.TextView
import androidx.fragment.app.Fragment
import androidx.lifecycle.LifecycleOwner
import androidx.lifecycle.lifecycleScope
import kotlinx.coroutines.flow.launch
import kotlinx.coroutines.flow.collect
import timber.log.Timber
import javax.inject.Inject
import javax.inject.Singleton

/**
 * UI Access Controller - Prevents direct role-based UI binding
 * Enforces all UI visibility through RoleContext
 */
@Singleton
class UIAccessController @Inject constructor(
    private val roleContext: RoleContext
) {
    
    /**
     * Initialize UI access controller for a fragment
     */
    fun initialize(fragment: Fragment) {
        if (!roleContext.isInitialized()) {
            Timber.w("RoleContext not initialized when initializing UI for ${fragment.javaClass.simpleName}")
            return
        }
        
        // Monitor role context changes
        fragment.lifecycleScope.launch {
            // This would need to be implemented as a Flow in RoleContext
            // For now, we'll use current state
        }
    }
    
    /**
     * Set view visibility based on permission
     */
    fun setViewVisibility(view: View, permission: Permission, lifecycleOwner: LifecycleOwner) {
        val hasPermission = roleContext.hasPermission(permission)
        view.visibility = if (hasPermission) View.VISIBLE else View.GONE
        
        Timber.d("View visibility set for ${permission.displayName}: $hasPermission")
    }
    
    /**
     * Set view visibility based on any permission
     */
    fun setViewVisibilityForAnyPermission(view: View, vararg permissions: Permission, lifecycleOwner: LifecycleOwner) {
        val hasPermission = roleContext.hasAnyPermission(*permissions)
        view.visibility = if (hasPermission) View.VISIBLE else View.GONE
        
        Timber.d("View visibility set for any permission: $hasPermission")
    }
    
    /**
     * Set view visibility based on all permissions
     */
    fun setViewVisibilityForAllPermissions(view: View, vararg permissions: Permission, lifecycleOwner: LifecycleOwner) {
        val hasPermission = roleContext.hasAllPermissions(*permissions)
        view.visibility = if (hasPermission) View.VISIBLE else View.GONE
        
        Timber.d("View visibility set for all permissions: $hasPermission")
    }
    
    /**
     * Set button enabled state based on permission
     */
    fun setButtonEnabled(button: Button, permission: Permission) {
        val hasPermission = roleContext.hasPermission(permission)
        button.isEnabled = hasPermission
        
        if (!hasPermission) {
            button.alpha = 0.5f
        } else {
            button.alpha = 1.0f
        }
        
        Timber.d("Button enabled state set for ${permission.displayName}: $hasPermission")
    }
    
    /**
     * Set button enabled state based on any permission
     */
    fun setButtonEnabledForAnyPermission(button: Button, vararg permissions: Permission) {
        val hasPermission = roleContext.hasAnyPermission(*permissions)
        button.isEnabled = hasPermission
        
        if (!hasPermission) {
            button.alpha = 0.5f
        } else {
            button.alpha = 1.0f
        }
        
        Timber.d("Button enabled state set for any permission: $hasPermission")
    }
    
    /**
     * Set button enabled state based on all permissions
     */
    fun setButtonEnabledForAllPermissions(button: Button, vararg permissions: Permission) {
        val hasPermission = roleContext.hasAllPermissions(*permissions)
        button.isEnabled = hasPermission
        
        if (!hasPermission) {
            button.alpha = 0.5f
        } else {
            button.alpha = 1.0f
        }
        
        Timber.d("Button enabled state set for all permissions: $hasPermission")
    }
    
    /**
     * Set text view visibility and content based on permission
     */
    fun setTextViewVisibility(textView: TextView, permission: Permission, lifecycleOwner: LifecycleOwner) {
        val hasPermission = roleContext.hasPermission(permission)
        textView.visibility = if (hasPermission) View.VISIBLE else View.GONE
        
        Timber.d("TextView visibility set for ${permission.displayName}: $hasPermission")
    }
    
    /**
     * Set image view visibility based on permission
     */
    fun setImageViewVisibility(imageView: ImageView, permission: Permission, lifecycleOwner: LifecycleOwner) {
        val hasPermission = roleContext.hasPermission(permission)
        imageView.visibility = if (hasPermission) View.VISIBLE else View.GONE
        
        Timber.d("ImageView visibility set for ${permission.displayName}: $hasPermission")
    }
    
    /**
     * Set view visibility based on resource access
     */
    fun setViewVisibilityForResource(view: View, resourceType: ResourceType, action: ResourceAction, lifecycleOwner: LifecycleOwner) {
        val hasAccess = roleContext.canAccessResource(resourceType, action)
        view.visibility = if (hasAccess) View.VISIBLE else View.GONE
        
        Timber.d("View visibility set for resource $resourceType:$action: $hasAccess")
    }
    
    /**
     * Set button enabled state based on resource access
     */
    fun setButtonEnabledForResource(button: Button, resourceType: ResourceType, action: ResourceAction) {
        val hasAccess = roleContext.canAccessResource(resourceType, action)
        button.isEnabled = hasAccess
        
        if (!hasAccess) {
            button.alpha = 0.5f
        } else {
            button.alpha = 1.0f
        }
        
        Timber.d("Button enabled state set for resource $resourceType:$action: $hasAccess")
    }
    
    /**
     * Get UI visibility configuration
     */
    fun getUIVisibility(): UIVisibility {
        return roleContext.getUIVisibility()
    }
    
    /**
     * Apply UI visibility to multiple views
     */
    fun applyUIVisibility(
        views: Map<View, Permission>,
        lifecycleOwner: LifecycleOwner
    ) {
        views.forEach { (view, permission) ->
            setViewVisibility(view, permission, lifecycleOwner)
        }
    }
    
    /**
     * Apply button states to multiple buttons
     */
    fun applyButtonStates(
        buttons: Map<Button, Permission>
    ) {
        buttons.forEach { (button, permission) ->
            setButtonEnabled(button, permission)
        }
    }
    
    /**
     * Check if view should be visible (without actually setting visibility)
     */
    fun shouldShowView(permission: Permission): Boolean {
        return roleContext.hasPermission(permission)
    }
    
    /**
     * Check if button should be enabled (without actually setting state)
     */
    fun shouldEnableButton(permission: Permission): Boolean {
        return roleContext.hasPermission(permission)
    }
    
    /**
     * Check if user can access resource
     */
    fun canAccessResource(resourceType: ResourceType, action: ResourceAction): Boolean {
        return roleContext.canAccessResource(resourceType, action)
    }
    
    /**
     * Get current role capabilities as formatted string
     */
    fun getRoleCapabilities(): String {
        return roleContext.getRoleCapabilities()
    }
    
    /**
     * Validate UI configuration
     */
    fun validateUIConfiguration(uiElements: List<UIElement>): ValidationResult {
        val issues = mutableListOf<String>()
        
        uiElements.forEach { element ->
            when (element.type) {
                UIElementType.VIEW -> {
                    val permission = element.permission
                    if (permission != null && !roleContext.hasPermission(permission)) {
                        issues.add("View ${element.name} requires permission ${permission.displayName}")
                    }
                }
                UIElementType.BUTTON -> {
                    val permission = element.permission
                    if (permission != null && !roleContext.hasPermission(permission)) {
                        issues.add("Button ${element.name} requires permission ${permission.displayName}")
                    }
                }
                UIElementType.RESOURCE -> {
                    val hasAccess = roleContext.canAccessResource(
                        element.resourceType ?: ResourceType.DASHBOARD,
                        element.resourceAction ?: ResourceAction.VIEW
                    )
                    if (!hasAccess) {
                        issues.add("Element ${element.name} cannot access resource ${element.resourceType}:${element.resourceAction}")
                    }
                }
            }
        }
        
        return ValidationResult(
            isValid = issues.isEmpty(),
            issues = issues
        )
    }
}

/**
 * UI element definition for validation
 */
data class UIElement(
    val name: String,
    val type: UIElementType,
    val permission: Permission? = null,
    val resourceType: ResourceType? = null,
    val resourceAction: ResourceAction? = null
)

/**
 * UI element types
 */
enum class UIElementType {
    VIEW,
    BUTTON,
    RESOURCE
}

/**
 * Validation result for UI configuration
 */
data class ValidationResult(
    val isValid: Boolean,
    val issues: List<String>
)
