package com.edham.logistics

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.TextView
import androidx.recyclerview.widget.RecyclerView

class RecentShipmentsAdapter(private var shipments: List<Shipment>) : 
    RecyclerView.Adapter<RecentShipmentsAdapter.ShipmentViewHolder>() {
    
    class ShipmentViewHolder(itemView: View) : RecyclerView.ViewHolder(itemView) {
        val tvId: TextView = itemView.findViewById(R.id.tv_shipment_id)
        val tvDate: TextView = itemView.findViewById(R.id.tv_date)
        val tvStatus: TextView = itemView.findViewById(R.id.tv_status)
        val tvFrom: TextView = itemView.findViewById(R.id.tv_from)
        val tvTo: TextView = itemView.findViewById(R.id.tv_to)
        val tvWeight: TextView = itemView.findViewById(R.id.tv_weight)
        val tvPrice: TextView = itemView.findViewById(R.id.tv_price)
    }
    
    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): ShipmentViewHolder {
        val view = LayoutInflater.from(parent.context)
            .inflate(R.layout.item_shipment, parent, false)
        return ShipmentViewHolder(view)
    }
    
    override fun onBindViewHolder(holder: ShipmentViewHolder, position: Int) {
        val shipment = shipments[position]
        
        holder.tvId.text = shipment.id
        holder.tvDate.text = shipment.date
        holder.tvStatus.text = shipment.status
        holder.tvFrom.text = shipment.from
        holder.tvTo.text = shipment.to
        holder.tvWeight.text = shipment.weight
        holder.tvPrice.text = shipment.price
        
        // Set status background
        holder.tvStatus.background = when (shipment.status) {
            "In Transit" -> holder.itemView.context.getDrawable(R.drawable.bg_status_transit)
            "Delivered" -> holder.itemView.context.getDrawable(R.drawable.bg_status_completed)
            "Pending" -> holder.itemView.context.getDrawable(R.drawable.bg_status_pending)
            "Cancelled" -> holder.itemView.context.getDrawable(R.drawable.bg_status_cancelled)
            else -> holder.itemView.context.getDrawable(R.drawable.bg_status_pending)
        }
    }
    
    override fun getItemCount(): Int = shipments.size
    
    fun updateData(newShipments: List<Shipment>) {
        shipments = newShipments
        notifyDataSetChanged()
    }
}
