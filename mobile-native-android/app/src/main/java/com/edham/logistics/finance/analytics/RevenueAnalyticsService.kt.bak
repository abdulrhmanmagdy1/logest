    private fun calculateComparison(previousRevenue: Float, currentRevenue: Float): ComparisonResult {
        val growthRate = if (previousRevenue > 0) ((currentRevenue - previousRevenue) / previousRevenue) * 100f else 0f
        val absoluteChange = currentRevenue - previousRevenue
        
        return ComparisonResult(
            previousRevenue = previousRevenue,
            currentRevenue = currentRevenue,
            absoluteChange = absoluteChange,
            percentageChange = growthRate,
            direction = if (growthRate > 0) ComparisonDirection.INCREASE else if (growthRate < 0) ComparisonDirection.DECREASE else ComparisonDirection.SAME
        )
    }
    
