/**
 * Data classes
 */
data class RevenueAnalytics(
    val revenueCalculations: RevenueCalculations,
    val revenueTrends: RevenueTrends,
    val revenueBreakdown: RevenueBreakdown,
    val revenueForecasts: RevenueForecasts,
    val performanceMetrics: RevenuePerformanceMetrics,
    val revenueComparisons: RevenueComparisons,
    val visualizationData: VisualizationData,
    val kpiMetrics: KPIMetrics,
    val currency: String,
    val dateRange: DateRange,
    val filters: RevenueFilters?,
    val generatedAt: Date
)

data class RevenueSummary(
    val totalRevenue: Float,
    val netRevenue: Float,
    val grossRevenue: Float,
    val averageDailyRevenue: Float,
    val revenueGrowthRate: Float,
    val profitMargin: Float,
    val topRevenueSource: RevenueByCategory?,
    val revenuePerCustomer: Float,
    val revenuePerShipment: Float,
    val currency: String,
    val dateRange: DateRange
)

data class RevenueCalculations(
    val totalRevenue: Float,
    val grossRevenue: Float,
    val netRevenue: Float,
    val totalExpenses: Float,
    val totalPayments: Float,
    val averageDailyRevenue: Float,
    val revenuePerPeriod: Float,
    val expensesRatio: Float,
    val paymentsRatio: Float,
    val currency: String
)

data class RevenueTrends(
    val monthlyTrend: List<MonthlyRevenue>,
    val trendDirection: TrendDirection,
    val trendPercentage: Float,
    val movingAverage: List<Float>,
    val seasonality: SeasonalityPattern,
    val momentum: Float
)

data class RevenueBreakdown(
    val categoryRevenue: List<RevenueByCategory>,
    val customerRevenue: List<RevenueByCustomer>,
    val serviceRevenue: List<RevenueByService>,
    val regionRevenue: List<RevenueByRegion>,
