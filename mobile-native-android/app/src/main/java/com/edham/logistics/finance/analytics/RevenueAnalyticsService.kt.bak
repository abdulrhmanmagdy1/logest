/**
 * Enums
 */
enum class RevenueAnalyticsState {
    Idle,
    Initializing,
    Ready,
    Processing,
    Error
}

enum class TrendDirection {
    UPWARD,
    DOWNWARD,
    STABLE
}

enum class ComparisonDirection {
    INCREASE,
    DECREASE,
    SAME
}

/**
 * Extension functions
 */
fun DateRange.previousPeriod(): DateRange {
    val duration = this.endDate.time - this.startDate.time
    val newEnd = this.startDate
    val newStart = Date(newEnd.time - duration)
    return DateRange(newStart, newEnd)
}

fun DateRange.previousYear(): DateRange {
    val calendar = Calendar.getInstance()
    calendar.time = this.startDate
    calendar.add(Calendar.YEAR, -1)
    val newStart = calendar.time
    
    calendar.time = this.endDate
    calendar.add(Calendar.YEAR, -1)
    val newEnd = calendar.time
    
    return DateRange(newStart, newEnd)
}

fun DateRange.last30Days(): DateRange {
    val calendar = Calendar.getInstance()
    val end = calendar.time
    calendar.add(Calendar.DAY_OF_MONTH, -30)
    val start = calendar.time
    return DateRange(start, end)
}

fun DateRange.last12Months(): DateRange {
    val calendar = Calendar.getInstance()
    val end = calendar.time
    calendar.add(Calendar.MONTH, -12)
    val start = calendar.time
    return DateRange(start, end)
}

fun DateRange.last90Days(): DateRange {
    val calendar = Calendar.getInstance()
    val end = calendar.time
    calendar.add(Calendar.DAY_OF_MONTH, -90)
    val start = calendar.time
    return DateRange(start, end)
}

fun <T> List<T>.zipWithNext(transform: (T, T) -> R): List<R> {
    return this.zipWithNext().map { (a, b) -> transform(a, b) }
}
