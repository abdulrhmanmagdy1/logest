    private fun calculateTrendDirection(monthlyRevenue: List<MonthlyRevenue>): TrendDirection {
        if (monthlyRevenue.size < 2) return TrendDirection.STABLE
        
        val recent = monthlyRevenue.takeLast(3).map { it.revenue }
        val earlier = monthlyRevenue.dropLast(3).takeLast(3).map { it.revenue }
        
        val recentAvg = recent.average().toFloat()
        val earlierAvg = earlier.average().toFloat()
        
        return when {
            recentAvg > earlierAvg * 1.05f -> TrendDirection.UPWARD
            recentAvg < earlierAvg * 0.95f -> TrendDirection.DOWNWARD
            else -> TrendDirection.STABLE
        }
    }
    
    private fun calculateTrendPercentage(monthlyRevenue: List<MonthlyRevenue>): Float {
        if (monthlyRevenue.size < 2) return 0f
        
        val first = monthlyRevenue.first().revenue
        val last = monthlyRevenue.last().revenue
        
        return if (first > 0) ((last - first) / first) * 100f else 0f
    }
    
    private fun calculateMovingAverage(monthlyRevenue: List<MonthlyRevenue>, period: Int): List<Float> {
        return monthlyRevenue.mapIndexed { index, revenue ->
            val start = maxOf(0, index - period + 1)
            val end = index + 1
            monthlyRevenue.subList(start, end).map { it.revenue }.average().toFloat()
        }
    }
    
