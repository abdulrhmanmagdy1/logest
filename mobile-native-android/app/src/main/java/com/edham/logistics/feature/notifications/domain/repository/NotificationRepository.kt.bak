package com.edham.logistics.feature.notifications.domain.repository

import com.edham.logistics.core.utils.Result
import com.edham.logistics.feature.notifications.domain.model.*

interface NotificationRepository {
    // Send notifications
    suspend fun sendNotification(request: SendNotificationRequest): Result<String>
    suspend fun sendBulkNotification(request: SendBulkNotificationRequest): Result<List<String>>
    suspend fun sendPushNotification(payload: PushNotificationPayload): Result<String>
    suspend fun sendEmailNotification(userIds: List<String>, subject: String, body: String): Result<Unit>
    suspend fun sendSmsNotification(phoneNumbers: List<String>, message: String): Result<Unit>
    
    // Get notifications
    suspend fun getNotifications(request: GetNotificationsRequest): Result<List<Notification>>
    suspend fun observeNotifications(userId: String, userRole: UserRole): Flow<Result<List<Notification>>>
    suspend fun getNotificationById(notificationId: String): Result<Notification>
    suspend fun getUnreadCount(userId: String, userRole: UserRole): Result<Int>
    
    // Update notifications
    suspend fun markNotificationAsRead(notificationId: String, userId: String): Result<Unit>
    suspend fun markAllNotificationsAsRead(userId: String, userRole: UserRole): Result<Unit>
    suspend fun deleteNotification(notificationId: String, userId: String): Result<Unit>
    suspend fun deleteAllNotifications(userId: String, userRole: UserRole): Result<Unit>
    
    // Notification settings
    suspend fun getNotificationSettings(userId: String): Result<NotificationSettings>
    suspend fun updateNotificationSettings(request: UpdateNotificationSettingsRequest): Result<NotificationSettings>
    suspend fun getDefaultNotificationSettings(userRole: UserRole): Result<NotificationSettings>
    suspend fun resetNotificationSettings(userId: String): Result<NotificationSettings>
    
    // Templates
    suspend fun getNotificationTemplate(type: NotificationType): Result<NotificationTemplate>
    suspend fun getAllNotificationTemplates(): Result<List<NotificationTemplate>>
    suspend fun updateNotificationTemplate(template: NotificationTemplate): Result<NotificationTemplate>
    
    // Statistics
    suspend fun getNotificationStats(request: GetNotificationStatsRequest): Result<NotificationStats>
    suspend fun getDeliveryStats(notificationId: String): Result<Map<String, Any>>
    suspend fun getUserStats(userId: String, period: String): Result<Map<String, Any>>
    
    // Device management
    suspend fun registerDevice(userId: String, fcmToken: String, deviceId: String): Result<Unit>
    suspend fun unregisterDevice(userId: String, deviceId: String): Result<Unit>
    suspend fun getUserDevices(userId: String): Result<List<Map<String, Any>>>
    suspend fun updateDeviceToken(userId: String, deviceId: String, fcmToken: String): Result<Unit>
    
    // WebSocket/Real-time
    suspend fun connectToNotificationWebSocket(): Result<Unit>
    suspend fun disconnectFromNotificationWebSocket(): Result<Unit>
    suspend fun observeNotificationMessages(): Flow<Result<NotificationWebSocketMessage>>
    suspend fun sendNotificationMessage(message: NotificationWebSocketMessage): Result<Unit>
    
    // Scheduling
    suspend fun scheduleNotification(request: SendNotificationRequest, scheduledAt: Long): Result<String>
    suspend fun cancelScheduledNotification(notificationId: String): Result<Unit>
    suspend fun getScheduledNotifications(userId: String): Result<List<Notification>>
    
    // Batch operations
    suspend fun markMultipleAsRead(notificationIds: List<String>, userId: String): Result<Unit>
    suspend fun deleteMultipleNotifications(notificationIds: List<String>, userId: String): Result<Unit>
    suspend fun archiveNotifications(notificationIds: List<String>, userId: String): Result<Unit>
    
    // Filtering and search
    suspend fun searchNotifications(userId: String, query: String, filters: Map<String, Any>): Result<List<Notification>>
    suspend fun getNotificationsByType(userId: String, type: NotificationType, limit: Int): Result<List<Notification>>
    suspend fun getNotificationsByCategory(userId: String, category: NotificationCategory, limit: Int): Result<List<Notification>>
    
    // Analytics
    suspend fun trackNotificationEvent(notificationId: String, event: String, data: Map<String, Any>): Result<Unit>
    suspend fun getNotificationAnalytics(period: String, filters: Map<String, Any>): Result<Map<String, Any>>
}
