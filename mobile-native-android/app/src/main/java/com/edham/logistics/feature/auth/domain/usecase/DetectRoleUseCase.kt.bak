package com.edham.logistics.feature.auth.domain.usecase

import com.edham.logistics.feature.auth.domain.model.UserRole
import javax.inject.Inject
import javax.inject.Singleton

@Singleton
class DetectRoleUseCase @Inject constructor() {
    
    suspend operator fun invoke(email: String): UserRole {
        return when {
            email.startsWith("client@") -> UserRole.CUSTOMER
            email.startsWith("driver@") -> UserRole.DRIVER
            email.startsWith("admin@") -> UserRole.ADMIN
            email.startsWith("accounting@") || email.startsWith("accountant@") -> UserRole.ACCOUNTANT
            else -> UserRole.CUSTOMER // Default role
        }
    }
}
