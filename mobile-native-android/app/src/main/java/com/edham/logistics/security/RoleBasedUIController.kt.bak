package com.edham.logistics.security

import androidx.compose.runtime.*
import androidx.compose.ui.graphics.Color
import com.edham.logistics.model.UserRole
import kotlinx.coroutines.flow.MutableStateFlow
import kotlinx.coroutines.flow.StateFlow
import kotlinx.coroutines.flow.asStateFlow

/**
 * Role-Based UI Controller for Android
 * Manages UI visibility, components, and interactions based on user roles
 */
class RoleBasedUIController(initialRole: UserRole) {
    
    private val _userRole = MutableStateFlow(initialRole)
    val userRole: StateFlow<UserRole> = _userRole.asStateFlow()
    
    private val _uiState = MutableStateFlow(RoleUIState())
    val uiState: StateFlow<RoleUIState> = _uiState.asStateFlow()
    
    private val _visibleComponents = MutableStateFlow<Set<String>>(emptySet())
    val visibleComponents: StateFlow<Set<String>> = _visibleComponents.asStateFlow()
    
    private val _enabledActions = MutableStateFlow<Set<String>>(emptySet())
    val enabledActions: StateFlow<Set<String>> = _enabledActions.asStateFlow()
    
    private val _themeColors = MutableStateFlow(RoleThemeColors())
    val themeColors: StateFlow<RoleThemeColors> = _themeColors.asStateFlow()
    
    init {
        updateUIState(initialRole)
    }
    
    /**
     * Update user role and refresh UI state
     */
    fun updateRole(newRole: UserRole) {
        _userRole.value = newRole
        updateUIState(newRole)
    }
    
    /**
     * Update UI state based on role
     */
    private fun updateUIState(role: UserRole) {
        val components = getRoleComponents(role)
        val actions = getRoleActions(role)
        val theme = RoleBasedScreenLock.getRoleThemeColors(role)
        
        _visibleComponents.value = components
        _enabledActions.value = actions
        _themeColors.value = theme
        
        _uiState.value = RoleUIState(
            role = role,
            visibleComponents = components,
            enabledActions = actions,
            themeColors = theme,
            navigationItems = RoleBasedScreenLock.getBottomNavigationItems(role),
            drawerItems = RoleBasedScreenLock.getDrawerNavigationItems(role)
        )
    }
    
    /**
     * Check if component is visible for current role
     */
    fun isComponentVisible(componentId: String): Boolean {
        return componentId in _visibleComponents.value
    }
    
    /**
     * Check if action is enabled for current role
     */
    fun isActionEnabled(actionId: String): Boolean {
        return actionId in _enabledActions.value
    }
    
    /**
     * Get role-specific components
     */
    private fun getRoleComponents(role: UserRole): Set<String> {
        return when (role) {
            UserRole.CLIENT -> setOf(
                "shipment_list", "create_shipment", "track_shipment",
                "profile", "wallet", "notifications", "settings",
                "help_support", "promotions", "address_management"
            )
            UserRole.DRIVER -> setOf(
                "task_list", "location_tracker", "shipment_status",
                "earnings", "schedule", "profile", "settings",
                "notifications", "help_support", "proof_upload"
            )
            UserRole.ADMIN -> setOf(
                "user_management", "role_management", "permission_management",
                "system_settings", "reports", "analytics", "dashboard",
                "vehicle_management", "maintenance_management", "emergency_management"
            )
            UserRole.ACCOUNTANT -> setOf(
                "invoice_management", "payment_management", "financial_reports",
                "tax_reports", "analytics", "dashboard", "settings",
                "export_data", "audit_logs"
            )
            UserRole.WORKSHOP -> setOf(
                "vehicle_management", "maintenance_management", "parts_inventory",
                "fleet_health", "dashboard", "schedule", "settings",
                "notifications", "reports"
            )
        }
    }
    
    /**
     * Get role-specific actions
     */
    private fun getRoleActions(role: UserRole): Set<String> {
        return when (role) {
            UserRole.CLIENT -> setOf(
                "create_shipment", "cancel_shipment", "track_shipment",
                "update_profile", "make_payment", "rate_shipment",
                "view_notifications", "contact_support"
            )
            UserRole.DRIVER -> setOf(
                "update_location", "update_status", "upload_proof",
                "accept_task", "decline_task", "view_earnings",
                "update_profile", "view_notifications"
            )
            UserRole.ADMIN -> setOf(
                "create_user", "update_user", "delete_user",
                "assign_role", "manage_permissions", "system_backup",
                "system_restore", "view_logs", "manage_settings",
                "generate_reports", "manage_vehicles", "manage_maintenance"
            )
            UserRole.ACCOUNTANT -> setOf(
                "create_invoice", "update_invoice", "delete_invoice",
                "process_payment", "refund_payment", "generate_report",
                "export_data", "manage_tax", "view_audit_logs"
            )
            UserRole.WORKSHOP -> setOf(
                "schedule_maintenance", "update_vehicle_status",
                "manage_parts", "update_inventory", "create_work_order",
                "complete_maintenance", "view_fleet_health",
                "generate_reports"
            )
        }
    }
    
    /**
     * Get component visibility state
     */
    @Composable
    fun getComponentVisibility(componentId: String): Boolean {
        val visibleComponents by _visibleComponents.asState()
        return componentId in visibleComponents
    }
    
    /**
     * Get action enabled state
     */
    @Composable
    fun getActionEnabled(actionId: String): Boolean {
        val enabledActions by _enabledActions.asState()
        return actionId in enabledActions
    }
    
    /**
     * Get theme color
     */
    @Composable
    fun getThemeColor(colorType: ThemeColorType): Color {
        val themeColors by _themeColors.asState()
        return when (colorType) {
            ThemeColorType.PRIMARY -> Color(android.graphics.Color.parseColor(themeColors.primary))
            ThemeColorType.SECONDARY -> Color(android.graphics.Color.parseColor(themeColors.secondary))
            ThemeColorType.ACCENT -> Color(android.graphics.Color.parseColor(themeColors.accent))
            ThemeColorType.BACKGROUND -> Color(android.graphics.Color.parseColor(themeColors.background))
        }
    }
    
    /**
     * Check if screen should be visible
     */
    fun shouldShowScreen(screenRoute: String): Boolean {
        val currentRole = _userRole.value
        return RoleBasedScreenLock.canAccessScreen(currentRole, screenRoute)
    }
    
    /**
     * Check if action can be performed on screen
     */
    fun canPerformAction(screenRoute: String, action: String): Boolean {
        val currentRole = _userRole.value
        return RoleBasedScreenLock.canPerformAction(currentRole, screenRoute, action)
    }
    
    /**
     * Get role-specific UI configuration
     */
    fun getRoleUIConfiguration(): RoleUIConfiguration {
        val currentRole = _userRole.value
        return RoleUIConfiguration(
            role = currentRole,
            visibleComponents = _visibleComponents.value,
            enabledActions = _enabledActions.value,
            themeColors = _themeColors.value,
            navigationItems = RoleBasedScreenLock.getBottomNavigationItems(currentRole),
            drawerItems = RoleBasedScreenLock.getDrawerNavigationItems(currentRole),
            accessibleScreens = RoleBasedScreenLock.getAccessibleScreens(currentRole),
            uiComponents = RoleBasedScreenLock.getAccessibleUIComponents(currentRole)
        )
    }
    
    /**
     * Refresh UI state (useful after role changes)
     */
    fun refreshUI() {
        val currentRole = _userRole.value
        updateUIState(currentRole)
    }
    
    /**
     * Clear UI state
     */
    fun clearUI() {
        _visibleComponents.value = emptySet()
        _enabledActions.value = emptySet()
        _uiState.value = RoleUIState()
    }
}

/**
 * UI State data class
 */
data class RoleUIState(
    val role: UserRole = UserRole.CLIENT,
    val visibleComponents: Set<String> = emptySet(),
    val enabledActions: Set<String> = emptySet(),
    val themeColors: RoleThemeColors = RoleThemeColors(),
    val navigationItems: List<NavigationItem> = emptyList(),
    val drawerItems: List<NavigationItem> = emptyList()
)

/**
 * UI Configuration data class
 */
data class RoleUIConfiguration(
    val role: UserRole,
    val visibleComponents: Set<String>,
    val enabledActions: Set<String>,
    val themeColors: RoleThemeColors,
    val navigationItems: List<NavigationItem>,
    val drawerItems: List<NavigationItem>,
    val accessibleScreens: List<Screen>,
    val uiComponents: List<String>
)

/**
 * Theme color type enum
 */
enum class ThemeColorType {
    PRIMARY,
    SECONDARY,
    ACCENT,
    BACKGROUND
}

/**
 * Composable for role-based component visibility
 */
@Composable
fun RoleBasedComponentVisibility(
    componentId: String,
    uiController: RoleBasedUIController,
    content: @Composable () -> Unit
) {
    if (uiController.getComponentVisibility(componentId)) {
        content()
    }
}

/**
 * Composable for role-based action enablement
 */
@Composable
fun RoleBasedActionEnablement(
    actionId: String,
    uiController: RoleBasedUIController,
    onActionDisabled: () -> Unit = {},
    content: @Composable () -> Unit
) {
    if (uiController.getActionEnabled(actionId)) {
        content()
    } else {
        onActionDisabled()
    }
}

/**
 * Composable for role-based screen protection
 */
@Composable
fun RoleBasedScreenProtection(
    screenRoute: String,
    uiController: RoleBasedUIController,
    onAccessDenied: @Composable () -> Unit = { AccessDeniedScreen() },
    content: @Composable () -> Unit
) {
    if (uiController.shouldShowScreen(screenRoute)) {
        content()
    } else {
        onAccessDenied()
    }
}

/**
 * Composable for role-based action protection
 */
@Composable
fun RoleBasedActionProtection(
    screenRoute: String,
    action: String,
    uiController: RoleBasedUIController,
    onAccessDenied: () -> Unit = {},
    content: @Composable () -> Unit
) {
    if (uiController.canPerformAction(screenRoute, action)) {
        content()
    } else {
        onAccessDenied()
    }
}

/**
 * ViewModel for role-based UI management
 */
class RoleBasedUIViewModel(
    initialRole: UserRole = UserRole.CLIENT
) : ViewModel() {
    
    private val uiController = RoleBasedUIController(initialRole)
    
    val userRole = uiController.userRole
    val uiState = uiController.uiState
    val visibleComponents = uiController.visibleComponents
    val enabledActions = uiController.enabledActions
    val themeColors = uiController.themeColors
    
    fun updateRole(newRole: UserRole) {
        uiController.updateRole(newRole)
    }
    
    fun refreshUI() {
        uiController.refreshUI()
    }
    
    fun clearUI() {
        uiController.clearUI()
    }
    
    @Composable
    fun getComponentVisibility(componentId: String): Boolean {
        return uiController.getComponentVisibility(componentId)
    }
    
    @Composable
    fun getActionEnabled(actionId: String): Boolean {
        return uiController.getActionEnabled(actionId)
    }
    
    @Composable
    fun getThemeColor(colorType: ThemeColorType): Color {
        return uiController.getThemeColor(colorType)
    }
    
    fun shouldShowScreen(screenRoute: String): Boolean {
        return uiController.shouldShowScreen(screenRoute)
    }
    
    fun canPerformAction(screenRoute: String, action: String): Boolean {
        return uiController.canPerformAction(screenRoute, action)
    }
    
    fun getRoleUIConfiguration(): RoleUIConfiguration {
        return uiController.getRoleUIConfiguration()
    }
}
