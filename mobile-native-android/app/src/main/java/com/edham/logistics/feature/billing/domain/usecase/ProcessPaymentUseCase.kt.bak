package com.edham.logistics.feature.billing.domain.usecase

import com.edham.logistics.core.utils.Result
import com.edham.logistics.feature.billing.domain.model.*
import com.edham.logistics.feature.billing.domain.repository.BillingRepository
import javax.inject.Inject

class ProcessPaymentUseCase @Inject constructor(
    private val billingRepository: BillingRepository
) {
    
    suspend operator fun invoke(request: ProcessPaymentRequest): Result<Payment> {
        return try {
            // Validate invoice
            val invoice = billingRepository.getInvoiceById(request.invoiceId)
            if (invoice is Result.Error) {
                return Result.Error(Exception("Invoice not found"))
            }
            
            val invoiceData = (invoice as Result.Success).data
            
            // Check if invoice is in payable status
            if (!isInvoicePayable(invoiceData.status)) {
                return Result.Error(Exception("Invoice cannot be paid in current status: ${invoiceData.status}"))
            }
            
            // Validate payment amount
            if (request.amount <= 0) {
                return Result.Error(Exception("Payment amount must be greater than zero"))
            }
            
            // Check if payment amount exceeds outstanding amount
            val outstandingAmount = calculateOutstandingAmount(invoiceData)
            if (request.amount > outstandingAmount) {
                return Result.Error(Exception("Payment amount exceeds outstanding amount"))
            }
            
            // Get payment gateway
            val gateway = billingRepository.getPaymentGateway(request.gatewayId)
            if (gateway is Result.Error) {
                return Result.Error(Exception("Payment gateway not found"))
            }
            
            val gatewayData = (gateway as Result.Success).data
            
            if (!gatewayData.isActive) {
                return Result.Error(Exception("Payment gateway is not active"))
            }
            
            if (!gatewayData.supportedMethods.contains(request.paymentMethod)) {
                return Result.Error(Exception("Payment method not supported by gateway"))
            }
            
            // Process payment through gateway
            val paymentResult = processPaymentThroughGateway(request, gatewayData)
            
            if (paymentResult is Result.Error) {
                return paymentResult
            }
            
            val gatewayResponse = (paymentResult as Result.Success).data
            
            // Create payment record
            val payment = Payment(
                id = "", // Will be generated by repository
                invoiceId = request.invoiceId,
                customerId = invoiceData.customerId,
                amount = request.amount,
                currency = invoiceData.currency,
                paymentMethod = request.paymentMethod,
                paymentStatus = PaymentStatus.PENDING,
                transactionId = generateTransactionId(),
                gatewayTransactionId = gatewayResponse.transactionId,
                paymentDate = System.currentTimeMillis(),
                processedAt = null,
                failureReason = null,
                gatewayResponse = gatewayResponse.response,
                metadata = mapOf(
                    "gatewayId" to request.gatewayId,
                    "gatewayName" to gatewayData.name,
                    "processedBy" to "system"
                ),
                createdBy = "system",
                createdAt = System.currentTimeMillis(),
                updatedAt = System.currentTimeMillis()
            )
            
            // Save payment record
            val savedPayment = billingRepository.createPayment(payment)
            
            // Update invoice status based on payment
            updateInvoiceStatusAfterPayment(invoiceData, savedPayment)
            
            // Send notifications
            sendPaymentNotifications(invoiceData, savedPayment)
            
            savedPayment
        } catch (e: Exception) {
            Result.Error(e)
        }
    }
    
    private fun isInvoicePayable(status: InvoiceStatus): Boolean {
        return status in listOf(InvoiceStatus.ISSUED, InvoiceStatus.SENT, InvoiceStatus.PARTIALLY_PAID)
    }
    
    private fun calculateOutstandingAmount(invoice: Invoice): Double {
        val totalPaid = billingRepository.getTotalPaidAmount(invoice.id)
        return if (totalPaid is Result.Success) {
            invoice.totalAmount - totalPaid.data
        } else {
            invoice.totalAmount
        }
    }
    
    private suspend fun processPaymentThroughGateway(
        request: ProcessPaymentRequest,
        gateway: PaymentGateway
    ): Result<GatewayPaymentResponse> {
        return try {
            // This would integrate with actual payment gateway SDK
            // For now, we'll simulate the process
            
            when (gateway.type) {
                PaymentGatewayType.STRIPE -> processStripePayment(request, gateway)
                PaymentGatewayType.PAYPAL -> processPayPalPayment(request, gateway)
                PaymentGatewayType.SQUARE -> processSquarePayment(request, gateway)
                PaymentGatewayType.LOCAL_BANK -> processBankTransferPayment(request, gateway)
                PaymentGatewayType.MOBILE_PAYMENT -> processMobilePayment(request, gateway)
                else -> Result.Error(Exception("Unsupported payment gateway type"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }
    
    private suspend fun processStripePayment(
        request: ProcessPaymentRequest,
        gateway: PaymentGateway
    ): Result<GatewayPaymentResponse> {
        // Simulate Stripe payment processing
        // In real implementation, this would use Stripe SDK
        
        val transactionId = "stripe_${System.currentTimeMillis()}"
        val success = simulatePaymentSuccess(request.paymentMethod)
        
        return if (success) {
            Result.Success(GatewayPaymentResponse(
                transactionId = transactionId,
                status = "success",
                response = mapOf(
                    "gateway" to "stripe",
                    "amount" to request.amount,
                    "currency" to "SAR",
                    "paymentMethod" to request.paymentMethod.name,
                    "processedAt" to System.currentTimeMillis()
                )
            ))
        } else {
            Result.Error(Exception("Stripe payment failed"))
        }
    }
    
    private suspend fun processPayPalPayment(
        request: ProcessPaymentRequest,
        gateway: PaymentGateway
    ): Result<GatewayPaymentResponse> {
        // Simulate PayPal payment processing
        val transactionId = "paypal_${System.currentTimeMillis()}"
        val success = simulatePaymentSuccess(request.paymentMethod)
        
        return if (success) {
            Result.Success(GatewayPaymentResponse(
                transactionId = transactionId,
                status = "success",
                response = mapOf(
                    "gateway" to "paypal",
                    "amount" to request.amount,
                    "currency" to "SAR",
                    "paymentMethod" to request.paymentMethod.name,
                    "processedAt" to System.currentTimeMillis()
                )
            ))
        } else {
            Result.Error(Exception("PayPal payment failed"))
        }
    }
    
    private suspend fun processSquarePayment(
        request: ProcessPaymentRequest,
        gateway: PaymentGateway
    ): Result<GatewayPaymentResponse> {
        // Simulate Square payment processing
        val transactionId = "square_${System.currentTimeMillis()}"
        val success = simulatePaymentSuccess(request.paymentMethod)
        
        return if (success) {
            Result.Success(GatewayPaymentResponse(
                transactionId = transactionId,
                status = "success",
                response = mapOf(
                    "gateway" to "square",
                    "amount" to request.amount,
                    "currency" to "SAR",
                    "paymentMethod" to request.paymentMethod.name,
                    "processedAt" to System.currentTimeMillis()
                )
            ))
        } else {
            Result.Error(Exception("Square payment failed"))
        }
    }
    
    private suspend fun processBankTransferPayment(
        request: ProcessPaymentRequest,
        gateway: PaymentGateway
    ): Result<GatewayPaymentResponse> {
        // Bank transfers are processed differently - they create a pending record
        val transactionId = "bank_${System.currentTimeMillis()}"
        
        return Result.Success(GatewayPaymentResponse(
            transactionId = transactionId,
            status = "pending",
            response = mapOf(
                "gateway" to "bank_transfer",
                "amount" to request.amount,
                "currency" to "SAR",
                "paymentMethod" to request.paymentMethod.name,
                "initiatedAt" to System.currentTimeMillis(),
                "expectedSettlement" to System.currentTimeMillis() + (2 * 24 * 60 * 60 * 1000) // 2 days
            )
        ))
    }
    
    private suspend fun processMobilePayment(
        request: ProcessPaymentRequest,
        gateway: PaymentGateway
    ): Result<GatewayPaymentResponse> {
        // Simulate mobile payment processing
        val transactionId = "mobile_${System.currentTimeMillis()}"
        val success = simulatePaymentSuccess(request.paymentMethod)
        
        return if (success) {
            Result.Success(GatewayPaymentResponse(
                transactionId = transactionId,
                status = "success",
                response = mapOf(
                    "gateway" to "mobile_payment",
                    "amount" to request.amount,
                    "currency" to "SAR",
                    "paymentMethod" to request.paymentMethod.name,
                    "processedAt" to System.currentTimeMillis()
                )
            ))
        } else {
            Result.Error(Exception("Mobile payment failed"))
        }
    }
    
    private fun simulatePaymentSuccess(paymentMethod: PaymentMethod): Boolean {
        // Simulate payment success rate based on payment method
        return when (paymentMethod) {
            PaymentMethod.CREDIT_CARD -> 0.95 // 95% success rate
            PaymentMethod.DEBIT_CARD -> 0.93 // 93% success rate
            PaymentMethod.BANK_TRANSFER -> 0.98 // 98% success rate
            PaymentMethod.CASH -> 1.0 // 100% success rate (cash is always successful)
            PaymentMethod.CHECK -> 0.90 // 90% success rate
            PaymentMethod.ONLINE_PAYMENT -> 0.94 // 94% success rate
            PaymentMethod.MOBILE_WALLET -> 0.96 // 96% success rate
            PaymentMethod.CRYPTOCURRENCY -> 0.85 // 85% success rate
        }
    }
    
    private suspend fun updateInvoiceStatusAfterPayment(invoice: Invoice, payment: Payment) {
        val totalPaid = billingRepository.getTotalPaidAmount(invoice.id)
        if (totalPaid is Result.Success) {
            val outstandingAmount = invoice.totalAmount - totalPaid.data
            
            val newStatus = when {
                outstandingAmount <= 0 -> InvoiceStatus.PAID
                totalPaid.data > 0 -> InvoiceStatus.PARTIALLY_PAID
                else -> invoice.status
            }
            
            if (newStatus != invoice.status) {
                billingRepository.updateInvoiceStatus(invoice.id, newStatus)
                
                // Update payment status
                val updatedPayment = payment.copy(
                    paymentStatus = PaymentStatus.COMPLETED,
                    processedAt = System.currentTimeMillis()
                )
                billingRepository.updatePayment(updatedPayment)
            }
        }
    }
    
    private suspend fun sendPaymentNotifications(invoice: Invoice, payment: Payment) {
        // Send email notification to customer
        billingRepository.sendInvoiceEmail(
            invoiceId = invoice.id,
            templateType = EmailTemplateType.PAYMENT_RECEIVED,
            customerEmail = invoice.customerEmail
        )
        
        // Send SMS notification if enabled
        billingRepository.sendInvoiceSms(
            invoiceId = invoice.id,
            templateType = SmsTemplateType.PAYMENT_RECEIVED,
            customerPhone = invoice.customerPhone
        )
        
        // Send notification to accountant
        billingRepository.sendBillingNotification(
            type = BillingWebSocketType.PAYMENT_RECEIVED,
            data = mapOf(
                "invoiceId" to invoice.id,
                "invoiceNumber" to invoice.invoiceNumber,
                "paymentId" to payment.id,
                "amount" to payment.amount,
                "customerId" to invoice.customerId,
                "customerName" to invoice.customerName
            )
        )
    }
    
    private fun generateTransactionId(): String {
        return "txn_${System.currentTimeMillis()}_${(1000..9999).random()}"
    }
}

// Helper data class for gateway response
data class GatewayPaymentResponse(
    val transactionId: String,
    val status: String,
    val response: Map<String, Any>
)
