package com.edham.logistics.feature.driver

import android.os.Bundle
import androidx.fragment.app.Fragment
import androidx.recyclerview.widget.LinearLayoutManager
import com.edham.logistics.R
import com.edham.logistics.databinding.FragmentTripHistoryBinding
import com.edham.logistics.feature.driver.adapters.TripHistoryAdapter
import com.edham.logistics.utils.VoiceAlertManager
import timber.log.Timber
import java.text.SimpleDateFormat
import java.util.*

class TripHistoryFragment : Fragment() {
    
    private var _binding: FragmentTripHistoryBinding? = null
    private val binding get() = _binding!!
    
    private lateinit var voiceAlertManager: VoiceAlertManager
    private lateinit var tripHistoryAdapter: TripHistoryAdapter
    private var tripHistoryList = mutableListOf<TripHistoryItem>()
    private val dateFormat = SimpleDateFormat("MMM dd, yyyy HH:mm", Locale.getDefault())
    private val durationFormat = SimpleDateFormat("HH:mm", Locale.getDefault())
    
    override fun onCreateView(
        inflater: android.view.LayoutInflater,
        container: android.view.ViewGroup?,
        savedInstanceState: Bundle?
    ): android.view.View {
        _binding = FragmentTripHistoryBinding.inflate(inflater, container, false)
        return binding.root
    }
    
    override fun onViewCreated(view: android.view.View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        
        voiceAlertManager = VoiceAlertManager(requireContext())
        setupUI()
        setupRecyclerView()
        setupClickListeners()
        loadTripHistory()
        
        voiceAlertManager.speak("Trip history screen opened")
    }
    
    private fun setupUI() {
        // Large touch targets for one-hand usage
        binding.btnFilter.minimumHeight = 72.dp
        binding.btnFilter.minimumWidth = 120.dp
        
        binding.btnSearch.minimumHeight = 72.dp
        binding.btnSearch.minimumWidth = 120.dp
        
        binding.btnExport.minimumHeight = 72.dp
        binding.btnExport.minimumWidth = 120.dp
        
        // Dark mode optimized colors
        binding.cardHistoryStats.setCardBackgroundColor(
            requireContext().getColor(R.color.dark_surface)
        )
        
        // High visibility status colors
        binding.viewStatusIndicator.setBackgroundColor(
            requireContext().getColor(R.color.status_active)
        )
        
        // Setup filter spinner
        val filterOptions = arrayOf("All Trips", "Completed", "Cancelled", "This Week", "This Month")
        // Implementation would setup spinner with these options
    }
    
    private fun setupRecyclerView() {
        tripHistoryAdapter = TripHistoryAdapter(tripHistoryList) { trip ->
            onTripClicked(trip)
        }
        
        binding.recyclerViewTripHistory.apply {
            layoutManager = LinearLayoutManager(requireContext())
            adapter = tripHistoryAdapter
        }
    }
    
    private fun setupClickListeners() {
        binding.btnFilter.setOnClickListener {
            showFilterDialog()
        }
        
        binding.btnSearch.setOnClickListener {
            searchTrips()
        }
        
        binding.btnExport.setOnClickListener {
            exportTripHistory()
        }
        
        binding.etSearch.setOnEditorActionListener { _, actionId, _ ->
            if (actionId == android.view.inputmethod.EditorInfo.IME_ACTION_SEARCH) {
                searchTrips()
                true
            } else {
                false
            }
        }
    }
    
    private fun loadTripHistory() {
        // Load trip history from API or local database
        // For now, simulate with sample data
        loadSampleTripHistory()
        updateHistoryStats()
    }
    
    private fun loadSampleTripHistory() {
        val sampleTrips = listOf(
            TripHistoryItem(
                id = "trip_001",
                date = System.currentTimeMillis() - 86400000, // Yesterday
                startTime = System.currentTimeMillis() - 86400000 - 7200000, // 2 hours before
                endTime = System.currentTimeMillis() - 86400000 - 1800000, // 30 min after start
                origin = "Warehouse A",
                destination = "123 Main St, Downtown",
                distance = 15.2,
                duration = 5400000, // 90 minutes in milliseconds
                status = "COMPLETED",
                earnings = 45.50,
                fuelUsed = 2.8,
                customerName = "John Smith",
                customerRating = 5.0,
                notes = "Smooth delivery, customer satisfied"
            ),
            TripHistoryItem(
                id = "trip_002",
                date = System.currentTimeMillis() - 172800000, // 2 days ago
                startTime = System.currentTimeMillis() - 172800000 - 5400000, // 1.5 hours before
                endTime = System.currentTimeMillis() - 172800000 - 900000, // 15 min after start
                origin = "Warehouse B",
                destination = "456 Oak Ave, Suburbs",
                distance = 22.8,
                duration = 4500000, // 75 minutes
                status = "COMPLETED",
                earnings = 62.75,
                fuelUsed = 4.1,
                customerName = "Sarah Johnson",
                customerRating = 4.0,
                notes = "Traffic delays but arrived on time"
            ),
            TripHistoryItem(
                id = "trip_003",
                date = System.currentTimeMillis() - 259200000, // 3 days ago
                startTime = System.currentTimeMillis() - 259200000 - 3600000, // 1 hour before
                endTime = System.currentTimeMillis() - 259200000 + 1800000, // 30 min after scheduled end
                origin = "Warehouse A",
                destination = "789 Pine St, Industrial Area",
                distance = 18.5,
                duration = 5400000, // 90 minutes
                status = "CANCELLED",
                earnings = 0.0,
                fuelUsed = 0.0,
                customerName = "Mike Wilson",
                customerRating = 0.0,
                notes = "Customer cancelled order"
            ),
            TripHistoryItem(
                id = "trip_004",
                date = System.currentTimeMillis() - 345600000, // 4 days ago
                startTime = System.currentTimeMillis() - 345600000 - 6300000, // 1.75 hours before
                endTime = System.currentTimeMillis() - 345600000 - 900000, // 15 min after start
                origin = "Warehouse C",
                destination = "321 Elm St, City Center",
                distance = 12.3,
                duration = 5400000, // 90 minutes
                status = "COMPLETED",
                earnings = 38.25,
                fuelUsed = 2.2,
                customerName = "Emily Brown",
                customerRating = 5.0,
                notes = "Express delivery, excellent service"
            ),
            TripHistoryItem(
                id = "trip_005",
                date = System.currentTimeMillis() - 432000000, // 5 days ago
                startTime = System.currentTimeMillis() - 432000000 - 5400000, // 1.5 hours before
                endTime = System.currentTimeMillis() - 432000000 - 600000, // 10 min after start
                origin = "Warehouse A",
                destination = "654 Maple Dr, Residential",
                distance = 8.7,
                duration = 4800000, // 80 minutes
                status = "COMPLETED",
                earnings = 28.90,
                fuelUsed = 1.6,
                customerName = "David Lee",
                customerRating = 4.5,
                notes = "Good delivery, customer tipped"
            )
        )
        
        tripHistoryList.addAll(sampleTrips)
        tripHistoryAdapter.notifyDataSetChanged()
    }
    
    private fun updateHistoryStats() {
        val completedTrips = tripHistoryList.count { it.status == "COMPLETED" }
        val cancelledTrips = tripHistoryList.count { it.status == "CANCELLED" }
        val totalDistance = tripHistoryList.filter { it.status == "COMPLETED" }.sumOf { it.distance }
        val totalEarnings = tripHistoryList.filter { it.status == "COMPLETED" }.sumOf { it.earnings }
        val avgRating = tripHistoryList.filter { it.status == "COMPLETED" && it.customerRating > 0 }
            .map { it.customerRating }.average()
        
        // Update statistics
        binding.tvTotalTrips.text = tripHistoryList.size.toString()
        binding.tvCompletedTrips.text = completedTrips.toString()
        binding.tvCancelledTrips.text = cancelledTrips.toString()
        binding.tvTotalDistance.text = String.format("%.1f km", totalDistance)
        binding.tvTotalEarnings.text = String.format("$%.2f", totalEarnings)
        binding.tvAverageRating.text = if (avgRating.isNaN()) "N/A" else String.format("%.1f ⭐", avgRating)
        
        // Calculate completion rate
        val completionRate = if (tripHistoryList.isNotEmpty()) {
            (completedTrips.toDouble() / tripHistoryList.size) * 100
        } else 0.0
        binding.tvCompletionRate.text = String.format("%.1f%%", completionRate)
    }
    
    private fun onTripClicked(trip: TripHistoryItem) {
        // Navigate to trip details
        voiceAlertManager.speak("Opening trip details")
        
        // Implementation would navigate to trip details screen
        showTripDetailsDialog(trip)
    }
    
    private fun showTripDetailsDialog(trip: TripHistoryItem) {
        // Show trip details in a dialog or navigate to details screen
        val details = """
            Trip ID: ${trip.id}
            Date: ${dateFormat.format(Date(trip.date))}
            Time: ${durationFormat.format(Date(trip.startTime))} - ${durationFormat.format(Date(trip.endTime))}
            Route: ${trip.origin} → ${trip.destination}
            Distance: ${trip.distance} km
            Duration: ${trip.duration / 60000} minutes
            Status: ${trip.status}
            Earnings: $${trip.earnings}
            Customer: ${trip.customerName}
            Rating: ${trip.customerRating} ⭐
            Notes: ${trip.notes}
        """.trimIndent()
        
        // Implementation would show this in a dialog
        Toast.makeText(requireContext(), "Trip details: ${trip.id}", Toast.LENGTH_LONG).show()
    }
    
    private fun showFilterDialog() {
        // Show filter options dialog
        voiceAlertManager.speak("Filter options")
        
        // Implementation would show filter dialog with options:
        // - Date range
        // - Status filter
        // - Earnings range
        // - Distance range
        // - Customer rating
    }
    
    private fun searchTrips() {
        val query = binding.etSearch.text.toString().trim()
        
        if (query.isBlank()) {
            // Show all trips
            loadTripHistory()
            return
        }
        
        // Filter trips based on search query
        val filteredTrips = tripHistoryList.filter { trip ->
            trip.destination.contains(query, ignoreCase = true) ||
            trip.customerName.contains(query, ignoreCase = true) ||
            trip.origin.contains(query, ignoreCase = true) ||
            trip.id.contains(query, ignoreCase = true) ||
            trip.notes.contains(query, ignoreCase = true)
        }
        
        // Update adapter with filtered results
        tripHistoryList.clear()
        tripHistoryList.addAll(filteredTrips)
        tripHistoryAdapter.notifyDataSetChanged()
        
        // Update search results count
        binding.tvSearchResults.text = "${filteredTrips.size} results found"
        
        voiceAlertManager.speak("Found ${filteredTrips.size} matching trips")
    }
    
    private fun exportTripHistory() {
        // Export trip history to PDF or Excel
        voiceAlertManager.speak("Exporting trip history")
        
        // Implementation would generate and share trip history report
        Toast.makeText(requireContext(), "Trip history exported", Toast.LENGTH_SHORT).show()
    }
    
    private fun refreshTripHistory() {
        // Refresh trip history from server
        voiceAlertManager.speak("Refreshing trip history")
        
        // Implementation would reload data from API
        loadTripHistory()
    }
    
    private fun sortByDate() {
        // Sort trips by date (newest first)
        tripHistoryList.sortByDescending { it.date }
        tripHistoryAdapter.notifyDataSetChanged()
        
        voiceAlertManager.speak("Sorted by date")
    }
    
    private fun sortByEarnings() {
        // Sort trips by earnings (highest first)
        tripHistoryList.sortByDescending { it.earnings }
        tripHistoryAdapter.notifyDataSetChanged()
        
        voiceAlertManager.speak("Sorted by earnings")
    }
    
    private fun sortByDistance() {
        // Sort trips by distance (longest first)
        tripHistoryList.sortByDescending { it.distance }
        tripHistoryAdapter.notifyDataSetChanged()
        
        voiceAlertManager.speak("Sorted by distance")
    }
    
    override fun onResume() {
        super.onResume()
        
        // Refresh data when fragment resumes
        refreshTripHistory()
    }
    
    override fun onDestroyView() {
        super.onDestroyView()
        
        voiceAlertManager.cleanup()
        _binding = null
    }
    
    // Extension for dp to pixels
    private val Int.dp: Int
        get() = (this * resources.displayMetrics.density).toInt()
}

data class TripHistoryItem(
    val id: String,
    val date: Long,
    val startTime: Long,
    val endTime: Long,
    val origin: String,
    val destination: String,
    val distance: Double,
    val duration: Long, // in milliseconds
    val status: String, // COMPLETED, CANCELLED, IN_PROGRESS
    val earnings: Double,
    val fuelUsed: Double,
    val customerName: String,
    val customerRating: Double,
    val notes: String
)
