package com.edham.logistics.feature.notifications.domain.usecase

import com.edham.logistics.core.utils.Result
import com.edham.logistics.feature.notifications.domain.model.SendBulkNotificationRequest
import com.edham.logistics.feature.notifications.domain.repository.NotificationRepository
import javax.inject.Inject

class SendBulkNotificationUseCase @Inject constructor(
    private val notificationRepository: NotificationRepository
) {
    
    suspend operator fun invoke(request: SendBulkNotificationRequest): Result<List<String>> {
        return notificationRepository.sendBulkNotification(request)
    }
}
