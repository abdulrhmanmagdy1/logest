package com.edham.logistics.core.auth

import android.app.Dialog
import android.content.Context
import android.os.Bundle
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import androidx.fragment.app.DialogFragment
import com.edham.logistics.databinding.DialogSessionExpiredBinding
import dagger.hilt.android.AndroidEntryPoint
import javax.inject.Inject

/**
 * Session Expired Dialog
 * Shows user-friendly dialog for session expiration scenarios
 * Provides options to retry login or logout
 */
@AndroidEntryPoint
class SessionExpiredDialog : DialogFragment() {
    
    @Inject
    lateinit var sessionExpiredHandler: SessionExpiredHandler
    
    private var _binding: DialogSessionExpiredBinding? = null
    private val binding get() = _binding!!
    
    private var message: String = ""
    private var canRetry: Boolean = false
    
    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        
        // Get arguments
        arguments?.let { args ->
            message = args.getString(ARG_MESSAGE, "Session expired. Please login again.")
            canRetry = args.getBoolean(ARG_CAN_RETRY, false)
        }
        
        // Set dialog style
        setStyle(STYLE_NORMAL, android.R.style.Theme_Material_Light_Dialog_Alert)
    }
    
    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View {
        _binding = DialogSessionExpiredBinding.inflate(inflater, container, false)
        return binding.root
    }
    
    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        
        setupUI()
        setupClickListeners()
    }
    
    override fun onCreateDialog(savedInstanceState: Bundle?): Dialog {
        val dialog = super.onCreateDialog(savedInstanceState)
        
        // Make dialog non-cancelable
        dialog.setCancelable(false)
        dialog.setCanceledOnTouchOutside(false)
        
        return dialog
    }
    
    private fun setupUI() {
        binding.textViewMessage.text = message
        
        // Show/hide retry button based on canRetry
        binding.buttonRetry.visibility = if (canRetry) View.VISIBLE else View.GONE
        
        // Set dialog title
        dialog?.setTitle("Session Expired")
    }
    
    private fun setupClickListeners() {
        binding.buttonRetry.setOnClickListener {
            sessionExpiredHandler.retryLogin()
            dismiss()
        }
        
        binding.buttonLogout.setOnClickListener {
            sessionExpiredHandler.logout()
            dismiss()
        }
        
        binding.buttonDismiss.setOnClickListener {
            sessionExpiredHandler.dismissExpiredMessage()
            dismiss()
        }
    }
    
    override fun onDestroyView() {
        super.onDestroyView()
        _binding = null
    }
    
    companion object {
        private const val ARG_MESSAGE = "message"
        private const val ARG_CAN_RETRY = "can_retry"
        
        fun newInstance(message: String, canRetry: Boolean): SessionExpiredDialog {
            val dialog = SessionExpiredDialog()
            val args = Bundle().apply {
                putString(ARG_MESSAGE, message)
                putBoolean(ARG_CAN_RETRY, canRetry)
            }
            dialog.arguments = args
            return dialog
        }
    }
}
