    override suspend fun observeVehicleTracking(vehicleId: String): Flow<Result<VehicleTracking>> {
        return flow {
            try {
                trackingWebSocketService.messageFlow.collect { message ->
                    if (message.vehicleId == vehicleId) {
                        when (message.type) {
                            TrackingMessageType.LOCATION_UPDATE,
                            TrackingMessageType.STATUS_CHANGE -> {
                                val response = trackingApiService.getVehicleTracking(vehicleId)
                                if (response.isSuccessful) {
                                    response.body()?.let { vehicleTracking ->
