    override suspend fun getFleetTracking(request: GetFleetTrackingRequest): Result<FleetTracking> {
        return try {
            val response = trackingApiService.getFleetTracking(request)
            if (response.isSuccessful) {
                response.body()?.let { fleetTracking ->
                    Result.Success(fleetTracking)
                } ?: Result.Error(Exception("Empty response"))
            } else {
                Result.Error(Exception("Failed to get fleet tracking: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun observeFleetTracking(): Flow<Result<FleetTracking>> {
        return flow {
            try {
                trackingWebSocketService.messageFlow.collect { message ->
                    when (message.type) {
                        TrackingMessageType.LOCATION_UPDATE,
                        TrackingMessageType.STATUS_CHANGE -> {
                            // Refresh fleet data
                            val response = trackingApiService.getFleetTracking(
                                GetFleetTrackingRequest(
                                    vehicleIds = null,
                                    driverIds = null,
                                    activeOnly = true
                                )
                            )
                            if (response.isSuccessful) {
                                response.body()?.let { fleetTracking ->
                                    emit(Result.Success(fleetTracking))
                                }
                            }
                        }
                        else -> {}
                    }
                }
            } catch (e: Exception) {
                emit(Result.Error(e))
            }
        }
    }

