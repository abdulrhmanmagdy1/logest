package com.edham.logistics.feature.tracking.data.repository

import com.edham.logistics.core.utils.Result
import com.edham.logistics.core.utils.TokenManager
import com.edham.logistics.feature.tracking.data.api.TrackingApiService
import com.edham.logistics.feature.tracking.data.database.TrackingDatabase
import com.edham.logistics.feature.tracking.data.service.TrackingWebSocketService
import com.edham.logistics.feature.tracking.domain.model.*
import com.edham.logistics.feature.tracking.domain.repository.TrackingRepository
import com.google.android.gms.maps.model.LatLng
import kotlinx.coroutines.flow.Flow
import kotlinx.coroutines.flow.flow
import kotlinx.coroutines.flow.map
import javax.inject.Inject
import javax.inject.Singleton

@Singleton
class TrackingRepositoryImpl @Inject constructor(
    private val trackingApiService: TrackingApiService,
    private val trackingDatabase: TrackingDatabase,
    private val trackingWebSocketService: TrackingWebSocketService,
    private val tokenManager: TokenManager
) : TrackingRepository {

    override suspend fun startTracking(request: StartTrackingRequest): Result<ShipmentTracking> {
        return try {
            val response = trackingApiService.startTracking(request)
            if (response.isSuccessful) {
                response.body()?.let { tracking ->
                    // Save to local database
                    trackingDatabase.trackingDao().insertTracking(tracking.toEntity())
                    Result.Success(tracking)
                } ?: Result.Error(Exception("Empty response"))
            } else {
                Result.Error(Exception("Failed to start tracking: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun stopTracking(shipmentId: String): Result<Unit> {
        return try {
            val response = trackingApiService.stopTracking(shipmentId)
            if (response.isSuccessful) {
                // Update local database
                trackingDatabase.trackingDao().updateTrackingStatus(
                    shipmentId,
                    TrackingStatus.DELIVERED.name
                )
                Result.Success(Unit)
            } else {
                Result.Error(Exception("Failed to stop tracking: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun pauseTracking(shipmentId: String): Result<Unit> {
        return try {
            val response = trackingApiService.pauseTracking(shipmentId)
            if (response.isSuccessful) {
                trackingDatabase.trackingDao().updateTrackingStatus(
                    shipmentId,
                    TrackingStatus.DELAYED.name
                )
                Result.Success(Unit)
            } else {
                Result.Error(Exception("Failed to pause tracking: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun resumeTracking(shipmentId: String): Result<Unit> {
        return try {
            val response = trackingApiService.resumeTracking(shipmentId)
            if (response.isSuccessful) {
                trackingDatabase.trackingDao().updateTrackingStatus(
                    shipmentId,
                    TrackingStatus.EN_ROUTE_TO_DESTINATION.name
                )
                Result.Success(Unit)
            } else {
                Result.Error(Exception("Failed to resume tracking: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun updateLocation(request: UpdateLocationRequest): Result<LocationUpdate> {
        return try {
            val response = trackingApiService.updateLocation(request)
            if (response.isSuccessful) {
                response.body()?.let { locationUpdate ->
                    // Save to local database
                    trackingDatabase.trackingDao().insertLocationUpdate(locationUpdate.toEntity())
                    Result.Success(locationUpdate)
                } ?: Result.Error(Exception("Empty response"))
            } else {
                Result.Error(Exception("Failed to update location: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun batchUpdateLocations(requests: List<UpdateLocationRequest>): Result<List<LocationUpdate>> {
        return try {
            val response = trackingApiService.batchUpdateLocations(requests)
            if (response.isSuccessful) {
                response.body()?.let { updates ->
                    // Save to local database
                    updates.forEach { update ->
                        trackingDatabase.trackingDao().insertLocationUpdate(update.toEntity())
                    }
                    Result.Success(updates)
                } ?: Result.Error(Exception("Empty response"))
            } else {
                Result.Error(Exception("Failed to batch update locations: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun getShipmentTracking(shipmentId: String): Result<ShipmentTracking> {
        return try {
            // Try local database first
            val localTracking = trackingDatabase.trackingDao().getTrackingByShipmentId(shipmentId)
            if (localTracking != null) {
                return Result.Success(localTracking.toDomainModel())
            }

            // Fetch from API if not in local database
            val response = trackingApiService.getShipmentTracking(shipmentId)
            if (response.isSuccessful) {
                response.body()?.let { tracking ->
                    // Save to local database
                    trackingDatabase.trackingDao().insertTracking(tracking.toEntity())
                    Result.Success(tracking)
                } ?: Result.Error(Exception("Empty response"))
            } else {
                Result.Error(Exception("Failed to get shipment tracking: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun observeShipmentTracking(shipmentId: String): Flow<Result<ShipmentTracking>> {
        return flow {
            try {
                // Emit local data first
                val localTracking = trackingDatabase.trackingDao().getTrackingByShipmentId(shipmentId)
                if (localTracking != null) {
                    emit(Result.Success(localTracking.toDomainModel()))
                }

                // Listen for WebSocket updates
                trackingWebSocketService.messageFlow.collect { message ->
                    if (message.shipmentId == shipmentId) {
                        when (message.type) {
                            TrackingMessageType.LOCATION_UPDATE,
                            TrackingMessageType.STATUS_CHANGE,
                            TrackingMessageType.ETA_UPDATE -> {
                                // Refresh local data
                                val updatedTracking = trackingDatabase.trackingDao().getTrackingByShipmentId(shipmentId)
                                updatedTracking?.let {
                                    emit(Result.Success(it.toDomainModel()))
                                }
                            }
                            else -> {}
                        }
                    }
                }
            } catch (e: Exception) {
                emit(Result.Error(e))
            }
        }
    }

    override suspend fun getCustomerTracking(customerId: String): Result<List<ShipmentTracking>> {
        return try {
            val response = trackingApiService.getCustomerTracking(customerId)
            if (response.isSuccessful) {
                response.body()?.let { trackings ->
