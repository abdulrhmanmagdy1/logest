            val response = trackingApiService.calculateETA(
                currentLocation,
                destinationLocation,
                currentSpeed,
                trafficData
            )
            if (response.isSuccessful) {
                response.body()?.let { eta ->
                    Result.Success(eta)
                } ?: Result.Error(Exception("Empty response"))
            } else {
                Result.Error(Exception("Failed to calculate ETA: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

