    override suspend fun connectToTrackingWebSocket(): Result<Unit> {
        return try {
            val token = tokenManager.getAccessToken()
            if (token != null) {
                trackingWebSocketService.connect(token)
                Result.Success(Unit)
            } else {
                Result.Error(Exception("No access token available"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun disconnectFromTrackingWebSocket(): Result<Unit> {
        return try {
            trackingWebSocketService.disconnect()
