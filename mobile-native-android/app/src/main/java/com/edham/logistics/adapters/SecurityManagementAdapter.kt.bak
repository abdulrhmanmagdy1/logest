package com.edham.logistics.adapters

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.ImageView
import android.widget.TextView
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.domain.model.SecuritySetting

class SecurityManagementAdapter(
    private var securitySettings: List<SecuritySetting>,
    private val onSettingClick: (SecuritySetting) -> Unit
) : RecyclerView.Adapter<SecurityManagementAdapter.SecurityViewHolder>() {

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): SecurityViewHolder {
        val view = LayoutInflater.from(parent.context)
            .inflate(R.layout.item_security_management, parent, false)
        return SecurityViewHolder(view)
    }

    override fun onBindViewHolder(holder: SecurityViewHolder, position: Int) {
        holder.bind(securitySettings[position])
    }

    override fun getItemCount(): Int = securitySettings.size

    fun updateSecuritySettings(newSecuritySettings: List<SecuritySetting>) {
        securitySettings = newSecuritySettings
        notifyDataSetChanged()
    }

    inner class SecurityViewHolder(itemView: View) : RecyclerView.ViewHolder(itemView) {
        private val tvSettingTitle: TextView = itemView.findViewById(R.id.tvSettingTitle)
        private val tvSettingDescription: TextView = itemView.findViewById(R.id.tvSettingDescription)
        private val tvCategory: TextView = itemView.findViewById(R.id.tvCategory)
        private val ivSecurityIcon: ImageView = itemView.findViewById(R.id.ivSecurityIcon)

        fun bind(setting: SecuritySetting) {
            tvSettingTitle.text = setting.title
            tvSettingDescription.text = setting.description
            tvCategory.text = setting.category

            // Set icon based on setting type
            when (setting.type) {
                "password" -> {
                    ivSecurityIcon.setImageResource(R.drawable.ic_lock)
                    ivSecurityIcon.setColorFilter(itemView.context.getColor(R.color.supervisor_primary))
                }
                "2fa" -> {
                    ivSecurityIcon.setImageResource(R.drawable.ic_security)
                    ivSecurityIcon.setColorFilter(itemView.context.getColor(R.color.supervisor_success))
                }
                "biometric" -> {
                    ivSecurityIcon.setImageResource(R.drawable.ic_fingerprint)
                    ivSecurityIcon.setColorFilter(itemView.context.getColor(R.color.supervisor_info))
                }
                "login_history" -> {
                    ivSecurityIcon.setImageResource(R.drawable.ic_history)
                    ivSecurityIcon.setColorFilter(itemView.context.getColor(R.color.supervisor_warning))
                }
                "trusted_devices" -> {
                    ivSecurityIcon.setImageResource(R.drawable.ic_devices)
                    ivSecurityIcon.setColorFilter(itemView.context.getColor(R.color.supervisor_accent))
                }
                "security_notifications" -> {
                    ivSecurityIcon.setImageResource(R.drawable.ic_notifications)
                    ivSecurityIcon.setColorFilter(itemView.context.getColor(R.color.supervisor_primary))
                }
                "backup" -> {
                    ivSecurityIcon.setImageResource(R.drawable.ic_backup)
                    ivSecurityIcon.setColorFilter(itemView.context.getColor(R.color.supervisor_secondary))
                }
                "encryption" -> {
                    ivSecurityIcon.setImageResource(R.drawable.ic_enhanced_encryption)
                    ivSecurityIcon.setColorFilter(itemView.context.getColor(R.color.supervisor_error))
                }
                else -> {
                    ivSecurityIcon.setImageResource(R.drawable.ic_security)
                    ivSecurityIcon.setColorFilter(itemView.context.getColor(R.color.text_secondary))
                }
            }

            itemView.setOnClickListener {
                onSettingClick(setting)
            }
        }
    }
}
