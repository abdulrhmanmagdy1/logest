package com.edham.logistics.feature.customer.presentation.adapter

import android.view.LayoutInflater
import android.view.ViewGroup
import androidx.recyclerview.widget.DiffUtil
import androidx.recyclerview.widget.ListAdapter
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.databinding.ItemCargoTypeBinding
import com.edham.logistics.feature.customer.domain.model.CargoType
import javax.inject.Inject

class CargoTypeAdapter @Inject constructor(
    private val onCargoTypeSelected: (CargoType) -> Unit
) : ListAdapter<CargoType, CargoTypeAdapter.CargoTypeViewHolder>(CargoTypeDiffCallback()) {

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): CargoTypeViewHolder {
        val binding = ItemCargoTypeBinding.inflate(
            LayoutInflater.from(parent.context),
            parent,
            false
        )
        return CargoTypeViewHolder(binding)
    }

    override fun onBindViewHolder(holder: CargoTypeViewHolder, position: Int) {
        holder.bind(getItem(position))
    }

    fun setSelectedItem(selectedCargoType: CargoType?) {
        val currentSelected = currentList.indexOfFirstOrNull { it.id == selectedCargoType?.id }
        if (currentSelected != -1) {
            notifyItemChanged(currentSelected)
        }
    }

    inner class CargoTypeViewHolder(
        private val binding: ItemCargoTypeBinding
    ) : RecyclerView.ViewHolder(binding.root) {

        fun bind(cargoType: CargoType) {
            binding.apply {
                textCargoTypeName.text = cargoType.displayName
                textPricePerKg.text = "${cargoType.pricePerKg} ريال/كجم"
                textMaxWeight.text = "الحد الأقصى: ${cargoType.maxWeight} كجم"
                
                // Set icon
                imageCargoTypeIcon.setImageResource(
                    when (cargoType.id) {
                        "general" -> com.edham.logistics.R.drawable.ic_cargo_general
                        "refrigerated" -> com.edham.logistics.R.drawable.ic_cargo_refrigerated
                        "fragile" -> com.edham.logistics.R.drawable.ic_cargo_fragile
                        "heavy" -> com.edham.logistics.R.drawable.ic_cargo_heavy
                        "urgent" -> com.edham.logistics.R.drawable.ic_cargo_urgent
                        "documents" -> com.edham.logistics.R.drawable.ic_cargo_documents
                        "electronics" -> com.edham.logistics.R.drawable.ic_cargo_electronics
                        "food" -> com.edham.logistics.R.drawable.ic_cargo_food
                        "medical" -> com.edham.logistics.R.drawable.ic_cargo_medical
                        "chemicals" -> com.edham.logistics.R.drawable.ic_cargo_chemicals
                        "livestock" -> com.edham.logistics.R.drawable.ic_cargo_livestock
                        "vehicles" -> com.edham.logistics.R.drawable.ic_cargo_vehicles
                        else -> com.edham.logistics.R.drawable.ic_cargo_general
                    }
                )
                
                // Show temperature badge if required
                if (cargoType.requiresTemperature) {
                    textTemperatureBadge.visible()
                    textTemperatureBadge.text = "مبرد"
                    textTemperatureBadge.setBackgroundColor(
                        android.graphics.Color.parseColor("#2196F3")
                    )
                } else {
                    textTemperatureBadge.gone()
                }
                
                // Set selected state
                val isSelected = adapterPosition != RecyclerView.NO_POSITION && 
                    currentList[adapterPosition].id == cargoType.id
                
                if (isSelected) {
                    cardCargoType.setCardBackgroundColor(
                        android.graphics.Color.parseColor("#E3F2FD")
                    )
                    textCargoTypeName.setTextColor(
                        android.graphics.Color.parseColor("#1976D2")
                    )
                } else {
                    cardCargoType.setCardBackgroundColor(
                        android.graphics.Color.parseColor("#FFFFFF")
                    )
                    textCargoTypeName.setTextColor(
                        android.graphics.Color.parseColor("#000000")
                    )
                }
                
                root.setOnClickListener {
                    onCargoTypeSelected(cargoType)
                    notifyDataSetChanged()
                }
            }
        }
    }

    private class CargoTypeDiffCallback : DiffUtil.ItemCallback<CargoType>() {
        override fun areItemsTheSame(oldItem: CargoType, newItem: CargoType): Boolean {
            return oldItem.id == newItem.id
        }

        override fun areContentsTheSame(oldItem: CargoType, newItem: CargoType): Boolean {
            return oldItem == newItem
        }
    }
}
