    /**
     * Update notification preferences
     */
    suspend fun updateNotificationPreferences(
        preferences: NotificationPreferences
    ): Result<Boolean> {
        return withContext(Dispatchers.IO) {
            try {
                // Validate preferences
                validateNotificationPreferences(preferences)
                
                // Save preferences to database
                database.notificationPreferenceDao().updatePreferences(preferences.toEntity())
                
                // Update state
                _notificationPreferences.value = preferences
                
                // Notify listeners
                notifyPreferencesUpdated(preferences)
                
                Result.success(true)
                
            } catch (e: Exception) {
                Result.failure(e)
            }
        }
    }
    
    /**
     * Mark notification as read
     */
    suspend fun markNotificationAsRead(
        notificationId: Long
    ): Result<Boolean> {
        return withContext(Dispatchers.IO) {
            try {
                // Update notification in database
                database.notificationDao().markAsRead(notificationId)
                
                // Update notification center
                updateNotificationCenterReadStatus(notificationId)
                
                // Notify listeners
                notifyNotificationRead(notificationId)
                
                Result.success(true)
                
            } catch (e: Exception) {
                Result.failure(e)
            }
        }
    }
    
    /**
     * Mark all notifications as read
     */
    suspend fun markAllNotificationsAsRead(): Result<Boolean> {
        return withContext(Dispatchers.IO) {
            try {
                // Update all notifications in database
                database.notificationDao().markAllAsRead()
                
                // Update notification center
                updateAllNotificationsReadStatus()
                
                // Notify listeners
                notifyAllNotificationsRead()
                
                Result.success(true)
                
            } catch (e: Exception) {
                Result.failure(e)
            }
        }
    }
    
    /**
     * Delete notification
     */
    suspend fun deleteNotification(
        notificationId: Long
    ): Result<Boolean> {
        return withContext(Dispatchers.IO) {
            try {
                // Delete from database
                database.notificationDao().deleteNotification(notificationId)
                
                // Update notification center
                updateNotificationCenterAfterDeletion(notificationId)
                
                // Notify listeners
                notifyNotificationDeleted(notificationId)
                
                Result.success(true)
                
            } catch (e: Exception) {
                Result.failure(e)
            }
        }
    }
    
    /**
     * Schedule notification
     */
    suspend fun scheduleNotification(
        scheduledRequest: ScheduledNotificationRequest
    ): Result<String> {
        return withContext(Dispatchers.IO) {
            try {
                // Validate scheduled request
                validateScheduledNotificationRequest(scheduledRequest)
                
                // Schedule notification
                val scheduleId = notificationScheduler.scheduleNotification(scheduledRequest)
                
                // Notify listeners
                notifyNotificationScheduled(scheduleId, scheduledRequest)
                
                Result.success(scheduleId)
                
            } catch (e: Exception) {
                Result.failure(e)
            }
        }
    }
    
    /**
     * Cancel scheduled notification
     */
    suspend fun cancelScheduledNotification(
        scheduleId: String
    ): Result<Boolean> {
        return withContext(Dispatchers.IO) {
            try {
                // Cancel scheduled notification
                notificationScheduler.cancelNotification(scheduleId)
                
                // Notify listeners
                notifyScheduledNotificationCancelled(scheduleId)
                
                Result.success(true)
                
            } catch (e: Exception) {
                Result.failure(e)
            }
        }
    }
    
    /**
     * Add notification listener
     */
    fun addNotificationListener(listener: NotificationListener) {
        notificationListeners.add(listener)
    }
    
    /**
     * Remove notification listener
     */
    fun removeNotificationListener(listener: NotificationListener) {
        notificationListeners.remove(listener)
    }
    
    /**
     * Helper functions
     */
    private suspend fun loadNotificationPreferences() {
        val preferences = database.notificationPreferenceDao().getPreferences()
        _notificationPreferences.value = preferences?.toDomainModel() ?: NotificationPreferences()
    }
    
    private suspend fun initializeNotificationServices() {
        pushNotificationService.initialize()
        smsNotificationService.initialize()
        emailNotificationService.initialize()
    }
    
    private suspend fun loadNotificationCenter() {
        val notifications = database.notificationDao().getAllNotifications()
        val center = NotificationCenter(
            notifications = notifications.map { it.toDomainModel() },
            unreadCount = notifications.count { !it.isRead },
            totalCount = notifications.size
        )
        _notificationCenter.value = center
    }
    
    private suspend fun startNotificationQueueProcessor() {
        notificationQueue.startProcessing()
    }
    
    private suspend fun loadNotificationAnalytics() {
        // Load notification analytics
        val analytics = NotificationAnalytics()
        _notificationAnalytics.value = analytics
    }
    
    private fun validateNotificationRequest(request: NotificationRequest) {
        if (request.title.isBlank()) throw Exception("Notification title cannot be empty")
        if (request.message.isBlank()) throw Exception("Notification message cannot be empty")
        if (request.recipients.isEmpty()) throw Exception("Notification must have at least one recipient")
    }
    
    private fun shouldSendNotification(request: NotificationRequest): Boolean {
        val preferences = _notificationPreferences.value
        
        // Check if silent mode is enabled
        if (preferences.silentMode && request.priority != NotificationPriority.EMERGENCY) {
            return false
        }
        
        // Check category preferences
        val categoryPreference = preferences.categoryPreferences[request.category]
        if (categoryPreference?.enabled == false) {
            return false
        }
        
        // Check time-based preferences
        if (preferences.doNotDisturbMode && isWithinDoNotDisturbHours()) {
            return request.priority == NotificationPriority.EMERGENCY
        }
        
        return true
    }
    
    private fun isWithinDoNotDisturbHours(): Boolean {
        val preferences = _notificationPreferences.value
        val currentTime = Calendar.getInstance()
        val currentHour = currentTime.get(Calendar.HOUR_OF_DAY)
        
        return currentHour >= preferences.doNotDisturbStartHour && 
               currentHour < preferences.doNotDisturbEndHour
    }
    
    private fun createNotificationRecord(request: NotificationRequest): Notification {
        return Notification(
            id = 0,
            title = request.title,
            message = request.message,
            category = request.category,
            priority = request.priority,
            status = NotificationStatus.PENDING,
            recipients = request.recipients,
            channels = request.channels,
            data = request.data,
            isRead = false,
            createdAt = Date(),
            updatedAt = Date()
        )
    }
    
    private fun createEmergencyNotification(request: EmergencyAlertRequest): Notification {
        return Notification(
            id = 0,
            title = "🚨 ${request.title}",
            message = request.message,
            category = NotificationCategory.EMERGENCY,
            priority = NotificationPriority.EMERGENCY,
            status = NotificationStatus.PENDING,
            recipients = request.recipients,
            channels = listOf(NotificationChannel.PUSH, NotificationChannel.IN_APP, NotificationChannel.SMS, NotificationChannel.EMAIL),
            data = request.data + ("isEmergency" to "true"),
            isRead = false,
            createdAt = Date(),
            updatedAt = Date()
        )
    }
    
    private fun determineNotificationChannels(request: NotificationRequest): List<NotificationChannel> {
        val preferences = _notificationPreferences.value
        
        // Use requested channels if available
        if (request.channels.isNotEmpty()) {
            return request.channels.filter { channel ->
                preferences.channelPreferences[channel]?.enabled != false
            }
        }
        
        // Use default channels based on category and priority
        return getDefaultChannels(request.category, request.priority)
    }
    
    private fun getDefaultChannels(category: NotificationCategory, priority: NotificationPriority): List<NotificationChannel> {
        return when (category) {
            NotificationCategory.EMERGENCY -> listOf(NotificationChannel.PUSH, NotificationChannel.SMS, NotificationChannel.EMAIL)
            NotificationCategory.SHIPMENT -> listOf(NotificationChannel.PUSH, NotificationChannel.IN_APP)
            NotificationCategory.DELAY -> listOf(NotificationChannel.PUSH, NotificationChannel.SMS)
            NotificationCategory.TEMPERATURE -> listOf(NotificationChannel.PUSH, NotificationChannel.IN_APP)
            NotificationCategory.MAINTENANCE -> listOf(NotificationChannel.PUSH, NotificationChannel.EMAIL)
            NotificationCategory.PAYMENT -> listOf(NotificationChannel.PUSH, NotificationChannel.EMAIL)
            NotificationCategory.DRIVER -> listOf(NotificationChannel.PUSH, NotificationChannel.SMS)
            else -> listOf(NotificationChannel.PUSH, NotificationChannel.IN_APP)
        }
    }
    
    private fun getDefaultShipmentChannels(alertType: ShipmentAlertType): List<NotificationChannel> {
        return when (alertType) {
            ShipmentAlertType.DELIVERED -> listOf(NotificationChannel.PUSH, NotificationChannel.EMAIL)
            ShipmentAlertType.OUT_FOR_DELIVERY -> listOf(NotificationChannel.PUSH, NotificationChannel.IN_APP)
            ShipmentAlertType.DELAYED -> listOf(NotificationChannel.PUSH, NotificationChannel.SMS)
            ShipmentAlertType.CANCELLED -> listOf(NotificationChannel.PUSH, NotificationChannel.SMS, NotificationChannel.EMAIL)
            ShipmentAlertType.RETURNED -> listOf(NotificationChannel.PUSH, NotificationChannel.EMAIL)
            else -> listOf(NotificationChannel.PUSH, NotificationChannel.IN_APP)
        }
    }
    
    private suspend fun sendPushNotification(
        notification: Notification,
        request: NotificationRequest,
        isEmergency: Boolean = false
    ): ChannelResult {
        return try {
            val result = pushNotificationService.sendNotification(notification, request, isEmergency)
            ChannelResult(
                channel = NotificationChannel.PUSH,
                status = if (result.isSuccess) NotificationStatus.SENT else NotificationStatus.FAILED,
                message = result.message,
                timestamp = Date()
            )
        } catch (e: Exception) {
            ChannelResult(
                channel = NotificationChannel.PUSH,
                status = NotificationStatus.FAILED,
                message = e.message ?: "Unknown error",
                timestamp = Date()
            )
        }
    }
    
    private suspend fun sendInAppNotification(
        notification: Notification,
        request: NotificationRequest,
        isEmergency: Boolean = false
    ): ChannelResult {
        return try {
