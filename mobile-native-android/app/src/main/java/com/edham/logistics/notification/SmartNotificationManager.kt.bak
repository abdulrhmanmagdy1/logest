            title = "تأخير في الشحنة",
            message = "الشحنة $shipmentId متأخرة ${delayData.delayMinutes} دقيقة. السبب: ${delayData.reason}",
            category = NotificationCategory.DELAY,
            priority = NotificationPriority.HIGH,
            recipients = delayData.recipients,
            data = mapOf(
                "shipmentId" to shipmentId,
                "delayMinutes" to delayData.delayMinutes,
                "reason" to delayData.reason,
                "estimatedNewArrival" to delayData.estimatedNewArrival.toString()
            ),
            channels = listOf(NotificationChannel.PUSH, NotificationChannel.SMS, NotificationChannel.EMAIL)
        )
        
        return sendNotification(request)
    }
    
    /**
     * Send temperature alert
     */
    suspend fun sendTemperatureAlert(
        sensorId: String,
        temperatureData: TemperatureAlertData
    ): Result<NotificationResult> {
        val request = NotificationRequest(
            title = "تنبيه درجة الحرارة",
            message = "درجة الحرارة ${temperatureData.currentTemperature}°${temperatureData.unit} في ${temperatureData.location}. الحد: ${temperatureData.threshold}°${temperatureData.unit}",
            category = NotificationCategory.TEMPERATURE,
            priority = if (temperatureData.isCritical) NotificationPriority.EMERGENCY else NotificationPriority.HIGH,
            recipients = temperatureData.recipients,
            data = mapOf(
                "sensorId" to sensorId,
                "currentTemperature" to temperatureData.currentTemperature,
                "threshold" to temperatureData.threshold,
                "unit" to temperatureData.unit,
                "location" to temperatureData.location,
                "isCritical" to temperatureData.isCritical
            ),
            channels = if (temperatureData.isCritical) {
                listOf(NotificationChannel.PUSH, NotificationChannel.SMS, NotificationChannel.EMAIL)
            } else {
                listOf(NotificationChannel.PUSH, NotificationChannel.IN_APP)
            }
        )
        
        return sendNotification(request)
    }
    
