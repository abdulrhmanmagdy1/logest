        } catch (e: Exception) {
            ChannelResult(
                channel = NotificationChannel.EMAIL,
                status = NotificationStatus.FAILED,
                message = e.message ?: "Unknown error",
                timestamp = Date()
            )
        }
    }
    
    private fun determineFinalStatus(results: List<ChannelResult>): NotificationStatus {
        val hasSuccess = results.any { it.status == NotificationStatus.SENT }
        val hasFailure = results.any { it.status == NotificationStatus.FAILED }
        
        return when {
            hasSuccess && !hasFailure -> NotificationStatus.SENT
            hasSuccess && hasFailure -> NotificationStatus.PARTIALLY_SENT
            !hasSuccess -> NotificationStatus.FAILED
            else -> NotificationStatus.FAILED
        }
    }
    
    private suspend fun updateNotificationStatus(notificationId: Long, status: NotificationStatus) {
        database.notificationDao().updateStatus(notificationId, status)
    }
    
    private suspend fun updateNotificationAnalytics(notification: Notification, results: List<ChannelResult>) {
        // Update notification analytics
    }
    
    private suspend fun updateNotificationCenter(notification: Notification) {
        val currentCenter = _notificationCenter.value
        val updatedCenter = currentCenter.copy(
            notifications = listOf(notification) + currentCenter.notifications,
            unreadCount = currentCenter.unreadCount + 1,
            totalCount = currentCenter.totalCount + 1
        )
        _notificationCenter.value = updatedCenter
    }
    
    private suspend fun updateEmergencyAlertCenter(notification: Notification) {
        val currentCenter = _notificationCenter.value
        val updatedCenter = currentCenter.copy(
            emergencyAlerts = listOf(notification) + currentCenter.emergencyAlerts,
            unreadCount = currentCenter.unreadCount + 1,
            totalCount = currentCenter.totalCount + 1
        )
        _notificationCenter.value = updatedCenter
    }
    
    private suspend fun updateNotificationCenterReadStatus(notificationId: Long) {
        val currentCenter = _notificationCenter.value
        val updatedNotifications = currentCenter.notifications.map { notification ->
            if (notification.id == notificationId) {
                notification.copy(isRead = true)
            } else {
                notification
            }
        }
        
        val updatedCenter = currentCenter.copy(
            notifications = updatedNotifications,
            unreadCount = (currentCenter.unreadCount - 1).coerceAtLeast(0)
        )
        _notificationCenter.value = updatedCenter
    }
    
    private suspend fun updateAllNotificationsReadStatus() {
        val currentCenter = _notificationCenter.value
        val updatedCenter = currentCenter.copy(
            notifications = currentCenter.notifications.map { it.copy(isRead = true) },
            unreadCount = 0
        )
        _notificationCenter.value = updatedCenter
    }
    
    private suspend fun updateNotificationCenterAfterDeletion(notificationId: Long) {
        val currentCenter = _notificationCenter.value
        val updatedNotifications = currentCenter.notifications.filter { it.id != notificationId }
        val deletedNotification = currentCenter.notifications.find { it.id == notificationId }
        
        val updatedCenter = currentCenter.copy(
            notifications = updatedNotifications,
            unreadCount = if (deletedNotification?.isRead == false) {
                (currentCenter.unreadCount - 1).coerceAtLeast(0)
            } else {
                currentCenter.unreadCount
            },
            totalCount = (currentCenter.totalCount - 1).coerceAtLeast(0)
        )
        _notificationCenter.value = updatedCenter
    }
    
    private fun validateEmergencyAlert(request: EmergencyAlertRequest) {
        if (request.title.isBlank()) throw Exception("Emergency alert title cannot be empty")
        if (request.message.isBlank()) throw Exception("Emergency alert message cannot be empty")
        if (request.recipients.isEmpty()) throw Exception("Emergency alert must have at least one recipient")
    }
    
    private fun validateNotificationPreferences(preferences: NotificationPreferences) {
        // Validate notification preferences
    }
    
    private fun validateScheduledNotificationRequest(request: ScheduledNotificationRequest) {
        if (request.title.isBlank()) throw Exception("Scheduled notification title cannot be empty")
        if (request.message.isBlank()) throw Exception("Scheduled notification message cannot be empty")
        if (request.recipients.isEmpty()) throw Exception("Scheduled notification must have at least one recipient")
        if (request.scheduledTime.before(Date())) throw Exception("Scheduled time cannot be in the past")
    }
    
    private fun getShipmentAlertTitle(alertType: ShipmentAlertType): String {
        return when (alertType) {
            ShipmentAlertType.CREATED -> "شحنة جديدة"
            ShipmentAlertType.PICKED_UP -> "تم استلام الشحنة"
            ShipmentAlertType.IN_TRANSIT -> "الشحنة في الطريق"
            ShipmentAlertType.OUT_FOR_DELIVERY -> "الشحنة خرجت للتسليم"
            ShipmentAlertType.DELIVERED -> "تم تسليم الشحنة"
            ShipmentAlertType.DELAYED -> "تأخير الشحنة"
            ShipmentAlertType.CANCELLED -> "إلغاء الشحنة"
            ShipmentAlertType.RETURNED -> "إرجاع الشحنة"
            ShipmentAlertType.LOST -> "فقدان الشحنة"
            ShipmentAlertType.DAMAGED -> "تلف الشحنة"
        }
    }
    
    private fun getShipmentAlertMessage(alertType: ShipmentAlertType, data: ShipmentAlertData): String {
        return when (alertType) {
            ShipmentAlertType.CREATED -> "تم إنشاء شحنة جديدة: ${data.shipmentId}"
            ShipmentAlertType.PICKED_UP -> "تم استلام الشحنة ${data.shipmentId} من ${data.pickupLocation}"
            ShipmentAlertType.IN_TRANSIT -> "الشحنة ${data.shipmentId} حالياً في الطريق إلى ${data.destination}"
            ShipmentAlertType.OUT_FOR_DELIVERY -> "الشحنة ${data.shipmentId} خرجت للتسليم إلى ${data.destination}"
            ShipmentAlertType.DELIVERED -> "تم تسليم الشحنة ${data.shipmentId} بنجاح"
            ShipmentAlertType.DELAYED -> "الشحنة ${data.shipmentId} متأخرة. التوصيل المتوقع: ${data.estimatedDelivery}"
            ShipmentAlertType.CANCELLED -> "تم إلغاء الشحنة ${data.shipmentId}. السبب: ${data.reason}"
            ShipmentAlertType.RETURNED -> "تم إرجاع الشحنة ${data.shipmentId}. السبب: ${data.reason}"
            ShipmentAlertType.LOST -> "فُقدت الشحنة ${data.shipmentId}. يرجى التواصل مع الدعم"
            ShipmentAlertType.DAMAGED -> "تعرضت الشحنة ${data.shipmentId} للتلف. يرجى التواصل مع الدعم"
        }
    }
    
    private fun getShipmentAlertPriority(alertType: ShipmentAlertType): NotificationPriority {
        return when (alertType) {
            ShipmentAlertType.CREATED -> NotificationPriority.NORMAL
            ShipmentAlertType.PICKED_UP -> NotificationPriority.NORMAL
            ShipmentAlertType.IN_TRANSIT -> NotificationPriority.NORMAL
            ShipmentAlertType.OUT_FOR_DELIVERY -> NotificationPriority.HIGH
            ShipmentAlertType.DELIVERED -> NotificationPriority.NORMAL
            ShipmentAlertType.DELAYED -> NotificationPriority.HIGH
            ShipmentAlertType.CANCELLED -> NotificationPriority.HIGH
            ShipmentAlertType.RETURNED -> NotificationPriority.HIGH
            ShipmentAlertType.LOST -> NotificationPriority.EMERGENCY
            ShipmentAlertType.DAMAGED -> NotificationPriority.EMERGENCY
        }
    }
    
    private fun getPaymentAlertMessage(paymentData: PaymentAlertData): String {
        return when (paymentData.status) {
            PaymentStatus.PENDING -> "دفع بقيمة ${paymentData.amount} ريال مستحق بتاريخ ${paymentData.dueDate}"
            PaymentStatus.OVERDUE -> "دفع بقيمة ${paymentData.amount} ريال متأخر منذ ${paymentData.daysOverdue} يوم"
            PaymentStatus.PAID -> "تم استلام دفع بقيمة ${paymentData.amount} ريال بنجاح"
            PaymentStatus.FAILED -> "فشل عملية الدفع بقيمة ${paymentData.amount} ريال. يرجى المحاولة مرة أخرى"
            PaymentStatus.CANCELLED -> "تم إلغاء الدفع بقيمة ${paymentData.amount} ريال"
        }
    }
    
    private fun getDriverAlertTitle(alertType: DriverAlertType): String {
        return when (alertType) {
            DriverAlertType.SPEEDING -> "تنبيه السرعة الزائدة"
            DriverAlertType.HARSH_BRAKING -> "تنبيه الكبح المفاجئ"
            DriverAlertType.RAPID_ACCELERATION -> "تنبيه التسارع المفاجئ"
            DriverAlertType.IDLING -> "تنبيه التوقف الطويل"
            DriverAlertType.FATIGUE -> "تنبيه الإرهاق"
            DriverAlertType.OFF_ROUTE -> "انحراف عن المسار"
            DriverAlertType.LOW_FUEL -> "مستوى الوقود منخفض"
            DriverAlertType.EMERGENCY -> "طوارئ السائق"
        }
    }
    
    private fun getDriverAlertMessage(alertData: DriverAlertData): String {
        return when (alertData.alertType) {
            DriverAlertType.SPEEDING -> "السائق يتجاوز السرعة المسموح بها (${alertData.details} كم/ساعة)"
            DriverAlertType.HARSH_BRAKING -> "تم اكتشاف كبح مفاجئ في ${alertData.location}"
            DriverAlertType.RAPID_ACCELERATION -> "تم اكتشاف تسارع مفاجئ في ${alertData.location}"
            DriverAlertType.IDLING -> "السائق متوقف لمدة ${alertData.details} دقيقة"
            DriverAlertType.FATIGUE -> "علامات إرهاق detected. يرجى أخذ استراحة"
            DriverAlertType.OFF_ROUTE -> "السائق انحرف عن المسار المحدد (${alertData.details} كم)"
            DriverAlertType.LOW_FUEL -> "مستوى الوقود منخفض (${alertData.details}%)"
            DriverAlertType.EMERGENCY -> "حالة طوارئ: ${alertData.details}"
        }
    }
    
    private fun notifyNotificationSent(notification: Notification, results: List<ChannelResult>) {
        notificationListeners.forEach { listener ->
            listener.onNotificationSent(notification, results)
        }
    }
    
    private fun notifyEmergencyAlertSent(notification: Notification, results: List<ChannelResult>) {
        notificationListeners.forEach { listener ->
            listener.onEmergencyAlertSent(notification, results)
        }
    }
    
    private fun notifyPreferencesUpdated(preferences: NotificationPreferences) {
        notificationListeners.forEach { listener ->
            listener.onNotificationPreferencesUpdated(preferences)
        }
    }
    
    private fun notifyNotificationRead(notificationId: Long) {
        notificationListeners.forEach { listener ->
            listener.onNotificationRead(notificationId)
        }
    }
    
    private fun notifyAllNotificationsRead() {
        notificationListeners.forEach { listener ->
            listener.onAllNotificationsRead()
        }
    }
    
    private fun notifyNotificationDeleted(notificationId: Long) {
        notificationListeners.forEach { listener ->
            listener.onNotificationDeleted(notificationId)
        }
    }
    
    private fun notifyNotificationScheduled(scheduleId: String, request: ScheduledNotificationRequest) {
        notificationListeners.forEach { listener ->
            listener.onNotificationScheduled(scheduleId, request)
        }
    }
    
    private fun notifyScheduledNotificationCancelled(scheduleId: String) {
        notificationListeners.forEach { listener ->
            listener.onScheduledNotificationCancelled(scheduleId)
        }
    }
    
    /**
     * Get initialization status
     */
    fun isInitialized(): Boolean = isInitialized
}

/**
 * Data classes
 */
data class NotificationRequest(
    val title: String,
    val message: String,
    val category: NotificationCategory,
    val priority: NotificationPriority,
    val recipients: List<NotificationRecipient>,
    val data: Map<String, String> = emptyMap(),
    val channels: List<NotificationChannel> = emptyList(),
    val scheduledTime: Date? = null
)

data class EmergencyAlertRequest(
    val title: String,
    val message: String,
    val recipients: List<NotificationRecipient>,
    val data: Map<String, String> = emptyMap(),
    val severity: EmergencySeverity = EmergencySeverity.HIGH
)

data class ScheduledNotificationRequest(
    val title: String,
    val message: String,
    val category: NotificationCategory,
    val priority: NotificationPriority,
    val recipients: List<NotificationRecipient>,
    val data: Map<String, String> = emptyMap(),
    val channels: List<NotificationChannel>,
    val scheduledTime: Date,
    val repeatInterval: Long? = null
)

data class ShipmentAlertData(
    val shipmentId: String,
    val pickupLocation: String,
    val destination: String,
    val estimatedDelivery: Date,
    val recipients: List<NotificationRecipient>,
    val reason: String? = null
)

data class DelayAlertData(
    val recipients: List<NotificationRecipient>,
    val delayMinutes: Int,
    val reason: String,
    val estimatedNewArrival: Date
)

data class TemperatureAlertData(
    val currentTemperature: Double,
    val threshold: Double,
    val unit: String,
    val location: String,
    val isCritical: Boolean,
    val recipients: List<NotificationRecipient>
)

data class MaintenanceAlertData(
    val maintenanceType: String,
    val description: String,
    val scheduledDate: Date,
    val estimatedCost: Float,
    val priority: NotificationPriority,
    val recipients: List<NotificationRecipient>
)

data class PaymentAlertData(
    val paymentId: String,
    val amount: Float,
    val dueDate: Date,
    val status: PaymentStatus,
    val daysOverdue: Int = 0,
    val recipients: List<NotificationRecipient>,
    val priority: NotificationPriority = NotificationPriority.NORMAL
)

data class DriverAlertData(
    val alertType: DriverAlertType,
    val location: String,
    val timestamp: Date,
    val details: String,
    val recipients: List<NotificationRecipient>,
    val priority: NotificationPriority = NotificationPriority.HIGH
)

data class Notification(
    val id: Long,
    val title: String,
    val message: String,
    val category: NotificationCategory,
    val priority: NotificationPriority,
    val status: NotificationStatus,
    val recipients: List<NotificationRecipient>,
    val channels: List<NotificationChannel>,
    val data: Map<String, String>,
    val isRead: Boolean,
    val createdAt: Date,
    val updatedAt: Date
)

data class NotificationCenter(
    val notifications: List<Notification> = emptyList(),
    val emergencyAlerts: List<Notification> = emptyList(),
    val unreadCount: Int = 0,
    val totalCount: Int = 0
)

data class NotificationPreferences(
    val silentMode: Boolean = false,
    val doNotDisturbMode: Boolean = false,
    val doNotDisturbStartHour: Int = 22,
    val doNotDisturbEndHour: Int = 7,
    val categoryPreferences: Map<NotificationCategory, CategoryPreference> = emptyMap(),
    val channelPreferences: Map<NotificationChannel, ChannelPreference> = emptyMap()
)

data class CategoryPreference(
    val enabled: Boolean = true,
    val priority: NotificationPriority = NotificationPriority.NORMAL,
    val channels: List<NotificationChannel> = listOf(NotificationChannel.PUSH, NotificationChannel.IN_APP)
)

data class ChannelPreference(
    val enabled: Boolean = true,
    val priority: NotificationPriority = NotificationPriority.NORMAL
)

data class NotificationAnalytics(
    val totalSent: Int = 0,
    val totalDelivered: Int = 0,
    val totalRead: Int = 0,
    val deliveryRate: Float = 0f,
    val readRate: Float = 0f,
    val categoryStats: Map<NotificationCategory, CategoryStats> = emptyMap(),
    val channelStats: Map<NotificationChannel, ChannelStats> = emptyMap()
)

data class CategoryStats(
    val sent: Int = 0,
    val delivered: Int = 0,
    val read: Int = 0,
    val deliveryRate: Float = 0f,
    val readRate: Float = 0f
)

data class ChannelStats(
    val sent: Int = 0,
    val delivered: Int = 0,
    val read: Int = 0,
    val deliveryRate: Float = 0f,
    val readRate: Float = 0f
)

data class NotificationResult(
    val id: String,
    val status: NotificationStatus,
    val channels: List<ChannelResult>? = null,
    val message: String? = null,
    val timestamp: Date
)

data class ChannelResult(
    val channel: NotificationChannel,
    val status: NotificationStatus,
    val message: String,
    val timestamp: Date
)

data class NotificationRecipient(
    val id: String,
    val type: RecipientType,
    val address: String,
    val name: String? = null
)

/**
 * Interfaces
 */
interface NotificationListener {
    fun onNotificationSent(notification: Notification, results: List<ChannelResult>)
    fun onEmergencyAlertSent(notification: Notification, results: List<ChannelResult>)
    fun onNotificationPreferencesUpdated(preferences: NotificationPreferences)
    fun onNotificationRead(notificationId: Long)
    fun onAllNotificationsRead()
    fun onNotificationDeleted(notificationId: Long)
    fun onNotificationScheduled(scheduleId: String, request: ScheduledNotificationRequest)
    fun onScheduledNotificationCancelled(scheduleId: String)
}

/**
 * Enums
 */
enum class NotificationState {
    Idle,
    Initializing,
    Ready,
    Sending,
    SendingEmergency,
    Sent,
    EmergencySent,
    Skipped,
    Error
}

enum class NotificationChannel {
    PUSH,
    IN_APP,
    SMS,
    EMAIL
}

enum class NotificationCategory {
    SHIPMENT,
    DELAY,
    TEMPERATURE,
    MAINTENANCE,
    PAYMENT,
    DRIVER,
    EMERGENCY,
    SYSTEM,
    MARKETING,
    GENERAL
}

enum class NotificationPriority {
    LOW,
    NORMAL,
    HIGH,
    EMERGENCY
}

enum class NotificationStatus {
    PENDING,
    SENT,
    DELIVERED,
    READ,
    FAILED,
    PARTIALLY_SENT,
    SKIPPED,
    CANCELLED
}

enum class ShipmentAlertType {
    CREATED,
    PICKED_UP,
    IN_TRANSIT,
    OUT_FOR_DELIVERY,
    DELIVERED,
    DELAYED,
    CANCELLED,
    RETURNED,
    LOST,
    DAMAGED
}

enum class PaymentStatus {
    PENDING,
    OVERDUE,
    PAID,
    FAILED,
    CANCELLED
}

enum class DriverAlertType {
    SPEEDING,
    HARSH_BRAKING,
    RAPID_ACCELERATION,
    IDLING,
    FATIGUE,
    OFF_ROUTE,
    LOW_FUEL,
    EMERGENCY
}

enum class RecipientType {
    USER,
    DRIVER,
    CUSTOMER,
    ADMIN,
    SYSTEM
}

enum class EmergencySeverity {
    LOW,
    MEDIUM,
    HIGH,
    CRITICAL
}
