    private suspend fun sendEmailNotification(
        notification: Notification,
        request: NotificationRequest,
        isEmergency: Boolean = false
    ): ChannelResult {
        return try {
            val result = emailNotificationService.sendNotification(notification, request, isEmergency)
            ChannelResult(
                channel = NotificationChannel.EMAIL,
                status = if (result.isSuccess) NotificationStatus.SENT else NotificationStatus.FAILED,
                message = result.message,
                timestamp = Date()
