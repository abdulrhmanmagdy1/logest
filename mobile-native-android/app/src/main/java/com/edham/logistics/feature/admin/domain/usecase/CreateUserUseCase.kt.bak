package com.edham.logistics.feature.admin.domain.usecase

import com.edham.logistics.core.utils.Result
import com.edham.logistics.feature.admin.domain.model.UserManagement
import com.edham.logistics.feature.admin.domain.repository.AdminRepository
import javax.inject.Inject
import javax.inject.Singleton

@Singleton
class CreateUserUseCase @Inject constructor(
    private val adminRepository: AdminRepository
) {
    suspend operator fun invoke(user: UserManagement): Result<UserManagement> {
        if (!isValidUser(user)) {
            return Result.Error(IllegalArgumentException("Invalid user data"))
        }
        
        return adminRepository.createUser(user)
    }
    
    private fun isValidUser(user: UserManagement): Boolean {
        return user.name.isNotBlank() &&
                user.email.isNotBlank() &&
                user.phone.isNotBlank() &&
                user.role.isNotBlank() &&
                user.email.isValidEmail() &&
                user.phone.isValidPhone()
    }
    
    private fun String.isValidEmail(): Boolean {
        return android.util.Patterns.EMAIL_ADDRESS.matcher(this).matches()
    }
    
    private fun String.isValidPhone(): Boolean {
        return this.matches(Regex("^[+]?[0-9]{10,15}$"))
    }
}
