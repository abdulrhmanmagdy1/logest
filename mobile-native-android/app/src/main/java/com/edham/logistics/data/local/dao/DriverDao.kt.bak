package com.edham.logistics.data.local.dao

import androidx.room.*
import com.edham.logistics.data.local.entity.DriverEntity
import kotlinx.coroutines.flow.Flow

@Dao
interface DriverDao {
    
    @Query("SELECT * FROM drivers ORDER BY name ASC")
    fun getAllDrivers(): Flow<List<DriverEntity>>
    
    @Query("SELECT * FROM drivers WHERE id = :id")
    suspend fun getDriverById(id: String): DriverEntity?
    
    @Query("SELECT * FROM drivers WHERE status = :status ORDER BY name ASC")
    fun getDriversByStatus(status: String): Flow<List<DriverEntity>>
    
    @Query("SELECT * FROM drivers WHERE status = 'available' ORDER BY rating DESC")
    fun getAvailableDrivers(): Flow<List<DriverEntity>>
    
    @Query("SELECT * FROM drivers WHERE status = 'on_trip' ORDER BY name ASC")
    fun getDriversOnTrip(): Flow<List<DriverEntity>>
    
    @Query("SELECT * FROM drivers WHERE name LIKE '%' || :query || '%' OR email LIKE '%' || :query || '%' OR phone LIKE '%' || :query || '%' ORDER BY name ASC")
    suspend fun searchDrivers(query: String): List<DriverEntity>
    
    @Query("SELECT * FROM drivers ORDER BY name ASC LIMIT :limit OFFSET :offset")
    suspend fun getDriversPaged(limit: Int, offset: Int): List<DriverEntity>
    
    @Insert(onConflict = OnConflictStrategy.REPLACE)
    suspend fun insertDriver(driver: DriverEntity): Long
    
    @Insert(onConflict = OnConflictStrategy.REPLACE)
    suspend fun insertDrivers(drivers: List<DriverEntity>): List<Long>
    
    @Update
    suspend fun updateDriver(driver: DriverEntity)
    
    @Delete
    suspend fun deleteDriver(driver: DriverEntity)
    
    @Query("DELETE FROM drivers WHERE id = :id")
    suspend fun deleteDriverById(id: String)
    
    @Query("UPDATE drivers SET status = :status WHERE id = :id")
    suspend fun updateDriverStatus(id: String, status: String)
    
    @Query("UPDATE drivers SET currentLatitude = :latitude, currentLongitude = :longitude, currentLocation = :address WHERE id = :id")
    suspend fun updateDriverLocation(id: String, latitude: Double, longitude: Double, address: String)
    
    @Query("UPDATE drivers SET rating = :rating WHERE id = :id")
    suspend fun updateDriverRating(id: String, rating: Float)
    
    @Query("UPDATE drivers SET currentVehicleId = :vehicleId WHERE id = :id")
    suspend fun assignDriverToVehicle(id: String, vehicleId: String)
    
    @Query("UPDATE drivers SET currentVehicleId = NULL WHERE id = :id")
    suspend fun unassignDriverFromVehicle(id: String)
    
    @Query("DELETE FROM drivers")
    suspend fun deleteAllDrivers()
    
    @Query("SELECT COUNT(*) FROM drivers")
    suspend fun getDriversCount(): Int
    
    @Query("SELECT COUNT(*) FROM drivers WHERE status = :status")
    suspend fun getDriversCountByStatus(status: String): Int
}
