package com.edham.logistics.performance.recyclerview

import android.graphics.Rect
import android.view.View
import androidx.recyclerview.widget.DiffUtil
import androidx.recyclerview.widget.GridLayoutManager
import androidx.recyclerview.widget.LinearLayoutManager
import androidx.recyclerview.widget.RecyclerView
import kotlinx.coroutines.*
import timber.log.Timber
import java.util.concurrent.ConcurrentHashMap
import java.util.concurrent.atomic.AtomicLong
import javax.inject.Inject
import javax.inject.Singleton

/**
 * RecyclerView Optimizer - Advanced RecyclerView performance optimization
 * Implements smooth scrolling, efficient adapters, and memory management
 */

@Singleton
class RecyclerViewOptimizer @Inject constructor() {

    private val optimizationScope = CoroutineScope(Dispatchers.Main + SupervisorJob())
    private val recyclerViewConfigs = ConcurrentHashMap<String, RecyclerViewConfig>()
    private val scrollListeners = ConcurrentHashMap<String, RecyclerView.OnScrollListener>()
    
    // Performance metrics
    private val totalScrollEvents = AtomicLong(0)
    private val smoothScrollEvents = AtomicLong(0)
    private val adapterUpdates = AtomicLong(0)
    private val averageScrollTime = AtomicLong(0)
    
    // Configuration
    private val defaultItemViewCacheSize = 20
    private val defaultDrawingCacheEnabled = true
    private val defaultHasFixedSize = true
    private val scrollThreshold = 5 // pixels
    private val scrollDelay = 16 // ~60fps
    
    /**
     * Optimize RecyclerView for smooth performance
     */
    fun optimizeRecyclerView(
        recyclerView: RecyclerView,
        config: RecyclerViewConfig? = null
    ): RecyclerViewConfig {
        val key = recyclerView.hashCode().toString()
        val finalConfig = config ?: getDefaultConfig()
        
        try {
            // Apply basic optimizations
            applyBasicOptimizations(recyclerView, finalConfig)
            
            // Apply layout manager optimizations
            optimizeLayoutManager(recyclerView, finalConfig)
            
            // Apply adapter optimizations
            optimizeAdapter(recyclerView, finalConfig)
            
            // Apply scrolling optimizations
            optimizeScrolling(recyclerView, finalConfig)
            
            // Apply memory optimizations
            optimizeMemoryUsage(recyclerView, finalConfig)
            
            // Store configuration
            recyclerViewConfigs[key] = finalConfig
            
            // Start performance monitoring
            startPerformanceMonitoring(recyclerView, key)
            
            Timber.d("RecyclerView optimized with config: $finalConfig")
            
        } catch (e: Exception) {
            Timber.e(e, "Error optimizing RecyclerView")
        }
        
        return finalConfig
    }
    
    /**
     * Create optimized layout manager
     */
    fun createOptimizedLayoutManager(
        recyclerView: RecyclerView,
        orientation: Int = RecyclerView.VERTICAL,
        spanCount: Int = 1,
        config: RecyclerViewConfig? = null
    ): RecyclerView.LayoutManager {
        val finalConfig = config ?: getDefaultConfig()
        
        return if (spanCount > 1) {
            createOptimizedGridLayoutManager(recyclerView, orientation, spanCount, finalConfig)
        } else {
            createOptimizedLinearLayoutManager(recyclerView, orientation, finalConfig)
        }
    }
    
    /**
     * Create optimized adapter with DiffUtil
     */
    fun <T> createOptimizedAdapter(
        recyclerView: RecyclerView,
        items: List<T>,
        itemLayout: Int,
        bindViewHolder: (View, T, Int) -> Unit,
        diffCallback: DiffUtil.Callback? = null
    ): OptimizedRecyclerAdapter<T> {
        return OptimizedRecyclerAdapter(
            items = items,
            itemLayout = itemLayout,
            bindViewHolder = bindViewHolder,
            diffCallback = diffCallback
        ).apply {
            setHasStableIds(true)
        }
    }
    
    /**
     * Enable smooth scrolling with performance optimization
     */
    fun enableSmoothScrolling(
        recyclerView: RecyclerView,
        config: SmoothScrollConfig? = null
    ) {
        val finalConfig = config ?: SmoothScrollConfig()
        
        try {
            // Remove existing scroll listener
            scrollListeners[recyclerView.hashCode().toString()]?.let {
                recyclerView.removeOnScrollListener(it)
            }
            
            // Add optimized scroll listener
            val scrollListener = createOptimizedScrollListener(finalConfig)
            recyclerView.addOnScrollListener(scrollListener)
            scrollListeners[recyclerView.hashCode().toString()] = scrollListener
            
            // Enable smooth scrolling
            recyclerView.layoutManager?.let { layoutManager ->
                if (layoutManager is LinearLayoutManager) {
                    layoutManager.isSmoothScrollbarEnabled = true
                }
            }
            
            Timber.d("Smooth scrolling enabled for RecyclerView")
            
        } catch (e: Exception) {
            Timber.e(e, "Error enabling smooth scrolling")
        }
    }
    
    /**
     * Optimize for large datasets
     */
    fun optimizeForLargeDataset(
        recyclerView: RecyclerView,
        config: LargeDatasetConfig? = null
    ) {
        val finalConfig = config ?: LargeDatasetConfig()
        
        try {
            // Increase cache size for large datasets
            recyclerView.setItemViewCacheSize(finalConfig.itemCacheSize)
            
            // Enable recycled view pool
            optimizeRecycledViewPool(recyclerView, finalConfig)
            
            // Set up pagination
            if (finalConfig.enablePagination) {
                setupPagination(recyclerView, finalConfig)
            }
            
            // Optimize item decorations
            optimizeItemDecorations(recyclerView, finalConfig)
            
            Timber.d("RecyclerView optimized for large dataset")
            
        } catch (e: Exception) {
            Timber.e(e, "Error optimizing for large dataset")
        }
    }
    
    /**
     * Monitor RecyclerView performance
     */
    fun startPerformanceMonitoring(
        recyclerView: RecyclerView,
        key: String
    ) {
        optimizationScope.launch {
            while (isActive) {
                try {
                    // Collect performance metrics
                    val metrics = collectPerformanceMetrics(recyclerView)
                    
                    // Log performance issues
                    if (metrics.averageFrameTime > 16) { // Below 60fps
                        Timber.w("RecyclerView performance issue: ${metrics.averageFrameTime}ms per frame")
                    }
                    
                    if (metrics.memoryUsage > 100 * 1024 * 1024) { // 100MB
                        Timber.w("RecyclerView high memory usage: ${metrics.memoryUsage / 1024 / 1024}MB")
                    }
                    
                    delay(1000) // Monitor every second
                    
                } catch (e: Exception) {
                    Timber.e(e, "Error monitoring RecyclerView performance")
                    delay(5000) // Wait longer on error
                }
            }
        }
    }
    
    /**
     * Get RecyclerView performance statistics
     */
    fun getPerformanceStats(recyclerView: RecyclerView): RecyclerViewPerformanceStats {
        val key = recyclerView.hashCode().toString()
        val config = recyclerViewConfigs[key] ?: getDefaultConfig()
        
        return RecyclerViewPerformanceStats(
            totalScrollEvents = totalScrollEvents.get(),
            smoothScrollEvents = smoothScrollEvents.get(),
            adapterUpdates = adapterUpdates.get(),
            averageScrollTime = averageScrollTime.get(),
            itemViewCacheSize = recyclerView.itemViewCacheSize,
            hasFixedSize = recyclerView.hasFixedSize(),
            drawingCacheEnabled = config.drawingCacheEnabled,
            layoutManagerType = recyclerView.layoutManager?.javaClass?.simpleName ?: "Unknown",
            adapterType = recyclerView.adapter?.javaClass?.simpleName ?: "Unknown"
        )
    }
    
    // Private methods
    
    private fun applyBasicOptimizations(
        recyclerView: RecyclerView,
        config: RecyclerViewConfig
    ) {
        // Set item view cache size
        recyclerView.setItemViewCacheSize(config.itemViewCacheSize)
        
        // Enable drawing cache
        if (config.drawingCacheEnabled) {
            recyclerView.setDrawingCacheEnabled(true)
            recyclerView.setDrawingCacheQuality(View.DRAWING_CACHE_QUALITY_HIGH)
        }
        
        // Set fixed size if content size is predictable
        recyclerView.setHasFixedSize(config.hasFixedSize)
        
        // Enable nested scrolling if needed
        recyclerView.setNestedScrollingEnabled(config.nestedScrollingEnabled)
        
        // Set fade in/out animations
        recyclerView.setItemAnimator(OptimizedItemAnimator())
    }
    
    private fun optimizeLayoutManager(
        recyclerView: RecyclerView,
        config: RecyclerViewConfig
    ) {
        val layoutManager = recyclerView.layoutManager ?: return
        
        when (layoutManager) {
            is LinearLayoutManager -> {
                layoutManager.recycleChildrenOnDetach = true
                layoutManager.isItemPrefetchEnabled = config.itemPrefetchEnabled
            }
            is GridLayoutManager -> {
                layoutManager.recycleChildrenOnDetach = true
                layoutManager.isItemPrefetchEnabled = config.itemPrefetchEnabled
            }
        }
    }
    
    private fun optimizeAdapter(
        recyclerView: RecyclerView,
        config: RecyclerViewConfig
    ) {
        val adapter = recyclerView.adapter ?: return
        
        // Enable stable IDs for better performance
        adapter.setHasStableIds(config.hasStableIds)
        
        // Set item animator to null for better performance with large lists
        if (config.disableItemAnimator) {
            recyclerView.itemAnimator = null
        }
    }
    
    private fun optimizeScrolling(
        recyclerView: RecyclerView,
        config: RecyclerViewConfig
    ) {
        // Enable smooth scrolling
        recyclerView.layoutManager?.let { layoutManager ->
            if (layoutManager is LinearLayoutManager) {
                layoutManager.isSmoothScrollbarEnabled = true
            }
        }
    }
    
    private fun optimizeMemoryUsage(
        recyclerView: RecyclerView,
        config: RecyclerViewConfig
    ) {
        // Optimize recycled view pool
        val recycledViewPool = recyclerView.recycledViewPool
        recycledViewPool.setMaxRecycledViews(0, config.maxRecycledViews)
        
        // Clear caches when not needed
        if (config.clearCacheOnDetach) {
            recyclerView.addOnAttachStateChangeListener(object : View.OnAttachStateChangeListener {
                override fun onViewAttachedToWindow(v: View) {}
                
                override fun onViewDetachedFromWindow(v: View) {
                    recyclerView.recycledViewPool.clear()
                }
            })
        }
    }
    
    private fun createOptimizedLinearLayoutManager(
        recyclerView: RecyclerView,
        orientation: Int,
        config: RecyclerViewConfig
    ): LinearLayoutManager {
        return object : LinearLayoutManager(recyclerView.context, orientation, false) {
            override fun supportsPredictiveItemAnimations(): Boolean {
                return config.supportsPredictiveItemAnimations
            }
            
            override fun onLayoutChildren(recycler: RecyclerView.Recycler?, state: RecyclerView.State?) {
                try {
                    super.onLayoutChildren(recycler, state)
                } catch (e: IndexOutOfBoundsException) {
                    // Handle IndexOutOfBoundsException that can occur with fast scrolling
                    Timber.w("IndexOutOfBoundsException in RecyclerView layout")
                }
            }
        }
    }
    
    private fun createOptimizedGridLayoutManager(
        recyclerView: RecyclerView,
        orientation: Int,
        spanCount: Int,
        config: RecyclerViewConfig
    ): GridLayoutManager {
        return object : GridLayoutManager(recyclerView.context, spanCount, orientation, false) {
            override fun supportsPredictiveItemAnimations(): Boolean {
                return config.supportsPredictiveItemAnimations
            }
            
            override fun onLayoutChildren(recycler: RecyclerView.Recycler?, state: RecyclerView.State?) {
                try {
                    super.onLayoutChildren(recycler, state)
                } catch (e: IndexOutOfBoundsException) {
                    Timber.w("IndexOutOfBoundsException in RecyclerView layout")
                }
            }
        }
    }
    
    private fun createOptimizedScrollListener(config: SmoothScrollConfig): RecyclerView.OnScrollListener {
        return object : RecyclerView.OnScrollListener() {
            private var lastScrollTime = 0L
            
            override fun onScrolled(recyclerView: RecyclerView, dx: Int, dy: Int) {
                super.onScrolled(recyclerView, dx, dy)
                
                val currentTime = System.currentTimeMillis()
                if (currentTime - lastScrollTime > config.scrollDelay) {
                    totalScrollEvents.incrementAndGet()
                    
                    if (config.enableSmoothScrolling && (Math.abs(dx) > config.scrollThreshold || Math.abs(dy) > config.scrollThreshold)) {
                        smoothScrollEvents.incrementAndGet()
                    }
                    
                    lastScrollTime = currentTime
                }
            }
            
            override fun onScrollStateChanged(recyclerView: RecyclerView, newState: Int) {
                super.onScrollStateChanged(recyclerView, newState)
                
                when (newState) {
                    RecyclerView.SCROLL_STATE_DRAGGING -> {
                        // User is actively scrolling
                    }
                    RecyclerView.SCROLL_STATE_SETTLING -> {
                        // RecyclerView is settling after a scroll/fling
                    }
                    RecyclerView.SCROLL_STATE_IDLE -> {
                        // RecyclerView is not currently scrolling
                        if (config.clearCacheOnIdle) {
                            recyclerView.recycledViewPool.clear()
                        }
                    }
                }
            }
        }
    }
    
    private fun optimizeRecycledViewPool(
        recyclerView: RecyclerView,
        config: LargeDatasetConfig
    ) {
        val recycledViewPool = recyclerView.recycledViewPool
        
        // Set max recycled views for different view types
        for (i in 0 until config.viewTypeCount) {
            recycledViewPool.setMaxRecycledViews(i, config.maxRecycledViewsPerType)
        }
    }
    
    private fun setupPagination(
        recyclerView: RecyclerView,
        config: LargeDatasetConfig
    ) {
        // Add scroll listener for pagination
        recyclerView.addOnScrollListener(object : RecyclerView.OnScrollListener() {
            override fun onScrolled(recyclerView: RecyclerView, dx: Int, dy: Int) {
                super.onScrolled(recyclerView, dx, dy)
                
                val layoutManager = recyclerView.layoutManager as? LinearLayoutManager ?: return
                val visibleItemCount = layoutManager.childCount
                val totalItemCount = layoutManager.itemCount
                val firstVisibleItemPosition = layoutManager.findFirstVisibleItemPosition()
                
                if (!config.isLoading && !config.isLastPage) {
                    if (visibleItemCount + firstVisibleItemPosition >= totalItemCount && firstVisibleItemPosition >= 0) {
                        // Load more data
                        config.loadMoreCallback?.invoke()
                    }
                }
            }
        })
    }
    
    private fun optimizeItemDecorations(
        recyclerView: RecyclerView,
        config: LargeDatasetConfig
    ) {
        // Remove unnecessary item decorations for better performance
        if (config.minimizeDecorations) {
            val itemCount = recyclerView.itemDecorationCount
            for (i in itemCount - 1 downTo 0) {
                val decoration = recyclerView.getItemDecorationAt(i)
                if (decoration is Rect) {
                    recyclerView.removeItemDecorationAt(i)
                }
            }
        }
    }
    
    private suspend fun collectPerformanceMetrics(recyclerView: RecyclerView): RecyclerViewMetrics {
        return RecyclerViewMetrics(
            averageFrameTime = averageScrollTime.get(),
            memoryUsage = estimateMemoryUsage(recyclerView),
            adapterCount = recyclerView.adapter?.itemCount ?: 0,
            layoutManagerType = recyclerView.layoutManager?.javaClass?.simpleName ?: "Unknown"
        )
    }
    
    private fun estimateMemoryUsage(recyclerView: RecyclerView): Long {
        // Rough estimation of memory usage
        val adapter = recyclerView.adapter
        val itemCount = adapter?.itemCount ?: 0
        val viewHolderCount = recyclerView.layoutManager?.childCount ?: 0
        
        return (itemCount * 1024L) + (viewHolderCount * 2048L) // Rough estimation
    }
    
    private fun getDefaultConfig(): RecyclerViewConfig {
        return RecyclerViewConfig(
            itemViewCacheSize = defaultItemViewCacheSize,
            drawingCacheEnabled = defaultDrawingCacheEnabled,
            hasFixedSize = defaultHasFixedSize,
            nestedScrollingEnabled = true,
            itemPrefetchEnabled = true,
            hasStableIds = true,
            disableItemAnimator = false,
            supportsPredictiveItemAnimations = true,
            clearCacheOnDetach = true,
            maxRecycledViews = 20
        )
    }
    
    /**
     * Clean up resources
     */
    fun cleanup(recyclerView: RecyclerView) {
        val key = recyclerView.hashCode().toString()
        
        // Remove scroll listener
        scrollListeners[key]?.let {
            recyclerView.removeOnScrollListener(it)
        }
        scrollListeners.remove(key)
        
        // Clear configuration
        recyclerViewConfigs.remove(key)
        
        // Clear recycled view pool
        recyclerView.recycledViewPool.clear()
        
        Timber.d("RecyclerView cleanup completed")
    }
    
    /**
     * Stop all optimization monitoring
     */
    fun stop() {
        optimizationScope.cancel()
        recyclerViewConfigs.clear()
        scrollListeners.clear()
    }
}

/**
 * Optimized RecyclerView Adapter
 */
class OptimizedRecyclerAdapter<T>(
    private var items: List<T>,
    private val itemLayout: Int,
    private val bindViewHolder: (View, T, Int) -> Unit,
    private val diffCallback: DiffUtil.Callback? = null
) : RecyclerView.Adapter<OptimizedViewHolder>() {
    
    override fun onCreateViewHolder(parent: android.view.ViewGroup, viewType: Int): OptimizedViewHolder {
        val view = android.view.LayoutInflater.from(parent.context).inflate(itemLayout, parent, false)
        return OptimizedViewHolder(view)
    }
    
    override fun onBindViewHolder(holder: OptimizedViewHolder, position: Int) {
        bindViewHolder(holder.itemView, items[position], position)
    }
    
    override fun getItemCount(): Int = items.size
    
    override fun getItemId(position: Int): Long {
        return items[position]?.hashCode()?.toLong() ?: position.toLong()
    }
    
    fun updateItems(newItems: List<T>) {
        if (diffCallback != null) {
            val result = DiffUtil.calculateDiff(diffCallback)
            items = newItems
            result.dispatchUpdatesTo(this)
        } else {
            items = newItems
            notifyDataSetChanged()
        }
    }
}

/**
 * Optimized ViewHolder
 */
class OptimizedViewHolder(itemView: View) : RecyclerView.ViewHolder(itemView)

/**
 * Optimized Item Animator
 */
class OptimizedItemAnimator : androidx.recyclerview.widget.DefaultItemAnimator() {
    init {
        addDuration = 100
        removeDuration = 100
        changeDuration = 100
        moveDuration = 100
    }
}

/**
 * Data Classes
 */
data class RecyclerViewConfig(
    val itemViewCacheSize: Int = 20,
    val drawingCacheEnabled: Boolean = true,
    val hasFixedSize: Boolean = true,
    val nestedScrollingEnabled: Boolean = true,
    val itemPrefetchEnabled: Boolean = true,
    val hasStableIds: Boolean = true,
    val disableItemAnimator: Boolean = false,
    val supportsPredictiveItemAnimations: Boolean = true,
    val clearCacheOnDetach: Boolean = true,
    val maxRecycledViews: Int = 20
)

data class SmoothScrollConfig(
    val enableSmoothScrolling: Boolean = true,
    val scrollThreshold: Int = 5,
    val scrollDelay: Long = 16L,
    val clearCacheOnIdle: Boolean = false
)

data class LargeDatasetConfig(
    val itemCacheSize: Int = 50,
    val maxRecycledViews: Int = 50,
    val maxRecycledViewsPerType: Int = 25,
    val viewTypeCount: Int = 5,
    val enablePagination: Boolean = false,
    val minimizeDecorations: Boolean = true,
    val isLoading: Boolean = false,
    val isLastPage: Boolean = false,
    val loadMoreCallback: (() -> Unit)? = null
)

data class RecyclerViewPerformanceStats(
    val totalScrollEvents: Long,
    val smoothScrollEvents: Long,
    val adapterUpdates: Long,
    val averageScrollTime: Long,
    val itemViewCacheSize: Int,
    val hasFixedSize: Boolean,
    val drawingCacheEnabled: Boolean,
    val layoutManagerType: String,
    val adapterType: String
) {
    val smoothScrollRate: Double get() = if (totalScrollEvents > 0) smoothScrollEvents.toDouble() / totalScrollEvents else 0.0
}

data class RecyclerViewMetrics(
    val averageFrameTime: Long,
    val memoryUsage: Long,
    val adapterCount: Int,
    val layoutManagerType: String
)
