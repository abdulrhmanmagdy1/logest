@Composable
fun AlertIndicator(
    alert: AlertIndicator,
    isLiveMode: Boolean
) {
    var blinkAnimation by remember { mutableStateOf(false) }
    
    LaunchedEffect(isLiveMode) {
        if (isLiveMode && alert.severity == "CRITICAL") {
            while (true) {
                delay(500)
                blinkAnimation = !blinkAnimation
            }
        }
    }
    
    Row(
        modifier = Modifier
            .fillMaxWidth()
            .clip(RoundedCornerShape(8.dp))
            .background(
                color = alert.color.copy(
                    alpha = if (blinkAnimation && alert.severity == "CRITICAL") 0.3f else 0.1f
                )
            )
            .padding(12.dp),
        horizontalArrangement = Arrangement.SpaceBetween,
        verticalAlignment = Alignment.CenterVertically
    ) {
        Row(
            verticalAlignment = Alignment.CenterVertically
        ) {
            Box(
                modifier = Modifier
                    .size(12.dp)
                    .background(
                        color = alert.color,
                        shape = CircleShape
                    )
            )
            
            Spacer(modifier = Modifier.width(12.dp))
            
            Column {
                Text(
                    text = alert.title,
                    style = MaterialTheme.typography.bodyMedium,
                    color = MaterialTheme.colorScheme.onSurface,
                    fontWeight = FontWeight.Medium
                )
                
                Text(
                    text = alert.description,
                    style = MaterialTheme.typography.bodySmall,
                    color = MaterialTheme.colorScheme.onSurface.copy(alpha = 0.7f)
                )
            }
        }
        
        Row(
            verticalAlignment = Alignment.CenterVertically
        ) {
            Text(
                text = alert.count.toString(),
                style = MaterialTheme.typography.titleMedium,
                color = alert.color,
                fontWeight = FontWeight.Bold
            )
            
            if (isLiveMode) {
                Spacer(modifier = Modifier.width(8.dp))
                Box(
                    modifier = Modifier
                        .size(6.dp)
                        .background(
                            color = SuccessGreen,
                            shape = CircleShape
                        )
                )
            }
        }
    }
}

