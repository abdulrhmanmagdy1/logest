@Composable
fun StatusLight(
    light: StatusLight,
    isLiveMode: Boolean
) {
    var pulseAnimation by remember { mutableStateOf(false) }
    
    LaunchedEffect(isLiveMode) {
        if (isLiveMode && light.isActive) {
            while (true) {
                delay(1000)
                pulseAnimation = !pulseAnimation
            }
        }
    }
    
    Column(
        horizontalAlignment = Alignment.CenterHorizontally
    ) {
        Box(
            modifier = Modifier.size(60.dp),
            contentAlignment = Alignment.Center
        ) {
            // Glow effect
            if (light.isActive && isLiveMode) {
                Box(
                    modifier = Modifier
                        .size(if (pulseAnimation) 60.dp else 50.dp)
                        .background(
                            color = light.color.copy(alpha = 0.3f),
                            shape = CircleShape
                        )
                        .animateContentSize(
                            animationSpec = tween(500)
                        )
                )
            }
            
            // Main light
            Box(
                modifier = Modifier
                    .size(40.dp)
                    .background(
                        color = if (light.isActive) light.color else MaterialTheme.colorScheme.surfaceVariant,
                        shape = CircleShape
                    )
            )
        }
        
        Spacer(modifier = Modifier.height(8.dp))
        
        Text(
            text = light.name,
            style = MaterialTheme.typography.bodySmall,
            color = MaterialTheme.colorScheme.onSurface,
            textAlign = TextAlign.Center
        )
        
        Text(
            text = if (light.isActive) "ON" else "OFF",
            style = MaterialTheme.typography.bodySmall,
            color = if (light.isActive) light.color else MaterialTheme.colorScheme.onSurface.copy(alpha = 0.5f),
            fontWeight = FontWeight.Bold
        )
    }
}

