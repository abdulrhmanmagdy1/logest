// Data classes
data class SystemStatusIndicator(
    val name: String,
    val status: String,
    val statusColor: Color
)

data class PerformanceGauge(
    val name: String,
    val value: Float,
    val color: Color
)

data class AlertIndicator(
    val title: String,
    val description: String,
    val count: Int,
    val severity: String,
    val color: Color
)

data class ProgressIndicator(
    val name: String,
    val description: String,
    val progress: Float,
    val color: Color
)

data class StatusLight(
    val name: String,
    val isActive: Boolean,
    val color: Color
)

data class LiveMetric(
    val name: String,
    val value: Float,
    val formattedValue: String,
    val color: Color
)

data class RealTimeIndicatorsData(
    val systemStatus: List<SystemStatusIndicator>,
    val performanceGauges: List<PerformanceGauge>,
    val alertIndicators: List<AlertIndicator>,
    val progressIndicators: List<ProgressIndicator>,
    val statusLights: List<StatusLight>,
    val liveMetrics: List<LiveMetric>
)
