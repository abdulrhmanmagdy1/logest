@Composable
fun PerformanceGauge(
    gauge: PerformanceGauge,
    isLiveMode: Boolean
) {
    var animatedValue by remember { mutableStateOf(0f) }
    
    LaunchedEffect(gauge.value) {
        animatedValue = gauge.value
    }
    
    Card(
        modifier = Modifier
            .width(150.dp)
            .height(150.dp),
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.surface
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier
                .fillMaxSize()
                .padding(16.dp),
            horizontalAlignment = Alignment.CenterHorizontally,
            verticalArrangement = Arrangement.SpaceBetween
        ) {
            // Circular gauge
            Box(
                modifier = Modifier.size(80.dp),
                contentAlignment = Alignment.Center
            ) {
                Canvas(
                    modifier = Modifier.size(80.dp)
                ) { canvas ->
                    drawCircularGauge(
                        value = animatedValue,
                        maxValue = 100f,
                        primaryColor = gauge.color,
                        backgroundColor = MaterialTheme.colorScheme.surfaceVariant,
                        size = Size(80f, 80f)
                    )
                }
                
                Column(
                    horizontalAlignment = Alignment.CenterHorizontally
                ) {
                    Text(
                        text = "${String.format("%.0f", animatedValue)}%",
                        style = MaterialTheme.typography.titleMedium,
                        color = gauge.color,
                        fontWeight = FontWeight.Bold
                    )
                    
                    if (isLiveMode) {
                        Box(
                            modifier = Modifier
                                .size(6.dp)
                                .background(
                                    color = SuccessGreen,
                                    shape = CircleShape
                                )
                        )
                    }
                }
            }
            
            Text(
                text = gauge.name,
                style = MaterialTheme.typography.bodySmall,
                color = MaterialTheme.colorScheme.onSurface,
                textAlign = TextAlign.Center,
                maxLines = 2
            )
        }
    }
}

private fun DrawScope.drawCircularGauge(
    value: Float,
    maxValue: Float,
    primaryColor: Color,
    backgroundColor: Color,
    size: Size
) {
    val strokeWidth = 8.dp.toPx()
    val sweepAngle = (value / maxValue) * 270f // 270 degrees arc
    val startAngle = -135f // Start from top-left
    
    // Background arc
    drawArc(
        color = backgroundColor,
        startAngle = startAngle,
        sweepAngle = 270f,
        useCenter = false,
        style = Stroke(width = strokeWidth),
        size = size,
        topLeft = Offset(0f, 0f)
    )
    
    // Value arc
    drawArc(
        color = primaryColor,
        startAngle = startAngle,
        sweepAngle = sweepAngle,
        useCenter = false,
        style = Stroke(width = strokeWidth),
        size = size,
        topLeft = Offset(0f, 0f)
    )
}

