@Composable
fun SystemStatusIndicator(
    indicator: SystemStatusIndicator,
    isLiveMode: Boolean
) {
    var pulseAnimation by remember { mutableStateOf(false) }
    
    LaunchedEffect(isLiveMode) {
        if (isLiveMode) {
            while (true) {
                delay(1000)
                pulseAnimation = !pulseAnimation
            }
        }
    }
    
    Card(
        modifier = Modifier
            .width(120.dp)
            .height(100.dp),
        colors = CardDefaults.cardColors(
            containerColor = indicator.statusColor.copy(alpha = 0.1f)
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier
                .fillMaxSize()
                .padding(12.dp),
            horizontalAlignment = Alignment.CenterHorizontally,
            verticalArrangement = Arrangement.SpaceBetween
        ) {
            // Status indicator with animation
            Box(
                modifier = Modifier.size(32.dp),
                contentAlignment = Alignment.Center
            ) {
                if (isLiveMode && indicator.status == "ACTIVE") {
                    Box(
                        modifier = Modifier
                            .size(32.dp)
                            .background(
                                color = indicator.statusColor.copy(alpha = 0.3f),
                                shape = CircleShape
                            )
                    )
                    Box(
                        modifier = Modifier
                            .size(if (pulseAnimation) 28.dp else 24.dp)
                            .background(
                                color = indicator.statusColor,
                                shape = CircleShape
                            )
                            .animateContentSize(
                                animationSpec = tween(500)
                            )
                    )
                } else {
                    Box(
                        modifier = Modifier
                            .size(24.dp)
                            .background(
                                color = indicator.statusColor,
                                shape = CircleShape
                            )
                    )
                }
            }
            
            Column(
                horizontalAlignment = Alignment.CenterHorizontally
            ) {
                Text(
                    text = indicator.name,
                    style = MaterialTheme.typography.bodySmall,
                    color = MaterialTheme.colorScheme.onSurface,
                    textAlign = TextAlign.Center,
                    maxLines = 1
                )
                
                Text(
                    text = indicator.status,
                    style = MaterialTheme.typography.bodySmall,
                    color = indicator.statusColor,
                    fontWeight = FontWeight.Bold,
                    textAlign = TextAlign.Center
                )
            }
        }
    }
}

