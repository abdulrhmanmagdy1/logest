package com.edham.logistics.presentation.reports

import androidx.lifecycle.ViewModel
import androidx.lifecycle.viewModelScope
import com.edham.logistics.core.reports.ReportManager
import com.edham.logistics.core.reports.data.*
import com.edham.logistics.domain.reports.ReportUseCases
import dagger.hilt.android.lifecycle.HiltViewModel
import kotlinx.coroutines.flow.MutableStateFlow
import kotlinx.coroutines.flow.StateFlow
import kotlinx.coroutines.flow.asStateFlow
import kotlinx.coroutines.launch
import java.util.*
import javax.inject.Inject

/**
 * Report ViewModel - MVVM ViewModel for business intelligence reports
 * Manages UI state and business logic for report generation and management
 */
@HiltViewModel
class ReportViewModel @Inject constructor(
    private val reportUseCases: ReportUseCases,
    private val reportManager: ReportManager
) : ViewModel() {

    // UI State
    private val _uiState = MutableStateFlow(ReportUiState())
    val uiState: StateFlow<ReportUiState> = _uiState.asStateFlow()

    // Report States
    private val _revenueReportState = MutableStateFlow<ReportState<RevenueReport>>(ReportState.Idle)
    val revenueReportState: StateFlow<ReportState<RevenueReport>> = _revenueReportState.asStateFlow()

    private val _shipmentReportState = MutableStateFlow<ReportState<ShipmentPerformanceReport>>(ReportState.Idle)
    val shipmentReportState: StateFlow<ReportState<ShipmentPerformanceReport>> = _shipmentReportState.asStateFlow()

    private val _driverReportState = MutableStateFlow<ReportState<DriverPerformanceReport>>(ReportState.Idle)
    val driverReportState: StateFlow<ReportState<DriverPerformanceReport>> = _driverReportState.asStateFlow()

    private val _customerReportState = MutableStateFlow<ReportState<CustomerBehaviorReport>>(ReportState.Idle)
    val customerReportState: StateFlow<ReportState<CustomerBehaviorReport>> = _customerReportState.asStateFlow()

    // Report History
    private val _reportHistory = MutableStateFlow<List<ReportHistory>>(emptyList())
    val reportHistory: StateFlow<List<ReportHistory>> = _reportHistory.asStateFlow()

    // Export State
    private val _exportState = MutableStateFlow<ExportState>(ExportState.Idle)
    val exportState: StateFlow<ExportState> = _exportState.asStateFlow()

    init {
        loadReportHistory()
    }

    // Revenue Report Generation
    fun generateRevenueReport(
        startDate: Long,
        endDate: Long,
        reportType: RevenueReportType = RevenueReportType.DETAILED
    ) {
        viewModelScope.launch {
            _revenueReportState.value = ReportState.Loading
            try {
                val result = reportUseCases.generateRevenueReport(startDate, endDate, reportType)
                if (result.isSuccess) {
                    _revenueReportState.value = ReportState.Success(result.getOrNull()!!)
                    saveReport(result.getOrNull()!!)
                } else {
                    _revenueReportState.value = ReportState.Error(result.exceptionOrNull()?.message ?: "Unknown error")
                }
            } catch (e: Exception) {
                _revenueReportState.value = ReportState.Error(e.message ?: "Unknown error")
            }
        }
    }

    // Shipment Performance Report Generation
    fun generateShipmentPerformanceReport(
        startDate: Long,
        endDate: Long,
        reportType: ShipmentReportType = ShipmentReportType.COMPREHENSIVE
    ) {
        viewModelScope.launch {
            _shipmentReportState.value = ReportState.Loading
            try {
                val result = reportUseCases.generateShipmentPerformanceReport(startDate, endDate, reportType)
                if (result.isSuccess) {
                    _shipmentReportState.value = ReportState.Success(result.getOrNull()!!)
                    saveReport(result.getOrNull()!!)
                } else {
                    _shipmentReportState.value = ReportState.Error(result.exceptionOrNull()?.message ?: "Unknown error")
                }
            } catch (e: Exception) {
                _shipmentReportState.value = ReportState.Error(e.message ?: "Unknown error")
            }
        }
    }

    // Driver Performance Report Generation
    fun generateDriverPerformanceReport(
        startDate: Long,
        endDate: Long,
        reportType: DriverReportType = DriverReportType.DETAILED
    ) {
        viewModelScope.launch {
            _driverReportState.value = ReportState.Loading
            try {
                val result = reportUseCases.generateDriverPerformanceReport(startDate, endDate, reportType)
                if (result.isSuccess) {
                    _driverReportState.value = ReportState.Success(result.getOrNull()!!)
                    saveReport(result.getOrNull()!!)
                } else {
                    _driverReportState.value = ReportState.Error(result.exceptionOrNull()?.message ?: "Unknown error")
                }
            } catch (e: Exception) {
                _driverReportState.value = ReportState.Error(e.message ?: "Unknown error")
            }
        }
    }

    // Customer Behavior Report Generation
    fun generateCustomerBehaviorReport(
        startDate: Long,
        endDate: Long,
        reportType: CustomerReportType = CustomerReportType.COMPREHENSIVE
    ) {
        viewModelScope.launch {
            _customerReportState.value = ReportState.Loading
            try {
                val result = reportUseCases.generateCustomerBehaviorReport(startDate, endDate, reportType)
                if (result.isSuccess) {
                    _customerReportState.value = ReportState.Success(result.getOrNull()!!)
                    saveReport(result.getOrNull()!!)
                } else {
                    _customerReportState.value = ReportState.Error(result.exceptionOrNull()?.message ?: "Unknown error")
                }
            } catch (e: Exception) {
                _customerReportState.value = ReportState.Error(e.message ?: "Unknown error")
            }
        }
    }

    // Export Functions
    fun exportToPDF(report: Any, fileName: String) {
        viewModelScope.launch {
            _exportState.value = ExportState.Loading
            try {
                val filePath = when (report) {
                    is RevenueReport -> reportManager.exportToPDF(report, fileName)
                    is ShipmentPerformanceReport -> reportManager.exportToPDF(report, fileName)
                    is DriverPerformanceReport -> reportManager.exportToPDF(report, fileName)
                    is CustomerBehaviorReport -> reportManager.exportToPDF(report, fileName)
                    else -> throw IllegalArgumentException("Unsupported report type")
                }
                _exportState.value = ExportState.Success(filePath)
            } catch (e: Exception) {
                _exportState.value = ExportState.Error(e.message ?: "Export failed")
            }
        }
    }

    fun exportToExcel(report: Any, fileName: String) {
        viewModelScope.launch {
            _exportState.value = ExportState.Loading
            try {
                val filePath = when (report) {
                    is RevenueReport -> reportManager.exportToExcel(report, fileName)
                    is ShipmentPerformanceReport -> reportManager.exportToExcel(report, fileName)
                    is DriverPerformanceReport -> reportManager.exportToExcel(report, fileName)
                    is CustomerBehaviorReport -> reportManager.exportToExcel(report, fileName)
                    else -> throw IllegalArgumentException("Unsupported report type")
                }
                _exportState.value = ExportState.Success(filePath)
            } catch (e: Exception) {
                _exportState.value = ExportState.Error(e.message ?: "Export failed")
            }
        }
    }

    // Report Management
    private fun saveReport(report: Any) {
        viewModelScope.launch {
            try {
                when (report) {
                    is RevenueReport -> reportUseCases.saveReport(report)
                    is ShipmentPerformanceReport -> reportUseCases.saveReport(report)
                    is DriverPerformanceReport -> reportUseCases.saveReport(report)
                    is CustomerBehaviorReport -> reportUseCases.saveReport(report)
                }
                loadReportHistory()
            } catch (e: Exception) {
                // Handle save error
            }
        }
    }

    fun deleteReport(reportId: String, reportType: String) {
        viewModelScope.launch {
            try {
                reportUseCases.deleteReport(reportId, reportType)
                loadReportHistory()
            } catch (e: Exception) {
                // Handle delete error
            }
        }
    }

    fun getReportById(reportId: String, reportType: String) {
        viewModelScope.launch {
            try {
                val result = reportUseCases.getReportById(reportId, reportType)
                if (result.isSuccess) {
                    when (val report = result.getOrNull()) {
                        is RevenueReport -> _revenueReportState.value = ReportState.Success(report)
                        is ShipmentPerformanceReport -> _shipmentReportState.value = ReportState.Success(report)
                        is DriverPerformanceReport -> _driverReportState.value = ReportState.Success(report)
                        is CustomerBehaviorReport -> _customerReportState.value = ReportState.Success(report)
                    }
                }
            } catch (e: Exception) {
                // Handle load error
            }
        }
    }

    // Report History
    private fun loadReportHistory() {
        viewModelScope.launch {
            try {
                reportUseCases.getReportHistory().collect { history ->
                    _reportHistory.value = history
                }
            } catch (e: Exception) {
                // Handle load error
            }
        }
    }

    // UI State Management
    fun updateReportFilters(filters: ReportFilters) {
        _uiState.value = _uiState.value.copy(filters = filters)
    }

    fun updateSelectedReportType(reportType: ReportType) {
        _uiState.value = _uiState.value.copy(selectedReportType = reportType)
    }

    fun updateDateRange(startDate: Long, endDate: Long) {
        _uiState.value = _uiState.value.copy(
            startDate = startDate,
            endDate = endDate
        )
    }

    fun clearReportState(reportType: ReportType) {
        when (reportType) {
            ReportType.REVENUE -> _revenueReportState.value = ReportState.Idle
            ReportType.SHIPMENT -> _shipmentReportState.value = ReportState.Idle
            ReportType.DRIVER -> _driverReportState.value = ReportState.Idle
            ReportType.CUSTOMER -> _customerReportState.value = ReportState.Idle
        }
    }

    fun clearExportState() {
        _exportState.value = ExportState.Idle
    }

    // Utility Functions
    fun getCurrentReportType(): ReportType {
        return _uiState.value.selectedReportType
    }

    fun getCurrentDateRange(): Pair<Long, Long> {
        return Pair(_uiState.value.startDate, _uiState.value.endDate)
    }

    fun getCurrentFilters(): ReportFilters {
        return _uiState.value.filters
    }

    // Quick Report Generation
    fun generateTodayRevenueReport() {
        val today = Calendar.getInstance()
        val startOfDay = today.apply {
            set(Calendar.HOUR_OF_DAY, 0)
            set(Calendar.MINUTE, 0)
            set(Calendar.SECOND, 0)
            set(Calendar.MILLISECOND, 0)
        }.timeInMillis
        
        val endOfDay = today.apply {
            set(Calendar.HOUR_OF_DAY, 23)
            set(Calendar.MINUTE, 59)
            set(Calendar.SECOND, 59)
            set(Calendar.MILLISECOND, 999)
        }.timeInMillis
        
        generateRevenueReport(startOfDay, endOfDay, RevenueReportType.DAILY)
    }

    fun generateThisMonthShipmentReport() {
        val today = Calendar.getInstance()
        val startOfMonth = today.apply {
            set(Calendar.DAY_OF_MONTH, 1)
            set(Calendar.HOUR_OF_DAY, 0)
            set(Calendar.MINUTE, 0)
            set(Calendar.SECOND, 0)
            set(Calendar.MILLISECOND, 0)
        }.timeInMillis
        
        val endOfMonth = today.apply {
            set(Calendar.DAY_OF_MONTH, getActualMaximum(Calendar.DAY_OF_MONTH))
            set(Calendar.HOUR_OF_DAY, 23)
            set(Calendar.MINUTE, 59)
            set(Calendar.SECOND, 59)
            set(Calendar.MILLISECOND, 999)
        }.timeInMillis
        
        generateShipmentPerformanceReport(startOfMonth, endOfMonth, ShipmentReportType.COMPREHENSIVE)
    }

    fun generateThisQuarterDriverReport() {
        val today = Calendar.getInstance()
        val currentMonth = today.get(Calendar.MONTH)
        val quarterStartMonth = (currentMonth / 3) * 3
        
        val startOfQuarter = today.apply {
            set(Calendar.MONTH, quarterStartMonth)
            set(Calendar.DAY_OF_MONTH, 1)
            set(Calendar.HOUR_OF_DAY, 0)
            set(Calendar.MINUTE, 0)
            set(Calendar.SECOND, 0)
            set(Calendar.MILLISECOND, 0)
        }.timeInMillis
        
        val endOfQuarter = today.apply {
            set(Calendar.MONTH, quarterStartMonth + 2)
            set(Calendar.DAY_OF_MONTH, getActualMaximum(Calendar.DAY_OF_MONTH))
            set(Calendar.HOUR_OF_DAY, 23)
            set(Calendar.MINUTE, 59)
            set(Calendar.SECOND, 59)
            set(Calendar.MILLISECOND, 999)
        }.timeInMillis
        
        generateDriverPerformanceReport(startOfQuarter, endOfQuarter, DriverReportType.DETAILED)
    }

    fun generateThisYearCustomerReport() {
        val today = Calendar.getInstance()
        val startOfYear = today.apply {
            set(Calendar.DAY_OF_YEAR, 1)
            set(Calendar.HOUR_OF_DAY, 0)
            set(Calendar.MINUTE, 0)
            set(Calendar.SECOND, 0)
            set(Calendar.MILLISECOND, 0)
        }.timeInMillis
        
        val endOfYear = today.apply {
            set(Calendar.DAY_OF_YEAR, getActualMaximum(Calendar.DAY_OF_YEAR))
            set(Calendar.HOUR_OF_DAY, 23)
            set(Calendar.MINUTE, 59)
            set(Calendar.SECOND, 59)
            set(Calendar.MILLISECOND, 999)
        }.timeInMillis
        
        generateCustomerBehaviorReport(startOfYear, endOfYear, CustomerReportType.COMPREHENSIVE)
    }
}

// UI State Data Classes
data class ReportUiState(
    val selectedReportType: ReportType = ReportType.REVENUE,
    val startDate: Long = getDefaultStartDate(),
    val endDate: Long = System.currentTimeMillis(),
    val filters: ReportFilters = ReportFilters()
)

data class ReportFilters(
    val customerIds: List<String> = emptyList(),
    val driverIds: List<String> = emptyList(),
    val vehicleTypes: List<String> = emptyList(),
    val serviceTypes: List<String> = emptyList(),
    val locations: List<String> = emptyList(),
    val statusFilters: List<String> = emptyList(),
    val minAmount: Double? = null,
    val maxAmount: Double? = null
)

// Report State
sealed class ReportState<out T> {
    object Idle : ReportState<Nothing>()
    object Loading : ReportState<Nothing>()
    data class Success<T>(val data: T) : ReportState<T>()
    data class Error(val message: String) : ReportState<Nothing>()
}

// Export State
sealed class ExportState {
    object Idle : ExportState()
    object Loading : ExportState()
    data class Success(val filePath: String) : ExportState()
    data class Error(val message: String) : ExportState()
}

// Report Types
enum class ReportType {
    REVENUE, SHIPMENT, DRIVER, CUSTOMER
}

// Utility Functions
fun getDefaultStartDate(): Long {
    val calendar = Calendar.getInstance()
    calendar.add(Calendar.DAY_OF_YEAR, -30)
    calendar.set(Calendar.HOUR_OF_DAY, 0)
    calendar.set(Calendar.MINUTE, 0)
    calendar.set(Calendar.SECOND, 0)
    calendar.set(Calendar.MILLISECOND, 0)
    return calendar.timeInMillis
}
