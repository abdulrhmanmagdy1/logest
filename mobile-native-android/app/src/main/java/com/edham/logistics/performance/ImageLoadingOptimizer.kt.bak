package com.edham.logistics.performance

import android.content.Context
import android.graphics.Bitmap
import android.graphics.BitmapFactory
import android.graphics.drawable.Drawable
import com.bumptech.glide.Glide
import com.bumptech.glide.load.engine.DiskCacheStrategy
import com.bumptech.glide.load.resource.bitmap.DownsampleStrategy
import com.bumptech.glide.request.RequestOptions
import kotlinx.coroutines.*
import java.io.File
import java.io.FileOutputStream
import java.net.URL
import java.util.concurrent.ConcurrentHashMap

/**
 * Image Loading Optimizer
 * Optimizes image loading, caching, and memory usage
 */
class ImageLoadingOptimizer(private val context: Context) {

    companion object {
        private const val MEMORY_CACHE_SIZE = 100
        private const val DISK_CACHE_SIZE = 50 * 1024 * 1024L // 50MB
        private const val MAX_IMAGE_WIDTH = 1024
        private const val MAX_IMAGE_HEIGHT = 1024
        private const val COMPRESSION_QUALITY = 85
    }

    private val memoryCache = ConcurrentHashMap<String, Bitmap>()
    private val diskCacheDir = File(context.cacheDir, "image_cache")
    private val imageScope = CoroutineScope(Dispatchers.IO + SupervisorJob())

    init {
        if (!diskCacheDir.exists()) {
            diskCacheDir.mkdirs()
        }
    }

    /**
     * Load image with optimizations
     */
    fun loadImage(
        url: String,
        targetWidth: Int = MAX_IMAGE_WIDTH,
        targetHeight: Int = MAX_IMAGE_HEIGHT,
        callback: (Bitmap?) -> Unit
    ) {
        imageScope.launch {
            try {
                // Check memory cache first
                memoryCache[url]?.let { cachedBitmap ->
                    callback(cachedBitmap)
                    return@launch
                }

                // Check disk cache
                val cachedFile = File(diskCacheDir, getCacheKey(url))
                if (cachedFile.exists()) {
                    val bitmap = BitmapFactory.decodeFile(cachedFile.absolutePath)
                    if (bitmap != null) {
                        memoryCache[url] = bitmap
                        callback(bitmap)
                        return@launch
                    }
                }

                // Load from network
                val bitmap = loadBitmapFromNetwork(url, targetWidth, targetHeight)
                if (bitmap != null) {
                    // Cache in memory
                    if (memoryCache.size < MEMORY_CACHE_SIZE) {
                        memoryCache[url] = bitmap
                    }

                    // Cache to disk
                    saveBitmapToDisk(bitmap, url)

                    callback(bitmap)
                } else {
                    callback(null)
                }

            } catch (e: Exception) {
                callback(null)
            }
        }
    }

    /**
     * Load image using Glide with optimizations
     */
    fun loadImageWithGlide(
        url: String,
        into: android.widget.ImageView,
        options: RequestOptions = defaultGlideOptions()
    ) {
        Glide.with(context)
            .load(url)
            .apply(options)
            .into(into)
    }

    /**
     * Preload images
     */
    fun preloadImages(urls: List<String>) {
        imageScope.launch {
            urls.chunked(5).forEach { chunk ->
                chunk.forEach { url ->
                    try {
                        loadImage(url) { /* Preload only */ }
                    } catch (e: Exception) {
                        // Continue with other images
                    }
                }
                delay(100) // Small delay between chunks
            }
        }
    }

    /**
     * Optimize bitmap
     */
    fun optimizeBitmap(bitmap: Bitmap): Bitmap {
        val width = bitmap.width
        val height = bitmap.height

        // Check if optimization is needed
        if (width <= MAX_IMAGE_WIDTH && height <= MAX_IMAGE_HEIGHT) {
            return bitmap
        }

        // Calculate new dimensions
        val ratio = minOf(
            MAX_IMAGE_WIDTH.toFloat() / width,
            MAX_IMAGE_HEIGHT.toFloat() / height
        )
        val newWidth = (width * ratio).toInt()
        val newHeight = (height * ratio).toInt()

        return Bitmap.createScaledBitmap(bitmap, newWidth, newHeight, true)
    }

    /**
     * Compress bitmap
     */
    fun compressBitmap(bitmap: Bitmap, quality: Int = COMPRESSION_QUALITY): Bitmap {
        // Create a compressed version
        val stream = java.io.ByteArrayOutputStream()
        bitmap.compress(Bitmap.CompressFormat.JPEG, quality, stream)
        
        // Decode compressed bitmap
        val compressedData = stream.toByteArray()
        return BitmapFactory.decodeByteArray(compressedData, 0, compressedData.size)
    }

    /**
     * Clear caches
     */
    fun clearMemoryCache() {
        memoryCache.clear()
    }

    fun clearDiskCache() {
        diskCacheDir.listFiles()?.forEach { it.delete() }
    }

    fun clearAllCaches() {
        clearMemoryCache()
        clearDiskCache()
    }

    /**
     * Get cache statistics
     */
    fun getCacheStats(): ImageCacheStats {
        val memoryCacheSize = memoryCache.values.sumOf { it.byteCount }
        val diskCacheSize = diskCacheDir.walkTopDown().sumOf { it.length() }

        return ImageCacheStats(
            memoryCacheCount = memoryCache.size,
            memoryCacheSize = memoryCacheSize,
            diskCacheCount = diskCacheDir.listFiles()?.size ?: 0,
            diskCacheSize = diskCacheSize
        )
    }

    // Private helper methods
    private fun loadBitmapFromNetwork(url: String, targetWidth: Int, targetHeight: Int): Bitmap? {
        return try {
            val connection = URL(url).openConnection()
            connection.doInput = true
            connection.connect()

            val inputStream = connection.getInputStream()
            val options = BitmapFactory.Options().apply {
                inJustDecodeBounds = true
            }

            // Get image dimensions
            BitmapFactory.decodeStream(inputStream, null, options)
            
            // Calculate sample size
            options.inSampleSize = calculateInSampleSize(options, targetWidth, targetHeight)
            options.inJustDecodeBounds = false

            // Decode with sample size
            val bitmap = BitmapFactory.decodeStream(URL(url).openStream(), null, options)
            
            // Optimize further if needed
            bitmap?.let { optimizeBitmap(it) }

        } catch (e: Exception) {
            null
        }
    }

    private fun calculateInSampleSize(
        options: BitmapFactory.Options,
        reqWidth: Int,
        reqHeight: Int
    ): Int {
        val height = options.outHeight
        val width = options.outWidth
        var inSampleSize = 1

        if (height > reqHeight || width > reqWidth) {
            val halfHeight = height / 2
            val halfWidth = width / 2

            while (halfHeight / inSampleSize >= reqHeight && halfWidth / inSampleSize >= reqWidth) {
                inSampleSize *= 2
            }
        }

        return inSampleSize
    }

    private fun saveBitmapToDisk(bitmap: Bitmap, url: String) {
        try {
            val file = File(diskCacheDir, getCacheKey(url))
            val outputStream = FileOutputStream(file)
            bitmap.compress(Bitmap.CompressFormat.JPEG, COMPRESSION_QUALITY, outputStream)
            outputStream.close()
        } catch (e: Exception) {
            // Handle error silently
        }
    }

    private fun getCacheKey(url: String): String {
        return url.hashCode().toString()
    }

    private fun defaultGlideOptions(): RequestOptions {
        return RequestOptions()
            .diskCacheStrategy(DiskCacheStrategy.ALL)
            .skipMemoryCache(false)
            .downsample(DownsampleStrategy.CENTER_INSIDE)
            .override(MAX_IMAGE_WIDTH, MAX_IMAGE_HEIGHT)
            .centerCrop()
    }

    // Data classes
    data class ImageCacheStats(
        val memoryCacheCount: Int,
        val memoryCacheSize: Long,
        val diskCacheCount: Int,
        val diskCacheSize: Long
    )

    /**
     * Image loading strategies
     */
    enum class LoadingStrategy {
        FAST,        // Prioritize speed over quality
        BALANCED,    // Balance speed and quality
        QUALITY      // Prioritize quality over speed
    }

    /**
     * Image loading configuration
     */
    data class ImageLoadingConfig(
        val strategy: LoadingStrategy = LoadingStrategy.BALANCED,
        val enableMemoryCache: Boolean = true,
        val enableDiskCache: Boolean = true,
        val maxMemoryCacheSize: Int = MEMORY_CACHE_SIZE,
        val maxDiskCacheSize: Long = DISK_CACHE_SIZE,
        val compressionQuality: Int = COMPRESSION_QUALITY,
        val maxImageWidth: Int = MAX_IMAGE_WIDTH,
        val maxImageHeight: Int = MAX_IMAGE_HEIGHT
    )

    /**
     * Image loading builder
     */
    class Builder(private val context: Context) {
        private var config = ImageLoadingConfig()

        fun strategy(strategy: LoadingStrategy) = apply {
            config = config.copy(strategy = strategy)
        }

        fun enableMemoryCache(enable: Boolean) = apply {
            config = config.copy(enableMemoryCache = enable)
        }

        fun enableDiskCache(enable: Boolean) = apply {
            config = config.copy(enableDiskCache = enable)
        }

        fun maxMemoryCacheSize(size: Int) = apply {
            config = config.copy(maxMemoryCacheSize = size)
        }

        fun maxDiskCacheSize(size: Long) = apply {
            config = config.copy(maxDiskCacheSize = size)
        }

        fun compressionQuality(quality: Int) = apply {
            config = config.copy(compressionQuality = quality)
        }

        fun maxImageDimensions(width: Int, height: Int) = apply {
            config = config.copy(maxImageWidth = width, maxImageHeight = height)
        }

        fun build(): ImageLoadingOptimizer {
            return ImageLoadingOptimizer(context)
        }
    }

    /**
     * Image loading utilities
     */
    object ImageUtils {
        fun calculateOptimalDimensions(
            originalWidth: Int,
            originalHeight: Int,
            maxWidth: Int,
            maxHeight: Int
        ): Pair<Int, Int> {
            val ratio = minOf(
                maxWidth.toFloat() / originalWidth,
                maxHeight.toFloat() / originalHeight
            )
            
            return if (ratio < 1) {
                Pair((originalWidth * ratio).toInt(), (originalHeight * ratio).toInt())
            } else {
                Pair(originalWidth, originalHeight)
            }
        }

        fun isImageLarge(width: Int, height: Int): Boolean {
            return width > MAX_IMAGE_WIDTH || height > MAX_IMAGE_HEIGHT
        }

        fun getMemorySize(bitmap: Bitmap): Long {
            return bitmap.byteCount.toLong()
        }

        fun formatFileSize(sizeInBytes: Long): String {
            val kb = sizeInBytes / 1024.0
            val mb = kb / 1024.0
            
            return when {
                mb >= 1.0 -> "%.1f MB".format(mb)
                kb >= 1.0 -> "%.1f KB".format(kb)
                else -> "$sizeInBytes B"
            }
        }
    }
}
