package com.edham.logistics.adapters

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.ImageView
import android.widget.TextView
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.SidebarMenuItem

class SidebarMenuAdapter(
    private val menuItems: List<SidebarMenuItem>,
    private val onItemClick: (Int) -> Unit
) : RecyclerView.Adapter<SidebarMenuAdapter.SidebarMenuViewHolder>() {

    private var selectedPosition = 0

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): SidebarMenuViewHolder {
        val view = LayoutInflater.from(parent.context)
            .inflate(R.layout.item_sidebar_menu, parent, false)
        return SidebarMenuViewHolder(view)
    }

    override fun onBindViewHolder(holder: SidebarMenuViewHolder, position: Int) {
        holder.bind(menuItems[position], position == selectedPosition)
    }

    override fun getItemCount(): Int = menuItems.size

    fun setSelectedPosition(position: Int) {
        val previousPosition = selectedPosition
        selectedPosition = position
        notifyItemChanged(previousPosition)
        notifyItemChanged(position)
    }

    inner class SidebarMenuViewHolder(itemView: View) : RecyclerView.ViewHolder(itemView) {
        private val ivMenuIcon: ImageView = itemView.findViewById(R.id.ivMenuIcon)
        private val tvMenuTitle: TextView = itemView.findViewById(R.id.tvMenuTitle)
        private val tvMenuDescription: TextView = itemView.findViewById(R.id.tvMenuDescription)
        private val menuContainer: View = itemView.findViewById(R.id.menuContainer)

        fun bind(menuItem: SidebarMenuItem, isSelected: Boolean) {
            tvMenuTitle.text = menuItem.title
            tvMenuDescription.text = menuItem.description
            ivMenuIcon.setImageResource(menuItem.icon)

            // Update selection state
            if (isSelected) {
                menuContainer.setBackgroundColor(itemView.context.getColor(R.color.primary_transparent))
                tvMenuTitle.setTextColor(itemView.context.getColor(R.color.primary))
                ivMenuIcon.setColorFilter(itemView.context.getColor(R.color.primary))
            } else {
                menuContainer.setBackgroundColor(itemView.context.getColor(android.R.color.transparent))
                tvMenuTitle.setTextColor(itemView.context.getColor(R.color.text_primary))
                ivMenuIcon.setColorFilter(itemView.context.getColor(R.color.text_primary))
            }

            itemView.setOnClickListener {
                val previousPosition = selectedPosition
                selectedPosition = adapterPosition
                notifyItemChanged(previousPosition)
                notifyItemChanged(selectedPosition)
                onItemClick(adapterPosition)
            }
        }
    }
}
