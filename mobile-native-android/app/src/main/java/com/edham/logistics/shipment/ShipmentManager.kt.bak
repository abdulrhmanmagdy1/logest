    /**
     * Get shipment statistics
     */
    suspend fun getShipmentStats(): ShipmentStats {
        return withContext(Dispatchers.IO) {
            val allShipments = database.shipmentDao().getAllShipments()
            
            val totalShipments = allShipments.size
            val completedShipments = allShipments.count { it.status == ShipmentStatus.DELIVERED }
            val inTransitShipments = allShipments.count { it.status == ShipmentStatus.IN_TRANSIT }
            val delayedShipments = allShipments.count { it.isDelayed() }
            val priorityShipments = allShipments.count { it.priority == Priority.HIGH }
            val coldChainShipments = allShipments.count { it.isColdChain }
            
            ShipmentStats(
                totalShipments = totalShipments,
                completedShipments = completedShipments,
                inTransitShipments = inTransitShipments,
                delayedShipments = delayedShipments,
                priorityShipments = priorityShipments,
                coldChainShipments = coldChainShipments,
                completionRate = if (totalShipments > 0) completedShipments.toFloat() / totalShipments else 0f,
                averageDeliveryTime = calculateAverageDeliveryTime(allShipments)
            )
        }
    }
    
    /**
     * Helper functions
     */
    private fun generateShipmentId(): String {
        val timestamp = System.currentTimeMillis()
        val random = (1000..9999).random()
        return "$SHIPMENT_ID_PREFIX-$timestamp-$random"
    }
    
    private fun generateBarcode(shipmentId: String): String {
        // Implementation would generate actual barcode
        return "BARCODE_$shipmentId"
    }
    
    private fun generateQRCode(shipmentId: String): String {
        // Implementation would generate actual QR code
        return "QRCODE_$shipmentId"
    }
    
    private suspend fun createShipmentStops(shipmentId: Long, stops: List<ShipmentStopRequest>) {
        stops.forEachIndexed { index, stopRequest ->
            val stop = ShipmentStopEntity(
                id = 0,
                shipmentId = shipmentId,
                sequence = index + 1,
                address = stopRequest.address,
                latitude = stopRequest.latitude,
                longitude = stopRequest.longitude,
                contact = stopRequest.contact,
                phone = stopRequest.phone,
                instructions = stopRequest.instructions,
                estimatedArrival = stopRequest.estimatedArrival,
                actualArrival = null,
                status = ShipmentStopStatus.PENDING,
                completedAt = null,
                createdAt = Date(),
                updatedAt = Date()
            )
            
            database.shipmentStopDao().insertStop(stop)
        }
    }
    
    private fun validateShipmentRequest(request: CreateShipmentRequest) {
        // Validate required fields
        if (request.customerId.isBlank()) throw Exception("Customer ID is required")
        if (request.customerName.isBlank()) throw Exception("Customer name is required")
        if (request.pickupAddress.isBlank()) throw Exception("Pickup address is required")
        if (request.deliveryAddress.isBlank()) throw Exception("Delivery address is required")
        
        // Validate coordinates
        if (request.pickupLatitude == 0.0 && request.pickupLongitude == 0.0) {
            throw Exception("Pickup coordinates are required")
        }
        if (request.deliveryLatitude == 0.0 && request.deliveryLongitude == 0.0) {
            throw Exception("Delivery coordinates are required")
        }
        
        // Validate cold chain requirements
        if (request.isColdChain && request.temperatureRequirements == null) {
            throw Exception("Temperature requirements are required for cold chain shipments")
        }
    }
    
    private fun validateShipmentUpdate(shipment: ShipmentEntity, request: UpdateShipmentRequest) {
        // Validate status changes
        if (request.status != null && !isValidStatusTransition(shipment.status, request.status)) {
            throw Exception("Invalid status transition")
        }
        
        // Validate priority changes
        if (request.priority != null && !isValidPriorityChange(shipment.priority, request.priority)) {
            throw Exception("Invalid priority change")
        }
    }
    
