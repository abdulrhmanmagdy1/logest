    private suspend fun updateShipmentList() {
        val allShipments = database.shipmentDao().getAllShipments()
        _shipments.value = allShipments
    }
    
    private fun calculateAverageDeliveryTime(shipments: List<ShipmentEntity>): Double {
        val deliveredShipments = shipments.filter { it.status == ShipmentStatus.DELIVERED && it.actualDeliveryTime != null }
        
        if (deliveredShipments.isEmpty()) return 0.0
        
        val totalDeliveryTime = deliveredShipments.sumOf { shipment ->
            val createdTime = shipment.createdAt.time
            val deliveredTime = shipment.actualDeliveryTime!!.time
            deliveredTime - createdTime
        }
        
        return totalDeliveryTime / deliveredShipments.size / (1000 * 60 * 60) // Convert to hours
    }
    
    private fun ShipmentEntity.isDelayed(): Boolean {
        val now = Date()
        return estimatedDeliveryTime?.before(now) == true && status != ShipmentStatus.DELIVERED
    }
}

/**
 * Data classes
 */
data class ShipmentStats(
    val totalShipments: Int,
    val completedShipments: Int,
    val inTransitShipments: Int,
    val delayedShipments: Int,
    val priorityShipments: Int,
    val coldChainShipments: Int,
    val completionRate: Float,
    val averageDeliveryTime: Double
)

data class ShipmentAlert(
    val type: ShipmentAlertType,
    val shipmentId: Long,
    val message: String,
    val severity: AlertSeverity,
    val timestamp: Date
)

/**
 * Enums
 */
enum class ShipmentState {
    Idle,
    Creating,
    Created,
    Updating,
    Updated,
    AssigningDriver,
    DriverAssigned,
    AssigningVehicle,
    VehicleAssigned,
    Scheduling,
    Scheduled,
    ConfirmingPickup,
    PickupConfirmed,
    ConfirmingDelivery,
    DeliveryConfirmed,
    Error
}

enum class ShipmentAlertType {
    DELAYED,
    COLD_CHAIN_VIOLATION,
    DRIVER_UNRESPONSIVE,
    VEHICLE_ISSUE,
    ADDRESS_ISSUE,
    CUSTOMER_ISSUE
}

enum class AlertSeverity {
    LOW,
    MEDIUM,
    HIGH,
    CRITICAL
}
