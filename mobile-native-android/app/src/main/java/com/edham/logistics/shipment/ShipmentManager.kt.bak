        // Check if driver is available
        // Implementation would check driver availability
    }
    
    private fun validateVehicleAssignment(shipment: ShipmentEntity, vehicleId: String) {
        // Check if vehicle is available
        // Implementation would check vehicle availability
    }
    
    private fun validateShipmentScheduling(shipment: ShipmentEntity, scheduledTime: Date) {
        // Check if scheduling is valid
        if (scheduledTime.before(Date())) {
            throw Exception("Scheduled time cannot be in the past")
        }
    }
    
    private fun isValidStatusTransition(currentStatus: ShipmentStatus, newStatus: ShipmentStatus): Boolean {
        // Define valid transitions
        val validTransitions = mapOf(
            ShipmentStatus.CREATED to setOf(ShipmentStatus.ASSIGNED, ShipmentStatus.SCHEDULED, ShipmentStatus.CANCELLED),
            ShipmentStatus.ASSIGNED to setOf(ShipmentStatus.SCHEDULED, ShipmentStatus.CANCELLED),
            ShipmentStatus.SCHEDULED to setOf(ShipmentStatus.ASSIGNED, ShipmentStatus.CANCELLED),
            ShipmentStatus.ASSIGNED to setOf(ShipmentStatus.IN_TRANSIT, ShipmentStatus.CANCELLED),
            ShipmentStatus.IN_TRANSIT to setOf(ShipmentStatus.DELIVERED, ShipmentStatus.RETURNED, ShipmentStatus.CANCELLED),
            ShipmentStatus.DELIVERED to emptySet(),
            ShipmentStatus.CANCELLED to emptySet(),
            ShipmentStatus.RETURNED to emptySet()
        )
        
        return validTransitions[currentStatus]?.contains(newStatus) == true
    }
    
    private fun isValidPriorityChange(currentPriority: Priority, newPriority: Priority): Boolean {
        // Allow priority changes for shipments that are not yet in transit
        return true // Simplified validation
    }
    
