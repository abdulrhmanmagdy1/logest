        )
    }
    
    private fun determineBenchmarkPerformance(actual: Float, benchmark: Float): BenchmarkPerformance {
        val ratio = actual / benchmark
        val score = when {
            ratio >= 1.1f -> 100f
            ratio >= 1.0f -> 90f
            ratio >= 0.9f -> 80f
            ratio >= 0.8f -> 70f
            else -> 60f
        }
        
        return BenchmarkPerformance(
            actual = actual,
            benchmark = benchmark,
            ratio = ratio,
            score = score
        )
    }
    
    private fun generateBenchmarkingRecommendations(
        utilization: BenchmarkComparison,
        cost: BenchmarkComparison,
        efficiency: BenchmarkComparison
    ): List<String> {
        val recommendations = mutableListOf<String>()
        
        if (utilization.ratio < 0.9f) {
            recommendations.add("Improve vehicle utilization to meet industry standards")
        }
        
        if (cost.ratio > 1.1f) {
            recommendations.add("Reduce operating costs to improve competitiveness")
        }
        
        if (efficiency.ratio < 0.9f) {
            recommendations.add("Focus on operational efficiency improvements")
        }
        
        return recommendations
    }
    
