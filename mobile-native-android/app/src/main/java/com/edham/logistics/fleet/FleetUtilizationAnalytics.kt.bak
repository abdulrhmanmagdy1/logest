    private fun calculateFleetEfficiencyScore(utilizationRate: Float, costPerMile: Float, revenuePerMile: Float): Float {
        return (utilizationRate * 0.4f + (COST_PER_MILE_TARGET / costPerMile) * 0.3f + (revenuePerMile / 2f) * 0.3f) * 100f
    }
    
    private fun getIndustryBenchmarks(): IndustryBenchmarks {
        return IndustryBenchmarks(
            utilizationRate = 75f,
            costPerMile = 1.50f,
            efficiencyScore = 80f
        )
    }
    
    private fun getHistoricalBenchmarks(dateRange: DateRange): IndustryBenchmarks {
