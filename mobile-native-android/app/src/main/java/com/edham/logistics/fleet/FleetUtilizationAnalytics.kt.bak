/**
 * Data classes
 */
data class FleetUtilizationReport(
    val dateRange: DateRange,
    val utilizationMetrics: UtilizationMetrics,
    val vehicleUtilization: Map<Long, VehicleUtilization>,
    val driverPerformance: Map<String, DriverPerformance>,
    val routeEfficiency: RouteEfficiencyAnalysis,
    val costAnalysis: CostAnalysis,
    val optimizationRecommendations: List<OptimizationRecommendation>,
    val generatedAt: Date
)

data class UtilizationMetrics(
    val totalVehicles: Int,
    val activeVehicles: Int,
    val availableVehicles: Int,
    val totalOperatingHours: Float,
    val totalDistance: Float,
    val overallUtilizationRate: Float,
    val averageCostPerMile: Float,
    val averageRevenuePerMile: Float,
    val totalRevenue: Float,
    val totalCosts: Float,
    val fleetEfficiencyScore: Float
)

data class VehicleUtilization(
    val vehicleId: Long,
    val vehicleIdString: String,
    val utilizationRate: Float,
    val costPerMile: Float,
    val revenuePerMile: Float,
    val totalDistance: Float,
    val totalOperatingHours: Float,
    val performanceRating: PerformanceRating
)

data class DriverPerformance(
    val driverId: String,
    val totalAssignments: Int,
    val completedAssignments: Int,
    val completionRate: Float,
    val onTimeRate: Float,
    val totalDistance: Float,
    val efficiencyScore: Float,
    val performanceRating: PerformanceRating
)

data class VehicleUtilizationDetails(
    val vehicleId: Long,
    val vehicleIdString: String,
    val dateRange: DateRange,
    val totalAssignments: Int,
    val activeAssignments: Int,
    val totalOperatingHours: Float,
    val totalDistance: Float,
    val utilizationRate: Float,
    val costPerMile: Float,
    val revenuePerMile: Float,
    val totalRevenue: Float,
    val totalCosts: Float,
    val dailyUtilization: Map<String, Float>,
    val utilizationTrend: TrendAnalysis,
    val performanceRating: PerformanceRating
)

data class DriverPerformanceAnalytics(
    val driverId: String,
    val dateRange: DateRange,
    val totalAssignments: Int,
    val completedAssignments: Int,
    val onTimeDeliveries: Int,
    val completionRate: Float,
    val onTimeRate: Float,
    val totalDistance: Float,
    val totalOperatingHours: Float,
    val averageDistancePerAssignment: Float,
    val averageTimePerAssignment: Float,
    val totalRevenue: Float,
    val fuelConsumption: Float,
    val efficiencyScore: Float,
    val performanceTrend: TrendAnalysis,
    val ranking: Int,
    val performanceRating: PerformanceRating
)

data class RouteEfficiencyAnalysis(
    val averageRouteDistance: Float,
    val averageRouteTime: Float,
    val routeEfficiencyScore: Float,
    val optimizedRoutes: Int,
    val deviationRate: Float
)

data class CostAnalysis(
    val totalCosts: Float,
    val costPerMile: Float,
    val costBreakdown: Map<String, Float>,
    val costTrend: TrendAnalysis
)

data class OptimizationRecommendation(
    val type: OptimizationType,
    val priority: RecommendationPriority,
    val title: String,
    val description: String,
    val potentialSavings: Float,
    val actions: List<String>
)

data class FleetBenchmarking(
    val dateRange: DateRange,
    val utilizationBenchmark: BenchmarkComparison,
    val costBenchmark: BenchmarkComparison,
    val efficiencyBenchmark: BenchmarkComparison,
    val overallScore: Float,
    val industryAverages: IndustryBenchmarks,
    val historicalAverages: IndustryBenchmarks,
    val recommendations: List<String>
)

data class ROIAnalysis(
    val dateRange: DateRange,
    val totalRevenue: Float,
    val totalCosts: Float,
    val totalInvestment: Float,
    val roi: Float,
    val paybackPeriod: Float,
    val revenueByVehicle: Map<Long, Float>,
    val costsByVehicle: Map<Long, Float>,
    val roiByVehicle: Map<Long, Float>,
    val monthlyROI: Map<String, Float>,
    val roiTrend: TrendAnalysis,
    val projectedAnnualROI: Float
)

data class BenchmarkComparison(
    val actual: Float,
    val industry: Float,
    val historical: Float,
    val performance: BenchmarkPerformance
)

data class BenchmarkPerformance(
    val actual: Float,
    val benchmark: Float,
    val ratio: Float,
    val score: Float
)

data class IndustryBenchmarks(
    val utilizationRate: Float,
    val costPerMile: Float,
    val efficiencyScore: Float
)

data class TrendAnalysis(
    val direction: TrendDirection,
    val changePercentage: Float,
    val strength: Float
)

/**
 * Enums
 */
enum class AnalyticsState {
    Idle,
    Generating,
    Completed,
    Error
}

enum class OptimizationType {
    VEHICLE_UTILIZATION,
    COST_OPTIMIZATION,
    DRIVER_PERFORMANCE,
    ROUTE_OPTIMIZATION,
    MAINTENANCE_OPTIMIZATION,
    FLEET_SIZE_OPTIMIZATION
}

enum class RecommendationPriority {
    LOW,
    MEDIUM,
    HIGH,
    CRITICAL
}

enum class PerformanceRating {
    EXCELLENT,
    GOOD,
    AVERAGE,
    BELOW_AVERAGE,
    POOR
}

enum class TrendDirection {
    INCREASING,
    DECREASING,
    STABLE
}
