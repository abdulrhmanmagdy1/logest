    data class TripConsumptionPrediction(
        val vehicleId: String,
        val routeId: String,
        val distanceKm: Double,
        val predictedConsumption: Double,
        val estimatedCost: Double,
        val confidenceInterval: ConfidenceInterval,
        val influencingFactors: List<String>,
        val optimizationTips: List<String>,
        val generatedAt: LocalDateTime
    )
    
    // Supporting data classes
    data class SpeedImpactAnalysis(
        val consumptionBySpeedRange: Map<String, Double>,
        val optimalSpeedRange: String,
        val efficiencyLossBySpeed: Map<String, Double>
    )
    
    data class IdleTimeImpactAnalysis(
        val consumptionByIdleLevel: Map<String, Double>,
        val averageIdleTime: Double,
        val potentialSavings: Double
    )
    
    data class ConsumptionPrediction(
        val predictedConsumption: Double,
        val confidence: Double,
        val factors: List<String>
    )
    
    data class OptimizationPotential(
        val currentAverageConsumption: Double,
        val bestObservedConsumption: Double,
        val potentialSavingsPercentage: Double,
        val estimatedAnnualSavings: Double
    )
    
    data class ConsumptionRecommendation(
        val type: RecommendationType,
        val title: String,
        val description: String,
        val potentialSavings: Double,
        val priority: Priority
    )
    
    data class ConfidenceInterval(
        val lowerBound: Double,
        val upperBound: Double,
        val confidence: Double
    )
    
    // Enums
    enum class WeatherCondition {
        SUNNY, CLOUDY, RAINY, SNOWY, FOGGY, WINDY
    }
    
    enum class TrafficCondition {
        LIGHT, MODERATE, HEAVY, CONGESTED
    }
    
    enum class RoadType {
        HIGHWAY, CITY, RURAL, MOUNTAIN, MIXED
    }
    
    enum class ElevationProfile {
        FLAT, HILLY, MOUNTAINOUS, VARIABLE
    }
    
    enum class LoadLevel {
        EMPTY, LIGHT, MEDIUM, HEAVY, MAXIMUM
    }
    
    enum class LoadType {
        PASSENGERS, CARGO, MIXED, SPECIALIZED
    }
    
    enum class DrivingStyle {
        ECO, NORMAL, AGGRESSIVE, CONSERVATIVE, UNKNOWN
    }
    
    enum class TrendDirection {
        INCREASING, DECREASING, STABLE
    }
    
    enum class TimeWindow(val duration: java.time.Duration) {
        LAST_7_DAYS(java.time.Duration.ofDays(7)),
        LAST_30_DAYS(java.time.Duration.ofDays(30)),
        LAST_90_DAYS(java.time.Duration.ofDays(90)),
        LAST_YEAR(java.time.Duration.ofDays(365))
    }
    
    enum class RecommendationType {
        SPEED_OPTIMIZATION, IDLE_REDUCTION, ROUTE_OPTIMIZATION, 
        MAINTENANCE, DRIVER_TRAINING, VEHICLE_UPGRADE
    }
    
    enum class Priority {
        LOW, MEDIUM, HIGH, CRITICAL
    }
    
