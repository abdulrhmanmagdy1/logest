package com.edham.logistics.feature.fuel

import android.util.Log
import kotlinx.coroutines.Dispatchers
import kotlinx.coroutines.withContext
import java.time.LocalDateTime
import java.time.format.DateTimeFormatter

/**
 * Comprehensive Fuel Consumption Analytics System
 * 
 * Provides advanced fuel consumption analysis capabilities including:
 * - Vehicle-specific consumption patterns and trends
 * - Driver behavior impact on fuel efficiency
 * - Route and condition-based consumption analysis
 * - Predictive consumption modeling
 * - Fleet-wide consumption optimization insights
 */
class FuelConsumptionAnalytics {
    
    companion object {
        private const val TAG = "FuelConsumptionAnalytics"
        private const val EFFICIENCY_THRESHOLD_LOW = 8.0 // L/100km
        private const val EFFICIENCY_THRESHOLD_GOOD = 6.0 // L/100km
        private const val EFFICIENCY_THRESHOLD_EXCELLENT = 4.0 // L/100km
    }
    
    private val vehicleConsumptionData = mutableMapOf<String, MutableList<VehicleConsumptionRecord>>()
    private val driverConsumptionProfiles = mutableMapOf<String, DriverConsumptionProfile>()
    private val routeConsumptionPatterns = mutableMapOf<String, RouteConsumptionPattern>()
    private val consumptionModels = mutableMapOf<String, ConsumptionPredictionModel>()
    
    /**
     * Records fuel consumption data for a vehicle
     */
    suspend fun recordConsumptionData(
        vehicleId: String,
        driverId: String,
        fuelType: FuelType,
        volumeLiters: Double,
        distanceKm: Double,
        routeId: String? = null,
        drivingConditions: DrivingConditions,
        vehicleLoad: VehicleLoad,
        averageSpeed: Double,
        idleTimeMinutes: Int,
        timestamp: LocalDateTime = LocalDateTime.now()
    ): Result<VehicleConsumptionRecord> = withContext(Dispatchers.IO) {
        try {
            Log.d(TAG, "Recording consumption data for vehicle: $vehicleId")
            
            // Validate input data
            val validationResult = validateConsumptionData(
                volumeLiters, distanceKm, averageSpeed, idleTimeMinutes
            )
            
            if (!validationResult.isValid) {
                Log.e(TAG, "Invalid consumption data: ${validationResult.errors}")
                return@withContext Result.failure(
                    IllegalArgumentException("Invalid consumption data: ${validationResult.errors.joinToString(", ")}")
                )
            }
            
            // Calculate consumption metrics
            val consumptionRate = calculateConsumptionRate(volumeLiters, distanceKm)
            val efficiencyScore = calculateEfficiencyScore(consumptionRate, fuelType)
            val costPerKm = calculateCostPerKm(volumeLiters, distanceKm, fuelType)
            
            // Create consumption record
            val record = VehicleConsumptionRecord(
                id = generateConsumptionRecordId(),
                vehicleId = vehicleId,
                driverId = driverId,
                fuelType = fuelType,
                volumeLiters = volumeLiters,
                distanceKm = distanceKm,
                consumptionRate = consumptionRate,
                efficiencyScore = efficiencyScore,
                costPerKm = costPerKm,
                routeId = routeId,
                drivingConditions = drivingConditions,
                vehicleLoad = vehicleLoad,
                averageSpeed = averageSpeed,
                idleTimeMinutes = idleTimeMinutes,
                timestamp = timestamp
            )
            
            // Store consumption data
            val vehicleData = vehicleConsumptionData.getOrPut(vehicleId) { mutableListOf() }
            vehicleData.add(record)
            
            // Update driver consumption profile
            updateDriverConsumptionProfile(driverId, record)
            
            // Update route consumption patterns
            routeId?.let { updateRouteConsumptionPattern(it, record) }
            
            // Update prediction models
            updateConsumptionModels(vehicleId, record)
            
            Log.d(TAG, "Consumption data recorded successfully: ${record.id}")
            Result.success(record)
            
        } catch (e: Exception) {
            Log.e(TAG, "Error recording consumption data", e)
            Result.failure(e)
        }
    }
    
    /**
     * Gets comprehensive consumption analytics for a vehicle
     */
    suspend fun getVehicleConsumptionAnalytics(
        vehicleId: String,
        timeWindow: TimeWindow = TimeWindow.LAST_30_DAYS
    ): Result<VehicleConsumptionAnalytics> = withContext(Dispatchers.IO) {
        try {
            Log.d(TAG, "Getting consumption analytics for vehicle: $vehicleId")
            
            val consumptionData = getVehicleConsumptionInTimeWindow(vehicleId, timeWindow)
            
            if (consumptionData.isEmpty()) {
                return@withContext Result.failure(
                    IllegalArgumentException("No consumption data found for vehicle: $vehicleId")
                )
            }
            
            // Calculate analytics
            val averageConsumptionRate = consumptionData.map { it.consumptionRate }.average()
            val averageEfficiencyScore = consumptionData.map { it.efficiencyScore }.average()
            val totalDistance = consumptionData.sumOf { it.distanceKm }
            val totalFuelConsumed = consumptionData.sumOf { it.volumeLiters }
            val totalCost = consumptionData.sumOf { it.volumeLiters * getCurrentFuelPrice(it.fuelType) }
            val averageCostPerKm = totalCost / totalDistance
            
            // Performance trends
            val consumptionTrend = calculateConsumptionTrend(consumptionData)
            val efficiencyTrend = calculateEfficiencyTrend(consumptionData)
            
            // Factor analysis
            val conditionImpact = analyzeDrivingConditionsImpact(consumptionData)
            val loadImpact = analyzeVehicleLoadImpact(consumptionData)
            val speedImpact = analyzeSpeedImpact(consumptionData)
            val idleImpact = analyzeIdleTimeImpact(consumptionData)
            
            // Predictions
            val nextPeriodPrediction = predictNextPeriodConsumption(vehicleId, timeWindow)
            val optimizationPotential = calculateOptimizationPotential(consumptionData)
            
            val analytics = VehicleConsumptionAnalytics(
                vehicleId = vehicleId,
                timeWindow = timeWindow,
                averageConsumptionRate = averageConsumptionRate,
                averageEfficiencyScore = averageEfficiencyScore,
                totalDistance = totalDistance,
                totalFuelConsumed = totalFuelConsumed,
                totalCost = totalCost,
                averageCostPerKm = averageCostPerKm,
                consumptionTrend = consumptionTrend,
                efficiencyTrend = efficiencyTrend,
                conditionImpact = conditionImpact,
                loadImpact = loadImpact,
                speedImpact = speedImpact,
                idleImpact = idleImpact,
                nextPeriodPrediction = nextPeriodPrediction,
                optimizationPotential = optimizationPotential,
                recommendations = generateConsumptionRecommendations(consumptionData),
                lastUpdated = LocalDateTime.now()
            )
            
            Result.success(analytics)
            
        } catch (e: Exception) {
            Log.e(TAG, "Error getting vehicle consumption analytics", e)
            Result.failure(e)
        }
    }
    
    /**
     * Gets driver consumption behavior analysis
     */
    suspend fun getDriverConsumptionAnalysis(
        driverId: String,
        timeWindow: TimeWindow = TimeWindow.LAST_30_DAYS
    ): Result<DriverConsumptionAnalysis> = withContext(Dispatchers.IO) {
        try {
            Log.d(TAG, "Getting driver consumption analysis for: $driverId")
            
            val profile = driverConsumptionProfiles[driverId]
                ?: return@withContext Result.failure(
                    IllegalArgumentException("Driver profile not found: $driverId")
                )
            
            // Get recent consumption data
            val recentData = getDriverConsumptionInTimeWindow(driverId, timeWindow)
            
            if (recentData.isEmpty()) {
                return@withContext Result.failure(
                    IllegalArgumentException("No recent consumption data for driver: $driverId")
                )
            }
            
            // Calculate driver-specific metrics
            val averageEfficiency = recentData.map { it.efficiencyScore }.average()
            val consistencyScore = calculateDrivingConsistency(recentData)
            val ecoDrivingScore = calculateEcoDrivingScore(recentData)
            val fuelSavingPotential = calculateDriverFuelSavingPotential(recentData)
            
            // Behavior patterns
            val speedBehavior = analyzeSpeedBehavior(recentData)
            val idleBehavior = analyzeIdleBehavior(recentData)
            val routePreference = analyzeRoutePreference(recentData)
            val loadManagement = analyzeLoadManagement(recentData)
            
            // Comparison with fleet average
            val fleetComparison = compareWithFleetAverage(driverId, recentData)
            
            // Improvement recommendations
            val recommendations = generateDriverRecommendations(recentData, profile)
            
            val analysis = DriverConsumptionAnalysis(
                driverId = driverId,
                timeWindow = timeWindow,
                averageEfficiencyScore = averageEfficiency,
                consistencyScore = consistencyScore,
                ecoDrivingScore = ecoDrivingScore,
                fuelSavingPotential = fuelSavingPotential,
                speedBehavior = speedBehavior,
                idleBehavior = idleBehavior,
                routePreference = routePreference,
                loadManagement = loadManagement,
                fleetComparison = fleetComparison,
                recommendations = recommendations,
                lastUpdated = LocalDateTime.now()
            )
            
            Result.success(analysis)
            
        } catch (e: Exception) {
            Log.e(TAG, "Error getting driver consumption analysis", e)
            Result.failure(e)
        }
    }
    
    /**
     * Gets route-specific consumption analysis
     */
    suspend fun getRouteConsumptionAnalysis(
        routeId: String,
        timeWindow: TimeWindow = TimeWindow.LAST_30_DAYS
    ): Result<RouteConsumptionAnalysis> = withContext(Dispatchers.IO) {
        try {
            Log.d(TAG, "Getting route consumption analysis for: $routeId")
            
            val pattern = routeConsumptionPatterns[routeId]
                ?: return@withContext Result.failure(
                    IllegalArgumentException("Route pattern not found: $routeId")
                )
            
            // Get route consumption data
            val routeData = getRouteConsumptionInTimeWindow(routeId, timeWindow)
            
            if (routeData.isEmpty()) {
                return@withContext Result.failure(
                    IllegalArgumentException("No consumption data for route: $routeId")
                )
            }
            
            // Calculate route metrics
            val averageConsumption = routeData.map { it.consumptionRate }.average()
            val consumptionVariability = calculateConsumptionVariability(routeData)
            val optimalConditions = identifyOptimalConditions(routeData)
            val challengingSegments = identifyChallengingSegments(routeData)
            
            // Time-based analysis
            val timeOfDayImpact = analyzeTimeOfDayImpact(routeData)
            val seasonalImpact = analyzeSeasonalImpact(routeData)
            val weatherImpact = analyzeWeatherImpact(routeData)
            
            // Optimization opportunities
            val optimizationPotential = calculateRouteOptimizationPotential(routeData)
            val alternativeRoutes = suggestAlternativeRoutes(routeId, routeData)
            
            val analysis = RouteConsumptionAnalysis(
                routeId = routeId,
                timeWindow = timeWindow,
                averageConsumptionRate = averageConsumption,
                consumptionVariability = consumptionVariability,
                optimalConditions = optimalConditions,
                challengingSegments = challengingSegments,
                timeOfDayImpact = timeOfDayImpact,
                seasonalImpact = seasonalImpact,
                weatherImpact = weatherImpact,
                optimizationPotential = optimizationPotential,
                alternativeRoutes = alternativeRoutes,
                recommendations = generateRouteRecommendations(routeData),
                lastUpdated = LocalDateTime.now()
            )
            
            Result.success(analysis)
            
        } catch (e: Exception) {
            Log.e(TAG, "Error getting route consumption analysis", e)
            Result.failure(e)
        }
    }
    
    /**
     * Gets fleet-wide consumption analytics
     */
    suspend fun getFleetConsumptionAnalytics(
        timeWindow: TimeWindow = TimeWindow.LAST_30_DAYS
    ): Result<FleetConsumptionAnalytics> = withContext(Dispatchers.IO) {
        try {
            Log.d(TAG, "Getting fleet consumption analytics")
            
            // Aggregate data from all vehicles
            val allVehicleData = mutableListOf<VehicleConsumptionRecord>()
            vehicleConsumptionData.values.forEach { vehicleData ->
                allVehicleData.addAll(
                    vehicleData.filter { it.timestamp >= LocalDateTime.now().minus(timeWindow.duration) }
                )
            }
            
            if (allVehicleData.isEmpty()) {
                return@withContext Result.failure(
                    IllegalArgumentException("No fleet consumption data available")
                )
            }
            
            // Fleet-level metrics
            val fleetAverageConsumption = allVehicleData.map { it.consumptionRate }.average()
            val fleetAverageEfficiency = allVehicleData.map { it.efficiencyScore }.average()
            val totalFleetDistance = allVehicleData.sumOf { it.distanceKm }
            val totalFleetFuel = allVehicleData.sumOf { it.volumeLiters }
            val totalFleetCost = allVehicleData.sum { record -> 
                record.volumeLiters * getCurrentFuelPrice(record.fuelType) 
            }
            
            // Vehicle performance distribution
            val performanceDistribution = calculatePerformanceDistribution(allVehicleData)
            val topPerformers = identifyTopPerformers(allVehicleData)
            val underPerformers = identifyUnderPerformers(allVehicleData)
            
            // Factor analysis
            val fuelTypeComparison = compareFuelTypeEfficiency(allVehicleData)
            val driverImpact = analyzeDriverImpactOnFleet(allVehicleData)
            val vehicleTypeImpact = analyzeVehicleTypeImpact(allVehicleData)
            
            // Trends and predictions
            val consumptionTrend = calculateFleetConsumptionTrend(allVehicleData)
            val costProjection = projectFleetFuelCosts(allVehicleData)
            val savingsOpportunities = identifyFleetSavingsOpportunities(allVehicleData)
            
            val analytics = FleetConsumptionAnalytics(
                timeWindow = timeWindow,
                fleetAverageConsumption = fleetAverageConsumption,
                fleetAverageEfficiency = fleetAverageEfficiency,
                totalFleetDistance = totalFleetDistance,
                totalFleetFuel = totalFleetFuel,
                totalFleetCost = totalFleetCost,
                performanceDistribution = performanceDistribution,
                topPerformers = topPerformers,
                underPerformers = underPerformers,
                fuelTypeComparison = fuelTypeComparison,
                driverImpact = driverImpact,
                vehicleTypeImpact = vehicleTypeImpact,
                consumptionTrend = consumptionTrend,
                costProjection = costProjection,
                savingsOpportunities = savingsOpportunities,
                recommendations = generateFleetRecommendations(allVehicleData),
                lastUpdated = LocalDateTime.now()
            )
            
            Result.success(analytics)
            
        } catch (e: Exception) {
            Log.e(TAG, "Error getting fleet consumption analytics", e)
            Result.failure(e)
        }
    }
    
    /**
     * Predicts fuel consumption for upcoming trips
     */
    suspend fun predictTripConsumption(
        vehicleId: String,
        routeId: String,
        distanceKm: Double,
        expectedConditions: DrivingConditions,
        expectedLoad: VehicleLoad,
        driverId: String? = null
    ): Result<TripConsumptionPrediction> = withContext(Dispatchers.IO) {
        try {
            Log.d(TAG, "Predicting trip consumption for vehicle: $vehicleId")
            
            // Get vehicle consumption model
            val model = consumptionModels[vehicleId]
                ?: return@withContext Result.failure(
                    IllegalArgumentException("No consumption model available for vehicle: $vehicleId")
                )
            
            // Get route pattern if available
            val routePattern = routeConsumptionPatterns[routeId]
            
            // Get driver profile if specified
            val driverProfile = driverId?.let { driverConsumptionProfiles[it] }
            
            // Base prediction from vehicle model
            val baseConsumption = model.predictConsumption(distanceKm, expectedConditions, expectedLoad)
            
            // Adjust for route pattern
            val routeAdjustment = routePattern?.getConsumptionAdjustment(expectedConditions) ?: 1.0
            
            // Adjust for driver behavior
            val driverAdjustment = driverProfile?.getEfficiencyAdjustment() ?: 1.0
            
            // Calculate final prediction
            val adjustedConsumption = baseConsumption * routeAdjustment * driverAdjustment
            val estimatedCost = adjustedConsumption * getCurrentFuelPrice(model.fuelType)
            
            // Calculate confidence interval
            val confidenceInterval = calculatePredictionConfidence(
                model, routePattern, driverProfile, distanceKm
            )
            
            // Generate optimization tips
            val optimizationTips = generateTripOptimizationTips(
                vehicleId, routeId, expectedConditions, expectedLoad
            )
            
            val prediction = TripConsumptionPrediction(
                vehicleId = vehicleId,
                routeId = routeId,
                distanceKm = distanceKm,
                predictedConsumption = adjustedConsumption,
                estimatedCost = estimatedCost,
                confidenceInterval = confidenceInterval,
                influencingFactors = listOf(
                    "Vehicle Model: ${model.accuracy}",
                    if (routePattern != null) "Route Pattern: Known" else "Route Pattern: Unknown",
                    if (driverProfile != null) "Driver Profile: Known" else "Driver Profile: Unknown"
                ),
                optimizationTips = optimizationTips,
                generatedAt = LocalDateTime.now()
            )
            
            Result.success(prediction)
            
        } catch (e: Exception) {
            Log.e(TAG, "Error predicting trip consumption", e)
            Result.failure(e)
        }
    }
    
    // Private helper methods
    
    private fun validateConsumptionData(
        volume: Double,
        distance: Double,
        averageSpeed: Double,
        idleTime: Int
    ): ValidationResult {
        val errors = mutableListOf<String>()
        
        if (volume <= 0) {
            errors.add("Fuel volume must be positive")
        }
        
        if (distance <= 0) {
            errors.add("Distance must be positive")
        }
        
        if (averageSpeed < 0 || averageSpeed > 200) {
            errors.add("Invalid average speed: $averageSpeed")
        }
        
        if (idleTime < 0 || idleTime > 1440) { // Max 24 hours
            errors.add("Invalid idle time: $idleTime")
        }
        
        return ValidationResult(
            isValid = errors.isEmpty(),
            errors = errors
        )
    }
    
    private fun calculateConsumptionRate(volumeLiters: Double, distanceKm: Double): Double {
        return (volumeLiters / distanceKm) * 100 // L/100km
    }
    
    private fun calculateEfficiencyScore(consumptionRate: Double, fuelType: FuelType): Double {
        val threshold = when (fuelType) {
            FuelType.PETROL, FuelType.PREMIUM_PETROL -> EFFICIENCY_THRESHOLD_GOOD
            FuelType.DIESEL, FuelType.PREMIUM_DIESEL -> EFFICIENCY_THRESHOLD_LOW
            FuelType.CNG, FuelType.LPG -> EFFICIENCY_THRESHOLD_LOW * 1.2
            FuelType.ELECTRIC -> 0.0 // Electric vehicles have different metrics
            FuelType.HYBRID -> EFFICIENCY_THRESHOLD_EXCELLENT
        }
        
        return when {
            consumptionRate <= threshold -> 100.0
            consumptionRate <= threshold * 1.5 -> 80.0
            consumptionRate <= threshold * 2.0 -> 60.0
            consumptionRate <= threshold * 3.0 -> 40.0
            else -> 20.0
        }
    }
    
    private fun calculateCostPerKm(volumeLiters: Double, distanceKm: Double, fuelType: FuelType): Double {
        val fuelPrice = getCurrentFuelPrice(fuelType)
        return (volumeLiters * fuelPrice) / distanceKm
    }
    
    private fun getCurrentFuelPrice(fuelType: FuelType): Double {
        // Mock implementation - in real app, this would fetch from pricing service
        return when (fuelType) {
            FuelType.PETROL -> 1.85
            FuelType.PREMIUM_PETROL -> 2.05
            FuelType.DIESEL -> 1.75
            FuelType.PREMIUM_DIESEL -> 1.95
            FuelType.CNG -> 0.85
            FuelType.LPG -> 0.95
            FuelType.ELECTRIC -> 0.15 // per kWh equivalent
            FuelType.HYBRID -> 1.80
        }
    }
    
    private fun updateDriverConsumptionProfile(driverId: String, record: VehicleConsumptionRecord) {
        val profile = driverConsumptionProfiles.getOrPut(driverId) {
            DriverConsumptionProfile(
                driverId = driverId,
                totalTrips = 0,
                averageEfficiency = 0.0,
                averageSpeed = 0.0,
                averageIdleTime = 0,
                preferredRoutes = mutableSetOf(),
                drivingStyle = DrivingStyle.UNKNOWN,
                createdAt = LocalDateTime.now()
            )
        }
        
        // Update profile with new data
        val allRecords = vehicleConsumptionData.values.flatten()
            .filter { it.driverId == driverId }
        
        profile.copy(
            totalTrips = allRecords.size,
            averageEfficiency = allRecords.map { it.efficiencyScore }.average(),
            averageSpeed = allRecords.map { it.averageSpeed }.average(),
            averageIdleTime = allRecords.map { it.idleTimeMinutes }.average().toInt(),
            drivingStyle = determineDrivingStyle(allRecords)
        ).let { updatedProfile ->
            driverConsumptionProfiles[driverId] = updatedProfile
        }
    }
    
    private fun updateRouteConsumptionPattern(routeId: String, record: VehicleConsumptionRecord) {
        val pattern = routeConsumptionPatterns.getOrPut(routeId) {
            RouteConsumptionPattern(
                routeId = routeId,
                totalTrips = 0,
                averageConsumption = 0.0,
                conditionMultipliers = mutableMapOf(),
                difficultyScore = 0.0,
                optimalSpeedRange = 0.0..0.0,
                createdAt = LocalDateTime.now()
            )
        }
        
        // Update pattern with new data
        val routeRecords = vehicleConsumptionData.values.flatten()
            .filter { it.routeId == routeId }
        
        pattern.copy(
            totalTrips = routeRecords.size,
            averageConsumption = routeRecords.map { it.consumptionRate }.average(),
            difficultyScore = calculateRouteDifficulty(routeRecords),
            optimalSpeedRange = calculateOptimalSpeedRange(routeRecords)
        ).let { updatedPattern ->
            routeConsumptionPatterns[routeId] = updatedPattern
        }
    }
    
    private fun updateConsumptionModels(vehicleId: String, record: VehicleConsumptionRecord) {
        val model = consumptionModels.getOrPut(vehicleId) {
            ConsumptionPredictionModel(
                vehicleId = vehicleId,
                fuelType = record.fuelType,
                baseConsumptionRate = record.consumptionRate,
                conditionMultipliers = mutableMapOf(),
                loadMultipliers = mutableMapOf(),
                speedMultipliers = mutableMapOf(),
                accuracy = 0.0,
                lastTrained = LocalDateTime.now()
            )
        }
        
        // Update model with new data
        val vehicleRecords = vehicleConsumptionData[vehicleId] ?: emptyList()
        
        model.copy(
            baseConsumptionRate = vehicleRecords.map { it.consumptionRate }.average(),
            conditionMultipliers = calculateConditionMultipliers(vehicleRecords),
            loadMultipliers = calculateLoadMultipliers(vehicleRecords),
            speedMultipliers = calculateSpeedMultipliers(vehicleRecords),
            accuracy = calculateModelAccuracy(vehicleRecords),
            lastTrained = LocalDateTime.now()
        ).let { updatedModel ->
            consumptionModels[vehicleId] = updatedModel
        }
    }
    
    private fun getVehicleConsumptionInTimeWindow(
        vehicleId: String,
        timeWindow: TimeWindow
    ): List<VehicleConsumptionRecord> {
        val cutoffDate = LocalDateTime.now().minus(timeWindow.duration)
        return vehicleConsumptionData[vehicleId]?.filter { it.timestamp >= cutoffDate } ?: emptyList()
    }
    
    private fun getDriverConsumptionInTimeWindow(
        driverId: String,
        timeWindow: TimeWindow
    ): List<VehicleConsumptionRecord> {
        val cutoffDate = LocalDateTime.now().minus(timeWindow.duration)
        return vehicleConsumptionData.values.flatten()
            .filter { it.driverId == driverId && it.timestamp >= cutoffDate }
    }
    
    private fun getRouteConsumptionInTimeWindow(
        routeId: String,
        timeWindow: TimeWindow
    ): List<VehicleConsumptionRecord> {
        val cutoffDate = LocalDateTime.now().minus(timeWindow.duration)
        return vehicleConsumptionData.values.flatten()
            .filter { it.routeId == routeId && it.timestamp >= cutoffDate }
    }
    
    // Additional calculation methods would be implemented here...
    // For brevity, I'm including key method signatures
    
    private fun calculateConsumptionTrend(data: List<VehicleConsumptionRecord>): TrendDirection {
        if (data.size < 2) return TrendDirection.STABLE
        
        val sortedData = data.sortedBy { it.timestamp }
        val firstHalf = sortedData.take(sortedData.size / 2)
        val secondHalf = sortedData.drop(sortedData.size / 2)
        
        val firstHalfAvg = firstHalf.map { it.consumptionRate }.average()
        val secondHalfAvg = secondHalf.map { it.consumptionRate }.average()
        
        return when {
            secondHalfAvg > firstHalfAvg * 1.05 -> TrendDirection.INCREASING
            secondHalfAvg < firstHalfAvg * 0.95 -> TrendDirection.DECREASING
            else -> TrendDirection.STABLE
        }
    }
    
    private fun calculateEfficiencyTrend(data: List<VehicleConsumptionRecord>): TrendDirection {
        if (data.size < 2) return TrendDirection.STABLE
        
        val sortedData = data.sortedBy { it.timestamp }
        val firstHalf = sortedData.take(sortedData.size / 2)
        val secondHalf = sortedData.drop(sortedData.size / 2)
        
        val firstHalfAvg = firstHalf.map { it.efficiencyScore }.average()
        val secondHalfAvg = secondHalf.map { it.efficiencyScore }.average()
        
        return when {
            secondHalfAvg > firstHalfAvg * 1.05 -> TrendDirection.INCREASING
            secondHalfAvg < firstHalfAvg * 0.95 -> TrendDirection.DECREASING
            else -> TrendDirection.STABLE
        }
    }
    
    private fun analyzeDrivingConditionsImpact(data: List<VehicleConsumptionRecord>): Map<WeatherCondition, Double> {
        return data.groupBy { it.drivingConditions.weather }
            .mapValues { (_, records) -> records.map { it.consumptionRate }.average() }
    }
    
    private fun analyzeVehicleLoadImpact(data: List<VehicleConsumptionRecord>): Map<LoadLevel, Double> {
        return data.groupBy { it.vehicleLoad.loadLevel }
            .mapValues { (_, records) -> records.map { it.consumptionRate }.average() }
    }
    
    private fun analyzeSpeedImpact(data: List<VehicleConsumptionRecord>): SpeedImpactAnalysis {
        val speedRanges = mapOf(
            "0-30" to data.filter { it.averageSpeed <= 30 },
            "31-60" to data.filter { it.averageSpeed in 31.0..60.0 },
            "61-90" to data.filter { it.averageSpeed in 61.0..90.0 },
            "90+" to data.filter { it.averageSpeed > 90 }
        )
        
        val consumptionByRange = speedRanges.mapValues { (_, records) ->
            if (records.isNotEmpty()) records.map { it.consumptionRate }.average() else 0.0
        }
        
        val optimalRange = consumptionByRange.minByOrNull { it.value }?.key ?: "61-90"
        
        return SpeedImpactAnalysis(
            consumptionBySpeedRange = consumptionByRange,
            optimalSpeedRange = optimalRange,
            efficiencyLossBySpeed = calculateEfficiencyLossBySpeed(consumptionByRange)
        )
    }
    
    private fun analyzeIdleTimeImpact(data: List<VehicleConsumptionRecord>): IdleTimeImpactAnalysis {
        val idleRanges = mapOf(
            "Low" to data.filter { it.idleTimeMinutes <= 5 },
            "Medium" to data.filter { it.idleTimeMinutes in 6..15 },
            "High" to data.filter { it.idleTimeMinutes > 15 }
        )
        
        val consumptionByIdleLevel = idleRanges.mapValues { (_, records) ->
            if (records.isNotEmpty()) records.map { it.consumptionRate }.average() else 0.0
        }
        
        return IdleTimeImpactAnalysis(
            consumptionByIdleLevel = consumptionByIdleLevel,
            averageIdleTime = data.map { it.idleTimeMinutes }.average(),
            potentialSavings = calculateIdleTimeSavings(data)
        )
    }
    
    // Additional helper methods for calculations...
    
    private fun predictNextPeriodConsumption(vehicleId: String, timeWindow: TimeWindow): ConsumptionPrediction {
        val historicalData = getVehicleConsumptionInTimeWindow(vehicleId, timeWindow)
        val averageConsumption = historicalData.map { it.consumptionRate }.average()
        val trend = calculateConsumptionTrend(historicalData)
        
        val trendAdjustment = when (trend) {
            TrendDirection.INCREASING -> 1.05
            TrendDirection.DECREASING -> 0.95
            TrendDirection.STABLE -> 1.0
        }
        
        return ConsumptionPrediction(
            predictedConsumption = averageConsumption * trendAdjustment,
            confidence = 0.85,
            factors = listOf("Historical Average", "Trend Analysis")
        )
    }
    
    private fun calculateOptimizationPotential(data: List<VehicleConsumptionRecord>): OptimizationPotential {
        val currentAverage = data.map { it.consumptionRate }.average()
        val bestPerformance = data.minByOrNull { it.consumptionRate }?.consumptionRate ?: currentAverage
        val potentialSavings = ((currentAverage - bestPerformance) / currentAverage) * 100
        
        return OptimizationPotential(
            currentAverageConsumption = currentAverage,
            bestObservedConsumption = bestPerformance,
            potentialSavingsPercentage = potentialSavings,
            estimatedAnnualSavings = calculateAnnualSavings(data, potentialSavings)
        )
    }
    
    private fun generateConsumptionRecommendations(data: List<VehicleConsumptionRecord>): List<ConsumptionRecommendation> {
        val recommendations = mutableListOf<ConsumptionRecommendation>()
        
        // Speed optimization
        val highSpeedRecords = data.filter { it.averageSpeed > 90 }
        if (highSpeedRecords.size > data.size * 0.3) {
            recommendations.add(
                ConsumptionRecommendation(
                    type = RecommendationType.SPEED_OPTIMIZATION,
                    title = "Reduce High-Speed Driving",
                    description = "30% of your trips involve speeds over 90 km/h. Maintaining speeds between 60-80 km/h can improve fuel efficiency by 15-20%.",
                    potentialSavings = 15.0,
                    priority = Priority.HIGH
                )
            )
        }
        
        // Idle time reduction
        val highIdleRecords = data.filter { it.idleTimeMinutes > 15 }
        if (highIdleRecords.isNotEmpty()) {
            recommendations.add(
                ConsumptionRecommendation(
                    type = RecommendationType.IDLE_REDUCTION,
                    title = "Minimize Idle Time",
                    description = "Excessive idling wastes fuel. Consider turning off engine during stops longer than 2 minutes.",
                    potentialSavings = 8.0,
                    priority = Priority.MEDIUM
                )
            )
        }
        
        // Route optimization
        val poorEfficiencyRoutes = data.filter { it.efficiencyScore < 60 }
        if (poorEfficiencyRoutes.isNotEmpty()) {
            recommendations.add(
                ConsumptionRecommendation(
                    type = RecommendationType.ROUTE_OPTIMIZATION,
                    title = "Review Route Planning",
                    description = "Some routes show poor efficiency. Consider alternative routes or travel times to avoid congestion.",
                    potentialSavings = 12.0,
                    priority = Priority.MEDIUM
                )
            )
        }
        
        return recommendations
    }
    
    // ID generation methods
    private fun generateConsumptionRecordId(): String = "CON_${System.currentTimeMillis()}_${(1000..9999).random()}"
    
    // Data classes and enums
    
    data class VehicleConsumptionRecord(
        val id: String,
        val vehicleId: String,
        val driverId: String,
        val fuelType: FuelType,
        val volumeLiters: Double,
        val distanceKm: Double,
        val consumptionRate: Double, // L/100km
        val efficiencyScore: Double, // 0-100
        val costPerKm: Double,
        val routeId: String?,
        val drivingConditions: DrivingConditions,
        val vehicleLoad: VehicleLoad,
        val averageSpeed: Double,
        val idleTimeMinutes: Int,
        val timestamp: LocalDateTime
    )
    
    data class DrivingConditions(
        val weather: WeatherCondition,
        val traffic: TrafficCondition,
        val roadType: RoadType,
        val elevation: ElevationProfile
    )
    
    data class VehicleLoad(
        val loadLevel: LoadLevel,
        val weightKg: Double,
        val loadType: LoadType
    )
    
    data class DriverConsumptionProfile(
        val driverId: String,
        var totalTrips: Int,
        var averageEfficiency: Double,
        var averageSpeed: Double,
        var averageIdleTime: Int,
        val preferredRoutes: MutableSet<String>,
        var drivingStyle: DrivingStyle,
        val createdAt: LocalDateTime
    )
    
    data class RouteConsumptionPattern(
        val routeId: String,
        var totalTrips: Int,
        var averageConsumption: Double,
        val conditionMultipliers: MutableMap<WeatherCondition, Double>,
        var difficultyScore: Double,
        var optimalSpeedRange: ClosedFloatingPointRange<Double>,
        val createdAt: LocalDateTime
    )
    
    data class ConsumptionPredictionModel(
        val vehicleId: String,
        val fuelType: FuelType,
        var baseConsumptionRate: Double,
        val conditionMultipliers: MutableMap<WeatherCondition, Double>,
        val loadMultipliers: MutableMap<LoadLevel, Double>,
        val speedMultipliers: MutableMap<ClosedFloatingPointRange<Double>, Double>,
        var accuracy: Double,
        var lastTrained: LocalDateTime
    )
    
    data class VehicleConsumptionAnalytics(
        val vehicleId: String,
        val timeWindow: TimeWindow,
        val averageConsumptionRate: Double,
        val averageEfficiencyScore: Double,
        val totalDistance: Double,
        val totalFuelConsumed: Double,
        val totalCost: Double,
        val averageCostPerKm: Double,
        val consumptionTrend: TrendDirection,
        val efficiencyTrend: TrendDirection,
        val conditionImpact: Map<WeatherCondition, Double>,
        val loadImpact: Map<LoadLevel, Double>,
        val speedImpact: SpeedImpactAnalysis,
        val idleImpact: IdleTimeImpactAnalysis,
        val nextPeriodPrediction: ConsumptionPrediction,
        val optimizationPotential: OptimizationPotential,
        val recommendations: List<ConsumptionRecommendation>,
        val lastUpdated: LocalDateTime
    )
    
    data class DriverConsumptionAnalysis(
        val driverId: String,
        val timeWindow: TimeWindow,
        val averageEfficiencyScore: Double,
        val consistencyScore: Double,
        val ecoDrivingScore: Double,
        val fuelSavingPotential: Double,
        val speedBehavior: SpeedBehaviorAnalysis,
        val idleBehavior: IdleBehaviorAnalysis,
        val routePreference: RoutePreferenceAnalysis,
        val loadManagement: LoadManagementAnalysis,
        val fleetComparison: FleetComparison,
        val recommendations: List<DriverRecommendation>,
