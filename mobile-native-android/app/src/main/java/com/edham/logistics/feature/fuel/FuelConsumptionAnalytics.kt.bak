    data class RouteConsumptionAnalysis(
        val routeId: String,
        val timeWindow: TimeWindow,
        val averageConsumptionRate: Double,
        val consumptionVariability: Double,
        val optimalConditions: List<DrivingConditions>,
        val challengingSegments: List<RouteSegment>,
        val timeOfDayImpact: TimeOfDayImpact,
        val seasonalImpact: SeasonalImpact,
        val weatherImpact: WeatherImpactAnalysis,
