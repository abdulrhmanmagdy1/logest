package com.edham.logistics.adapters

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.ImageView
import android.widget.TextView
import androidx.recyclerview.widget.RecyclerView
import com.edham.logistics.R
import com.edham.logistics.domain.model.InventoryItem

class InventoryManagementAdapter(
    private var inventory: List<InventoryItem>,
    private val onItemClick: (InventoryItem) -> Unit
) : RecyclerView.Adapter<InventoryManagementAdapter.InventoryViewHolder>() {

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): InventoryViewHolder {
        val view = LayoutInflater.from(parent.context)
            .inflate(R.layout.item_inventory_management, parent, false)
        return InventoryViewHolder(view)
    }

    override fun onBindViewHolder(holder: InventoryViewHolder, position: Int) {
        holder.bind(inventory[position])
    }

    override fun getItemCount(): Int = inventory.size

    fun updateInventory(newInventory: List<InventoryItem>) {
        inventory = newInventory
        notifyDataSetChanged()
    }

    inner class InventoryViewHolder(itemView: View) : RecyclerView.ViewHolder(itemView) {
        private val tvItemName: TextView = itemView.findViewById(R.id.tvItemName)
        private val tvCategory: TextView = itemView.findViewById(R.id.tvCategory)
        private val tvQuantity: TextView = itemView.findViewById(R.id.tvQuantity)
        private val tvPrice: TextView = itemView.findViewById(R.id.tvPrice)
        private val tvStatus: TextView = itemView.findViewById(R.id.tvStatus)
        private val ivStatusIcon: ImageView = itemView.findViewById(R.id.ivStatusIcon)

        fun bind(item: InventoryItem) {
            tvItemName.text = item.name
            tvCategory.text = item.category
            tvQuantity.text = "${item.quantity} قطعة"
            tvPrice.text = String.format("%.2f ريال", item.price)
            tvStatus.text = item.status

            // Set status icon and color
            when (item.status) {
                "متوفر" -> {
                    ivStatusIcon.setImageResource(R.drawable.circle_green)
                    tvStatus.setTextColor(itemView.context.getColor(R.color.supervisor_success))
                }
                "مخزون منخفض" -> {
                    ivStatusIcon.setImageResource(R.drawable.circle_warning)
                    tvStatus.setTextColor(itemView.context.getColor(R.color.supervisor_warning))
                }
                "نفد المخزون" -> {
                    ivStatusIcon.setImageResource(R.drawable.circle_red)
                    tvStatus.setTextColor(itemView.context.getColor(R.color.supervisor_error))
                }
                "مطلوب" -> {
                    ivStatusIcon.setImageResource(R.drawable.circle_blue)
                    tvStatus.setTextColor(itemView.context.getColor(R.color.supervisor_info))
                }
                else -> {
                    ivStatusIcon.setImageResource(R.drawable.circle_grey)
                    tvStatus.setTextColor(itemView.context.getColor(R.color.text_secondary))
                }
            }

            itemView.setOnClickListener {
                onItemClick(item)
            }
        }
    }
}
