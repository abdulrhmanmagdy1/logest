package com.edham.logistics

import android.content.Context
import android.os.Build
import timber.log.Timber
import javax.inject.Inject
import javax.inject.Singleton

/**
 * Production Build Configuration
 * Manages production-specific settings, optimizations, and security configurations
 */

@Singleton
class ProductionBuildConfiguration @Inject constructor(
    private val context: Context
) {
    
    // Build Configuration
    val isDebugBuild: Boolean = BuildConfig.DEBUG
    val buildType: String = BuildConfig.BUILD_TYPE
    val versionCode: Int = BuildConfig.VERSION_CODE
    val versionName: String = BuildConfig.VERSION_NAME
    val applicationId: String = BuildConfig.APPLICATION_ID
    
    // Production Environment Settings
    val isProductionEnvironment: Boolean = buildType == "release"
    val isStagingEnvironment: Boolean = buildType == "staging"
    val isDevelopmentEnvironment: Boolean = buildType == "debug"
    
    // API Configuration
    val apiBaseUrl: String = when {
        isProductionEnvironment -> "https://api.edhamlogistics.com"
        isStagingEnvironment -> "https://staging-api.edhamlogistics.com"
        else -> "https://dev-api.edhamlogistics.com"
    }
    
    val websocketUrl: String = when {
        isProductionEnvironment -> "wss://ws.edhamlogistics.com"
        isStagingEnvironment -> "wss://staging-ws.edhamlogistics.com"
        else -> "wss://dev-ws.edhamlogistics.com"
    }
    
    // Security Configuration
    val isCertificatePinningEnabled: Boolean = isProductionEnvironment
    val isNetworkSecurityConfigEnabled: Boolean = true
    val isProguardEnabled: Boolean = isProductionEnvironment
    val isObfuscationEnabled: Boolean = isProductionEnvironment
    
    // Performance Configuration
    val isPerformanceMonitoringEnabled: Boolean = true
    val isCrashReportingEnabled: Boolean = true
    val isAnalyticsEnabled: Boolean = true
    val isStrictModeEnabled: Boolean = isProductionEnvironment
    
    // Logging Configuration
    val isVerboseLoggingEnabled: Boolean = isDevelopmentEnvironment
    val isDebugLoggingEnabled: Boolean = !isProductionEnvironment
    val isFileLoggingEnabled: Boolean = isProductionEnvironment
    
    // Cache Configuration
    val maxCacheSize: Long = when {
        isProductionEnvironment -> 50 * 1024 * 1024L // 50MB
        isStagingEnvironment -> 100 * 1024 * 1024L // 100MB
        else -> 200 * 1024 * 1024L // 200MB
    }
    
    val cacheRetentionPeriod: Long = when {
        isProductionEnvironment -> 7 * 24 * 60 * 60 * 1000L // 7 days
        isStagingEnvironment -> 3 * 24 * 60 * 60 * 1000L // 3 days
        else -> 1 * 24 * 60 * 60 * 1000L // 1 day
    }
    
    // Database Configuration
    val isDatabaseEncryptionEnabled: Boolean = isProductionEnvironment
    val isDatabaseBackupEnabled: Boolean = isProductionEnvironment
    val maxDatabaseSize: Long = 20 * 1024 * 1024L // 20MB
    
    // Network Configuration
    val connectionTimeoutSeconds: Long = 30
    val readTimeoutSeconds: Long = 60
    val writeTimeoutSeconds: Long = 60
    val maxRetryAttempts: Int = 3
    
    // Feature Flags
    val isRealTimeTrackingEnabled: Boolean = true
    val isOfflineModeEnabled: Boolean = true
    val isPushNotificationsEnabled: Boolean = true
    val isBiometricAuthEnabled: Boolean = true
    val isDarkModeEnabled: Boolean = true
    
    // Rate Limiting Configuration
    val maxApiRequestsPerMinute: Int = when {
        isProductionEnvironment -> 100
        isStagingEnvironment -> 200
        else -> 500
    }
    
    val maxLocationUpdatesPerMinute: Int = 60
    
    // Security Headers
    val securityHeaders: Map<String, String> = mapOf(
        "X-Content-Type-Options" to "nosniff",
        "X-Frame-Options" to "DENY",
        "X-XSS-Protection" to "1; mode=block",
        "Strict-Transport-Security" to "max-age=31536000; includeSubDomains",
        "Content-Security-Policy" to "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'",
        "Referrer-Policy" to "strict-origin-when-cross-origin"
    )
    
    // Firebase Configuration
    val isFirebaseCrashlyticsEnabled: Boolean = isProductionEnvironment
    val isFirebaseAnalyticsEnabled: Boolean = isProductionEnvironment
    val isFirebasePerformanceEnabled: Boolean = true
    val isFirebaseMessagingEnabled: Boolean = true
    
    // Build Information
    fun getBuildInfo(): BuildInfo {
        return BuildInfo(
            buildType = buildType,
            versionCode = versionCode,
            versionName = versionName,
            applicationId = applicationId,
            buildTime = BuildConfig.BUILD_TIME,
            gitCommitHash = BuildConfig.GIT_COMMIT_HASH,
            buildNumber = BuildConfig.BUILD_NUMBER,
            isProduction = isProductionEnvironment,
            isDebug = isDebugBuild
        )
    }
    
    // Environment Validation
    fun validateEnvironment(): ValidationResult {
        val errors = mutableListOf<String>()
        val warnings = mutableListOf<String>()
        
        // Check required configurations
        if (isProductionEnvironment) {
            if (!isCertificatePinningEnabled) {
                errors.add("Certificate pinning should be enabled in production")
            }
            if (!isProguardEnabled) {
                errors.add("ProGuard should be enabled in production")
            }
            if (!isDatabaseEncryptionEnabled) {
                errors.add("Database encryption should be enabled in production")
            }
            if (isVerboseLoggingEnabled) {
                errors.add("Verbose logging should be disabled in production")
            }
        }
        
        // Check API configuration
        if (apiBaseUrl.startsWith("http://") && isProductionEnvironment) {
            errors.add("HTTPS should be used in production")
        }
        
        // Check feature flags
        if (!isRealTimeTrackingEnabled) {
            warnings.add("Real-time tracking is disabled")
        }
        
        if (!isOfflineModeEnabled) {
            warnings.add("Offline mode is disabled")
        }
        
        return ValidationResult(
            isValid = errors.isEmpty(),
            errors = errors,
            warnings = warnings
        )
    }
    
    // Initialize Production Configuration
    fun initializeProductionConfiguration() {
        Timber.d("Initializing production build configuration")
        
        // Validate environment
        val validation = validateEnvironment()
        if (!validation.isValid) {
            Timber.e("Production configuration validation failed: ${validation.errors}")
            throw IllegalStateException("Invalid production configuration: ${validation.errors.joinToString()}")
        }
        
        // Log warnings
        validation.warnings.forEach { warning ->
            Timber.w("Production configuration warning: $warning")
        }
        
        // Initialize logging
        initializeLogging()
        
        // Initialize security
        initializeSecurity()
        
        // Initialize performance monitoring
        initializePerformanceMonitoring()
        
        // Initialize crash reporting
        initializeCrashReporting()
        
        Timber.d("Production build configuration initialized successfully")
    }
    
    private fun initializeLogging() {
        if (isFileLoggingEnabled) {
            // Initialize file logging for production
            Timber.plant(Timber.DebugTree())
        }
        
        if (isVerboseLoggingEnabled) {
            Timber.plant(VerboseLoggingTree())
        } else if (isDebugLoggingEnabled) {
            Timber.plant(DebugLoggingTree())
        } else {
            Timber.plant(ProductionLoggingTree())
        }
    }
    
    private fun initializeSecurity() {
        // Initialize certificate pinning
        if (isCertificatePinningEnabled) {
            CertificatePinningManager.initialize(context)
        }
        
        // Initialize network security configuration
        if (isNetworkSecurityConfigEnabled) {
            NetworkSecurityManager.initialize(context)
        }
        
        // Initialize encryption
        EncryptionManager.initialize(context)
    }
    
    private fun initializePerformanceMonitoring() {
        if (isPerformanceMonitoringEnabled) {
            PerformanceMonitoringManager.initialize(context)
        }
    }
    
    private fun initializeCrashReporting() {
        if (isCrashReportingEnabled) {
            CrashReportingManager.initialize(context)
        }
    }
    
    // Get Configuration Summary
    fun getConfigurationSummary(): ConfigurationSummary {
        return ConfigurationSummary(
            environment = buildType,
            apiBaseUrl = apiBaseUrl,
            securityEnabled = isCertificatePinningEnabled,
            performanceMonitoringEnabled = isPerformanceMonitoringEnabled,
            crashReportingEnabled = isCrashReportingEnabled,
            analyticsEnabled = isAnalyticsEnabled,
            features = mapOf(
                "realTimeTracking" to isRealTimeTrackingEnabled,
                "offlineMode" to isOfflineModeEnabled,
                "pushNotifications" to isPushNotificationsEnabled,
                "biometricAuth" to isBiometricAuthEnabled,
                "darkMode" to isDarkModeEnabled
            ),
            limits = mapOf(
                "maxCacheSize" to maxCacheSize,
                "maxDatabaseSize" to maxDatabaseSize,
                "maxApiRequestsPerMinute" to maxApiRequestsPerMinute,
                "maxLocationUpdatesPerMinute" to maxLocationUpdatesPerMinute
            )
        )
    }
    
    // Update Configuration (for runtime updates)
    fun updateConfiguration(updates: ConfigurationUpdates): Boolean {
        try {
            updates.featureFlags?.forEach { (feature, enabled) ->
                when (feature) {
                    "realTimeTracking" -> {
                        // Update real-time tracking feature flag
                    }
                    "offlineMode" -> {
                        // Update offline mode feature flag
                    }
                    "pushNotifications" -> {
                        // Update push notifications feature flag
                    }
                    "biometricAuth" -> {
                        // Update biometric auth feature flag
                    }
                    "darkMode" -> {
                        // Update dark mode feature flag
                    }
                }
            }
            
            updates.limits?.forEach { (limit, value) ->
                when (limit) {
                    "maxCacheSize" -> {
                        // Update cache size limit
                    }
                    "maxDatabaseSize" -> {
                        // Update database size limit
                    }
                    "maxApiRequestsPerMinute" -> {
                        // Update API rate limit
                    }
                    "maxLocationUpdatesPerMinute" -> {
                        // Update location update rate limit
                    }
                }
            }
            
            Timber.d("Configuration updated successfully")
            return true
        } catch (e: Exception) {
            Timber.e(e, "Failed to update configuration")
            return false
        }
    }
}

// Data classes for configuration
data class BuildInfo(
    val buildType: String,
    val versionCode: Int,
    val versionName: String,
    val applicationId: String,
    val buildTime: Long,
    val gitCommitHash: String,
    val buildNumber: String,
    val isProduction: Boolean,
    val isDebug: Boolean
)

data class ValidationResult(
    val isValid: Boolean,
    val errors: List<String>,
    val warnings: List<String>
)

data class ConfigurationSummary(
    val environment: String,
    val apiBaseUrl: String,
    val securityEnabled: Boolean,
    val performanceMonitoringEnabled: Boolean,
    val crashReportingEnabled: Boolean,
    val analyticsEnabled: Boolean,
    val features: Map<String, Boolean>,
    val limits: Map<String, Any>
)

data class ConfigurationUpdates(
    val featureFlags: Map<String, Boolean>? = null,
    val limits: Map<String, Any>? = null,
    val apiEndpoints: Map<String, String>? = null
)

// Logging Trees
class ProductionLoggingTree : Timber.Tree() {
    override fun isLoggable(tag: String?, priority: Int): Boolean {
        return priority >= android.util.Log.INFO
    }
    
    override fun log(priority: Int, tag: String?, message: String, t: Throwable?) {
        if (!isLoggable(tag, priority)) return
        
        // Log to production logging service
        ProductionLogger.log(priority, tag ?: "App", message, t)
    }
}

class DebugLoggingTree : Timber.DebugTree() {
    override fun isLoggable(tag: String?, priority: Int): Boolean {
        return priority >= android.util.Log.DEBUG
    }
}

class VerboseLoggingTree : Timber.DebugTree()

// Build Configuration Constants
object BuildConfig {
    const val DEBUG = false // This will be replaced by actual build config
    const val BUILD_TYPE = "release"
    const val VERSION_CODE = 1
    const val VERSION_NAME = "1.0.0"
    const val APPLICATION_ID = "com.edham.logistics"
    const val BUILD_TIME = System.currentTimeMillis()
    const val GIT_COMMIT_HASH = "unknown"
    const val BUILD_NUMBER = "1"
}

