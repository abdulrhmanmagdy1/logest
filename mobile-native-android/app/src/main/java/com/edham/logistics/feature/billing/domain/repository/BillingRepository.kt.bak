package com.edham.logistics.feature.billing.domain.repository

import com.edham.logistics.core.utils.Result
import com.edham.logistics.feature.billing.domain.model.*
import kotlinx.coroutines.flow.Flow

interface BillingRepository {
    
    // Invoice Management
    suspend fun createInvoice(invoice: Invoice): Result<Invoice>
    suspend fun getInvoiceById(invoiceId: String): Result<Invoice>
    suspend fun updateInvoice(invoice: Invoice): Result<Invoice>
    suspend fun updateInvoiceStatus(invoiceId: String, status: InvoiceStatus): Result<Unit>
    suspend fun deleteInvoice(invoiceId: String): Result<Unit>
    suspend fun getInvoices(request: GetInvoicesRequest): Result<List<Invoice>>
    suspend fun getInvoicesByCustomer(customerId: String): Result<List<Invoice>>
    suspend fun getOverdueInvoices(): Result<List<Invoice>>
    
    // Payment Management
    suspend fun createPayment(payment: Payment): Result<Payment>
    suspend fun getPaymentById(paymentId: String): Result<Payment>
    suspend fun updatePayment(payment: Payment): Result<Payment>
    suspend fun getPayments(request: GetPaymentsRequest): Result<List<Payment>>
    suspend fun getInvoicePayments(invoiceId: String): Result<List<Payment>>
    suspend fun getCustomerPayments(customerId: String): Result<List<Payment>>
    suspend fun getTotalPaidAmount(invoiceId: String): Result<Double>
    
    // Payment Gateway Management
    suspend fun getPaymentGateway(gatewayId: String): Result<PaymentGateway>
    suspend fun getAllPaymentGateways(): Result<List<PaymentGateway>>
    suspend fun createPaymentGateway(gateway: PaymentGateway): Result<PaymentGateway>
    suspend fun updatePaymentGateway(gateway: PaymentGateway): Result<PaymentGateway>
    suspend fun deletePaymentGateway(gatewayId: String): Result<Unit>
    
    // Billing Settings
    suspend fun getBillingSettings(): Result<BillingSettings>
    suspend fun updateBillingSettings(settings: BillingSettings): Result<BillingSettings>
    suspend fun resetBillingSettings(): Result<BillingSettings>
    
    // Invoice Generation
    suspend fun getShipmentById(shipmentId: String): Result<ShipmentDetails>
    suspend fun generateInvoiceNumber(prefix: String, format: String): Result<String>
    suspend fun calculateShippingFee(shipmentId: String): Result<Double>
    suspend fun calculateInsuranceFee(insuranceValue: Double): Result<Double>
    suspend fun calculateTaxAmount(amount: Double): Result<Double>
    
    // Export and Reports
    suspend fun saveExportFile(fileName: String, content: ByteArray, contentType: String): Result<String>
    suspend fun getExportFileUrl(filePath: String): Result<String>
    suspend fun deleteExportFile(filePath: String): Result<Unit>
    suspend fun generateFinancialReport(type: FinancialReportType, period: ReportPeriod): Result<FinancialReport>
    suspend fun getAgingReport(): Result<List<AgingReportItem>>
    
    // Notifications and Communication
    suspend fun sendInvoiceEmail(invoiceId: String, templateType: EmailTemplateType, customerEmail: String): Result<Unit>
    suspend fun sendInvoiceSms(invoiceId: String, templateType: SmsTemplateType, customerPhone: String): Result<Unit>
    suspend fun sendPaymentConfirmation(paymentId: String): Result<Unit>
    suspend fun sendOverdueReminders(): Result<List<String>>
    
    // WebSocket and Real-time Updates
    suspend fun sendBillingNotification(type: BillingWebSocketType, data: Map<String, Any>): Result<Unit>
    suspend fun observeBillingUpdates(): Flow<Result<BillingWebSocketMessage>>
    
    // Templates Management
    suspend fun getEmailTemplate(type: EmailTemplateType): Result<EmailTemplate>
    suspend fun updateEmailTemplate(template: EmailTemplate): Result<EmailTemplate>
    suspend fun getSmsTemplate(type: SmsTemplateType): Result<SmsTemplate>
    suspend fun updateSmsTemplate(template: SmsTemplate): Result<SmsTemplate>
    
    // Analytics and Statistics
    suspend fun getInvoiceStatistics(period: ReportPeriod): Result<InvoiceStatistics>
    suspend fun getPaymentStatistics(period: ReportPeriod): Result<PaymentStatistics>
    suspend fun getRevenueAnalytics(period: ReportPeriod): Result<RevenueAnalytics>
    suspend fun getCustomerBillingAnalytics(customerId: String, period: ReportPeriod): Result<CustomerBillingAnalytics>
    
    // Batch Operations
    suspend fun markInvoicesAsOverdue(): Result<Int>
    suspend fun applyLateFees(): Result<Int>
    suspend fun sendBulkInvoices(invoiceIds: List<String>): Result<Int>
    suspend fun processRefunds(refundRequests: List<RefundRequest>): Result<List<RefundResult>>
    
    // Search and Filtering
    suspend fun searchInvoices(query: String, filters: Map<String, Any>): Result<List<Invoice>>
    suspend fun searchPayments(query: String, filters: Map<String, Any>): Result<List<Payment>>
    suspend fun filterInvoicesByDateRange(startDate: Long, endDate: Long): Result<List<Invoice>>
    suspend fun filterPaymentsByDateRange(startDate: Long, endDate: Long): Result<List<Payment>>
    
    // Validation and Business Rules
    suspend fun validateInvoice(invoice: Invoice): Result<ValidationResult>
    suspend fun validatePayment(payment: Payment): Result<ValidationResult>
    suspend fun checkDuplicateInvoice(invoiceNumber: String): Result<Boolean>
    suspend fun checkPaymentLimits(customerId: String, amount: Double): Result<Boolean>
    
    // Audit and Logging
    suspend fun logBillingActivity(activity: BillingActivity): Result<Unit>
    suspend fun getBillingAuditLog(filters: Map<String, Any>): Result<List<BillingActivity>>
    suspend fun trackInvoiceAccess(invoiceId: String, userId: String): Result<Unit>
}

// Supporting data classes for repository operations
data class InvoiceStatistics(
    val totalInvoices: Long,
    val paidInvoices: Long,
    val unpaidInvoices: Long,
    val overdueInvoices: Long,
    val totalRevenue: Double,
    val averageInvoiceAmount: Double,
    val invoicesByStatus: Map<InvoiceStatus, Long>,
    val revenueByMonth: List<MonthlyRevenue>
)

data class PaymentStatistics(
    val totalPayments: Long,
    val totalAmount: Double,
    val successfulPayments: Long,
    val failedPayments: Long,
    val paymentsByMethod: Map<PaymentMethod, Long>,
    val paymentsByStatus: Map<PaymentStatus, Long>,
    val averagePaymentAmount: Double
)

data class RevenueAnalytics(
    val totalRevenue: Double,
    val monthlyRevenue: List<MonthlyRevenue>,
    val revenueByCategory: Map<String, Double>,
    val growthRate: Double,
    val forecast: RevenueForecast
)

data class CustomerBillingAnalytics(
    val customerId: String,
    val customerName: String,
    val totalInvoices: Long,
    val totalPayments: Double,
    val outstandingAmount: Double,
    val averageInvoiceAmount: Double,
    val paymentHistory: List<PaymentSummary>,
    const val latePaymentCount: Int,
    val creditScore: Double
)

data class PaymentSummary(
    val paymentId: String,
    val amount: Double,
    val paymentDate: Long,
    val paymentMethod: PaymentMethod,
    val status: PaymentStatus
)

data class AgingReportItem(
    val customerId: String,
    val customerName: String,
    val current: Double,
    val days1_30: Double,
    val days31_60: Double,
    val days61_90: Double,
    val over90: Double,
    val total: Double
)

data class RefundRequest(
    val paymentId: String,
    val amount: Double,
    val reason: String,
    val processedBy: String
)

data class RefundResult(
    val paymentId: String,
    val success: Boolean,
    val refundId: String?,
    val errorMessage: String?
)

data class ValidationResult(
    val isValid: Boolean,
    val errors: List<String>,
    val warnings: List<String>
)

data class BillingActivity(
    val id: String,
    val type: BillingActivityType,
    val userId: String,
    val userName: String,
    val invoiceId: String?,
    val paymentId: String?,
    val description: String,
    val metadata: Map<String, Any>,
    val timestamp: Long
)

enum class BillingActivityType {
    INVOICE_CREATED,
    INVOICE_UPDATED,
    INVOICE_DELETED,
    PAYMENT_PROCESSED,
    PAYMENT_FAILED,
    REFUND_PROCESSED,
    SETTINGS_UPDATED,
    REPORT_GENERATED,
    EXPORT_CREATED
}
