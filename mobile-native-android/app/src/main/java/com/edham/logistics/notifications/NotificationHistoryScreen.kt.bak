package com.edham.logistics.notifications

import androidx.compose.animation.*
import androidx.compose.foundation.background
import androidx.compose.foundation.clickable
import androidx.compose.foundation.layout.*
import androidx.compose.foundation.lazy.LazyColumn
import androidx.compose.foundation.lazy.items
import androidx.compose.foundation.shape.RoundedCornerShape
import androidx.compose.material.icons.Icons
import androidx.compose.material.icons.filled.*
import androidx.compose.material3.*
import androidx.compose.runtime.*
import androidx.compose.ui.Alignment
import androidx.compose.ui.Modifier
import androidx.compose.ui.draw.clip
import androidx.compose.ui.graphics.Color
import androidx.compose.ui.graphics.vector.ImageVector
import androidx.compose.ui.text.font.FontWeight
import androidx.compose.ui.text.style.TextOverflow
import androidx.compose.ui.unit.dp
import androidx.compose.ui.unit.sp
import java.time.LocalDateTime
import java.time.format.DateTimeFormatter

/**
 * Notification history screen
 * Displays all notifications with filtering, search, and management options
 */
@OptIn(ExperimentalMaterial3Api::class)
@Composable
fun NotificationHistoryScreen(
    notifications: List<UnifiedNotificationService.InAppNotification>,
    onNotificationClick: (UnifiedNotificationService.InAppNotification) -> Unit,
    onMarkAsRead: (String) -> Unit,
    onMarkAllAsRead: () -> Unit,
    onClearAll: () -> Unit,
    onDeleteNotification: (String) -> Unit,
    modifier: Modifier = Modifier
) {
    var selectedCategory by remember { mutableStateOf<NotificationCategory?>(null) }
    var selectedPriority by remember { mutableStateOf<NotificationPriority?>(null) }
    var searchQuery by remember { mutableStateOf("") }
    var showFilters by remember { mutableStateOf(false) }
    var selectedNotification by remember { mutableStateOf<UnifiedNotificationService.InAppNotification?>(null) }

    // Filter notifications
    val filteredNotifications = remember(notifications, selectedCategory, selectedPriority, searchQuery) {
        notifications.filter { notification ->
            // Category filter
            val categoryMatch = selectedCategory == null || 
                    NotificationCategory.valueOf(notification.category) == selectedCategory
            
            // Priority filter
            val priorityMatch = selectedPriority == null || 
                    NotificationPriority.valueOf(notification.priority) == selectedPriority
            
            // Search filter
            val searchMatch = searchQuery.isEmpty() || 
                    notification.title.contains(searchQuery, ignoreCase = true) ||
                    notification.body.contains(searchQuery, ignoreCase = true)
            
            categoryMatch && priorityMatch && searchMatch
        }
    }

    // Statistics
    val statistics = remember(notifications) {
        NotificationStatistics(
            total = notifications.size,
            unread = notifications.count { !it.read },
            byCategory = notifications.groupBy { it.category }
                .mapValues { it.value.size },
            byPriority = notifications.groupBy { it.priority }
                .mapValues { it.value.size }
        )
    }

    Column(
        modifier = modifier
            .fillMaxSize()
            .background(Color(0xFF1A1A1A))
            .padding(16.dp)
    ) {
        // Header
        NotificationHeader(
            statistics = statistics,
            onMarkAllAsRead = onMarkAllAsRead,
            onClearAll = onClearAll,
            onShowFilters = { showFilters = true }
        )

        Spacer(modifier = Modifier.height(16.dp))

        // Search bar
        SearchBar(
            query = searchQuery,
            onQueryChange = { searchQuery = it },
            placeholder = "Search notifications..."
        )

        Spacer(modifier = Modifier.height(16.dp))

        // Filters
        if (showFilters) {
            FilterSection(
                selectedCategory = selectedCategory,
                selectedPriority = selectedPriority,
                onCategorySelected = { selectedCategory = it },
                onPrioritySelected = { selectedPriority = it },
                onDismiss = { showFilters = false }
            )
            
            Spacer(modifier = Modifier.height(16.dp))
        }

        // Notification list
        if (filteredNotifications.isEmpty()) {
            EmptyState(
                message = if (searchQuery.isNotEmpty() || selectedCategory != null || selectedPriority != null) {
                    "No notifications found matching your criteria"
                } else {
                    "No notifications yet"
                }
            )
        } else {
            LazyColumn(
                verticalArrangement = Arrangement.spacedBy(8.dp)
            ) {
                items(filteredNotifications) { notification ->
                    NotificationItem(
                        notification = notification,
                        onClick = { onNotificationClick(notification) },
                        onMarkAsRead = { onMarkAsRead(notification.id) },
                        onDelete = { onDeleteNotification(notification.id) }
                    )
                }
            }
        }
    }

    // Notification detail dialog
    selectedNotification?.let { notification ->
        NotificationDetailDialog(
            notification = notification,
            onDismiss = { selectedNotification = null },
            onMarkAsRead = { onMarkAsRead(notification.id) },
            onDelete = { onDeleteNotification(notification.id) }
        )
    }
}

/**
 * Notification header with statistics and actions
 */
@Composable
private fun NotificationHeader(
    statistics: NotificationStatistics,
    onMarkAllAsRead: () -> Unit,
    onClearAll: () -> Unit,
    onShowFilters: () -> Unit,
    modifier: Modifier = Modifier
) {
    Column(modifier = modifier) {
        // Title and statistics
        Row(
            modifier = Modifier.fillMaxWidth(),
            horizontalArrangement = Arrangement.SpaceBetween,
            verticalAlignment = Alignment.CenterVertically
        ) {
            Text(
                text = "Notifications",
                fontSize = 24.sp,
                fontWeight = FontWeight.Bold,
                color = Color.White
            )
            
            // Unread count badge
            if (statistics.unread > 0) {
                BadgedBox(
                    badge = {
                        Text(
                            text = statistics.unread.toString(),
                            color = Color.White,
                            fontSize = 12.sp,
                            fontWeight = FontWeight.Bold
                        )
                    }
                ) {
                    Icon(
                        imageVector = Icons.Default.Notifications,
                        contentDescription = "Notifications",
                        tint = Color(0xFFF97316)
                    )
                }
            }
        }

        Spacer(modifier = Modifier.height(8.dp))

        // Statistics row
        Row(
            modifier = Modifier.fillMaxWidth(),
            horizontalArrangement = Arrangement.SpaceBetween,
            verticalAlignment = Alignment.CenterVertically
        ) {
            Text(
                text = "${statistics.total} total • ${statistics.unread} unread",
                fontSize = 14.sp,
                color = Color(0xFF9CA3AF)
            )

            Row(
                horizontalArrangement = Arrangement.spacedBy(8.dp)
            ) {
                // Filter button
                IconButton(
                    onClick = onShowFilters,
                    modifier = Modifier
                        .background(Color(0xFF374151), RoundedCornerShape(8.dp))
                        .size(40.dp)
                ) {
                    Icon(
                        imageVector = Icons.Default.FilterList,
                        contentDescription = "Filter",
                        tint = Color.White
                    )
                }

                // Mark all as read button
                if (statistics.unread > 0) {
                    IconButton(
                        onClick = onMarkAllAsRead,
                        modifier = Modifier
                            .background(Color(0xFF10B981), RoundedCornerShape(8.dp))
                            .size(40.dp)
                    ) {
                        Icon(
                            imageVector = Icons.Default.DoneAll,
                            contentDescription = "Mark all as read",
                            tint = Color.White
                        )
                    }
                }

                // Clear all button
                IconButton(
                    onClick = onClearAll,
                    modifier = Modifier
                        .background(Color(0xFFEF4444), RoundedCornerShape(8.dp))
                        .size(40.dp)
                ) {
                    Icon(
                        imageVector = Icons.Default.ClearAll,
                        contentDescription = "Clear all",
                        tint = Color.White
                    )
                }
            }
        }
    }
}

/**
 * Search bar for notifications
 */
@Composable
private fun SearchBar(
    query: String,
    onQueryChange: (String) -> Unit,
    placeholder: String,
    modifier: Modifier = Modifier
) {
    OutlinedTextField(
        value = query,
        onValueChange = onQueryChange,
        placeholder = { Text(placeholder, color = Color(0xFF9CA3AF)) },
        leadingIcon = {
            Icon(
                imageVector = Icons.Default.Search,
                contentDescription = "Search",
                tint = Color(0xFF9CA3AF)
            )
        },
        modifier = modifier.fillMaxWidth(),
        colors = OutlinedTextFieldDefaults.colors(
            focusedBorderColor = Color(0xFFF97316),
            unfocusedBorderColor = Color(0xFF374151),
            cursorColor = Color(0xFFF97316),
            textColor = Color.White
        ),
        shape = RoundedCornerShape(12.dp)
    )
}

/**
 * Filter section for categories and priorities
 */
@Composable
private fun FilterSection(
    selectedCategory: NotificationCategory?,
    selectedPriority: NotificationPriority?,
    onCategorySelected: (NotificationCategory?) -> Unit,
    onPrioritySelected: (NotificationPriority?) -> Unit,
    onDismiss: () -> Unit,
    modifier: Modifier = Modifier
) {
    Card(
        modifier = modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(containerColor = Color(0xFF374151))
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            // Header
            Row(
                modifier = Modifier.fillMaxWidth(),
                horizontalArrangement = Arrangement.SpaceBetween,
                verticalAlignment = Alignment.CenterVertically
            ) {
                Text(
                    text = "Filters",
                    fontSize = 18.sp,
                    fontWeight = FontWeight.Bold,
                    color = Color.White
                )

                IconButton(onClick = onDismiss) {
                    Icon(
                        imageVector = Icons.Default.Close,
                        contentDescription = "Close",
                        tint = Color.White
                    )
                }
            }

            Spacer(modifier = Modifier.height(16.dp))

            // Category filters
            Text(
                text = "Category",
                fontSize = 14.sp,
                fontWeight = FontWeight.Medium,
                color = Color(0xFF9CA3AF)
            )

            Spacer(modifier = Modifier.height(8.dp))

            LazyColumn(
                verticalArrangement = Arrangement.spacedBy(4.dp)
            ) {
                item {
                    FilterChip(
                        text = "All Categories",
                        isSelected = selectedCategory == null,
                        onClick = { onCategorySelected(null) }
                    )
                }

                items(NotificationCategory.values()) { category ->
                    FilterChip(
                        text = getDisplayName(category),
                        isSelected = selectedCategory == category,
                        onClick = { onCategorySelected(category) }
                    )
                }
            }

            Spacer(modifier = Modifier.height(16.dp))

            // Priority filters
            Text(
                text = "Priority",
                fontSize = 14.sp,
                fontWeight = FontWeight.Medium,
                color = Color(0xFF9CA3AF)
            )

            Spacer(modifier = Modifier.height(8.dp))

            LazyColumn(
                verticalArrangement = Arrangement.spacedBy(4.dp)
            ) {
                item {
                    FilterChip(
                        text = "All Priorities",
                        isSelected = selectedPriority == null,
                        onClick = { onPrioritySelected(null) }
                    )
                }

                items(NotificationPriority.values()) { priority ->
                    FilterChip(
                        text = getPriorityDisplayName(priority),
                        isSelected = selectedPriority == priority,
                        onClick = { onPrioritySelected(priority) }
                    )
                }
            }
        }
    }
}

/**
 * Individual notification item
 */
@Composable
private fun NotificationItem(
    notification: UnifiedNotificationService.InAppNotification,
    onClick: () -> Unit,
    onMarkAsRead: () -> Unit,
    onDelete: () -> Unit,
    modifier: Modifier = Modifier
) {
    val isRead by remember { mutableStateOf(notification.read) }
    val category = NotificationCategory.valueOf(notification.category)
    val priority = NotificationPriority.valueOf(notification.priority)

    Card(
        modifier = modifier
            .fillMaxWidth()
            .clickable { onClick() },
        colors = CardDefaults.cardColors(
            containerColor = if (isRead) Color(0xFF374151) else Color(0xFF4B5563)
        )
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            // Header with category, priority, and actions
            Row(
                modifier = Modifier.fillMaxWidth(),
                horizontalArrangement = Arrangement.SpaceBetween,
                verticalAlignment = Alignment.CenterVertically
            ) {
                // Category and priority
                Row(
                    horizontalArrangement = Arrangement.spacedBy(8.dp),
                    verticalAlignment = Alignment.CenterVertically
                ) {
                    // Category badge
                    CategoryBadge(category = category)

                    // Priority badge
                    PriorityBadge(priority = priority)
                }

                // Actions
                Row(
                    horizontalArrangement = Arrangement.spacedBy(4.dp)
                ) {
                    if (!isRead) {
                        IconButton(
                            onClick = onMarkAsRead,
                            modifier = Modifier.size(32.dp)
                        ) {
                            Icon(
                                imageVector = Icons.Default.Done,
                                contentDescription = "Mark as read",
                                tint = Color(0xFF10B981),
                                modifier = Modifier.size(16.dp)
                            )
                        }
                    }

                    IconButton(
                        onClick = onDelete,
                        modifier = Modifier.size(32.dp)
                    ) {
                        Icon(
                            imageVector = Icons.Default.Delete,
                            contentDescription = "Delete",
                            tint = Color(0xFFEF4444),
                            modifier = Modifier.size(16.dp)
                        )
                    }
                }
            }

            Spacer(modifier = Modifier.height(8.dp))

            // Title
            Text(
                text = notification.title,
                fontSize = 16.sp,
                fontWeight = if (isRead) FontWeight.Normal else FontWeight.Bold,
                color = Color.White,
                maxLines = 2,
                overflow = TextOverflow.Ellipsis
            )

            Spacer(modifier = Modifier.height(4.dp))

            // Body
            Text(
                text = notification.body,
                fontSize = 14.sp,
                color = Color(0xFF9CA3AF),
                maxLines = 3,
                overflow = TextOverflow.Ellipsis
            )

            Spacer(modifier = Modifier.height(8.dp))

            // Timestamp
            Text(
                text = formatTimestamp(notification.timestamp),
                fontSize = 12.sp,
                color = Color(0xFF6B7280)
            )
        }
    }
}

/**
 * Category badge
 */
@Composable
private fun CategoryBadge(category: NotificationCategory) {
    Box(
        modifier = Modifier
            .clip(RoundedCornerShape(4.dp))
            .background(getCategoryColor(category))
            .padding(horizontal = 8.dp, vertical = 4.dp)
    ) {
        Text(
            text = getDisplayName(category),
            fontSize = 12.sp,
            fontWeight = FontWeight.Medium,
            color = Color.White
        )
    }
}

/**
 * Priority badge
 */
@Composable
private fun PriorityBadge(priority: NotificationPriority) {
    Box(
        modifier = Modifier
            .clip(RoundedCornerShape(4.dp))
            .background(getPriorityColor(priority))
            .padding(horizontal = 8.dp, vertical = 4.dp)
    ) {
        Text(
            text = getPriorityDisplayName(priority),
            fontSize = 12.sp,
            fontWeight = FontWeight.Medium,
            color = Color.White
        )
    }
}

/**
 * Filter chip
 */
@Composable
private fun FilterChip(
    text: String,
    isSelected: Boolean,
    onClick: () -> Unit
) {
    Box(
        modifier = Modifier
            .clip(RoundedCornerShape(16.dp))
            .background(
                if (isSelected) Color(0xFFF97316) else Color(0xFF4B5563)
            )
            .clickable { onClick() }
            .padding(horizontal = 12.dp, vertical = 6.dp)
    ) {
        Text(
            text = text,
            fontSize = 14.sp,
            fontWeight = FontWeight.Medium,
            color = Color.White
        )
    }
}

/**
 * Empty state
 */
@Composable
private fun EmptyState(message: String) {
    Column(
        modifier = Modifier.fillMaxWidth(),
        horizontalAlignment = Alignment.CenterHorizontally,
        verticalArrangement = Arrangement.Center
    ) {
        Icon(
            imageVector = Icons.Default.NotificationsNone,
            contentDescription = "No notifications",
            tint = Color(0xFF6B7280),
            modifier = Modifier.size(64.dp)
        )

        Spacer(modifier = Modifier.height(16.dp))

        Text(
            text = message,
            fontSize = 16.sp,
            color = Color(0xFF9CA3AF),
            textAlign = androidx.compose.ui.text.style.TextAlign.Center
        )
    }
}

/**
 * Notification detail dialog
 */
@Composable
private fun NotificationDetailDialog(
    notification: UnifiedNotificationService.InAppNotification,
    onDismiss: () -> Unit,
    onMarkAsRead: () -> Unit,
    onDelete: () -> Unit
) {
    AlertDialog(
        onDismissRequest = onDismiss,
        title = {
            Text(
                text = notification.title,
                color = Color.White,
                fontWeight = FontWeight.Bold
            )
        },
        text = {
            Column {
                // Category and priority
                Row(
                    horizontalArrangement = Arrangement.spacedBy(8.dp),
                    verticalAlignment = Alignment.CenterVertically
                ) {
                    CategoryBadge(category = NotificationCategory.valueOf(notification.category))
                    PriorityBadge(priority = NotificationPriority.valueOf(notification.priority))
                }

                Spacer(modifier = Modifier.height(16.dp))

                // Body
                Text(
                    text = notification.body,
                    color = Color(0xFF9CA3AF),
                    fontSize = 14.sp
                )

                Spacer(modifier = Modifier.height(16.dp))

                // Timestamp
                Text(
                    text = "Received: ${formatTimestamp(notification.timestamp)}",
                    color = Color(0xFF6B7280),
                    fontSize = 12.sp
                )

                // Additional data if available
                notification.data.forEach { (key, value) ->
                    if (key != "title" && key != "body" && key != "category" && key != "priority" && key != "timestamp") {
                        Spacer(modifier = Modifier.height(8.dp))
                        Text(
                            text = "$key: $value",
                            color = Color(0xFF9CA3AF),
                            fontSize = 12.sp
                        )
                    }
                }
            }
        },
        confirmButton = {
            if (!notification.read) {
                TextButton(onClick = {
                    onMarkAsRead()
                    onDismiss()
                }) {
                    Text("Mark as Read", color = Color(0xFF10B981))
                }
            }
        },
        dismissButton = {
            TextButton(onClick = onDismiss) {
                Text("Close", color = Color(0xFF9CA3AF))
            }
        },
        containerColor = Color(0xFF1F2937)
    )
}

// Helper functions and data classes
private fun getDisplayName(category: NotificationCategory): String {
    return when (category) {
        NotificationCategory.SHIPMENT -> "Shipment"
        NotificationCategory.COLD_CHAIN -> "Cold Chain"
        NotificationCategory.DRIVER -> "Driver"
        NotificationCategory.PAYMENT -> "Payment"
        NotificationCategory.FINANCIAL -> "Financial"
        NotificationCategory.SYSTEM -> "System"
        NotificationCategory.EMERGENCY -> "Emergency"
    }
}

private fun getPriorityDisplayName(priority: NotificationPriority): String {
    return when (priority) {
        NotificationPriority.CRITICAL -> "Critical"
        NotificationPriority.HIGH -> "High"
        NotificationPriority.MEDIUM -> "Medium"
        NotificationPriority.LOW -> "Low"
    }
}

private fun getCategoryColor(category: NotificationCategory): Color {
    return when (category) {
        NotificationCategory.SHIPMENT -> Color(0xFF3B82F6)
        NotificationCategory.COLD_CHAIN -> Color(0xFF10B981)
        NotificationCategory.DRIVER -> Color(0xFFF59E0B)
        NotificationCategory.PAYMENT -> Color(0xFF8B5CF6)
        NotificationCategory.FINANCIAL -> Color(0xFF6366F1)
        NotificationCategory.SYSTEM -> Color(0xFF6B7280)
        NotificationCategory.EMERGENCY -> Color(0xFFEF4444)
    }
}

private fun getPriorityColor(priority: NotificationPriority): Color {
    return when (priority) {
        NotificationPriority.CRITICAL -> Color(0xFFEF4444)
        NotificationPriority.HIGH -> Color(0xFFF59E0B)
        NotificationPriority.MEDIUM -> Color(0xFF3B82F6)
        NotificationPriority.LOW -> Color(0xFF6B7280)
    }
}

private fun formatTimestamp(timestamp: Long): String {
    val dateTime = LocalDateTime.ofEpochSecond(timestamp / 1000, 0, java.time.ZoneOffset.UTC)
    return dateTime.format(DateTimeFormatter.ofPattern("MMM dd, yyyy HH:mm"))
}

data class NotificationStatistics(
    val total: Int,
    val unread: Int,
    val byCategory: Map<String, Int>,
    val byPriority: Map<String, Int>
)

enum class NotificationCategory {
    SHIPMENT, COLD_CHAIN, DRIVER, PAYMENT, FINANCIAL, SYSTEM, EMERGENCY
}

enum class NotificationPriority {
    CRITICAL, HIGH, MEDIUM, LOW
}
