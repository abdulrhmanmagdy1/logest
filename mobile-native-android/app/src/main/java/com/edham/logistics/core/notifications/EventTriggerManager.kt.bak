package com.edham.logistics.core.notifications

import kotlinx.coroutines.*
import kotlinx.coroutines.flow.*
import java.util.*
import java.util.concurrent.ConcurrentHashMap
import javax.inject.Inject
import javax.inject.Singleton

/**
 * Event Trigger Manager - Manages smart notification triggers
 * Handles event detection, condition evaluation, and trigger execution
 */
@Singleton
class EventTriggerManager @Inject constructor() {

    private val coroutineScope = CoroutineScope(SupervisorJob() + Dispatchers.IO)
    
    // Event listeners
    private val eventListeners = ConcurrentHashMap<NotificationEvent, MutableList<EventListener>>()
    
    // Trigger conditions
    private val triggerConditions = ConcurrentHashMap<NotificationEvent, MutableList<TriggerCondition>>()
    
    // Event history
    private val eventHistory = MutableStateFlow<List<EventRecord>>(emptyList())
    
    // Active triggers
    private val activeTriggers = ConcurrentHashMap<String, TriggerInstance>()

    /**
     * Initialize event triggers
     */
    fun initialize() {
        setupDefaultTriggers()
        startEventMonitoring()
    }

    /**
     * Register event listener
     */
    fun registerEventListener(
        event: NotificationEvent,
        listener: EventListener
    ) {
        val listeners = eventListeners.getOrPut(event) { mutableListOf() }
        listeners.add(listener)
    }

    /**
     * Register trigger condition
     */
    fun registerTriggerCondition(
        event: NotificationEvent,
        condition: TriggerCondition
    ) {
        val conditions = triggerConditions.getOrPut(event) { mutableListOf() }
        conditions.add(condition)
    }

    /**
     * Process event
     */
    suspend fun processEvent(
        event: NotificationEvent,
        data: Map<String, Any> = emptyMap()
    ) {
        withContext(Dispatchers.IO) {
            try {
                // Create event record
                val eventRecord = EventRecord(
                    id = UUID.randomUUID().toString(),
                    event = event,
                    data = data,
                    timestamp = System.currentTimeMillis()
                )
                
                // Add to history
                addToHistory(eventRecord)
                
                // Check trigger conditions
                val conditions = triggerConditions[event] ?: emptyList()
                val shouldTrigger = conditions.all { it.evaluate(data) }
                
                if (shouldTrigger) {
                    // Create trigger instance
                    val triggerInstance = TriggerInstance(
                        id = UUID.randomUUID().toString(),
                        event = event,
                        data = data,
                        timestamp = System.currentTimeMillis(),
                        status = TriggerStatus.ACTIVE
                    )
                    
                    activeTriggers[triggerInstance.id] = triggerInstance
                    
                    // Notify listeners
                    notifyListeners(event, data, triggerInstance)
                    
                    // Execute trigger actions
                    executeTriggerActions(triggerInstance)
                }
                
            } catch (e: Exception) {
                // Handle event processing error
            }
        }
    }

    /**
     * Setup default triggers
     */
    private fun setupDefaultTriggers() {
        // Shipment delay trigger
        registerTriggerCondition(NotificationEvent.SHIPMENT_DELAYED) { data ->
            val delayMinutes = data["delayMinutes"] as? Int ?: 0
            delayMinutes >= 30 // Trigger if delayed by 30 minutes or more
        }
        
        // Temperature issue trigger
        registerTriggerCondition(NotificationEvent.TEMPERATURE_ISSUE) { data ->
            val currentTemp = data["currentTemp"] as? Double ?: 0.0
            val minTemp = data["minTemp"] as? Double ?: 0.0
            val maxTemp = data["maxTemp"] as? Double ?: 0.0
            
            currentTemp < minTemp || currentTemp > maxTemp
        }
        
        // Payment overdue trigger
        registerTriggerCondition(NotificationEvent.PAYMENT_OVERDUE) { data ->
            val daysOverdue = data["daysOverdue"] as? Int ?: 0
            daysOverdue >= 7 // Trigger if overdue by 7 days or more
        }
        
        // Critical temperature trigger
        registerTriggerCondition(NotificationEvent.TEMPERATURE_ISSUE) { data ->
            val currentTemp = data["currentTemp"] as? Double ?: 0.0
            currentTemp > 50 || currentTemp < -20 // Critical temperature range
        }
        
        // Severe delay trigger
        registerTriggerCondition(NotificationEvent.SHIPMENT_DELAYED) { data ->
            val delayMinutes = data["delayMinutes"] as? Int ?: 0
            delayMinutes >= 240 // Trigger if delayed by 4 hours or more
        }
    }

    /**
     * Start event monitoring
     */
    private fun startEventMonitoring() {
        coroutineScope.launch {
            // Monitor for shipment delays
            monitorShipmentDelays()
            
            // Monitor for temperature issues
            monitorTemperatureIssues()
            
            // Monitor for payment overdue
            monitorPaymentOverdue()
        }
    }

    /**
     * Monitor shipment delays
     */
    private suspend fun monitorShipmentDelays() {
        coroutineScope.launch {
            while (isActive) {
                try {
                    // Check for delayed shipments
                    // This would integrate with the shipment tracking system
                    
                    delay(60000) // Check every minute
                } catch (e: Exception) {
                    // Handle monitoring error
                }
            }
        }
    }

    /**
     * Monitor temperature issues
     */
    private suspend fun monitorTemperatureIssues() {
        coroutineScope.launch {
            while (isActive) {
                try {
                    // Check for temperature issues
                    // This would integrate with temperature sensors
                    
                    delay(30000) // Check every 30 seconds
                } catch (e: Exception) {
                    // Handle monitoring error
                }
            }
        }
    }

    /**
     * Monitor payment overdue
     */
    private suspend fun monitorPaymentOverdue() {
        coroutineScope.launch {
            while (isActive) {
                try {
                    // Check for overdue payments
                    // This would integrate with the payment system
                    
                    delay(3600000) // Check every hour
                } catch (e: Exception) {
                    // Handle monitoring error
                }
            }
        }
    }

    /**
     * Notify listeners
     */
    private suspend fun notifyListeners(
        event: NotificationEvent,
        data: Map<String, Any>,
        triggerInstance: TriggerInstance
    ) {
        val listeners = eventListeners[event] ?: emptyList()
        
        listeners.forEach { listener ->
            try {
                listener.onEventTriggered(event, data, triggerInstance)
            } catch (e: Exception) {
                // Handle listener error
            }
        }
    }

    /**
     * Execute trigger actions
     */
    private suspend fun executeTriggerActions(triggerInstance: TriggerInstance) {
        withContext(Dispatchers.IO) {
            try {
                when (triggerInstance.event) {
                    NotificationEvent.SHIPMENT_DELAYED -> {
                        // Auto-reschedule if possible
                        if (shouldAutoReschedule(triggerInstance.data)) {
                            triggerInstance.actions.add(TriggerAction.AUTO_RESCHEDULE)
                        }
                        
                        // Notify customer
                        triggerInstance.actions.add(TriggerAction.NOTIFY_CUSTOMER)
                        
                        // Alert driver
                        triggerInstance.actions.add(TriggerAction.ALERT_DRIVER)
                    }
                    
                    NotificationEvent.TEMPERATURE_ISSUE -> {
                        val currentTemp = triggerInstance.data["currentTemp"] as? Double ?: 0.0
                        
                        if (currentTemp > 50 || currentTemp < -20) {
                            // Critical temperature - immediate action
                            triggerInstance.actions.add(TriggerAction.EMERGENCY_ALERT)
                            triggerInstance.actions.add(TriggerAction.NOTIFY_SUPERVISOR)
                        } else {
                            // Standard temperature issue
                            triggerInstance.actions.add(TriggerAction.NOTIFY_DRIVER)
                            triggerInstance.actions.add(TriggerAction.LOG_ISSUE)
                        }
                    }
                    
                    NotificationEvent.PAYMENT_OVERDUE -> {
                        val daysOverdue = triggerInstance.data["daysOverdue"] as? Int ?: 0
                        
                        if (daysOverdue > 30) {
                            // Severe overdue
                            triggerInstance.actions.add(TriggerAction.SUSPEND_SERVICE)
                            triggerInstance.actions.add(TriggerAction.NOTIFY_MANAGER)
                        } else {
                            // Standard overdue
                            triggerInstance.actions.add(TriggerAction.SEND_REMINDER)
                            triggerInstance.actions.add(TriggerAction.APPLY_LATE_FEE)
                        }
                    }
                }
                
                // Update trigger status
                triggerInstance.status = TriggerStatus.COMPLETED
                triggerInstance.completedAt = System.currentTimeMillis()
                
            } catch (e: Exception) {
                // Handle action execution error
                triggerInstance.status = TriggerStatus.FAILED
                triggerInstance.error = e.message
            }
        }
    }

    /**
     * Check if should auto-reschedule
     */
    private fun shouldAutoReschedule(data: Map<String, Any>): Boolean {
        val delayMinutes = data["delayMinutes"] as? Int ?: 0
        val shipmentType = data["shipmentType"] as? String ?: ""
        
        // Auto-reschedule for certain shipment types and delay ranges
        return delayMinutes < 120 && shipmentType in listOf("EXPRESS", "PRIORITY")
    }

    /**
     * Add to history
     */
    private fun addToHistory(eventRecord: EventRecord) {
        val currentHistory = eventHistory.value.toMutableList()
        currentHistory.add(0, eventRecord)
        
        // Keep only last 1000 events
        if (currentHistory.size > 1000) {
            currentHistory.removeAt(currentHistory.size - 1)
        }
        
        eventHistory.value = currentHistory
    }

    /**
     * Get trigger statistics
     */
    fun getTriggerStatistics(): TriggerStatistics {
        val history = eventHistory.value
        val now = System.currentTimeMillis()
        val last24Hours = history.filter { now - it.timestamp < 24 * 60 * 60 * 1000 }
        val last7Days = history.filter { now - it.timestamp < 7 * 24 * 60 * 60 * 1000 }
        
        return TriggerStatistics(
            totalEvents = history.size,
            last24Hours = last24Hours.size,
            last7Days = last7Days.size,
            byEvent = history.groupBy { it.event },
            activeTriggers = activeTriggers.size,
            completedTriggers = activeTriggers.values.count { it.status == TriggerStatus.COMPLETED }
        )
    }

    /**
     * Get active triggers
     */
    fun getActiveTriggers(): List<TriggerInstance> {
        return activeTriggers.values.filter { it.status == TriggerStatus.ACTIVE }
    }

    /**
     * Clear trigger history
     */
    fun clearTriggerHistory() {
        eventHistory.value = emptyList()
        activeTriggers.clear()
    }

    /**
     * Cleanup
     */
    fun cleanup() {
        coroutineScope.cancel()
    }
}

/**
 * Data classes and interfaces
 */
data class EventRecord(
    val id: String,
    val event: NotificationEvent,
    val data: Map<String, Any>,
    val timestamp: Long
)

data class TriggerInstance(
    val id: String,
    val event: NotificationEvent,
    val data: Map<String, Any>,
    val timestamp: Long,
    var status: TriggerStatus,
    var actions: MutableList<TriggerAction> = mutableListOf(),
    var completedAt: Long? = null,
    var error: String? = null
)

data class TriggerStatistics(
    val totalEvents: Int,
    val last24Hours: Int,
    val last7Days: Int,
    val byEvent: Map<NotificationEvent, List<EventRecord>>,
    val activeTriggers: Int,
    val completedTriggers: Int
)

enum class TriggerStatus {
    ACTIVE,
    COMPLETED,
    FAILED,
    CANCELLED
}

enum class TriggerAction {
    AUTO_RESCHEDULE,
    NOTIFY_CUSTOMER,
    ALERT_DRIVER,
    EMERGENCY_ALERT,
    NOTIFY_SUPERVISOR,
    LOG_ISSUE,
    SUSPEND_SERVICE,
    NOTIFY_MANAGER,
    SEND_REMINDER,
    APPLY_LATE_FEE
}

interface EventListener {
    suspend fun onEventTriggered(
        event: NotificationEvent,
        data: Map<String, Any>,
        triggerInstance: TriggerInstance
    )
}

interface TriggerCondition {
    fun evaluate(data: Map<String, Any>): Boolean
}
