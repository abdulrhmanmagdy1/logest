    override suspend fun getTemperatureHistory(request: GetTemperatureHistoryRequest): Result<TemperatureHistory> {
        return try {
            val response = coldChainApiService.getTemperatureHistory(request)
            if (response.isSuccessful) {
                response.body()?.let { temperatureHistory ->
                    Result.Success(temperatureHistory)
                } ?: Result.Error(Exception("Empty response"))
            } else {
                Result.Error(Exception("Failed to get temperature history: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun observeTemperatureHistory(shipmentId: String): Flow<Result<TemperatureHistory>> {
        return flow {
            try {
                coldChainWebSocketService.messageFlow.collect { message ->
                    if (message.shipmentId == shipmentId) {
                        when (message.type) {
                            ColdChainMessageType.TEMPERATURE_UPDATE -> {
                                // Refresh temperature history
                                val response = coldChainApiService.getTemperatureHistory(
                                    GetTemperatureHistoryRequest(
                                        shipmentId = shipmentId,
                                        startTime = null,
                                        endTime = null,
                                        includeAlerts = true
                                    )
                                )
                                if (response.isSuccessful) {
                                    response.body()?.let { history ->
                                        emit(Result.Success(history))
                                    }
                                }
                            }
                            else -> {}
                        }
                    }
                }
            } catch (e: Exception) {
                emit(Result.Error(e))
            }
        }
    }

