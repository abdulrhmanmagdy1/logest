    override suspend fun observePredictiveAlerts(): Flow<Result<PredictiveAnalysis>> {
        return flow {
            try {
                coldChainWebSocketService.messageFlow.collect { message ->
                    when (message.type) {
                        ColdChainMessageType.PREDICTIVE_ALERT -> {
                            // Handle predictive alerts
                            val analysis = message.data as PredictiveAnalysis
                            emit(Result.Success(analysis))
                        }
                        else -> {}
                    }
                }
            } catch (e: Exception) {
                emit(Result.Error(e))
            }
        }
    }

