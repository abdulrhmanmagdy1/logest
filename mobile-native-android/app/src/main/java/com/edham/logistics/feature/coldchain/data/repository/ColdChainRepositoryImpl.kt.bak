    override suspend fun escalateAlert(alertId: String, reason: String): Result<Unit> {
        return try {
            val response = coldChainApiService.escalateAlert(alertId, reason)
            if (response.isSuccessful) {
                Result.Success(Unit)
            } else {
                Result.Error(Exception("Failed to escalate alert: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun getAlertTrends(period: String): Result<Map<String, Any>> {
        return try {
            val response = coldChainApiService.getAlertTrends(period)
            if (response.isSuccessful) {
                response.body()?.let { trends ->
                    Result.Success(trends)
                } ?: Result.Error(Exception("Empty response"))
            } else {
                Result.Error(Exception("Failed to get alert trends: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun exportTemperatureData(shipmentId: String, format: ExportFormat, dateRange: DateRange): Result<String> {
        return try {
            val response = coldChainApiService.exportTemperatureData(shipmentId, format, dateRange)
            if (response.isSuccessful) {
                response.body()?.let { exportUrl ->
                    Result.Success(exportUrl)
                } ?: Result.Error(Exception("Empty response"))
            } else {
                Result.Error(Exception("Failed to export temperature data: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun exportComplianceData(customerId: String, format: ExportFormat, dateRange: DateRange): Result<String> {
        return try {
            val response = coldChainApiService.exportComplianceData(customerId, format, dateRange)
            if (response.isSuccessful) {
                response.body()?.let { exportUrl ->
                    Result.Success(exportUrl)
                } ?: Result.Error(Exception("Empty response"))
            } else {
                Result.Error(Exception("Failed to export compliance data: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun exportAlertData(format: ExportFormat, dateRange: DateRange): Result<String> {
        return try {
            val response = coldChainApiService.exportAlertData(format, dateRange)
            if (response.isSuccessful) {
                response.body()?.let { exportUrl ->
                    Result.Success(exportUrl)
                } ?: Result.Error(Exception("Empty response"))
            } else {
                Result.Error(Exception("Failed to export alert data: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }
}
