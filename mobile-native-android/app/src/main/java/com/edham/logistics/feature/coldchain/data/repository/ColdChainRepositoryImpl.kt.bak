    override suspend fun observeAlerts(shipmentId: String): Flow<Result<List<TemperatureAlert>>> {
        return flow {
            try {
                coldChainWebSocketService.messageFlow.collect { message ->
                    if (message.shipmentId == shipmentId) {
                        when (message.type) {
                            ColdChainMessageType.ALERT_TRIGGERED,
                            ColdChainMessageType.ALERT_RESOLVED -> {
                                // Refresh alerts
                                val response = coldChainApiService.getActiveAlerts(shipmentId)
                                if (response.isSuccessful) {
                                    response.body()?.let { alerts ->
                                        emit(Result.Success(alerts))
                                    }
                                }
                            }
                            else -> {}
                        }
                    }
                }
            } catch (e: Exception) {
                emit(Result.Error(e))
            }
        }
    }

