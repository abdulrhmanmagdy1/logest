    override suspend fun connectToColdChainWebSocket(): Result<Unit> {
        return try {
            val token = tokenManager.getAccessToken()
            if (token != null) {
                coldChainWebSocketService.connect(token)
                Result.Success(Unit)
            } else {
                Result.Error(Exception("No access token available"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun disconnectFromColdChainWebSocket(): Result<Unit> {
