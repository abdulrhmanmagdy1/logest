    override suspend fun observeSensorStatus(sensorId: String): Flow<Result<SensorStatus>> {
        return flow {
            try {
                coldChainWebSocketService.messageFlow.collect { message ->
                    if (message.sensorId == sensorId) {
                        when (message.type) {
                            ColdChainMessageType.SENSOR_OFFLINE,
                            ColdChainMessageType.BATTERY_LOW,
                            ColdChainMessageType.CALIBRATION_REQUIRED -> {
                                // Refresh sensor status
                                val response = coldChainApiService.getSensorStatus(sensorId)
                                if (response.isSuccessful) {
                                    response.body()?.let { status ->
                                        emit(Result.Success(status))
                                    }
                                }
                            }
                            else -> {}
                        }
                    }
                }
            } catch (e: Exception) {
                emit(Result.Error(e))
            }
        }
    }

