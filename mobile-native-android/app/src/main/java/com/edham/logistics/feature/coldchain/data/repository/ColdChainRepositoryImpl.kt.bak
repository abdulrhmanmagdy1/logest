package com.edham.logistics.feature.coldchain.data.repository

import com.edham.logistics.core.utils.Result
import com.edham.logistics.core.utils.TokenManager
import com.edham.logistics.feature.coldchain.data.api.ColdChainApiService
import com.edham.logistics.feature.coldchain.data.database.ColdChainDatabase
import com.edham.logistics.feature.coldchain.data.service.ColdChainWebSocketService
import com.edham.logistics.feature.coldchain.domain.model.*
import com.edham.logistics.feature.coldchain.domain.repository.ColdChainRepository
import kotlinx.coroutines.flow.Flow
import kotlinx.coroutines.flow.flow
import kotlinx.coroutines.flow.map
import javax.inject.Inject
import javax.inject.Singleton

@Singleton
class ColdChainRepositoryImpl @Inject constructor(
    private val coldChainApiService: ColdChainApiService,
    private val coldChainDatabase: ColdChainDatabase,
    private val coldChainWebSocketService: ColdChainWebSocketService,
    private val tokenManager: TokenManager
) : ColdChainRepository {

    override suspend fun startColdChainMonitoring(request: StartColdChainMonitoringRequest): Result<ColdChainShipment> {
        return try {
            val response = coldChainApiService.startColdChainMonitoring(request)
            if (response.isSuccessful) {
                response.body()?.let { coldChainShipment ->
                    // Save to local database
                    coldChainDatabase.coldChainDao().insertColdChainShipment(coldChainShipment.toEntity())
                    Result.Success(coldChainShipment)
                } ?: Result.Error(Exception("Empty response"))
            } else {
                Result.Error(Exception("Failed to start cold chain monitoring: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun stopColdChainMonitoring(shipmentId: String): Result<Unit> {
        return try {
            val response = coldChainApiService.stopColdChainMonitoring(shipmentId)
            if (response.isSuccessful) {
                // Update local database
                coldChainDatabase.coldChainDao().updateShipmentStatus(
                    shipmentId,
                    ColdChainStatus.OFFLINE.name
                )
                Result.Success(Unit)
            } else {
                Result.Error(Exception("Failed to stop cold chain monitoring: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun pauseColdChainMonitoring(shipmentId: String): Result<Unit> {
        return try {
            val response = coldChainApiService.pauseColdChainMonitoring(shipmentId)
            if (response.isSuccessful) {
                coldChainDatabase.coldChainDao().updateShipmentStatus(
                    shipmentId,
                    ColdChainStatus.MAINTENANCE.name
                )
                Result.Success(Unit)
            } else {
                Result.Error(Exception("Failed to pause cold chain monitoring: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun resumeColdChainMonitoring(shipmentId: String): Result<Unit> {
        return try {
            val response = coldChainApiService.resumeColdChainMonitoring(shipmentId)
            if (response.isSuccessful) {
                coldChainDatabase.coldChainDao().updateShipmentStatus(
                    shipmentId,
                    ColdChainStatus.NORMAL.name
                )
                Result.Success(Unit)
            } else {
                Result.Error(Exception("Failed to resume cold chain monitoring: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun updateTemperature(request: UpdateTemperatureRequest): Result<TemperatureReading> {
        return try {
            val response = coldChainApiService.updateTemperature(request)
            if (response.isSuccessful) {
                response.body()?.let { temperatureReading ->
                    // Save to local database
                    coldChainDatabase.coldChainDao().insertTemperatureReading(temperatureReading.toEntity())
                    Result.Success(temperatureReading)
                } ?: Result.Error(Exception("Empty response"))
            } else {
                Result.Error(Exception("Failed to update temperature: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun batchUpdateTemperatures(requests: List<UpdateTemperatureRequest>): Result<List<TemperatureReading>> {
        return try {
            val response = coldChainApiService.batchUpdateTemperatures(requests)
            if (response.isSuccessful) {
                response.body()?.let { temperatureReadings ->
                    // Save to local database
                    temperatureReadings.forEach { reading ->
                        coldChainDatabase.coldChainDao().insertTemperatureReading(reading.toEntity())
                    }
                    Result.Success(temperatureReadings)
                } ?: Result.Error(Exception("Empty response"))
            } else {
                Result.Error(Exception("Failed to batch update temperatures: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun getColdChainStatus(request: GetColdChainStatusRequest): Result<List<ColdChainShipment>> {
        return try {
            val response = coldChainApiService.getColdChainStatus(request)
            if (response.isSuccessful) {
                response.body()?.let { coldChainShipments ->
                    Result.Success(coldChainShipments)
                } ?: Result.Success(emptyList())
            } else {
                Result.Error(Exception("Failed to get cold chain status: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun getShipmentColdChainStatus(shipmentId: String): Result<ColdChainShipment> {
        return try {
            // Try local database first
            val localShipment = coldChainDatabase.coldChainDao().getColdChainShipment(shipmentId)
            if (localShipment != null) {
                return Result.Success(localShipment.toDomainModel())
            }

            // Fetch from API if not in local database
            val response = coldChainApiService.getShipmentColdChainStatus(shipmentId)
            if (response.isSuccessful) {
                response.body()?.let { coldChainShipment ->
                    // Save to local database
                    coldChainDatabase.coldChainDao().insertColdChainShipment(coldChainShipment.toEntity())
                    Result.Success(coldChainShipment)
                } ?: Result.Error(Exception("Empty response"))
            } else {
                Result.Error(Exception("Failed to get shipment cold chain status: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun observeShipmentColdChainStatus(shipmentId: String): Flow<Result<ColdChainShipment>> {
        return flow {
            try {
                // Emit local data first
                val localShipment = coldChainDatabase.coldChainDao().getColdChainShipment(shipmentId)
                if (localShipment != null) {
                    emit(Result.Success(localShipment.toDomainModel()))
                }

                // Listen for WebSocket updates
                coldChainWebSocketService.messageFlow.collect { message ->
                    if (message.shipmentId == shipmentId) {
                        when (message.type) {
                            ColdChainMessageType.TEMPERATURE_UPDATE,
                            ColdChainMessageType.ALERT_TRIGGERED,
                            ColdChainMessageType.ALERT_RESOLVED -> {
                                // Refresh local data
                                val updatedShipment = coldChainDatabase.coldChainDao().getColdChainShipment(shipmentId)
                                updatedShipment?.let {
                                    emit(Result.Success(it.toDomainModel()))
                                }
                            }
                            else -> {}
                        }
                    }
                }
            } catch (e: Exception) {
                emit(Result.Error(e))
            }
        }
    }

    override suspend fun getCustomerColdChainStatus(customerId: String): Result<List<ColdChainShipment>> {
        return try {
            val response = coldChainApiService.getCustomerColdChainStatus(customerId)
            if (response.isSuccessful) {
                response.body()?.let { coldChainShipments ->
                    Result.Success(coldChainShipments)
                } ?: Result.Success(emptyList())
            } else {
                Result.Error(Exception("Failed to get customer cold chain status: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

