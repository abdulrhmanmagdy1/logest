    override suspend fun createTemperatureAlert(request: CreateAlertRequest): Result<TemperatureAlert> {
        return try {
            val response = coldChainApiService.createTemperatureAlert(request)
            if (response.isSuccessful) {
                response.body()?.let { alert ->
                    // Save to local database
                    coldChainDatabase.coldChainDao().insertTemperatureAlert(alert.toEntity())
                    Result.Success(alert)
                } ?: Result.Error(Exception("Empty response"))
            } else {
                Result.Error(Exception("Failed to create temperature alert: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun resolveTemperatureAlert(request: ResolveAlertRequest): Result<TemperatureAlert> {
        return try {
            val response = coldChainApiService.resolveTemperatureAlert(request)
            if (response.isSuccessful) {
                response.body()?.let { alert ->
                    // Update local database
                    coldChainDatabase.coldChainDao().updateAlertResolved(
                        request.alertId,
                        true,
                        System.currentTimeMillis(),
                        request.resolvedBy
                    )
                    Result.Success(alert)
                } ?: Result.Error(Exception("Empty response"))
            } else {
                Result.Error(Exception("Failed to resolve temperature alert: ${response.code()}"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

