package com.edham.logistics.feature.driver

import android.app.Activity
import android.content.Intent
import android.os.Bundle
import android.widget.Toast
import androidx.fragment.app.Fragment
import com.edham.logistics.R
import com.edham.logistics.databinding.FragmentFuelLoggingBinding
import com.edham.logistics.utils.VoiceAlertManager
import timber.log.Timber
import java.text.SimpleDateFormat
import java.util.*

class FuelLoggingFragment : Fragment() {
    
    private var _binding: FragmentFuelLoggingBinding? = null
    private val binding get() = _binding!!
    
    private lateinit var voiceAlertManager: VoiceAlertManager
    private val dateFormat = SimpleDateFormat("yyyy-MM-dd HH:mm", Locale.getDefault())
    
    override fun onCreateView(
        inflater: android.view.LayoutInflater,
        container: android.view.ViewGroup?,
        savedInstanceState: Bundle?
    ): android.view.View {
        _binding = FragmentFuelLoggingBinding.inflate(inflater, container, false)
        return binding.root
    }
    
    override fun onViewCreated(view: android.view.View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        
        voiceAlertManager = VoiceAlertManager(requireContext())
        setupUI()
        setupClickListeners()
        
        // Set current date and time
        binding.etDate.setText(dateFormat.format(Date()))
        
        voiceAlertManager.speak("Fuel logging screen opened")
    }
    
    private fun setupUI() {
        // Large touch targets for one-hand usage
        binding.btnSaveFuel.minimumHeight = 80.dp
        binding.btnSaveFuel.minimumWidth = 160.dp
        
        binding.btnTakePhoto.minimumHeight = 72.dp
        binding.btnTakePhoto.minimumWidth = 120.dp
        
        binding.btnCancel.minimumHeight = 72.dp
        binding.btnCancel.minimumWidth = 120.dp
        
        // Dark mode optimized colors
        binding.cardFuelDetails.setCardBackgroundColor(
            requireContext().getColor(R.color.dark_surface)
        )
        
        // High visibility status colors
        binding.viewStatusIndicator.setBackgroundColor(
            requireContext().getColor(R.color.status_idle)
        )
    }
    
    private fun setupClickListeners() {
        binding.btnSaveFuel.setOnClickListener {
            saveFuelLog()
        }
        
        binding.btnTakePhoto.setOnClickListener {
            takeFuelPhoto()
        }
        
        binding.btnCancel.setOnClickListener {
            requireActivity().onBackPressed()
        }
        
        // Auto-calculate total cost
        binding.etAmount.setOnFocusChangeListener { _, hasFocus ->
            if (!hasFocus) {
                calculateTotalCost()
            }
        }
        
        binding.etPricePerLiter.setOnFocusChangeListener { _, hasFocus ->
            if (!hasFocus) {
                calculateTotalCost()
            }
        }
    }
    
    private fun saveFuelLog() {
        val amount = binding.etAmount.text.toString().toDoubleOrNull()
        val pricePerLiter = binding.etPricePerLiter.text.toString().toDoubleOrNull()
        val location = binding.etLocation.text.toString()
        val odometer = binding.etOdometer.text.toString().toLongOrNull()
        val fuelType = binding.spinnerFuelType.selectedItem?.toString()
        val notes = binding.etNotes.text.toString()
        
        // Validate inputs
        if (amount == null || amount <= 0) {
            binding.etAmount.error = "Invalid amount"
            voiceAlertManager.speak("Please enter valid fuel amount")
            return
        }
        
        if (pricePerLiter == null || pricePerLiter <= 0) {
            binding.etPricePerLiter.error = "Invalid price"
            voiceAlertManager.speak("Please enter valid price per liter")
            return
        }
        
        if (location.isBlank()) {
            binding.etLocation.error = "Location required"
            voiceAlertManager.speak("Please enter fuel station location")
            return
        }
        
        if (odometer == null || odometer <= 0) {
            binding.etOdometer.error = "Invalid odometer reading"
            voiceAlertManager.speak("Please enter odometer reading")
            return
        }
        
        // Create fuel log
        val fuelLog = FuelLog(
            id = UUID.randomUUID().toString(),
            amount = amount,
            pricePerLiter = pricePerLiter,
            totalPrice = amount * pricePerLiter,
            location = location,
            odometer = odometer,
            fuelType = fuelType ?: "Regular",
            notes = notes,
            timestamp = System.currentTimeMillis(),
            date = dateFormat.format(Date())
        )
        
        // Process fuel log
        processFuelLog(fuelLog)
    }
    
    private fun calculateTotalCost() {
        val amount = binding.etAmount.text.toString().toDoubleOrNull()
        val pricePerLiter = binding.etPricePerLiter.text.toString().toDoubleOrNull()
        
        if (amount != null && pricePerLiter != null) {
            val totalCost = amount * pricePerLiter
            binding.tvTotalCost.text = String.format("Total: $%.2f", totalCost)
        } else {
            binding.tvTotalCost.text = "Total: $0.00"
        }
    }
    
    private fun takeFuelPhoto() {
        // Launch camera to take photo of fuel receipt
        val cameraIntent = Intent(android.provider.MediaStore.ACTION_IMAGE_CAPTURE)
        startActivityForResult(cameraIntent, CAMERA_REQUEST_CODE)
        
        voiceAlertManager.speak("Taking photo of fuel receipt")
    }
    
    private fun processFuelLog(fuelLog: FuelLog) {
        // Show loading state
        binding.progressBar.visibility = android.view.View.VISIBLE
        binding.btnSaveFuel.isEnabled = false
        
        // Update status
        updateStatus("PROCESSING")
        
        // Process fuel log (API call or local storage)
        // This would typically involve:
        // 1. Save fuel log to local database
        // 2. Upload to server if online
        // 3. Update vehicle fuel tracking
        // 4. Calculate fuel efficiency
        
        // Simulate processing
        binding.root.postDelayed({
            binding.progressBar.visibility = android.view.View.GONE
            binding.btnSaveFuel.isEnabled = true
            
            updateStatus("SAVED")
            voiceAlertManager.speak("Fuel log saved successfully")
            Toast.makeText(requireContext(), "Fuel log saved successfully", Toast.LENGTH_LONG).show()
            
            // Navigate back or to next screen
            requireActivity().onBackPressed()
        }, 2000)
    }
    
    private fun updateStatus(status: String) {
        binding.tvStatus.text = status
        
        val color = when (status) {
            "PROCESSING" -> requireContext().getColor(R.color.status_active)
            "SAVED" -> requireContext().getColor(R.color.status_completed)
            "ERROR" -> requireContext().getColor(R.color.status_error)
            else -> requireContext().getColor(R.color.status_idle)
        }
        
        binding.viewStatusIndicator.setBackgroundColor(color)
    }
    
    override fun onActivityResult(requestCode: Int, resultCode: Int, data: Intent?) {
        super.onActivityResult(requestCode, resultCode, data)
        
        if (requestCode == CAMERA_REQUEST_CODE && resultCode == Activity.RESULT_OK) {
            // Handle photo capture
            voiceAlertManager.speak("Photo captured successfully")
            binding.btnTakePhoto.text = "Photo Taken"
            binding.btnTakePhoto.setBackgroundColor(
                requireContext().getColor(R.color.status_completed)
            )
        }
    }
    
    override fun onDestroyView() {
        super.onDestroyView()
        voiceAlertManager.cleanup()
        _binding = null
    }
    
    // Extension for dp to pixels
    private val Int.dp: Int
        get() = (this * resources.displayMetrics.density).toInt()
    
    companion object {
        private const val CAMERA_REQUEST_CODE = 1001
    }
}

data class FuelLog(
    val id: String,
    val amount: Double,
    val pricePerLiter: Double,
    val totalPrice: Double,
    val location: String,
    val odometer: Long,
    val fuelType: String,
    val notes: String,
    val timestamp: Long,
    val date: String
)
