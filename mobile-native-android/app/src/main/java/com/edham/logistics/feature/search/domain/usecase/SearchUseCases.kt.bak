// Convenience use cases for specific search scenarios

@Singleton
class ShipmentSearchUseCase @Inject constructor(
    private val searchRepository: SearchRepository
) {
    suspend operator fun invoke(
        query: String,
        filters: ShipmentSearchFilters = ShipmentSearchFilters(),
        pagination: PaginationOptions = PaginationOptions()
    ): Result<List<SearchResult>> {
        return try {
            val searchFilters = SearchFilters(
                entityTypes = listOf(SearchResultType.SHIPMENT),
                dateRange = filters.dateRange,
                statusFilter = filters.statusFilter?.let { 
                    StatusFilter("status", it.statuses) 
                },
                locationFilter = filters.locationFilter,
                customFilters = mapOf(
                    "trackingNumber" to (filters.trackingNumber ?: ""),
                    "customerName" to (filters.customerName ?: ""),
                    "driverName" to (filters.driverName ?: "")
                ).filterValues { it.isNotEmpty() }
            )
            
            val searchQuery = SearchQuery(
                text = query,
                filters = searchFilters,
                options = SearchOptions(
                    fuzzySearch = true,
                    includeHighlights = true
                ),
                pagination = pagination,
                sorting = SortingOptions(
                    field = filters.sortBy.fieldName,
                    order = filters.sortOrder
                ),
                facets = listOf(
                    FacetOption("status", 10),
                    FacetOption("priority", 5)
                )
            )
            
            when (val result = searchRepository.search(searchQuery)) {
                is Result.Success -> Result.Success(result.data.results)
                is Result.Error -> Result.Error(result.exception)
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }
}

@Singleton
class UserSearchUseCase @Inject constructor(
    private val searchRepository: SearchRepository
) {
    suspend operator fun invoke(
        query: String,
        filters: UserSearchFilters = UserSearchFilters(),
        pagination: PaginationOptions = PaginationOptions()
    ): Result<List<SearchResult>> {
        return try {
            val searchFilters = SearchFilters(
                entityTypes = listOf(SearchResultType.USER),
                roleFilter = filters.roleFilter?.let { 
                    RoleFilter(it.roles.map { it.name }) 
                },
                statusFilter = filters.statusFilter?.let { 
                    StatusFilter("status", it.statuses) 
                },
                locationFilter = filters.locationFilter,
                customFilters = mapOf(
                    "username" to (filters.username ?: ""),
                    "email" to (filters.email ?: ""),
                    "phoneNumber" to (filters.phoneNumber ?: "")
                ).filterValues { it.isNotEmpty() }
            )
            
            val searchQuery = SearchQuery(
                text = query,
                filters = searchFilters,
                options = SearchOptions(
                    fuzzySearch = true,
                    includeHighlights = true
                ),
                pagination = pagination,
                sorting = SortingOptions(
                    field = filters.sortBy.fieldName,
                    order = filters.sortOrder
                ),
                facets = listOf(
                    FacetOption("role", 10),
                    FacetOption("status", 10)
                )
            )
            
            when (val result = searchRepository.search(searchQuery)) {
                is Result.Success -> Result.Success(result.data.results)
                is Result.Error -> Result.Error(result.exception)
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }
}

