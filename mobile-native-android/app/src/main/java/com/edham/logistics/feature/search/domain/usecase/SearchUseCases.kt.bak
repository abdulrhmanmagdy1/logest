/**
 * Global search use cases for intelligent search and filtering
 */
@Singleton
class GlobalSearchUseCase @Inject constructor(
    private val searchRepository: SearchRepository
) {
    suspend operator fun invoke(
        query: String,
        filters: SearchFilters = SearchFilters(),
        options: SearchOptions = SearchOptions(),
        pagination: PaginationOptions = PaginationOptions(),
        sorting: SortingOptions = SortingOptions()
    ): Result<SearchResponse> {
        return try {
            val searchQuery = SearchQuery(
                text = query,
                filters = filters,
                options = options,
                pagination = pagination,
                sorting = sorting,
                facets = generateDefaultFacets(filters)
            )
            
            searchRepository.search(searchQuery)
        } catch (e: Exception) {
            Result.Error(e)
        }
    }
    
    private fun generateDefaultFacets(filters: SearchFilters): List<FacetOption> {
        val facets = mutableListOf<FacetOption>()
        
        // Add entity type facet if not filtered
        if (filters.entityTypes.isEmpty()) {
            facets.add(FacetOption("type", 10, FacetSort.COUNT))
        }
        
        // Add status facet if status filter is not specific
        if (filters.statusFilter == null) {
            facets.add(FacetOption("status", 10, FacetSort.COUNT))
        }
        
        // Add role facet if role filter is not specific
        if (filters.roleFilter == null) {
            facets.add(FacetOption("role", 10, FacetSort.COUNT))
        }
        
        // Add priority facet
        facets.add(FacetOption("priority", 5, FacetSort.COUNT))
        
        // Add category facet
        facets.add(FacetOption("categories", 10, FacetSort.COUNT))
        
        return facets
    }
}

