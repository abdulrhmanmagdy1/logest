@Singleton
class SearchHistoryUseCase @Inject constructor(
    private val searchRepository: SearchRepository
) {
    suspend operator fun invoke(
        userId: String,
        limit: Int = 50
    ): Result<List<SearchHistory>> {
        return try {
            searchRepository.getSearchHistory(userId, limit)
        } catch (e: Exception) {
            Result.Error(e)
        }
    }
    
    suspend fun addToHistory(
        userId: String,
        query: String,
        filters: SearchFilters,
        resultCount: Int,
        duration: Long
    ): Result<SearchHistory> {
        return try {
            val history = SearchHistory(
                id = java.util.UUID.randomUUID().toString(),
                userId = userId,
                query = query,
                filters = filters,
                resultCount = resultCount,
                timestamp = System.currentTimeMillis(),
                duration = duration,
                clickedResults = emptyList()
            )
            searchRepository.addToSearchHistory(history)
        } catch (e: Exception) {
            Result.Error(e)
        }
    }
    
    suspend fun clearHistory(userId: String): Result<Unit> {
        return try {
            searchRepository.clearSearchHistory(userId)
        } catch (e: Exception) {
            Result.Error(e)
        }
    }
}

