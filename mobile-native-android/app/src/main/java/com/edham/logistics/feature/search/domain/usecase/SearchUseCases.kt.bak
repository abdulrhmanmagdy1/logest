                pagination = pagination,
                sorting = SortingOptions(
                    field = filters.sortBy.fieldName,
                    order = filters.sortOrder
                ),
                facets = listOf(
                    FacetOption("status", 10),
                    FacetOption("priority", 5)
                )
            )
            
            when (val result = searchRepository.search(searchQuery)) {
                is Result.Success -> Result.Success(result.data.results)
                is Result.Error -> Result.Error(result.exception)
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }
