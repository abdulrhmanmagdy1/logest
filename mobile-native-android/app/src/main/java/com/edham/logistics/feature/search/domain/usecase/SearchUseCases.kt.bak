// Helper classes for specific search filters

data class ShipmentSearchFilters(
    val dateRange: DateRangeFilter? = null,
    val statusFilter: StatusFilter? = null,
    val locationFilter: LocationFilter? = null,
    val trackingNumber: String? = null,
    val customerName: String? = null,
    val driverName: String? = null,
    val sortBy: ShipmentSortField = ShipmentSortField.CREATED_AT,
    val sortOrder: SortOrder = SortOrder.DESC
)

enum class ShipmentSortField(val fieldName: String) {
    CREATED_AT("createdAt"),
    UPDATED_AT("updatedAt"),
    PRIORITY("priority"),
    STATUS("status"),
    ESTIMATED_DELIVERY("estimatedDelivery")
}

data class UserSearchFilters(
    val roleFilter: RoleFilter? = null,
    val statusFilter: StatusFilter? = null,
    val locationFilter: LocationFilter? = null,
    val username: String? = null,
    val email: String? = null,
    val phoneNumber: String? = null,
    val sortBy: UserSortField = UserSortField.CREATED_AT,
    val sortOrder: SortOrder = SortOrder.DESC
)

enum class UserSortField(val fieldName: String) {
    CREATED_AT("createdAt"),
    UPDATED_AT("updatedAt"),
    USERNAME("username"),
    EMAIL("email"),
    LAST_LOGIN("lastLogin")
}

data class VehicleSearchFilters(
    val statusFilter: StatusFilter? = null,
    val locationFilter: LocationFilter? = null,
    val licensePlate: String? = null,
    val make: String? = null,
    val model: String? = null,
    val year: Int? = null,
    val sortBy: VehicleSortField = VehicleSortField.CREATED_AT,
    val sortOrder: SortOrder = SortOrder.DESC
)

enum class VehicleSortField(val fieldName: String) {
    CREATED_AT("createdAt"),
    UPDATED_AT("updatedAt"),
    LICENSE_PLATE("licensePlate"),
    MAKE("make"),
    MODEL("model"),
    YEAR("year")
}

data class InvoiceSearchFilters(
    val dateRange: DateRangeFilter? = null,
    val statusFilter: StatusFilter? = null,
    val customerFilter: OwnerFilter? = null,
    val invoiceNumber: String? = null,
    val customerName: String? = null,
    val amount: Double? = null,
    val sortBy: InvoiceSortField = InvoiceSortField.CREATED_AT,
    val sortOrder: SortOrder = SortOrder.DESC
)

enum class InvoiceSortField(val fieldName: String) {
    CREATED_AT("createdAt"),
    UPDATED_AT("updatedAt"),
    INVOICE_NUMBER("invoiceNumber"),
    AMOUNT("amount"),
    DUE_DATE("dueDate")
}

data class TimeRange(
    val startTime: Long,
    val endTime: Long
)

data class SlowQuery(
    val query: String,
    val executionTime: Long,
    val timestamp: Long,
    val resultCount: Int,
    val userId: String?
)

data class CacheStatistics(
    val hitRate: Float,
    val missRate: Float,
    val size: Long,
    val maxSize: Long,
    val evictions: Long,
    val hits: Long,
    val misses: Long
)
