package com.edham.logistics.feature.telematics

import android.util.Log
import kotlinx.coroutines.Dispatchers
import kotlinx.coroutines.withContext
import java.time.LocalDateTime
import kotlin.math.max
import kotlin.math.min

/**
 * Safety Charts System - Advanced safety visualization and analytics
 * Provides comprehensive charts and visualizations for driver safety metrics
 */
class SafetyCharts {
    
    companion object {
        private const val TAG = "SafetyCharts"
        
        // Chart types
        enum class ChartType {
            LINE_CHART,
            BAR_CHART,
            PIE_CHART,
            RADAR_CHART,
            AREA_CHART
        }
        
        // Data aggregation periods
        enum class AggregationPeriod {
            HOURLY,
            DAILY,
            WEEKLY,
            MONTHLY
        }
    }
    
    /**
     * Generate safety trend chart data
     */
    suspend fun generateSafetyTrendChart(
        driverId: String,
        sessions: List<DrivingSession>,
        timeWindow: TimeWindow = TimeWindow.LAST_30_DAYS,
        aggregationPeriod: AggregationPeriod = AggregationPeriod.DAILY
    ): SafetyChartData {
        return withContext(Dispatchers.IO) {
            try {
                Log.d(TAG, "Generating safety trend chart for driver $driverId")
                
                // Aggregate data based on period
                val aggregatedData = aggregateSafetyData(sessions, aggregationPeriod)
                
                // Generate chart data points
                val dataPoints = aggregatedData.map { (period, data) ->
                    ChartDataPoint(
                        label = formatPeriodLabel(period, aggregationPeriod),
                        value = data.averageSafetyScore,
                        metadata = mapOf(
                            "harshBraking" to data.harshBrakingCount,
                            "rapidAcceleration" to data.rapidAccelerationCount,
                            "overSpeeding" to data.overSpeedingCount,
                            "sharpTurns" to data.sharpTurnCount,
                            "seatbeltViolations" to data.seatbeltViolations
                        )
                    )
                }
                
                val chartData = SafetyChartData(
                    driverId = driverId,
                    chartType = ChartType.LINE_CHART,
                    title = "Safety Score Trend",
                    dataPoints = dataPoints,
                    timeWindow = timeWindow,
                    aggregationPeriod = aggregationPeriod,
                    generatedAt = LocalDateTime.now()
                )
                
                Log.d(TAG, "Safety trend chart generated: ${dataPoints.size} data points")
                chartData
                
            } catch (e: Exception) {
                Log.e(TAG, "Error generating safety trend chart", e)
                SafetyChartData.createError(driverId, ChartType.LINE_CHART)
            }
        }
    }
    
    /**
     * Generate event distribution chart
     */
    suspend fun generateEventDistributionChart(
        driverId: String,
        sessions: List<DrivingSession>,
        timeWindow: TimeWindow = TimeWindow.LAST_30_DAYS
    ): SafetyChartData {
        return withContext(Dispatchers.IO) {
            try {
                Log.d(TAG, "Generating event distribution chart for driver $driverId")
                
                // Calculate event totals
                val totalEvents = mapOf(
                    "Harsh Braking" to sessions.sumOf { it.harshBrakingCount },
                    "Rapid Acceleration" to sessions.sumOf { it.rapidAccelerationCount },
                    "Over-speeding" to sessions.sumOf { it.overSpeedingCount },
                    "Sharp Turns" to sessions.sumOf { it.sharpTurnCount },
                    "Seatbelt Violations" to sessions.sumOf { it.seatbeltViolations }
                )
                
                // Generate pie chart data
                val dataPoints = totalEvents.map { (eventType, count) ->
                    ChartDataPoint(
                        label = eventType,
                        value = count.toDouble(),
                        percentage = if (totalEvents.values.sum() > 0) {
                            (count.toDouble() / totalEvents.values.sum()) * 100
                        } else 0.0
                    )
                }
                
                val chartData = SafetyChartData(
                    driverId = driverId,
                    chartType = ChartType.PIE_CHART,
                    title = "Safety Events Distribution",
                    dataPoints = dataPoints,
                    timeWindow = timeWindow,
                    generatedAt = LocalDateTime.now()
                )
                
                Log.d(TAG, "Event distribution chart generated")
                chartData
                
            } catch (e: Exception) {
                Log.e(TAG, "Error generating event distribution chart", e)
                SafetyChartData.createError(driverId, ChartType.PIE_CHART)
            }
        }
    }
    
    /**
     * Generate safety radar chart
     */
    suspend fun generateSafetyRadarChart(
        driverId: String,
        sessions: List<DrivingSession>,
        timeWindow: TimeWindow = TimeWindow.LAST_30_DAYS
    ): SafetyChartData {
        return withContext(Dispatchers.IO) {
            try {
                Log.d(TAG, "Generating safety radar chart for driver $driverId")
                
                if (sessions.isEmpty()) {
                    return@withContext SafetyChartData.createEmpty(driverId, ChartType.RADAR_CHART)
                }
                
                // Calculate safety metrics for radar chart
                val metrics = mapOf(
                    "Braking Safety" to calculateBrakingSafetyScore(sessions),
                    "Acceleration Control" to calculateAccelerationSafetyScore(sessions),
                    "Speed Compliance" to calculateSpeedComplianceScore(sessions),
                    "Turning Safety" to calculateTurningSafetyScore(sessions),
                    "Seatbelt Compliance" to calculateSeatbeltComplianceScore(sessions),
                    "Overall Safety" to sessions.mapNotNull { it.safetyScore }.average()
                )
                
                val dataPoints = metrics.map { (metric, score) ->
                    ChartDataPoint(
                        label = metric,
                        value = score,
                        maxValue = 100.0
                    )
                }
                
                val chartData = SafetyChartData(
                    driverId = driverId,
                    chartType = ChartType.RADAR_CHART,
                    title = "Safety Performance Radar",
                    dataPoints = dataPoints,
                    timeWindow = timeWindow,
                    generatedAt = LocalDateTime.now()
                )
                
                Log.d(TAG, "Safety radar chart generated")
                chartData
                
            } catch (e: Exception) {
                Log.e(TAG, "Error generating safety radar chart", e)
                SafetyChartData.createError(driverId, ChartType.RADAR_CHART)
            }
        }
    }
    
    /**
     * Generate weekly comparison chart
     */
    suspend fun generateWeeklyComparisonChart(
        driverId: String,
        sessions: List<DrivingSession>,
        timeWindow: TimeWindow = TimeWindow.LAST_90_DAYS
    ): SafetyChartData {
        return withContext(Dispatchers.IO) {
            try {
                Log.d(TAG, "Generating weekly comparison chart for driver $driverId")
                
                // Group by week
                val weeklyData = sessions.groupBy { 
                    it.startTime.toLocalDate().withDayOfWeek(1) // Start of week
                }.mapValues { (_, weekSessions) ->
                    WeekSafetyData(
                        weekSessions.mapNotNull { it.safetyScore }.average(),
                        weekSessions.sumOf { it.harshBrakingCount },
                        weekSessions.sumOf { it.rapidAccelerationCount },
                        weekSessions.sumOf { it.overSpeedingCount }
                    )
                }
                
                val dataPoints = weeklyData.map { (weekStart, data) ->
                    ChartDataPoint(
                        label = "Week ${weekStart.monthValue}/${weekStart.dayOfMonth}",
                        value = data.averageSafetyScore,
                        metadata = mapOf(
                            "harshBraking" to data.harshBrakingCount,
                            "rapidAcceleration" to data.rapidAccelerationCount,
                            "overSpeeding" to data.overSpeedingCount
                        )
                    )
                }.sortedBy { it.label }
                
                val chartData = SafetyChartData(
                    driverId = driverId,
                    chartType = ChartType.BAR_CHART,
                    title = "Weekly Safety Performance",
                    dataPoints = dataPoints,
                    timeWindow = timeWindow,
                    generatedAt = LocalDateTime.now()
                )
                
                Log.d(TAG, "Weekly comparison chart generated")
                chartData
                
            } catch (e: Exception) {
                Log.e(TAG, "Error generating weekly comparison chart", e)
                SafetyChartData.createError(driverId, ChartType.BAR_CHART)
            }
        }
    }
    
    // Helper methods
    private fun aggregateSafetyData(
        sessions: List<DrivingSession>,
        period: AggregationPeriod
    ): Map<String, AggregatedSafetyData> {
        return when (period) {
            AggregationPeriod.HOURLY -> {
                sessions.groupBy { it.startTime.hour.toString() }
                    .mapValues { (_, hourSessions) ->
                        AggregatedSafetyData(
                            averageSafetyScore = hourSessions.mapNotNull { it.safetyScore }.average(),
                            harshBrakingCount = hourSessions.sumOf { it.harshBrakingCount },
                            rapidAccelerationCount = hourSessions.sumOf { it.rapidAccelerationCount },
                            overSpeedingCount = hourSessions.sumOf { it.overSpeedingCount },
                            sharpTurnCount = hourSessions.sumOf { it.sharpTurnCount },
                            seatbeltViolations = hourSessions.sumOf { it.seatbeltViolations }
                        )
                    }
            }
            AggregationPeriod.DAILY -> {
                sessions.groupBy { it.startTime.toLocalDate() }
                    .mapValues { (_, daySessions) ->
                        AggregatedSafetyData(
                            averageSafetyScore = daySessions.mapNotNull { it.safetyScore }.average(),
                            harshBrakingCount = daySessions.sumOf { it.harshBrakingCount },
                            rapidAccelerationCount = daySessions.sumOf { it.rapidAccelerationCount },
                            overSpeedingCount = daySessions.sumOf { it.overSpeedingCount },
                            sharpTurnCount = daySessions.sumOf { it.sharpTurnCount },
                            seatbeltViolations = daySessions.sumOf { it.seatbeltViolations }
                        )
                    }
            }
            AggregationPeriod.WEEKLY -> {
                sessions.groupBy { it.startTime.toLocalDate().withDayOfWeek(1) }
                    .mapValues { (_, weekSessions) ->
                        AggregatedSafetyData(
                            averageSafetyScore = weekSessions.mapNotNull { it.safetyScore }.average(),
                            harshBrakingCount = weekSessions.sumOf { it.harshBrakingCount },
                            rapidAccelerationCount = weekSessions.sumOf { it.rapidAccelerationCount },
                            overSpeedingCount = weekSessions.sumOf { it.overSpeedingCount },
                            sharpTurnCount = weekSessions.sumOf { it.sharpTurnCount },
                            seatbeltViolations = weekSessions.sumOf { it.seatbeltViolations }
                        )
                    }
            }
            AggregationPeriod.MONTHLY -> {
                sessions.groupBy { "${it.startTime.year}-${it.startTime.monthValue}" }
                    .mapValues { (_, monthSessions) ->
                        AggregatedSafetyData(
                            averageSafetyScore = monthSessions.mapNotNull { it.safetyScore }.average(),
                            harshBrakingCount = monthSessions.sumOf { it.harshBrakingCount },
                            rapidAccelerationCount = monthSessions.sumOf { it.rapidAccelerationCount },
                            overSpeedingCount = monthSessions.sumOf { it.overSpeedingCount },
                            sharpTurnCount = monthSessions.sumOf { it.sharpTurnCount },
                            seatbeltViolations = monthSessions.sumOf { it.seatbeltViolations }
                        )
                    }
            }
        }
    }
    
    private fun formatPeriodLabel(period: String, aggregationPeriod: AggregationPeriod): String {
        return when (aggregationPeriod) {
            AggregationPeriod.HOURLY -> "${period}:00"
            AggregationPeriod.DAILY -> period
            AggregationPeriod.WEEKLY, AggregationPeriod.MONTHLY -> period
        }
    }
    
    private fun calculateBrakingSafetyScore(sessions: List<DrivingSession>): Double {
        val totalBraking = sessions.sumOf { it.harshBrakingCount }
        val totalDistance = sessions.sumOf { it.distance }
        val brakingPer100km = if (totalDistance > 0) (totalBraking / totalDistance) * 100 else 0.0
        return maxOf(0.0, 100.0 - (brakingPer100km * 10))
    }
    
    private fun calculateAccelerationSafetyScore(sessions: List<DrivingSession>): Double {
        val totalAcceleration = sessions.sumOf { it.rapidAccelerationCount }
        val totalDistance = sessions.sumOf { it.distance }
        val accelerationPer100km = if (totalDistance > 0) (totalAcceleration / totalDistance) * 100 else 0.0
        return maxOf(0.0, 100.0 - (accelerationPer100km * 10))
    }
    
    private fun calculateSpeedComplianceScore(sessions: List<DrivingSession>): Double {
        val totalSpeeding = sessions.sumOf { it.overSpeedingCount }
        val totalDistance = sessions.sumOf { it.distance }
        val speedingPer100km = if (totalDistance > 0) (totalSpeeding / totalDistance) * 100 else 0.0
        return maxOf(0.0, 100.0 - (speedingPer100km * 15))
    }
    
    private fun calculateTurningSafetyScore(sessions: List<DrivingSession>): Double {
        val totalTurns = sessions.sumOf { it.sharpTurnCount }
        val totalDistance = sessions.sumOf { it.distance }
        val turnsPer100km = if (totalDistance > 0) (totalTurns / totalDistance) * 100 else 0.0
        return maxOf(0.0, 100.0 - (turnsPer100km * 8))
    }
    
    private fun calculateSeatbeltComplianceScore(sessions: List<DrivingSession>): Double {
        val totalViolations = sessions.sumOf { it.seatbeltViolations }
        val totalSessions = sessions.size
        val violationRate = if (totalSessions > 0) (totalViolations.toDouble() / totalSessions) * 100 else 0.0
        return maxOf(0.0, 100.0 - (violationRate * 20))
    }
}

// Data classes
data class SafetyChartData(
    val driverId: String,
    val chartType: SafetyCharts.ChartType,
    val title: String,
    val dataPoints: List<ChartDataPoint>,
    val timeWindow: TimeWindow,
    val aggregationPeriod: SafetyCharts.AggregationPeriod? = null,
    val generatedAt: LocalDateTime,
    val errorMessage: String? = null
) {
    companion object {
        fun createError(driverId: String, chartType: SafetyCharts.ChartType): SafetyChartData {
            return SafetyChartData(
                driverId = driverId,
                chartType = chartType,
                title = "Error",
                dataPoints = emptyList(),
                timeWindow = TimeWindow.LAST_7_DAYS,
                generatedAt = LocalDateTime.now(),
                errorMessage = "Error generating chart data"
            )
        }
        
        fun createEmpty(driverId: String, chartType: SafetyCharts.ChartType): SafetyChartData {
            return SafetyChartData(
                driverId = driverId,
                chartType = chartType,
                title = "No Data",
                dataPoints = emptyList(),
                timeWindow = TimeWindow.LAST_7_DAYS,
                generatedAt = LocalDateTime.now()
            )
        }
    }
}

data class ChartDataPoint(
    val label: String,
    val value: Double,
    val percentage: Double = 0.0,
    val maxValue: Double = 100.0,
    val metadata: Map<String, Any> = emptyMap()
)

data class AggregatedSafetyData(
    val averageSafetyScore: Double,
    val harshBrakingCount: Int,
    val rapidAccelerationCount: Int,
    val overSpeedingCount: Int,
    val sharpTurnCount: Int,
    val seatbeltViolations: Int
)

data class WeekSafetyData(
    val averageSafetyScore: Double,
    val harshBrakingCount: Int,
    val rapidAccelerationCount: Int,
    val overSpeedingCount: Int
)
