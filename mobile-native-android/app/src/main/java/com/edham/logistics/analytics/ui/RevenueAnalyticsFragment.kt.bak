/**
 * Revenue Analytics Fragment - Comprehensive revenue and financial analytics
 * 
 * Features:
 * - Revenue overview and trends
 * - Revenue breakdown by category
 * - Customer revenue analysis
 * - Route revenue metrics
 * - Profit analysis
 * - Revenue forecasting
 * - Interactive charts
 * - Financial KPIs
 */
@AndroidEntryPoint
class RevenueAnalyticsFragment : Fragment() {
    
    @Inject
    lateinit var analyticsEngineService: AnalyticsEngineService
    
    private val viewModel: RevenueAnalyticsViewModel by viewModels()
    
    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View {
        return ComposeView(requireContext()).apply {
            setContent {
                EdhamLogisticsTheme {
                    RevenueAnalyticsScreen(
                        viewModel = viewModel,
                        analyticsEngineService = analyticsEngineService
                    )
                }
            }
        }
    }
    
    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        
        // Initialize analytics engine
        lifecycleScope.launch {
            analyticsEngineService.initialize()
        }
        
        // Load revenue analytics
        viewModel.loadRevenueAnalytics()
    }
}

@Composable
fun RevenueAnalyticsScreen(
    viewModel: RevenueAnalyticsViewModel,
    analyticsEngineService: AnalyticsEngineService
) {
    val revenueAnalytics by viewModel.revenueAnalytics.collectAsStateWithLifecycle()
    val isLoading by viewModel.isLoading.collectAsStateWithLifecycle()
    val errorMessage by viewModel.errorMessage.collectAsStateWithLifecycle()
    val selectedTimeRange by viewModel.selectedTimeRange.collectAsStateWithLifecycle()
    
    LaunchedEffect(selectedTimeRange) {
        viewModel.loadRevenueAnalytics()
    }
    
    Column(
        modifier = Modifier
            .fillMaxSize()
            .padding(16.dp),
        verticalArrangement = Arrangement.spacedBy(16.dp)
    ) {
        // Header with time range selector
        RevenueAnalyticsHeader(
            selectedTimeRange = selectedTimeRange,
            onTimeRangeChanged = viewModel::setTimeRange,
            onRefresh = viewModel::refreshAnalytics,
            isLoading = isLoading
        )
        
        // Error message
        errorMessage?.let { error ->
            Card(
                modifier = Modifier.fillMaxWidth(),
                colors = CardDefaults.cardColors(
                    containerColor = ErrorRed.copy(alpha = 0.1f)
                ),
                elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
            ) {
                Text(
                    text = error,
                    modifier = Modifier.padding(16.dp),
                    color = ErrorRed,
                    style = MaterialTheme.typography.bodyMedium
                )
            }
        }
        
        // Revenue Analytics Content
        revenueAnalytics?.let { analytics ->
            // Revenue Overview
            RevenueOverviewSection(analytics = analytics)
            
            // Revenue Breakdown
            RevenueBreakdownSection(analytics = analytics)
            
            // Customer Revenue Analysis
            CustomerRevenueSection(analytics = analytics)
            
            // Route Revenue Metrics
            RouteRevenueSection(analytics = analytics)
            
            // Profit Analysis
            ProfitAnalysisSection(analytics = analytics)
            
            // Revenue Trends
            RevenueTrendsSection(analytics = analytics)
            
            // Financial KPIs
            FinancialKPIsSection(analytics = analytics)
        }
        
        // Loading indicator
        if (isLoading) {
            Box(
                modifier = Modifier.fillMaxWidth(),
                contentAlignment = Alignment.Center
            ) {
                CircularProgressIndicator(
                    color = EdhamOrange,
                    strokeWidth = 3.dp
                )
            }
        }
    }
}

@Composable
fun RevenueAnalyticsHeader(
    selectedTimeRange: TimeRange,
    onTimeRangeChanged: (TimeRange) -> Unit,
    onRefresh: () -> Unit,
    isLoading: Boolean
) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.surface
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Row(
                modifier = Modifier.fillMaxWidth(),
                horizontalArrangement = Arrangement.SpaceBetween,
                verticalAlignment = Alignment.CenterVertically
            ) {
                Text(
                    text = "Revenue Analytics",
                    style = MaterialTheme.typography.headlineMedium,
                    color = EdhamOrange,
                    fontWeight = FontWeight.Bold
                )
                
                Row {
                    // Time range selector
                    TimeRangeSelector(
                        selectedTimeRange = selectedTimeRange,
                        onTimeRangeChanged = onTimeRangeChanged
                    )
                    
                    Spacer(modifier = Modifier.width(8.dp))
                    
                    // Refresh button
                    IconButton(
                        onClick = onRefresh,
                        enabled = !isLoading
                    ) {
                        Icon(
                            painter = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_rotate),
                            contentDescription = "Refresh",
                            tint = EdhamOrange
                        )
                    }
                }
            }
        }
    }
}

@Composable
fun RevenueOverviewSection(analytics: RevenueAnalytics) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.surface
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Text(
                text = "Revenue Overview",
                style = MaterialTheme.typography.titleMedium,
                color = EdhamOrange,
                fontWeight = FontWeight.Bold
            )
            
            Spacer(modifier = Modifier.height(16.dp))
            
            LazyColumn(
                verticalArrangement = Arrangement.spacedBy(12.dp)
            ) {
                item {
                    OverviewMetric(
                        title = "Total Revenue",
                        value = "SAR ${String.format("%,.2f", analytics.totalRevenue)}",
                        subtitle = "In selected period",
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_more),
                        color = SuccessGreen,
                        change = analytics.revenueChange
                    )
                }
                
                item {
                    OverviewMetric(
                        title = "Net Profit",
                        value = "SAR ${String.format("%,.2f", analytics.netProfit)}",
                        subtitle = "After expenses",
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_preferences),
                        color = if (analytics.netProfit >= 0) SuccessGreen else ErrorRed,
                        change = analytics.profitChange
                    )
                }
                
                item {
                    OverviewMetric(
                        title = "Profit Margin",
                        value = "${String.format("%.1f", analytics.profitMargin)}%",
                        subtitle = "Profit as percentage of revenue",
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_info_details),
                        color = if (analytics.profitMargin >= 15) SuccessGreen else WarningYellow,
                        change = analytics.profitMarginChange
                    )
                }
                
                item {
                    OverviewMetric(
                        title = "Average Revenue per Shipment",
                        value = "SAR ${String.format("%,.2f", analytics.averageRevenuePerShipment)}",
                        subtitle = "Per shipment average",
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_agenda),
                        color = EdhamOrange,
                        change = analytics.averageRevenueChange
                    )
                }
            }
        }
    }
}

