@Composable
fun FinancialKPIsSection(analytics: RevenueAnalytics) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.surface
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Text(
                text = "Financial KPIs",
                style = MaterialTheme.typography.titleMedium,
                color = EdhamOrange,
                fontWeight = FontWeight.Bold
            )
            
            Spacer(modifier = Modifier.height(16.dp))
            
            LazyColumn(
                verticalArrangement = Arrangement.spacedBy(8.dp)
            ) {
                item {
                    KPIItem(
                        title = "Revenue per Employee",
                        value = "SAR ${String.format("%,.2f", analytics.revenuePerEmployee)}",
                        status = if (analytics.revenuePerEmployee >= 100000) "Excellent" else "Good"
                    )
                }
                
                item {
                    KPIItem(
                        title = "Revenue per Vehicle",
                        value = "SAR ${String.format("%,.2f", analytics.revenuePerVehicle)}",
                        status = if (analytics.revenuePerVehicle >= 50000) "Excellent" else "Good"
                    )
                }
                
                item {
                    KPIItem(
                        title = "Cash Conversion Cycle",
                        value = "${analytics.cashConversionCycle} days",
                        status = if (analytics.cashConversionCycle <= 30) "Excellent" else "Needs Improvement"
                    )
                }
                
                item {
                    KPIItem(
                        title = "Return on Investment",
                        value = "${String.format("%.1f", analytics.returnOnInvestment)}%",
                        status = if (analytics.returnOnInvestment >= 15) "Excellent" else "Good"
                    )
                }
            }
        }
    }
}

@Composable
fun KPIItem(
    title: String,
    value: String,
    status: String
) {
    Row(
        modifier = Modifier.fillMaxWidth(),
        horizontalArrangement = Arrangement.SpaceBetween,
        verticalAlignment = Alignment.CenterVertically
    ) {
        Text(
            text = title,
            style = MaterialTheme.typography.bodyMedium,
            color = MaterialTheme.colorScheme.onSurface
        )
        
        Row(
            verticalAlignment = Alignment.CenterVertically
        ) {
            Text(
                text = value,
                style = MaterialTheme.typography.titleMedium,
                color = EdhamOrange,
                fontWeight = FontWeight.Bold
            )
            
            Spacer(modifier = Modifier.width(8.dp))
            
            Card(
                colors = CardDefaults.cardColors(
                    containerColor = if (status == "Excellent") SuccessGreen else WarningYellow
                ),
                shape = RoundedCornerShape(12.dp)
            ) {
                Text(
                    text = status,
                    modifier = Modifier.padding(horizontal = 8.dp, vertical = 4.dp),
                    style = MaterialTheme.typography.bodySmall,
                    color = Color.White,
                    fontWeight = FontWeight.Medium
                )
            }
        }
    }
}

// Data classes
data class RevenueBreakdownData(
    val category: String,
    val revenue: Double,
    val count: Int,
    val percentage: Float,
    val color: Color
)

data class CustomerRevenueData(
    val customerName: String,
    val totalRevenue: Double,
    val shipmentCount: Int,
    val averageRevenuePerShipment: Double
)

data class RouteRevenueData(
    val routeName: String,
    val totalRevenue: Double,
    val shipmentCount: Int,
    val averageRevenuePerShipment: Double
)
