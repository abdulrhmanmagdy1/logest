            containerColor = MaterialTheme.colorScheme.surface
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Text(
                text = "Profit Analysis",
                style = MaterialTheme.typography.titleMedium,
                color = EdhamOrange,
                fontWeight = FontWeight.Bold
            )
            
            Spacer(modifier = Modifier.height(16.dp))
            
            LazyColumn(
                verticalArrangement = Arrangement.spacedBy(12.dp)
            ) {
                item {
                    ProfitMetric(
                        title = "Total Expenses",
                        value = "SAR ${String.format("%,.2f", analytics.totalExpenses)}",
                        subtitle = "All operational costs",
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_info_details),
                        color = ErrorRed
                    )
                }
                
                item {
                    ProfitMetric(
                        title = "Operating Profit",
                        value = "SAR ${String.format("%,.2f", analytics.operatingProfit)}",
                        subtitle = "Revenue - Operating Expenses",
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_preferences),
                        color = if (analytics.operatingProfit >= 0) SuccessGreen else ErrorRed
                    )
                }
                
                item {
                    ProfitMetric(
                        title = "Gross Profit Margin",
                        value = "${String.format("%.1f", analytics.grossProfitMargin)}%",
                        subtitle = "Gross profit as percentage",
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_more),
                        color = if (analytics.grossProfitMargin >= 20) SuccessGreen else WarningYellow
                    )
                }
                
                item {
                    ProfitMetric(
                        title = "EBITDA",
                        value = "SAR ${String.format("%,.2f", analytics.ebitda)}",
                        subtitle = "Earnings before interest, taxes, depreciation",
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_star),
                        color = if (analytics.ebitda >= 0) SuccessGreen else ErrorRed
                    )
                }
            }
        }
    }
}

@Composable
fun ProfitMetric(
    title: String,
    value: String,
    subtitle: String,
    icon: androidx.compose.ui.graphics.painter.Painter,
    color: Color
) {
    Row(
        modifier = Modifier.fillMaxWidth(),
        verticalAlignment = Alignment.CenterVertically
    ) {
        Card(
            modifier = Modifier.size(40.dp),
            colors = CardDefaults.cardColors(
                containerColor = color.copy(alpha = 0.1f)
            ),
            elevation = CardDefaults.cardElevation(defaultElevation = 1.dp)
        ) {
            Box(
                modifier = Modifier.fillMaxSize(),
                contentAlignment = Alignment.Center
            ) {
                Icon(
                    painter = icon,
                    contentDescription = null,
                    tint = color,
                    modifier = Modifier.size(20.dp)
                )
            }
        }
        
        Spacer(modifier = Modifier.width(12.dp))
        
        Column(modifier = Modifier.weight(1f)) {
            Text(
                text = title,
                style = MaterialTheme.typography.bodyMedium,
                color = MaterialTheme.colorScheme.onSurface
            )
            
            Text(
                text = value,
                style = MaterialTheme.typography.titleMedium,
                color = color,
                fontWeight = FontWeight.Bold
            )
            
            Text(
                text = subtitle,
                style = MaterialTheme.typography.bodySmall,
                color = MaterialTheme.colorScheme.onSurface.copy(alpha = 0.5f)
            )
        }
    }
}

