package com.edham.logistics.offline.cache

import kotlinx.coroutines.*
import kotlinx.coroutines.flow.*
import timber.log.Timber
import java.util.concurrent.ConcurrentHashMap
import javax.inject.Inject
import javax.inject.Singleton

/**
 * Optimized Cache Strategy - Advanced caching with intelligent eviction and memory management
 * Implements multi-tier caching, adaptive sizing, and performance optimization
 */

// Temporarily disabled due to missing dependencies
// @Singleton
// class OptimizedCacheStrategy @Inject constructor(
//     private val shipmentCache: ShipmentCache,
//     private val mapsCache: MapsCache,
//     private val offlineDatabase: OfflineDatabase
// ) {
class OptimizedCacheStrategy {

    private val cacheScope = CoroutineScope(Dispatchers.IO + SupervisorJob())
    
    // Cache tiers
    private val hotCache = ConcurrentHashMap<String, CacheEntry>() // Most frequently accessed
    private val warmCache = ConcurrentHashMap<String, CacheEntry>() // Moderately accessed
    private val coldCache = ConcurrentHashMap<String, CacheEntry>() // Rarely accessed
    
    // Cache configuration
    private val maxHotCacheSize = 50
    private val maxWarmCacheSize = 200
    private val maxColdCacheSize = 1000
    private val maxTotalMemorySize = 100 * 1024 * 1024L // 100MB
    
    // Access tracking
    private val accessTracker = ConcurrentHashMap<String, AccessStats>()
    private val accessHistory = mutableListOf<AccessRecord>()
    
    // Cache statistics
    private val _cacheStats = MutableStateFlow(CacheStrategyStats())
    val cacheStats: StateFlow<CacheStrategyStats> = _cacheStats.asStateFlow()

    init {
        startCacheOptimization()
    }

    /**
     * Get data from optimized cache
     */
    suspend fun <T> get(key: String, type: CacheType): T? {
        return try {
            val startTime = System.currentTimeMillis()
            
            // Check hot cache first
            hotCache[key]?.let { entry ->
                if (!isExpired(entry)) {
                    updateAccessStats(key, "HOT")
                    recordCacheHit(type, "HOT", System.currentTimeMillis() - startTime)
                    return entry.data as T
                } else {
                    hotCache.remove(key)
                }
            }
            
            // Check warm cache
            warmCache[key]?.let { entry ->
                if (!isExpired(entry)) {
                    // Promote to hot cache if frequently accessed
                    if (shouldPromoteToHot(key)) {
                        promoteToHotCache(key, entry)
                        warmCache.remove(key)
                    }
                    updateAccessStats(key, "WARM")
                    recordCacheHit(type, "WARM", System.currentTimeMillis() - startTime)
                    return entry.data as T
                } else {
                    warmCache.remove(key)
                }
            }
            
            // Check cold cache
            coldCache[key]?.let { entry ->
                if (!isExpired(entry)) {
                    // Promote to warm cache
                    if (shouldPromoteToWarm(key)) {
                        promoteToWarmCache(key, entry)
                        coldCache.remove(key)
                    }
                    updateAccessStats(key, "COLD")
                    recordCacheHit(type, "COLD", System.currentTimeMillis() - startTime)
                    return entry.data as T
                } else {
                    coldCache.remove(key)
                }
            }
            
            // Cache miss - try to load from persistent storage
            val data = loadFromPersistentStorage(key, type)
            if (data != null) {
                put(key, data, type)
                recordCacheHit(type, "PERSISTENT", System.currentTimeMillis() - startTime)
                return data
            }
            
            recordCacheMiss(type, System.currentTimeMillis() - startTime)
            null
            
        } catch (e: Exception) {
            Timber.e(e, "Error getting from optimized cache")
            null
        }
    }

    /**
     * Put data in optimized cache
     */
    suspend fun <T> put(key: String, data: T, type: CacheType) {
        try {
            val entry = CacheEntry(
                key = key,
                data = data,
                type = type,
                createdAt = System.currentTimeMillis(),
                lastAccessed = System.currentTimeMillis(),
                accessCount = 1,
                size = estimateSize(data),
                expiryTime = calculateExpiryTime(type)
            )
            
            // Determine initial cache tier based on access patterns
            val targetTier = determineInitialTier(key, type)
            
            when (targetTier) {
                CacheTier.HOT -> {
                    if (hotCache.size >= maxHotCacheSize) {
                        evictFromHotCache()
                    }
                    hotCache[key] = entry
                }
                CacheTier.WARM -> {
                    if (warmCache.size >= maxWarmCacheSize) {
                        evictFromWarmCache()
                    }
                    warmCache[key] = entry
                }
                CacheTier.COLD -> {
                    if (coldCache.size >= maxColdCacheSize) {
                        evictFromColdCache()
                    }
                    coldCache[key] = entry
                }
            }
            
            // Also save to persistent storage
            saveToPersistentStorage(key, data, type)
            
            // Update access stats
            updateAccessStats(key, targetTier.name)
            
            // Check memory usage and optimize if needed
            checkMemoryUsage()
            
            Timber.d("Cached data in ${targetTier.name}: $key")
            
        } catch (e: Exception) {
            Timber.e(e, "Error putting in optimized cache")
        }
    }

    /**
     * Invalidate cache entry
     */
    suspend fun invalidate(key: String) {
        try {
            hotCache.remove(key)
            warmCache.remove(key)
            coldCache.remove(key)
            accessTracker.remove(key)
            
            // Also remove from persistent storage
            removeFromPersistentStorage(key)
            
            Timber.d("Invalidated cache entry: $key")
            
        } catch (e: Exception) {
            Timber.e(e, "Error invalidating cache entry")
        }
    }

    /**
     * Clear all caches
     */
    suspend fun clearAll() {
        try {
            hotCache.clear()
            warmCache.clear()
            coldCache.clear()
            accessTracker.clear()
            accessHistory.clear()
            
            // Clear persistent caches
            shipmentCache.clearCache()
            mapsCache.clearCache()
            
            // Reset statistics
            _cacheStats.value = CacheStrategyStats()
            
            Timber.d("Cleared all optimized caches")
            
        } catch (e: Exception) {
            Timber.e(e, "Error clearing all caches")
        }
    }

    /**
     * Get cache performance metrics
     */
    fun getPerformanceMetrics(): CachePerformanceMetrics {
        val totalEntries = hotCache.size + warmCache.size + coldCache.size
        val totalMemoryUsage = calculateTotalMemoryUsage()
        val hitRate = calculateHitRate()
        val averageAccessTime = calculateAverageAccessTime()
        
        return CachePerformanceMetrics(
            totalEntries = totalEntries,
            hotCacheSize = hotCache.size,
            warmCacheSize = warmCache.size,
            coldCacheSize = coldCache.size,
            totalMemoryUsage = totalMemoryUsage,
            hitRate = hitRate,
            averageAccessTime = averageAccessTime,
            evictionRate = calculateEvictionRate(),
            promotionRate = calculatePromotionRate()
        )
    }

    /**
     * Optimize cache configuration
     */
    suspend fun optimizeCache() {
        try {
            // Analyze access patterns and adjust cache sizes
            val accessPatterns = analyzeAccessPatterns()
            
            // Adjust cache sizes based on patterns
            adjustCacheSizes(accessPatterns)
            
            // Reorganize cache tiers
            reorganizeCacheTiers()
            
            // Clear expired entries
            clearExpiredEntries()
            
            // Update statistics
            updateCacheStats()
            
            Timber.d("Cache optimization completed")
            
        } catch (e: Exception) {
            Timber.e(e, "Error during cache optimization")
        }
    }

    // Private methods

    private fun startCacheOptimization() {
        cacheScope.launch {
            while (isActive) {
                try {
                    // Periodic optimization
                    optimizeCache()
                    
                    // Clean up old access records
                    cleanupAccessHistory()
                    
                    delay(300000) // Run every 5 minutes
                    
                } catch (e: Exception) {
                    Timber.e(e, "Error in cache optimization")
                    delay(600000) // Wait longer on error
                }
            }
        }
    }

    private fun isExpired(entry: CacheEntry): Boolean {
        return System.currentTimeMillis() > entry.expiryTime
    }

    private fun shouldPromoteToHot(key: String): Boolean {
        val stats = accessTracker[key] ?: return false
        return stats.accessCount >= 10 && stats.averageAccessInterval < 60000 // 1 minute
    }

    private fun shouldPromoteToWarm(key: String): Boolean {
        val stats = accessTracker[key] ?: return false
        return stats.accessCount >= 3 && stats.averageAccessInterval < 300000 // 5 minutes
    }

    private fun promoteToHotCache(key: String, entry: CacheEntry) {
        if (hotCache.size >= maxHotCacheSize) {
            evictFromHotCache()
        }
        
        val promotedEntry = entry.copy(
            lastAccessed = System.currentTimeMillis(),
            accessCount = entry.accessCount + 1
        )
        
        hotCache[key] = promotedEntry
    }

    private fun promoteToWarmCache(key: String, entry: CacheEntry) {
        if (warmCache.size >= maxWarmCacheSize) {
            evictFromWarmCache()
        }
        
        val promotedEntry = entry.copy(
            lastAccessed = System.currentTimeMillis(),
            accessCount = entry.accessCount + 1
        )
        
        warmCache[key] = promotedEntry
    }

    private fun evictFromHotCache() {
        val lruKey = hotCache.entries.minByOrNull { it.value.lastAccessed }?.key
        if (lruKey != null) {
            val entry = hotCache.remove(lruKey)
            if (entry != null) {
                // Demote to warm cache
                if (warmCache.size < maxWarmCacheSize) {
                    warmCache[lruKey] = entry
                }
            }
        }
    }

    private fun evictFromWarmCache() {
        val lruKey = warmCache.entries.minByOrNull { it.value.lastAccessed }?.key
        if (lruKey != null) {
            val entry = warmCache.remove(lruKey)
            if (entry != null) {
                // Demote to cold cache
                if (coldCache.size < maxColdCacheSize) {
                    coldCache[lruKey] = entry
                }
            }
        }
    }

    private fun evictFromColdCache() {
        val lruKey = coldCache.entries.minByOrNull { it.value.lastAccessed }?.key
        if (lruKey != null) {
            coldCache.remove(lruKey)
            accessTracker.remove(lruKey)
        }
    }

    private fun determineInitialTier(key: String, type: CacheType): CacheTier {
        val stats = accessTracker[key]
        
        return when {
            stats?.accessCount ?: 0 >= 5 -> CacheTier.HOT
            stats?.accessCount ?: 0 >= 2 -> CacheTier.WARM
            else -> CacheTier.COLD
        }
    }

    private fun updateAccessStats(key: String, tier: String) {
        val currentTime = System.currentTimeMillis()
        val stats = accessTracker.getOrPut(key) {
            AccessStats(
                key = key,
                accessCount = 0,
                firstAccess = currentTime,
                lastAccess = currentTime,
                totalAccessTime = 0L,
                averageAccessInterval = 0L
            )
        }
        
        stats.accessCount++
        stats.lastAccessed = currentTime
        
        // Calculate access interval
        if (stats.accessCount > 1) {
            val interval = currentTime - stats.lastAccessed
            stats.totalAccessTime += interval
            stats.averageAccessInterval = stats.totalAccessTime / (stats.accessCount - 1)
        }
        
        // Record access
        accessHistory.add(AccessRecord(key, tier, currentTime))
        
        // Limit history size
        if (accessHistory.size > 10000) {
            accessHistory.removeFirst()
        }
    }

    private fun calculateExpiryTime(type: CacheType): Long {
        val baseExpiry = when (type) {
            CacheType.SHIPMENT -> 30 * 60 * 1000L // 30 minutes
            CacheType.DRIVER -> 60 * 60 * 1000L // 1 hour
            CacheType.VEHICLE -> 2 * 60 * 60 * 1000L // 2 hours
            CacheType.LOCATION -> 15 * 60 * 1000L // 15 minutes
            CacheType.MAPS_TILES -> 24 * 60 * 60 * 1000L // 24 hours
            CacheType.MAPS_ROUTES -> 2 * 60 * 60 * 1000L // 2 hours
            CacheType.MAPS_GEOCODING -> 7 * 24 * 60 * 60 * 1000L // 7 days
        }
        
        return System.currentTimeMillis() + baseExpiry
    }

    private fun estimateSize(data: Any): Long {
        return when (data) {
            is String -> data.length.toLong()
            is ByteArray -> data.size.toLong()
            else -> 1024L // Default 1KB
        }
    }

    private fun checkMemoryUsage() {
        val totalUsage = calculateTotalMemoryUsage()
        if (totalUsage > maxTotalMemorySize) {
            // Evict from cold cache first
            while (totalUsage > maxTotalMemorySize * 0.8 && coldCache.isNotEmpty()) {
                evictFromColdCache()
            }
            
            // Then from warm cache
            while (totalUsage > maxTotalMemorySize * 0.6 && warmCache.isNotEmpty()) {
                evictFromWarmCache()
            }
            
            // Finally from hot cache
            while (totalUsage > maxTotalMemorySize * 0.4 && hotCache.isNotEmpty()) {
                evictFromHotCache()
            }
        }
    }

    private fun calculateTotalMemoryUsage(): Long {
        return hotCache.values.sumOf { it.size } +
               warmCache.values.sumOf { it.size } +
               coldCache.values.sumOf { it.size }
    }

    private suspend fun loadFromPersistentStorage(key: String, type: CacheType): Any? {
        return try {
            when (type) {
                CacheType.SHIPMENT -> shipmentCache.getShipment(key)
                CacheType.MAPS_TILES -> mapsCache.getMapTiles(key)
                CacheType.MAPS_ROUTES -> mapsCache.getRoute(key)
                CacheType.MAPS_GEOCODING -> mapsCache.getGeocoding(key)
                else -> null
            }
        } catch (e: Exception) {
            Timber.e(e, "Error loading from persistent storage")
            null
        }
    }

    private suspend fun saveToPersistentStorage(key: String, data: Any, type: CacheType) {
        try {
            when (type) {
                CacheType.SHIPMENT -> {
                    if (data is ShipmentEntity) {
                        shipmentCache.putShipment(data)
                    }
                }
                CacheType.MAPS_TILES -> {
                    if (data is String) {
                        mapsCache.putMapTiles(key, data)
                    }
                }
                CacheType.MAPS_ROUTES -> {
                    if (data is String) {
                        mapsCache.putRoute(key, data)
                    }
                }
                CacheType.MAPS_GEOCODING -> {
                    if (data is String) {
                        mapsCache.putGeocoding(key, data)
                    }
                }
                else -> {}
            }
        } catch (e: Exception) {
            Timber.e(e, "Error saving to persistent storage")
        }
    }

    private suspend fun removeFromPersistentStorage(key: String) {
        try {
            // Implementation would depend on specific cache type
            // For now, just log
            Timber.d("Removed from persistent storage: $key")
        } catch (e: Exception) {
            Timber.e(e, "Error removing from persistent storage")
        }
    }

    private fun analyzeAccessPatterns(): AccessPatterns {
        val recentAccess = accessHistory.takeLast(1000)
        
        val hotAccess = recentAccess.count { it.tier == "HOT" }
        val warmAccess = recentAccess.count { it.tier == "WARM" }
        val coldAccess = recentAccess.count { it.tier == "COLD" }
        
        val totalAccess = hotAccess + warmAccess + coldAccess
        
        return AccessPatterns(
            hotAccessPercentage = if (totalAccess > 0) hotAccess.toDouble() / totalAccess else 0.0,
            warmAccessPercentage = if (totalAccess > 0) warmAccess.toDouble() / totalAccess else 0.0,
            coldAccessPercentage = if (totalAccess > 0) coldAccess.toDouble() / totalAccess else 0.0,
            mostAccessedKeys = recentAccess.groupBy { it.key }.mapValues { it.value.size }.toList().sortedByDescending { it.second }.take(10).map { it.first }
        )
    }

    private fun adjustCacheSizes(patterns: AccessPatterns) {
        // Adjust cache sizes based on access patterns
        // This is a simplified implementation
        if (patterns.hotAccessPercentage > 0.3) {
            // Increase hot cache size
            // Implementation would adjust maxHotCacheSize
        }
    }

    private fun reorganizeCacheTiers() {
        // Move entries between tiers based on access patterns
        accessTracker.forEach { (key, stats) ->
            when {
                stats.accessCount >= 10 && stats.averageAccessInterval < 60000 -> {
                    // Should be in hot cache
                    coldCache.remove(key)?.let { entry ->
                        promoteToHotCache(key, entry)
                    }
                    warmCache.remove(key)?.let { entry ->
                        promoteToHotCache(key, entry)
                    }
                }
                stats.accessCount >= 3 && stats.averageAccessInterval < 300000 -> {
                    // Should be in warm cache
                    coldCache.remove(key)?.let { entry ->
                        promoteToWarmCache(key, entry)
                    }
                }
                else -> {
                    // Should be in cold cache
                    hotCache.remove(key)?.let { entry ->
                        if (coldCache.size < maxColdCacheSize) {
                            coldCache[key] = entry
                        }
                    }
                    warmCache.remove(key)?.let { entry ->
                        if (coldCache.size < maxColdCacheSize) {
                            coldCache[key] = entry
                        }
                    }
                }
            }
        }
    }

    private suspend fun clearExpiredEntries() {
        val currentTime = System.currentTimeMillis()
        
        hotCache.entries.removeIf { isExpired(it.value) }
        warmCache.entries.removeIf { isExpired(it.value) }
        coldCache.entries.removeIf { isExpired(it.value) }
    }

    private fun cleanupAccessHistory() {
        // Keep only last 24 hours of access history
        val twentyFourHoursAgo = System.currentTimeMillis() - (24 * 60 * 60 * 1000L)
        accessHistory.removeIf { it.timestamp < twentyFourHoursAgo }
    }

    private fun updateCacheStats() {
        val metrics = getPerformanceMetrics()
        _cacheStats.value = CacheStrategyStats(
            totalEntries = metrics.totalEntries,
            hitRate = metrics.hitRate,
            averageAccessTime = metrics.averageAccessTime,
            memoryUsage = metrics.totalMemoryUsage
        )
    }

