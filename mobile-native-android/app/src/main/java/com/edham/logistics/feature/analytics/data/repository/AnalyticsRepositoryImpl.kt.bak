    override suspend fun observeAnalyticsMessages(): Flow<Result<AnalyticsWebSocketMessage>> {
        return analyticsWebSocketService.messageFlow.map { message ->
            Result.Success(message)
        }
    }

    override suspend fun refreshDashboardData(userId: String, userRole: String): Result<Unit> {
        return try {
            when (userRole) {
                "admin" -> {
                    analyticsDatabase.adminDashboardDao().deleteDashboardData(userId)
                    getAdminDashboardData(userId, null)
                }
                "customer" -> {
                    analyticsDatabase.customerDashboardDao().deleteDashboardData(userId)
                    getCustomerDashboardData(userId, null)
                }
                "driver" -> {
                    analyticsDatabase.driverDashboardDao().deleteDashboardData(userId)
                    getDriverDashboardData(userId, null)
                }
                "accountant" -> {
                    analyticsDatabase.accountantDashboardDao().deleteDashboardData(userId)
                    getAccountantDashboardData(userId, null)
                }
                else -> Result.Error(Exception("Invalid user role"))
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

    override suspend fun clearCache(userId: String): Result<Unit> {
        return try {
            analyticsDatabase.adminDashboardDao().deleteDashboardData(userId)
            analyticsDatabase.customerDashboardDao().deleteDashboardData(userId)
            analyticsDatabase.driverDashboardDao().deleteDashboardData(userId)
            analyticsDatabase.accountantDashboardDao().deleteDashboardData(userId)
            Result.Success(Unit)
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

