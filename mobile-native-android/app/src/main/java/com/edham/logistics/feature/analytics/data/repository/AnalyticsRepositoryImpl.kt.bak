    override suspend fun getAdminDashboardData(userId: String, filters: FilterOptions?): Result<AdminDashboardData> {
        return try {
            // Try local cache first
            val cachedData = analyticsDatabase.adminDashboardDao().getDashboardData(userId)
            if (cachedData != null && !isCacheExpired(cachedData.timestamp)) {
                Result.Success(cachedData.toDomainModel())
            } else {
                // Fetch from API
                val response = analyticsApiService.getAdminDashboardData(userId, filters)
                if (response.isSuccessful) {
                    response.body()?.let { data ->
                        // Cache the data
                        analyticsDatabase.adminDashboardDao().insertDashboardData(data.toEntity(userId))
                        Result.Success(data)
                    } ?: Result.Error(Exception("Empty response"))
                } else {
                    Result.Error(Exception("Failed to fetch admin dashboard data: ${response.code()}"))
                }
            }
        } catch (e: Exception) {
            Result.Error(e)
        }
    }

