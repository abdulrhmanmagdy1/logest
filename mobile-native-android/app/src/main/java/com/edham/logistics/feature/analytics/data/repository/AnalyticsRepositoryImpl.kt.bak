    override suspend fun observeDashboardUpdates(userId: String, userRole: String): Flow<Result<DashboardData>> {
        return flow {
            try {
                // Listen for WebSocket updates
                analyticsWebSocketService.messageFlow.collect { message ->
                    when (message.type) {
                        AnalyticsWebSocketType.DASHBOARD_UPDATED -> {
                            // Refresh dashboard data
                            when (userRole) {
                                "admin" -> {
                                    val result = getAdminDashboardData(userId, null)
                                    if (result is Result.Success) {
                                        emit(Result.Success(DashboardData.AdminData(result.data)))
                                    }
                                }
                                "customer" -> {
                                    val result = getCustomerDashboardData(userId, null)
                                    if (result is Result.Success) {
                                        emit(Result.Success(DashboardData.CustomerData(result.data)))
                                    }
                                }
                                "driver" -> {
                                    val result = getDriverDashboardData(userId, null)
                                    if (result is Result.Success) {
                                        emit(Result.Success(DashboardData.DriverData(result.data)))
                                    }
                                }
                                "accountant" -> {
                                    val result = getAccountantDashboardData(userId, null)
                                    if (result is Result.Success) {
                                        emit(Result.Success(DashboardData.AccountantData(result.data)))
                                    }
                                }
                            }
                        }
                        else -> {}
                    }
                }
            } catch (e: Exception) {
                emit(Result.Error(e))
            }
        }
    }

    override suspend fun observeMetricUpdates(userId: String, userRole: String): Flow<Result<List<MetricCard>>> {
        return flow {
            try {
                // Listen for metric updates
                analyticsWebSocketService.messageFlow.collect { message ->
                    when (message.type) {
                        AnalyticsWebSocketType.METRIC_CHANGED -> {
                            // Fetch updated metrics
                            val metrics = getMetrics(userId, userRole, listOf(
                                MetricType.TOTAL_SHIPMENTS,
                                MetricType.ACTIVE_SHIPMENTS,
                                MetricType.REVENUE,
                                MetricType.PROFIT
                            ))
                            emit(metrics)
                        }
                        else -> {}
                    }
                }
            } catch (e: Exception) {
                emit(Result.Error(e))
            }
        }
    }

