/**
 * Fleet Analytics Fragment - Comprehensive fleet analytics and insights
 * 
 * Features:
 * - Fleet overview statistics
 * - Vehicle utilization metrics
 * - Performance analytics
 * - Cost analysis
 * - Maintenance insights
 * - Interactive charts
 * - Filtering and date ranges
 */
@AndroidEntryPoint
class FleetAnalyticsFragment : Fragment() {
    
    @Inject
    lateinit var analyticsEngineService: AnalyticsEngineService
    
    private val viewModel: FleetAnalyticsViewModel by viewModels()
    
    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View {
        return ComposeView(requireContext()).apply {
            setContent {
                EdhamLogisticsTheme {
                    FleetAnalyticsScreen(
                        viewModel = viewModel,
                        analyticsEngineService = analyticsEngineService
                    )
                }
            }
        }
    }
    
    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        
        // Initialize analytics engine
        lifecycleScope.launch {
            analyticsEngineService.initialize()
        }
        
        // Load fleet analytics
        viewModel.loadFleetAnalytics()
    }
}

@Composable
fun FleetAnalyticsScreen(
    viewModel: FleetAnalyticsViewModel,
    analyticsEngineService: AnalyticsEngineService
) {
    val fleetAnalytics by viewModel.fleetAnalytics.collectAsStateWithLifecycle()
    val isLoading by viewModel.isLoading.collectAsStateWithLifecycle()
    val errorMessage by viewModel.errorMessage.collectAsStateWithLifecycle()
    val selectedTimeRange by viewModel.selectedTimeRange.collectAsStateWithLifecycle()
    
    LaunchedEffect(selectedTimeRange) {
        viewModel.loadFleetAnalytics()
    }
    
    Column(
        modifier = Modifier
            .fillMaxSize()
            .padding(16.dp),
        verticalArrangement = Arrangement.spacedBy(16.dp)
    ) {
        // Header with time range selector
        FleetAnalyticsHeader(
            selectedTimeRange = selectedTimeRange,
            onTimeRangeChanged = viewModel::setTimeRange,
            onRefresh = viewModel::refreshAnalytics,
            isLoading = isLoading
        )
        
        // Error message
        errorMessage?.let { error ->
            Card(
                modifier = Modifier.fillMaxWidth(),
                colors = CardDefaults.cardColors(
                    containerColor = ErrorRed.copy(alpha = 0.1f)
                ),
                elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
            ) {
                Text(
                    text = error,
                    modifier = Modifier.padding(16.dp),
                    color = ErrorRed,
                    style = MaterialTheme.typography.bodyMedium
                )
            }
        }
        
        // Fleet Overview
        fleetAnalytics?.let { analytics ->
            FleetOverviewSection(analytics = analytics)
            
            // Vehicle Utilization
            VehicleUtilizationSection(analytics = analytics)
            
            // Performance Metrics
            PerformanceMetricsSection(analytics = analytics)
            
            // Cost Analysis
            CostAnalysisSection(analytics = analytics)
            
            // Maintenance Insights
            MaintenanceInsightsSection(analytics = analytics)
            
            // Fleet Status Breakdown
            FleetStatusBreakdownSection(analytics = analytics)
        }
        
        // Loading indicator
        if (isLoading) {
            Box(
                modifier = Modifier.fillMaxWidth(),
                contentAlignment = Alignment.Center
            ) {
                CircularProgressIndicator(
                    color = EdhamOrange,
                    strokeWidth = 3.dp
                )
            }
        }
    }
}

@Composable
fun FleetAnalyticsHeader(
    selectedTimeRange: TimeRange,
    onTimeRangeChanged: (TimeRange) -> Unit,
    onRefresh: () -> Unit,
    isLoading: Boolean
) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.surface
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Row(
                modifier = Modifier.fillMaxWidth(),
                horizontalArrangement = Arrangement.SpaceBetween,
                verticalAlignment = Alignment.CenterVertically
            ) {
                Text(
                    text = "Fleet Analytics",
                    style = MaterialTheme.typography.headlineMedium,
                    color = EdhamOrange,
                    fontWeight = FontWeight.Bold
                )
                
                Row {
                    // Time range selector
                    TimeRangeSelector(
                        selectedTimeRange = selectedTimeRange,
                        onTimeRangeChanged = onTimeRangeChanged
                    )
                    
                    Spacer(modifier = Modifier.width(8.dp))
                    
                    // Refresh button
                    IconButton(
                        onClick = onRefresh,
                        enabled = !isLoading
                    ) {
                        Icon(
                            painter = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_rotate),
                            contentDescription = "Refresh",
                            tint = EdhamOrange
                        )
                    }
                }
            }
        }
    }
}

@Composable
fun TimeRangeSelector(
    selectedTimeRange: TimeRange,
    onTimeRangeChanged: (TimeRange) -> Unit
) {
    var expanded by remember { mutableStateOf(false) }
    
    OutlinedButton(
        onClick = { expanded = true },
        colors = ButtonDefaults.outlinedButtonColors(
            contentColor = EdhamOrange,
            borderColor = EdhamOrange
        )
    ) {
        Text(
            text = selectedTimeRange.displayName,
            style = MaterialTheme.typography.bodyMedium,
            fontWeight = FontWeight.Medium
        )
        
        Icon(
            painter = androidx.compose.ui.res.painterResource(id = android.R.drawable.arrow_down_float),
            contentDescription = "Dropdown",
            tint = EdhamOrange
        )
        
        DropdownMenu(
            expanded = expanded,
            onDismissRequest = { expanded = false }
        ) {
            TimeRange.values().forEach { timeRange ->
                DropdownMenuItem(
                    text = {
                        Text(
                            text = timeRange.displayName,
                            color = if (timeRange == selectedTimeRange) EdhamOrange 
                            else MaterialTheme.colorScheme.onSurface
                        )
                    },
                    onClick = {
                        onTimeRangeChanged(timeRange)
                        expanded = false
                    }
                )
            }
        }
    }
}

@Composable
fun FleetOverviewSection(analytics: FleetAnalytics) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.surface
        ),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(
            modifier = Modifier.padding(16.dp)
        ) {
            Text(
                text = "Fleet Overview",
                style = MaterialTheme.typography.titleMedium,
                color = EdhamOrange,
                fontWeight = FontWeight.Bold
            )
            
            Spacer(modifier = Modifier.height(16.dp))
            
            LazyColumn(
                verticalArrangement = Arrangement.spacedBy(12.dp)
            ) {
                item {
                    OverviewMetric(
                        title = "Total Vehicles",
                        value = analytics.totalVehicles.toString(),
                        subtitle = "In fleet",
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_camera),
                        color = IceBlue
                    )
                }
                
                item {
                    OverviewMetric(
                        title = "Active Vehicles",
                        value = analytics.activeVehicles.toString(),
                        subtitle = "Currently operational",
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_play),
                        color = SuccessGreen
                    )
                }
                
                item {
                    OverviewMetric(
                        title = "Fleet Utilization",
                        value = "${String.format("%.1f", analytics.fleetUtilization)}%",
                        subtitle = "Average utilization rate",
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_more),
                        color = EdhamOrange
                    )
                }
                
                item {
                    OverviewMetric(
                        title = "Average Age",
                        value = "${analytics.averageVehicleAge} years",
                        subtitle = "Fleet average",
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_recent_history),
                        color = WarningYellow
                    )
                }
            }
        }
    }
}

@Composable
