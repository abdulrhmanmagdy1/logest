                        color = SuccessGreen
                    )
                }
                
                item {
                    PerformanceMetric(
                        title = "Maintenance Cost/km",
                        value = "SAR ${String.format("%.2f", analytics.maintenanceCostPerKm)}",
                        change = analytics.maintenanceCostChange,
                        icon = androidx.compose.ui.res.painterResource(id = android.R.drawable.ic_menu_info_details),
                        color = WarningYellow
                    )
                }
            }
