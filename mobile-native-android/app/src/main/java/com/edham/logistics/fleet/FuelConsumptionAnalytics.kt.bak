/**
 * Data classes
 */
data class FuelConsumptionReport(
    val dateRange: DateRange,
    val consumptionTrends: ConsumptionTrends,
    val efficiencyMetrics: EfficiencyMetrics,
    val costAnalysis: CostAnalysis,
    val benchmarking: BenchmarkingReport,
    val anomalies: List<ConsumptionAnomaly>,
    val predictiveAnalytics: PredictiveAnalytics,
    val generatedAt: Date
)

data class ConsumptionTrends(
    val dateRange: DateRange,
    val dailyConsumption: Map<String, Float>,
    val weeklyConsumption: Map<String, Float>,
    val monthlyConsumption: Map<String, Float>,
    val trendAnalysis: TrendAnalysis,
    val seasonality: SeasonalityAnalysis,
    val volatility: Float
)

data class VehicleConsumptionTrends(
    val vehicleId: Long,
    val vehicleIdString: String,
    val dateRange: DateRange,
    val dailyConsumption: Map<String, Float>,
    val weeklyConsumption: Map<String, Float>,
    val monthlyConsumption: Map<String, Float>,
    val trendAnalysis: TrendAnalysis,
    val seasonality: SeasonalityAnalysis,
    val efficiency: VehicleEfficiency
)

data class FleetEfficiencyComparison(
    val dateRange: DateRange,
    val fleetAverage: Float,
    val topPerformers: List<VehicleEfficiency>,
    val bottomPerformers: List<VehicleEfficiency>,
    val allVehicles: List<VehicleEfficiency>,
    val efficiencyDistribution: Map<String, Int>,
    val improvementOpportunities: List<ImprovementOpportunity>
)

data class CostOptimizationRecommendation(
    val type: OptimizationType,
    val title: String,
    val description: String,
    val potentialSavings: Float,
    val priority: RecommendationPriority,
    val actions: List<String>
)

data class ConsumptionForecast(
    val forecastPeriod: DateRange,
    val dailyForecast: List<Float>,
    val totalForecastedConsumption: Float,
    val confidence: Float,
    val seasonalAdjustment: Float,
    val modelAccuracy: Float,
    val generatedAt: Date
)

data class EfficiencyMetrics(
    val dateRange: DateRange,
    val fleetAverage: Float,
    val vehicleEfficiencies: List<VehicleEfficiency>,
    val efficiencyByType: Map<VehicleType, Float>,
    val efficiencyTrend: TrendAnalysis,
    val benchmarkComparison: BenchmarkComparison
)

data class CostAnalysis(
    val dateRange: DateRange,
    val totalCost: Float,
    val totalFuel: Float,
    val averagePrice: Float,
    val costByFuelType: Map<FuelType, Float>,
    val costByVehicle: Map<Long, Float>,
    val priceTrend: TrendAnalysis,
    val costProjection: CostProjection
)

data class BenchmarkingReport(
    val efficiencyBenchmark: BenchmarkComparison,
    val costBenchmark: BenchmarkComparison,
    val overallScore: Float,
    val industryAverages: IndustryBenchmarks,
    val recommendations: List<String>
)

data class PredictiveAnalytics(
    val consumptionForecast: ConsumptionPrediction,
    val costForecast: CostPrediction,
    val maintenancePredictions: List<MaintenancePrediction>,
    val riskAssessment: RiskAssessment,
    val confidence: Float,
    val generatedAt: Date
)

data class ConsumptionAnomaly(
    val id: Long,
    val vehicleId: Long,
    val type: AnomalyType,
    val description: String,
    val severity: AnomalySeverity,
    val detectedAt: Date,
    val recommendation: String
)

data class TrendAnalysis(
    val direction: TrendDirection,
    val changePercentage: Float,
    val strength: Float
)

data class SeasonalityAnalysis(
    val hasSeasonality: Boolean,
    val seasonalPattern: Map<String, Float>,
    val peakSeason: String?,
    val offPeakSeason: String?
)

data class BenchmarkComparison(
    val actual: Float,
    val benchmark: Float,
    val performance: PerformanceLevel,
    val percentile: Float
)

data class IndustryBenchmarks(
    val fuelEfficiency: Float,
    val fuelCost: Float,
    val maintenanceInterval: Float,
    val tireLife: Float
)

data class ConsumptionPrediction(
    val nextPeriod: Float,
    val confidence: Float,
    val factors: List<String>
)

data class CostPrediction(
    val nextPeriod: Float,
    val confidence: Float,
    val factors: List<String>
)

data class MaintenancePrediction(
    val vehicleId: Long,
    val predictedMileage: Float,
    val predictedDate: Date,
    val confidence: Float
)

data class RiskAssessment(
    val overallRisk: RiskLevel,
    val riskFactors: List<RiskFactor>,
    val mitigationStrategies: List<String>
)

data class CostProjection(
    val nextMonth: Float,
    val nextQuarter: Float,
    val nextYear: Float,
    val confidence: Float
)

data class ImprovementOpportunity(
    val vehicleId: Long,
    val type: OpportunityType,
    val description: String,
    val potentialSavings: Float,
    val priority: RecommendationPriority
)

/**
 * Enums
 */
enum class AnalyticsState {
    Idle,
    Generating,
    Completed,
    Error
}

enum class TrendDirection {
    INCREASING,
    DECREASING,
    STABLE
}

enum class PerformanceLevel {
    EXCELLENT,
    GOOD,
    AVERAGE,
    BELOW_AVERAGE,
    POOR
}

enum class AnomalyType {
    LOW_EFFICIENCY,
    HIGH_CONSUMPTION,
    ABNORMAL_PATTERN,
    FUEL_THEFT,
    MAINTENANCE_ISSUE
}

enum class AnomalySeverity {
    LOW,
    MEDIUM,
    HIGH,
    CRITICAL
}

enum class OptimizationType {
    FUEL_PRICE_OPTIMIZATION,
    VEHICLE_EFFICIENCY,
    REFUELING_OPTIMIZATION,
    ROUTE_OPTIMIZATION,
    MAINTENANCE_OPTIMIZATION
}

enum class RecommendationPriority {
    LOW,
    MEDIUM,
    HIGH,
    CRITICAL
}

enum class OpportunityType {
    EFFICIENCY_IMPROVEMENT,
    COST_REDUCTION,
    MAINTENANCE_OPTIMIZATION,
    DRIVER_TRAINING
}

enum class RiskLevel {
    LOW,
    MEDIUM,
    HIGH,
    CRITICAL
}

data class RiskFactor(
    val type: String,
    val description: String,
    val impact: String,
    val probability: Float
)
