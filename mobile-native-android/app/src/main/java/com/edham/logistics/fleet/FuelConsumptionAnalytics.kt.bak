    private fun determinePerformance(actual: Float, benchmark: Float): PerformanceLevel {
        val ratio = actual / benchmark
        return when {
            ratio >= 1.1 -> PerformanceLevel.EXCELLENT
            ratio >= 0.95 -> PerformanceLevel.GOOD
            ratio >= 0.85 -> PerformanceLevel.AVERAGE
            ratio >= 0.75 -> PerformanceLevel.BELOW_AVERAGE
            else -> PerformanceLevel.POOR
        }
    }
    
    private fun calculatePercentile(actual: Float, benchmark: Float): Float {
        // Implementation would calculate percentile rank
        return 75f // Placeholder
    }
    
    private fun getIndustryBenchmarks(): IndustryBenchmarks {
        return IndustryBenchmarks(
            fuelEfficiency = 12.0f,
            fuelCost = 1.5f,
            maintenanceInterval = 10000f,
            tireLife = 50000f
        )
    }
    
    private fun generateBenchmarkRecommendations(
        efficiency: BenchmarkComparison,
        cost: BenchmarkComparison
    ): List<String> {
        val recommendations = mutableListOf<String>()
        
        if (efficiency.performance == PerformanceLevel.POOR) {
            recommendations.add("Focus on improving fuel efficiency through driver training and vehicle maintenance")
        }
        
        if (cost.performance == PerformanceLevel.POOR) {
            recommendations.add("Negotiate better fuel prices and optimize purchasing strategy")
        }
        
        return recommendations
    }
    
    private fun detectVehicleAnomalies(
        vehicle: VehicleEntity,
        transactions: List<FuelTransactionEntity>
    ): List<ConsumptionAnomaly> {
        val anomalies = mutableListOf<ConsumptionAnomaly>()
        
        // Check for unusual consumption patterns
        val efficiency = calculateVehicleEfficiency(transactions, vehicle)
        if (efficiency.kmPerLiter < EFFICIENCY_BENCHMARK * 0.7) {
            anomalies.add(ConsumptionAnomaly(
                id = 0,
                vehicleId = vehicle.id,
                type = AnomalyType.LOW_EFFICIENCY,
                description = "Vehicle efficiency is 30% below benchmark",
                severity = AnomalySeverity.HIGH,
                detectedAt = Date(),
                recommendation = "Schedule maintenance check and review driving habits"
            ))
        }
        
        return anomalies
    }
    
