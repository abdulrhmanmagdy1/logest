package com.edham.logistics.feature.driver.presentation.ui

import androidx.lifecycle.viewModelScope
import com.edham.logistics.core.utils.Result
import com.edham.logistics.feature.driver.domain.usecase.*
import com.edham.logistics.feature.driver.domain.model.*
import com.edham.logistics.presentation.ui.base.BaseViewModel
import dagger.hilt.android.lifecycle.HiltViewModel
import kotlinx.coroutines.flow.MutableStateFlow
import kotlinx.coroutines.flow.StateFlow
import kotlinx.coroutines.flow.asStateFlow
import kotlinx.coroutines.launch
import javax.inject.Inject

@HiltViewModel
class DriverDashboardViewModel @Inject constructor(
    private val getDriverDashboardUseCase: GetDriverDashboardUseCase,
    private val acceptTripUseCase: AcceptTripUseCase,
    private val rejectTripUseCase: RejectTripUseCase,
    private val startTripUseCase: StartTripUseCase,
    private val updateTripStatusUseCase: UpdateTripStatusUseCase,
    private val uploadDeliveryProofUseCase: UploadDeliveryProofUseCase
) : BaseViewModel<DriverDashboardViewModel.DriverDashboardUiState>() {

    private val _uiState = MutableStateFlow(DriverDashboardUiState())
    val uiState: StateFlow<DriverDashboardUiState> = _uiState.asStateFlow()

    override fun createInitialState(): DriverDashboardUiState = DriverDashboardUiState()

    private var driverId: String = ""

    fun initialize(driverId: String) {
        this.driverId = driverId
        loadDashboard()
    }

    fun loadDashboard() {
        if (driverId.isBlank()) return
        
        viewModelScope.launch {
            getDriverDashboardUseCase(driverId).collect { result ->
                when (result) {
                    is Result.Loading -> {
                        updateUiState { copy(isLoading = true, error = null) }
                    }
                    is Result.Success -> {
                        updateUiState {
                            copy(
                                isLoading = false,
                                dashboardData = result.data,
                                error = null
                            )
                        }
                    }
                    is Result.Error -> {
                        updateUiState {
                            copy(
                                isLoading = false,
                                error = result.exception.message ?: "فشل تحميل لوحة التحكم"
                            )
                        }
                    }
                }
            }
        }
    }

    fun acceptTrip(tripId: String, notes: String? = null) {
        viewModelScope.launch {
            when (val result = acceptTripUseCase(tripId, notes)) {
                is Result.Success -> {
                    updateUiState { copy(
                        actionSuccess = "تم قبول الرحلة بنجاح",
                        error = null
                    )}
                    loadDashboard() // Refresh data
                }
                is Result.Error -> {
                    updateUiState { copy(error = result.exception.message ?: "فشل قبول الرحلة") }
                }
                is Result.Loading -> {
                    updateUiState { copy(isLoading = true) }
                }
            }
        }
    }

    fun rejectTrip(tripId: String, notes: String? = null) {
        viewModelScope.launch {
            when (val result = rejectTripUseCase(tripId, notes)) {
                is Result.Success -> {
                    updateUiState { copy(
                        actionSuccess = "تم رفض الرحلة",
                        error = null
                    )}
                    loadDashboard() // Refresh data
                }
                is Result.Error -> {
                    updateUiState { copy(error = result.exception.message ?: "فشل رفض الرحلة") }
                }
                is Result.Loading -> {
                    updateUiState { copy(isLoading = true) }
                }
            }
        }
    }

    fun startTrip(tripId: String, notes: String? = null) {
        viewModelScope.launch {
            when (val result = startTripUseCase(tripId, notes)) {
                is Result.Success -> {
                    updateUiState { copy(
                        actionSuccess = "تم بدء الرحلة بنجاح",
                        error = null
                    )}
                    loadDashboard() // Refresh data
                }
                is Result.Error -> {
                    updateUiState { copy(error = result.exception.message ?: "فشل بدء الرحلة") }
                }
                is Result.Loading -> {
                    updateUiState { copy(isLoading = true) }
                }
            }
        }
    }

    fun updateTripStatus(
        tripId: String,
        status: TripStatus,
        location: LocationPoint? = null,
        notes: String? = null
    ) {
        viewModelScope.launch {
            when (val result = updateTripStatusUseCase(tripId, status, location, notes)) {
                is Result.Success -> {
                    updateUiState { copy(
                        actionSuccess = "تم تحديث حالة الرحلة",
                        error = null
                    )}
                    loadDashboard() // Refresh data
                }
                is Result.Error -> {
                    updateUiState { copy(error = result.exception.message ?: "فشل تحديث الحالة") }
                }
                is Result.Loading -> {
                    updateUiState { copy(isLoading = true) }
                }
            }
        }
    }

    fun uploadDeliveryProof(
        tripId: String,
        photoBase64: String? = null,
        signatureBase64: String? = null,
        recipientName: String,
        recipientPhone: String,
        notes: String? = null,
        location: LocationPoint
    ) {
        viewModelScope.launch {
            when (val result = uploadDeliveryProofUseCase(
                tripId, photoBase64, signatureBase64, recipientName, recipientPhone, notes, location
            )) {
                is Result.Success -> {
                    updateUiState { copy(
                        actionSuccess = "تم رفع دليل التسليم بنجاح",
                        error = null
                    )}
                    loadDashboard() // Refresh data
                }
                is Result.Error -> {
                    updateUiState { copy(error = result.exception.message ?: "فشل رفع دليل التسليم") }
                }
                is Result.Loading -> {
                    updateUiState { copy(isLoading = true) }
                }
            }
        }
    }

    fun clearError() {
        updateUiState { copy(error = null) }
    }

    fun clearSuccess() {
        updateUiState { copy(actionSuccess = null) }
    }

    fun refresh() {
        loadDashboard()
    }

    data class DriverDashboardUiState(
        val isLoading: Boolean = false,
        val dashboardData: DriverDashboardData? = null,
        val error: String? = null,
        val actionSuccess: String? = null
    ) : com.edham.logistics.presentation.ui.base.UiState {
        override fun copyLoading(isLoading: Boolean): UiState = copy(isLoading = isLoading)
        override fun copyError(error: String?): UiState = copy(error = error)
        override fun copySuccess(message: String?): UiState = copy(actionSuccess = message)
    }
}
