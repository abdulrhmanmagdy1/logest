<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ============================================ -->
    <!-- 🎨 Edham Logistics Design System - Themes -->
    <!-- ============================================ -->
    
    <!-- Base Application Theme -->
    <style name="Theme.Edham" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary Colors -->
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/brand_on_primary</item>
        <item name="colorPrimaryContainer">@color/brand_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/brand_on_primary_container</item>
        
        <!-- Secondary Colors -->
        <item name="colorSecondary">@color/brand_secondary</item>
        <item name="colorOnSecondary">@color/brand_on_secondary</item>
        <item name="colorSecondaryContainer">@color/brand_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/brand_on_secondary_container</item>
        
        <!-- Tertiary Colors -->
        <item name="colorTertiary">@color/brand_tertiary</item>
        <item name="colorOnTertiary">@color/brand_on_tertiary</item>
        <item name="colorTertiaryContainer">@color/brand_tertiary_container</item>
        <item name="colorOnTertiaryContainer">@color/brand_on_tertiary_container</item>
        
        <!-- Surface Colors -->
        <item name="android:colorBackground">@color/surface_0</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorSurface">@color/surface_0</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/surface_100</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        
        <!-- Status Colors -->
        <item name="colorError">@color/status_error</item>
        <item name="colorOnError">@color/text_inverse</item>
        <item name="colorErrorContainer">@color/error_container</item>
        <item name="colorOnErrorContainer">@color/error_on_container</item>
        
        <!-- Typography -->
        <item name="android:textAppearance">@style/TextAppearance.Edham.BodyMedium</item>
        <item name="textAppearanceHeadline1">@style/TextAppearance.Edham.DisplayLarge</item>
        <item name="textAppearanceHeadline2">@style/TextAppearance.Edham.DisplayMedium</item>
        <item name="textAppearanceHeadline3">@style/TextAppearance.Edham.DisplaySmall</item>
        <item name="textAppearanceHeadline4">@style/TextAppearance.Edham.HeadlineLarge</item>
        <item name="textAppearanceHeadline5">@style/TextAppearance.Edham.HeadlineMedium</item>
        <item name="textAppearanceHeadline6">@style/TextAppearance.Edham.HeadlineSmall</item>
        <item name="textAppearanceSubtitle1">@style/TextAppearance.Edham.TitleLarge</item>
        <item name="textAppearanceSubtitle2">@style/TextAppearance.Edham.TitleMedium</item>
        <item name="textAppearanceBody1">@style/TextAppearance.Edham.BodyLarge</item>
        <item name="textAppearanceBody2">@style/TextAppearance.Edham.BodyMedium</item>
        <item name="textAppearanceCaption">@style/TextAppearance.Edham.BodySmall</item>
        <item name="textAppearanceButton">@style/TextAppearance.Edham.LabelLarge</item>
        <item name="textAppearanceOverline">@style/TextAppearance.Edham.LabelSmall</item>
        
        <!-- Component Styles -->
        <item name="materialButtonStyle">@style/Widget.Edham.Button</item>
        <item name="materialButtonOutlinedStyle">@style/Widget.Edham.Button.Outlined</item>
        <item name="floatingActionButtonStyle">@style/Widget.Edham.FloatingActionButton</item>
        <item name="textInputStyle">@style/Widget.Edham.TextInputLayout</item>
        <item name="chipStyle">@style/Widget.Edham.Chip</item>
        <item name="badgeStyle">@style/Widget.Edham.Badge</item>
        <item name="bottomNavigationStyle">@style/Widget.Edham.BottomNavigationView</item>
        <item name="toolbarStyle">@style/Widget.Edham.Toolbar</item>
        <item name="tabStyle">@style/Widget.Edham.TabLayout</item>
        <item name="switchStyle">@style/Widget.Edham.Switch</item>
        <item name="checkboxStyle">@style/Widget.Edham.CheckBox</item>
        <item name="radioButtonStyle">@style/Widget.Edham.RadioButton</item>
        <item name="sliderStyle">@style/Widget.Edham.Slider</item>
        <item name="cardViewStyle">@style/Widget.Edham.Card</item>
        <item name="materialCardViewStyle">@style/Widget.Edham.MaterialCard</item>
        <item name="snackbarStyle">@style/Widget.Edham.Snackbar</item>
        <item name="snackbarButtonStyle">@style/Widget.Edham.Button.TextButton.Snackbar</item>
        
        <!-- System UI -->
        <item name="android:statusBarColor">@color/surface_0</item>
        <item name="android:navigationBarColor">@color/surface_0</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        
        <!-- RTL Support -->
        <item name="android:layoutDirection">locale</item>
        <item name="android:textDirection">locale</item>
        
        <!-- Window Flags -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
    </style>
    
    <!-- Light Theme Variant -->
    <style name="Theme.Edham.Light" parent="Theme.Edham">
        <item name="android:statusBarColor">@color/surface_0</item>
        <item name="android:navigationBarColor">@color/surface_0</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>
    
    <!-- Dark Theme Variant -->
    <style name="Theme.Edham.Dark" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary Colors -->
        <item name="colorPrimary">@color/brand_primary_dark_theme</item>
        <item name="colorOnPrimary">@color/brand_on_primary_dark_theme</item>
        <item name="colorPrimaryContainer">@color/brand_primary_container_dark_theme</item>
        <item name="colorOnPrimaryContainer">@color/brand_on_primary_container_dark_theme</item>
        
        <!-- Secondary Colors -->
        <item name="colorSecondary">@color/brand_secondary_dark_theme</item>
        <item name="colorOnSecondary">@color/brand_on_secondary_dark_theme</item>
        <item name="colorSecondaryContainer">@color/brand_secondary_container_dark_theme</item>
        <item name="colorOnSecondaryContainer">@color/brand_on_secondary_container_dark_theme</item>
        
        <!-- Tertiary Colors -->
        <item name="colorTertiary">@color/brand_tertiary_dark_theme</item>
        <item name="colorOnTertiary">@color/brand_on_tertiary_dark_theme</item>
        <item name="colorTertiaryContainer">@color/brand_tertiary_container_dark_theme</item>
        <item name="colorOnTertiaryContainer">@color/brand_on_tertiary_container_dark_theme</item>
        
        <!-- Surface Colors -->
        <item name="android:colorBackground">@color/surface_0_dark</item>
        <item name="colorOnBackground">@color/text_primary_dark</item>
        <item name="colorSurface">@color/surface_0_dark</item>
        <item name="colorOnSurface">@color/text_primary_dark</item>
        <item name="colorSurfaceVariant">@color/surface_100_dark</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary_dark</item>
        
        <!-- Status Colors -->
        <item name="colorError">@color/status_error_dark</item>
        <item name="colorOnError">@color/text_inverse</item>
        <item name="colorErrorContainer">@color/error_container_dark</item>
        <item name="colorOnErrorContainer">@color/error_on_container_dark</item>
        
        <!-- Typography -->
        <item name="android:textAppearance">@style/TextAppearance.Edham.BodyMedium.Dark</item>
        <item name="textAppearanceHeadline1">@style/TextAppearance.Edham.DisplayLarge.Dark</item>
        <item name="textAppearanceHeadline2">@style/TextAppearance.Edham.DisplayMedium.Dark</item>
        <item name="textAppearanceHeadline3">@style/TextAppearance.Edham.DisplaySmall.Dark</item>
        <item name="textAppearanceHeadline4">@style/TextAppearance.Edham.HeadlineLarge.Dark</item>
        <item name="textAppearanceHeadline5">@style/TextAppearance.Edham.HeadlineMedium.Dark</item>
        <item name="textAppearanceHeadline6">@style/TextAppearance.Edham.HeadlineSmall.Dark</item>
        <item name="textAppearanceSubtitle1">@style/TextAppearance.Edham.TitleLarge</item>
        <item name="textAppearanceSubtitle2">@style/TextAppearance.Edham.TitleMedium</item>
        <item name="textAppearanceBody1">@style/TextAppearance.Edham.BodyLarge</item>
        <item name="textAppearanceBody2">@style/TextAppearance.Edham.BodyMedium.Dark</item>
        <item name="textAppearanceCaption">@style/TextAppearance.Edham.BodySmall</item>
        <item name="textAppearanceButton">@style/TextAppearance.Edham.LabelLarge</item>
        <item name="textAppearanceOverline">@style/TextAppearance.Edham.LabelSmall</item>
        
        <!-- Component Styles -->
        <item name="materialButtonStyle">@style/Widget.Edham.Button</item>
        <item name="materialButtonOutlinedStyle">@style/Widget.Edham.Button.Outlined</item>
        <item name="floatingActionButtonStyle">@style/Widget.Edham.FloatingActionButton</item>
        <item name="textInputStyle">@style/Widget.Edham.TextInputLayout</item>
        <item name="chipStyle">@style/Widget.Edham.Chip</item>
        <item name="badgeStyle">@style/Widget.Edham.Badge</item>
        <item name="bottomNavigationStyle">@style/Widget.Edham.BottomNavigationView</item>
        <item name="toolbarStyle">@style/Widget.Edham.Toolbar</item>
        <item name="tabStyle">@style/Widget.Edham.TabLayout</item>
        <item name="switchStyle">@style/Widget.Edham.Switch</item>
        <item name="checkboxStyle">@style/Widget.Edham.CheckBox</item>
        <item name="radioButtonStyle">@style/Widget.Edham.RadioButton</item>
        <item name="sliderStyle">@style/Widget.Edham.Slider</item>
        <item name="cardViewStyle">@style/Widget.Edham.Card</item>
        <item name="materialCardViewStyle">@style/Widget.Edham.MaterialCard</item>
        <item name="snackbarStyle">@style/Widget.Edham.Snackbar</item>
        <item name="snackbarButtonStyle">@style/Widget.Edham.Button.TextButton.Snackbar</item>
        
        <!-- System UI -->
        <item name="android:statusBarColor">@color/surface_0_dark</item>
        <item name="android:navigationBarColor">@color/surface_0_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        
        <!-- RTL Support -->
        <item name="android:layoutDirection">locale</item>
        <item name="android:textDirection">locale</item>
        
        <!-- Window Flags -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
    </style>
    
    <!-- Arabic RTL Theme -->
    <style name="Theme.Edham.Arabic" parent="Theme.Edham">
        <!-- RTL Typography -->
        <item name="android:textAppearance">@style/TextAppearance.Edham.Arabic.BodyMedium</item>
        <item name="textAppearanceHeadline1">@style/TextAppearance.Edham.Arabic.DisplayLarge</item>
        <item name="textAppearanceHeadline2">@style/TextAppearance.Edham.Arabic.DisplayMedium</item>
        <item name="textAppearanceHeadline3">@style/TextAppearance.Edham.Arabic.DisplaySmall</item>
        <item name="textAppearanceHeadline4">@style/TextAppearance.Edham.Arabic.HeadlineLarge</item>
        <item name="textAppearanceHeadline5">@style/TextAppearance.Edham.Arabic.HeadlineMedium</item>
        <item name="textAppearanceHeadline6">@style/TextAppearance.Edham.Arabic.HeadlineSmall</item>
        <item name="textAppearanceSubtitle1">@style/TextAppearance.Edham.Arabic.TitleLarge</item>
        <item name="textAppearanceSubtitle2">@style/TextAppearance.Edham.Arabic.TitleMedium</item>
        <item name="textAppearanceBody1">@style/TextAppearance.Edham.Arabic.BodyLarge</item>
        <item name="textAppearanceBody2">@style/TextAppearance.Edham.Arabic.BodyMedium</item>
        <item name="textAppearanceCaption">@style/TextAppearance.Edham.Arabic.BodySmall</item>
        <item name="textAppearanceButton">@style/TextAppearance.Edham.Arabic.LabelLarge</item>
        <item name="textAppearanceOverline">@style/TextAppearance.Edham.Arabic.LabelSmall</item>
        
        <!-- RTL Direction -->
        <item name="android:layoutDirection">rtl</item>
        <item name="android:textDirection">rtl</item>
        
        <!-- RTL Component Adjustments -->
        <item name="materialButtonStyle">@style/Widget.Edham.Button</item>
        <item name="textInputStyle">@style/Widget.Edham.TextInputLayout</item>
        <item name="bottomNavigationStyle">@style/Widget.Edham.BottomNavigationView</item>
        <item name="toolbarStyle">@style/Widget.Edham.Toolbar</item>
        <item name="tabStyle">@style/Widget.Edham.TabLayout</item>
    </style>
    
    <!-- Arabic Dark Theme -->
    <style name="Theme.Edham.Arabic.Dark" parent="Theme.Edham.Dark">
        <!-- RTL Typography Dark -->
        <item name="android:textAppearance">@style/TextAppearance.Edham.Arabic.BodyMedium.Dark</item>
        <item name="textAppearanceHeadline1">@style/TextAppearance.Edham.Arabic.DisplayLarge.Dark</item>
        <item name="textAppearanceHeadline2">@style/TextAppearance.Edham.Arabic.DisplayMedium.Dark</item>
        <item name="textAppearanceHeadline3">@style/TextAppearance.Edham.Arabic.DisplaySmall.Dark</item>
        <item name="textAppearanceHeadline4">@style/TextAppearance.Edham.Arabic.HeadlineLarge.Dark</item>
        <item name="textAppearanceHeadline5">@style/TextAppearance.Edham.Arabic.HeadlineMedium.Dark</item>
        <item name="textAppearanceHeadline6">@style/TextAppearance.Edham.Arabic.HeadlineSmall.Dark</item>
        <item name="textAppearanceSubtitle1">@style/TextAppearance.Edham.Arabic.TitleLarge</item>
        <item name="textAppearanceSubtitle2">@style/TextAppearance.Edham.Arabic.TitleMedium</item>
        <item name="textAppearanceBody1">@style/TextAppearance.Edham.Arabic.BodyLarge</item>
        <item name="textAppearanceBody2">@style/TextAppearance.Edham.Arabic.BodyMedium.Dark</item>
        <item name="textAppearanceCaption">@style/TextAppearance.Edham.Arabic.BodySmall</item>
        <item name="textAppearanceButton">@style/TextAppearance.Edham.Arabic.LabelLarge</item>
        <item name="textAppearanceOverline">@style/TextAppearance.Edham.Arabic.LabelSmall</item>
        
        <!-- RTL Direction Dark -->
        <item name="android:layoutDirection">rtl</item>
        <item name="android:textDirection">rtl</item>
    </style>
    
    <!-- Splash Screen Theme -->
    <style name="Theme.Edham.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/brand_primary</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/edham_logo</item>
        <item name="windowSplashScreenAnimationDuration">1000</item>
        <item name="postSplashScreenTheme">@style/Theme.Edham</item>
    </style>
    
    <!-- NoActionBar Theme for Fullscreen -->
    <style name="Theme.Edham.NoActionBar" parent="Theme.Edham">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Login Theme — dark navy status bar to match login background -->
    <style name="Theme.Edham.Login" parent="Theme.Edham.NoActionBar">
        <item name="android:statusBarColor">@color/navy_950</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Fullscreen Theme -->
    <style name="Theme.Edham.Fullscreen" parent="Theme.Edham.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
    </style>
    
    <!-- Transparent Theme -->
    <style name="Theme.Edham.Transparent" parent="Theme.Edham.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>
    
    <!-- Dialog Theme -->
    <style name="Theme.Edham.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="alertDialogTheme">@style/ThemeOverlay.Edham.MaterialAlertDialog</item>
    </style>
    
    <style name="ThemeOverlay.Edham.MaterialAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="alertDialogStyle">@style/MaterialAlertDialog.Edham</item>
        <item name="materialAlertDialogTitlePanelStyle">@style/MaterialAlertDialog.Edham.Title.Panel</item>
        <item name="materialAlertDialogTitleTextStyle">@style/TextAppearance.Edham.HeadlineSmall</item>
        <item name="materialAlertDialogBodyTextStyle">@style/TextAppearance.Edham.BodyMedium</item>
    </style>
    
    <!-- Bottom Sheet Theme -->
    <style name="Theme.Edham.BottomSheetDialog" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.Edham.BottomSheet</item>
    </style>
    
    <!-- Collapsing Toolbar Theme -->
    <style name="Theme.Edham.CollapsingToolbar" parent="Theme.Edham">
        <item name="collapsingToolbarLayoutLargeStyle">@style/Widget.Edham.CollapsingToolbar</item>
    </style>
    
    <!-- Search View Theme -->
    <style name="Theme.Edham.SearchView" parent="Theme.Edham">
        <item name="searchViewStyle">@style/Widget.Edham.SearchView</item>
    </style>
    
</resources>
