<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ============================================ -->
    <!-- 🧩 Edham Logistics Design System - Components -->
    <!-- ============================================ -->
    
    <!-- Base Component Styles -->
    
    <style name="Widget.Edham" parent="@android:style/Widget" />

    <!-- Card Components -->
    <style name="Widget.Edham.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/spacing_md</item>
        <item name="cardElevation">@dimen/spacing_sm</item>
        <item name="cardUseCompatPadding">true</item>
        <item name="android:layout_margin">@dimen/spacing_card_margin</item>
        <item name="strokeWidth">0dp</item>
        <item name="strokeColor">@color/border_default</item>
    </style>
    
    <style name="Widget.Edham.Card.Surface">
        <item name="cardBackgroundColor">@color/surface_0</item>
        <item name="cardElevation">@dimen/spacing_xs</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/border_default</item>
    </style>
    
    <style name="Widget.Edham.Card.Primary">
        <item name="cardBackgroundColor">@color/brand_primary_container</item>
        <item name="cardElevation">@dimen/spacing_md</item>
        <item name="strokeWidth">0dp</item>
    </style>
    
    <style name="Widget.Edham.Card.Glassmorphism">
        <item name="cardBackgroundColor">@color/glassmorphism_overlay</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/glassmorphism_border</item>
    </style>

    <style name="Widget.Edham.Card.Elevated" parent="Widget.Edham.Card">
        <item name="cardElevation">@dimen/elevation_level_3</item>
    </style>

    <style name="Widget.Edham.Card.Alert" parent="Widget.Edham.Card">
        <item name="cardBackgroundColor">@color/color_error_100</item>
        <item name="strokeColor">@color/status_error</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.Edham.Card.Status" parent="Widget.Edham.Card">
        <item name="cardBackgroundColor">@color/surface_100</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/border_default</item>
    </style>
    
    <!-- Button Components -->
    <style name="Widget.Edham.Button.FAB" parent="Widget.Material3.FloatingActionButton.Primary" />

    <style name="Widget.Edham.Button.FAB.Mini" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="fabSize">mini</item>
    </style>

    <style name="Widget.Edham.Button.Icon" parent="Widget.Material3.Button.IconButton">
        <item name="iconTint">@color/brand_primary</item>
    </style>

    <style name="Widget.Edham.Button" parent="Widget.Material3.Button">
        <item name="android:textAppearance">@style/TextAppearance.Edham.LabelLarge</item>
        <item name="android:textColor">@color/brand_on_primary</item>
        <item name="android:paddingHorizontal">@dimen/spacing_button_padding_horizontal</item>
        <item name="android:paddingVertical">@dimen/spacing_button_padding_vertical</item>
        <item name="android:layout_margin">@dimen/spacing_button_margin</item>
        <item name="cornerRadius">@dimen/spacing_md</item>
        <item name="android:minHeight">@dimen/spacing_touch_target_min</item>
        <item name="backgroundTint">@color/brand_primary</item>
    </style>
    
    <style name="Widget.Edham.Button.Primary">
        <item name="backgroundTint">@color/brand_primary</item>
        <item name="android:textColor">@color/brand_on_primary</item>
        <item name="rippleColor">@color/interactive_pressed</item>
    </style>
    
    <style name="Widget.Edham.Button.Secondary">
        <item name="backgroundTint">@color/brand_secondary</item>
        <item name="android:textColor">@color/brand_on_secondary</item>
        <item name="rippleColor">@color/brand_secondary_dark</item>
    </style>
    
    <style name="Widget.Edham.Button.Outlined">
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="android:textColor">@color/brand_primary</item>
        <item name="strokeColor">@color/brand_primary</item>
        <item name="strokeWidth">2dp</item>
        <item name="rippleColor">@color/brand_primary_container</item>
    </style>

    <style name="Widget.Edham.Button.OutlinedButton" parent="Widget.Edham.Button.Outlined" />
    
    <style name="Widget.Edham.Button.Text">
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="android:textColor">@color/brand_primary</item>
        <item name="strokeWidth">0dp</item>
        <item name="rippleColor">@color/brand_primary_container</item>
    </style>

    <style name="Widget.Edham.Button.TextButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/brand_primary</item>
    </style>
    
    <style name="Widget.Edham.Button.Danger">
        <item name="backgroundTint">@color/status_error</item>
        <item name="android:textColor">@color/text_inverse</item>
        <item name="rippleColor">@color/status_error</item>
    </style>
    
    <!-- Floating Action Button -->
    <style name="Widget.Edham.FloatingActionButton" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/brand_primary</item>
        <item name="tint">@color/brand_on_primary</item>
        <item name="android:layout_margin">@dimen/spacing_fab_margin</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Edham.SmallComponent</item>
    </style>
    
    <!-- Input Field Components -->
    <style name="Widget.Edham.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/brand_primary</item>
        <item name="boxStrokeWidth">2dp</item>
        <item name="boxCornerRadiusTopStart">@dimen/spacing_md</item>
        <item name="boxCornerRadiusTopEnd">@dimen/spacing_md</item>
        <item name="boxCornerRadiusBottomStart">@dimen/spacing_md</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/spacing_md</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="errorTextColor">@color/status_error</item>
        <item name="errorIconTint">@color/status_error</item>
        <item name="boxStrokeErrorColor">@color/status_error</item>
        <item name="boxBackgroundColor">@color/surface_0</item>
        <item name="android:layout_margin">@dimen/spacing_input_margin</item>
    </style>
    
    <style name="Widget.Edham.TextInputLayout.Email" parent="Widget.Edham.TextInputLayout" />

    <style name="Widget.Edham.TextInputLayout.OutlinedBox" parent="Widget.Edham.TextInputLayout" />

    <style name="Widget.Edham.TextInputLayout.Password" parent="Widget.Edham.TextInputLayout" />

    <style name="Widget.Edham.TextInputLayout.Phone" parent="Widget.Edham.TextInputLayout" />

    <style name="Widget.Edham.TextInputLayout.Filled">
        <item name="boxBackgroundColor">@color/surface_100</item>
        <item name="boxStrokeWidth">0dp</item>
    </style>
    
    <!-- Chip Components -->
    <style name="Widget.Edham.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/brand_primary_container</item>
        <item name="android:textColor">@color/brand_on_primary_container</item>
        <item name="chipStrokeColor">@color/brand_primary</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipCornerRadius">@dimen/spacing_xxxl</item>
        <item name="android:textAppearance">@style/TextAppearance.Edham.LabelMedium</item>
    </style>
    
    <style name="Widget.Edham.Chip.Status">
        <item name="chipBackgroundColor">@color/success_container</item>
        <item name="android:textColor">@color/success_on_container</item>
        <item name="chipStrokeColor">@color/status_success</item>
    </style>
    
    <style name="Widget.Edham.Chip.Error">
        <item name="chipBackgroundColor">@color/error_container</item>
        <item name="android:textColor">@color/error_on_container</item>
        <item name="chipStrokeColor">@color/status_error</item>
    </style>
    
    <!-- Badge Components -->
    <style name="Widget.Edham.Badge" parent="Widget.Material3.Badge">
        <item name="backgroundColor">@color/brand_primary</item>
        <item name="android:textColor">@color/brand_on_primary</item>
        <item name="android:textAppearance">@style/TextAppearance.Edham.LabelSmall</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Edham.SmallComponent</item>
    </style>
    
    <style name="Widget.Edham.Badge.Notification">
        <item name="backgroundColor">@color/status_error</item>
        <item name="android:textColor">@color/text_inverse</item>
    </style>
    
    <!-- Progress Indicator Components -->
    <style name="Widget.Edham.LinearProgressIndicator" parent="Widget.Material3.LinearProgressIndicator">
        <item name="trackColor">@color/surface_200</item>
        <item name="trackThickness">@dimen/spacing_progress_track_height</item>
        <item name="trackCornerRadius">@dimen/spacing_progress_track_height</item>
        <item name="indicatorColor">@color/brand_primary</item>
        <item name="android:layout_margin">@dimen/spacing_progress_margin</item>
    </style>
    
    <style name="Widget.Edham.CircularProgressIndicator" parent="Widget.Material3.CircularProgressIndicator">
        <item name="indicatorColor">@color/brand_primary</item>
        <item name="trackColor">@color/surface_200</item>
        <item name="indicatorSize">@dimen/spacing_huge</item>
    </style>
    
    <!-- Bottom Navigation -->
    <style name="Widget.Edham.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/surface_0</item>
        <item name="itemTextColor">@color/bottom_nav_item_text</item>
        <item name="itemIconTint">@color/bottom_nav_item_icon</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="android:textAppearance">@style/TextAppearance.Edham.LabelSmall</item>
        <item name="elevation">@dimen/spacing_md</item>
    </style>
    
    <!-- Toolbar Components -->
    <style name="Widget.Edham.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/surface_0</item>
        <item name="titleTextColor">@color/text_primary</item>
        <item name="subtitleTextColor">@color/text_secondary</item>
        <item name="android:elevation">@dimen/spacing_md</item>
        <item name="titleTextAppearance">@style/TextAppearance.Edham.TitleMedium</item>
        <item name="subtitleTextAppearance">@style/TextAppearance.Edham.BodySmall</item>
    </style>
    
    <style name="Widget.Edham.Toolbar.Primary">
        <item name="android:background">@color/brand_primary</item>
        <item name="titleTextColor">@color/brand_on_primary</item>
        <item name="subtitleTextColor">@color/brand_on_primary</item>
        <item name="navigationIconTint">@color/brand_on_primary</item>
        <item name="actionMenuTextColor">@color/brand_on_primary</item>
    </style>
    
    <!-- AppBar Layout -->
    <style name="Widget.Edham.AppBarLayout" parent="Widget.Material3.AppBarLayout">
        <item name="android:background">@color/surface_0</item>
        <item name="android:elevation">@dimen/spacing_md</item>
        <item name="liftOnScroll">true</item>
    </style>
    
    <!-- Collapsing Toolbar -->
    <style name="Widget.Edham.CollapsingToolbar" parent="Widget.Material3.CollapsingToolbar">
        <item name="expandedTitleTextAppearance">@style/TextAppearance.Edham.HeadlineMedium</item>
        <item name="collapsedTitleTextAppearance">@style/TextAppearance.Edham.TitleLarge</item>
        <item name="expandedTitleTextColor">@color/text_primary</item>
        <item name="collapsedTitleTextColor">@color/text_primary</item>
        <item name="contentScrim">@color/surface_0</item>
        <item name="statusBarScrim">@color/surface_0</item>
    </style>
    
    <!-- Tab Layout -->
    <style name="Widget.Edham.TabLayout" parent="Widget.Material3.TabLayout">
        <item name="android:background">@color/surface_0</item>
        <item name="tabTextColor">@color/text_secondary</item>
        <item name="tabSelectedTextColor">@color/brand_primary</item>
        <item name="tabIndicatorColor">@color/brand_primary</item>
        <item name="tabIndicatorHeight">2dp</item>
        <item name="tabTextAppearance">@style/TextAppearance.Edham.LabelMedium</item>
        <item name="tabRippleColor">@color/brand_primary_container</item>
    </style>
    
    <!-- Divider Components -->
    <style name="Widget.Edham.Divider" parent="Widget.MaterialComponents.MaterialDivider">
        <item name="android:background">@color/border_default</item>
        <item name="android:layout_height">@dimen/spacing_border_divider_height</item>
        <item name="android:layout_marginHorizontal">@dimen/spacing_divider_margin_horizontal</item>
        <item name="android:layout_marginVertical">@dimen/spacing_divider_margin_vertical</item>
    </style>
    
    <!-- Switch Components -->
    <style name="Widget.Edham.Switch" parent="Widget.MaterialComponents.CompoundButton.Switch">
        <item name="trackColor">@color/surface_300</item>
        <item name="thumbColor">@color/surface_0</item>
        <item name="trackTint">@color/surface_300</item>
        <item name="thumbTint">@color/surface_0</item>
        <item name="android:thumbTint">@color/surface_0</item>
        <item name="android:trackTint">@color/surface_300</item>
    </style>
    
    <style name="Widget.Edham.Switch.Primary">
        <item name="trackTint">@color/brand_primary_container</item>
        <item name="thumbTint">@color/brand_primary</item>
        <item name="android:thumbTint">@color/brand_primary</item>
        <item name="android:trackTint">@color/brand_primary_container</item>
    </style>
    
    <!-- Checkbox Components -->
    <style name="Widget.Edham.CheckBox" parent="Widget.Material3.CompoundButton.CheckBox">
        <item name="buttonTint">@color/brand_primary</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textAppearance">@style/TextAppearance.Edham.BodyMedium</item>
    </style>
    
    <!-- Radio Button Components -->
    <style name="Widget.Edham.RadioButton" parent="Widget.Material3.CompoundButton.RadioButton">
        <item name="buttonTint">@color/brand_primary</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textAppearance">@style/TextAppearance.Edham.BodyMedium</item>
    </style>
    
    <!-- Slider Components -->
    <style name="Widget.Edham.Slider" parent="Widget.Material3.Slider">
        <item name="trackColorActive">@color/brand_primary</item>
        <item name="trackColorInactive">@color/surface_300</item>
        <item name="thumbColor">@color/brand_primary</item>
        <item name="haloColor">@color/brand_primary_container</item>
    </style>
    
    <!-- Search View Components -->
    <style name="Widget.Edham.SearchView" parent="Widget.AppCompat.SearchView">
        <item name="queryBackground">@drawable/shape_search_background</item>
        <item name="searchIcon">@drawable/ic_search</item>
        <item name="closeIcon">@drawable/ic_close</item>
        <item name="queryHint">ابحث...</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
    </style>
    
    <!-- Material Card Components -->
    <style name="Widget.Edham.MaterialCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface_0</item>
        <item name="cardCornerRadius">@dimen/spacing_lg</item>
        <item name="cardElevation">@dimen/spacing_sm</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/border_default</item>
        <item name="rippleColor">@color/surface_100</item>
    </style>
    
    <!-- Shape Appearances -->
    <style name="ShapeAppearance.Edham.SmallComponent" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/spacing_sm</item>
    </style>
    
    <style name="ShapeAppearance.Edham.MediumComponent" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/spacing_md</item>
    </style>
    
    <style name="ShapeAppearance.Edham.LargeComponent" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/spacing_lg</item>
    </style>
    
    <!-- Bottom Sheet Components -->
    <style name="Widget.Edham.BottomSheet" parent="Widget.Material3.BottomSheet.Modal">
        <item name="android:background">@color/surface_0</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Edham.LargeComponent</item>
        <item name="android:padding">@dimen/spacing_bottom_sheet_padding</item>
    </style>
    
    <!-- Alert Dialog Components -->
    <style name="Widget.Edham.AlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="alertDialogStyle">@style/MaterialAlertDialog.Edham</item>
    </style>
    
    <style name="MaterialAlertDialog.Edham" parent="MaterialAlertDialog.Material3">
        <item name="shapeAppearance">@style/ShapeAppearance.Edham.MediumComponent</item>
        <item name="backgroundTint">@color/surface_0</item>
    </style>

    <style name="MaterialAlertDialog.Edham.Title.Panel" parent="MaterialAlertDialog.Material3.Title.Panel" />
    
    <!-- Snackbar Components -->
    <style name="Widget.Edham.Snackbar" parent="Widget.Material3.Snackbar">
        <item name="android:background">@color/surface_900</item>
        <item name="android:textColor">@color/text_inverse</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Edham.MediumComponent</item>
    </style>

    <style name="Widget.Edham.Button.TextButton.Snackbar" parent="Widget.Material3.Button.TextButton.Snackbar">
        <item name="android:textColor">@color/brand_primary</item>
    </style>
    
    <!-- Loading Components -->
    <style name="Widget.Edham.Loading" parent="Widget.Material3.CircularProgressIndicator">
        <item name="indicatorColor">@color/brand_primary</item>
        <item name="trackColor">@color/surface_200</item>
        <item name="indicatorSize">@dimen/spacing_huge</item>
    </style>
    
    <!-- Status Badge Components -->
    <style name="Widget.Edham.StatusBadge">
        <item name="android:textAppearance">@style/TextAppearance.Edham.StatusLabel</item>
        <item name="android:paddingHorizontal">@dimen/spacing_badge_padding_horizontal</item>
        <item name="android:paddingVertical">@dimen/spacing_badge_padding_vertical</item>
        <item name="android:layout_margin">@dimen/spacing_badge_margin</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Edham.SmallComponent</item>
        <item name="android:background">@drawable/shape_status_badge</item>
    </style>
    
    <!-- Avatar Components -->
    <style name="Widget.Edham.Avatar">
        <item name="android:layout_width">@dimen/spacing_huge</item>
        <item name="android:layout_height">@dimen/spacing_huge</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Edham.SmallComponent</item>
        <item name="android:background">@color/surface_300</item>
        <item name="android:scaleType">centerCrop</item>
        <item name="android:padding">@dimen/spacing_avatar_padding</item>
    </style>
    
    <style name="Widget.Edham.Avatar.Small">
        <item name="android:layout_width">@dimen/spacing_xxl</item>
        <item name="android:layout_height">@dimen/spacing_xxl</item>
    </style>
    
    <style name="Widget.Edham.Avatar.Large">
        <item name="android:layout_width">@dimen/spacing_massive</item>
        <item name="android:layout_height">@dimen/spacing_massive</item>
    </style>
    
</resources>
