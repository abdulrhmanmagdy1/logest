<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ============================================ -->
    <!-- 🌑 Edham Logistics Design Tokens - Shadows & Elevations -->
    <!-- ============================================ -->
    
    <!-- ELEVATION LEVELS -->
    <!-- Based on Material Design 3 elevation system -->
    <dimen name="elevation_level_0">0dp</dimen>
    <dimen name="elevation_level_1">1dp</dimen>
    <dimen name="elevation_level_2">3dp</dimen>
    <dimen name="elevation_level_3">6dp</dimen>
    <dimen name="elevation_level_4">8dp</dimen>
    <dimen name="elevation_level_5">12dp</dimen>
    <dimen name="elevation_level_6">16dp</dimen>
    <dimen name="elevation_level_7">20dp</dimen>
    <dimen name="elevation_level_8">24dp</dimen>
    
    <!-- SHADOW PRESETS -->
    <!-- Predefined shadow styles for different elevations -->
    <style name="Shadow.Edham" />

    <style name="Shadow" parent="Shadow.Edham" />

    <!-- Level 0 - No Shadow -->
    <style name="Shadow.Edham.Level0">
        <item name="android:elevation">@dimen/elevation_level_0</item>
    </style>
    
    <!-- Level 1 - Subtle Shadow -->
    <style name="Shadow.Edham.Level1">
        <item name="android:elevation">@dimen/elevation_level_1</item>
    </style>
    
    <!-- Level 2 - Light Shadow -->
    <style name="Shadow.Edham.Level2">
        <item name="android:elevation">@dimen/elevation_level_2</item>
    </style>
    
    <!-- Level 3 - Medium Shadow -->
    <style name="Shadow.Edham.Level3">
        <item name="android:elevation">@dimen/elevation_level_3</item>
    </style>
    
    <!-- Level 4 - Strong Shadow -->
    <style name="Shadow.Edham.Level4">
        <item name="android:elevation">@dimen/elevation_level_4</item>
    </style>
    
    <!-- Level 5 - Heavy Shadow -->
    <style name="Shadow.Edham.Level5">
        <item name="android:elevation">@dimen/elevation_level_5</item>
    </style>
    
    <!-- COMPONENT SHADOWS -->
    <!-- Specific shadow styles for different components -->
    
    <!-- Button Shadows -->
    <style name="Shadow.Edham.Button">
        <item name="android:elevation">@dimen/elevation_level_2</item>
    </style>
    
    <style name="Shadow.Edham.Button.Pressed">
        <item name="android:elevation">@dimen/elevation_level_1</item>
    </style>
    
    <style name="Shadow.Edham.Button.Disabled">
        <item name="android:elevation">@dimen/elevation_level_0</item>
    </style>
    
    <!-- Card Shadows -->
    <style name="Shadow.Edham.Card">
        <item name="android:elevation">@dimen/elevation_level_2</item>
    </style>
    
    <style name="Shadow.Edham.Card.Elevated">
        <item name="android:elevation">@dimen/elevation_level_4</item>
    </style>
    
    <style name="Shadow.Edham.Card.Floating">
        <item name="android:elevation">@dimen/elevation_level_6</item>
    </style>
    
    <!-- Navigation Shadows -->
    <style name="Shadow.Edham.Navigation">
        <item name="android:elevation">@dimen/elevation_level_3</item>
    </style>
    
    <!-- Modal/Dialog Shadows -->
    <style name="Shadow.Edham.Modal">
        <item name="android:elevation">@dimen/elevation_level_6</item>
    </style>
    
    <!-- FAB Shadows -->
    <style name="Shadow.Edham.FAB">
        <item name="android:elevation">@dimen/elevation_level_5</item>
    </style>
    
    <!-- Input Field Shadows -->
    <style name="Shadow.Edham.Input">
        <item name="android:elevation">@dimen/elevation_level_1</item>
    </style>
    
    <style name="Shadow.Edham.Input.Focused">
        <item name="android:elevation">@dimen/elevation_level_2</item>
    </style>
    
    <!-- Chip Shadows -->
    <style name="Shadow.Edham.Chip">
        <item name="android:elevation">@dimen/elevation_level_1</item>
    </style>
    
    <!-- Status Badge Shadows -->
    <style name="Shadow.Edham.StatusBadge">
        <item name="android:elevation">@dimen/elevation_level_1</item>
    </style>
    
    <!-- Avatar Shadows -->
    <style name="Shadow.Edham.Avatar">
        <item name="android:elevation">@dimen/elevation_level_2</item>
    </style>
    
    <!-- Tab Bar Shadows -->
    <style name="Shadow.Edham.TabBar">
        <item name="android:elevation">@dimen/elevation_level_3</item>
    </style>
    
    <!-- Bottom Sheet Shadows -->
    <style name="Shadow.Edham.BottomSheet">
        <item name="android:elevation">@dimen/elevation_level_6</item>
    </style>
    
    <!-- Dropdown/Menu Shadows -->
    <style name="Shadow.Edham.Dropdown">
        <item name="android:elevation">@dimen/elevation_level_4</item>
    </style>
    
    <!-- Tooltip Shadows -->
    <style name="Shadow.Edham.Tooltip">
        <item name="android:elevation">@dimen/elevation_level_3</item>
    </style>
    
    <!-- Progress Indicator Shadows -->
    <style name="Shadow.Edham.Progress">
        <item name="android:elevation">@dimen/elevation_level_1</item>
    </style>
    
    <!-- SPECIAL EFFECT SHADOWS -->
    
    <!-- Neon Glow Effect -->
    <style name="Shadow.Edham.NeonGlow">
        <item name="android:elevation">@dimen/elevation_level_2</item>
    </style>
    
    <!-- Glassmorphism Effect -->
    <style name="Shadow.Edham.Glassmorphism">
        <item name="android:elevation">@dimen/elevation_level_1</item>
    </style>
    
    <!-- Hover Effect -->
    <style name="Shadow.Edham.Hover">
        <item name="android:elevation">@dimen/elevation_level_4</item>
    </style>
    
    <!-- Active/Focused Effect -->
    <style name="Shadow.Edham.Active">
        <item name="android:elevation">@dimen/elevation_level_3</item>
    </style>
    
    <!-- STATE-BASED SHADOWS -->
    
    <!-- Pressed State -->
    <style name="Shadow.Edham.Pressed">
        <item name="android:elevation">@dimen/elevation_level_1</item>
    </style>
    
    <!-- Disabled State -->
    <style name="Shadow.Edham.Disabled">
        <item name="android:elevation">@dimen/elevation_level_0</item>
    </style>
    
    <!-- Loading State -->
    <style name="Shadow.Edham.Loading">
        <item name="android:elevation">@dimen/elevation_level_2</item>
    </style>
    
    <!-- Success State -->
    <style name="Shadow.Edham.Success">
        <item name="android:elevation">@dimen/elevation_level_2</item>
    </style>
    
    <!-- Error State -->
    <style name="Shadow.Edham.Error">
        <item name="android:elevation">@dimen/elevation_level_2</item>
    </style>
    
    <!-- WARNING STATE -->
    <style name="Shadow.Edham.Warning">
        <item name="android:elevation">@dimen/elevation_level_2</item>
    </style>
    
    <!-- ANIMATED SHADOWS -->
    
    <!-- Shadow Animation Durations -->
    <integer name="shadow_animation_duration_fast">150</integer>
    <integer name="shadow_animation_duration_normal">300</integer>
    <integer name="shadow_animation_duration_slow">500</integer>
    
    <!-- Shadow Animation Interpolators -->
    <string name="shadow_animation_interpolator_linear">@android:interpolator/linear</string>
    <string name="shadow_animation_interpolator_accelerate">@android:interpolator/accelerate_decelerate</string>
    <string name="shadow_animation_interpolator_decelerate">@android:interpolator/decelerate_quint</string>
    <string name="shadow_animation_interpolator_bounce">@android:interpolator/bounce</string>
    
    <!-- SHADOW UTILITIES -->
    
    <!-- Shadow Offsets -->
    <dimen name="shadow_offset_none">0dp</dimen>
    <dimen name="shadow_offset_small">2dp</dimen>
    <dimen name="shadow_offset_medium">4dp</dimen>
    <dimen name="shadow_offset_large">8dp</dimen>
    <dimen name="shadow_offset_xlarge">16dp</dimen>
    
    <!-- Shadow Radii -->
    <dimen name="shadow_radius_none">0dp</dimen>
    <dimen name="shadow_radius_small">2dp</dimen>
    <dimen name="shadow_radius_medium">4dp</dimen>
    <dimen name="shadow_radius_large">8dp</dimen>
    <dimen name="shadow_radius_xlarge">16dp</dimen>
    <dimen name="shadow_radius_xxlarge">24dp</dimen>
    
    <!-- SHADOW COLORS FOR DIFFERENT THEMES -->
    
    <!-- Light Theme Shadows -->
    <color name="shadow_light_theme_level_1">#0A000000</color>
    <color name="shadow_light_theme_level_2">#14000000</color>
    <color name="shadow_light_theme_level_3">#1A000000</color>
    <color name="shadow_light_theme_level_4">#26000000</color>
    <color name="shadow_light_theme_level_5">#33000000</color>
    
    <!-- Dark Theme Shadows -->
    <color name="shadow_dark_theme_level_1">#1AFFFFFF</color>
    <color name="shadow_dark_theme_level_2">#33FFFFFF</color>
    <color name="shadow_dark_theme_level_3">#4DFFFFFF</color>
    <color name="shadow_dark_theme_level_4">#66FFFFFF</color>
    <color name="shadow_dark_theme_level_5">#80FFFFFF</color>
    
    <!-- SHADOW SYSTEM REFERENCE -->
    <string-array name="elevation_levels">
        <item>Level 0: 0dp - No elevation</item>
        <item>Level 1: 1dp - Subtle</item>
        <item>Level 2: 3dp - Light</item>
        <item>Level 3: 6dp - Medium</item>
        <item>Level 4: 8dp - Strong</item>
        <item>Level 5: 12dp - Heavy</item>
        <item>Level 6: 16dp - Elevated</item>
        <item>Level 7: 20dp - High</item>
        <item>Level 8: 24dp - Maximum</item>
    </string-array>
    
    <string-array name="shadow_guidelines">
        <item>Use lower elevations for interactive elements</item>
        <item>Use higher elevations for floating elements</item>
        <item>Shadows should enhance depth, not distract</item>
        <item>Consider ambient light direction</item>
        <item>Use consistent shadow colors</item>
        <item>Animate elevation changes smoothly</item>
    </string-array>
    
    <string-array name="component_elevations">
        <item>Buttons: Level 1-2</item>
        <item>Cards: Level 2-4</item>
        <item>Navigation: Level 3</item>
        <item>Modals: Level 6</item>
        <item>FAB: Level 5</item>
        <item>Inputs: Level 1-2</item>
        <item>Chips: Level 1</item>
        <item>Bottom Sheets: Level 6</item>
        <item>Dropdowns: Level 4</item>
    </string-array>
    
</resources>
