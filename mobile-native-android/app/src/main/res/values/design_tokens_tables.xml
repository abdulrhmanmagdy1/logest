<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ============================================ -->
    <!-- 📊 Edham Logistics Design Tokens - Tables -->
    <!-- ============================================ -->
    
    <!-- BASE TABLE STYLES -->
    
    <style name="TextAppearance.Edham.Table" parent="TextAppearance.Edham" />

    <!-- Primary Table -->
    <style name="Widget.Edham.Table" parent="Widget.Edham">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_margin">@dimen/spacing_md</item>
        <item name="android:background">@color/surface_primary</item>
        <item name="android:elevation">@dimen/elevation_level_1</item>
    </style>
    
    <!-- TABLE HEADER STYLES -->
    
    <!-- Table Header -->
    <style name="Widget.Edham.Table.Header">
        <item name="android:background">@color/surface_secondary</item>
        <item name="android:padding">@dimen/spacing_md</item>
        <item name="android:elevation">@dimen/elevation_level_1</item>
    </style>
    
    <!-- Table Header Text -->
    <style name="TextAppearance.Edham.Table.Header">
        <item name="android:textAppearance">@style/TextAppearance.Edham.LabelMedium</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center_vertical</item>
    </style>
    
    <!-- TABLE ROW STYLES -->
    
    <!-- Table Row -->
    <style name="Widget.Edham.Table.Row">
        <item name="android:background">@drawable/table_row_selector</item>
        <item name="android:padding">@dimen/spacing_md</item>
        <item name="android:minHeight">@dimen/spacing_touch_target_min</item>
        <item name="android:gravity">center_vertical</item>
    </style>
    
    <!-- Table Row Even -->
    <style name="Widget.Edham.Table.Row.Even">
        <item name="android:background">@color/surface_primary</item>
        <item name="android:padding">@dimen/spacing_md</item>
        <item name="android:minHeight">@dimen/spacing_touch_target_min</item>
        <item name="android:gravity">center_vertical</item>
    </style>
    
    <!-- Table Row Odd -->
    <style name="Widget.Edham.Table.Row.Odd">
        <item name="android:background">@color/surface_secondary</item>
        <item name="android:padding">@dimen/spacing_md</item>
        <item name="android:minHeight">@dimen/spacing_touch_target_min</item>
        <item name="android:gravity">center_vertical</item>
    </style>
    
    <!-- TABLE CELL STYLES -->
    
    <!-- Table Cell -->
    <style name="Widget.Edham.Table.Cell">
        <item name="android:padding">@dimen/spacing_md</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:layout_gravity">center_vertical</item>
    </style>
    
    <!-- Table Cell Text -->
    <style name="TextAppearance.Edham.Table.Cell">
        <item name="android:textAppearance">@style/TextAppearance.Edham.BodyMedium</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:gravity">center_vertical</item>
    </style>
    
    <!-- TABLE SIZE VARIANTS -->
    
    <!-- Compact Table -->
    <style name="Widget.Edham.Table.Compact">
        <item name="android:layout_margin">@dimen/spacing_sm</item>
    </style>
    
    <style name="Widget.Edham.Table.Compact.Header">
        <item name="android:padding">@dimen/spacing_sm</item>
    </style>
    
    <style name="Widget.Edham.Table.Compact.Row">
        <item name="android:padding">@dimen/spacing_sm</item>
    </style>
    
    <!-- Spacious Table -->
    <style name="Widget.Edham.Table.Spacious">
        <item name="android:layout_margin">@dimen/spacing_lg</item>
    </style>
    
    <style name="Widget.Edham.Table.Spacious.Header">
        <item name="android:padding">@dimen/spacing_lg</item>
    </style>
    
    <style name="Widget.Edham.Table.Spacious.Row">
        <item name="android:padding">@dimen/spacing_lg</item>
    </style>
    
    <!-- TABLE STYLE VARIANTS -->
    
    <!-- Bordered Table -->
    <style name="Widget.Edham.Table.Bordered">
        <item name="android:background">@drawable/table_bordered_background</item>
        <item name="android:layout_margin">@dimen/spacing_md</item>
    </style>
    
    <!-- Striped Table -->
    <style name="Widget.Edham.Table.Striped">
        <item name="android:background">@color/surface_primary</item>
        <item name="android:layout_margin">@dimen/spacing_md</item>
    </style>
    
    <!-- Hover Table -->
    <style name="Widget.Edham.Table.Hover">
        <item name="android:background">@color/surface_primary</item>
        <item name="android:layout_margin">@dimen/spacing_md</item>
    </style>
    
    <!-- LOGISTICS SPECIFIC TABLES -->
    
    <!-- Shipment Table -->
    <style name="Widget.Edham.Table.Shipment">
        <item name="android:background">@color/surface_primary</item>
        <item name="android:layout_margin">@dimen/spacing_md</item>
    </style>
    
    <!-- Driver Table -->
    <style name="Widget.Edham.Table.Driver">
        <item name="android:background">@color/surface_primary</item>
        <item name="android:layout_margin">@dimen/spacing_md</item>
    </style>
    
    <!-- Vehicle Table -->
    <style name="Widget.Edham.Table.Vehicle">
        <item name="android:background">@color/surface_primary</item>
        <item name="android:layout_margin">@dimen/spacing_md</item>
    </style>
    
    <!-- TABLE STATE STYLES -->
    
    <!-- Loading Table -->
    <style name="Widget.Edham.Table.Loading">
        <item name="android:alpha">0.6</item>
    </style>
    
    <!-- Empty Table -->
    <style name="Widget.Edham.Table.Empty">
        <item name="android:gravity">center</item>
        <item name="android:padding">@dimen/spacing_xxl</item>
    </style>
    
    <!-- TABLE REFERENCE -->
    <string-array name="table_sizes">
        <item>Compact: 8dp padding</item>
        <item>Standard: 16dp padding (default)</item>
        <item>Spacious: 24dp padding</item>
    </string-array>
    
    <string-array name="table_variants">
        <item>Standard: Clean design</item>
        <item>Bordered: Full borders</item>
        <item>Striped: Alternating rows</item>
        <item>Hover: Interactive rows</item>
    </string-array>
    
    <string-array name="table_guidelines">
        <item>Consistent row height: 48dp minimum</item>
        <item>Clear header hierarchy</item>
        <item>Proper text alignment</item>
        <item>Meaningful row states</item>
        <item>Responsive column widths</item>
        <item>Accessible touch targets</item>
    </string-array>
    
</resources>
