<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Premium Accountant Card Styles -->
    <style name="AccountantCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/acc_card_bg</item>
        <item name="cardElevation">0dp</item>
        <item name="cardCornerRadius">10dp</item>
        <item name="strokeColor">@color/acc_border</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="AccountantCard.Green">
        <item name="strokeColor">@color/acc_emerald</item>
    </style>

    <style name="AccountantCard.Rust">
        <item name="strokeColor">@color/acc_rust</item>
    </style>

    <style name="AccountantCard.Copper">
        <item name="strokeColor">@color/acc_copper</item>
    </style>

    <style name="AccountantCard.Sky">
        <item name="strokeColor">@color/acc_sky</item>
    </style>

    <!-- Typography Styles -->
    <style name="SupervisorText">
        <item name="android:textColor">@color/ed_white</item>
        <item name="android:fontFamily">@string/font_family_arabic_primary</item>
    </style>

    <style name="SupervisorText.Title">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">@string/font_family_arabic_secondary</item>
    </style>

    <style name="SupervisorText.Subtitle">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/ed_text_muted</item>
    </style>

    <style name="SupervisorText.StatValue">
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">@string/font_family_arabic_secondary</item>
    </style>

    <style name="SupervisorText.StatLabel">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/ed_text_dim</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- Button Styles -->
    <style name="SupervisorButton" parent="Widget.MaterialComponents.Button">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:fontFamily">@string/font_family_arabic_secondary</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="SupervisorButton.Primary">
        <item name="backgroundTint">@color/ed_teal</item>
        <item name="android:textColor">@color/ed_white</item>
    </style>

    <style name="SupervisorButton.Outline">
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="android:textColor">@color/ed_text_dim</item>
        <item name="strokeColor">@color/ed_card_border</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Supervisor Card Styles -->
    <style name="SupervisorCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/ed_card_bg</item>
        <item name="cardElevation">0dp</item>
        <item name="cardCornerRadius">14dp</item>
        <item name="strokeColor">@color/ed_card_border</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="SupervisorCard.Teal">
        <item name="strokeColor">@color/ed_teal_light</item>
    </style>

    <style name="SupervisorCard.Success">
        <item name="strokeColor">@color/ed_success</item>
    </style>

    <style name="SupervisorCard.Orange">
        <item name="strokeColor">@color/ed_orange</item>
    </style>

    <style name="SupervisorCard.Rust">
        <item name="strokeColor">@color/ed_rust</item>
    </style>
</resources>
