<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ============================================ -->
    <!-- 📈 Edham Logistics Design Tokens - Charts -->
    <!-- ============================================ -->
    
    <!-- CHART COLORS -->
    
    <!-- Primary Chart Colors -->
    <color name="chart_color_primary_1">@color/chart_color_1</color>
    <color name="chart_color_primary_2">@color/chart_color_2</color>
    <color name="chart_color_primary_3">@color/chart_color_3</color>
    <color name="chart_color_primary_4">@color/chart_color_4</color>
    <color name="chart_color_primary_5">@color/chart_color_5</color>
    <color name="chart_color_primary_6">@color/chart_color_6</color>
    <color name="chart_color_primary_7">@color/chart_color_7</color>
    <color name="chart_color_primary_8">@color/chart_color_8</color>
    
    <!-- Secondary Chart Colors -->
    <color name="chart_color_secondary_1">@color/color_primary_500</color>
    <color name="chart_color_secondary_2">@color/color_secondary_500</color>
    <color name="chart_color_secondary_3">@color/color_tertiary_500</color>
    <color name="chart_color_secondary_4">@color/color_success_500</color>
    <color name="chart_color_secondary_5">@color/color_warning_500</color>
    <color name="chart_color_secondary_6">@color/color_error_500</color>
    <color name="chart_color_secondary_7">@color/color_info_500</color>
    <color name="chart_color_secondary_8">@color/color_neutral_500</color>
    
    <!-- Chart Background Colors -->
    <color name="chart_background_primary">@color/surface_primary</color>
    <color name="chart_background_secondary">@color/surface_secondary</color>
    <color name="chart_background_grid">@color/border_primary</color>
    <color name="chart_background_overlay">@color/overlay_light</color>
    
    <!-- Chart Text Colors -->
    <color name="chart_text_primary">@color/text_primary</color>
    <color name="chart_text_secondary">@color/text_secondary</color>
    <color name="chart_text_tertiary">@color/text_tertiary</color>
    <color name="chart_text_legend">@color/text_secondary</color>
    
    <!-- CHART DIMENSIONS -->
    
    <!-- Chart Sizes -->
    <dimen name="chart_size_small">120dp</dimen>
    <dimen name="chart_size_medium">200dp</dimen>
    <dimen name="chart_size_large">300dp</dimen>
    <dimen name="chart_size_xlarge">400dp</dimen>
    
    <!-- Chart Heights -->
    <dimen name="chart_height_small">100dp</dimen>
    <dimen name="chart_height_medium">150dp</dimen>
    <dimen name="chart_height_large">200dp</dimen>
    <dimen name="chart_height_xlarge">300dp</dimen>
    
    <!-- Chart Widths -->
    <dimen name="chart_width_small">120dp</dimen>
    <dimen name="chart_width_medium">200dp</dimen>
    <dimen name="chart_width_large">300dp</dimen>
    <dimen name="chart_width_xlarge">400dp</dimen>
    
    <!-- Chart Padding -->
    <dimen name="chart_padding_small">@dimen/spacing_sm</dimen>
    <dimen name="chart_padding_medium">@dimen/spacing_md</dimen>
    <dimen name="chart_padding_large">@dimen/spacing_lg</dimen>
    <dimen name="chart_padding_xlarge">@dimen/spacing_xl</dimen>
    
    <!-- Chart Margins -->
    <dimen name="chart_margin_small">@dimen/spacing_sm</dimen>
    <dimen name="chart_margin_medium">@dimen/spacing_md</dimen>
    <dimen name="chart_margin_large">@dimen/spacing_lg</dimen>
    <dimen name="chart_margin_xlarge">@dimen/spacing_xl</dimen>

    <!-- Chart widget styles: stubs (previous chart_* attrs require a custom view) -->
    <style name="Widget.Edham.Chart" parent="Widget.Edham">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>
    <style name="Widget.Edham.Chart.Line" parent="Widget.Edham.Chart" />
    <style name="Widget.Edham.Chart.Bar" parent="Widget.Edham.Chart" />
    <style name="Widget.Edham.Chart.Pie" parent="Widget.Edham.Chart" />
    <style name="Widget.Edham.Chart.Donut" parent="Widget.Edham.Chart" />
    <style name="Widget.Edham.Chart.Area" parent="Widget.Edham.Chart" />
    <style name="Widget.Edham.Chart.Scatter" parent="Widget.Edham.Chart" />
    <style name="Widget.Edham.Chart.Radar" parent="Widget.Edham.Chart" />
    <style name="Widget.Edham.Chart.Gauge" parent="Widget.Edham.Chart" />
    <style name="Widget.Edham.Chart.Progress" parent="Widget.Edham.Chart" />
    <style name="Widget.Edham.Chart.Small" parent="Widget.Edham.Chart" />
    <style name="Widget.Edham.Chart.Large" parent="Widget.Edham.Chart" />
    <style name="Widget.Edham.Chart.Minimal" parent="Widget.Edham.Chart" />
    <style name="Widget.Edham.Chart.Detailed" parent="Widget.Edham.Chart" />
    <style name="Widget.Edham.Chart.Interactive" parent="Widget.Edham.Chart" />
    <style name="Widget.Edham.Chart.DeliveryPerformance" parent="Widget.Edham.Chart.Line" />
    <style name="Widget.Edham.Chart.Revenue" parent="Widget.Edham.Chart.Bar" />
    <style name="Widget.Edham.Chart.FleetUtilization" parent="Widget.Edham.Chart.Donut" />
    <style name="Widget.Edham.Chart.RouteEfficiency" parent="Widget.Edham.Chart.Area" />
    <style name="Widget.Edham.Chart.DriverPerformance" parent="Widget.Edham.Chart.Radar" />
    <style name="Widget.Edham.Chart.ShipmentStatus" parent="Widget.Edham.Chart.Pie" />
    <style name="Widget.Edham.Chart.CostAnalysis" parent="Widget.Edham.Chart.Bar" />
    <style name="Widget.Edham.Chart.Legend" parent="Widget.Edham.Chart">
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center</item>
    </style>
    <style name="Widget.Edham.Chart.LegendItem" parent="Widget.Edham.Chart" />
    <style name="Widget.Edham.Chart.LegendColor" parent="Widget.Edham.Chart" />
    <style name="Widget.Edham.Chart.XAxis" parent="Widget.Edham.Chart" />
    <style name="Widget.Edham.Chart.YAxis" parent="Widget.Edham.Chart" />
    <style name="Widget.Edham.Chart.Tooltip" parent="Widget.Edham.Chart">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:padding">@dimen/spacing_sm</item>
        <item name="android:background">@drawable/tooltip_background</item>
        <item name="android:elevation">@dimen/elevation_level_3</item>
    </style>
    <style name="Widget.Edham.Chart.Animated" parent="Widget.Edham.Chart" />
    <style name="Widget.Edham.Chart.Animated.Fast" parent="Widget.Edham.Chart.Animated" />
    <style name="Widget.Edham.Chart.Animated.Slow" parent="Widget.Edham.Chart.Animated" />
    <style name="Widget.Edham.Chart.Dark" parent="Widget.Edham.Chart">
        <item name="android:background">@color/dark_surface_100</item>
    </style>
    <style name="Widget.Edham.Chart.Light" parent="Widget.Edham.Chart">
        <item name="android:background">@color/surface_secondary</item>
    </style>
    <style name="Widget.Edham.Chart.FullWidth" parent="Widget.Edham.Chart">
        <item name="android:layout_width">match_parent</item>
    </style>
    <style name="Widget.Edham.Chart.Compact" parent="Widget.Edham.Chart" />
    <style name="Widget.Edham.Chart.Spacious" parent="Widget.Edham.Chart" />

    <style name="TextAppearance.Edham.Chart.Legend">
        <item name="android:textAppearance">@style/TextAppearance.Edham.LabelSmall</item>
        <item name="android:textColor">@color/chart_text_legend</item>
        <item name="android:gravity">center_vertical</item>
    </style>
    <style name="TextAppearance.Edham.Chart.Tooltip">
        <item name="android:textAppearance">@style/TextAppearance.Edham.LabelSmall</item>
        <item name="android:textColor">@color/chart_text_primary</item>
        <item name="android:gravity">center</item>
    </style>
    
    <!-- CHART COLOR ARRAYS -->
    <string-array name="chart_colors_primary">
        <item>@color/chart_color_1</item>
        <item>@color/chart_color_2</item>
        <item>@color/chart_color_3</item>
        <item>@color/chart_color_4</item>
        <item>@color/chart_color_5</item>
        <item>@color/chart_color_6</item>
        <item>@color/chart_color_7</item>
        <item>@color/chart_color_8</item>
    </string-array>
    
    <string-array name="chart_colors_secondary">
        <item>@color/color_primary_500</item>
        <item>@color/color_secondary_500</item>
        <item>@color/color_tertiary_500</item>
        <item>@color/color_success_500</item>
        <item>@color/color_warning_500</item>
        <item>@color/color_error_500</item>
        <item>@color/color_info_500</item>
        <item>@color/color_neutral_500</item>
    </string-array>
    
    <string-array name="fleet_utilization_colors">
        <item>@color/color_success_500</item>
        <item>@color/color_warning_500</item>
        <item>@color/color_error_500</item>
        <item>@color/color_neutral_400</item>
    </string-array>
    
    <string-array name="shipment_status_colors">
        <item>@color/shipment_delivered</item>
        <item>@color/shipment_in_transit</item>
        <item>@color/shipment_loaded</item>
        <item>@color/shipment_preparing</item>
        <item>@color/shipment_accepted</item>
        <item>@color/shipment_created</item>
        <item>@color/shipment_cancelled</item>
        <item>@color/shipment_delayed</item>
    </string-array>
    
    <string-array name="chart_colors_dark">
        <item>@color/color_primary_400</item>
        <item>@color/color_secondary_400</item>
        <item>@color/color_tertiary_400</item>
        <item>@color/color_success_400</item>
        <item>@color/color_warning_400</item>
        <item>@color/color_error_400</item>
        <item>@color/color_info_400</item>
        <item>@color/color_neutral_400</item>
    </string-array>
    
    <!-- CHART REFERENCE -->
    <string-array name="chart_sizes">
        <item>Small: 120dp × 100dp</item>
        <item>Medium: 200dp × 150dp (default)</item>
        <item>Large: 300dp × 200dp</item>
        <item>XLarge: 400dp × 300dp</item>
    </string-array>
    
    <string-array name="chart_types">
        <item>Line: Trend visualization</item>
        <item>Bar: Comparison data</item>
        <item>Pie: Proportion data</item>
        <item>Donut: Ring chart</item>
        <item>Area: Filled line chart</item>
        <item>Scatter: Point distribution</item>
        <item>Radar: Multi-dimensional data</item>
        <item>Gauge: Progress indicator</item>
        <item>Progress: Linear progress</item>
    </string-array>
    
    <string-array name="chart_guidelines">
        <item>Consistent color palette</item>
        <item>Clear axis labels</item>
        <item>Proper spacing and margins</item>
        <item>Responsive sizing</item>
        <item>Accessible color contrast</item>
        <item>Clear legend positioning</item>
        <item>Smooth animations</item>
    </string-array>
    
</resources>
