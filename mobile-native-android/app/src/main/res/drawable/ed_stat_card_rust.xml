<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/ed_card_bg"/>
            <stroke android:width="1dp" android:color="@color/ed_card_border_solid"/>
            <corners android:radius="14dp"/>
        </shape>
    </item>
    <item android:height="3dp" android:gravity="top">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:startColor="@color/ed_rust_dark"
                android:endColor="@color/ed_rust"/>
            <corners android:topLeftRadius="14dp" android:topRightRadius="14dp"/>
        </shape>
    </item>
</layer-list>
