<?xml version="1.0" encoding="utf-8"?>
<!--
  ~ ============================================
  ~ 📋 Network Security Config - Open for Debugging
  ~ ============================================
  -->
<network-security-config>
    <!-- Allow ALL cleartext traffic for testing and local IP communication -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>

    <!-- Specific domains can still be defined if needed, but base-config covers all -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">20.199.136.55</domain>
    </domain-config>
</network-security-config>
