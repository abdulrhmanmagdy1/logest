<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/tvAgingLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 – 30 يوم (جديدة)"
            android:textColor="@color/customer_text_muted"
            android:textSize="12sp"/>
        <TextView
            android:id="@+id/tvAgingAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="18,200 ر.س"
            android:textColor="#FFF"
            android:textSize="13sp"
            android:textStyle="bold"/>
    </RelativeLayout>

    <ProgressBar
        android:id="@+id/pbAging"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_marginTop="8dp"
        android:progress="72"
        android:progressTint="@color/vault_emerald"/>

</LinearLayout>
