<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/navy_950">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/profileToolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="الملف الشخصي"
            app:titleTextColor="@color/surface_0"
            app:navigationIcon="@drawable/ic_back"
            app:navigationIconTint="@color/surface_0" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center_horizontal">

            <!-- Hero Section -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/profileAvatar"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:background="@drawable/circle_glow"
                    android:backgroundTint="@color/brand_primary"
                    android:gravity="center"
                    android:text="م"
                    android:textColor="@color/navy_950"
                    android:textSize="36sp"
                    android:textStyle="bold" />

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/btnChangeAvatar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    app:fabCustomSize="32dp"
                    app:srcCompat="@drawable/ic_camera"
                    app:tint="@color/surface_0"
                    app:backgroundTint="@color/brand_primary"
                    app:borderWidth="2dp"
                    android:elevation="4dp"
                    android:clickable="true"
                    android:focusable="true" />
            </FrameLayout>

            <TextView
                android:id="@+id/profileName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="محمد العبدالله"
                android:textColor="@color/surface_0"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/profilePhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text=""
                android:textColor="@color/surface_0"
                android:alpha="0.7"
                android:textSize="14sp"
                android:textDirection="ltr" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_role_tag"
                android:backgroundTint="@color/gold_dim"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="عميل بريميوم 👑"
                android:textColor="@color/vault_gold"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- Stats Grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:orientation="horizontal"
                android:weightSum="3">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card"
                    android:backgroundTint="@color/navy_800"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:id="@+id/statShipments"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/brand_primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="شحنة"
                        android:textColor="@color/text_tertiary"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card"
                    android:backgroundTint="@color/navy_800"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:id="@+id/statRating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5.0"
                        android:textColor="@color/vault_gold"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="تقييمك"
                        android:textColor="@color/text_tertiary"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card"
                    android:backgroundTint="@color/navy_800"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <TextView
                        android:id="@+id/statYears"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="جديد"
                        android:textColor="@color/vault_emerald"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="العضوية"
                        android:textColor="@color/text_tertiary"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Menu List -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/navy_800"
                app:strokeColor="@color/navy_700"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp">

                    <include layout="@layout/item_profile_menu" android:id="@+id/menuEditProfile" />
                    <include layout="@layout/item_profile_menu" android:id="@+id/menuCompany" />
                    <include layout="@layout/item_profile_menu" android:id="@+id/menuSettings" />
                    <include layout="@layout/item_profile_menu" android:id="@+id/menuPrivacy" />
                    <include layout="@layout/item_profile_menu" android:id="@+id/menuCharter" />
                    <include layout="@layout/item_profile_menu" android:id="@+id/menuPrivacyPolicy" />
                    <include layout="@layout/item_profile_menu" android:id="@+id/menuSupport" />

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/navy_700" android:layout_marginVertical="8dp"/>

                    <include layout="@layout/item_profile_menu" android:id="@+id/menuLogout" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
