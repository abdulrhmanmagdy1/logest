<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="7dp"
    android:baselineAligned="false">

    <!-- Icon -->
    <FrameLayout
        android:id="@+id/iconContainer"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:background="@drawable/bg_stat_icon_teal"
        android:backgroundTint="#80104C64"
        android:layout_marginEnd="7dp">
        <TextView
            android:id="@+id/tvIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="⛽"
            android:textSize="14sp"
            android:textColor="@color/acc_sky"/>
    </FrameLayout>

    <!-- Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">
        <TextView
            android:id="@+id/tvExpenseName"
            style="@style/SupervisorText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="---"
            android:textSize="11sp" />
        <TextView
            android:id="@+id/tvAttachmentStatus"
            style="@style/SupervisorText.Subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="---"
            android:textSize="9sp"
            android:textColor="@color/acc_text_muted"/>
    </LinearLayout>

    <!-- Amount & Actions -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">
        <TextView
            android:id="@+id/tvAmount"
            style="@style/SupervisorText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 ج"
            android:textColor="@color/acc_copper"
            android:textStyle="bold"
            android:textSize="11sp"/>

        <LinearLayout
            android:id="@+id/actionGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnApprove"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="اعتماد"
                android:textSize="10sp"
                android:textColor="@color/acc_emerald"
                android:backgroundTint="#262A9D6E"
                android:paddingHorizontal="9dp"
                android:paddingVertical="3dp"
                android:minHeight="0dp"
                android:minWidth="0dp"
                app:cornerRadius="5dp"
                style="@style/Widget.MaterialComponents.Button.TextButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReject"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:text="رفض"
                android:textSize="10sp"
                android:textColor="@color/acc_rust"
                android:backgroundTint="#1FB6410F"
                android:paddingHorizontal="9dp"
                android:paddingVertical="3dp"
                android:minHeight="0dp"
                android:minWidth="0dp"
                app:cornerRadius="5dp"
                style="@style/Widget.MaterialComponents.Button.TextButton" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
