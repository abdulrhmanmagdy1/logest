<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    tools:context=".maintenance.MaintenanceAnalyticsFragment">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_dark"
        app:elevation="4dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="تحليلات الصيانة"
            app:titleTextColor="@color/white"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:menu="@menu/maintenance_analytics_menu" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Date Range Selector -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_date_range"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/surface_dark"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="فترة التحليل"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:fontFamily="sans-serif-medium" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_date_range"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="آخر 30 يوم"
                    android:textSize="14sp"
                    android:textColor="@color/primary_blue"
                    android:fontFamily="sans-serif"
                    tools:text="آخر 30 يوم" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_calendar"
                    android:tint="@color/primary_blue"
                    android:layout_marginStart="4dp" />

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Key Metrics Cards -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Total Cost Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/surface_dark">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="إجمالي التكلفة"
                    android:textSize="12sp"
                    android:textColor="@color/white_80"
                    android:fontFamily="sans-serif" />

                <TextView
                    android:id="@+id/tv_total_cost"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="45,250 ريال"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_blue"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif-medium"
                    tools:text="45,250 ريال" />

                <TextView
                    android:id="@+id/tv_cost_trend"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↑ 12.5%"
                    android:textSize="12sp"
                    android:textColor="@color/green"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif"
                    tools:text="↑ 12.5%" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Average Duration Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/surface_dark">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="متوسط المدة"
                    android:textSize="12sp"
                    android:textColor="@color/white_80"
                    android:fontFamily="sans-serif" />

                <TextView
                    android:id="@+id/tv_avg_duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2.5 ساعة"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/orange"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif-medium"
                    tools:text="2.5 ساعة" />

                <TextView
                    android:id="@+id/tv_duration_trend"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↓ 8.2%"
                    android:textSize="12sp"
                    android:textColor="@color/red"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif"
                    tools:text="↓ 8.2%" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- Cost Breakdown Chart -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_cost_breakdown"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/surface_dark"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="تحليل التكاليف"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/btn_cost_details"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="تفاصيل"
                    android:textSize="14sp"
                    android:textColor="@color/primary_blue"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="8dp"
                    android:fontFamily="sans-serif" />

            </LinearLayout>

            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/chart_cost_breakdown"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginBottom="8dp" />

            <!-- Cost Breakdown Legend -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@color/primary_blue"
                        android:layout_marginEnd="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="قطع غيار"
                        android:textSize="12sp"
                        android:textColor="@color/white_80"
                        android:fontFamily="sans-serif" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@color/green"
                        android:layout_marginEnd="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="عمالة"
                        android:textSize="12sp"
                        android:textColor="@color/white_80"
                        android:fontFamily="sans-serif" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@color/orange"
                        android:layout_marginEnd="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="أخرى"
                        android:textSize="12sp"
                        android:textColor="@color/white_80"
                        android:fontFamily="sans-serif" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Maintenance Trends Chart -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_maintenance_trends"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/surface_dark"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="اتجاهات الصيانة"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:fontFamily="sans-serif-medium" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btn_trends_weekly"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="أسبوعي"
                        android:textSize="12sp"
                        android:textColor="@color/primary_blue"
                        android:background="@drawable/bg_chart_tab_selected"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:layout_marginEnd="4dp" />

                    <TextView
                        android:id="@+id/btn_trends_monthly"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="شهري"
                        android:textSize="12sp"
                        android:textColor="@color/white_60"
                        android:background="@drawable/bg_chart_tab_unselected"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp" />

                </LinearLayout>

            </LinearLayout>

            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/chart_maintenance_trends"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginBottom="8dp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Top Maintenance Types -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_top_maintenance"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/surface_dark"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="أكثر أنواع الصيانة شيوعاً"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_marginBottom="12dp"
                android:fontFamily="sans-serif-medium" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_top_maintenance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_top_maintenance" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Performance Metrics -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_performance_metrics"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/surface_dark"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="مقاييس الأداء"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_marginBottom="12dp"
                android:fontFamily="sans-serif-medium" />

            <!-- Performance Grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <!-- On-Time Completion -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp"
                    android:background="@drawable/bg_metric_card"
                    android:layout_marginEnd="4dp">

                    <TextView
                        android:id="@+id/tv_on_time_completion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="92.5%"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/green"
                        android:fontFamily="sans-serif-medium"
                        tools:text="92.5%" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="الإكمال في الوقت"
                        android:textSize="12sp"
                        android:textColor="@color/white_80"
                        android:layout_marginTop="2dp"
                        android:fontFamily="sans-serif" />

                </LinearLayout>

                <!-- Cost Efficiency -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp"
                    android:background="@drawable/bg_metric_card"
                    android:layout_marginStart="4dp">

                    <TextView
                        android:id="@+id/tv_cost_efficiency"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="87.3%"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_blue"
                        android:fontFamily="sans-serif-medium"
                        tools:text="87.3%" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="كفاءة التكلفة"
                        android:textSize="12sp"
                        android:textColor="@color/white_80"
                        android:layout_marginTop="2dp"
                        android:fontFamily="sans-serif" />

                </LinearLayout>

            </LinearLayout>

            <!-- Additional Metrics -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginTop="8dp">

                <!-- Preventive Maintenance Rate -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp"
                    android:background="@drawable/bg_metric_card"
                    android:layout_marginEnd="4dp">

                    <TextView
                        android:id="@+id/tv_preventive_rate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="78.2%"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/orange"
                        android:fontFamily="sans-serif-medium"
                        tools:text="78.2%" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="معدل الصيانة الوقائية"
                        android:textSize="12sp"
                        android:textColor="@color/white_80"
                        android:layout_marginTop="2dp"
                        android:fontFamily="sans-serif" />

                </LinearLayout>

                <!-- Repeat Issues Rate -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp"
                    android:background="@drawable/bg_metric_card"
                    android:layout_marginStart="4dp">

                    <TextView
                        android:id="@+id/tv_repeat_issues"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="15.4%"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/red"
                        android:fontFamily="sans-serif-medium"
                        tools:text="15.4%" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="معدل المشاكل المتكررة"
                        android:textSize="12sp"
                        android:textColor="@color/white_80"
                        android:layout_marginTop="2dp"
                        android:fontFamily="sans-serif" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Floating Action Button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_export"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:src="@drawable/ic_download"
        app:tint="@color/white"
        app:backgroundTint="@color/primary_blue" />

    <!-- Loading Indicator -->
    <LinearLayout
        android:id="@+id/layout_loading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="@color/primary_blue" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="جاري تحليل بيانات الصيانة..."
            android:textSize="14sp"
            android:textColor="@color/white"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
