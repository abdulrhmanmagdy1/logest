<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ed_deep"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Stats Grid (High Fidelity) -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:alignmentMode="alignMargins"
            android:columnCount="2"
            android:layout_marginBottom="20dp">

            <!-- Total Trucks -->
            <com.google.android.material.card.MaterialCardView
                style="@style/SupervisorCard.Teal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:text="🚛"
                        android:textSize="20sp"
                        android:gravity="center"
                        android:background="@drawable/bg_stat_icon_teal"
                        android:padding="4dp"/>
                    <TextView
                        android:id="@+id/stat_total_trucks"
                        style="@style/SupervisorText.StatValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="42" />
                    <TextView
                        style="@style/SupervisorText.StatLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="إجمالي الشاحنات" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Active Trucks -->
            <com.google.android.material.card.MaterialCardView
                style="@style/SupervisorCard.Success"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:text="✅"
                        android:textSize="20sp"
                        android:gravity="center"
                        android:background="@drawable/bg_stat_icon_success"
                        android:padding="4dp"/>
                    <TextView
                        android:id="@+id/stat_active_trucks"
                        style="@style/SupervisorText.StatValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="36" />
                    <TextView
                        style="@style/SupervisorText.StatLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="شاحنات نشطة" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Loads This Month -->
            <com.google.android.material.card.MaterialCardView
                style="@style/SupervisorCard.Orange"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:text="📦"
                        android:textSize="20sp"
                        android:gravity="center"
                        android:background="@drawable/bg_stat_icon_orange"
                        android:padding="4dp"/>
                    <TextView
                        android:id="@+id/stat_loads"
                        style="@style/SupervisorText.StatValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="128" />
                    <TextView
                        style="@style/SupervisorText.StatLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="حمولات الشهر" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Revenue -->
            <com.google.android.material.card.MaterialCardView
                style="@style/SupervisorCard.Rust"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:text="💰"
                        android:textSize="20sp"
                        android:gravity="center"
                        android:background="@drawable/bg_stat_icon_rust"
                        android:padding="4dp"/>
                    <TextView
                        android:id="@+id/stat_revenue"
                        style="@style/SupervisorText.StatValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="2.4M" />
                    <TextView
                        style="@style/SupervisorText.StatLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="إيرادات الشهر" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </GridLayout>

        <!-- Live Tracking Map -->
        <com.google.android.material.card.MaterialCardView
            style="@style/SupervisorCard.Teal"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_marginBottom="24dp">

            <fragment
                android:id="@+id/dashboard_map"
                android:name="com.google.android.gms.maps.SupportMapFragment"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- Map Controls Overlay -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_margin="12dp"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/btnMapType"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/ed_card_bg"
                    android:padding="8dp"
                    android:src="@drawable/ic_map"
                    app:tint="@color/ed_teal_lighter"
                    android:elevation="4dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- New Requests -->
        <TextView
            style="@style/SupervisorText.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🆕 طلبات جديدة بانتظار التعيين"
            android:layout_marginBottom="12dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPendingOrders"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:listitem="@layout/item_supervisor_shipment"
            tools:itemCount="3"/>

        <!-- Analytics Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <com.google.android.material.card.MaterialCardView
                style="@style/SupervisorCard"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="8dp">
                <com.github.mikephil.charting.charts.PieChart
                    android:id="@+id/fleetChart"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="8dp"/>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/SupervisorCard"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="8dp">
                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/revenueChart"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="8dp"/>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- AI Risk Summary -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnRiskMatrix"
            style="@style/SupervisorCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:clickable="true"
            android:focusable="true"
            app:strokeColor="@color/ed_rust"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="@color/ed_rust_15">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:gravity="center_vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🧠 استخبارات المخاطر (AI)" android:textColor="@color/ed_rust_2" android:textStyle="bold" android:textSize="14sp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="12dp" android:text="يوجد 2 شاحنة في منطقة خطر" android:textColor="@color/ed_text_muted_new" android:textSize="10sp"/>
                <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_arrow_back" app:tint="@color/ed_rust_2" android:rotation="180"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Urgent Alerts Hub -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                style="@style/SupervisorText.Title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🔔 التنبيهات الفورية" />

            <HorizontalScrollView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:scrollbars="none">
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/alertFilterGroup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipAllAlerts"
                        style="@style/Widget.MaterialComponents.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="الكل"
                        android:checked="true"
                        app:chipBackgroundColor="@color/ed_teal_15"
                        android:textColor="@color/ed_white"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipHeatAlerts"
                        style="@style/Widget.MaterialComponents.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="حرارة"
                        app:chipBackgroundColor="@color/ed_teal_15"
                        android:textColor="@color/ed_white"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipDelayAlerts"
                        style="@style/Widget.MaterialComponents.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="تأخير"
                        app:chipBackgroundColor="@color/ed_teal_15"
                        android:textColor="@color/ed_white"/>
                </com.google.android.material.chip.ChipGroup>
            </HorizontalScrollView>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            style="@style/SupervisorCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardElevation="0dp">
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAlerts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_smart_alert"
                tools:itemCount="3"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- Driver Leaderboard -->
        <TextView
            style="@style/SupervisorText.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏆 أفضل السائقين"
            android:layout_marginBottom="12dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvLeaderboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:nestedScrollingEnabled="false"
            tools:listitem="@layout/item_driver_status" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
