<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    tools:context=".fleet.AnalyticsChartsFragment">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_dark"
        app:elevation="4dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="تحليلات الأسطول"
            app:titleTextColor="@color/white"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:menu="@menu/analytics_menu" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Date Range Selector -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/surface_dark">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="فترة التحليل"
                        android:textSize="16sp"
                        android:textColor="@color/white"
                        android:fontFamily="sans-serif-medium" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_date_range"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="آخر 30 يوم"
                        android:textSize="14sp"
                        android:textColor="@color/primary_blue"
                        app:strokeColor="@color/primary_blue"
                        app:cornerRadius="8dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Key Metrics Cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="16dp">

                <!-- Utilization Rate Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/surface_dark">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="معدل الاستغلال"
                            android:textSize="12sp"
                            android:textColor="@color/white_80"
                            android:fontFamily="sans-serif" />

                        <TextView
                            android:id="@+id/tv_utilization_rate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="78.5%"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_blue"
                            android:layout_marginTop="4dp"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:id="@+id/tv_utilization_trend"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="↑ 5.2%"
                            android:textSize="12sp"
                            android:textColor="@color/green"
                            android:layout_marginTop="4dp"
                            android:fontFamily="sans-serif" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Cost per Mile Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/surface_dark">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="التكلفة لكل كم"
                            android:textSize="12sp"
                            android:textColor="@color/white_80"
                            android:fontFamily="sans-serif" />

                        <TextView
                            android:id="@+id/tv_cost_per_mile"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1.25 ريال"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/green"
                            android:layout_marginTop="4dp"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:id="@+id/tv_cost_trend"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="↓ 2.1%"
                            android:textSize="12sp"
                            android:textColor="@color/red"
                            android:layout_marginTop="4dp"
                            android:fontFamily="sans-serif" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Fleet Utilization Chart -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/surface_dark">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="استغلال الأسطول"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:fontFamily="sans-serif-medium" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/btn_utilization_daily"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="يومي"
                                android:textSize="12sp"
                                android:textColor="@color/primary_blue"
                                android:background="@drawable/bg_chart_tab_selected"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="4dp"
                                android:layout_marginEnd="4dp" />

                            <TextView
                                android:id="@+id/btn_utilization_weekly"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="أسبوعي"
                                android:textSize="12sp"
                                android:textColor="@color/white_60"
                                android:background="@drawable/bg_chart_tab_unselected"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="4dp"
                                android:layout_marginEnd="4dp" />

                            <TextView
                                android:id="@+id/btn_utilization_monthly"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="شهري"
                                android:textSize="12sp"
                                android:textColor="@color/white_60"
                                android:background="@drawable/bg_chart_tab_unselected"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="4dp" />

                        </LinearLayout>

                    </LinearLayout>

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/chart_utilization"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="متوسط: "
                            android:textSize="12sp"
                            android:textColor="@color/white_80"
                            android:fontFamily="sans-serif" />

                        <TextView
                            android:id="@+id/tv_utilization_average"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="82.3%"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:fontFamily="sans-serif-medium" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="أعلى: "
                            android:textSize="12sp"
                            android:textColor="@color/white_80"
                            android:fontFamily="sans-serif" />

                        <TextView
                            android:id="@+id/tv_utilization_peak"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="95.2%"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:fontFamily="sans-serif-medium" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Fuel Consumption Chart -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/surface_dark">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="استهلاك الوقود"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:fontFamily="sans-serif-medium" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/btn_fuel_daily"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="يومي"
                                android:textSize="12sp"
                                android:textColor="@color/primary_blue"
                                android:background="@drawable/bg_chart_tab_selected"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="4dp"
                                android:layout_marginEnd="4dp" />

                            <TextView
                                android:id="@+id/btn_fuel_weekly"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="أسبوعي"
                                android:textSize="12sp"
                                android:textColor="@color/white_60"
                                android:background="@drawable/bg_chart_tab_unselected"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="4dp"
                                android:layout_marginEnd="4dp" />

                            <TextView
                                android:id="@+id/btn_fuel_monthly"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="شهري"
                                android:textSize="12sp"
                                android:textColor="@color/white_60"
                                android:background="@drawable/bg_chart_tab_unselected"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="4dp" />

                        </LinearLayout>

                    </LinearLayout>

                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/chart_fuel_consumption"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="مجموع: "
                            android:textSize="12sp"
                            android:textColor="@color/white_80"
                            android:fontFamily="sans-serif" />

                        <TextView
                            android:id="@+id/tv_fuel_total"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2,450 لتر"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:fontFamily="sans-serif-medium" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="متوسط: "
                            android:textSize="12sp"
                            android:textColor="@color/white_80"
                            android:fontFamily="sans-serif" />

                        <TextView
                            android:id="@+id/tv_fuel_average"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="81.8 لتر"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:fontFamily="sans-serif-medium" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Cost Analysis Chart -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/surface_dark">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="تحليل التكاليف"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:layout_marginBottom="12dp"
                        android:fontFamily="sans-serif-medium" />

                    <com.github.mikephil.charting.charts.PieChart
                        android:id="@+id/chart_cost_analysis"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="إجمالي التكاليف: "
                            android:textSize="12sp"
                            android:textColor="@color/white_80"
                            android:fontFamily="sans-serif" />

                        <TextView
                            android:id="@+id/tv_total_cost"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="45,250 ريال"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:fontFamily="sans-serif-medium" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Performance Metrics -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/surface_dark">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="مقاييس الأداء"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:layout_marginBottom="16dp"
                        android:fontFamily="sans-serif-medium" />

                    <!-- Performance Grid -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <!-- On-Time Delivery -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_metric_card"
                            android:padding="12dp">

                            <TextView
                                android:id="@+id/tv_on_time_rate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="92.5%"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/green"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="التسليم في الوقت"
                                android:textSize="12sp"
                                android:textColor="@color/white_80"
                                android:layout_marginTop="4dp"
                                android:fontFamily="sans-serif" />

                        </LinearLayout>

                        <!-- Vehicle Efficiency -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_metric_card"
                            android:padding="12dp">

                            <TextView
                                android:id="@+id/tv_efficiency_rate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="87.3%"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/primary_blue"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="كفاءة المركبات"
                                android:textSize="12sp"
                                android:textColor="@color/white_80"
                                android:layout_marginTop="4dp"
                                android:fontFamily="sans-serif" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Additional Metrics -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2"
                        android:layout_marginTop="8dp">

                        <!-- Average Speed -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_metric_card"
                            android:padding="12dp">

                            <TextView
                                android:id="@+id/tv_avg_speed"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="65.2 كم/س"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/white"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="متوسط السرعة"
                                android:textSize="12sp"
                                android:textColor="@color/white_80"
                                android:layout_marginTop="4dp"
                                android:fontFamily="sans-serif" />

                        </LinearLayout>

                        <!-- Distance Traveled -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_metric_card"
                            android:padding="12dp">

                            <TextView
                                android:id="@+id/tv_total_distance"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="12,450 كم"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/white"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="إجمالي المسافة"
                                android:textSize="12sp"
                                android:textColor="@color/white_80"
                                android:layout_marginTop="4dp"
                                android:fontFamily="sans-serif" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Export Button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_export"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:src="@drawable/ic_download"
        app:tint="@color/white"
        app:backgroundTint="@color/primary_blue" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
