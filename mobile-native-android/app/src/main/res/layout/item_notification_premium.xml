<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="14dp"
    android:clickable="true"
    android:focusable="true"
    android:background="?attr/selectableItemBackground">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/notifIconCard"
        android:layout_width="42dp"
        android:layout_height="42dp"
        app:cardCornerRadius="13dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/sky_glow">
        <ImageView
            android:id="@+id/ivNotifIcon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_truck"
            app:tint="@color/prem_sky"/>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="16dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvNotifTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="شحنتك في الطريق ❄️"
            android:textColor="#FFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvNotifMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="الشحنة #IDH-0891 غادرت الرياض وفي طريقها إلى جدة"
            android:textColor="@color/customer_text_muted"
            android:textSize="12sp"
            android:lineSpacingExtra="2dp"/>

        <TextView
            android:id="@+id/tvNotifTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="منذ 30 دقيقة"
            android:textColor="@color/customer_text_muted"
            android:textSize="11sp" />
    </LinearLayout>

    <View
        android:id="@+id/unreadDot"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:layout_marginTop="5dp"
        android:background="@drawable/circle_blue"
        android:visibility="visible"/>

</LinearLayout>
