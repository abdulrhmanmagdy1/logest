<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="260dp"
    android:layout_height="match_parent"
    android:background="@drawable/ed_sidebar_bg"
    android:orientation="vertical">

    <!-- Logo Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="24dp"
        android:gravity="center_vertical"
        android:background="@drawable/ed_divider">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_snowflake"
            android:tint="@color/ed_white"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EDHAM"
                android:textColor="@color/ed_white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="للنقل المبرد"
                android:textColor="@color/ed_copper"
                android:textSize="10sp"
                android:fontFamily="sans-serif"/>
        </LinearLayout>
    </LinearLayout>

    <!-- User Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="@drawable/ed_divider">

        <View
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/ed_avatar_circle"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="أحمد محمد"
                android:textColor="@color/ed_white"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="مدير الأسطول"
                android:textColor="@color/ed_copper"
                android:textSize="11sp"
                android:fontFamily="sans-serif"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Navigation Items -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Main Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="الرئيسية"
                android:textColor="@color/ed_text_muted"
                android:textSize="10sp"
                android:textStyle="bold"
                android:padding="12dp"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif"/>

            <LinearLayout
                android:id="@+id/nav_dashboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="10dp"
                android:gravity="center_vertical"
                android:background="@drawable/ed_nav_item_active">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_dashboard"
                    android:tint="@color/ed_teal_lighter"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="لوحة التحكم"
                    android:textColor="@color/ed_teal_lighter"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/nav_tracking"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="10dp"
                android:gravity="center_vertical"
                android:background="@drawable/ed_nav_item_bg">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_map"
                    android:tint="@color/ed_text_dim"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="تتبع السائقين"
                    android:textColor="@color/ed_text_dim"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12"
                    android:textColor="@color/ed_white"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:padding="4dp"
                    android:background="@drawable/ed_nav_badge"
                    android:fontFamily="sans-serif"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/nav_fleet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="10dp"
                android:gravity="center_vertical"
                android:background="@drawable/ed_nav_item_bg">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_truck"
                    android:tint="@color/ed_text_dim"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="إدارة الأسطول"
                    android:textColor="@color/ed_text_dim"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/nav_loads"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="10dp"
                android:gravity="center_vertical"
                android:background="@drawable/ed_nav_item_bg">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_package"
                    android:tint="@color/ed_text_dim"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="إدارة الحمولات"
                    android:textColor="@color/ed_text_dim"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif"/>
            </LinearLayout>

            <!-- Finance Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="المالية"
                android:textColor="@color/ed_text_muted"
                android:textSize="10sp"
                android:textStyle="bold"
                android:padding="12dp"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif"/>

            <LinearLayout
                android:id="@+id/nav_invoices"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="10dp"
                android:gravity="center_vertical"
                android:background="@drawable/ed_nav_item_bg">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_invoice"
                    android:tint="@color/ed_text_dim"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="الفواتير والمديونيات"
                    android:textColor="@color/ed_text_dim"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5"
                    android:textColor="@color/ed_white"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:padding="4dp"
                    android:background="@drawable/ed_nav_badge"
                    android:fontFamily="sans-serif"/>
            </LinearLayout>

            <!-- Maintenance Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="الصيانة"
                android:textColor="@color/ed_text_muted"
                android:textSize="10sp"
                android:textStyle="bold"
                android:padding="12dp"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif"/>

            <LinearLayout
                android:id="@+id/nav_maintenance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="10dp"
                android:gravity="center_vertical"
                android:background="@drawable/ed_nav_item_bg">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_build"
                    android:tint="@color/ed_text_dim"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="الورشة والصيانة"
                    android:textColor="@color/ed_text_dim"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/nav_parts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="10dp"
                android:gravity="center_vertical"
                android:background="@drawable/ed_nav_item_bg">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_settings"
                    android:tint="@color/ed_text_dim"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="إدارة القطع"
                    android:textColor="@color/ed_text_dim"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif"/>
            </LinearLayout>

            <!-- Reports Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="التقارير"
                android:textColor="@color/ed_text_muted"
                android:textSize="10sp"
                android:textStyle="bold"
                android:padding="12dp"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif"/>

            <LinearLayout
                android:id="@+id/nav_reports"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="10dp"
                android:gravity="center_vertical"
                android:background="@drawable/ed_nav_item_bg">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_analytics"
                    android:tint="@color/ed_text_dim"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="التقارير والتحليلات"
                    android:textColor="@color/ed_text_dim"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/nav_survey"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="10dp"
                android:gravity="center_vertical"
                android:background="@drawable/ed_nav_item_bg">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_people"
                    android:tint="@color/ed_text_dim"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="استبيان السائقين"
                    android:textColor="@color/ed_text_dim"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@drawable/ed_divider">

        <LinearLayout
            android:id="@+id/nav_logout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_logout"
                android:tint="@color/ed_text_muted"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="تسجيل الخروج"
                android:textColor="@color/ed_text_muted"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
