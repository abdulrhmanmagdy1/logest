<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_50"
    tools:context=".feature.billing.presentation.ui.AccountantBillingFragment">

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Main Content -->
    <ScrollView
        android:id="@+id/contentLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header with Actions -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="إدارة الفواتير والدفع"
                    android:textColor="@color/black"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonRefresh"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="تحديث"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    app:backgroundTint="@color/primary"
                    app:cornerRadius="4dp"
                    app:icon="@drawable/ic_refresh"
                    app:iconGravity="textEnd"
                    style="@style/Widget.MaterialComponents.Button.TextButton" />

            </LinearLayout>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonGenerateInvoice"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="إنشاء فاتورة"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    app:backgroundTint="@color/green_500"
                    app:cornerRadius="4dp"
                    app:icon="@drawable/ic_add"
                    app:iconGravity="textEnd"
                    style="@style/Widget.MaterialComponents.Button.TextButton" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonProcessPayment"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp"
                    android:text="معالجة دفع"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    app:backgroundTint="@color/blue_500"
                    app:cornerRadius="4dp"
                    app:icon="@drawable/ic_payment"
                    app:iconGravity="textEnd"
                    style="@style/Widget.MaterialComponents.Button.TextButton" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonExportInvoices"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="تصدير الفواتير"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    app:backgroundTint="@color/purple_500"
                    app:cornerRadius="4dp"
                    app:icon="@drawable/ic_export"
                    app:iconGravity="textEnd"
                    style="@style/Widget.MaterialComponents.Button.TextButton" />

            </LinearLayout>

            <!-- Financial Summary Cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="16dp">

                <!-- Total Revenue Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTotalRevenue"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="2dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_revenue"
                                android:tint="@color/green_500"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="إجمالي الإيرادات"
                                android:textColor="@color/gray_600"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/textTotalRevenueTrend"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="↑ 18%"
                                android:textColor="@color/green_500"
                                android:textSize="10sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/textTotalRevenue"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="4,500 ر.س"
                            android:textColor="@color/black"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Total Expenses Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTotalExpenses"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="2dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_expense"
                                android:tint="@color/red_500"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="إجمالي المصروفات"
                                android:textColor="@color/gray_600"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/textTotalExpensesTrend"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="↑ 9%"
                                android:textColor="@color/red_500"
                                android:textSize="10sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/textTotalExpenses"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="1,200 ر.س"
                            android:textColor="@color/black"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Second Row of Financial Cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="16dp">

                <!-- Unpaid Invoices Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardUnpaidInvoices"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="2dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_invoice_unpaid"
                                android:tint="@color/orange_500"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="الفواتير غير المدفوعة"
                                android:textColor="@color/gray_600"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/textUnpaidInvoicesTrend"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="↑ 2"
                                android:textColor="@color/orange_500"
                                android:textSize="10sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/textUnpaidInvoices"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="2"
                            android:textColor="@color/black"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Total Profit Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTotalProfit"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="2dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_profit"
                                android:tint="@color/blue_500"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="إجمالي الأرباح"
                                android:textColor="@color/gray_600"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/textTotalProfitTrend"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="↑ 22%"
                                android:textColor="@color/blue_500"
                                android:textSize="10sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/textTotalProfit"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="3,300 ر.س"
                            android:textColor="@color/black"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Quick Actions -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonMarkAsPaid"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="تعليم كمدفوع"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    app:backgroundTint="@color/green_500"
                    app:cornerRadius="4dp"
                    style="@style/Widget.MaterialComponents.Button.TextButton" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonMarkAsUnpaid"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="تعليم كغير مدفوع"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    app:backgroundTint="@color/orange_500"
                    app:cornerRadius="4dp"
                    style="@style/Widget.MaterialComponents.Button.TextButton" />

            </LinearLayout>

            <!-- Financial Summary List -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:orientation="vertical"
                android:background="@color/white"
                android:elevation="2dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ملخص مالي"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:padding="12dp"
                    android:background="@color/gray_100" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerViewFinancialSummary"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:padding="4dp"
                    android:clipToPadding="false"
                    android:scrollbars="vertical" />

            </LinearLayout>

            <!-- Invoices Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:orientation="vertical"
                android:background="@color/white"
                android:elevation="2dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="الفواتير الأخيرة"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:padding="12dp"
                    android:background="@color/gray_100" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerViewInvoices"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:padding="4dp"
                    android:clipToPadding="false"
                    android:scrollbars="vertical" />

            </LinearLayout>

            <!-- Payments Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:orientation="vertical"
                android:background="@color/white"
                android:elevation="2dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="الدفعات الأخيرة"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:padding="12dp"
                    android:background="@color/gray_100" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerViewPayments"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:padding="4dp"
                    android:clipToPadding="false"
                    android:scrollbars="vertical" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Error Layout -->
    <LinearLayout
        android:id="@+id/layoutError"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginBottom="16dp"
            android:src="@drawable/ic_error"
            android:tint="@color/red_500" />

        <TextView
            android:id="@+id/textError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="حدث خطأ في تحميل بيانات الفواتير"
            android:textColor="@color/red_500"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonRetry"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="إعادة المحاولة"
            android:textColor="@color/white"
            app:backgroundTint="@color/red_500"
            app:cornerRadius="8dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
