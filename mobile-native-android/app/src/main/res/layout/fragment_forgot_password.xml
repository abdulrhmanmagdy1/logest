<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".auth.ForgotPasswordFragment">

    <!-- Background -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/auth_background"
        android:alpha="0.1" />

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_xl"
            android:gravity="center"
            android:layout_marginTop="@dimen/spacing_xxxl">

            <!-- Icon and Title -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="@dimen/spacing_xxxl">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/ic_lock"
                    android:layout_marginBottom="@dimen/spacing_md" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/forgot_password"
                    style="@style/TextAppearance.Edham.HeadlineSmall"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/forgot_password_description"
                    style="@style/TextAppearance.Edham.BodyMedium"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:layout_marginBottom="@dimen/spacing_md" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/forgot_password_instructions"
                    style="@style/TextAppearance.Edham.BodySmall"
                    android:textColor="@color/text_tertiary"
                    android:gravity="center" />

            </LinearLayout>

            <!-- Email Input Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.Edham.Card.Elevated"
                android:layout_marginBottom="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_xl">

                    <!-- Email Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/email_input_layout"
                        style="@style/Widget.Edham.TextInputLayout.Email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_lg"
                        android:hint="@string/email_hint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/email_edit_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textEmailAddress"
                            android:maxLines="1"
                            android:textDirection="ltr" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Send Reset Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/send_reset_button"
                        style="@style/Widget.Edham.Button.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_md"
                        android:text="@string/send_reset_link" />

                    <!-- Back to Login -->
                    <TextView
                        android:id="@+id/back_to_login_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/back_to_login"
                        style="@style/TextAppearance.Edham.LabelMedium"
                        android:textColor="@color/color_primary_500"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="@dimen/spacing_sm"
                        android:layout_gravity="center" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Help Section -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="@dimen/spacing_lg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/password_reset_help"
                    style="@style/TextAppearance.Edham.BodySmall"
                    android:textColor="@color/text_tertiary"
                    android:gravity="center"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <TextView
                    android:id="@+id/contact_support_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/contact_support"
                    style="@style/TextAppearance.Edham.LabelSmall"
                    android:textColor="@color/color_primary_500"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="@dimen/spacing_sm" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Progress Overlay -->
    <LinearLayout
        android:id="@+id/progress_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/overlay_medium"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            app:indicatorColor="@color/color_primary_500"
            app:indicatorSize="48dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sending_reset_link"
            style="@style/TextAppearance.Edham.LabelMedium"
            android:textColor="@color/text_primary"
            android:layout_marginTop="@dimen/spacing_md" />

    </LinearLayout>

    <!-- Success Message -->
    <LinearLayout
        android:id="@+id/success_message"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="@dimen/spacing_xl"
        android:background="@color/overlay_medium"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_check_circle"
            android:layout_marginBottom="@dimen/spacing_lg" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reset_link_sent"
            style="@style/TextAppearance.Edham.HeadlineSmall"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="@dimen/spacing_sm"
            android:gravity="center" />

        <TextView
            android:id="@+id/success_description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reset_link_sent_description"
            style="@style/TextAppearance.Edham.BodyMedium"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_lg" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/ok_button"
            style="@style/Widget.Edham.Button.Primary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ok" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
