<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".shipment.SmartFiltersFragment">

    <!-- App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/overlay_light"
        app:elevation="4dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Smart Filters"
            app:navigationIcon="@drawable/ic_back"
            app:menu="@menu/filters_menu" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="?attr/actionBarSize"
        android:fillViewport="true"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg">

            <!-- Search Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.Edham.Card.Elevated"
                android:layout_marginBottom="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Search Shipments"
                        style="@style/TextAppearance.Edham.LabelMedium"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <!-- Search Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/search_input_layout"
                        style="@style/Widget.Edham.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Search by ID, customer, or location"
                        app:startIconDrawable="@drawable/ic_search"
                        app:startIconTint="@color/text_tertiary"
                        app:endIconDrawable="@drawable/ic_clear"
                        app:endIconTint="@color/text_tertiary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/search_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:maxLines="1" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Quick Search Options -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="@dimen/spacing_md">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/quick_today"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/spacing_sm"
                            android:text="Today"
                            app:chipBackgroundColor="@color/color_info_100"
                            android:textColor="@color/color_info_700"
                            android:checkable="true" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/quick_delayed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/spacing_sm"
                            android:text="Delayed"
                            app:chipBackgroundColor="@color/color_error_100"
                            android:textColor="@color/color_error_700"
                            android:checkable="true" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/quick_priority"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Priority"
                            app:chipBackgroundColor="@color/color_warning_100"
                            android:textColor="@color/color_warning_700"
                            android:checkable="true" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Status Filters -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.Edham.Card.Elevated"
                android:layout_marginBottom="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/spacing_md">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Status"
                            style="@style/TextAppearance.Edham.LabelMedium"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:id="@+id/status_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 selected"
                            style="@style/TextAppearance.Edham.LabelSmall"
                            android:textColor="@color/text_tertiary" />

                    </LinearLayout>

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/status_chip_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:selectionRequired="false"
                        app:chipSpacingHorizontal="@dimen/spacing_sm"
                        app:chipSpacingVertical="@dimen/spacing_sm">

                        <com.google.android.material.chip.Chip
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Created"
                            app:chipBackgroundColor="@color/surface_variant"
                            android:textColor="@color/text_primary"
                            android:checkable="true" />

                        <com.google.android.material.chip.Chip
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Assigned"
                            app:chipBackgroundColor="@color/color_primary_100"
                            android:textColor="@color/color_primary_700"
                            android:checkable="true" />

                        <com.google.android.material.chip.Chip
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="In Transit"
                            app:chipBackgroundColor="@color/color_warning_100"
                            android:textColor="@color/color_warning_700"
                            android:checkable="true" />

                        <com.google.android.material.chip.Chip
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Delivered"
                            app:chipBackgroundColor="@color/color_success_100"
                            android:textColor="@color/color_success_700"
                            android:checkable="true" />

                        <com.google.android.material.chip.Chip
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cancelled"
                            app:chipBackgroundColor="@color/color_error_100"
                            android:textColor="@color/color_error_700"
                            android:checkable="true" />

                    </com.google.android.material.chip.ChipGroup>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Priority Filters -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.Edham.Card.Elevated"
                android:layout_marginBottom="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/spacing_md">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Priority"
                            style="@style/TextAppearance.Edham.LabelMedium"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:id="@+id/priority_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 selected"
                            style="@style/TextAppearance.Edham.LabelSmall"
                            android:textColor="@color/text_tertiary" />

                    </LinearLayout>

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/priority_chip_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:selectionRequired="false"
                        app:chipSpacingHorizontal="@dimen/spacing_sm">

                        <com.google.android.material.chip.Chip
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Critical"
                            app:chipBackgroundColor="@color/color_error_100"
                            android:textColor="@color/color_error_700"
                            android:checkable="true" />

                        <com.google.android.material.chip.Chip
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="High"
                            app:chipBackgroundColor="@color/color_warning_100"
                            android:textColor="@color/color_warning_700"
                            android:checkable="true" />

                        <com.google.android.material.chip.Chip
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Normal"
                            app:chipBackgroundColor="@color/color_info_100"
                            android:textColor="@color/color_info_700"
                            android:checkable="true" />

                        <com.google.android.material.chip.Chip
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Low"
                            app:chipBackgroundColor="@color/color_success_100"
                            android:textColor="@color/color_success_700"
                            android:checkable="true" />

                    </com.google.android.material.chip.ChipGroup>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Date Range Filter -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.Edham.Card.Elevated"
                android:layout_marginBottom="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/spacing_md">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Date Range"
                            style="@style/TextAppearance.Edham.LabelMedium"
                            android:textColor="@color/text_secondary" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/clear_dates"
                            style="@style/Widget.Edham.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Clear"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <!-- Date Options -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="@dimen/spacing_md">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/today_button"
                            style="@style/Widget.Edham.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="@dimen/spacing_sm"
                            android:text="Today"
                            android:textSize="12sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/week_button"
                            style="@style/Widget.Edham.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="@dimen/spacing_sm"
                            android:text="This Week"
                            android:textSize="12sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/month_button"
                            style="@style/Widget.Edham.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="This Month"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <!-- Custom Date Range -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/date_from_layout"
                            style="@style/Widget.Edham.TextInputLayout.OutlinedBox"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="@dimen/spacing_md"
                            android:hint="From"
                            app:startIconDrawable="@drawable/ic_calendar"
                            app:startIconTint="@color/text_tertiary">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/date_from"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="date"
                                android:focusable="false"
                                android:clickable="true" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/date_to_layout"
                            style="@style/Widget.Edham.TextInputLayout.OutlinedBox"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="To"
                            app:startIconDrawable="@drawable/ic_calendar"
                            app:startIconTint="@color/text_tertiary">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/date_to"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="date"
                                android:focusable="false"
                                android:clickable="true" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Special Filters -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.Edham.Card.Elevated"
                android:layout_marginBottom="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Special Filters"
                        style="@style/TextAppearance.Edham.LabelMedium"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/special_chip_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:selectionRequired="false"
                        app:chipSpacingHorizontal="@dimen/spacing_sm"
                        app:chipSpacingVertical="@dimen/spacing_sm">

                        <com.google.android.material.chip.Chip
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cold Chain"
                            app:chipBackgroundColor="@color/ice_blue_100"
                            android:textColor="@color/ice_blue_700"
                            android:checkable="true" />

                        <com.google.android.material.chip.Chip
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Multi-Stop"
                            app:chipBackgroundColor="@color/purple_100"
                            android:textColor="@color/purple_700"
                            android:checkable="true" />

                        <com.google.android.material.chip.Chip
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Express"
                            app:chipBackgroundColor="@color/orange_100"
                            android:textColor="@color/orange_700"
                            android:checkable="true" />

                        <com.google.android.material.chip.Chip
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="International"
                            app:chipBackgroundColor="@color/teal_100"
                            android:textColor="@color/teal_700"
                            android:checkable="true" />

                        <com.google.android.material.chip.Chip
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fragile"
                            app:chipBackgroundColor="@color/pink_100"
                            android:textColor="@color/pink_700"
                            android:checkable="true" />

                        <com.google.android.material.chip.Chip
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Insurance"
                            app:chipBackgroundColor="@color/indigo_100"
                            android:textColor="@color/indigo_700"
                            android:checkable="true" />

                    </com.google.android.material.chip.ChipGroup>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Saved Filters -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.Edham.Card.Elevated"
                android:layout_marginBottom="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/spacing_md">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Saved Filters"
                            style="@style/TextAppearance.Edham.LabelMedium"
                            android:textColor="@color/text_secondary" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/save_current_filter"
                            style="@style/Widget.Edham.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Save Current"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/saved_filters_recycler_view"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        tools:listitem="@layout/item_saved_filter" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/spacing_lg">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/clear_all_filters"
                    style="@style/Widget.Edham.Button.Secondary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/spacing_md"
                    android:text="Clear All" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/apply_filters"
                    style="@style/Widget.Edham.Button.Primary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Apply Filters" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Filter Summary Bar -->
    <LinearLayout
        android:id="@+id/filter_summary_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/surface_variant"
        android:paddingHorizontal="@dimen/spacing_md"
        android:paddingVertical="@dimen/spacing_sm"
        android:layout_gravity="bottom"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="5 filters applied"
            style="@style/TextAppearance.Edham.LabelSmall"
            android:textColor="@color/text_secondary"
            tools:text="5 filters applied" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/remove_filters"
            style="@style/Widget.Edham.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Remove"
            android:textSize="12sp" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
