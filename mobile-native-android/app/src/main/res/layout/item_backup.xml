<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Backup Icon -->
        <ImageView
            android:id="@+id/imageBackupType"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_backup"
            android:tint="@color/primary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Backup Name -->
        <TextView
            android:id="@+id/textBackupName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:text="Backup Name"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintStart_toEndOf="@id/imageBackupType"
            app:layout_constraintEnd_toStartOf="@id/textBackupSize"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Backup Size -->
        <TextView
            android:id="@+id/textBackupSize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 MB"
            android:textSize="14sp"
            android:textColor="@color/gray_600"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Backup Type -->
        <TextView
            android:id="@+id/textBackupType"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Manual Backup"
            android:textSize="14sp"
            android:textColor="@color/gray_600"
            app:layout_constraintStart_toStartOf="@id/imageBackupType"
            app:layout_constraintEnd_toStartOf="@id/textBackupDate"
            app:layout_constraintTop_toBottomOf="@id/textBackupName" />

        <!-- Backup Date -->
        <TextView
            android:id="@+id/textBackupDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:text="2024-01-01 12:00"
            android:textSize="14sp"
            android:textColor="@color/gray_600"
            app:layout_constraintEnd_toStartOf="@id/textBackupStatus"
            app:layout_constraintTop_toBottomOf="@id/textBackupName" />

        <!-- Backup Status -->
        <TextView
            android:id="@+id/textBackupStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Completed"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/success"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/textBackupName" />

        <!-- Encryption Status -->
        <ImageView
            android:id="@+id/imageEncryption"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginTop="8dp"
            android:src="@drawable/ic_lock"
            android:tint="@color/gray_400"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="@id/imageBackupType"
            app:layout_constraintTop_toBottomOf="@id/textBackupType" />

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:gravity="end"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/imageEncryption">

            <TextView
                android:id="@+id/buttonRestore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="استعادة"
                android:textSize="14sp"
                android:textColor="@color/primary"
                android:background="@drawable/bg_button_outline"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/buttonDownload"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="تحميل"
                android:textSize="14sp"
                android:textColor="@color/gray_600"
                android:background="@drawable/bg_button_outline"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/buttonDelete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="حذف"
                android:textSize="14sp"
                android:textColor="@color/red"
                android:background="@drawable/bg_button_outline" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
