<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/ed_navy_3"
    app:cardCornerRadius="10dp"
    app:strokeColor="@color/ed_border_new"
    app:strokeWidth="1dp"
    android:layout_marginBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvOrderId"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:text="#PR-882"
            android:textColor="@color/ed_sky"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tvOrderName"
                style="@style/SupervisorText.Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="كمبروسور ثرمو كينج"
                android:textSize="12sp" />
            <TextView
                android:id="@+id/tvOrderDetails"
                style="@style/SupervisorText.Subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="المبلغ: 3,400 ج.م · الكمية: 1"
                android:textSize="11sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvOrderStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_role_badge"
            android:backgroundTint="#26C07820"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="⏳ انتظار"
            android:textColor="@color/ed_copper_new"
            android:textSize="11sp"
            android:textStyle="bold" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
