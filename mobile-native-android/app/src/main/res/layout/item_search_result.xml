<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- Entity Type Icon -->
        <ImageView
            android:id="@+id/ivEntityTypeIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="12dp"
            android:src="@drawable/ic_shipment"
            android:background="@drawable/bg_circle_light"
            android:padding="8dp"
            android:tint="@color/primary" />

        <!-- Result Content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Title and Type -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="شحنة #12345"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvEntityType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="شحنة"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:background="@drawable/bg_entity_type_tag"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp" />

            </LinearLayout>

            <!-- Description -->
            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="شحنة من الرياض إلى جدة - حالة: قيد التوصيل"
                android:textColor="@color/gray_700"
                android:textSize="12sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginBottom="4dp" />

            <!-- Highlights -->
            <LinearLayout
                android:id="@+id/layoutHighlights"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvHighlights"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="تسليط على: الرياض"
                    android:textColor="@color/gray_600"
                    android:textSize="11sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

            </LinearLayout>

            <!-- Metadata -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Status -->
                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="نشط"
                    android:textColor="@color/green_500"
                    android:textSize="10sp"
                    android:background="@drawable/bg_status_tag"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:layout_marginEnd="8dp" />

                <!-- Priority -->
                <TextView
                    android:id="@+id/tvPriority"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="عادي"
                    android:textColor="@color/blue_500"
                    android:textSize="10sp"
                    android:background="@drawable/bg_priority_tag"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:layout_marginEnd="8dp" />

                <!-- Timestamp -->
                <TextView
                    android:id="@+id/tvTimestamp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="منذ 2 ساعة"
                    android:textColor="@color/gray_500"
                    android:textSize="10sp" />

                <!-- Relevance Score -->
                <TextView
                    android:id="@+id/tvRelevanceScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="95%"
                    android:textColor="@color/gray_500"
                    android:textSize="10sp"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- Additional Details -->
            <LinearLayout
                android:id="@+id/layoutAdditionalDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp"
                android:visibility="gone">

                <!-- Separator -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/gray_200"
                    android:layout_marginBottom="8dp" />

                <!-- Details Grid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Left Column -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvCustomerName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="العميل: أحمد محمد"
                            android:textColor="@color/gray_600"
                            android:textSize="10sp"
                            android:layout_marginBottom="2dp" />

                        <TextView
                            android:id="@+id/tvDriverName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="السائق: محمد علي"
                            android:textColor="@color/gray_600"
                            android:textSize="10sp"
                            android:layout_marginBottom="2dp" />

                        <TextView
                            android:id="@+id/tvVehicleInfo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="المركبة: Toyota Hilux"
                            android:textColor="@color/gray_600"
                            android:textSize="10sp" />

                    </LinearLayout>

                    <!-- Right Column -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvEstimatedDelivery"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="التوصيل المتوقع: 2024-12-25"
                            android:textColor="@color/gray_600"
                            android:textSize="10sp"
                            android:layout_marginBottom="2dp" />

                        <TextView
                            android:id="@+id/tvLocation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="الموقع الحالي: الرياض"
                            android:textColor="@color/gray_600"
                            android:textSize="10sp"
                            android:layout_marginBottom="2dp" />

                        <TextView
                            android:id="@+id/tvWeight"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="الوزن: 500 كجم"
                            android:textColor="@color/gray_600"
                            android:textSize="10sp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Tags -->
                <LinearLayout
                    android:id="@+id/layoutTags"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:id="@+id/tvTag1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="سريع"
                        android:textColor="@color/white"
                        android:textSize="8sp"
                        android:background="@drawable/bg_tag_blue"
                        android:paddingHorizontal="4dp"
                        android:paddingVertical="2dp"
                        android:layout_marginEnd="4dp" />

                    <TextView
                        android:id="@+id/tvTag2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="مهم"
                        android:textColor="@color/white"
                        android:textSize="8sp"
                        android:background="@drawable/bg_tag_orange"
                        android:paddingHorizontal="4dp"
                        android:paddingVertical="2dp"
                        android:layout_marginEnd="4dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Action Menu -->
        <ImageButton
            android:id="@+id/btnMoreActions"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_more_vert"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:tint="@color/gray_600"
            android:layout_gravity="center_vertical" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
