<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- Checkbox for selection -->
        <CheckBox
            android:id="@+id/checkboxLog"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="12dp"
            android:visibility="gone" />

        <!-- Severity Indicator -->
        <View
            android:id="@+id/viewSeverityIndicator"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_severity_indicator" />

        <!-- Log Content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Header Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <!-- Action Icon -->
                <ImageView
                    android:id="@+id/ivActionIcon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginEnd="8dp"
                    android:src="@drawable/ic_info"
                    android:tint="@color/gray_600" />

                <!-- Action and Description -->
                <TextView
                    android:id="@+id/tvActionDescription"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="User logged in successfully"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <!-- Severity Badge -->
                <TextView
                    android:id="@+id/tvSeverity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="INFO"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:background="@drawable/bg_severity_tag"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp" />

            </LinearLayout>

            <!-- User and Entity Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <!-- User Info -->
                <TextView
                    android:id="@+id/tvUserInfo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="أحمد محمد (admin)"
                    android:textColor="@color/gray_700"
                    android:textSize="12sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <!-- Entity Info -->
                <TextView
                    android:id="@+id/tvEntityInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="User: ahmed@example.com"
                    android:textColor="@color/gray_600"
                    android:textSize="10sp"
                    android:background="@drawable/bg_entity_tag"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <!-- Details Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Timestamp -->
                <TextView
                    android:id="@+id/tvTimestamp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="منذ 5 دقائق"
                    android:textColor="@color/gray_500"
                    android:textSize="10sp" />

                <!-- Success Indicator -->
                <ImageView
                    android:id="@+id/ivSuccessIndicator"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_check_circle"
                    android:tint="@color/green_500"
                    android:layout_marginStart="8dp" />

                <!-- IP Address -->
                <TextView
                    android:id="@+id/tvIpAddress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="192.168.1.1"
                    android:textColor="@color/gray_500"
                    android:textSize="10sp"
                    android:layout_marginStart="8dp"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- Expandable Details -->
            <LinearLayout
                android:id="@+id/layoutExpandableDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp"
                android:visibility="gone">

                <!-- Separator -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/gray_200"
                    android:layout_marginBottom="8dp" />

                <!-- Additional Details -->
                <TextView
                    android:id="@+id/tvAdditionalDetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Additional details..."
                    android:textColor="@color/gray_700"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp" />

                <!-- Device and Location Info -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvDeviceInfo"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Device: Android"
                        android:textColor="@color/gray_600"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/tvLocation"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Location: Riyadh"
                        android:textColor="@color/gray_600"
                        android:textSize="10sp"
                        android:gravity="end" />

                </LinearLayout>

                <!-- Session Info -->
                <TextView
                    android:id="@+id/tvSessionInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Session: abc123"
                    android:textColor="@color/gray_600"
                    android:textSize="10sp"
                    android:layout_marginTop="4dp" />

                <!-- Error Message (if any) -->
                <TextView
                    android:id="@+id/tvErrorMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Error message..."
                    android:textColor="@color/red_500"
                    android:textSize="10sp"
                    android:layout_marginTop="4dp"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>

        <!-- Action Menu -->
        <ImageButton
            android:id="@+id/btnMoreActions"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_more_vert"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:tint="@color/gray_600"
            android:layout_gravity="center_vertical" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
