<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#001D39">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#062E54"
        android:elevation="4dp"
        app:navigationIcon="@color/white"
        app:title="تتبع GPS"
        app:titleTextColor="@android:color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Map Fragment -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_margin="16dp"
                android:background="#062E54">

                <fragment
                    android:id="@+id/mapFragment"
                    android:name="com.google.android.gms.maps.SupportMapFragment"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

            </FrameLayout>

            <!-- GPS Status Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/gpsStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="جاري الاتصال بـ GPS..."
                    android:textColor="#7BBDE8"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/accuracyText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="الدقة: --"
                    android:textColor="#A0FFFFFF"
                    android:textSize="13sp"
                    android:paddingBottom="4dp" />

                <TextView
                    android:id="@+id/speedText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="السرعة: --"
                    android:textColor="#A0FFFFFF"
                    android:textSize="13sp"
                    android:paddingBottom="4dp" />

                <TextView
                    android:id="@+id/latitudeText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="خط العرض: --"
                    android:textColor="#A0FFFFFF"
                    android:textSize="13sp"
                    android:paddingBottom="4dp" />

                <TextView
                    android:id="@+id/longitudeText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="خط الطول: --"
                    android:textColor="#A0FFFFFF"
                    android:textSize="13sp"
                    android:paddingBottom="4dp" />

            </LinearLayout>

            <!-- Dashboard Content -->
            <LinearLayout
                android:id="@+id/gpsContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
