<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardBackgroundColor="@color/supervisor_card"
    app:strokeWidth="1dp"
    app:strokeColor="@color/supervisor_card_stroke"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Setting Icon -->
        <ImageView
            android:id="@+id/ivSettingIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_settings"
            android:layout_marginEnd="16dp" />

        <!-- Setting Content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvSettingTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="الإشعارات"
                android:textColor="@color/supervisor_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSettingDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="تفعيل الإشعارات الفورية"
                android:textColor="@color/supervisor_text_secondary"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- Setting Value (for non-toggle settings) -->
        <TextView
            android:id="@+id/tvSettingValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="العربية"
            android:textColor="@color/supervisor_text_primary"
            android:textSize="14sp"
            android:background="@drawable/supervisor_info_transparent"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:visibility="gone" />

        <!-- Setting Toggle (for boolean settings) -->
        <Switch
            android:id="@+id/swSettingToggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:thumbTint="@color/supervisor_primary"
            android:trackTint="@color/supervisor_primary_transparent" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
