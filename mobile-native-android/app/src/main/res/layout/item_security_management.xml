<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardBackgroundColor="@color/supervisor_card"
    app:strokeWidth="1dp"
    app:strokeColor="@color/supervisor_card_stroke"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Security Icon -->
        <ImageView
            android:id="@+id/ivSecurityIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_security"
            android:layout_marginEnd="16dp" />

        <!-- Security Content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvSettingTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="تغيير كلمة المرور"
                android:textColor="@color/supervisor_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSettingDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="تحديث كلمة المرور الخاصة بك"
                android:textColor="@color/supervisor_text_secondary"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="إدارة"
                android:textColor="@color/supervisor_text_hint"
                android:textSize="12sp"
                android:layout_marginTop="2dp"
                android:background="@drawable/time_badge_background"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp" />

        </LinearLayout>

        <!-- Arrow Icon -->
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_arrow_forward"
            android:tint="@color/supervisor_text_hint" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
