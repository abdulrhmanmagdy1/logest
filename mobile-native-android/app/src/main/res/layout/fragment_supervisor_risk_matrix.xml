<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ed_deep">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                style="@style/SupervisorText.Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="مصفوفة مخاطر الأسطول (AI)"
                android:textSize="20sp" />

            <TextView
                style="@style/SupervisorText.Subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="تنبؤات الذكاء الاصطناعي بالأعطال والحوادث الوشيكة" />

            <!-- Risk Heatmap Simulation -->
            <com.google.android.material.card.MaterialCardView
                style="@style/SupervisorCard"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="@color/ed_navy_2"
                app:strokeColor="@color/ed_rust"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">
                    <TextView android:text="خريطة تركز المخاطر اللحظية" android:textColor="@color/ed_text_muted_new" android:textSize="10sp" android:layout_marginBottom="12dp"/>
                    <com.github.mikephil.charting.charts.BubbleChart
                        android:id="@+id/riskHeatmap"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Predictive Alerts -->
            <TextView
                style="@style/SupervisorText.Title"
                android:text="🚨 تنبؤات حرجة (High Risk)"
                android:textSize="15sp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.card.MaterialCardView
                style="@style/SupervisorCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/ed_navy_3">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:gravity="center_vertical">
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="🚚" android:textSize="20sp" android:gravity="center" android:background="@drawable/bg_stat_icon_teal" android:backgroundTint="@color/ed_rust_15"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:orientation="vertical">
                        <TextView style="@style/SupervisorText.Title" android:text="شاحنة #T-211" android:textSize="14sp"/>
                        <TextView style="@style/SupervisorText.Subtitle" android:text="احتمالية عطل في المحرك بنسبة 85% خلال 200 كم" android:textColor="@color/ed_rust_2" android:textSize="10sp"/>
                    </LinearLayout>
                    <TextView android:text="حرج" android:textColor="@color/ed_rust_2" android:textStyle="bold" android:textSize="11sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/SupervisorCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/ed_navy_3">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:gravity="center_vertical">
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="❄️" android:textSize="20sp" android:gravity="center" android:background="@drawable/bg_stat_icon_teal" android:backgroundTint="@color/ed_copper_20"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:orientation="vertical">
                        <TextView style="@style/SupervisorText.Title" android:text="دينا تبريد #D-04" android:textSize="14sp"/>
                        <TextView style="@style/SupervisorText.Subtitle" android:text="إجهاد حراري مرتفع - يوصى بفحص غاز الفريون" android:textColor="@color/ed_copper_new" android:textSize="10sp"/>
                    </LinearLayout>
                    <TextView android:text="تحذير" android:textColor="@color/ed_copper_new" android:textStyle="bold" android:textSize="11sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
