<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".shipment.ShipmentTimelineTrackingFragment">

    <!-- App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/overlay_light"
        app:elevation="4dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Shipment Timeline"
            app:navigationIcon="@drawable/ic_back"
            app:menu="@menu/timeline_menu" />

        <!-- Timeline Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_md"
            android:paddingVertical="@dimen/spacing_sm"
            android:gravity="center_vertical"
            android:background="@color/surface_variant">

            <!-- Filter Chips -->
            <HorizontalScrollView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:scrollbars="none">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/filter_chip_group"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:selectionRequired="false"
                    app:chipSpacingHorizontal="@dimen/spacing_sm">

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="All Events"
                        app:chipBackgroundColor="@color/color_primary_100"
                        android:textColor="@color/color_primary_700"
                        android:checkable="true"
                        android:checked="true" />

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Milestones"
                        app:chipBackgroundColor="@color/color_success_100"
                        android:textColor="@color/color_success_700"
                        android:checkable="true" />

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Issues"
                        app:chipBackgroundColor="@color/color_error_100"
                        android:textColor="@color/color_error_700"
                        android:checkable="true" />

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Location"
                        app:chipBackgroundColor="@color/color_info_100"
                        android:textColor="@color/color_info_700"
                        android:checkable="true" />

                </com.google.android.material.chip.ChipGroup>

            </HorizontalScrollView>

            <!-- View Toggle -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/rounded_background"
                android:backgroundTint="@color/outline_primary"
                android:padding="2dp"
                android:layout_marginStart="@dimen/spacing_md">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/timeline_view"
                    style="@style/Widget.Edham.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="0dp"
                    android:paddingHorizontal="@dimen/spacing_sm"
                    android:paddingVertical="@dimen/spacing_xs"
                    android:text="Timeline"
                    android:textSize="12sp"
                    app:backgroundTint="@color/primary_container"
                    app:rippleColor="@color/primary_container" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/map_view"
                    style="@style/Widget.Edham.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="0dp"
                    android:paddingHorizontal="@dimen/spacing_sm"
                    android:paddingVertical="@dimen/spacing_xs"
                    android:text="Map"
                    android:textSize="12sp"
                    app:backgroundTint="@android:color/transparent"
                    app:rippleColor="@color/primary_container" />

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/timeline_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="?attr/actionBarSize"
        android:fillViewport="true"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg">

            <!-- Shipment Overview Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.Edham.Card.Elevated"
                android:layout_marginBottom="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <!-- Shipment Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/spacing_md">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_marginEnd="@dimen/spacing_md"
                            android:src="@drawable/ic_package"
                            app:tint="@color/color_primary_500" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/shipment_id"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SHP-2024-001234"
                                style="@style/TextAppearance.Edham.LabelMedium"
                                android:textColor="@color/text_secondary"
                                tools:text="SHP-2024-001234" />

                            <TextView
                                android:id="@+id/shipment_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="In Transit"
                                style="@style/TextAppearance.Edham.TitleMedium"
                                android:textColor="@color/text_primary"
                                tools:text="In Transit" />

                        </LinearLayout>

                        <!-- Status Badge -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/status_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/Widget.Edham.Card.Status"
                            app:cardBackgroundColor="@color/color_info_100">

                            <TextView
                                android:id="@+id/status_badge_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ACTIVE"
                                style="@style/TextAppearance.Edham.LabelSmall"
                                android:textColor="@color/color_info_700"
                                android:paddingHorizontal="@dimen/spacing_sm"
                                android:paddingVertical="@dimen/spacing_xs"
                                tools:text="ACTIVE" />

                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                    <!-- Progress Info -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/spacing_md">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Progress"
                            style="@style/TextAppearance.Edham.LabelMedium"
                            android:textColor="@color/text_secondary"
                            android:layout_marginEnd="@dimen/spacing_md" />

                        <ProgressBar
                            android:id="@+id/shipment_progress"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:progressTint="@color/color_primary_500"
                            android:progress="65"
                            tools:progress="65" />

                        <TextView
                            android:id="@+id/progress_percentage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="65%"
                            style="@style/TextAppearance.Edham.LabelMedium"
                            android:textColor="@color/text_secondary"
                            android:layout_marginStart="@dimen/spacing_md"
                            tools:text="65%" />

                    </LinearLayout>

                    <!-- Route Info -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/spacing_md">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginEnd="@dimen/spacing_sm"
                            android:src="@drawable/ic_route"
                            app:tint="@color/text_tertiary" />

                        <TextView
                            android:id="@+id/route_info"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Riyadh → Jeddah"
                            style="@style/TextAppearance.Edham.LabelMedium"
                            android:textColor="@color/text_secondary"
                            tools:text="Riyadh → Jeddah" />

                    </LinearLayout>

                    <!-- Time Info -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginEnd="@dimen/spacing_sm"
                            android:src="@drawable/ic_clock"
                            app:tint="@color/text_tertiary" />

                        <TextView
                            android:id="@+id/time_info"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Started 2 hours ago • ETA Tomorrow, 3:30 PM"
                            style="@style/TextAppearance.Edham.LabelMedium"
                            android:textColor="@color/text_secondary"
                            tools:text="Started 2 hours ago • ETA Tomorrow, 3:30 PM" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Timeline Events -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/timeline_recycler_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_timeline_event" />

            <!-- Loading Indicator -->
            <LinearLayout
                android:id="@+id/loading_indicator"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="@dimen/spacing_xxxl"
                android:visibility="gone"
                tools:visibility="visible">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:indeterminate="true"
                    app:indicatorColor="@color/color_primary_500"
                    app:indicatorSize="48dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loading timeline..."
                    style="@style/TextAppearance.Edham.LabelMedium"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="@dimen/spacing_md" />

            </LinearLayout>

            <!-- Empty State -->
            <LinearLayout
                android:id="@+id/empty_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="@dimen/spacing_xxxl"
                android:visibility="gone"
                tools:visibility="visible">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_marginBottom="@dimen/spacing_lg"
                    android:src="@drawable/ic_timeline_empty"
                    app:tint="@color/text_tertiary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No Timeline Events"
                    style="@style/TextAppearance.Edham.TitleMedium"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Timeline events will appear here once the shipment is in transit"
                    style="@style/TextAppearance.Edham.BodyMedium"
                    android:textColor="@color/text_tertiary"
                    android:gravity="center"
                    android:layout_marginBottom="@dimen/spacing_lg" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/refresh_button"
                    style="@style/Widget.Edham.Button.Secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Refresh" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Map View (Hidden by default) -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/map_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="?attr/actionBarSize"
        android:visibility="gone"
        android:name="com.google.android.gms.maps.SupportMapFragment" />

    <!-- Floating Action Buttons -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="@dimen/spacing_lg"
        android:orientation="vertical">

        <!-- Export FAB -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_export"
            style="@style/Widget.Edham.Button.FAB.Mini"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            app:srcCompat="@drawable/ic_export"
            app:tint="@color/text_on_primary" />

        <!-- Refresh FAB -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_refresh"
            style="@style/Widget.Edham.Button.FAB.Mini"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:srcCompat="@drawable/ic_refresh"
            app:tint="@color/text_on_primary" />

    </LinearLayout>

    <!-- Event Details Bottom Sheet -->
    <LinearLayout
        android:id="@+id/event_details_bottom_sheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bottom_sheet_background"
        android:padding="@dimen/spacing_lg"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_hideable="true"
        app:behavior_peekHeight="0dp"
        android:visibility="gone">

        <!-- Event Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/spacing_lg">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Event Details"
                style="@style/TextAppearance.Edham.TitleMedium"
                android:textColor="@color/text_primary" />

            <ImageView
                android:id="@+id/close_details"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_close"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="@dimen/spacing_xs"
                app:tint="@color/text_tertiary" />

        </LinearLayout>

        <!-- Event Content -->
        <LinearLayout
            android:id="@+id/event_details_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Event details will be populated dynamically -->

        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
