<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/customer_bg_primary">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/customer_bg_secondary"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_back"
            app:title="ميثاق العملاء"
            app:titleTextColor="@color/html_white" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="التزامنا تجاهكم"
                android:textColor="@color/prem_sky"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="في مؤسسة ادهام، نضع رضاكم في مقدمة أولوياتنا. نلتزم بتقديم خدمات لوجستية تتسم بالشفافية، السرعة، والأمان الفائق لبضائعكم."
                android:textColor="@color/html_white"
                android:textSize="14sp"
                android:lineSpacingExtra="6dp"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. دقة المواعيد\nنحرص دائماً على تسليم الشحنات في وقتها المحدد لضمان استمرارية أعمالكم."
                android:textColor="@color/customer_text_muted"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="2. سلامة سلسلة التبريد\nنضمن الحفاظ على درجات الحرارة المطلوبة من لحظة الاستلام وحتى التسليم."
                android:textColor="@color/customer_text_muted"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="3. الشفافية والتتبع\nنوفر لكم تتبعاً مباشراً لحظة بلحظة لكل شحنة عبر تطبيقنا الذكي."
                android:textColor="@color/customer_text_muted"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="16dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
