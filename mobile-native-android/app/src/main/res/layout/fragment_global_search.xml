<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_50"
    tools:context=".feature.search.presentation.ui.GlobalSearchFragment">

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Search Header -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Search Mode Toggle -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="البحث العالمي"
                        android:textColor="@color/black"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAdvancedSearch"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="بحث متقدم"
                        android:textColor="@color/primary"
                        android:textSize="12sp"
                        app:backgroundTint="@color/transparent"
                        app:cornerRadius="4dp"
                        app:strokeColor="@color/primary"
                        app:strokeWidth="1dp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                </LinearLayout>

                <!-- Search Input -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilSearch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    app:boxStrokeColor="@color/primary"
                    app:hintTextColor="@color/primary"
                    app:startIconDrawable="@drawable/ic_search"
                    app:endIconMode="clear_text"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSearch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="ابحث في الشحنات، المستخدمين، المركبات، الفواتير..."
                        android:inputType="text"
                        android:textSize="14sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Search Suggestions -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvSuggestions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    tools:listitem="@layout/item_search_suggestion" />

                <!-- Quick Filters -->
                <LinearLayout
                    android:id="@+id/layoutQuickFilters"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <com.google.android.material.chip.ChipGroup
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipShipments"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="الشحنات"
                            android:textSize="12sp"
                            app:chipBackgroundColor="@color/primary_light"
                            app:chipCornerRadius="16dp"
                            style="@style/Widget.MaterialComponents.Chip.Filter" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipUsers"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="المستخدمين"
                            android:textSize="12sp"
                            style="@style/Widget.MaterialComponents.Chip.Filter" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipVehicles"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="المركبات"
                            android:textSize="12sp"
                            style="@style/Widget.MaterialComponents.Chip.Filter" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipInvoices"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="الفواتير"
                            android:textSize="12sp"
                            style="@style/Widget.MaterialComponents.Chip.Filter" />

                    </com.google.android.material.chip.ChipGroup>

                    <ImageButton
                        android:id="@+id/btnMoreFilters"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_filter"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:tint="@color/primary"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Advanced Filters Panel -->
        <LinearLayout
            android:id="@+id/layoutAdvancedFilters"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Date Range Filter -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="نطاق التاريخ"
                            android:textColor="@color/black"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvDateRange"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="كل الوقت"
                            android:textColor="@color/primary"
                            android:textSize="12sp"
                            android:background="?android:attr/selectableItemBackground"
                            android:padding="8dp" />

                    </LinearLayout>

                    <!-- Status Filter -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="الحالة"
                            android:textColor="@color/black"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvStatusFilter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="الكل"
                            android:textColor="@color/primary"
                            android:textSize="12sp"
                            android:background="?android:attr/selectableItemBackground"
                            android:padding="8dp" />

                    </LinearLayout>

                    <!-- Role Filter -->
                    <LinearLayout
                        android:id="@+id/layoutRoleFilter"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="الدور"
                            android:textColor="@color/black"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvRoleFilter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="الكل"
                            android:textColor="@color/primary"
                            android:textSize="12sp"
                            android:background="?android:attr/selectableItemBackground"
                            android:padding="8dp" />

                    </LinearLayout>

                    <!-- Location Filter -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="الموقع"
                            android:textColor="@color/black"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvLocationFilter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="الكل"
                            android:textColor="@color/primary"
                            android:textSize="12sp"
                            android:background="?android:attr/selectableItemBackground"
                            android:padding="8dp" />

                    </LinearLayout>

                    <!-- Filter Actions -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="end">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnClearFilters"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:text="مسح الفلاتر"
                            android:textColor="@color/primary"
                            android:textSize="12sp"
                            android:layout_marginEnd="8dp"
                            app:backgroundTint="@color/transparent"
                            app:cornerRadius="4dp"
                            app:strokeColor="@color/primary"
                            app:strokeWidth="1dp"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnApplyFilters"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:text="تطبيق"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            app:backgroundTint="@color/primary"
                            app:cornerRadius="4dp"
                            style="@style/Widget.MaterialComponents.Button.TextButton" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Search Results Header -->
        <LinearLayout
            android:id="@+id/layoutResultsHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvResultsCount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0 نتيجة"
                android:textColor="@color/black"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="الترتيب:"
                    android:textColor="@color/gray_600"
                    android:textSize="12sp"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/tvSortBy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="الصلة"
                    android:textColor="@color/primary"
                    android:textSize="12sp"
                    android:background="?android:attr/selectableItemBackground"
                    android:padding="4dp" />

                <ImageButton
                    android:id="@+id/btnSortOrder"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_arrow_down"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:tint="@color/primary"
                    android:layout_marginStart="4dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Search Results -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSearchResults"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingHorizontal="16dp"
            android:clipToPadding="false"
            tools:listitem="@layout/item_search_result" />

        <!-- Empty State -->
        <LinearLayout
            android:id="@+id/layoutEmptyState"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginBottom="16dp"
                android:src="@drawable/ic_search"
                android:tint="@color/gray_400" />

            <TextView
                android:id="@+id/tvEmptyTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="لم يتم العثور على نتائج"
                android:textColor="@color/gray_600"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvEmptyDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="جرب تعديل كلمات البحث أو الفلاتر"
                android:textColor="@color/gray_500"
                android:textSize="14sp"
                android:gravity="center" />

        </LinearLayout>

        <!-- Pagination -->
        <LinearLayout
            android:id="@+id/layoutPagination"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="16dp"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPreviousPage"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="السابق"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:layout_marginEnd="8dp"
                app:backgroundTint="@color/transparent"
                app:cornerRadius="4dp"
                app:strokeColor="@color/primary"
                app:strokeWidth="1dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            <TextView
                android:id="@+id/tvPageInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1 / 1"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:layout_marginHorizontal="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNextPage"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="التالي"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:layout_marginStart="8dp"
                app:backgroundTint="@color/transparent"
                app:cornerRadius="4dp"
                app:strokeColor="@color/primary"
                app:strokeWidth="1dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        </LinearLayout>

    </LinearLayout>

    <!-- Error Layout -->
    <LinearLayout
        android:id="@+id/layoutError"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginBottom="16dp"
            android:src="@drawable/ic_error"
            android:tint="@color/red_500" />

        <TextView
            android:id="@+id/textError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="حدث خطأ في البحث"
            android:textColor="@color/red_500"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonRetry"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="إعادة المحاولة"
            android:textColor="@color/white"
            app:backgroundTint="@color/red_500"
            app:cornerRadius="8dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
