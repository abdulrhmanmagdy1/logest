<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="الحجم والوزن"
            android:textColor="@color/customer_text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ساعدنا في تقدير التكلفة والمساحة المطلوبة"
            android:textColor="@color/customer_text_muted"
            android:textSize="13sp"
            android:layout_marginBottom="24dp"/>

        <!-- Size Selection -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="الحجم التقديري"
            android:textColor="@color/customer_blue_light"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginBottom="32dp">

            <TextView
                android:id="@+id/size_small"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="صغير"
                android:gravity="center"
                android:padding="14dp"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_btn_pill_dark"
                android:layout_marginEnd="6dp"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/size_medium"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="متوسط"
                android:gravity="center"
                android:padding="14dp"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_btn_pill_dark"
                android:layout_marginHorizontal="3dp"
                android:textSize="13sp"
                android:alpha="0.6"/>

            <TextView
                android:id="@+id/size_large"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="كبير"
                android:gravity="center"
                android:padding="14dp"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_btn_pill_dark"
                android:layout_marginStart="6dp"
                android:textSize="13sp"
                android:alpha="0.6"/>
        </LinearLayout>

        <!-- Weight Slider -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="الوزن الإجمالي"
                android:textColor="@color/customer_blue_light"
                android:textSize="12sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/textWeightValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="50 كجم"
                android:textColor="@color/customer_text_primary"
                android:textSize="16sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Estimate Info Box -->
        <com.google.android.material.slider.Slider
            android:id="@+id/weightSlider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:stepSize="1"
            android:value="50"
            android:valueFrom="1"
            android:valueTo="1000"
            app:thumbColor="@color/customer_blue_primary"
            app:trackColorActive="@color/customer_blue_primary"
            app:trackColorInactive="@color/customer_bg_tertiary" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/customer_blue_dark"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="18dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="التقدير المبدئي"
                    android:textColor="#90CAF9"
                    android:textSize="13sp"/>
                <TextView
                    android:id="@+id/textEstimatePrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="250.00 ريال"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/ed_badge_info"
            android:backgroundTint="#1A2196F3"
            android:padding="12dp"
            android:text="💡 وفر حتى 70٪ على تكاليف الشحن مع إدهام"
            android:textColor="@color/prem_sky"
            android:textSize="11sp"
            android:gravity="center"
            android:textStyle="bold"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
