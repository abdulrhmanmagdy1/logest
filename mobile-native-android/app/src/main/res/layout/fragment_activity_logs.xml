<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_50"
    tools:context=".feature.activitylogs.presentation.ui.ActivityLogsFragment">

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Main Content -->
    <ScrollView
        android:id="@+id/contentLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header with Actions -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="سجل النشاط"
                    android:textColor="@color/black"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/btnRefresh"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_refresh"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:tint="@color/primary"
                        android:layout_marginEnd="8dp" />

                    <ImageButton
                        android:id="@+id/btnExport"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_download"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:tint="@color/primary"
                        android:layout_marginEnd="8dp" />

                    <ImageButton
                        android:id="@+id/btnFilter"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_filter"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:tint="@color/primary" />

                </LinearLayout>

            </LinearLayout>

            <!-- Statistics Cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="4"
                android:layout_marginBottom="16dp">

                <!-- Total Logs -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvTotalLogs"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/black"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="إجمالي السجلات"
                            android:textColor="@color/gray_600"
                            android:textSize="10sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Success Logs -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvSuccessLogs"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/green_500"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ناجح"
                            android:textColor="@color/gray_600"
                            android:textSize="10sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Error Logs -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvErrorLogs"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/red_500"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="خطأ"
                            android:textColor="@color/gray_600"
                            android:textSize="10sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Critical Logs -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvCriticalLogs"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/orange_500"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="حرج"
                            android:textColor="@color/gray_600"
                            android:textSize="10sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Search and Filters -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Search Bar -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilSearch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:boxStrokeColor="@color/primary"
                        app:hintTextColor="@color/primary"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etSearch"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="البحث في السجلات..."
                            android:inputType="text"
                            android:textSize="14sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Filter Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="3">

                        <!-- Category Filter -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilCategoryFilter"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="4dp"
                            android:layout_weight="1"
                            app:boxStrokeColor="@color/primary"
                            app:hintTextColor="@color/primary"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                            <AutoCompleteTextView
                                android:id="@+id/actvCategoryFilter"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="الفئة"
                                android:inputType="none"
                                android:textSize="12sp" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Severity Filter -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilSeverityFilter"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="4dp"
                            android:layout_weight="1"
                            app:boxStrokeColor="@color/primary"
                            app:hintTextColor="@color/primary"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                            <AutoCompleteTextView
                                android:id="@+id/actvSeverityFilter"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="الشدة"
                                android:inputType="none"
                                android:textSize="12sp" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Action Filter -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilActionFilter"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:layout_weight="1"
                            app:boxStrokeColor="@color/primary"
                            app:hintTextColor="@color/primary"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                            <AutoCompleteTextView
                                android:id="@+id/actvActionFilter"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="الإجراء"
                                android:inputType="none"
                                android:textSize="12sp" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                    <!-- Date Range Filter -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnDateRange"
                            android:layout_width="0dp"
                            android:layout_height="32dp"
                            android:layout_weight="1"
                            android:text="نطاق التاريخ"
                            android:textColor="@color/primary"
                            android:textSize="12sp"
                            android:layout_marginEnd="8dp"
                            app:backgroundTint="@color/transparent"
                            app:cornerRadius="4dp"
                            app:strokeColor="@color/primary"
                            app:strokeWidth="1dp"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnClearFilters"
                            android:layout_width="0dp"
                            android:layout_height="32dp"
                            android:layout_weight="1"
                            android:text="مسح الفلاتر"
                            android:textColor="@color/primary"
                            android:textSize="12sp"
                            app:backgroundTint="@color/transparent"
                            app:cornerRadius="4dp"
                            app:strokeColor="@color/primary"
                            app:strokeWidth="1dp"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Bulk Actions -->
            <LinearLayout
                android:id="@+id/bulkActionsLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvSelectedCount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="تم تحديد 0 سجل"
                    android:textColor="@color/black"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBulkDelete"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="حذف"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:layout_marginEnd="4dp"
                    app:backgroundTint="@color/red_500"
                    app:cornerRadius="4dp"
                    style="@style/Widget.MaterialComponents.Button.TextButton" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBulkArchive"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="أرشفة"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:layout_marginEnd="4dp"
                    app:backgroundTint="@color/orange_500"
                    app:cornerRadius="4dp"
                    style="@style/Widget.MaterialComponents.Button.TextButton" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBulkTag"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="وسم"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    app:backgroundTint="@color/blue_500"
                    app:cornerRadius="4dp"
                    style="@style/Widget.MaterialComponents.Button.TextButton" />

            </LinearLayout>

            <!-- Activity Logs List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvActivityLogs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_activity_log_card" />

            <!-- Pagination -->
            <LinearLayout
                android:id="@+id/paginationLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:visibility="gone">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPreviousPage"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="السابق"
                    android:textColor="@color/primary"
                    android:textSize="12sp"
                    android:layout_marginEnd="8dp"
                    app:backgroundTint="@color/transparent"
                    app:cornerRadius="4dp"
                    app:strokeColor="@color/primary"
                    app:strokeWidth="1dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                <TextView
                    android:id="@+id/tvPageInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1 / 1"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:layout_marginHorizontal="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNextPage"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="التالي"
                    android:textColor="@color/primary"
                    android:textSize="12sp"
                    android:layout_marginStart="8dp"
                    app:backgroundTint="@color/transparent"
                    app:cornerRadius="4dp"
                    app:strokeColor="@color/primary"
                    app:strokeWidth="1dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Error Layout -->
    <LinearLayout
        android:id="@+id/layoutError"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginBottom="16dp"
            android:src="@drawable/ic_error"
            android:tint="@color/red_500" />

        <TextView
            android:id="@+id/textError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="حدث خطأ في تحميل سجلات النشاط"
            android:textColor="@color/red_500"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonRetry"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="إعادة المحاولة"
            android:textColor="@color/white"
            app:backgroundTint="@color/red_500"
            app:cornerRadius="8dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
