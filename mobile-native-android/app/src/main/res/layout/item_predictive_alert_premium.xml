<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/ed_navy_3"
    app:cardCornerRadius="10dp"
    app:strokeColor="@color/ed_border_new"
    app:strokeWidth="1dp"
    android:layout_marginBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <View
            android:id="@+id/alertDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/ic_status_dot"
            android:backgroundTint="@color/ed_copper_new"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvAlertTitle"
                style="@style/SupervisorText.Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="شاحنة كريم عبدالله — تغيير سير"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvAlertSub"
                style="@style/SupervisorText.Subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="اقتربت من عتبة 100,000 كم"
                android:textSize="10sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvAlertKm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="99,180 كم"
            android:textColor="@color/ed_sky"
            android:textSize="11sp"
            android:textStyle="bold" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
