<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/navy_950"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/navy_950"
        app:titleTextColor="#FFFFFF"
        app:navigationIcon="@android:drawable/ic_menu_revert"
        app:navigationIconTint="@color/brand_primary"
        app:title="@string/menu_new_shipment"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ProgressBar
        android:id="@+id/wizardProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="6dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:max="4"
        android:progress="1"
        android:progressTint="@color/brand_primary"
        android:progressBackgroundTint="#33FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/stepIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="24dp"
        android:textColor="#80FFFFFF"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/wizardProgress"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        app:layout_constraintTop_toBottomOf="@id/stepIndicator"
        app:layout_constraintBottom_toTopOf="@id/btnPrimary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ViewFlipper
            android:id="@+id/wizardFlipper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Step 1: Category -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="اختر نوع الخدمة"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="20dp" />

                <RadioGroup
                    android:id="@+id/categoryGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <RadioButton android:id="@+id/cat_refrigerated" android:text="نقل مبرد ❄️"
                        android:textColor="#FFFFFF" android:textSize="16sp"
                        android:buttonTint="@color/brand_primary"
                        android:padding="12dp" android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                    <RadioButton android:id="@+id/cat_dry" android:text="نقل جاف 📦"
                        android:textColor="#FFFFFF" android:textSize="16sp"
                        android:buttonTint="@color/brand_primary"
                        android:padding="12dp" android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                    <RadioButton android:id="@+id/cat_express" android:text="شحن سريع ⚡"
                        android:textColor="#FFFFFF" android:textSize="16sp"
                        android:buttonTint="@color/brand_primary"
                        android:padding="12dp" android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                    <RadioButton android:id="@+id/cat_heavy" android:text="حمولات ثقيلة 🚛"
                        android:textColor="#FFFFFF" android:textSize="16sp"
                        android:buttonTint="@color/brand_primary"
                        android:padding="12dp" android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                    <RadioButton android:id="@+id/cat_intl" android:text="شحن دولي 🌍"
                        android:textColor="#FFFFFF" android:textSize="16sp"
                        android:buttonTint="@color/brand_primary"
                        android:padding="12dp" android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </RadioGroup>

            </LinearLayout>

            <!-- Step 2: Pickup & Drop-off -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="عناوين الشحن"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="20dp" />

                <!-- Pickup City -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:hint="مدينة الاستلام"
                    android:textColorHint="#80FFFFFF"
                    app:boxBackgroundColor="@color/navy_800"
                    app:boxStrokeColor="@color/brand_primary"
                    app:hintTextColor="@color/brand_primary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/pickupCity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:textColor="#FFFFFF" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Pickup Address Detail -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:hint="عنوان الاستلام بالتفصيل"
                    android:textColorHint="#80FFFFFF"
                    app:boxBackgroundColor="@color/navy_800"
                    app:boxStrokeColor="@color/brand_primary"
                    app:hintTextColor="@color/brand_primary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/pickupAddr"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine"
                        android:textColor="#FFFFFF" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMapPickup"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="تحديد الموقع من الخريطة"
                    android:textColor="#7BBDE8"
                    android:textSize="13sp"
                    app:icon="@android:drawable/ic_menu_mylocation"
                    app:iconTint="#7BBDE8" />

                <!-- Drop City -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:hint="مدينة التسليم"
                    android:textColorHint="#80FFFFFF"
                    app:boxBackgroundColor="@color/navy_800"
                    app:boxStrokeColor="@color/brand_primary"
                    app:hintTextColor="@color/brand_primary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/dropCity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:textColor="#FFFFFF" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Drop Address Detail -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:hint="عنوان التسليم بالكامل"
                    android:textColorHint="#80FFFFFF"
                    app:boxBackgroundColor="@color/navy_800"
                    app:boxStrokeColor="@color/brand_primary"
                    app:hintTextColor="@color/brand_primary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/dropAddr"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine"
                        android:textColor="#FFFFFF" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMapDrop"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="تحديد موقع التسليم من الخريطة"
                    android:textColor="#7BBDE8"
                    android:textSize="13sp"
                    app:icon="@android:drawable/ic_menu_mylocation"
                    app:iconTint="#7BBDE8" />

                <!-- Recipient Name & Phone -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:layout_marginBottom="12dp"
                        android:hint="اسم المستلم"
                        android:textColorHint="#80FFFFFF"
                        app:boxBackgroundColor="@color/navy_800"
                        app:boxStrokeColor="@color/brand_primary"
                        app:hintTextColor="@color/brand_primary">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/recipientName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPersonName"
                            android:textColor="#FFFFFF" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:layout_marginBottom="12dp"
                        android:hint="رقم الهاتف"
                        android:textColorHint="#80FFFFFF"
                        app:boxBackgroundColor="@color/navy_800"
                        app:boxStrokeColor="@color/brand_primary"
                        app:hintTextColor="@color/brand_primary">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/recipientPhone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="phone"
                            android:textColor="#FFFFFF" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Date & Time -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:hint="تاريخ التحميل"
                        android:textColorHint="#80FFFFFF"
                        app:boxBackgroundColor="@color/navy_800"
                        app:boxStrokeColor="@color/brand_primary"
                        app:hintTextColor="@color/brand_primary">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/pickupDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="date"
                            android:textColor="#FFFFFF" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:hint="الوقت المناسب"
                        android:textColorHint="#80FFFFFF"
                        app:boxBackgroundColor="@color/navy_800"
                        app:boxStrokeColor="@color/brand_primary"
                        app:hintTextColor="@color/brand_primary">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/pickupTime"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="time"
                            android:textColor="#FFFFFF" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

            </LinearLayout>

            <!-- Step 3: Details -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="تفاصيل الشحنة"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="20dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:hint="وصف البضاعة"
                    android:textColorHint="#80FFFFFF"
                    app:boxBackgroundColor="@color/navy_800"
                    app:boxStrokeColor="@color/brand_primary"
                    app:hintTextColor="@color/brand_primary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/cargoDesc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine"
                        android:textColor="#FFFFFF" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Number of Pieces & Weight -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:layout_marginBottom="12dp"
                        android:hint="عدد القطع"
                        android:textColorHint="#80FFFFFF"
                        app:boxBackgroundColor="@color/navy_800"
                        app:boxStrokeColor="@color/brand_primary"
                        app:hintTextColor="@color/brand_primary">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/pieceCount"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:textColor="#FFFFFF" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:layout_marginBottom="12dp"
                        android:hint="الوزن (كجم)"
                        android:textColorHint="#80FFFFFF"
                        app:boxBackgroundColor="@color/navy_800"
                        app:boxStrokeColor="@color/brand_primary"
                        app:hintTextColor="@color/brand_primary">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/cargoWeight"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:textColor="#FFFFFF" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Vehicle Type -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="نوع المركبة المطلوب"
                    android:textColor="#A0FFFFFF"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <RadioGroup
                    android:id="@+id/vehicleTypeGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <RadioButton
                        android:id="@+id/vtSmall"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="شاحنة صغيرة"
                        android:textColor="#FFFFFF"
                        android:checked="true" />
                    <RadioButton
                        android:id="@+id/vtLarge"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="شاحنة كبيرة"
                        android:textColor="#FFFFFF" />
                    <RadioButton
                        android:id="@+id/vtRefrigerated"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="تبريد"
                        android:textColor="#FFFFFF" />
                    <RadioButton
                        android:id="@+id/vtExpress"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="نقل سريع"
                        android:textColor="#FFFFFF" />
                </RadioGroup>

                <!-- Photo Upload -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUploadPhotos"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="12dp"
                    android:text="إرفاق صور الحمولة (اختياري)"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    app:backgroundTint="#1A7BBDE8"
                    app:cornerRadius="12dp"
                    app:icon="@android:drawable/ic_menu_camera"
                    app:iconTint="#7BBDE8"
                    app:strokeColor="#7BBDE8"
                    app:strokeWidth="1dp" />

                <!-- Photo Preview RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/photoPreviewRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:orientation="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="ملاحظات للسائق (اختياري)"
                    android:textColorHint="#80FFFFFF"
                    app:boxBackgroundColor="@color/navy_800"
                    app:boxStrokeColor="@color/brand_primary"
                    app:hintTextColor="@color/brand_primary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/cargoNotes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine"
                        android:minLines="2"
                        android:textColor="#FFFFFF" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <!-- Step 4: Review -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="مراجعة الطلب"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="20dp" />

                <LinearLayout
                    android:id="@+id/reviewContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>

        </ViewFlipper>

    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPrimary"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="24dp"
        android:text="@string/signup_continue"
        android:textColor="#001D39"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="@color/brand_primary"
        app:cornerRadius="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
