<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/ed_navy_3"
    app:cardCornerRadius="10dp"
    app:strokeColor="@color/ed_border_new"
    app:strokeWidth="1dp"
    android:layout_marginBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvTruckId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="T-224"
                    android:textColor="@color/ed_sky"
                    android:textSize="11sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvTruckName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="مرسيدس أكتروس 2548"
                    android:textColor="#E0EEF5"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvTaskStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_role_badge"
                android:backgroundTint="@color/ed_orange_15"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="جارٍ"
                android:textColor="@color/ed_copper_new"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvOperationName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙ عمرة محرك دورية — الفئة A"
            android:textColor="@color/ed_text_muted_new"
            android:textSize="11sp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvTechnician"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="م. أحمد فاروق — قسم المحركات"
            android:textColor="@color/ed_emerald_2"
            android:textSize="11sp"
            android:layout_marginBottom="12dp"/>

        <ProgressBar
            android:id="@+id/pbTaskProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:progress="65"
            android:progressTint="@color/ed_sky"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvProgressLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="65% مكتمل · يُتوقع الانتهاء خلال 3 ساعات"
            android:textColor="@color/ed_text_muted_new"
            android:textSize="10sp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
