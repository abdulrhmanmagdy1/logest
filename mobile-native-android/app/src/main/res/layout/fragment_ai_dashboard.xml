<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_background"
    android:padding="16dp">

    <!-- Header -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="AI &amp; Smart Automation"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- AI Status -->
    <LinearLayout
        android:id="@+id/linearLayoutAIStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/ivAIStatus"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_ai_active"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tvAIStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="AI Active"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <View
            android:id="@+id/viewAIStatus"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/circle_indicator"
            android:layout_marginStart="8dp" />

        <TextView
            android:id="@+id/tvModelStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Models Trained"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:layout_marginStart="8dp" />

        <View
            android:id="@+id/viewModelStatus"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/circle_indicator"
            android:layout_marginStart="8dp" />

        <Button
            android:id="@+id/btnRefreshAI"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Refresh"
            android:textSize="10sp"
            android:textColor="@color/text_on_primary"
            android:background="@drawable/secondary_button_bg"
            android:layout_marginStart="8dp"
            android:minWidth="64dp" />

    </LinearLayout>

    <!-- AI Insights Cards -->
    <LinearLayout
        android:id="@+id/linearLayoutAIInsights"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/linearLayoutAIStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Total Predictions Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Predictions"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvTotalPredictions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Fuel Savings Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fuel Savings"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvFuelSavings"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="@color/ai_positive"
                    android:textSize="20sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Delays Prevented Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Delays Prevented"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvDelaysPrevented"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/ai_positive"
                    android:textSize="20sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- AI Features Grid -->
    <LinearLayout
        android:id="@+id/linearLayoutAIFeatures"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/linearLayoutAIInsights"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnETAPrediction"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="ETA Prediction"
            android:textColor="@color/text_on_primary"
            android:background="@drawable/ai_button_bg"
            android:layout_marginEnd="4dp"
            android:minHeight="56dp" />

        <Button
            android:id="@+id/btnDelayPrediction"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="Delay Prediction"
            android:textColor="@color/text_on_primary"
            android:background="@drawable/ai_button_bg"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:minHeight="56dp" />

        <Button
            android:id="@+id/btnRouteOptimization"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="Route AI"
            android:textColor="@color/text_on_primary"
            android:background="@drawable/ai_button_bg"
            android:layout_marginStart="4dp"
            android:minHeight="56dp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/linearLayoutAIFeatures2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/linearLayoutAIFeatures"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnFuelOptimization"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="Fuel AI"
            android:textColor="@color/text_on_primary"
            android:background="@drawable/ai_button_bg"
            android:layout_marginEnd="4dp"
            android:minHeight="56dp" />

        <Button
            android:id="@+id/btnDriverBehavior"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="Driver AI"
            android:textColor="@color/text_on_primary"
            android:background="@drawable/ai_button_bg"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:minHeight="56dp" />

        <Button
            android:id="@+id/btnMaintenancePrediction"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="Maintenance AI"
            android:textColor="@color/text_on_primary"
            android:background="@drawable/ai_button_bg"
            android:layout_marginStart="4dp"
            android:minHeight="56dp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/linearLayoutAIFeatures3"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/linearLayoutAIFeatures2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnDemandForecasting"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="Demand AI"
            android:textColor="@color/text_on_primary"
            android:background="@drawable/ai_button_bg"
            android:layout_marginEnd="4dp"
            android:minHeight="56dp" />

        <Button
            android:id="@+id/btnRiskAnalysis"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="Risk AI"
            android:textColor="@color/text_on_primary"
            android:background="@drawable/ai_button_bg"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:minHeight="56dp" />

        <Button
            android:id="@+id/btnViewAll"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="View All"
            android:textColor="@color/text_on_primary"
            android:background="@drawable/primary_button_bg"
            android:layout_marginStart="4dp"
            android:minHeight="56dp" />

    </LinearLayout>

    <!-- Predictions Section -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardPredictions"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/linearLayoutAIFeatures3"
        app:layout_constraintBottom_toTopOf="@id/linearLayoutRecommendations"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Predictions Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="AI Predictions"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvPredictionCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 predictions"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- Search and Filter -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <EditText
                    android:id="@+id/etSearchPredictions"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:hint="Search predictions..."
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:background="@drawable/search_input_bg"
                    android:padding="12dp"
                    android:layout_marginEnd="8dp"
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:maxLines="1" />

                <Button
                    android:id="@+id/btnViewPredictions"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="View All"
                    android:textSize="10sp"
                    android:textColor="@color/text_on_primary"
                    android:background="@drawable/secondary_button_bg"
                    android:minWidth="64dp" />

            </LinearLayout>

            <!-- Search Results -->
            <TextView
                android:id="@+id/tvPredictionSearchResults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <!-- Predictions RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewPredictions"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Recommendations Section -->
    <LinearLayout
        android:id="@+id/linearLayoutRecommendations"
        android:layout_width="0dp"
        android:layout_height="200dp"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/cardPredictions"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="AI Recommendations"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvRecommendationCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 items"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                </LinearLayout>

                <!-- Search and Filter -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <EditText
                        android:id="@+id/etSearchRecommendations"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:hint="Search recommendations..."
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:background="@drawable/search_input_bg"
                        android:padding="12dp"
                        android:layout_marginEnd="8dp"
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        android:maxLines="1" />

                    <Button
                        android:id="@+id/btnViewRecommendations"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="View All"
                        android:textSize="10sp"
                        android:textColor="@color/text_on_primary"
                        android:background="@drawable/secondary_button_bg"
                        android:minWidth="64dp" />

                </LinearLayout>

                <!-- Search Results -->
                <TextView
                    android:id="@+id/tvRecommendationSearchResults"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone" />

                <!-- Recommendations RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerViewRecommendations"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Smart Alerts Section -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Smart Alerts"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvAlertCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 alerts"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                </LinearLayout>

                <!-- Alerts RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerViewSmartAlerts"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <!-- View All Alerts Button -->
                <Button
                    android:id="@+id/btnViewAlerts"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="View All Alerts"
                    android:textColor="@color/text_on_primary"
                    android:background="@drawable/secondary_button_bg"
                    android:layout_marginTop="12dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- Bottom Actions -->
    <LinearLayout
        android:id="@+id/linearLayoutBottomActions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnViewPredictionsBottom"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="All Predictions"
            android:textColor="@color/text_on_primary"
            android:background="@drawable/secondary_button_bg"
            android:layout_marginEnd="8dp"
            android:minHeight="56dp" />

        <Button
            android:id="@+id/btnViewRecommendationsBottom"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="All Recommendations"
            android:textColor="@color/text_on_primary"
            android:background="@drawable/secondary_button_bg"
            android:layout_marginEnd="8dp"
            android:minHeight="56dp" />

        <Button
            android:id="@+id/btnViewAlertsBottom"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="All Alerts"
            android:textColor="@color/text_on_primary"
            android:background="@drawable/secondary_button_bg"
            android:minHeight="56dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
