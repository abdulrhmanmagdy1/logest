<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".shipment.KanbanBoardFragment">

    <!-- App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/overlay_light"
        app:elevation="4dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Shipment Board"
            app:navigationIcon="@drawable/ic_menu"
            app:menu="@menu/kanban_menu" />

        <!-- Filter Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_md"
            android:paddingVertical="@dimen/spacing_sm"
            android:gravity="center_vertical">

            <!-- Search View -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/spacing_md"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="@dimen/spacing_md">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="@dimen/spacing_sm"
                        android:src="@drawable/ic_search"
                        app:tint="@color/text_tertiary" />

                    <EditText
                        android:id="@+id/search_edit_text"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="Search shipments..."
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_tertiary" />

                    <ImageView
                        android:id="@+id/clear_search"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_clear"
                        app:tint="@color/text_tertiary"
                        android:visibility="gone" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Filter Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/filter_button"
                style="@style/Widget.Edham.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Filter"
                android:textSize="12sp"
                app:icon="@drawable/ic_filter"
                app:iconGravity="textStart" />

        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="?attr/actionBarSize"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_md"
            android:paddingBottom="@dimen/spacing_md">

            <!-- Created Column -->
            <LinearLayout
                android:layout_width="300dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="@dimen/spacing_md"
                android:orientation="vertical">

                <!-- Column Header -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/surface_variant">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="@dimen/spacing_md"
                        android:gravity="center_vertical">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="@dimen/spacing_sm"
                            android:background="@drawable/rounded_background"
                            android:backgroundTint="@color/color_info_500" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Created"
                            style="@style/TextAppearance.Edham.LabelMedium"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/created_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            style="@style/TextAppearance.Edham.LabelSmall"
                            android:textColor="@color/text_secondary"
                            android:background="@drawable/rounded_background"
                            android:backgroundTint="@color/outline_primary"
                            android:paddingHorizontal="@dimen/spacing_sm"
                            android:paddingVertical="@dimen/spacing_xs" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Shipment Cards -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/created_recycler_view"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:clipToPadding="false"
                    android:scrollbars="vertical"
                    tools:listitem="@layout/item_kanban_shipment" />

            </LinearLayout>

            <!-- Assigned Column -->
            <LinearLayout
                android:layout_width="300dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="@dimen/spacing_md"
                android:orientation="vertical">

                <!-- Column Header -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/surface_variant">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="@dimen/spacing_md"
                        android:gravity="center_vertical">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="@dimen/spacing_sm"
                            android:background="@drawable/rounded_background"
                            android:backgroundTint="@color/color_primary_500" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Assigned"
                            style="@style/TextAppearance.Edham.LabelMedium"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/assigned_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            style="@style/TextAppearance.Edham.LabelSmall"
                            android:textColor="@color/text_secondary"
                            android:background="@drawable/rounded_background"
                            android:backgroundTint="@color/outline_primary"
                            android:paddingHorizontal="@dimen/spacing_sm"
                            android:paddingVertical="@dimen/spacing_xs" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Shipment Cards -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/assigned_recycler_view"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:clipToPadding="false"
                    android:scrollbars="vertical"
                    tools:listitem="@layout/item_kanban_shipment" />

            </LinearLayout>

            <!-- In Transit Column -->
            <LinearLayout
                android:layout_width="300dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="@dimen/spacing_md"
                android:orientation="vertical">

                <!-- Column Header -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/surface_variant">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="@dimen/spacing_md"
                        android:gravity="center_vertical">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="@dimen/spacing_sm"
                            android:background="@drawable/rounded_background"
                            android:backgroundTint="@color/color_warning_500" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="In Transit"
                            style="@style/TextAppearance.Edham.LabelMedium"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/in_transit_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            style="@style/TextAppearance.Edham.LabelSmall"
                            android:textColor="@color/text_secondary"
                            android:background="@drawable/rounded_background"
                            android:backgroundTint="@color/outline_primary"
                            android:paddingHorizontal="@dimen/spacing_sm"
                            android:paddingVertical="@dimen/spacing_xs" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Shipment Cards -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/in_transit_recycler_view"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:clipToPadding="false"
                    android:scrollbars="vertical"
                    tools:listitem="@layout/item_kanban_shipment" />

            </LinearLayout>

            <!-- Delivered Column -->
            <LinearLayout
                android:layout_width="300dp"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <!-- Column Header -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/surface_variant">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="@dimen/spacing_md"
                        android:gravity="center_vertical">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="@dimen/spacing_sm"
                            android:background="@drawable/rounded_background"
                            android:backgroundTint="@color/color_success_500" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Delivered"
                            style="@style/TextAppearance.Edham.LabelMedium"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/delivered_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            style="@style/TextAppearance.Edham.LabelSmall"
                            android:textColor="@color/text_secondary"
                            android:background="@drawable/rounded_background"
                            android:backgroundTint="@color/outline_primary"
                            android:paddingHorizontal="@dimen/spacing_sm"
                            android:paddingVertical="@dimen/spacing_xs" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Shipment Cards -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/delivered_recycler_view"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:clipToPadding="false"
                    android:scrollbars="vertical"
                    tools:listitem="@layout/item_kanban_shipment" />

            </LinearLayout>

        </LinearLayout>

    </HorizontalScrollView>

    <!-- Floating Action Button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_shipment"
        style="@style/Widget.Edham.Button.FAB"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="@dimen/spacing_lg"
        app:srcCompat="@drawable/ic_add"
        app:tint="@color/text_on_primary" />

    <!-- Filter Bottom Sheet -->
    <LinearLayout
        android:id="@+id/filter_bottom_sheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bottom_sheet_background"
        android:padding="@dimen/spacing_lg"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_hideable="true"
        app:behavior_peekHeight="0dp"
        android:visibility="gone">

        <!-- Filter Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Filter Shipments"
            style="@style/TextAppearance.Edham.TitleMedium"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="@dimen/spacing_lg" />

        <!-- Priority Filter -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Priority"
            style="@style/TextAppearance.Edham.LabelMedium"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="@dimen/spacing_sm" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/priority_chip_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_lg"
            app:selectionRequired="false"
            app:chipSpacingHorizontal="@dimen/spacing_sm">

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Critical"
                app:chipBackgroundColor="@color/color_error_100"
                android:textColor="@color/color_error_700" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="High"
                app:chipBackgroundColor="@color/color_warning_100"
                android:textColor="@color/color_warning_700" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Normal"
                app:chipBackgroundColor="@color/color_info_100"
                android:textColor="@color/color_info_700" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Low"
                app:chipBackgroundColor="@color/color_success_100"
                android:textColor="@color/color_success_700" />

        </com.google.android.material.chip.ChipGroup>

        <!-- Date Filter -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Date Range"
            style="@style/TextAppearance.Edham.LabelMedium"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="@dimen/spacing_sm" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/spacing_lg">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/spacing_md"
                style="@style/Widget.Edham.TextInputLayout.OutlinedBox"
                android:hint="From">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/date_from"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="date" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/Widget.Edham.TextInputLayout.OutlinedBox"
                android:hint="To">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/date_to"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="date" />

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/clear_filters"
                style="@style/Widget.Edham.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/spacing_md"
                android:text="Clear" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/apply_filters"
                style="@style/Widget.Edham.Button.Primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Apply" />

        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
