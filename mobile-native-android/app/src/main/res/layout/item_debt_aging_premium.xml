<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    style="@style/AccountantCard"
    android:layout_marginBottom="7dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp"
            android:baselineAligned="false">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvClientName"
                    style="@style/SupervisorText.Title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="شركة النيل للتبريد"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/tvDelayDays"
                    style="@style/SupervisorText.Subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="متأخر ٩٤ يوماً ⚠"
                    android:textColor="@color/acc_rust"
                    android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">
                <TextView
                    android:id="@+id/tvDebtAmount"
                    style="@style/SupervisorText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="١٨,٤٠٠ ج"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#FFFFFF"/>
                <TextView
                    android:id="@+id/tvDebtStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:background="@drawable/bg_role_badge"
                    android:backgroundTint="#2EB6410F"
                    android:paddingHorizontal="7dp"
                    android:paddingVertical="2dp"
                    android:text="متأخر جداً"
                    android:textColor="@color/acc_rust"
                    android:textSize="9sp"
                    android:textStyle="bold"/>
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWhatsapp"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="تذكير واتساب"
                android:textSize="10sp"
                android:textColor="#25D366"
                app:backgroundTint="#2625D366"
                app:icon="@drawable/ic_chat"
                app:iconTint="#25D366"
                app:iconSize="14dp"
                app:cornerRadius="6dp"
                android:minHeight="0dp"
                android:paddingVertical="5dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCollect"
                style="@style/SupervisorButton.Primary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="تحصيل فوري"
                android:textSize="10sp"
                app:backgroundTint="@color/acc_teal"
                android:textColor="#9de4ff"
                app:cornerRadius="6dp"
                android:minHeight="0dp"
                android:paddingVertical="5dp"/>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
