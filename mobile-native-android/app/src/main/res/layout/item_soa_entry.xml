<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="10dp"
    android:gravity="center_vertical">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">
        <TextView
            android:id="@+id/tvEntryId"
            style="@style/SupervisorText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="رح-٢٢٤١"
            android:textSize="12sp"
            android:textStyle="bold"/>
        <TextView
            android:id="@+id/tvEntryDate"
            style="@style/SupervisorText.Subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="٢٠٢٦/٠٥/١٢"
            android:textSize="9sp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvAmount"
        style="@style/SupervisorText"
        android:layout_width="60dp"
        android:layout_height="wrap_content"
        android:text="١٢,٠٠٠"
        android:gravity="center"
        android:textSize="11sp"/>

    <TextView
        android:id="@+id/tvPaid"
        style="@style/SupervisorText"
        android:layout_width="55dp"
        android:layout_height="wrap_content"
        android:text="١٢,٠٠٠"
        android:gravity="center"
        android:textSize="11sp"/>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="45dp"
        android:layout_height="wrap_content"
        android:text="مسدد"
        android:gravity="center"
        android:background="@drawable/status_paid_bg"
        android:textColor="@color/ed_success"
        android:textSize="8sp"
        android:textStyle="bold"
        android:paddingVertical="2dp"/>

</LinearLayout>
