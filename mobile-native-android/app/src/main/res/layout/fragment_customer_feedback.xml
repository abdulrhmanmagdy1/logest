<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ed_deep">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <TextView
                style="@style/SupervisorText.Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="تقييم تجربة الشحن"
                android:textSize="22sp" />

            <TextView
                style="@style/SupervisorText.Subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="رأيك يساعدنا في تحسين جودة خدمات إدهام" />

            <com.google.android.material.card.MaterialCardView
                style="@style/AccountantCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center_horizontal">

                    <TextView
                        style="@style/SupervisorText.Subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ما مدى رضاك عن سرعة التوصيل؟"
                        android:textSize="14sp" />

                    <RatingBar
                        android:id="@+id/ratingSpeed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:numStars="5"
                        android:stepSize="1"
                        android:progressTint="@color/ed_sky" />

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/ed_border_new" android:layout_marginVertical="24dp"/>

                    <TextView
                        style="@style/SupervisorText.Subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="كيف كانت حالة الحمولة عند الاستلام؟"
                        android:textSize="14sp" />

                    <RatingBar
                        android:id="@+id/ratingQuality"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:numStars="5"
                        android:stepSize="1"
                        android:progressTint="@color/ed_emerald_2" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="32dp"
                        android:hint="هل لديك أي ملاحظات إضافية؟"
                        app:hintTextColor="@color/ed_text_muted_new">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etFeedbackComment"
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:gravity="top"
                            android:textColor="@color/ed_white"
                            android:background="@color/ed_input_bg"/>
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmitFeedback"
                style="@style/SupervisorButton.Primary"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="32dp"
                android:text="إرسال التقييم ✓"
                android:textSize="16sp"
                app:backgroundTint="@color/ed_teal"
                android:textColor="@color/ed_white"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
