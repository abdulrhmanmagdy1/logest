<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ed_deep">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                style="@style/SupervisorText.Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="نادي أبطال إدهام 🎖️"
                android:textSize="20sp" />

            <TextView
                style="@style/SupervisorText.Subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="أداءك المتميز يمنحك مزايا حصرية" />

            <!-- Rank Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="@color/ed_navy_2"
                app:strokeColor="@color/ed_sky"
                app:strokeWidth="1.5dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="24dp"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView android:id="@+id/tvRewardIcon" android:layout_width="64dp" android:layout_height="64dp" android:text="🎖️" android:textSize="48sp" android:gravity="center"/>
                    <TextView android:id="@+id/tvRankTitle" style="@style/SupervisorText.Title" android:text="---" android:layout_marginTop="12dp" android:textColor="@color/ed_sky"/>
                    <TextView android:id="@+id/tvRankDesc" style="@style/SupervisorText.Subtitle" android:text="جاري تحميل مستوى الأداء..." />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Progress to next Reward -->
            <TextView
                style="@style/SupervisorText.Title"
                android:text="المهمة القادمة للمكافأة"
                android:textSize="14sp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/ed_navy_3">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="20dp" android:orientation="vertical">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:id="@+id/tvRewardGoalTitle" style="@style/SupervisorText" android:text="---"/>
                        <TextView android:id="@+id/tvRewardGoalProgress" android:layout_alignParentEnd="true" style="@style/SupervisorText" android:text="0/0" android:textColor="@color/ed_emerald"/>
                    </RelativeLayout>
                    <ProgressBar
                        android:id="@+id/pbRewardProgress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_marginTop="12dp"
                        android:progress="0"
                        android:progressTint="@color/ed_emerald"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
