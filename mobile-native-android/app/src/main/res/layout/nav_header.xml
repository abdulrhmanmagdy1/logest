<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="180dp"
    android:background="@color/customer_bg_secondary"
    android:gravity="bottom"
    android:orientation="vertical"
    android:padding="24dp">

    <ImageView
        android:id="@+id/navHeaderImage"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginBottom="16dp"
        android:src="@drawable/ic_user_default"
        android:contentDescription="User Avatar" />

    <TextView
        android:id="@+id/navHeaderName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/customer_text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        tools:text="أحمد العميل" />

    <TextView
        android:id="@+id/navHeaderEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="@color/customer_text_secondary"
        android:textSize="14sp"
        tools:text="ahmed@example.com" />

    <TextView
        android:id="@+id/navHeaderRole"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/customer_blue_primary"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textAllCaps="true"
        tools:text="عميل بريميوم" />

</LinearLayout>
