<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp"
    android:layout_marginVertical="4dp">

    <!-- Avatar for received messages -->
    <ImageView
        android:id="@+id/ivSenderAvatar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_default_avatar"
        android:background="@drawable/circle_avatar_bg"
        android:scaleType="centerCrop"
        android:layout_marginEnd="8dp"
        android:visibility="gone" />

    <!-- Message Container -->
    <LinearLayout
        android:id="@+id/layoutMessageContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="@drawable/chat_message_received_bg"
        android:maxWidth="300dp">

        <!-- Sender Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/tvSenderName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Dispatcher"
                android:textColor="@color/chat_sender_name"
                android:textSize="12sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvMessageTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2:30 PM"
                android:textColor="@color/chat_message_time"
                android:textSize="11sp"
                android:fontFamily="monospace" />

        </LinearLayout>

        <!-- Message Content -->
        <TextView
            android:id="@+id/tvMessageContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="This is a sample message content that can span multiple lines and should wrap properly within the message bubble."
            android:textColor="@color/chat_message_text"
            android:textSize="16sp"
            android:lineSpacingExtra="2dp"
            android:layout_marginBottom="4dp" />

        <!-- Media Preview -->
        <LinearLayout
            android:id="@+id/layoutMediaPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/media_preview_bg"
            android:padding="8dp"
            android:layout_marginBottom="4dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/ivMessageMedia"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_attachment"
                android:layout_marginEnd="8dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvMediaFileName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="document.pdf"
                android:textColor="@color/chat_media_name"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvMediaFileSize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2.3 MB"
                android:textColor="@color/chat_media_size"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginStart="8dp" />

            <ImageView
                android:id="@+id/ivPlayButton"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_play"
                android:background="@drawable/play_button_bg"
                android:padding="8dp"
                android:layout_marginStart="8dp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Location Preview -->
        <LinearLayout
            android:id="@+id/layoutLocationPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/location_preview_bg"
            android:padding="8dp"
            android:layout_marginBottom="4dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/ivLocationIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_location"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvLocationAddress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Riyadh, Saudi Arabia"
                android:textColor="@color/chat_location_text"
                android:textSize="14sp"
                android:maxLines="2"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- Status Indicators -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end|center_vertical"
            android:layout_marginTop="4dp">

            <View
                android:id="@+id/viewDeliveryStatus"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/circle_pending"
                android:layout_marginEnd="4dp" />

            <View
                android:id="@+id/viewReadReceipt"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/circle_unread"
                android:layout_marginEnd="4dp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
