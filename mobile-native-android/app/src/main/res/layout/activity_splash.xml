<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#001D39">

    <!-- حاوية المركز لضمان خروج الكلام من النجمة -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/splashContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.45">

        <!-- الثلجاية - تبدأ في المنتصف تماماً -->
        <ImageView
            android:id="@+id/splashSnowflake"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/ic_snowflake"
            android:scaleX="0"
            android:scaleY="0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:contentDescription="Snowflake"/>

        <!-- الكلام - يكون خلف النجمة في البداية -->
        <LinearLayout
            android:id="@+id/splashTextBlock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:alpha="0"
            app:layout_constraintStart_toEndOf="@id/splashSnowflake"
            app:layout_constraintTop_toTopOf="@id/splashSnowflake"
            app:layout_constraintBottom_toBottomOf="@id/splashSnowflake">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="إدهام"
                android:textColor="#FFFFFF"
                android:textSize="38sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EDHAM"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="for refrigerated"
                android:textColor="#FF4D4D"
                android:textSize="16sp"
                android:textStyle="italic"
                android:layout_marginTop="-4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Transportation"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="italic"
                android:layout_marginTop="-2dp"/>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/splashTagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Logistics &amp; Refrigerated Transport"
        android:textColor="#80FFFFFF"
        android:textSize="12sp"
        android:alpha="0"
        app:layout_constraintTop_toBottomOf="@id/splashContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"/>

    <ProgressBar
        android:id="@+id/splashProgress"
        style="@android:style/Widget.Material.ProgressBar.Small"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:indeterminateTint="#7BBDE8"
        android:alpha="0"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="64dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
