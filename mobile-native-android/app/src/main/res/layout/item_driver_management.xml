<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardBackgroundColor="@color/supervisor_card"
    app:strokeWidth="1dp"
    app:strokeColor="@color/supervisor_card_stroke"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Status Indicator -->
        <ImageView
            android:id="@+id/ivStatusIndicator"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/circle_green"
            android:layout_marginEnd="16dp" />

        <!-- Driver Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvDriverName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="أحمد محمد"
                android:textColor="@color/supervisor_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvVehicleNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="سيارة #1234"
                android:textColor="@color/supervisor_text_secondary"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvCurrentTask"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="متاح"
                android:textColor="@color/supervisor_text_hint"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Status and Contact -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tvDriverStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="نشط"
                android:textColor="@color/supervisor_success"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/success_badge_background"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp" />

            <TextView
                android:id="@+id/tvPhoneNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0551234567"
                android:textColor="@color/supervisor_text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="8dp" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
