<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.chip.Chip xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.Material3.Chip.Filter"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/spacing_chip_margin"
    android:text="Chip Label"
    android:textAppearance="@style/TextAppearance.Edham.LabelMedium"
    android:textColor="@color/text_primary"
    app:chipBackgroundColor="@color/color_primary_50"
    app:chipCornerRadius="@dimen/spacing_md"
    app:chipStrokeColor="@color/color_primary_200"
    app:chipStrokeWidth="1dp"
    app:closeIconVisible="true"
    app:closeIconTint="@color/text_secondary" />
