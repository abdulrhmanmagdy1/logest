<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/prem_navy"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="مراجعة الطلب النهائي"
            android:textColor="@color/html_white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="يرجى مراجعة كافة التفاصيل قبل إرسال الطلب"
            android:textColor="@color/customer_text_muted"
            android:textSize="13sp" />

        <!-- Pickup Summary -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/html_card_bg"
            app:strokeWidth="1dp"
            app:strokeColor="@color/customer_blue_border">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="نقطة التحميل" android:textColor="@color/prem_sky" android:textSize="11sp" android:textStyle="bold"/>
                <TextView android:id="@+id/tvPickupSummary" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="الرياض، حي الملز" android:textColor="#FFF" android:layout_marginTop="4dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Delivery Summary -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/html_card_bg"
            app:strokeWidth="1dp"
            app:strokeColor="@color/customer_blue_border">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="نقطة التفريغ" android:textColor="@color/customer_danger" android:textSize="11sp" android:textStyle="bold"/>
                <TextView android:id="@+id/tvDeliverySummary" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="جدة، الميناء" android:textColor="#FFF" android:layout_marginTop="4dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Cargo & Vehicle Summary -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/html_card_bg"
            app:strokeWidth="1dp"
            app:strokeColor="@color/customer_blue_border">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                         <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="نوع الحمولة" android:textColor="@color/customer_text_muted" android:textSize="10sp"/>
                         <TextView android:id="@+id/tvCargoSummary" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="مواد غذائية" android:textColor="#FFF" android:textStyle="bold"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                         <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="الوزن" android:textColor="@color/customer_text_muted" android:textSize="10sp"/>
                         <TextView android:id="@+id/tvWeightSummary" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5 طن" android:textColor="#FFF" android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:orientation="horizontal" android:weightSum="2">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                         <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="نوع المركبة" android:textColor="@color/customer_text_muted" android:textSize="10sp"/>
                         <TextView android:id="@+id/tvVehicleSummary" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="جامبو" android:textColor="#FFF" android:textStyle="bold"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                         <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="الموعد" android:textColor="@color/customer_text_muted" android:textSize="10sp"/>
                         <TextView android:id="@+id/tvScheduleSummary" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="فوري" android:textColor="#FFF" android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/customer_blue_border" android:layout_marginVertical="12dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="التكلفة التقديرية" android:textColor="#FFF" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1,250 ريال" android:textColor="@color/prem_sky" android:textSize="18sp" android:textStyle="bold"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <CheckBox
            android:id="@+id/cbTerms"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="أوافق على الشروط والأحكام وسياسة النقل"
            android:textColor="@color/html_white"
            android:buttonTint="@color/prem_sky"
            android:paddingBottom="40dp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
