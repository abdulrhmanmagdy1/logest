<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingBottom="24dp">

    <View
        android:id="@+id/lineAbove"
        android:layout_width="2dp"
        android:layout_height="0dp"
        android:background="#2ECC71"
        app:layout_constraintBottom_toTopOf="@id/indicator"
        app:layout_constraintEnd_toEndOf="@id/indicator"
        app:layout_constraintStart_toStartOf="@id/indicator"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/indicator"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:background="@drawable/circle_green"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/lineBelow"
        android:layout_width="2dp"
        android:layout_height="0dp"
        android:background="#E0E0E0"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/indicator"
        app:layout_constraintStart_toStartOf="@id/indicator"
        app:layout_constraintTop_toBottomOf="@id/indicator" />

    <TextView
        android:id="@+id/tvStatusTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="تم استلام البضاعة"
        android:textColor="#1A1C2E"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@id/indicator"
        app:layout_constraintTop_toTopOf="@id/indicator"
        app:layout_constraintBottom_toBottomOf="@id/indicator" />

    <TextView
        android:id="@+id/tvStatusTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="10:05"
        android:textColor="#8E8E93"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="@id/tvStatusTitle"
        app:layout_constraintTop_toBottomOf="@id/tvStatusTitle" />

</androidx.constraintlayout.widget.ConstraintLayout>
