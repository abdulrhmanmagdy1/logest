<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/acc_navy">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Financial Header (Premium OCC) -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:background="@color/acc_navy_light">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <FrameLayout
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_stat_icon_teal">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="🏦"
                            android:textSize="20sp"/>
                    </FrameLayout>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:orientation="vertical">
                        <TextView style="@style/SupervisorText.Title" android:text="@string/smart_accountant" android:textSize="14sp"/>
                        <include layout="@layout/item_system_heartbeat" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <ImageView
                        android:id="@+id/btnNotifCenter"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:padding="8dp"
                        android:src="@drawable/ic_notifications"
                        app:tint="@color/acc_sky"
                        android:background="@drawable/bg_stat_icon_teal"
                        android:layout_marginEnd="8dp" />
                    <TextView
                        android:id="@+id/tvAvatarCircle"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_stat_icon_teal"
                        android:gravity="center"
                        android:text="أح"
                        android:textColor="@color/acc_sky"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </RelativeLayout>

            <!-- KPI Grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:padding="14dp">

                <com.google.android.material.card.MaterialCardView
                    style="@style/AccountantCard.Sky"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="12dp" android:orientation="vertical">
                        <TextView style="@style/SupervisorText.StatLabel" android:text="@string/liquidity" android:textSize="10sp" android:textColor="@color/acc_text_muted" app:drawableStartCompat="@drawable/ic_wallet" android:drawablePadding="5dp" app:drawableTint="@color/acc_text_muted"/>
                        <TextView android:id="@+id/tvLiquidity" style="@style/SupervisorText.StatValue" android:text="٢٨٧,٤٠٠" android:textColor="@color/acc_sky" android:textSize="18sp" android:layout_marginTop="6dp"/>
                        <TextView style="@style/SupervisorText.Subtitle" android:text="↑ ٥.٢٪ هذا الشهر" android:textColor="@color/acc_emerald" android:textSize="10sp" android:layout_marginTop="3dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/AccountantCard.Rust"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="12dp" android:orientation="vertical">
                        <TextView style="@style/SupervisorText.StatLabel" android:text="@string/outstanding_debts" android:textSize="10sp" android:textColor="@color/acc_text_muted" app:drawableStartCompat="@drawable/ic_clock" android:drawablePadding="5dp" app:drawableTint="@color/acc_text_muted"/>
                        <TextView android:id="@+id/tvOutstanding" style="@style/SupervisorText.StatValue" android:text="٩٤,٢٠٠" android:textColor="@color/acc_rust" android:textSize="18sp" android:layout_marginTop="6dp"/>
                        <TextView style="@style/SupervisorText.Subtitle" android:text="↑ ١٢ عميل متأخر" android:textColor="@color/acc_rust" android:textSize="10sp" android:layout_marginTop="3dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/AccountantCard.Copper"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="12dp" android:orientation="vertical">
                        <TextView style="@style/SupervisorText.StatLabel" android:text="@string/monthly_expenses" android:textSize="10sp" android:textColor="@color/acc_text_muted" app:drawableStartCompat="@drawable/ic_invoice" android:drawablePadding="5dp" app:drawableTint="@color/acc_text_muted"/>
                        <TextView android:id="@+id/tvExpenses" style="@style/SupervisorText.StatValue" android:text="٦١,٨٠٠" android:textColor="@color/acc_copper" android:textSize="18sp" android:layout_marginTop="6dp"/>
                        <TextView style="@style/SupervisorText.Subtitle" android:text="من ٧٠,٠٠٠ مخطط" android:textColor="@color/acc_text_muted" android:textSize="10sp" android:layout_marginTop="3dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/AccountantCard.Green"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="12dp" android:orientation="vertical">
                        <TextView style="@style/SupervisorText.StatLabel" android:text="@string/net_profit" android:textSize="10sp" android:textColor="@color/acc_text_muted" app:drawableStartCompat="@drawable/ic_trending_up" android:drawablePadding="5dp" app:drawableTint="@color/acc_text_muted"/>
                        <TextView android:id="@+id/tvNetProfit" style="@style/SupervisorText.StatValue" android:text="٤٢,٦٠٠" android:textColor="@color/acc_emerald" android:textSize="18sp" android:layout_marginTop="6dp"/>
                        <TextView style="@style/SupervisorText.Subtitle" android:text="↑ هامش ٢٢.٣٪" android:textColor="@color/acc_emerald" android:textSize="10sp" android:layout_marginTop="3dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

            <!-- Comparison Chart -->
            <com.google.android.material.card.MaterialCardView
                style="@style/AccountantCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="14dp"
                android:layout_marginBottom="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="12dp" android:orientation="vertical">
                    <TextView style="@style/SupervisorText.Subtitle" android:text="📊 مقارنة الدخل والمصاريف — يونيو ٢٠٢٦" android:textSize="11sp" android:textColor="@color/acc_text_muted" android:layout_marginBottom="10dp"/>
                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/revenueChart"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Distribution Chart -->
            <com.google.android.material.card.MaterialCardView
                style="@style/AccountantCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="14dp"
                android:layout_marginBottom="32dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="12dp" android:orientation="vertical">
                    <TextView style="@style/SupervisorText.Subtitle" android:text="🍩 توزيع المصاريف" android:textSize="11sp" android:textColor="@color/acc_text_muted" android:layout_marginBottom="10dp"/>
                    <com.github.mikephil.charting.charts.PieChart
                        android:id="@+id/expenseDonutChart"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Final Quick Actions -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp"
                android:layout_marginBottom="64dp"
                android:weightSum="2">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOpenReports"
                    style="@style/SupervisorButton.Outline"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="@string/export_center_title"
                    app:icon="@drawable/ic_download"
                    android:textColor="@color/acc_sky"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnIssueReceipt"
                    style="@style/SupervisorButton.Primary"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="@string/receipt_voucher_title"
                    app:icon="@drawable/ic_add"
                    app:backgroundTint="@color/acc_emerald"
                    android:textColor="@color/acc_navy"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
