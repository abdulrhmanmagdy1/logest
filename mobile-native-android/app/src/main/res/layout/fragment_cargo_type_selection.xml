<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/prem_navy"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ما نوع حمولتك؟"
            android:textColor="@color/html_white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="اختر هوية الحمولة لضمان أفضل طريقة نقل"
            android:textColor="@color/customer_text_muted"
            android:textSize="13sp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:columnCount="2"
            android:alignmentMode="alignMargins">

            <!-- Refrigerated -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/type_refrigerated"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                app:cardBackgroundColor="@color/html_card_bg"
                app:cardCornerRadius="16dp"
                app:strokeWidth="1.5dp"
                app:strokeColor="@color/prem_ice">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="❄️" android:textSize="32sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="مبرد" android:textColor="@color/html_white" android:layout_marginTop="8dp" android:textStyle="bold" android:textSize="13sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Frozen -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/type_frozen"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                app:cardBackgroundColor="@color/html_card_bg"
                app:cardCornerRadius="16dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/customer_blue_border">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🧊" android:textSize="32sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="مجمد" android:textColor="@color/html_white" android:layout_marginTop="8dp" android:textSize="13sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Dry -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/type_dry"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                app:cardBackgroundColor="@color/html_card_bg"
                app:cardCornerRadius="16dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/customer_blue_border">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📦" android:textSize="32sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="جاف/عادي" android:textColor="@color/html_white" android:layout_marginTop="8dp" android:textSize="13sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Bulk -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/type_bulk"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                app:cardBackgroundColor="@color/html_card_bg"
                app:cardCornerRadius="16dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/customer_blue_border">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🚛" android:textSize="32sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="سائبة" android:textColor="@color/html_white" android:layout_marginTop="8dp" android:textSize="13sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Warehouse to Store -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/type_warehouse"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                app:cardBackgroundColor="@color/html_card_bg"
                app:cardCornerRadius="16dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/customer_blue_border">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🏬" android:textSize="32sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="مستودع لمتجر" android:textColor="@color/html_white" android:layout_marginTop="8dp" android:textSize="11sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </GridLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="الوزن التقريبي"
            android:textColor="@color/html_white"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="اختر الوزن أو استخدم شريط التمرير"
            android:textColor="@color/customer_text_muted"
            android:textSize="13sp" />

        <!-- Weight Buttons Grid -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:columnCount="2"
            android:alignmentMode="alignMargins">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/weight_5"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                app:cardBackgroundColor="@color/html_card_bg"
                app:cardCornerRadius="12dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/customer_blue_border">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5" android:textColor="#FFF" android:textSize="20sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="طن" android:textColor="@color/customer_text_muted" android:textSize="11sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/weight_10"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                app:cardBackgroundColor="@color/html_card_bg"
                app:cardCornerRadius="12dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/customer_blue_border">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="10" android:textColor="#FFF" android:textSize="20sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="طن" android:textColor="@color/customer_text_muted" android:textSize="11sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </GridLayout>

        <!-- Slider Placeholder -->
        <com.google.android.material.slider.Slider
            android:id="@+id/weightSlider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:value="5"
            android:valueFrom="1"
            android:valueTo="40"
            app:thumbColor="@color/prem_sky"
            app:trackColorActive="@color/prem_sky"
            app:trackColorInactive="@color/customer_blue_border"/>

        <TextView
            android:id="@+id/textWeightDisplay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="الوزن الحالي: 5 طن"
            android:textColor="@color/prem_sky"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:textStyle="bold"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
