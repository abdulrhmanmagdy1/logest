<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/chat_background"
    android:padding="16dp">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/linearLayoutHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_back"
            android:background="@drawable/chat_icon_bg"
            android:padding="12dp"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvConversationName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Support Chat"
                android:textColor="@color/chat_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">

                <View
                    android:id="@+id/viewOnlineStatus"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/circle_online"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/tvOnlineStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Online"
                    android:textColor="@color/chat_secondary"
                    android:textSize="12sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tvUnreadCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/chat_on_primary"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:background="@drawable/chat_badge_bg"
                    android:padding="4dp"
                    android:minWidth="20dp"
                    android:minHeight="20dp"
                    android:gravity="center"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>

        <ImageView
            android:id="@+id/btnClearChat"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_clear"
            android:background="@drawable/chat_icon_bg"
            android:padding="12dp"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <!-- Messages RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewMessages"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginBottom="16dp"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/linearLayoutHeader"
        app:layout_constraintBottom_toTopOf="@id/linearLayoutTypingIndicator"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_chat_message" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/layoutEmptyState"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/linearLayoutHeader"
        app:layout_constraintBottom_toTopOf="@id/linearLayoutTypingIndicator"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_chat_empty"
            android:alpha="0.3"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No messages yet"
            android:textColor="@color/chat_tertiary"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Start a conversation by sending a message below"
            android:textColor="@color/chat_tertiary"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp" />

    </LinearLayout>

    <!-- Typing Indicator -->
    <LinearLayout
        android:id="@+id/linearLayoutTypingIndicator"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp"
        android:padding="12dp"
        android:background="@drawable/chat_typing_indicator_bg"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/linearLayoutInput"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ProgressBar
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:indeterminateTint="@color/chat_secondary"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/typingIndicator"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Someone is typing..."
            android:textColor="@color/chat_secondary"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Input Area -->
    <LinearLayout
        android:id="@+id/linearLayoutInput"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/chat_input_container_bg"
        android:padding="12dp"
        app:layout_constraintBottom_toTopOf="@id/linearLayoutActions"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Message Input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/etMessage"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="Type a message..."
                android:textColor="@color/chat_primary"
                android:textColorHint="@color/chat_tertiary"
                android:background="@drawable/chat_input_bg"
                android:padding="12dp"
                android:maxLines="3"
                android:inputType="textMultiLine|textCapSentences"
                android:imeOptions="actionSend"
                android:textSize="16sp"
                android:layout_marginEnd="8dp" />

            <ImageView
                android:id="@+id/btnAttach"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_attach"
                android:background="@drawable/chat_action_button_bg"
                android:padding="12dp"
                android:layout_marginEnd="8dp" />

            <ImageView
                android:id="@+id/btnVoice"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_mic"
                android:background="@drawable/chat_action_button_bg"
                android:padding="12dp"
                android:layout_marginEnd="8dp" />

            <ImageView
                android:id="@+id/btnLocation"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_location"
                android:background="@drawable/chat_action_button_bg"
                android:padding="12dp" />

        </LinearLayout>

        <!-- Voice Recording Status -->
        <LinearLayout
            android:id="@+id/layoutVoiceRecording"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp"
            android:padding="8dp"
            android:background="@drawable/voice_recording_bg"
            android:visibility="gone">

            <View
                android:layout_width="4dp"
                android:layout_height="24dp"
                android:background="@drawable/voice_recording_indicator"
                android:layout_marginEnd="12dp" />

            <TextView
                android:id="@+id/tvRecordingStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Recording..."
                android:textColor="@color/chat_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvRecordingDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="@color/chat_secondary"
                android:textSize="12sp"
                android:fontFamily="monospace" />

        </LinearLayout>

    </LinearLayout>

    <!-- Action Buttons -->
    <LinearLayout
        android:id="@+id/linearLayoutActions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp"
        app:layout_constraintBottom_toTopOf="@id/linearLayoutEmergency"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnSend"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Send"
            android:textColor="@color/chat_on_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/chat_send_button_bg"
            android:elevation="0dp"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnEmergency"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Emergency"
            android:textColor="@color/chat_on_emergency"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/chat_emergency_button_bg"
            android:elevation="0dp"
            android:minWidth="100dp" />

    </LinearLayout>

    <!-- Emergency Message Input -->
    <LinearLayout
        android:id="@+id/linearLayoutEmergency"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/emergency_input_bg"
        android:padding="12dp"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/etEmergencyMessage"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Type emergency message..."
            android:textColor="@color/chat_primary"
            android:textColorHint="@color/chat_tertiary"
            android:background="@drawable/emergency_input_field_bg"
            android:padding="12dp"
            android:maxLines="2"
            android:inputType="textMultiLine"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <Button
                android:id="@+id/btnCancelEmergency"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Cancel"
                android:textColor="@color/chat_secondary"
                android:textSize="14sp"
                android:background="@drawable/chat_cancel_button_bg"
                android:elevation="0dp"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnSendEmergency"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Send Emergency"
                android:textColor="@color/chat_on_emergency"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/chat_emergency_send_button_bg"
                android:elevation="0dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
