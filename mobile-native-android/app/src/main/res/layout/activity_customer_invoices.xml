<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/prem_navy">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/prem_navy"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="20dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/ed_card_bg"
                android:padding="10dp"
                android:src="@drawable/ic_back"
                app:tint="#FFF"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="خزنة الفواتير"
                    android:textColor="#FFF"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="كل سجلاتك المالية"
                    android:textColor="@color/customer_text_muted"
                    android:textSize="12sp"/>
            </LinearLayout>

            <ImageView
                android:id="@+id/btnSearch"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/ed_card_bg"
                android:padding="10dp"
                android:src="@drawable/ic_search"
                app:tint="@color/customer_text_muted"/>
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Analytics Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="@color/html_card_bg"
                app:strokeWidth="1dp"
                app:strokeColor="@color/customer_blue_border">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="إجمالي الإنفاق - يناير 2025"
                        android:textColor="#FFF"
                        android:textStyle="bold"
                        android:textSize="13sp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <TextView
                            android:id="@+id/tvTotalSpend"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/prem_sky"
                            android:textSize="32sp"
                            android:textStyle="bold"/>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ريال" android:textColor="@color/customer_text_muted" android:textSize="11sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--% عن الشهر الماضي" android:textColor="@color/customer_text_muted" android:textSize="10sp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Mini Chart Placeholder -->
                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/miniChart"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:layout_marginTop="20dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Filter Chips -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:scrollbars="none">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:id="@+id/chipAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="الكل"
                        android:textColor="#FFF"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:background="@drawable/ed_badge_info"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"/>
                    <TextView
                        android:id="@+id/chipCold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="مبرد ❄️"
                        android:textColor="@color/customer_text_muted"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/ed_card_bg"
                        android:clickable="true"
                        android:focusable="true"/>
                    <TextView
                        android:id="@+id/chipDry"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="جاف 📦"
                        android:textColor="@color/customer_text_muted"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/ed_card_bg"
                        android:clickable="true"
                        android:focusable="true"/>
                    <TextView
                        android:id="@+id/chipHeavy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ثقيل 🚛"
                        android:textColor="@color/customer_text_muted"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:background="@drawable/ed_card_bg"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>
            </HorizontalScrollView>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvInvoices"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="40dp"
                    tools:listitem="@layout/item_invoice_new" />

                <LinearLayout
                    android:id="@+id/emptyStateInvoices"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:visibility="gone"
                    tools:visibility="visible">
                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/ic_invoice"
                        app:tint="@color/customer_text_muted"
                        android:alpha="0.5"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="لا توجد فواتير صادرة"
                        android:textColor="@color/customer_text_muted"
                        android:textSize="14sp" />
                </LinearLayout>
            </FrameLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
