<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.Edham.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/spacing_card_margin"
    app:cardCornerRadius="@dimen/spacing_md"
    app:cardElevation="@dimen/elevation_level_2"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_card_padding">

        <!-- Card Title -->
        <TextView
            android:id="@+id/card_title"
            style="@style/TextAppearance.Edham.Card.Title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Card Title" />

        <!-- Card Subtitle -->
        <TextView
            android:id="@+id/card_subtitle"
            style="@style/TextAppearance.Edham.Card.Subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Card subtitle description" />

        <!-- Card Content -->
        <TextView
            android:id="@+id/card_content"
            style="@style/TextAppearance.Edham.Card.Description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="This is the main content of the card. It can contain multiple lines of text and should be kept concise." />

        <!-- Card Metadata -->
        <TextView
            android:id="@+id/card_metadata"
            style="@style/TextAppearance.Edham.Card.Metadata"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Last updated: 2 hours ago" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
