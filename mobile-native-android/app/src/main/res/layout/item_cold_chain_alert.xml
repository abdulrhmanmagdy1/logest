<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Alert Icon -->
        <ImageView
            android:id="@+id/alertIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_warning"
            android:layout_marginEnd="12dp" />

        <!-- Alert Content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Alert Title and Status -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/alertTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Temperature Too Low"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/alertStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ACTIVE"
                    android:textColor="@color/status_active"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:background="@drawable/status_bg"
                    android:padding="4dp" />

            </LinearLayout>

            <!-- Alert Message -->
            <TextView
                android:id="@+id/alertMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Temperature: 15.0°C (Threshold: 18.0°C)"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginBottom="4dp" />

            <!-- Alert Time and Severity -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/alertTime"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="14:32:15"
                    android:textColor="@color/text_tertiary"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/alertSeverity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CRITICAL"
                    android:textColor="@color/severity_critical"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:background="@drawable/severity_bg"
                    android:padding="2dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="8dp">

            <Button
                android:id="@+id/btnAcknowledge"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Ack"
                android:textSize="10sp"
                android:textColor="@color/text_on_primary"
                android:background="@drawable/ack_button_bg"
                android:layout_marginBottom="4dp"
                android:minWidth="48dp" />

            <Button
                android:id="@+id/btnResolve"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Resolve"
                android:textSize="10sp"
                android:textColor="@color/text_on_primary"
                android:background="@drawable/resolve_button_bg"
                android:minWidth="48dp"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
