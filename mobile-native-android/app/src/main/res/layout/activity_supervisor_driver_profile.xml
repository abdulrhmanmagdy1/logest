<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ed_deep">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ed_card_bg">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_back"
            app:title="ملف السائق"
            app:titleTextColor="@color/ed_white" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Profile Header -->
            <com.google.android.material.card.MaterialCardView
                style="@style/SupervisorCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:id="@+id/tvAvatarLarge"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:background="@drawable/bg_stat_icon_teal"
                        android:gravity="center"
                        android:text="أم"
                        android:textColor="@color/ed_white"
                        android:textSize="32sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDriverName"
                        style="@style/SupervisorText.Title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="أحمد محمد" />

                    <TextView
                        android:id="@+id/tvDriverEmail"
                        style="@style/SupervisorText.Subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="ahmed@edham.co" />

                    <TextView
                        android:id="@+id/tvStatusBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_role_badge"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:text="نشط الآن"
                        android:textColor="@color/ed_success"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Stats Grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:alignmentMode="alignMargins">

                <com.google.android.material.card.MaterialCardView
                    style="@style/SupervisorCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView style="@style/SupervisorText.StatValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="126" android:textSize="20sp"/>
                        <TextView style="@style/SupervisorText.StatLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="إجمالي الرحلات" android:textSize="10sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/SupervisorCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView style="@style/SupervisorText.StatValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="4.9" android:textColor="@color/ed_orange" android:textSize="20sp"/>
                        <TextView style="@style/SupervisorText.StatLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="تقييم العميل" android:textSize="10sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

            <!-- Vehicle Info -->
            <TextView
                style="@style/SupervisorText.Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:text="🚛 الشاحنة المعينة"
                android:textSize="16sp" />

            <com.google.android.material.card.MaterialCardView
                style="@style/SupervisorCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView android:id="@+id/tvVehicleType" style="@style/SupervisorText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="مرسيدس أكتروس" android:textStyle="bold"/>
                        <TextView android:id="@+id/tvPlateNumber" style="@style/SupervisorText.Subtitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="أ ب ج ١٢٣٤"/>
                    </LinearLayout>
                    <TextView style="@style/SupervisorText.Title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-18°م" android:textColor="@color/ed_teal_lighter" android:textSize="18sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCallDriver"
                    style="@style/SupervisorButton.Primary"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="اتصال هاتفي"
                    app:backgroundTint="@color/ed_success"
                    app:icon="@drawable/ic_call" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMessageDriver"
                    style="@style/SupervisorButton.Outline"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="إرسال رسالة"
                    app:icon="@drawable/ic_chat" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
