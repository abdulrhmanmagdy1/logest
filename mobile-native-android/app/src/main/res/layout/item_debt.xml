<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textDebtId"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="DEBT-2024-001"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/textStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="متأخر"
                android:textColor="@color/red_500"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/status_badge"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp" />

        </LinearLayout>

        <!-- Customer Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textCustomerName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="محمد أحمد"
                android:textColor="@color/gray_600"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/textCustomerPhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+966501234567"
                android:textColor="@color/gray_500"
                android:textSize="11sp"
                android:drawableStart="@drawable/ic_phone_small"
                android:drawablePadding="4dp" />

        </LinearLayout>

        <!-- Amount Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="المبلغ الإجمالي:"
                    android:textColor="@color/gray_600"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/textTotalAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1,500.00 ريال"
                    android:textColor="@color/black"
                    android:textSize="12sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="المبلغ المدفوع:"
                    android:textColor="@color/gray_600"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/textPaidAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="500.00 ريال"
                    android:textColor="@color/green_500"
                    android:textSize="12sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="المبلغ المتبقي:"
                    android:textColor="@color/gray_600"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/textRemainingAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1,000.00 ريال"
                    android:textColor="@color/red_500"
                    android:textSize="12sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

        <!-- Progress Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="التقدم:"
                android:textColor="@color/gray_600"
                android:textSize="11sp"
                android:layout_marginEnd="8dp" />

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="0dp"
                android:layout_height="6dp"
                android:layout_weight="1"
                android:progress="33"
                android:progressDrawable="@drawable/progress_bar_background"
                style="?android:attr/progressBarStyleHorizontal" />

            <TextView
                android:id="@+id/textProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="33%"
                android:textColor="@color/primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <!-- Due Date and Overdue Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="تاريخ الاستحقاق:"
                    android:textColor="@color/gray_600"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/textDueDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2024/01/15"
                    android:textColor="@color/orange_500"
                    android:textSize="11sp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutOverdueDays"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="end"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="التأخير:"
                    android:textColor="@color/gray_600"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/textOverdueDays"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3 أيام"
                    android:textColor="@color/red_500"
                    android:textSize="11sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Last Payment Date -->
        <LinearLayout
            android:id="@+id/layoutLastPaymentDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="آخر دفعة:"
                android:textColor="@color/gray_600"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/textLastPaymentDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="2024/01/10"
                android:textColor="@color/green_500"
                android:textSize="11sp"
                android:gravity="end" />

        </LinearLayout>

        <!-- Payment Plan Info -->
        <LinearLayout
            android:id="@+id/layoutPaymentPlan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="خطة الدفع:"
                android:textColor="@color/gray_600"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/textPaymentPlanStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="نشط"
                android:textColor="@color/blue_500"
                android:textSize="11sp"
                android:gravity="end" />

        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonDetails"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:text="تفاصيل"
                android:textColor="@color/white"
                android:textSize="12sp"
                app:backgroundTint="@color/blue_500"
                app:cornerRadius="4dp"
                style="@style/Widget.MaterialComponents.Button.TextButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonPayment"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:text="دفع"
                android:textColor="@color/white"
                android:textSize="12sp"
                app:backgroundTint="@color/green_500"
                app:cornerRadius="4dp"
                style="@style/Widget.MaterialComponents.Button.TextButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonPlan"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:text="خطة"
                android:textColor="@color/white"
                android:textSize="12sp"
                app:backgroundTint="@color/purple_500"
                app:cornerRadius="4dp"
                style="@style/Widget.MaterialComponents.Button.TextButton" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
