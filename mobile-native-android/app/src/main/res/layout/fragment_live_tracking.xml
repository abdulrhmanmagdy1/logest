<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".tracking.LiveTrackingFragment">

    <!-- Map Container -->
    <fragment
        android:id="@+id/map_fragment"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top Action Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/overlay_light"
        app:elevation="4dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Live Tracking"
            app:navigationIcon="@drawable/ic_menu"
            app:menu="@menu/tracking_menu" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Floating Action Buttons -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|bottom"
        android:layout_margin="@dimen/spacing_lg"
        android:orientation="vertical"
        android:gravity="end">

        <!-- Center on Vehicle FAB -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_center_vehicle"
            style="@style/Widget.Edham.Button.FAB"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            app:srcCompat="@drawable/ic_center_on_vehicle"
            app:tint="@color/text_on_primary" />

        <!-- Traffic Toggle FAB -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_traffic_toggle"
            style="@style/Widget.Edham.Button.FAB"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            app:srcCompat="@drawable/ic_traffic"
            app:tint="@color/text_on_primary" />

        <!-- Heatmap Toggle FAB -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_heatmap_toggle"
            style="@style/Widget.Edham.Button.FAB"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:srcCompat="@drawable/ic_heatmap"
            app:tint="@color/text_on_primary" />

    </LinearLayout>

    <!-- Bottom Sheet - Vehicle Details -->
    <LinearLayout
        android:id="@+id/bottom_sheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bottom_sheet_background"
        android:elevation="@dimen/elevation_level_4"
        android:orientation="vertical"
        app:behavior_hideable="false"
        app:behavior_peekHeight="@dimen/bottom_sheet_peek_height"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <!-- Drag Handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center"
            android:layout_margin="@dimen/spacing_md"
            android:background="@drawable/drag_handle" />

        <!-- Vehicle Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="@dimen/spacing_lg">

            <!-- Vehicle Icon -->
            <ImageView
                android:id="@+id/vehicle_icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="@dimen/spacing_md"
                android:src="@drawable/ic_truck"
                app:tint="@color/color_primary_500" />

            <!-- Vehicle Details -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/vehicle_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Truck - KSA 1234"
                    style="@style/TextAppearance.Edham.TitleMedium"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/vehicle_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Active • On Route"
                    style="@style/TextAppearance.Edham.LabelMedium"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>

            <!-- Live Indicator -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/live_indicator_background"
                android:paddingHorizontal="@dimen/spacing_sm"
                android:paddingVertical="@dimen/spacing_xs">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_marginEnd="@dimen/spacing_xs"
                    android:background="@drawable/live_dot"
                    android:backgroundTint="@color/color_success_500" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LIVE"
                    style="@style/TextAppearance.Edham.LabelSmall"
                    android:textColor="@color/color_success_500" />

            </LinearLayout>

        </LinearLayout>

        <!-- Stats Grid -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_lg"
            android:paddingBottom="@dimen/spacing_lg">

            <!-- Speed -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/speed_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="65"
                    style="@style/TextAppearance.Edham.HeadlineSmall"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="km/h"
                    style="@style/TextAppearance.Edham.LabelSmall"
                    android:textColor="@color/text_tertiary" />

            </LinearLayout>

            <!-- Distance -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/distance_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="125"
                    style="@style/TextAppearance.Edham.HeadlineSmall"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="km"
                    style="@style/TextAppearance.Edham.LabelSmall"
                    android:textColor="@color/text_tertiary" />

            </LinearLayout>

            <!-- ETA -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/eta_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2:45"
                    style="@style/TextAppearance.Edham.HeadlineSmall"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ETA"
                    style="@style/TextAppearance.Edham.LabelSmall"
                    android:textColor="@color/text_tertiary" />

            </LinearLayout>

            <!-- Fuel -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/fuel_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="75%"
                    style="@style/TextAppearance.Edham.HeadlineSmall"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fuel"
                    style="@style/TextAppearance.Edham.LabelSmall"
                    android:textColor="@color/text_tertiary" />

            </LinearLayout>

        </LinearLayout>

        <!-- Progress Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_lg"
            android:paddingBottom="@dimen/spacing_lg">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Route Progress"
                style="@style/TextAppearance.Edham.LabelMedium"
                android:textColor="@color/text_secondary"
                android:layout_marginEnd="@dimen/spacing_md" />

            <ProgressBar
                android:id="@+id/route_progress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:progressTint="@color/color_primary_500"
                android:progress="65" />

            <TextView
                android:id="@+id/progress_percentage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="65%"
                style="@style/TextAppearance.Edham.LabelMedium"
                android:textColor="@color/text_secondary"
                android:layout_marginStart="@dimen/spacing_md" />

        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="@dimen/spacing_lg"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_navigation"
                style="@style/Widget.Edham.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/spacing_md"
                android:text="Navigate"
                app:icon="@drawable/ic_navigation"
                app:iconGravity="textStart" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_contact_driver"
                style="@style/Widget.Edham.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_md"
                android:text="Contact"
                app:icon="@drawable/ic_phone"
                app:iconGravity="textStart" />

        </LinearLayout>

    </LinearLayout>

    <!-- Live Status Overlay -->
    <LinearLayout
        android:id="@+id/live_status_overlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="@dimen/spacing_lg"
        android:background="@drawable/status_overlay_background"
        android:elevation="@dimen/elevation_level_3"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md"
        android:visibility="gone"
        tools:visibility="visible">

        <!-- Status Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Live Status"
            style="@style/TextAppearance.Edham.LabelMedium"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="@dimen/spacing_sm" />

        <!-- Status Items -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/spacing_xs">

                <View
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:layout_marginEnd="@dimen/spacing_xs"
                    android:background="@drawable/status_dot"
                    android:backgroundTint="@color/color_success_500" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GPS Connected"
                    style="@style/TextAppearance.Edham.LabelSmall"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/spacing_xs">

                <View
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:layout_marginEnd="@dimen/spacing_xs"
                    android:background="@drawable/status_dot"
                    android:backgroundTint="@color/color_success_500" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Network Active"
                    style="@style/TextAppearance.Edham.LabelSmall"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:layout_marginEnd="@dimen/spacing_xs"
                    android:background="@drawable/status_dot"
                    android:backgroundTint="@color/color_info_500" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Updating..."
                    style="@style/TextAppearance.Edham.LabelSmall"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Alert Banner -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/alert_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_margin="@dimen/spacing_lg"
        style="@style/Widget.Edham.Card.Alert"
        android:visibility="gone"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="@dimen/spacing_md"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="@dimen/spacing_md"
                android:src="@drawable/ic_warning"
                app:tint="@color/color_warning_500" />

            <TextView
                android:id="@+id/alert_message"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Vehicle has exceeded speed limit"
                style="@style/TextAppearance.Edham.LabelMedium"
                android:textColor="@color/text_primary" />

            <ImageView
                android:id="@+id/alert_dismiss"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_close"
                app:tint="@color/text_secondary"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="@dimen/spacing_xs" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
