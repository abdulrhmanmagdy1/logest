<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_md"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="@drawable/ripple_effect"
    tools:context=".shipment.KanbanBoardFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <!-- Header with Priority and Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/spacing_sm">

            <!-- Priority Badge -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/priority_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/spacing_sm"
                app:cardCornerRadius="4dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/color_warning_100">

                <TextView
                    android:id="@+id/priority_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HIGH"
                    style="@style/TextAppearance.Edham.LabelSmall"
                    android:textColor="@color/color_warning_700"
                    android:paddingHorizontal="@dimen/spacing_xs"
                    android:paddingVertical="@dimen/spacing_xs" />

            </com.google.android.material.card.MaterialCardView>

            <!-- Shipment ID -->
            <TextView
                android:id="@+id/shipment_id"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SHP-2024-001234"
                style="@style/TextAppearance.Edham.LabelMedium"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                tools:text="SHP-2024-001234" />

            <!-- Status Indicator -->
            <View
                android:id="@+id/status_indicator"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/circle_background"
                android:backgroundTint="@color/color_info_500" />

        </LinearLayout>

        <!-- Customer Information -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/spacing_sm"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="@dimen/spacing_xs"
                android:src="@drawable/ic_customer"
                app:tint="@color/text_tertiary" />

            <TextView
                android:id="@+id/customer_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ahmed Mohammed"
                style="@style/TextAppearance.Edham.BodySmall"
                android:textColor="@color/text_secondary"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Ahmed Mohammed" />

        </LinearLayout>

        <!-- Route Information -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/spacing_sm"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="@dimen/spacing_xs"
                android:src="@drawable/ic_location_small"
                app:tint="@color/text_tertiary" />

            <TextView
                android:id="@+id/route_info"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Riyadh → Jeddah"
                style="@style/TextAppearance.Edham.BodySmall"
                android:textColor="@color/text_secondary"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Riyadh → Jeddah" />

        </LinearLayout>

        <!-- Package Information -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/spacing_sm"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="@dimen/spacing_xs"
                android:src="@drawable/ic_package_small"
                app:tint="@color/text_tertiary" />

            <TextView
                android:id="@+id/package_info"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="2.5 kg • Electronics"
                style="@style/TextAppearance.Edham.BodySmall"
                android:textColor="@color/text_secondary"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="2.5 kg • Electronics" />

        </LinearLayout>

        <!-- Special Indicators -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/spacing_sm"
            android:gravity="center_vertical">

            <!-- Cold Chain Indicator -->
            <LinearLayout
                android:id="@+id/cold_chain_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:background="@drawable/rounded_background"
                android:backgroundTint="@color/ice_blue_100"
                android:paddingHorizontal="@dimen/spacing_xs"
                android:paddingVertical="@dimen/spacing_xs"
                android:visibility="gone"
                tools:visibility="visible">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginEnd="@dimen/spacing_xs"
                    android:src="@drawable/ic_snowflake"
                    app:tint="@color/ice_blue_700" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cold"
                    style="@style/TextAppearance.Edham.LabelSmall"
                    android:textColor="@color/ice_blue_700"
                    android:textSize="10sp" />

            </LinearLayout>

            <!-- Multi-stop Indicator -->
            <LinearLayout
                android:id="@+id/multi_stop_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:background="@drawable/rounded_background"
                android:backgroundTint="@color/purple_100"
                android:paddingHorizontal="@dimen/spacing_xs"
                android:paddingVertical="@dimen/spacing_xs"
                android:visibility="gone"
                tools:visibility="visible">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginEnd="@dimen/spacing_xs"
                    android:src="@drawable/ic_route"
                    app:tint="@color/purple_700" />

                <TextView
                    android:id="@+id/stop_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3 stops"
                    style="@style/TextAppearance.Edham.LabelSmall"
                    android:textColor="@color/purple_700"
                    android:textSize="10sp"
                    tools:text="3 stops" />

            </LinearLayout>

            <!-- Delayed Indicator -->
            <LinearLayout
                android:id="@+id/delayed_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/rounded_background"
                android:backgroundTint="@color/color_error_100"
                android:paddingHorizontal="@dimen/spacing_xs"
                android:paddingVertical="@dimen/spacing_xs"
                android:visibility="gone"
                tools:visibility="visible">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginEnd="@dimen/spacing_xs"
                    android:src="@drawable/ic_alert"
                    app:tint="@color/color_error_700" />

                <TextView
                    android:id="@+id/delay_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Delayed"
                    style="@style/TextAppearance.Edham.LabelSmall"
                    android:textColor="@color/color_error_700"
                    android:textSize="10sp"
                    tools:text="Delayed" />

            </LinearLayout>

        </LinearLayout>

        <!-- Progress Bar (for in-transit shipments) -->
        <LinearLayout
            android:id="@+id/progress_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="@dimen/spacing_sm"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Progress"
                style="@style/TextAppearance.Edham.LabelSmall"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="@dimen/spacing_xs" />

            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:progressTint="@color/color_primary_500"
                android:progress="65"
                tools:progress="65" />

            <TextView
                android:id="@+id/progress_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="65% Complete"
                style="@style/TextAppearance.Edham.LabelSmall"
                android:textColor="@color/text_tertiary"
                android:layout_marginTop="@dimen/spacing_xs"
                tools:text="65% Complete" />

        </LinearLayout>

        <!-- Time Information -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Created Time -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginEnd="@dimen/spacing_xs"
                    android:src="@drawable/ic_clock_small"
                    app:tint="@color/text_tertiary" />

                <TextView
                    android:id="@+id/time_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2 hours ago"
                    style="@style/TextAppearance.Edham.LabelSmall"
                    android:textColor="@color/text_tertiary"
                    tools:text="2 hours ago" />

            </LinearLayout>

            <!-- ETA (for active shipments) -->
            <LinearLayout
                android:id="@+id/eta_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/rounded_background"
                android:backgroundTint="@color/color_success_100"
                android:paddingHorizontal="@dimen/spacing_xs"
                android:paddingVertical="@dimen/spacing_xs"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/eta_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ETA 3:30 PM"
                    style="@style/TextAppearance.Edham.LabelSmall"
                    android:textColor="@color/color_success_700"
                    android:textSize="10sp"
                    tools:text="ETA 3:30 PM" />

            </LinearLayout>

        </LinearLayout>

        <!-- Driver Assignment (for assigned shipments) -->
        <LinearLayout
            android:id="@+id/driver_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="@dimen/spacing_sm"
            android:background="@drawable/rounded_background"
            android:backgroundTint="@color/surface_variant"
            android:padding="@dimen/spacing_sm"
            android:visibility="gone"
            tools:visibility="visible">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:src="@drawable/ic_driver"
                app:tint="@color/text_secondary" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Driver"
                    style="@style/TextAppearance.Edham.LabelSmall"
                    android:textColor="@color/text_tertiary" />

                <TextView
                    android:id="@+id/driver_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mohammed Ali"
                    style="@style/TextAppearance.Edham.LabelMedium"
                    android:textColor="@color/text_primary"
                    tools:text="Mohammed Ali" />

            </LinearLayout>

            <ImageView
                android:id="@+id/call_driver"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_phone"
                android:background="@drawable/ripple_background_circle"
                android:padding="@dimen/spacing_xs"
                app:tint="@color/color_primary_500" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
