<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/prem_navy"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="اختيار المركبة"
            android:textColor="@color/html_white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="اختر نوع السيارة المناسب لحجم حمولتك"
            android:textColor="@color/customer_text_muted"
            android:textSize="13sp" />

        <RadioGroup
            android:id="@+id/rgVehicles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/html_card_bg"
                app:strokeWidth="1dp"
                app:strokeColor="@color/customer_blue_border">
                <RadioButton
                    android:id="@+id/rbTricycle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="تروسيكل"
                    android:textColor="#FFF"
                    android:buttonTint="@color/prem_sky"/>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/html_card_bg"
                app:strokeWidth="1dp"
                app:strokeColor="@color/customer_blue_border">
                <RadioButton
                    android:id="@+id/rbQuarter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="ربع نقل"
                    android:textColor="#FFF"
                    android:buttonTint="@color/prem_sky"/>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/html_card_bg"
                app:strokeWidth="1dp"
                app:strokeColor="@color/customer_blue_border">
                <RadioButton
                    android:id="@+id/rbHalf"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="نصف نقل"
                    android:textColor="#FFF"
                    android:buttonTint="@color/prem_sky"/>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/html_card_bg"
                app:strokeWidth="1dp"
                app:strokeColor="@color/customer_blue_border">
                <RadioButton
                    android:id="@+id/rbJumbo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="جامبو"
                    android:textColor="#FFF"
                    android:buttonTint="@color/prem_sky"/>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/html_card_bg"
                app:strokeWidth="1dp"
                app:strokeColor="@color/customer_blue_border">
                <RadioButton
                    android:id="@+id/rbTrailer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="تريلا"
                    android:textColor="#FFF"
                    android:buttonTint="@color/prem_sky"/>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/html_card_bg"
                app:strokeWidth="1dp"
                app:strokeColor="@color/customer_blue_border">
                <RadioButton
                    android:id="@+id/rbOther"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="أخرى"
                    android:textColor="#FFF"
                    android:buttonTint="@color/prem_sky"/>
            </com.google.android.material.card.MaterialCardView>

        </RadioGroup>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
