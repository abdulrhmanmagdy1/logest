<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cockpit_black">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Status Header (Tactical Style) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="@color/cockpit_black_2"
                app:strokeWidth="1dp"
                app:strokeColor="@color/border">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:src="@drawable/ic_driver"
                        android:background="@drawable/circle_glow"
                        android:backgroundTint="@color/green_glow"
                        android:padding="10dp"
                        app:tint="@color/cockpit_green"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">
                        <TextView android:id="@+id/tvDriverName" android:text="---" android:textColor="#FFF" android:textSize="18sp" android:textStyle="bold"/>
                        <TextView android:id="@+id/tvDriverRank" android:text="---" android:textColor="@color/cockpit_green" android:textSize="11sp" android:textStyle="bold"/>
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchOnline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        app:thumbTint="@color/cockpit_green"
                        app:trackTint="@color/green_glow"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tactical Tabs -->
            <com.google.android.material.tabs.TabLayout
                android:id="@+id/cockpitTabs"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:background="@color/cockpit_card"
                app:tabIndicatorColor="@color/cockpit_green"
                app:tabSelectedTextColor="@color/cockpit_green"
                app:tabTextColor="@color/customer_text_muted"
                app:tabMode="fixed"
                app:tabIndicatorGravity="bottom"
                app:tabIndicatorHeight="3dp">
                <com.google.android.material.tabs.TabItem android:text="الرئيسية" />
                <com.google.android.material.tabs.TabItem android:text="المهمة" />
                <com.google.android.material.tabs.TabItem android:text="الكوكبيت" />
            </com.google.android.material.tabs.TabLayout>

            <!-- Tactical Telemetry & SOS Hub -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <!-- Temperature Gauge Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.2"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="@color/cockpit_black_2"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/border">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center">
                        <TextView android:text="درجة المبرد" android:textColor="@color/customer_text_muted" android:textSize="10sp" android:textAllCaps="true"/>
                        <com.edham.logistics.ui.custom.TemperatureGauge
                            android:id="@+id/tempGauge"
                            android:layout_width="120dp"
                            android:layout_height="120dp"
                            android:layout_marginTop="8dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- SOS & Quick Actions -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.8"
                    android:orientation="vertical">

                    <!-- SOS Button -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnSOS"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:layout_marginBottom="8dp"
                        app:cardCornerRadius="20dp"
                        app:cardBackgroundColor="@color/ed_rust_15"
                        app:strokeWidth="2dp"
                        app:strokeColor="@color/ed_rust"
                        android:clickable="true"
                        android:focusable="true">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView android:text="🚨" android:textSize="24sp"/>
                            <TextView android:text="SOS" android:textColor="@color/ed_rust" android:textStyle="bold" android:textSize="12sp" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Performance Scorecard -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnScorecard"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        app:cardCornerRadius="20dp"
                        app:cardBackgroundColor="@color/cockpit_black_2"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/border"
                        android:clickable="true"
                        android:focusable="true">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView android:id="@+id/tvDriverScore" android:text="98" android:textColor="@color/cockpit_green" android:textStyle="bold" android:textSize="20sp"/>
                            <TextView android:text="مؤشر الأداء" android:textColor="@color/customer_text_muted" android:textSize="9sp" android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </LinearLayout>

            <!-- Earnings Radar Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="@color/cockpit_black_2"
                app:strokeWidth="1dp"
                app:strokeColor="@color/blue_glow">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center">

                    <TextView android:text="أرباح اليوم" android:textColor="@color/customer_text_muted" android:textSize="11sp" android:textAllCaps="true" android:letterSpacing="0.2"/>

                    <TextView
                        android:id="@+id/tvTodayEarnings"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1,240"
                        android:textColor="@color/cockpit_blue"
                        android:textSize="42sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"/>

                    <TextView android:text="ريال سعودي" android:textColor="@color/customer_text_muted" android:textSize="14sp"/>

                    <!-- Goal Progress Bar -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:orientation="vertical">
                        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                            <TextView android:id="@+id/tvDailyGoal" android:text="---" android:textColor="@color/customer_text_muted" android:textSize="11sp"/>
                            <TextView android:id="@+id/tvGoalPercent" android:layout_alignParentEnd="true" android:text="0%" android:textColor="@color/cockpit_green" android:textSize="11sp" android:textStyle="bold"/>
                        </RelativeLayout>
                        <ProgressBar
                            android:id="@+id/pbGoal"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:progress="0"
                            android:progressTint="@color/cockpit_green"
                            android:layout_marginTop="8dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Active Mission (The Ignition Center) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="📍 المهمة الحالية"
                android:textColor="#FFF"
                android:textStyle="bold"
                android:textSize="16sp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="@color/cockpit_card"
                app:strokeWidth="1dp"
                app:strokeColor="@color/green_glow">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView android:text="● نشطة" android:textColor="@color/cockpit_green" android:textSize="11sp" android:textStyle="bold" android:background="@drawable/ed_badge_success" android:paddingHorizontal="10dp" android:paddingVertical="4dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:orientation="horizontal">
                        <View android:layout_width="12dp" android:layout_height="12dp" android:background="@drawable/circle_green" android:layout_marginTop="4dp"/>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:orientation="vertical">
                            <TextView android:id="@+id/tvPickupName" android:text="---" android:textColor="#FFF" android:textStyle="bold" android:textSize="15sp"/>
                            <TextView android:id="@+id/tvPickupAddress" android:text="---" android:textColor="@color/customer_text_muted" android:textSize="11sp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="1.5dp" android:layout_height="30dp" android:background="@color/border_green" android:layout_marginStart="5dp" android:alpha="0.3"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <View android:layout_width="12dp" android:layout_height="12dp" android:background="@drawable/circle_red" android:layout_marginTop="4dp"/>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:orientation="vertical">
                            <TextView android:id="@+id/tvDeliveryName" android:text="---" android:textColor="#FFF" android:textStyle="bold" android:textSize="15sp"/>
                            <TextView android:id="@+id/tvDeliveryAddress" android:text="---" android:textColor="@color/customer_text_muted" android:textSize="11sp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStartMission"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:layout_marginTop="24dp"
                        android:text="إشعال المحرك — بدء الرحلة"
                        app:cornerRadius="16dp"
                        app:backgroundTint="@color/cockpit_green"
                        android:textColor="@color/cockpit_black"
                        android:textStyle="bold"
                        app:icon="@drawable/ic_play"
                        app:iconTint="@color/cockpit_black"
                        app:elevation="8dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
