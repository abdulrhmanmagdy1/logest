<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/prem_navy"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="مراجعة الطلب"
            android:textColor="@color/html_white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="تأكد من تفاصيل شحنتك قبل الدفع"
            android:textColor="@color/customer_text_muted"
            android:textSize="13sp" />

        <!-- Summary Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="24dp"
            app:cardBackgroundColor="@color/html_card_bg"
            app:strokeWidth="1dp"
            app:strokeColor="@color/customer_blue_border">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:background="#1A2196F3">
                    <TextView
                        android:id="@+id/review_order_id"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/customer_text_muted"
                        android:textSize="11sp"
                        android:fontFamily="monospace"/>
                    <TextView
                        android:id="@+id/review_type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text=""
                        android:textColor="@color/prem_sky"
                        android:textStyle="bold"
                        android:textSize="12sp"/>
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="من"
                        android:textColor="@color/prem_sky"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"/>
                    <TextView
                        android:id="@+id/review_pickup"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="الرياض، حي العزيزية"
                        android:textColor="#FFF"
                        android:textSize="14sp"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="إلى"
                        android:textColor="@color/customer_danger"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"/>
                    <TextView
                        android:id="@+id/review_delivery"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="جدة، المنطقة الصناعية"
                        android:textColor="#FFF"
                        android:textSize="14sp"
                        android:layout_marginBottom="12dp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/customer_blue_border"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="الوزن"
                            android:textColor="@color/customer_text_muted"
                            android:textSize="12sp"/>
                        <TextView
                            android:id="@+id/review_weight"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="#FFF"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#0D2196F3"
                    android:padding="20dp"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="المبلغ الإجمالي"
                        android:textColor="#FFF"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/review_total_price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/prem_sky"
                        android:textSize="24sp"
                        android:textStyle="bold"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Payment Methods -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="طريقة الدفع"
            android:textColor="#FFF"
            android:textStyle="bold"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="@color/html_card_bg"
                app:strokeWidth="1.5dp"
                app:strokeColor="@color/prem_sky">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:gravity="center_vertical">
                    <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_wallet" app:tint="@color/prem_sky"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:text="محفظة إدهام" android:textColor="#FFF" android:textStyle="bold"/>
                    <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true" android:buttonTint="@color/prem_sky"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
