<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/html_deep">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="إدارة القطع والمخزون"
                android:textColor="@color/html_white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_parts_summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="87 صنف مسجل في المستودع"
                android:textColor="@color/html_text_muted"
                android:textSize="13sp"
                android:layout_marginBottom="24dp" />

            <!-- Inventory Stats Grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:alignmentMode="alignMargins"
                android:layout_marginBottom="20dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="@color/html_card_bg"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚙️ أصناف القطع" android:textColor="@color/html_teal_lighter" android:textSize="11sp"/>
                        <TextView android:id="@+id/tv_total_parts_count" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="87" android:textColor="#FFF" android:textSize="20sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="@color/html_card_bg"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚠️ نفاذ وشيك" android:textColor="@color/html_rust" android:textSize="11sp"/>
                        <TextView android:id="@+id/tv_low_stock_count" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="12" android:textColor="#FFF" android:textSize="20sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="@color/html_card_bg"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔄 طلبات توريد" android:textColor="@color/html_orange" android:textSize="11sp"/>
                        <TextView android:id="@+id/tv_pending_orders" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="24" android:textColor="#FFF" android:textSize="20sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="@color/html_card_bg"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💰 قيمة المخزون" android:textColor="@color/html_success" android:textSize="11sp"/>
                        <TextView android:id="@+id/tv_inventory_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="185K" android:textColor="#FFF" android:textSize="20sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </GridLayout>

            <!-- Inventory List -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📦 مخزون القطع"
                android:textColor="#FFF"
                android:textStyle="bold"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPartsInventory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:listitem="@layout/item_part_inventory" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="24dp"
        android:text="طلب توريد"
        android:textColor="#FFF"
        app:icon="@drawable/ic_add"
        app:iconTint="#FFF"
        app:backgroundTint="@color/html_teal_lighter"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
