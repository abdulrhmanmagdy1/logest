<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_background"
    android:padding="16dp">

    <!-- Header -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Barcode &amp; QR Scanner"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scan Status -->
    <LinearLayout
        android:id="@+id/linearLayoutScanStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/ivScanStatusIcon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_scanner"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tvScanStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Ready to scan"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <View
            android:id="@+id/viewScanIndicator"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/circle_indicator"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <!-- Scanner Preview Area -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardScanner"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/linearLayoutScanStatus"
        app:layout_constraintBottom_toTopOf="@id/linearLayoutScanButtons"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

            <!-- Scanner Icon -->
            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_scanner"
                android:tint="@color/text_secondary"
                android:layout_marginBottom="16dp" />

            <!-- Scanner Instructions -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap scan button to start"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Position barcode/QR code in camera view"
                android:textColor="@color/text_tertiary"
                android:textSize="12sp"
                android:gravity="center" />

            <!-- Scan Count -->
            <TextView
                android:id="@+id/tvScanCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scan #0"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="16dp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Scan Buttons -->
    <LinearLayout
        android:id="@+id/linearLayoutScanButtons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/cardScanner"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnScanBarcode"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:text="Scan Barcode"
            android:textColor="@color/text_on_primary"
            android:background="@drawable/primary_button_bg"
            android:layout_marginEnd="8dp"
            android:minHeight="64dp" />

        <Button
            android:id="@+id/btnScanQR"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:text="Scan QR"
            android:textColor="@color/text_on_primary"
            android:background="@drawable/secondary_button_bg"
            android:layout_marginEnd="8dp"
            android:minHeight="64dp" />

        <Button
            android:id="@+id/btnManualEntry"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:text="Manual"
            android:textColor="@color/text_on_primary"
            android:background="@drawable/tertiary_button_bg"
            android:minHeight="64dp" />

    </LinearLayout>

    <!-- Manual Entry -->
    <LinearLayout
        android:id="@+id/layoutManualEntry"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/linearLayoutScanButtons"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/etManualCode"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:hint="Enter code manually"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:background="@drawable/search_input_bg"
            android:padding="12dp"
            android:layout_marginEnd="8dp"
            android:imeOptions="actionDone"
            android:inputType="text"
            android:maxLines="1" />

        <Button
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Process"
            android:textSize="12sp"
            android:textColor="@color/text_on_primary"
            android:background="@drawable/primary_button_bg"
            android:minWidth="64dp" />

    </LinearLayout>

    <!-- Scan Result -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardScanResult"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/layoutManualEntry"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Result Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Scan Result"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnClearResult"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Clear"
                    android:textSize="10sp"
                    android:textColor="@color/text_on_primary"
                    android:background="@drawable/secondary_button_bg"
                    android:minWidth="48dp" />

            </LinearLayout>

            <!-- Scanned Code -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Code:"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tvScannedCode"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="123456789"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:background="@drawable/code_bg"
                    android:padding="8dp"
                    android:fontFamily="monospace" />

            </LinearLayout>

            <!-- Scan Type and Time -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvScanType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BARCODE"
                    android:textColor="@color/status_active"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:background="@drawable/status_bg"
                    android:padding="4dp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tvScanTime"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="14:30:25"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- Item Information -->
            <TextView
                android:id="@+id/tvItemInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Item information will appear here"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/item_info_bg"
                android:padding="8dp" />

            <!-- Process Button -->
            <Button
                android:id="@+id/btnProcessItem"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="View Item Details"
                android:textColor="@color/text_on_primary"
                android:background="@drawable/primary_button_bg"
                android:layout_marginTop="8dp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Bottom Actions -->
    <LinearLayout
        android:id="@+id/linearLayoutBottomActions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnViewHistory"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="History"
            android:textColor="@color/text_on_primary"
            android:background="@drawable/secondary_button_bg"
            android:layout_marginEnd="8dp"
            android:minHeight="56dp" />

        <Button
            android:id="@+id/btnExportSession"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="Export"
            android:textColor="@color/text_on_primary"
            android:background="@drawable/tertiary_button_bg"
            android:minHeight="56dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
