<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_50"
    tools:context=".feature.tracking.presentation.ui.FleetTrackingFragment">

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Main Content -->
    <LinearLayout
        android:id="@+id/contentLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Header with Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:background="@color/white"
            android:elevation="4dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="تتبع الأسطول"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <!-- Search Bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:orientation="horizontal"
                    android:background="@drawable/search_background"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_search"
                        android:tint="@color/gray_500"
                        android:layout_marginEnd="8dp" />

                    <EditText
                        android:id="@+id/editTextSearch"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="ابحث عن سائق أو مركبة..."
                        android:background="@null"
                        android:textSize="14sp"
                        android:textColor="@color/black"
                        android:textColorHint="@color/gray_500"
                        android:inputType="text"
                        android:imeOptions="actionSearch" />

                    <ImageButton
                        android:id="@+id/buttonClearSearch"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_clear"
                        android:tint="@color/gray_500"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:visibility="gone" />

                </LinearLayout>

            </LinearLayout>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="16dp">

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/buttonRefresh"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="8dp"
                    app:fabSize="mini"
                    app:backgroundTint="@color/primary"
                    android:src="@drawable/ic_refresh"
                    android:contentDescription="تحديث" />

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/buttonToggleMapStyle"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="8dp"
                    app:fabSize="mini"
                    app:backgroundTint="@color/gray_600"
                    android:src="@drawable/ic_map_style"
                    android:contentDescription="تغيير نمط الخريطة" />

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/buttonToggleTraffic"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    app:fabSize="mini"
                    app:backgroundTint="@color/blue_500"
                    android:src="@drawable/ic_traffic"
                    android:contentDescription="عرض حركة المرور" />

            </LinearLayout>

        </LinearLayout>

        <!-- Filters Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:background="@color/white"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="نوع المركبة:"
                android:textColor="@color/gray_600"
                android:textSize="12sp"
                android:layout_marginEnd="8dp" />

            <Spinner
                android:id="@+id/spinnerVehicleType"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:background="@drawable/spinner_background"
                android:entries="@array/vehicle_types"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="الحالة:"
                android:textColor="@color/gray_600"
                android:textSize="12sp"
                android:layout_marginEnd="8dp" />

            <Spinner
                android:id="@+id/spinnerStatus"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:background="@drawable/spinner_background"
                android:entries="@array/vehicle_statuses" />

        </LinearLayout>

        <!-- Map and Info Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <!-- Map Container -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2"
                android:orientation="vertical">

                <fragment
                    android:id="@+id/map"
                    android:name="com.google.android.gms.maps.SupportMapFragment"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <!-- Map Controls -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="8dp"
                    android:background="@color/white"
                    android:gravity="center">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonCenterOnFleet"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="توسيط على الأسطول"
                        android:textSize="12sp"
                        app:backgroundTint="@color/primary"
                        app:cornerRadius="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonShowRoutes"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:text="عرض المسارات"
                        android:textSize="12sp"
                        app:backgroundTint="@color/green_500"
                        app:cornerRadius="4dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Side Panel with Vehicles List -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@color/white"
                android:elevation="2dp">

                <!-- Selected Info Panel -->
                <LinearLayout
                    android:id="@+id/layoutSelectedInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:background="@color/primary"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/textSelectedTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="مركبة: ABC-123"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/textSelectedDriver"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="السائق: أحمد محمد"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:id="@+id/textSelectedStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="الحالة: متحرك"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:id="@+id/textSelectedSpeed"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="السرعة: 65 كم/س"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:id="@+id/textSelectedShipment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="الشحنة: EDHAM-2024-001"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:layout_marginBottom="2dp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/textSelectedETA"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="وقت الوصول: 14:30"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:visibility="gone" />

                </LinearLayout>

                <!-- Vehicles List Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="8dp"
                    android:background="@color/gray_100">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="المركبات"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textVehicleCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 مركبة"
                        android:textColor="@color/gray_600"
                        android:textSize="12sp" />

                </LinearLayout>

                <!-- Vehicles RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerViewVehicles"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:padding="4dp"
                    android:clipToPadding="false"
                    android:scrollbars="vertical" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Error Layout -->
    <LinearLayout
        android:id="@+id/layoutError"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginBottom="16dp"
            android:src="@drawable/ic_error"
            android:tint="@color/red_500" />

        <TextView
            android:id="@+id/textError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="حدث خطأ في تحميل بيانات التتبع"
            android:textColor="@color/red_500"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonRetry"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="إعادة المحاولة"
            android:textColor="@color/white"
            app:backgroundTint="@color/red_500"
            app:cornerRadius="8dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
