<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/html_deep">

    <!-- Header -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/html_card_bg"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/html_card_bg"
            app:title="الإحصائيات المالية"
            app:titleTextColor="@color/html_white"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/html_white" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Finance Statistics Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Monthly Spend Chart -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/html_card_bg"
                app:strokeColor="@color/html_card_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="المصروف الشهري (ر.س)"
                        android:textColor="@color/html_white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <!-- Monthly Spend Bars -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:layout_width="48dp"
                                android:layout_height="wrap_content"
                                android:text="يناير"
                                android:textColor="@color/html_text_muted"
                                android:textSize="12sp" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="24dp"
                                android:layout_weight="0.375"
                                android:background="@color/html_teal_lighter"
                                android:layout_marginStart="8dp" />

                            <TextView
                                android:layout_width="48dp"
                                android:layout_height="wrap_content"
                                android:text="450"
                                android:textColor="@color/html_text_dim"
                                android:textSize="12sp"
                                android:layout_marginStart="8dp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:layout_width="48dp"
                                android:layout_height="wrap_content"
                                android:text="فبراير"
                                android:textColor="@color/html_text_muted"
                                android:textSize="12sp" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="24dp"
                                android:layout_weight="0.517"
                                android:background="@color/html_teal_lighter"
                                android:layout_marginStart="8dp" />

                            <TextView
                                android:layout_width="48dp"
                                android:layout_height="wrap_content"
                                android:text="620"
                                android:textColor="@color/html_text_dim"
                                android:textSize="12sp"
                                android:layout_marginStart="8dp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:layout_width="48dp"
                                android:layout_height="wrap_content"
                                android:text="مارس"
                                android:textColor="@color/html_text_muted"
                                android:textSize="12sp" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="24dp"
                                android:layout_weight="0.425"
                                android:background="@color/html_teal_lighter"
                                android:layout_marginStart="8dp" />

                            <TextView
                                android:layout_width="48dp"
                                android:layout_height="wrap_content"
                                android:text="510"
                                android:textColor="@color/html_text_dim"
                                android:textSize="12sp"
                                android:layout_marginStart="8dp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:layout_width="48dp"
                                android:layout_height="wrap_content"
                                android:text="أبريل"
                                android:textColor="@color/html_text_muted"
                                android:textSize="12sp" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="24dp"
                                android:layout_weight="0.667"
                                android:background="@color/html_teal_lighter"
                                android:layout_marginStart="8dp" />

                            <TextView
                                android:layout_width="48dp"
                                android:layout_height="wrap_content"
                                android:text="800"
                                android:textColor="@color/html_text_dim"
                                android:textSize="12sp"
                                android:layout_marginStart="8dp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="48dp"
                                android:layout_height="wrap_content"
                                android:text="مايو"
                                android:textColor="@color/html_text_muted"
                                android:textSize="12sp" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="24dp"
                                android:layout_weight="1"
                                android:background="@color/html_orange"
                                android:layout_marginStart="8dp" />

                            <TextView
                                android:layout_width="48dp"
                                android:layout_height="wrap_content"
                                android:text="1200"
                                android:textColor="@color/html_orange"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:layout_marginStart="8dp" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Shipment Categories -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/html_card_bg"
                app:strokeColor="@color/html_card_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="فئات الشحنات"
                        android:textColor="@color/html_white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <!-- Express Shipments -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="شحنات سريعة"
                            android:textColor="@color/html_text_muted"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="12"
                            android:textColor="@color/html_teal_lighter"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:background="@drawable/badge_background"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp" />

                    </LinearLayout>

                    <!-- Standard Shipments -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="شحنات عادية"
                            android:textColor="@color/html_text_muted"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="29"
                            android:textColor="@color/html_success"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:background="@drawable/badge_background"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Total Summary -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/html_card_bg"
                app:strokeColor="@color/html_card_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="الملخص الإجمالي"
                        android:textColor="@color/html_white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="إجمالي الشحنات"
                            android:textColor="@color/html_text_dim"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="41"
                            android:textColor="@color/html_text_muted"
                            android:textSize="14sp" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="إجمالي المصروف (5 أشهر)"
                            android:textColor="@color/html_text_dim"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3,580 ر.س"
                            android:textColor="@color/html_teal_lighter"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="متوسط المصروف الشهري"
                            android:textColor="@color/html_text_dim"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="716 ر.س"
                            android:textColor="@color/html_success"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
