<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    style="@style/Widget.Edham.Card.Elevated"
    android:clickable="true"
    android:focusable="true"
    android:foreground="@drawable/ripple_effect"
    tools:context=".shipment.ShipmentCardView">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg">

        <!-- Header Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/spacing_md">

            <!-- Priority and Status Indicators -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginEnd="@dimen/spacing_md">

                <!-- Priority Badge -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/priority_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/spacing_xs"
                    app:cardCornerRadius="4dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/color_warning_100">

                    <TextView
                        android:id="@+id/priority_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HIGH"
                        style="@style/TextAppearance.Edham.LabelSmall"
                        android:textColor="@color/color_warning_700"
                        android:paddingHorizontal="@dimen/spacing_xs"
                        android:paddingVertical="@dimen/spacing_xs"
                        tools:text="HIGH" />

                </com.google.android.material.card.MaterialCardView>

                <!-- Status Indicator -->
                <View
                    android:id="@+id/status_indicator"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/circle_background"
                    android:backgroundTint="@color/color_info_500" />

            </LinearLayout>

            <!-- Shipment ID and Status -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/shipment_id"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SHP-2024-001234"
                    style="@style/TextAppearance.Edham.LabelMedium"
                    android:textColor="@color/text_secondary"
                    android:maxLines="1"
                    android:ellipsize="end"
                    tools:text="SHP-2024-001234" />

                <TextView
                    android:id="@+id/shipment_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="In Transit"
                    style="@style/TextAppearance.Edham.LabelMedium"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    tools:text="In Transit" />

            </LinearLayout>

            <!-- Action Menu -->
            <ImageView
                android:id="@+id/action_menu"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_more_vert"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="@dimen/spacing_xs"
                app:tint="@color/text_tertiary" />

        </LinearLayout>

        <!-- Customer Information -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/spacing_sm"
            android:background="@drawable/rounded_background"
            android:backgroundTint="@color/surface_variant"
            android:padding="@dimen/spacing_sm">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:src="@drawable/ic_customer_small"
                app:tint="@color/text_secondary" />

            <TextView
                android:id="@+id/customer_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ahmed Mohammed Al-Rashid"
                style="@style/TextAppearance.Edham.BodyMedium"
                android:textColor="@color/text_primary"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Ahmed Mohammed Al-Rashid" />

            <ImageView
                android:id="@+id/call_customer"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="@dimen/spacing_sm"
                android:src="@drawable/ic_phone"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="@dimen/spacing_xs"
                app:tint="@color/color_primary_500"
                android:visibility="gone"
                tools:visibility="visible" />

        </LinearLayout>

        <!-- Route Information -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/spacing_sm">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:src="@drawable/ic_route_small"
                app:tint="@color/text_tertiary" />

            <TextView
                android:id="@+id/route_info"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Riyadh → Jeddah → Mecca"
                style="@style/TextAppearance.Edham.BodySmall"
                android:textColor="@color/text_secondary"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Riyadh → Jeddah → Mecca" />

        </LinearLayout>

        <!-- Package Information -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/spacing_sm">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:src="@drawable/ic_package_small"
                app:tint="@color/text_tertiary" />

            <TextView
                android:id="@+id/package_info"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="2.5 kg • Electronics • 3 stops"
                style="@style/TextAppearance.Edham.BodySmall"
                android:textColor="@color/text_secondary"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="2.5 kg • Electronics • 3 stops" />

        </LinearLayout>

        <!-- Special Indicators -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/spacing_md">

            <!-- Cold Chain Indicator -->
            <LinearLayout
                android:id="@+id/cold_chain_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/rounded_background"
                android:backgroundTint="@color/ice_blue_100"
                android:paddingHorizontal="@dimen/spacing_xs"
                android:paddingVertical="@dimen/spacing_xs"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:visibility="gone"
                tools:visibility="visible">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginEnd="@dimen/spacing_xs"
                    android:src="@drawable/ic_snowflake"
                    app:tint="@color/ice_blue_700" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2-8°C"
                    style="@style/TextAppearance.Edham.LabelSmall"
                    android:textColor="@color/ice_blue_700"
                    android:textSize="10sp"
                    tools:text="2-8°C" />

            </LinearLayout>

            <!-- Multi-stop Indicator -->
            <LinearLayout
                android:id="@+id/multi_stop_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/rounded_background"
                android:backgroundTint="@color/purple_100"
                android:paddingHorizontal="@dimen/spacing_xs"
                android:paddingVertical="@dimen/spacing_xs"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:visibility="gone"
                tools:visibility="visible">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginEnd="@dimen/spacing_xs"
                    android:src="@drawable/ic_route"
                    app:tint="@color/purple_700" />

                <TextView
                    android:id="@+id/stop_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3 stops"
                    style="@style/TextAppearance.Edham.LabelSmall"
                    android:textColor="@color/purple_700"
                    android:textSize="10sp"
                    tools:text="3 stops" />

            </LinearLayout>

            <!-- Delayed Indicator -->
            <LinearLayout
                android:id="@+id/delayed_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/rounded_background"
                android:backgroundTint="@color/color_error_100"
                android:paddingHorizontal="@dimen/spacing_xs"
                android:paddingVertical="@dimen/spacing_xs"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:visibility="gone"
                tools:visibility="visible">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginEnd="@dimen/spacing_xs"
                    android:src="@drawable/ic_alert"
                    app:tint="@color/color_error_700" />

                <TextView
                    android:id="@+id/delay_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2h delay"
                    style="@style/TextAppearance.Edham.LabelSmall"
                    android:textColor="@color/color_error_700"
                    android:textSize="10sp"
                    tools:text="2h delay" />

            </LinearLayout>

            <!-- Express Indicator -->
            <LinearLayout
                android:id="@+id/express_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/rounded_background"
                android:backgroundTint="@color/orange_100"
                android:paddingHorizontal="@dimen/spacing_xs"
                android:paddingVertical="@dimen/spacing_xs"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:visibility="gone"
                tools:visibility="visible">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginEnd="@dimen/spacing_xs"
                    android:src="@drawable/ic_flash"
                    app:tint="@color/orange_700" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Express"
                    style="@style/TextAppearance.Edham.LabelSmall"
                    android:textColor="@color/orange_700"
                    android:textSize="10sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Progress Section (for active shipments) -->
        <LinearLayout
            android:id="@+id/progress_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="@dimen/spacing_md"
            android:visibility="gone"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/spacing_xs">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Progress"
                    style="@style/TextAppearance.Edham.LabelSmall"
                    android:textColor="@color/text_secondary"
                    android:layout_marginEnd="@dimen/spacing_sm" />

                <TextView
                    android:id="@+id/progress_percentage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="65%"
                    style="@style/TextAppearance.Edham.LabelSmall"
                    android:textColor="@color/text_tertiary"
                    tools:text="65%" />

            </LinearLayout>

            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:progressTint="@color/color_primary_500"
                android:progress="65"
                tools:progress="65" />

        </LinearLayout>

        <!-- Driver Assignment Section -->
        <LinearLayout
            android:id="@+id/driver_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/rounded_background"
            android:backgroundTint="@color/surface_variant"
            android:padding="@dimen/spacing_sm"
            android:layout_marginBottom="@dimen/spacing_md"
            android:visibility="gone"
            tools:visibility="visible">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:src="@drawable/ic_driver"
                app:tint="@color/text_secondary" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Driver"
                    style="@style/TextAppearance.Edham.LabelSmall"
                    android:textColor="@color/text_tertiary" />

                <TextView
                    android:id="@+id/driver_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mohammed Ali"
                    style="@style/TextAppearance.Edham.LabelMedium"
                    android:textColor="@color/text_primary"
                    tools:text="Mohammed Ali" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/call_driver"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="@dimen/spacing_xs"
                    android:src="@drawable/ic_phone"
                    android:background="@drawable/ripple_background_circle"
                    android:padding="@dimen/spacing_xs"
                    app:tint="@color/color_primary_500" />

                <ImageView
                    android:id="@+id/message_driver"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_message"
                    android:background="@drawable/ripple_background_circle"
                    android:padding="@dimen/spacing_xs"
                    app:tint="@color/color_primary_500" />

            </LinearLayout>

        </LinearLayout>

        <!-- Time and ETA Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Time Information -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginEnd="@dimen/spacing_xs"
                    android:src="@drawable/ic_clock_small"
                    app:tint="@color/text_tertiary" />

                <TextView
                    android:id="@+id/time_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Started 2h ago"
                    style="@style/TextAppearance.Edham.LabelSmall"
                    android:textColor="@color/text_tertiary"
                    tools:text="Started 2h ago" />

            </LinearLayout>

            <!-- ETA (for active shipments) -->
            <LinearLayout
                android:id="@+id/eta_section"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/rounded_background"
                android:backgroundTint="@color/color_success_100"
                android:paddingHorizontal="@dimen/spacing_sm"
                android:paddingVertical="@dimen/spacing_xs"
                android:visibility="gone"
                tools:visibility="visible">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginEnd="@dimen/spacing_xs"
                    android:src="@drawable/ic_clock_small"
                    app:tint="@color/color_success_700" />

                <TextView
                    android:id="@+id/eta_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ETA 3:30 PM"
                    style="@style/TextAppearance.Edham.LabelSmall"
                    android:textColor="@color/color_success_700"
                    android:textSize="10sp"
                    tools:text="ETA 3:30 PM" />

            </LinearLayout>

        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/spacing_md">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/track_button"
                style="@style/Widget.Edham.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:text="Track"
                android:textSize="12sp"
                app:icon="@drawable/ic_location"
                app:iconGravity="textStart" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/details_button"
                style="@style/Widget.Edham.Button.Primary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Details"
                android:textSize="12sp"
                app:icon="@drawable/ic_info"
                app:iconGravity="textStart" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
