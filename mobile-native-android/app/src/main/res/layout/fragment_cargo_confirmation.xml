<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/prem_navy"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="24dp">

    <View
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginTop="40dp"
        android:background="@drawable/emerald_glow_bg"
        android:foreground="@drawable/ic_check"
        android:foregroundGravity="center"
        android:foregroundTint="@color/prem_emerald"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="تم تأكيد طلبك!"
        android:textColor="#FFF"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="رقم الشحنة: #IDH-2024-0892"
        android:textColor="@color/prem_sky"
        android:textSize="14sp"
        android:fontFamily="monospace"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="سيتواصل معك السائق قريباً لتأكيد موعد الاستلام"
        android:textColor="@color/customer_text_muted"
        android:textSize="13sp" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        app:cardCornerRadius="24dp"
        app:cardBackgroundColor="@color/html_card_bg"
        app:strokeWidth="1dp"
        app:strokeColor="@color/customer_blue_border">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="الوقت المتوقع للوصول"
                android:textColor="@color/customer_text_muted"
                android:textSize="12sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="~10 ساعات"
                android:textColor="@color/prem_sky"
                android:textSize="32sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="اليوم - 11:30 م"
                android:textColor="@color/customer_text_muted"
                android:textSize="12sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTrack"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="تتبع الشحنة"
            app:cornerRadius="16dp"
            app:backgroundTint="@color/prem_sky"
            app:icon="@drawable/ic_track"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHome"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="الرئيسية"
            android:textColor="#FFF"
            app:cornerRadius="16dp"
            app:strokeColor="@color/customer_blue_border"/>
    </LinearLayout>

</LinearLayout>
