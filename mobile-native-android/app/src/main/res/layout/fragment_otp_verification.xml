<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".auth.OTPVerificationFragment">

    <!-- Background -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/auth_background"
        android:alpha="0.1" />

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_xl"
            android:gravity="center"
            android:layout_marginTop="@dimen/spacing_xxxl">

            <!-- Icon and Title -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="@dimen/spacing_xxxl">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/ic_otp"
                    android:layout_marginBottom="@dimen/spacing_md" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/otp_verification"
                    style="@style/TextAppearance.Edham.HeadlineSmall"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <TextView
                    android:id="@+id/otp_description"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/otp_description"
                    style="@style/TextAppearance.Edham.BodyMedium"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <TextView
                    android:id="@+id/phone_number_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+966 50 123 4567"
                    style="@style/TextAppearance.Edham.BodyLarge"
                    android:textColor="@color/color_primary_500"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- OTP Input Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.Edham.Card.Elevated"
                android:layout_marginBottom="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_xl">

                    <!-- OTP Code Input -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginBottom="@dimen/spacing_lg">

                        <EditText
                            android:id="@+id/otp_digit_1"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="@dimen/spacing_sm"
                            android:background="@drawable/otp_input_background"
                            android:gravity="center"
                            android:inputType="number"
                            android:maxLength="1"
                            android:textSize="24sp"
                            android:textColor="@color/text_primary"
                            android:textDirection="ltr"
                            android:imeOptions="actionNext" />

                        <EditText
                            android:id="@+id/otp_digit_2"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="@dimen/spacing_sm"
                            android:background="@drawable/otp_input_background"
                            android:gravity="center"
                            android:inputType="number"
                            android:maxLength="1"
                            android:textSize="24sp"
                            android:textColor="@color/text_primary"
                            android:textDirection="ltr"
                            android:imeOptions="actionNext" />

                        <EditText
                            android:id="@+id/otp_digit_3"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="@dimen/spacing_sm"
                            android:background="@drawable/otp_input_background"
                            android:gravity="center"
                            android:inputType="number"
                            android:maxLength="1"
                            android:textSize="24sp"
                            android:textColor="@color/text_primary"
                            android:textDirection="ltr"
                            android:imeOptions="actionNext" />

                        <EditText
                            android:id="@+id/otp_digit_4"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="@dimen/spacing_sm"
                            android:background="@drawable/otp_input_background"
                            android:gravity="center"
                            android:inputType="number"
                            android:maxLength="1"
                            android:textSize="24sp"
                            android:textColor="@color/text_primary"
                            android:textDirection="ltr"
                            android:imeOptions="actionNext" />

                        <EditText
                            android:id="@+id/otp_digit_5"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="@dimen/spacing_sm"
                            android:background="@drawable/otp_input_background"
                            android:gravity="center"
                            android:inputType="number"
                            android:maxLength="1"
                            android:textSize="24sp"
                            android:textColor="@color/text_primary"
                            android:textDirection="ltr"
                            android:imeOptions="actionNext" />

                        <EditText
                            android:id="@+id/otp_digit_6"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="@dimen/spacing_sm"
                            android:background="@drawable/otp_input_background"
                            android:gravity="center"
                            android:inputType="number"
                            android:maxLength="1"
                            android:textSize="24sp"
                            android:textColor="@color/text_primary"
                            android:textDirection="ltr"
                            android:imeOptions="actionDone" />

                    </LinearLayout>

                    <!-- Timer -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginBottom="@dimen/spacing_lg">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/resend_code_in"
                            style="@style/TextAppearance.Edham.BodyMedium"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:id="@+id/timer_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="02:00"
                            style="@style/TextAppearance.Edham.BodyMedium"
                            android:textColor="@color/color_primary_500"
                            android:textStyle="bold"
                            android:layout_marginStart="@dimen/spacing_sm" />

                    </LinearLayout>

                    <!-- Verify Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/verify_button"
                        style="@style/Widget.Edham.Button.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_md"
                        android:text="@string/verify_code" />

                    <!-- Resend Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/resend_button"
                        style="@style/Widget.Edham.Button.Secondary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/resend_code"
                        android:enabled="false" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Help Text -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/otp_help_text"
                    style="@style/TextAppearance.Edham.BodySmall"
                    android:textColor="@color/text_tertiary"
                    android:gravity="center"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <TextView
                    android:id="@+id/contact_support_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/contact_support"
                    style="@style/TextAppearance.Edham.LabelSmall"
                    android:textColor="@color/color_primary_500"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="@dimen/spacing_sm" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Progress Overlay -->
    <LinearLayout
        android:id="@+id/progress_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/overlay_medium"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            app:indicatorColor="@color/color_primary_500"
            app:indicatorSize="48dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/verifying"
            style="@style/TextAppearance.Edham.LabelMedium"
            android:textColor="@color/text_primary"
            android:layout_marginTop="@dimen/spacing_md" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
