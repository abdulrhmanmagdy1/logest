<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/acc_navy">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                style="@style/SupervisorText.Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="إصدار سند قبض"
                android:textSize="22sp" />

            <TextView
                style="@style/SupervisorText.Subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="تسجيل مبالغ محصلة يدوياً في الخزنة" />

            <!-- Voucher Form Card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/AccountantCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="اسم العميل"
                        app:boxStrokeColor="@color/acc_emerald"
                        app:hintTextColor="@color/acc_emerald"
                        app:hintEnabled="true">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etClientName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/acc_text_main"
                            android:background="@color/ed_input_bg"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:hint="المبلغ المحصل (ريال)"
                        app:boxStrokeColor="@color/acc_emerald"
                        app:hintTextColor="@color/acc_emerald">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etAmount"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:textColor="@color/acc_text_main"
                            android:background="@color/ed_input_bg"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        style="@style/SupervisorText.Subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:text="طريقة الدفع"
                        android:textSize="12sp" />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/togglePaymentMethod"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:singleSelection="true"
                        app:selectionRequired="true">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCash"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="كاش"
                            app:strokeColor="@color/acc_border"
                            android:textColor="@color/acc_text_main" />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTransfer"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="تحويل"
                            app:strokeColor="@color/acc_border"
                            android:textColor="@color/acc_text_main" />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCheque"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="شيك"
                            app:strokeColor="@color/acc_border"
                            android:textColor="@color/acc_text_main" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirmVoucher"
                style="@style/SupervisorButton.Primary"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="32dp"
                android:text="تأكيد وحفظ السند ✓"
                android:textSize="16sp"
                app:backgroundTint="@color/acc_emerald"
                android:textColor="@color/acc_navy"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
