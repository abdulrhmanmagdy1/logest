<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/surface_dark"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Vehicle Icon and Status -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="16dp">

            <ImageView
                android:id="@+id/iv_vehicle_icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_truck"
                android:tint="@color/white_60"
                tools:tint="@color/primary_blue" />

            <View
                android:id="@+id/view_health_indicator"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_health_indicator"
                tools:background="@drawable/bg_health_good" />

        </LinearLayout>

        <!-- Vehicle Information -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_vehicle_id"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="VH-2024-001"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:fontFamily="sans-serif-medium"
                    tools:text="VH-2024-001" />

                <TextView
                    android:id="@+id/tv_health_score"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="85%"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_health_score_badge"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    tools:background="@drawable/bg_health_good_badge"
                    tools:textColor="@color/white" />

            </LinearLayout>

            <TextView
                android:id="@+id/tv_vehicle_details"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Toyota Hilux - 2022"
                android:textSize="14sp"
                android:textColor="@color/white_80"
                android:layout_marginTop="2dp"
                android:fontFamily="sans-serif"
                tools:text="Toyota Hilux - 2022" />

            <!-- Health Metrics -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <!-- Fuel Level -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_local_gas_station"
                        android:tint="@color/white_60"
                        android:layout_marginEnd="4dp" />

                    <TextView
                        android:id="@+id/tv_fuel_level"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="75%"
                        android:textSize="12sp"
                        android:textColor="@color/white_80"
                        tools:textColor="@color/green" />

                </LinearLayout>

                <!-- Mileage -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_speed"
                        android:tint="@color/white_60"
                        android:layout_marginEnd="4dp" />

                    <TextView
                        android:id="@+id/tv_mileage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="45,230 كم"
                        android:textSize="12sp"
                        android:textColor="@color/white_80" />

                </LinearLayout>

            </LinearLayout>

            <!-- Health Issues -->
            <LinearLayout
                android:id="@+id/ll_health_issues"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                tools:visibility="visible">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_warning"
                    android:tint="@color/orange"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/tv_health_issues"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="تآكل الإطارات - صيانة قريبة"
                    android:textSize="12sp"
                    android:textColor="@color/orange"
                    android:fontFamily="sans-serif"
                    tools:text="تآكل الإطارات - صيانة قريبة" />

            </LinearLayout>

        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btn_view_details"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_info"
                android:tint="@color/primary_blue"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="عرض التفاصيل" />

            <ImageButton
                android:id="@+id/btn_more_actions"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_more_vert"
                android:tint="@color/white_60"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="المزيد من الإجراءات"
                android:layout_marginTop="8dp" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
