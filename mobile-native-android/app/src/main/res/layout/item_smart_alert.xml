<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="4dp"
    app:cardBackgroundColor="@color/ed_card_bg"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/ed_card_border">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Alert Icon Container -->
        <FrameLayout
            android:id="@+id/iconContainer"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_stat_icon_teal"
            android:layout_marginEnd="12dp">

            <TextView
                android:id="@+id/tvEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="⚠️"
                android:textSize="18sp"/>
        </FrameLayout>

        <!-- Alert Information -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/alertTitle"
                style="@style/SupervisorText.Title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="تأخير - شاحنة T-07"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/alertMessage"
                style="@style/SupervisorText.Subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="تأخر 2 ساعة عن الموعد المحدد في طريق الرياض-الدمام"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/alertTime"
                style="@style/SupervisorText.Subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="منذ 15 دقيقة"
                android:textSize="10sp"
                android:textColor="@color/ed_text_muted" />

        </LinearLayout>

        <!-- Priority/Action -->
        <ImageView
            android:id="@+id/btnAction"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="6dp"
            android:src="@drawable/ic_chevron_left"
            app:tint="@color/ed_text_muted" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
