<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/glass_white"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/cockpit_border">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvExportIcon"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/circle_glow"
            android:backgroundTint="@color/red_dim"
            android:gravity="center"
            android:text="📄"
            android:textSize="18sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvExportTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="تقرير ضريبة القيمة المضافة (VAT)"
                android:textColor="#FFF"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvExportSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="PDF — الربع الثاني 2026"
                android:textColor="@color/customer_text_muted"
                android:textSize="11sp" />
        </LinearLayout>

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_back"
            android:rotation="135"
            app:tint="@color/customer_text_muted" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
