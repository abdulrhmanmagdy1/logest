<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".tracking.ShipmentTimelineFragment">

    <!-- App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/overlay_light"
        app:elevation="4dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Shipment Timeline"
            app:navigationIcon="@drawable/ic_back"
            app:menu="@menu/timeline_menu" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="?attr/actionBarSize"
        android:fillViewport="true"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg">

            <!-- Shipment Overview Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.Edham.Card.Elevated"
                android:layout_marginBottom="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <!-- Shipment Info -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="@dimen/spacing_md">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_marginEnd="@dimen/spacing_md"
                            android:src="@drawable/ic_package"
                            app:tint="@color/color_primary_500" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/shipment_id"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SHP-2024-001234"
                                style="@style/TextAppearance.Edham.LabelMedium"
                                android:textColor="@color/text_secondary" />

                            <TextView
                                android:id="@+id/shipment_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="In Transit"
                                style="@style/TextAppearance.Edham.TitleMedium"
                                android:textColor="@color/text_primary" />

                        </LinearLayout>

                        <!-- Status Badge -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/Widget.Edham.Card.Status"
                            app:cardBackgroundColor="@color/color_info_100">

                            <TextView
                                android:id="@+id/status_badge"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ACTIVE"
                                style="@style/TextAppearance.Edham.LabelSmall"
                                android:textColor="@color/color_info_700"
                                android:paddingHorizontal="@dimen/spacing_sm"
                                android:paddingVertical="@dimen/spacing_xs" />

                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                    <!-- Progress Info -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/spacing_md">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Progress"
                            style="@style/TextAppearance.Edham.LabelMedium"
                            android:textColor="@color/text_secondary"
                            android:layout_marginEnd="@dimen/spacing_md" />

                        <ProgressBar
                            android:id="@+id/shipment_progress"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:progressTint="@color/color_primary_500"
                            android:progress="65" />

                        <TextView
                            android:id="@+id/progress_percentage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="65%"
                            style="@style/TextAppearance.Edham.LabelMedium"
                            android:textColor="@color/text_secondary"
                            android:layout_marginStart="@dimen/spacing_md" />

                    </LinearLayout>

                    <!-- ETA Info -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginEnd="@dimen/spacing_sm"
                            android:src="@drawable/ic_clock"
                            app:tint="@color/text_tertiary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ETA: "
                            style="@style/TextAppearance.Edham.LabelMedium"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:id="@+id/eta_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tomorrow, 2:30 PM"
                            style="@style/TextAppearance.Edham.LabelMedium"
                            android:textColor="@color/text_primary" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Timeline -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/timeline_recycler_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_timeline_event" />

            <!-- Loading Indicator -->
            <LinearLayout
                android:id="@+id/loading_indicator"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="@dimen/spacing_xxxl"
                android:visibility="gone"
                tools:visibility="visible">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:indeterminate="true"
                    app:indicatorColor="@color/color_primary_500"
                    app:indicatorSize="48dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loading timeline..."
                    style="@style/TextAppearance.Edham.LabelMedium"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="@dimen/spacing_md" />

            </LinearLayout>

            <!-- Empty State -->
            <LinearLayout
                android:id="@+id/empty_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="@dimen/spacing_xxxl"
                android:visibility="gone"
                tools:visibility="visible">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_marginBottom="@dimen/spacing_lg"
                    android:src="@drawable/ic_timeline_empty"
                    app:tint="@color/text_tertiary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No Timeline Events"
                    style="@style/TextAppearance.Edham.TitleMedium"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Timeline events will appear here once the shipment is in transit"
                    style="@style/TextAppearance.Edham.BodyMedium"
                    android:textColor="@color/text_tertiary"
                    android:gravity="center"
                    android:layout_marginBottom="@dimen/spacing_lg" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/refresh_button"
                    style="@style/Widget.Edham.Button.Secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Refresh" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Floating Action Button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_refresh"
        style="@style/Widget.Edham.Button.FAB"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="@dimen/spacing_lg"
        app:srcCompat="@drawable/ic_refresh"
        app:tint="@color/text_on_primary" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
