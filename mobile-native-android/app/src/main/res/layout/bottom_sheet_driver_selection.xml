<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:padding="20dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@drawable/drag_handle" />

    <TextView
        style="@style/SupervisorText.Title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="تعيين سائق للمهمة"
        android:layout_marginBottom="8dp"/>

    <TextView
        style="@style/SupervisorText.Subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="اختر السائق الأنسب بناءً على الموقع ونوع الشاحنة"
        android:layout_marginBottom="16dp"/>

    <!-- Filters -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="16dp">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <com.google.android.material.chip.Chip
                android:id="@+id/chipRefrigerated"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="شاحنة تبريد"
                android:layout_marginEnd="8dp"
                app:chipBackgroundColor="@color/ed_teal_15"
                app:chipStrokeColor="@color/ed_teal_light"
                android:textColor="@color/ed_white"
                app:chipIcon="@drawable/ic_snowflake"
                app:chipIconVisible="true"/>
            <com.google.android.material.chip.Chip
                android:id="@+id/chipNearby"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="الأقرب"
                app:chipBackgroundColor="@color/ed_teal_15"
                app:chipStrokeColor="@color/ed_teal_light"
                android:textColor="@color/ed_white"
                app:chipIcon="@drawable/ic_location"
                app:chipIconVisible="true"/>
        </LinearLayout>
    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDrivers"
        android:layout_width="match_parent"
        android:layout_height="400dp"
        tools:listitem="@layout/item_driver_status"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirmAssign"
        style="@style/SupervisorButton.Primary"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="تأكيد التعيين"
        android:layout_marginTop="16dp"
        android:visibility="gone"/>

</LinearLayout>
