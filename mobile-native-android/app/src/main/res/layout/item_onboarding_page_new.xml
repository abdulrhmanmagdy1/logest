<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="@dimen/spacing_xl"
    tools:context=".onboarding.OnboardingFragment">

    <!-- Icon/Image -->
    <ImageView
        android:id="@+id/onboarding_image"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_marginBottom="@dimen/spacing_xxxl"
        android:scaleType="centerInside"
        android:src="@drawable/ic_onboarding_1"
        tools:src="@drawable/ic_onboarding_1" />

    <!-- Title -->
    <TextView
        android:id="@+id/onboarding_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_lg"
        android:gravity="center"
        android:text="@string/onboarding_title_1"
        style="@style/TextAppearance.Edham.HeadlineMedium"
        android:textColor="@color/text_primary"
        tools:text="Welcome to Edham Logistics" />

    <!-- Description -->
    <TextView
        android:id="@+id/onboarding_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_xxxl"
        android:gravity="center"
        android:lineSpacingMultiplier="1.4"
        android:text="@string/onboarding_description_1"
        style="@style/TextAppearance.Edham.BodyLarge"
        android:textColor="@color/text_secondary"
        tools:text="Experience the future of logistics management with our comprehensive platform designed for efficiency and reliability." />

    <!-- Features List -->
    <LinearLayout
        android:id="@+id/features_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="@dimen/spacing_xxxl"
        android:visibility="gone"
        tools:visibility="visible">

        <!-- Feature 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/spacing_md">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="@dimen/spacing_md"
                android:src="@drawable/ic_check_circle"
                app:tint="@color/color_success_500" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/feature_1"
                style="@style/TextAppearance.Edham.BodyMedium"
                android:textColor="@color/text_secondary"
                tools:text="Real-time shipment tracking" />

        </LinearLayout>

        <!-- Feature 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/spacing_md">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="@dimen/spacing_md"
                android:src="@drawable/ic_check_circle"
                app:tint="@color/color_success_500" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/feature_2"
                style="@style/TextAppearance.Edham.BodyMedium"
                android:textColor="@color/text_secondary"
                tools:text="Advanced route optimization" />

        </LinearLayout>

        <!-- Feature 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="@dimen/spacing_md"
                android:src="@drawable/ic_check_circle"
                app:tint="@color/color_success_500" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/feature_3"
                style="@style/TextAppearance.Edham.BodyMedium"
                android:textColor="@color/text_secondary"
                tools:text="Comprehensive analytics dashboard" />

        </LinearLayout>

    </LinearLayout>

    <!-- Call to Action -->
    <LinearLayout
        android:id="@+id/cta_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_lg"
            android:gravity="center"
            android:text="@string/onboarding_cta_text"
            style="@style/TextAppearance.Edham.BodyMedium"
            android:textColor="@color/text_primary"
            tools:text="Ready to transform your logistics operations?" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/cta_button"
            style="@style/Widget.Edham.Button.Primary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/get_started"
            tools:text="Get Started" />

    </LinearLayout>

</LinearLayout>
