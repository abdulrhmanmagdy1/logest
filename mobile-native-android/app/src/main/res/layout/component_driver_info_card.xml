<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.Edham.MaterialCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_card_margin"
    tools:showIn="@layout/fragment_shipment_detail_production">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_card_padding">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/spacing_md">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_profile"
                app:tint="@color/brand_primary"
                android:layout_marginEnd="@dimen/spacing_sm" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/driver_name"
                style="@style/TextAppearance.Edham.LabelMedium" />

        </LinearLayout>

        <!-- Driver Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Driver Avatar -->
            <ImageView
                android:id="@+id/driverAvatar"
                style="@style/Widget.Edham.Avatar"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginEnd="@dimen/spacing_md"
                android:src="@drawable/ic_profile"
                android:background="@drawable/circle_primary_container"
                app:tint="@color/brand_primary" />

            <!-- Driver Details -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/driverName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="سالم محمد"
                    style="@style/TextAppearance.Edham.TitleMedium" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="@dimen/spacing_xs">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_star"
                        app:tint="@color/status_warning"
                        android:layout_marginEnd="@dimen/spacing_xs" />

                    <TextView
                        android:id="@+id/driverRating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4.8 (127 توصيل)"
                        style="@style/TextAppearance.Edham.BodySmall" />

                </LinearLayout>

                <TextView
                    android:id="@+id/driverExperience"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="خبرة 5 سنوات"
                    style="@style/TextAppearance.Edham.BodySmall" />

            </LinearLayout>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Call Button -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnCallDriver"
                    style="@style/Widget.Edham.Chip"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_phone"
                        app:tint="@color/brand_primary" />

                </com.google.android.material.card.MaterialCardView>

                <!-- Message Button -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnMessageDriver"
                    style="@style/Widget.Edham.Chip"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_message"
                        app:tint="@color/brand_primary" />

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>

        <!-- Vehicle Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="@dimen/spacing_md"
            android:padding="@dimen/spacing_sm"
            android:background="@drawable/shape_vehicle_info_bg">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_truck"
                app:tint="@color/text_secondary"
                android:layout_marginEnd="@dimen/spacing_sm" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/vehicleType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="شاحنة صغيرة - 3 طن"
                    style="@style/TextAppearance.Edham.LabelMedium" />

                <TextView
                    android:id="@+id/vehiclePlate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="لوحة: 1234-5678"
                    style="@style/TextAppearance.Edham.BodySmall" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
