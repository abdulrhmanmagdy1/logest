<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/prem_navy"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="تحديد موعد النقل"
            android:textColor="@color/html_white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="اختر ما إذا كنت تريد النقل الآن أو في وقت محدد"
            android:textColor="@color/customer_text_muted"
            android:textSize="13sp" />

        <RadioGroup
            android:id="@+id/rgSchedule"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/html_card_bg"
                app:strokeWidth="1dp"
                app:strokeColor="@color/customer_blue_border">
                <RadioButton
                    android:id="@+id/rbImmediate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="نقل فوري (أسرع وقت)"
                    android:textColor="#FFF"
                    android:checked="true"
                    android:buttonTint="@color/prem_sky"/>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/html_card_bg"
                app:strokeWidth="1dp"
                app:strokeColor="@color/customer_blue_border">
                <RadioButton
                    android:id="@+id/rbScheduled"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="تحديد موعد مسبق"
                    android:textColor="#FFF"
                    android:buttonTint="@color/prem_sky"/>
            </com.google.android.material.card.MaterialCardView>
        </RadioGroup>

        <LinearLayout
            android:id="@+id/scheduledOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="اختر التاريخ"
                app:icon="@drawable/ic_calendar"
                android:textColor="#FFF"
                app:strokeColor="@color/customer_blue_border"
                android:layout_marginBottom="10dp"/>

            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="اختر الساعة"
                app:icon="@drawable/ic_clock"
                android:textColor="#FFF"
                app:strokeColor="@color/customer_blue_border"/>
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
