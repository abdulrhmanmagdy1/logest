<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/divider_color"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- Notification Icon -->
        <LinearLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="12dp"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/iv_notification_icon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_notification_default"
                android:tint="@color/primary_blue"
                tools:tint="@color/orange" />

            <View
                android:id="@+id/view_unread_indicator"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/circle_background"
                android:backgroundTint="@color/orange"
                android:visibility="gone"
                tools:visibility="visible" />

        </LinearLayout>

        <!-- Notification Content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <!-- Category Badge -->
                <TextView
                    android:id="@+id/tv_category"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:text="شحنة"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/rounded_background"
                    android:backgroundTint="@color/primary_blue"
                    tools:backgroundTint="@color/orange" />

                <!-- Priority Badge -->
                <TextView
                    android:id="@+id/tv_priority"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:text="عالي"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/rounded_background"
                    android:backgroundTint="@color/orange"
                    tools:backgroundTint="@color/red" />

                <!-- Timestamp -->
                <TextView
                    android:id="@+id/tv_timestamp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="منذ 5 دقائق"
                    android:textSize="12sp"
                    android:textColor="@color/secondary_text"
                    android:gravity="end"
                    tools:gravity="start" />

            </LinearLayout>

            <!-- Title -->
            <TextView
                android:id="@+id/tv_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="شحنة جديدة تم إنشاؤها"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary_text"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginBottom="4dp" />

            <!-- Message -->
            <TextView
                android:id="@+id/tv_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="تم إنشاء شحنة جديدة برقم #12345 من الرياض إلى جدة"
                android:textSize="14sp"
                android:textColor="@color/secondary_text"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginBottom="8dp" />

            <!-- Action Buttons -->
            <LinearLayout
                android:id="@+id/layout_actions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:visibility="gone">

                <TextView
                    android:id="@+id/btn_mark_read"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:paddingHorizontal="12dp"
                    android:gravity="center"
                    android:text="تحديد كمقروء"
                    android:textSize="12sp"
                    android:textColor="@color/primary_blue"
                    android:background="@drawable/rounded_background"
                    android:backgroundTint="@color/primary_blue_light"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/btn_delete"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:paddingHorizontal="12dp"
                    android:gravity="center"
                    android:text="حذف"
                    android:textSize="12sp"
                    android:textColor="@color/red"
                    android:background="@drawable/rounded_background"
                    android:backgroundTint="@color/red_light" />

            </LinearLayout>

        </LinearLayout>

        <!-- Options Menu -->
        <ImageView
            android:id="@+id/iv_options"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_more_vert"
            android:tint="@color/secondary_text"
            android:padding="4dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="خيارات الإشعار" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
