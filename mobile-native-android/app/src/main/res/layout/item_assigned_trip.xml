<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/textTrackingNumber"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="EDHAM-2024-001"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/textStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="مخصص"
                android:textColor="@color/orange_500"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/status_badge"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp" />

            <TextView
                android:id="@+id/textPriority"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="عادي"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/priority_badge"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp" />

        </LinearLayout>

        <!-- Customer Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/textCustomerName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="محمد أحمد"
                android:textColor="@color/gray_600"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/textCustomerPhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+966501234567"
                android:textColor="@color/gray_500"
                android:textSize="11sp"
                android:drawableStart="@drawable/ic_phone_small"
                android:drawablePadding="4dp" />

        </LinearLayout>

        <!-- Locations -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/textPickupLocation"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="الرياض، شارع الملك"
                android:textColor="@color/gray_500"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:drawableStart="@drawable/ic_pickup_small"
                android:drawablePadding="4dp" />

            <TextView
                android:id="@+id/textDeliveryLocation"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="جدة، شارع الأمير"
                android:textColor="@color/gray_500"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:drawableStart="@drawable/ic_delivery_small"
                android:drawablePadding="4dp" />

        </LinearLayout>

        <!-- Cargo Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/textCargoType"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="بضائع عامة"
                android:textColor="@color/gray_600"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/textWeight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="15.5 كجم"
                android:textColor="@color/gray_600"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/textPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="250.0 ريال"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Special Instructions -->
        <TextView
            android:id="@+id/textSpecialInstructions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="ملاحظات خاصة بالشحنة"
            android:textColor="@color/red_500"
            android:textSize="11sp"
            android:background="@drawable/instructions_background"
            android:padding="4dp"
            android:visibility="gone" />

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonAccept"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:text="قبول"
                android:textColor="@color/white"
                android:textSize="12sp"
                app:backgroundTint="@color/green_500"
                app:cornerRadius="4dp"
                style="@style/Widget.MaterialComponents.Button.TextButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonReject"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:text="رفض"
                android:textColor="@color/white"
                android:textSize="12sp"
                app:backgroundTint="@color/red_500"
                app:cornerRadius="4dp"
                style="@style/Widget.MaterialComponents.Button.TextButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonStart"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:text="بدء"
                android:textColor="@color/white"
                android:textSize="12sp"
                app:backgroundTint="@color/blue_500"
                app:cornerRadius="4dp"
                style="@style/Widget.MaterialComponents.Button.TextButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonNavigation"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:text="الخريطة"
                android:textColor="@color/white"
                android:textSize="12sp"
                app:backgroundTint="@color/primary"
                app:cornerRadius="4dp"
                style="@style/Widget.MaterialComponents.Button.TextButton" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
