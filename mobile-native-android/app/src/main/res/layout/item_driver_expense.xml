<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="10dp"
    android:baselineAligned="false">

    <!-- Icon -->
    <FrameLayout
        android:id="@+id/iconContainer"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_stat_icon_teal"
        android:layout_marginEnd="12dp">
        <TextView
            android:id="@+id/tvIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="⛽"
            android:textSize="16sp"/>
    </FrameLayout>

    <!-- Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">
        <TextView
            android:id="@+id/tvExpenseName"
            style="@style/SupervisorText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="بنزين — محطة وادي النطرون"
            android:textSize="12sp"
            android:textStyle="bold"/>
        <TextView
            android:id="@+id/tvAttachmentStatus"
            style="@style/SupervisorText.Subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="صورة الفاتورة مرفقة ✓"
            android:textSize="9sp"
            android:textColor="@color/ed_success"/>
    </LinearLayout>

    <!-- Amount & Actions -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">
        <TextView
            android:id="@+id/tvAmount"
            style="@style/SupervisorText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="٥٤٠ ج"
            android:textColor="@color/ed_copper"
            android:textStyle="bold"
            android:textSize="13sp"/>

        <LinearLayout
            android:id="@+id/actionGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnApprove"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="اعتماد"
                android:textSize="10sp"
                android:textColor="@color/ed_success"
                android:backgroundTint="@color/ed_success_15"
                android:paddingHorizontal="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="6dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReject"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="6dp"
                android:text="رفض"
                android:textSize="10sp"
                android:textColor="@color/ed_rust"
                android:backgroundTint="@color/ed_rust_15"
                android:paddingHorizontal="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="6dp"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
