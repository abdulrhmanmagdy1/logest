<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ed_deep">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefreshDashboard"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Greeting Section -->
            <TextView
                android:id="@+id/textWelcome"
                style="@style/SupervisorText.Subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="مرحباً بك يا" />

            <TextView
                android:id="@+id/textUserName"
                style="@style/SupervisorText.Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="محمد العبدالله 👋" />

            <!-- Wallet Card (Unified Premium Style) -->
            <com.google.android.material.card.MaterialCardView
                style="@style/SupervisorCard.Teal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_nav_header"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            style="@style/SupervisorText.Subtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="محفظة إدهام"
                            android:textColor="#B3FFFFFF"
                            android:drawableStart="@drawable/ic_wallet"
                            android:drawablePadding="8dp"
                            app:drawableTint="@color/ed_teal_lighter"/>
                    </RelativeLayout>

                    <TextView
                        style="@style/SupervisorText.Subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="رصيدك الحالي"
                        android:textColor="#80FFFFFF" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="bottom">
                        <TextView
                            android:id="@+id/textWalletBalance"
                            style="@style/SupervisorText.StatValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.00"
                            android:textSize="38sp" />
                        <TextView
                            style="@style/SupervisorText.Title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="ريال"
                            android:textColor="@color/ed_teal_lighter" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRecharge"
                            style="@style/SupervisorButton.Primary"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="شحن الرصيد"
                            app:icon="@drawable/ic_add"
                            app:backgroundTint="@color/ed_teal_lighter"/>

                        <com.google.android.material.button.MaterialButton
                            style="@style/SupervisorButton.Outline"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="سحب"
                            android:textColor="#FFF" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Stats Grid -->
            <TextView
                style="@style/SupervisorText.Subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="نشاطك الحالي"
                android:textAllCaps="true"
                android:letterSpacing="0.1"/>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:columnCount="3"
                android:alignmentMode="alignMargins">

                <com.google.android.material.card.MaterialCardView
                    style="@style/SupervisorCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:id="@+id/textPendingCount"
                            style="@style/SupervisorText.StatValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/ed_orange"
                            android:textSize="22sp" />
                        <TextView
                            style="@style/SupervisorText.StatLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="معلقة"
                            android:textSize="9sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/SupervisorCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:id="@+id/textActiveCount"
                            style="@style/SupervisorText.StatValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/ed_teal_lighter"
                            android:textSize="22sp" />
                        <TextView
                            style="@style/SupervisorText.StatLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="في الطريق"
                            android:textSize="9sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/SupervisorCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:id="@+id/textCompletedCount"
                            style="@style/SupervisorText.StatValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/ed_success"
                            android:textSize="22sp" />
                        <TextView
                            style="@style/SupervisorText.StatLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="مكتملة"
                            android:textSize="9sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </GridLayout>

            <!-- Hero Action Button -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnNewCargo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/ed_teal_light">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_gradient"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="20dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            style="@style/SupervisorText.Title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="طلب شحنة جديدة"
                            android:textColor="#FFFFFF" />
                        <TextView
                            style="@style/SupervisorText.Subtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="اختر نوع حمولتك واحجز الآن"
                            android:textColor="#B3FFFFFF" />
                    </LinearLayout>
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_stat_icon_teal"
                        android:padding="12dp"
                        android:src="@drawable/ic_add"
                        app:tint="#FFFFFF" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Activity Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    style="@style/SupervisorText.Title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="آخر الشحنات" />
                <TextView
                    android:id="@+id/btnViewAllShipments"
                    style="@style/SupervisorText.Subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="عرض الكل"
                    android:textColor="@color/ed_teal_lighter"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerViewRecentShipments"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/item_recent_shipment_production" />

                <LinearLayout
                    android:id="@+id/emptyStateDashboard"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:visibility="gone">
                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/ic_empty_box"
                        app:tint="@color/ed_text_muted"
                        android:alpha="0.5"/>
                    <TextView
                        style="@style/SupervisorText.Subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="لا توجد شحنات حالياً" />
                </LinearLayout>
            </FrameLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
