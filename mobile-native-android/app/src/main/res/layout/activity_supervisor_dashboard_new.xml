<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ed_deep"
    tools:context=".ui.home.supervisor.SupervisorDashboardActivity">

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Topbar -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/topbar"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@drawable/ed_topbar_bg"
            android:elevation="4dp">

            <!-- Menu Button -->
            <ImageView
                android:id="@+id/btn_menu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="16dp"
                android:padding="8dp"
                android:src="@drawable/ic_menu"
                android:tint="@color/ed_text_dim"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <!-- Title -->
            <LinearLayout
                android:id="@+id/title_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="16dp"
                android:orientation="vertical"
                app:layout_constraintStart_toEndOf="@id/btn_menu"
                app:layout_constraintEnd_toStartOf="@id/right_actions"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <TextView
                    android:id="@+id/topbar_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="لوحة التحكم"
                    android:textColor="@color/ed_white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif"/>

                <TextView
                    android:id="@+id/topbar_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="نظرة عامة على الأسطول"
                    android:textColor="@color/ed_text_muted"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif"/>
            </LinearLayout>

            <!-- Right Actions -->
            <LinearLayout
                android:id="@+id/right_actions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginEnd="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <!-- Status Badge -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/ed_topbar_pill"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:layout_marginEnd="16dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <View
                        android:id="@+id/status_dot_pulse"
                        android:layout_width="7dp"
                        android:layout_height="7dp"
                        android:background="@drawable/ed_status_dot_pulse"/>

                    <TextView
                        android:id="@+id/label_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="الأسطول نشط"
                        android:textColor="@color/ed_text_dim"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif"/>
                </LinearLayout>

                <!-- Notification -->
                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp">

                    <ImageView
                        android:id="@+id/btn_notification"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:padding="6dp"
                        android:src="@drawable/ic_notifications"
                        android:tint="@color/ed_text_dim"/>

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="4dp"
                        android:layout_marginEnd="4dp"
                        android:background="@drawable/ed_notif_dot"/>
                </FrameLayout>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Fragment Container -->
        <FrameLayout
            android:id="@+id/fragment_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

    </LinearLayout>

    <!-- Sidebar Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="260dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="@drawable/ed_sidebar_bg"
        app:headerLayout="@layout/nav_header_supervisor"
        app:menu="@menu/menu_drawer_supervisor_v2"
        app:itemIconTint="@color/ed_text_dim"
        app:itemTextColor="@color/ed_text_dim"
        app:itemTextAppearance="@style/TextAppearance.Edham.BodyMedium"/>

</androidx.drawerlayout.widget.DrawerLayout>
