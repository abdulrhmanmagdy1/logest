<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cockpit_black">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="إنهاء المهمة"
                android:textColor="#FFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="بعد الوصول، وثّق التسليم بالصورة أو التوقيع"
                android:textColor="@color/customer_text_muted"
                android:textSize="13sp" />

            <!-- POD Photo Upload -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPhotoUpload"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="@color/cockpit_black_2"
                app:strokeWidth="2dp"
                app:strokeColor="@color/cockpit_border"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/ivUploadIcon"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_camera"
                        app:tint="@color/cockpit_green" />

                    <TextView
                        android:id="@+id/tvUploadText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="اضغط لالتقاط صورة الوصل"
                        android:textColor="@color/customer_text_muted"
                        android:textSize="14sp"
                        android:gravity="center"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="(POD - Proof of Delivery)"
                        android:textColor="@color/cockpit_green"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"/>

                    <ImageView
                        android:id="@+id/ivUploadPreview"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:layout_marginTop="16dp"
                        android:scaleType="centerCrop"
                        android:visibility="gone"
                        app:cardCornerRadius="12dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="@color/cockpit_black_2"
                app:strokeWidth="1dp"
                app:strokeColor="@color/cockpit_border">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✍️ توقيع العميل الرقمي"
                        android:textColor="#FFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <com.github.gcacace.signaturepad.views.SignaturePad
                        android:id="@+id/signature_pad"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/ed_card_bg"
                        app:penColor="@color/cockpit_green" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnClearSignature"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="مسح"
                            android:textColor="@color/cockpit_red"
                            app:strokeColor="@color/cockpit_red"
                            app:cornerRadius="10dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSaveSignature"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="حفظ التوقيع ✓"
                            app:backgroundTint="@color/cockpit_green"
                            android:textColor="@color/cockpit_black"
                            app:cornerRadius="10dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="@color/cockpit_black_2"
                app:strokeWidth="1dp"
                app:strokeColor="@color/cockpit_border">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📋 قائمة التحقق النهائية (Elite Checklist)"
                        android:textColor="#FFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <CheckBox
                        android:id="@+id/cbTempCheck"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="تم التأكد من درجة حرارة الحمولة عند الوصول"
                        android:textColor="@color/customer_text_muted"
                        android:buttonTint="@color/cockpit_green"
                        android:textSize="12sp"/>

                    <CheckBox
                        android:id="@+id/cbSealCheck"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="الأختام سليمة ولم يتم فتح الحاوية مسبقاً"
                        android:textColor="@color/customer_text_muted"
                        android:buttonTint="@color/cockpit_green"
                        android:textSize="12sp"/>

                    <CheckBox
                        android:id="@+id/cbQtyCheck"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="عدد الكراتين مطابق تماماً لبيان الشحنة"
                        android:textColor="@color/customer_text_muted"
                        android:buttonTint="@color/cockpit_green"
                        android:textSize="12sp"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCompleteMission"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="40dp"
                android:text="✅ تم الوصول وتسليم الشحنة"
                app:cornerRadius="16dp"
                app:backgroundTint="@color/cockpit_blue"
                android:textColor="@color/cockpit_black"
                android:textStyle="bold"
                app:elevation="8dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
