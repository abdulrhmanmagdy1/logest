<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Header with Vehicle Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textVehicleLicensePlate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ABC-123"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/textDriverName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="أحمد محمد"
                    android:textColor="@color/gray_600"
                    android:textSize="12sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/imageOnlineStatus"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_marginEnd="4dp"
                    android:src="@drawable/ic_online"
                    android:tint="@color/green_500" />

                <TextView
                    android:id="@+id/textOnlineStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="متصل"
                    android:textColor="@color/green_500"
                    android:textSize="10sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Status and Speed -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="متحرك"
                android:textColor="@color/green_500"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/status_badge"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp" />

            <TextView
                android:id="@+id/textSpeed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="65 كم/س"
                android:textColor="@color/blue_500"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Vehicle Type and Last Update -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textVehicleType"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="شاحنة"
                android:textColor="@color/gray_600"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/textLastUpdate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="منذ 5 دقائق"
                android:textColor="@color/gray_500"
                android:textSize="10sp" />

        </LinearLayout>

        <!-- Current Shipment -->
        <LinearLayout
            android:id="@+id/layoutCurrentShipment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="الشحنة:"
                android:textColor="@color/gray_600"
                android:textSize="11sp"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/textCurrentShipment"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="EDHAM-2024-001"
                android:textColor="@color/primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- Battery Level -->
        <LinearLayout
            android:id="@+id/layoutBattery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_battery"
                android:tint="@color/gray_500"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/textBatteryLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="85%"
                android:textColor="@color/gray_600"
                android:textSize="11sp"
                android:layout_marginEnd="8dp" />

            <ProgressBar
                android:id="@+id/progressBattery"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_weight="1"
                android:progress="85"
                android:progressDrawable="@drawable/progress_bar_background"
                style="?android:attr/progressBarStyleHorizontal" />

        </LinearLayout>

        <!-- Fuel Level -->
        <LinearLayout
            android:id="@+id/layoutFuel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_fuel"
                android:tint="@color/gray_500"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/textFuelLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="60%"
                android:textColor="@color/gray_600"
                android:textSize="11sp"
                android:layout_marginEnd="8dp" />

            <ProgressBar
                android:id="@+id/progressFuel"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_weight="1"
                android:progress="60"
                android:progressDrawable="@drawable/progress_bar_background"
                style="?android:attr/progressBarStyleHorizontal" />

        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonCenter"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:text="توسيط"
                android:textColor="@color/white"
                android:textSize="12sp"
                app:backgroundTint="@color/blue_500"
                app:cornerRadius="4dp"
                style="@style/Widget.MaterialComponents.Button.TextButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonDetails"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:text="تفاصيل"
                android:textColor="@color/white"
                android:textSize="12sp"
                app:backgroundTint="@color/gray_600"
                app:cornerRadius="4dp"
                style="@style/Widget.MaterialComponents.Button.TextButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonTrack"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:text="تتبع"
                android:textColor="@color/white"
                android:textSize="12sp"
                app:backgroundTint="@color/green_500"
                app:cornerRadius="4dp"
                style="@style/Widget.MaterialComponents.Button.TextButton" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
