<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/ed_card_bg"
    android:gravity="bottom"
    android:orientation="vertical"
    android:padding="24dp">

    <ImageView
        android:id="@+id/navHeaderIcon"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_circle_brand"
        android:padding="10dp"
        android:src="@drawable/ic_snowflake"
        app:tint="@color/ed_deep" />

    <TextView
        android:id="@+id/navHeaderName"
        style="@style/SupervisorText.Title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="المشرف"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/navHeaderEmail"
        style="@style/SupervisorText.Subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="supervisor@edham.co" />

    <TextView
        android:id="@+id/navHeaderRole"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_role_badge"
        android:paddingHorizontal="10dp"
        android:paddingVertical="2dp"
        android:text="@string/role_supervisor"
        android:textColor="@color/ed_copper"
        android:textSize="11sp"
        android:textStyle="bold"
        android:fontFamily="@string/font_family_arabic_secondary" />

</LinearLayout>
