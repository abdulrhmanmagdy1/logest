# Edham Logistics Backend - Environment Variables Configuration
# Copy this file to .env and update with your actual values

# ================================
# SPRING CONFIGURATION
# ================================
SPRING_PROFILES_ACTIVE=dev

# ================================
# DATABASE CONFIGURATION
# ================================
DATABASE_URL=jdbc:postgresql://localhost:5432/edham_logistics
DATABASE_USERNAME=edham_user
DATABASE_PASSWORD=your_secure_database_password_here

# ================================
# REDIS CONFIGURATION
# ================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_redis_password_here

# ================================
# JWT CONFIGURATION
# ================================
JWT_SECRET=your_super_secret_jwt_key_here_must_be_at_least_256_bits_long
JWT_ACCESS_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=86400000

# ================================
# FILE STORAGE CONFIGURATION
# ================================
STORAGE_TYPE=local
UPLOAD_DIR=./uploads

# For AWS S3 (if using S3)
# STORAGE_TYPE=s3
# AWS_ACCESS_KEY=your_aws_access_key
# AWS_SECRET_KEY=your_aws_secret_key
# AWS_REGION=us-east-1
# S3_BUCKET=edham-logistics-files
# S3_ENDPOINT=https://s3.amazonaws.com

# ================================
# EMAIL CONFIGURATION
# ================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_email_app_password
EMAIL_FROM=noreply@edham-logistics.com

# ================================
# SMS CONFIGURATION
# ================================
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# ================================
# PUSH NOTIFICATION CONFIGURATION
# ================================
FCM_SERVER_KEY=your_firebase_cloud_messaging_server_key

# ================================
# PAYMENT CONFIGURATION
# ================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ================================
# EXTERNAL SERVICES CONFIGURATION
# ================================
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
WEATHER_API_KEY=your_openweathermap_api_key
GEOCODING_API_KEY=your_google_geocoding_api_key

# ================================
# SERVER CONFIGURATION
# ================================
SERVER_PORT=8080

# ================================
# CORS CONFIGURATION
# ================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,https://edham-logistics.com

# ================================
# MONITORING CONFIGURATION
# ================================
# For Grafana (optional)
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123

# For pgAdmin (optional)
PGADMIN_EMAIL=admin@edham-logistics.com
PGADMIN_PASSWORD=admin123

# ================================
# SECURITY CONFIGURATION
# ================================
ENCRYPTION_KEY=your_encryption_key_for_sensitive_data_32_chars

# ================================
# BACKUP CONFIGURATION
# ================================
BACKUP_STORAGE_TYPE=s3
BACKUP_S3_BUCKET=edham-logistics-backups

# ================================
# DEVELOPMENT ONLY
# ================================
# Enable H2 console for development
SPRING_H2_CONSOLE_ENABLED=true

# Enable debug logging
LOGGING_LEVEL_COM_EDHAM_LOGISTICS=DEBUG
