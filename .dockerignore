#
# Docker Ignore - نظام إدهام
# Edham Logistics - Docker Ignore File
# ============================================

# Dependencies
node_modules
npm-debug.log
yarn-error.log

# Environment files
.env
.env.local
.env.*.local

# Logs
logs
*.log

# Testing
coverage
.nyc_output

# Uploads (will be created at runtime)
uploads/*
!uploads/.gitkeep

# Client (built separately)
client/node_modules
client/build

# IDE
.vscode
.idea
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Git
.git
.gitignore

# Documentation (optional - remove if you want docs in image)
*.md

# Misc
README.md
API_STRUCTURE.md
README_BACKEND.md
